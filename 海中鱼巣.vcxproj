  <Target Name="验证D455RealSense构建输入" BeforeTargets="PrepareForBuild"
          Condition="'$(EnableD455RealSense)'=='true' and '$(Platform)'=='x64'">
    <Error Condition="'$(D455VcpkgRoot)'==''" Text="启用 D455 RealSense 时必须通过 VcpkgRoot 或 VCPKG_ROOT 提供 SDK 根目录。" />
    <Error Condition="!Exists('$(D455VcpkgRoot)\installed\x64-windows\include\librealsense2\rs2.hpp')" Text="未找到 RealSense 头文件。" />
    <Error Condition="'$(Configuration)'=='Debug' and !Exists('$(D455VcpkgRoot)\installed\x64-windows\debug\bin\lz4d.dll')" Text="未找到 Debug RealSense 所需的 LZ4 运行库。" />
    <Error Condition="'$(Configuration)'=='Release' and !Exists('$(D455VcpkgRoot)\installed\x64-windows\bin\lz4.dll')" Text="未找到 Release RealSense 所需的 LZ4 运行库。" />
  </Target>
  <Target Name="复制D455RealSense运行库" AfterTargets="Build"
          Condition="'$(EnableD455RealSense)'=='true' and '$(Platform)'=='x64'">
    <Copy Condition="'$(Configuration)'=='Debug'"
          SourceFiles="$(D455VcpkgRoot)\installed\x64-windows\debug\bin\realsense2d.dll;$(D455VcpkgRoot)\installed\x64-windows\debug\bin\lz4d.dll"
          DestinationFolder="$(OutDir)" SkipUnchangedFiles="true" />
    <Copy Condition="'$(Configuration)'=='Release'"
          SourceFiles="$(D455VcpkgRoot)\installed\x64-windows\bin\realsense2.dll;$(D455VcpkgRoot)\installed\x64-windows\bin\lz4.dll"
          DestinationFolder="$(OutDir)" SkipUnchangedFiles="true" />
  </Target>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
  <ImportGroup Label="ExtensionTargets">
  </ImportGroup>
