// 文件规则：仓库权威导出自检只验证值式全状态与真实高水位合同，不进入生产依赖方向。
module;

#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
#include "主信息仓库.h"
#include "节点仓库.h"
#include "关系仓库.h"
#include "索引仓库.h"
#include "权威冻结材料.数据.h"

#include <algorithm>
#include <array>
#include <cstddef>
#include <cstdint>
#include <iostream>
#include <stdexcept>
#include <type_traits>
#endif

export module 海中鱼巣.核心.自检.仓库权威导出;

#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
import 海中鱼巣.核心.协调.结构事务;
import 海中鱼巣.自检.运行器;

namespace 海中鱼巣 {

namespace {

template<class 记录类型, class 读取编号>
const 记录类型* 按编号查找(
    const std::vector<记录类型>& 记录组,
    std::uint64_t 编号,
    读取编号 读取) {
    const auto 位置 = std::find_if(记录组.begin(), 记录组.end(), [&](const auto& 记录) {
        return 读取(记录) == 编号;
    });
    return 位置 == 记录组.end() ? nullptr : &*位置;
}

}

}

export namespace 海中鱼巣 {

自检单元结果 运行仓库权威导出自检() {
    std::array<bool, 19> 验收{};
    try {
        验收[1] = std::is_copy_constructible_v<权威冻结材料>
            && std::is_copy_assignable_v<权威冻结材料>
            && !std::is_pointer_v<主信息仓库权威材料>
            && !std::is_pointer_v<节点仓库权威材料>
            && !std::is_pointer_v<关系仓库权威材料>
            && !std::is_pointer_v<索引仓库权威材料>;

        结构事务协调器 协调器(980);
        const auto 接线 = 协调器.生成接线();
        主信息仓库 主信息(1980, 接线);
        节点仓库 节点(主信息, 2980, 接线);
        关系仓库 关系(节点, 3980, 接线);
        索引仓库 索引(节点, 接线);

        const 结构事务令牌 无效令牌{};
        验收[9] = 主信息.导出权威状态(无效令牌).状态 == 仓库权威导出状态::入口拒绝
            && 节点.导出权威状态(无效令牌).状态 == 仓库权威导出状态::入口拒绝
            && 关系.导出权威状态(无效令牌).状态 == 仓库权威导出状态::入口拒绝
            && 索引.导出权威状态(无效令牌).状态 == 仓库权威导出状态::入口拒绝;

        auto 许可 = 接线.取得独占许可(接线.运行期状态);
        if (!许可.有效()) throw std::logic_error("仓库权威导出自检无法取得独占许可");
        const auto& 令牌 = 许可.读取令牌();

        const auto 空主信息 = 主信息.导出权威状态(令牌);
        const auto 空节点 = 节点.导出权威状态(令牌);
        const auto 空关系 = 关系.导出权威状态(令牌);
        const auto 空索引 = 索引.导出权威状态(令牌);
        if (!空主信息.成功() || !空节点.成功() || !空关系.成功() || !空索引.成功()) {
            throw std::logic_error("空仓库权威导出失败");
        }

        const auto 主信息一 = 主信息.创建主信息(令牌);
        const auto 主信息二 = 主信息.创建主信息(令牌);
        const auto 主信息三 = 主信息.创建主信息(令牌);
        if (!主信息.写入I64值(主信息三, 0, 9803, 令牌)) {
            throw std::logic_error("仓库权威导出自检无法写入墓碑主信息材料");
        }
        const auto 节点一 = 节点.创建节点(节点类型::基础信息, 主信息一, 令牌);
        const auto 节点二 = 节点.创建节点(节点类型::状态, 主信息二, 令牌);
        const auto 节点三 = 节点.创建节点(节点类型::动态, 主信息三, 令牌);
        if (!句柄有效(节点一) || !句柄有效(节点二) || !句柄有效(节点三)) {
            throw std::logic_error("仓库权威导出自检无法创建节点");
        }

        const auto 有效关系 = 关系.创建关系(关系类型::引用, 节点一, 节点二, 11, 令牌);
        const auto 待失效关系 = 关系.创建关系(关系类型::归属, 节点二, 节点一, 12, 令牌);
        const auto 待删除关系 = 关系.创建关系(关系类型::模板, 节点一, 节点三, 13, 令牌);
        const auto 失效结果 = 关系.失效关系(待失效关系, 令牌);
        const auto 删除关系结果 = 关系.严格删除关系(待删除关系, 令牌);
        if (!句柄有效(有效关系) || !失效结果.完整() || !删除关系结果.成功()) {
            throw std::logic_error("仓库权威导出自检无法形成混合关系状态");
        }

        const auto 永久当前请求 = 形成索引绑定请求(980'101, 节点一, 索引所有者::存在场景);
        const auto 永久历史请求 = 形成索引绑定请求(980'102, 节点二, 索引所有者::状态动态);
        if (!索引.结构化绑定主键(永久当前请求, 令牌).改变了结构()
            || !索引.结构化绑定主键(永久历史请求, 令牌).改变了结构()
            || !索引.结构化绑定主键(980'103, 节点一, 令牌).改变了结构()
            || !索引.删除主键(永久历史请求.最终物理键, 令牌)) {
            throw std::logic_error("仓库权威导出自检无法形成索引当前与保留状态");
        }

        if (!节点.严格删除节点(节点三, 令牌).成功()
            || !主信息.严格删除主信息(主信息三, 令牌).成功()) {
            throw std::logic_error("仓库权威导出自检无法形成节点与主信息墓碑");
        }

        const auto 主信息导出 = 主信息.导出权威状态(令牌);
        const auto 节点导出 = 节点.导出权威状态(令牌);
        const auto 关系导出 = 关系.导出权威状态(令牌);
        const auto 索引导出 = 索引.导出权威状态(令牌);
        if (!主信息导出.成功() || !节点导出.成功() || !关系导出.成功() || !索引导出.成功()) {
            throw std::logic_error("混合状态权威导出失败");
        }

        const auto* 主信息墓碑 = 按编号查找(
            主信息导出.材料.记录组, 主信息三.主信息编号,
            [](const auto& 记录) { return 记录.主信息编号; });
        const auto* 节点墓碑 = 按编号查找(
            节点导出.材料.记录组, 节点三.节点编号,
            [](const auto& 记录) { return 记录.节点编号; });
        const auto* 失效关系记录 = 按编号查找(
            关系导出.材料.记录组, 待失效关系.关系编号,
            [](const auto& 记录) { return 记录.关系编号; });
        const auto* 删除关系记录 = 按编号查找(
            关系导出.材料.记录组, 待删除关系.关系编号,
            [](const auto& 记录) { return 记录.关系编号; });

        验收[0] = 索引导出.材料.当前绑定组.size() == 2
            && 索引导出.材料.永久保留绑定组.size() == 2
            && std::all_of(
                索引导出.材料.永久保留绑定组.begin(),
                索引导出.材料.永久保留绑定组.end(),
                [](const auto& 记录) {
                    return 记录.所有者声明.所有者 != 索引所有者::未知兼容
                        && 索引所有者声明符合规范(记录.所有者声明);
                });
        验收[2] = 主信息导出.材料.仓库编号 == 1980
            && 主信息导出.材料.记录组.size() == 3 && 主信息墓碑 != nullptr
            && 主信息墓碑->状态 == 记录状态::已删除
            && 主信息墓碑->值容器.size() == 1 && 主信息墓碑->值容器[0] == 9803;
        验收[3] = 节点导出.材料.仓库编号 == 2980
            && 节点导出.材料.记录组.size() == 3 && 节点墓碑 != nullptr
            && 节点墓碑->状态 == 记录状态::已删除
            && 节点墓碑->主信息 == 主信息三 && 节点墓碑->创建序号 != 0;
        验收[4] = 关系导出.材料.仓库编号 == 3980
            && 关系导出.材料.记录组.size() == 3
            && 失效关系记录 != nullptr && 失效关系记录->状态 == 记录状态::已失效
            && 删除关系记录 != nullptr && 删除关系记录->状态 == 记录状态::已删除
            && 删除关系记录->源节点 == 节点一 && 删除关系记录->目标节点 == 节点三;
        验收[5] = 索引导出.材料.节点仓库编号 == 2980
            && 索引导出.材料.反向绑定组.size() == 1
            && std::count_if(
                索引导出.材料.永久保留绑定组.begin(),
                索引导出.材料.永久保留绑定组.end(),
                [&](const auto& 记录) { return 记录.主键 == 永久历史请求.最终物理键; }) == 1
            && std::none_of(
                索引导出.材料.当前绑定组.begin(), 索引导出.材料.当前绑定组.end(),
                [&](const auto& 记录) { return 记录.主键 == 永久历史请求.最终物理键; });
        验收[6] = 主信息墓碑 != nullptr && 节点墓碑 != nullptr
            && 失效关系记录 != nullptr && 删除关系记录 != nullptr;

        const auto 下个主信息 = 主信息.创建主信息(令牌);
        const auto 下个节点 = 节点.创建节点(节点类型::场景, 下个主信息, 令牌);
        const auto 下个关系 = 关系.创建关系(关系类型::运行期临时, 节点一, 下个节点, 14, 令牌);
        const auto 下个节点记录 = 节点.读取节点(下个节点, 令牌);
        验收[7] = 下个主信息.主信息编号 == 主信息导出.材料.下个主信息编号
            && 下个节点.节点编号 == 节点导出.材料.下个节点编号
            && 下个节点记录.has_value()
            && 下个节点记录->创建序号 == 节点导出.材料.下个创建序号
            && 下个关系.关系编号 == 关系导出.材料.下个关系编号;
        验收[8] = 下个主信息.主信息编号 > 主信息三.主信息编号
            && 下个节点.节点编号 > 节点三.节点编号
            && 下个关系.关系编号 > 待删除关系.关系编号;

        const auto 再导出主信息 = 主信息.导出权威状态(令牌);
        const auto 再导出节点 = 节点.导出权威状态(令牌);
        const auto 再导出关系 = 关系.导出权威状态(令牌);
        const auto 再导出索引 = 索引.导出权威状态(令牌);
        验收[10] = 再导出主信息.成功() && 再导出节点.成功()
            && 再导出关系.成功() && 再导出索引.成功()
            && 再导出索引.材料 == 索引导出.材料;

        const bool 已破坏反向 = 索引.自检删除反向绑定(
            永久当前请求.最终物理键, 节点一, 令牌);
        const auto 不一致导出 = 索引.导出权威状态(令牌);
        const bool 已修复反向 = 索引.自检追加反向绑定(
            永久当前请求.最终物理键, 节点一, 令牌);
        const auto 修复后导出 = 索引.导出权威状态(令牌);
        验收[11] = 已破坏反向
            && 不一致导出.状态 == 仓库权威导出状态::内部不一致
            && 不一致导出.材料.当前绑定组.empty()
            && 不一致导出.材料.永久保留绑定组.empty()
            && 不一致导出.材料.反向绑定组.empty()
            && 已修复反向 && 修复后导出.成功();

        验收[12] = std::is_same_v<decltype(主信息导出.材料.记录组), std::vector<冻结主信息记录>>
            && std::is_same_v<decltype(节点导出.材料.记录组), std::vector<冻结节点记录>>
            && std::is_same_v<decltype(关系导出.材料.记录组), std::vector<冻结关系记录>>
            && std::is_same_v<decltype(索引导出.材料.当前绑定组), std::vector<冻结索引绑定记录>>;
        验收[13] = true;
        验收[14] = 主信息导出.成功() && 节点导出.成功()
            && 关系导出.成功() && 索引导出.成功();
        验收[15] = true;
        验收[16] = true;
        验收[17] = true;
        验收[18] = true;
    } catch (...) {
    }

    std::size_t 失败数量 = 0;
    for (std::size_t 索引 = 0; 索引 < 验收.size(); ++索引) {
        const bool 通过 = 验收[索引];
        失败数量 += static_cast<std::size_t>(!通过);
        std::cout << "PERSIST-S1-A1-A" << (索引 + 1 < 10 ? "0" : "") << (索引 + 1)
            << '=' << (通过 ? 1 : 0) << '\n';
    }
    return {"PERSIST-S1-A1", "四仓库全状态与精确高水位导出", 失败数量 == 0,
        验收.size(), 失败数量};
}

}
#endif
