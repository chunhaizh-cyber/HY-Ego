// 文件规则：仓库统一合同自检只验证四仓库通用生命周期和兼容边界；不得成为生产依赖或业务事实来源。
module;

#include "主信息仓库.h"
#include "节点仓库.h"
#include "关系仓库.h"
#include "索引仓库.h"
#include "结果.结构写入.h"

#include <array>
#include <cstddef>
#include <cstdint>
#include <iostream>
#include <limits>
#include <stdexcept>
#include <type_traits>

export module 海中鱼巣.核心.自检.仓库统一合同;

import 海中鱼巣.核心.协调.结构事务;
import 海中鱼巣.自检.运行器;

export namespace 海中鱼巣 {

自检单元结果 运行仓库统一合同自检() {
    std::array<bool, 14> 验收组{};
    try {
        验收组[0] = static_cast<std::uint32_t>(结构写入状态::已提交) == 1
            && static_cast<std::uint32_t>(结构写入状态::幂等读回) == 2
            && static_cast<std::uint32_t>(结构写入状态::入口拒绝) == 3
            && static_cast<std::uint32_t>(结构写入状态::许可拒绝) == 4
            && static_cast<std::uint32_t>(结构写入状态::版本漂移) == 5
            && static_cast<std::uint32_t>(结构写入状态::候选已撤销) == 6
            && static_cast<std::uint32_t>(结构写入状态::候选已确认) == 7
            && static_cast<std::uint32_t>(结构写入状态::内部不一致) == 8
            && 结构写入结果{结构写入状态::已提交}.成功()
            && !结构写入结果{结构写入状态::许可拒绝}.成功();

        结构事务协调器 协调器(700);
        const auto 接线 = 协调器.生成接线();
        主信息仓库 主信息(1700, 接线);
        节点仓库 节点(主信息, 2700, 接线);
        关系仓库 关系(节点, 3700, 接线);
        索引仓库 索引(节点, 接线);

        {
            auto 许可 = 接线.取得共享许可(接线.运行期状态);
            if (!许可.有效()) throw std::logic_error("仓库统一合同自检无法取得共享许可");
            const auto& 令牌 = 许可.读取令牌();
            const auto 节点数量 = 节点.有效节点数量(令牌);
            const auto 关系数量 = 关系.有效关系数量(令牌);
            const auto 索引数量 = 索引.有效主键数量(令牌);
            const auto 主信息创建 = 主信息.结构化创建主信息未发布候选(令牌);
            const auto 节点创建 = 节点.结构化创建节点未发布候选(节点类型::基础信息, {}, 令牌);
            const auto 关系创建 = 关系.结构化创建关系(关系类型::引用, {}, {}, 0, 令牌);
            const auto 索引绑定 = 索引.结构化绑定主键(700001, {}, 令牌);
            验收组[1] = 主信息创建.操作.状态 == 结构写入状态::许可拒绝
                && 节点创建.操作.状态 == 结构写入状态::许可拒绝
                && 关系创建.操作.状态 == 结构写入状态::许可拒绝
                && 索引绑定.状态 == 结构写入状态::许可拒绝
                && 主信息.严格删除主信息({}, 令牌).状态 == 结构写入状态::许可拒绝
                && 节点.严格删除节点({}, 令牌).状态 == 结构写入状态::许可拒绝
                && 关系.严格删除关系({}, 令牌).状态 == 结构写入状态::许可拒绝
                && 索引.严格删除主键(700001, {}, 令牌).状态 == 结构写入状态::许可拒绝
                && 节点.有效节点数量(令牌) == 节点数量
                && 关系.有效关系数量(令牌) == 关系数量
                && 索引.有效主键数量(令牌) == 索引数量;
        }

        主信息句柄 主信息甲;
        主信息句柄 主信息乙;
        节点句柄 节点甲;
        节点句柄 节点乙;
        关系句柄 关系甲;
        constexpr std::uint64_t 主键甲 = 700101;

        {
            auto 许可 = 接线.取得独占许可(接线.运行期状态);
            if (!许可.有效()) throw std::logic_error("仓库统一合同自检无法取得独占许可");
            const auto& 令牌 = 许可.读取令牌();

            auto 主信息候选甲 = 主信息.结构化创建主信息未发布候选(令牌);
            auto 主信息候选乙 = 主信息.结构化创建主信息未发布候选(令牌);
            if (!主信息候选甲.成功() || !主信息候选乙.成功()) {
                throw std::logic_error("仓库统一合同自检无法创建主信息候选");
            }
            主信息甲 = 主信息候选甲.值->读取主信息();
            主信息乙 = 主信息候选乙.值->读取主信息();
            auto 节点候选甲 = 节点.结构化创建节点未发布候选(
                节点类型::基础信息, 主信息甲, 令牌);
            auto 节点候选乙 = 节点.结构化创建节点未发布候选(
                节点类型::特征, 主信息乙, 令牌);
            if (!节点候选甲.成功() || !节点候选乙.成功()) {
                throw std::logic_error("仓库统一合同自检无法创建节点候选");
            }
            节点甲 = 节点候选甲.值->读取节点();
            节点乙 = 节点候选乙.值->读取节点();
            const auto 主信息记录甲 = 主信息.读取主信息(主信息甲, 令牌);
            const auto 节点记录甲 = 节点.读取节点(节点甲, 令牌);
            const auto 错误主信息 = 主信息句柄{主信息甲.仓库编号, 主信息甲.主信息编号,
                static_cast<std::uint32_t>(主信息甲.版本号 + 1)};
            const auto 节点拒绝前 = 节点.有效节点数量(令牌);
            const auto 错误节点创建 = 节点.结构化创建节点未发布候选(
                节点类型::基础信息, 错误主信息, 令牌);
            验收组[2] = 主信息候选甲.操作.状态 == 结构写入状态::已提交
                && 主信息候选乙.操作.状态 == 结构写入状态::已提交
                && 节点候选甲.操作.状态 == 结构写入状态::已提交
                && 节点候选乙.操作.状态 == 结构写入状态::已提交
                && 主信息记录甲.has_value()
                && 主信息记录甲->状态 == 记录状态::有效
                && 节点记录甲.has_value()
                && 节点记录甲->状态 == 记录状态::有效
                && 节点记录甲->主信息 == 主信息甲
                && 错误节点创建.操作.状态 == 结构写入状态::入口拒绝
                && 节点.有效节点数量(令牌) == 节点拒绝前;

            const auto 确认节点甲 = 节点.结构化确认未发布候选(*节点候选甲.值, 令牌);
            const auto 重复确认节点甲 = 节点.结构化确认未发布候选(*节点候选甲.值, 令牌);
            const auto 确认主信息甲 = 主信息.结构化确认未发布候选(*主信息候选甲.值, 令牌);
            const auto 重复确认主信息甲 = 主信息.结构化确认未发布候选(*主信息候选甲.值, 令牌);
            const auto 确认节点乙 = 节点.结构化确认未发布候选(*节点候选乙.值, 令牌);
            const auto 确认主信息乙 = 主信息.结构化确认未发布候选(*主信息候选乙.值, 令牌);
            验收组[3] = 确认节点甲.状态 == 结构写入状态::已提交
                && 重复确认节点甲.状态 == 结构写入状态::候选已确认
                && 确认主信息甲.状态 == 结构写入状态::已提交
                && 重复确认主信息甲.状态 == 结构写入状态::候选已确认
                && 确认节点乙.状态 == 结构写入状态::已提交
                && 确认主信息乙.状态 == 结构写入状态::已提交
                && 节点.结构化撤销未发布候选(*节点候选甲.值, 令牌).状态
                    == 结构写入状态::候选已确认
                && 主信息.结构化撤销未发布候选(*主信息候选甲.值, 令牌).状态
                    == 结构写入状态::候选已确认;

            const auto 撤销前节点数量 = 节点.有效节点数量(令牌);
            auto 撤销主信息候选 = 主信息.结构化创建主信息未发布候选(令牌);
            auto 撤销节点候选 = 撤销主信息候选.成功()
                ? 节点.结构化创建节点未发布候选(
                    节点类型::基础信息,
                    撤销主信息候选.值->读取主信息(),
                    令牌)
                : 带值结构写入结果<节点未发布候选>{};
            const auto 撤销主信息 = 撤销主信息候选.成功()
                ? 撤销主信息候选.值->读取主信息() : 主信息句柄{};
            const auto 撤销节点 = 撤销节点候选.成功()
                ? 撤销节点候选.值->读取节点() : 节点句柄{};
            const auto 首次撤销节点 = 撤销节点候选.成功()
                ? 节点.结构化撤销未发布候选(*撤销节点候选.值, 令牌) : 结构写入结果{};
            const auto 重复撤销节点 = 撤销节点候选.成功()
                ? 节点.结构化撤销未发布候选(*撤销节点候选.值, 令牌) : 结构写入结果{};
            const auto 首次撤销主信息 = 撤销主信息候选.成功()
                ? 主信息.结构化撤销未发布候选(*撤销主信息候选.值, 令牌) : 结构写入结果{};
            const auto 重复撤销主信息 = 撤销主信息候选.成功()
                ? 主信息.结构化撤销未发布候选(*撤销主信息候选.值, 令牌) : 结构写入结果{};
            验收组[4] = 首次撤销节点.状态 == 结构写入状态::已提交
                && 重复撤销节点.状态 == 结构写入状态::候选已撤销
                && 首次撤销主信息.状态 == 结构写入状态::已提交
                && 重复撤销主信息.状态 == 结构写入状态::候选已撤销
                && 节点.有效节点数量(令牌) == 撤销前节点数量
                && !节点.读取节点审计(撤销节点, 令牌).has_value()
                && !主信息.读取主信息审计(撤销主信息, 令牌).has_value();

            const auto 关系拒绝前 = 关系.有效关系数量(令牌);
            const auto 过期节点乙 = 节点句柄{节点乙.仓库编号, 节点乙.节点编号,
                static_cast<std::uint32_t>(节点乙.版本号 + 1)};
            const auto 错误关系 = 关系.结构化创建关系(
                关系类型::引用, 节点甲, 过期节点乙, 0, 令牌);
            const auto 关系创建 = 关系.结构化创建关系(
                关系类型::引用, 节点甲, 节点乙, 0, 令牌);
            if (!关系创建.成功()) throw std::logic_error("仓库统一合同自检无法创建关系");
            关系甲 = *关系创建.值;
            验收组[5] = 错误关系.操作.状态 == 结构写入状态::入口拒绝
                && 关系创建.操作.状态 == 结构写入状态::已提交
                && 关系.有效关系数量(令牌) == 关系拒绝前 + 1
                && 关系.读取关系(关系甲, 令牌).has_value();

            const auto 首次绑定 = 索引.结构化绑定主键(主键甲, 节点甲, 令牌);
            const auto 重复绑定 = 索引.结构化绑定主键(主键甲, 节点甲, 令牌);
            const auto 冲突绑定 = 索引.结构化绑定主键(主键甲, 节点乙, 令牌);
            验收组[6] = 首次绑定.状态 == 结构写入状态::已提交
                && 重复绑定.状态 == 结构写入状态::幂等读回
                && 冲突绑定.状态 == 结构写入状态::入口拒绝
                && 索引.按主键查节点(主键甲, 令牌) == std::optional<节点句柄>{节点甲}
                && 索引.有效主键数量(令牌) == 1;

            const auto 过期主信息甲 = 主信息句柄{主信息甲.仓库编号, 主信息甲.主信息编号,
                static_cast<std::uint32_t>(主信息甲.版本号 + 5)};
            const auto 过期节点甲 = 节点句柄{节点甲.仓库编号, 节点甲.节点编号,
                static_cast<std::uint32_t>(节点甲.版本号 + 5)};
            const auto 过期关系甲 = 关系句柄{关系甲.仓库编号, 关系甲.关系编号,
                static_cast<std::uint32_t>(关系甲.版本号 + 5)};
            const auto 主信息漂移 = 主信息.严格删除主信息(过期主信息甲, 令牌);
            const auto 节点漂移 = 节点.严格删除节点(过期节点甲, 令牌);
            const auto 关系漂移 = 关系.严格删除关系(过期关系甲, 令牌);
            const auto 索引漂移 = 索引.严格删除主键(主键甲, 过期节点甲, 令牌);
            验收组[10] = 主信息漂移.状态 == 结构写入状态::版本漂移
                && 节点漂移.状态 == 结构写入状态::版本漂移
                && 关系漂移.状态 == 结构写入状态::版本漂移
                && 索引漂移.状态 == 结构写入状态::版本漂移
                && 主信息.读取主信息(主信息甲, 令牌).has_value()
                && 节点.读取节点(节点甲, 令牌).has_value()
                && 关系.读取关系(关系甲, 令牌).has_value()
                && 索引.按主键查节点(主键甲, 令牌) == std::optional<节点句柄>{节点甲};

            const auto 回滚前节点 = 节点.有效节点数量(令牌);
            const auto 回滚前关系 = 关系.有效关系数量(令牌);
            const auto 回滚前索引 = 索引.有效主键数量(令牌);
            auto 回滚主信息候选 = 主信息.结构化创建主信息未发布候选(令牌);
            auto 回滚节点候选 = 回滚主信息候选.成功()
                ? 节点.结构化创建节点未发布候选(
                    节点类型::存在,
                    回滚主信息候选.值->读取主信息(),
                    令牌)
                : 带值结构写入结果<节点未发布候选>{};
            const auto 回滚主信息 = 回滚主信息候选.成功()
                ? 回滚主信息候选.值->读取主信息() : 主信息句柄{};
            const auto 回滚节点 = 回滚节点候选.成功()
                ? 回滚节点候选.值->读取节点() : 节点句柄{};
            auto 回滚关系 = 回滚节点候选.成功()
                ? 关系.结构化创建关系(关系类型::引用, 回滚节点, 节点乙, 0, 令牌)
                : 带值结构写入结果<关系句柄>{};
            constexpr std::uint64_t 回滚主键 = 700102;
            const auto 回滚索引 = 回滚节点候选.成功()
                ? 索引.结构化绑定主键(回滚主键, 回滚节点, 令牌) : 结构写入结果{};
            const auto 删除回滚索引 = 索引.严格删除主键(回滚主键, 回滚节点, 令牌);
            const auto 删除回滚关系 = 回滚关系.成功()
                ? 关系.严格删除关系(*回滚关系.值, 令牌) : 结构写入结果{};
            const auto 撤销回滚节点 = 回滚节点候选.成功()
                ? 节点.结构化撤销未发布候选(*回滚节点候选.值, 令牌) : 结构写入结果{};
            const auto 撤销回滚主信息 = 回滚主信息候选.成功()
                ? 主信息.结构化撤销未发布候选(*回滚主信息候选.值, 令牌) : 结构写入结果{};
            验收组[12] = 回滚主信息候选.成功()
                && 回滚节点候选.成功()
                && 回滚关系.成功()
                && 回滚索引.状态 == 结构写入状态::已提交
                && 删除回滚索引.状态 == 结构写入状态::已提交
                && 删除回滚关系.状态 == 结构写入状态::已提交
                && 撤销回滚节点.状态 == 结构写入状态::已提交
                && 撤销回滚主信息.状态 == 结构写入状态::已提交
                && 节点.有效节点数量(令牌) == 回滚前节点
                && 关系.有效关系数量(令牌) == 回滚前关系
                && 索引.有效主键数量(令牌) == 回滚前索引
                && !节点.读取节点审计(回滚节点, 令牌).has_value()
                && !主信息.读取主信息审计(回滚主信息, 令牌).has_value();
        }

        主信息句柄 兼容主信息甲;
        主信息句柄 兼容主信息乙;
        节点句柄 兼容节点甲;
        节点句柄 兼容节点乙;
        {
            auto 许可 = 接线.取得共享许可(接线.运行期状态);
            if (!许可.有效()) throw std::logic_error("仓库统一合同兼容自检无法取得共享许可");
            const auto& 令牌 = 许可.读取令牌();
            const auto 拒绝索引 = 索引.严格删除主键(主键甲, 节点甲, 令牌);
            const auto 拒绝关系 = 关系.严格删除关系(关系甲, 令牌);
            const auto 拒绝节点 = 节点.严格删除节点(节点甲, 令牌);
            const auto 拒绝主信息 = 主信息.严格删除主信息(主信息甲, 令牌);
            验收组[7] = 拒绝索引.状态 == 结构写入状态::许可拒绝
                && 拒绝关系.状态 == 结构写入状态::许可拒绝
                && 拒绝节点.状态 == 结构写入状态::许可拒绝
                && 拒绝主信息.状态 == 结构写入状态::许可拒绝
                && 索引.按主键查节点(主键甲, 令牌) == std::optional<节点句柄>{节点甲}
                && 关系.读取关系(关系甲, 令牌).has_value()
                && 节点.读取节点(节点甲, 令牌).has_value()
                && 主信息.读取主信息(主信息甲, 令牌).has_value();

            兼容主信息甲 = 主信息.创建主信息(令牌);
            兼容主信息乙 = 主信息.创建主信息(令牌);
            兼容节点甲 = 节点.创建节点(节点类型::基础信息, 兼容主信息甲, 令牌);
            兼容节点乙 = 节点.创建节点(节点类型::特征, 兼容主信息乙, 令牌);
            const auto 兼容关系 = 关系.创建关系(
                关系类型::引用, 兼容节点甲, 兼容节点乙, 0, 令牌);
            constexpr std::uint64_t 兼容主键 = 700201;
            const bool 兼容绑定 = 索引.绑定主键(兼容主键, 兼容节点甲, 令牌);
            验收组[11] = 句柄有效(兼容关系)
                && 兼容绑定
                && 关系.删除关系(兼容关系, 令牌)
                && 索引.删除主键(兼容主键, 令牌)
                && !关系.读取关系(兼容关系, 令牌).has_value()
                && !索引.按主键查节点(兼容主键, 令牌).has_value();
        }

        {
            auto 许可 = 接线.取得独占许可(接线.运行期状态);
            if (!许可.有效()) throw std::logic_error("仓库统一合同删除自检无法取得独占许可");
            const auto& 令牌 = 许可.读取令牌();
            const auto 删除索引 = 索引.严格删除主键(主键甲, 节点甲, 令牌);
            const auto 重复删除索引 = 索引.严格删除主键(主键甲, 节点甲, 令牌);
            const auto 删除关系 = 关系.严格删除关系(关系甲, 令牌);
            const auto 重复删除关系 = 关系.严格删除关系(关系甲, 令牌);
            验收组[8] = 删除索引.状态 == 结构写入状态::已提交
                && 重复删除索引.状态 == 结构写入状态::幂等读回
                && 删除关系.状态 == 结构写入状态::已提交
                && 重复删除关系.状态 == 结构写入状态::幂等读回
                && !索引.按主键查节点(主键甲, 令牌).has_value()
                && !关系.读取关系(关系甲, 令牌).has_value();

            const auto 删除节点甲 = 节点.严格删除节点(节点甲, 令牌);
            const auto 删除节点乙 = 节点.严格删除节点(节点乙, 令牌);
            const auto 重复删除节点甲 = 节点.严格删除节点(节点甲, 令牌);
            const auto 删除主信息甲 = 主信息.严格删除主信息(主信息甲, 令牌);
            const auto 删除主信息乙 = 主信息.严格删除主信息(主信息乙, 令牌);
            const auto 重复删除主信息甲 = 主信息.严格删除主信息(主信息甲, 令牌);
            验收组[9] = 删除节点甲.状态 == 结构写入状态::已提交
                && 删除节点乙.状态 == 结构写入状态::已提交
                && 重复删除节点甲.状态 == 结构写入状态::幂等读回
                && 删除主信息甲.状态 == 结构写入状态::已提交
                && 删除主信息乙.状态 == 结构写入状态::已提交
                && 重复删除主信息甲.状态 == 结构写入状态::幂等读回
                && !节点.读取节点(节点甲, 令牌).has_value()
                && !主信息.读取主信息(主信息甲, 令牌).has_value();

            const bool 兼容清理 = 节点.删除节点(兼容节点甲, 令牌)
                && 节点.删除节点(兼容节点乙, 令牌)
                && 主信息.删除主信息(兼容主信息甲, 令牌)
                && 主信息.删除主信息(兼容主信息乙, 令牌);
            if (!兼容清理) throw std::logic_error("仓库统一合同兼容材料清理失败");
        }

        using 旧关系删除签名 = bool (关系仓库::*)(关系句柄, const 结构事务令牌&);
        using 新关系删除签名 = 结构写入结果 (关系仓库::*)(关系句柄, const 结构事务令牌&);
        using 旧索引删除签名 = bool (索引仓库::*)(std::uint64_t, const 结构事务令牌&);
        using 新索引删除签名 = 结构写入结果 (索引仓库::*)(
            std::uint64_t, 节点句柄, const 结构事务令牌&);
        const auto 旧关系删除 = static_cast<旧关系删除签名>(&关系仓库::删除关系);
        const auto 新关系删除 = static_cast<新关系删除签名>(&关系仓库::严格删除关系);
        const auto 旧索引删除 = static_cast<旧索引删除签名>(&索引仓库::删除主键);
        const auto 新索引删除 = static_cast<新索引删除签名>(&索引仓库::严格删除主键);
        验收组[13] = !std::is_default_constructible_v<主信息未发布候选>
            && !std::is_copy_constructible_v<主信息未发布候选>
            && std::is_move_constructible_v<主信息未发布候选>
            && !std::is_default_constructible_v<节点未发布候选>
            && !std::is_copy_constructible_v<节点未发布候选>
            && std::is_move_constructible_v<节点未发布候选>
            && std::is_standard_layout_v<结构写入结果>
            && 旧关系删除 != nullptr
            && 新关系删除 != nullptr
            && 旧索引删除 != nullptr
            && 新索引删除 != nullptr;
    }
    catch (...) {
    }

    constexpr std::array<const char*, 14> 名称组{
        "统一结构写入状态数值与成功语义",
        "共享许可拒绝四仓库新写入且结构不变",
        "独占候选创建依赖与有效记录读回",
        "候选确认幂等且确认后拒绝撤销",
        "候选精确撤销幂等且无残留",
        "关系端点拒绝与独占创建读回",
        "索引绑定幂等、冲突拒绝与候选读回",
        "严格普通删除拒绝共享许可且结构不变",
        "关系索引严格删除与幂等读回",
        "节点主信息严格删除与版本推进",
        "四仓库版本漂移拒绝且结构不变",
        "关系索引旧共享删除兼容语义不变",
        "关系索引后逆序撤销身份候选回前态",
        "候选能力不可伪造且新旧删除签名并存"
    };
    std::size_t 失败数量 = 0;
    for (std::size_t 索引值 = 0; 索引值 < 验收组.size(); ++索引值) {
        if (!验收组[索引值]) ++失败数量;
        std::cout << "CORE-LAYER-S1-A" << (索引值 + 1 < 10 ? "0" : "") << 索引值 + 1
            << ' ' << 名称组[索引值] << ": " << (验收组[索引值] ? "通过" : "失败") << '\n';
    }
    return {"CORE-LAYER-S1", "四仓库统一生命周期合同", 失败数量 == 0, 验收组.size(), 失败数量};
}

}
