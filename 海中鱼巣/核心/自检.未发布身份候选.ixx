// 文件规则：未发布身份候选自检只验证核心候选能力与权限边界，不得成为生产依赖或业务事实来源。
module;

#include "主信息仓库.h"
#include "节点仓库.h"
#include "关系仓库.h"

#include <array>
#include <atomic>
#include <cstddef>
#include <stdexcept>
#include <thread>
#include <type_traits>
#include <utility>

export module 海中鱼巣.核心.自检.未发布身份候选;

import 海中鱼巣.核心.协调.结构事务;
import 海中鱼巣.自检.运行器;

export namespace 海中鱼巣 {

自检单元结果 运行未发布身份候选自检() {
    std::array<bool, 12> 验收组{};
    try {
        结构事务协调器 协调器(585);
        const auto 接线 = 协调器.生成接线();
        主信息仓库 主信息(1585, 接线);
        节点仓库 节点(主信息, 2585, 接线);
        关系仓库 关系(节点, 3585, 接线);

        节点句柄 已确认节点;
        主信息句柄 已确认主信息;
        std::optional<节点未发布候选> 跨许可节点候选;
        std::optional<主信息未发布候选> 跨许可主信息候选;
        std::uint64_t 原许可序号 = 0;
        {
            auto 许可 = 接线.取得共享许可(接线.运行期状态);
            if (!许可.有效()) throw std::logic_error("未发布身份候选自检无法取得共享许可");
            const auto& 令牌 = 许可.读取令牌();

            auto 主信息候选 = 主信息.创建主信息未发布候选(令牌);
            const auto 候选主信息 = 主信息候选 ? 主信息候选->读取主信息() : 主信息句柄{};
            验收组[0] = 主信息候选 && 主信息候选->完整()
                && 主信息.撤销未发布候选(*主信息候选, 令牌) == 核心未发布候选操作状态::已完成
                && !主信息.读取主信息(候选主信息, 令牌).has_value()
                && !主信息.读取主信息审计(候选主信息, 令牌).has_value();

            const auto 撤销前节点数量 = 节点.有效节点数量(令牌);
            auto 组合主信息候选 = 主信息.创建主信息未发布候选(令牌);
            auto 组合节点候选 = 组合主信息候选
                ? 节点.创建节点未发布候选(
                    节点类型::基础信息,
                    组合主信息候选->读取主信息(),
                    令牌)
                : std::nullopt;
            const auto 组合主信息 = 组合主信息候选 ? 组合主信息候选->读取主信息() : 主信息句柄{};
            const auto 组合节点 = 组合节点候选 ? 组合节点候选->读取节点() : 节点句柄{};
            验收组[1] = 组合主信息候选 && 组合节点候选
                && 节点.撤销未发布候选(*组合节点候选, 令牌) == 核心未发布候选操作状态::已完成
                && 主信息.撤销未发布候选(*组合主信息候选, 令牌) == 核心未发布候选操作状态::已完成
                && 节点.有效节点数量(令牌) == 撤销前节点数量
                && !节点.读取节点审计(组合节点, 令牌).has_value()
                && !主信息.读取主信息审计(组合主信息, 令牌).has_value();

            auto 撤销主信息候选 = 主信息.创建主信息未发布候选(令牌);
            auto 撤销节点候选 = 撤销主信息候选
                ? 节点.创建节点未发布候选(
                    节点类型::基础信息,
                    撤销主信息候选->读取主信息(),
                    令牌)
                : std::nullopt;
            const auto 撤销主信息 = 撤销主信息候选 ? 撤销主信息候选->读取主信息() : 主信息句柄{};
            const auto 撤销节点 = 撤销节点候选 ? 撤销节点候选->读取节点() : 节点句柄{};
            验收组[2] = 撤销主信息候选 && 撤销节点候选
                && 节点.确认未发布候选(*撤销节点候选, 令牌) == 核心未发布候选操作状态::已完成
                && 主信息.确认未发布候选(*撤销主信息候选, 令牌) == 核心未发布候选操作状态::已完成
                && 节点.撤销未发布候选(*撤销节点候选, 令牌) == 核心未发布候选操作状态::已完成
                && 主信息.撤销未发布候选(*撤销主信息候选, 令牌) == 核心未发布候选操作状态::已完成
                && !节点.读取节点(撤销节点, 令牌).has_value()
                && !主信息.读取主信息(撤销主信息, 令牌).has_value();

            auto 保留主信息候选 = 主信息.创建主信息未发布候选(令牌);
            auto 保留节点候选 = 保留主信息候选
                ? 节点.创建节点未发布候选(
                    节点类型::基础信息,
                    保留主信息候选->读取主信息(),
                    令牌)
                : std::nullopt;
            已确认主信息 = 保留主信息候选 ? 保留主信息候选->读取主信息() : 主信息句柄{};
            已确认节点 = 保留节点候选 ? 保留节点候选->读取节点() : 节点句柄{};
            const bool 保留确认完成 = 保留主信息候选 && 保留节点候选
                && 节点.确认未发布候选(*保留节点候选, 令牌) == 核心未发布候选操作状态::已完成
                && 主信息.确认未发布候选(*保留主信息候选, 令牌) == 核心未发布候选操作状态::已完成;
            if (保留确认完成) {
                原许可序号 = 令牌.许可序号;
                跨许可节点候选.emplace(std::move(*保留节点候选));
                跨许可主信息候选.emplace(std::move(*保留主信息候选));
            }
            验收组[2] = 验收组[2] && 保留确认完成
                && 跨许可节点候选 && 跨许可主信息候选;

            验收组[3] = !节点.删除节点(已确认节点, 令牌)
                && !主信息.删除主信息(已确认主信息, 令牌)
                && 节点.读取节点(已确认节点, 令牌).has_value()
                && 主信息.读取主信息(已确认主信息, 令牌).has_value();

            auto 幂等候选 = 主信息.创建主信息未发布候选(令牌);
            const auto 幂等主信息 = 幂等候选 ? 幂等候选->读取主信息() : 主信息句柄{};
            验收组[6] = 幂等候选
                && 主信息.撤销未发布候选(*幂等候选, 令牌) == 核心未发布候选操作状态::已完成
                && 主信息.撤销未发布候选(*幂等候选, 令牌) == 核心未发布候选操作状态::幂等已撤销
                && !主信息.读取主信息审计(幂等主信息, 令牌).has_value();

            auto 移动来源 = 主信息.创建主信息未发布候选(令牌);
            if (移动来源) {
                主信息未发布候选 移动目标(std::move(*移动来源));
                验收组[8] = !移动来源->完整() && 移动目标.完整()
                    && 主信息.撤销未发布候选(移动目标, 令牌) == 核心未发布候选操作状态::已完成;
            }
            验收组[8] = 验收组[8]
                && !std::is_default_constructible_v<主信息未发布候选>
                && !std::is_copy_constructible_v<主信息未发布候选>
                && std::is_move_constructible_v<主信息未发布候选>
                && !std::is_move_assignable_v<主信息未发布候选>
                && !std::is_default_constructible_v<节点未发布候选>
                && !std::is_copy_constructible_v<节点未发布候选>
                && std::is_move_constructible_v<节点未发布候选>
                && !std::is_move_assignable_v<节点未发布候选>;

            auto 嵌套许可 = 接线.取得共享许可(接线.运行期状态);
            验收组[9] = !嵌套许可.有效() && !句柄有效(主信息.创建主信息())
                && 接线.验证共享路径令牌(接线.运行期状态, 令牌);
        }

        {
            auto 后继许可 = 接线.取得共享许可(接线.运行期状态);
            if (!后继许可.有效()) throw std::logic_error("未发布身份候选跨许可拒绝自检无法取得共享许可");
            const auto& 后继令牌 = 后继许可.读取令牌();
            const auto 撤销前节点 = 节点.读取节点(已确认节点, 后继令牌);
            const auto 撤销前主信息 = 主信息.读取主信息(已确认主信息, 后继令牌);
            const auto 节点撤销结果 = 跨许可节点候选
                ? 节点.撤销未发布候选(*跨许可节点候选, 后继令牌)
                : 核心未发布候选操作状态::已拒绝;
            const auto 主信息撤销结果 = 跨许可主信息候选
                ? 主信息.撤销未发布候选(*跨许可主信息候选, 后继令牌)
                : 核心未发布候选操作状态::已拒绝;
            const auto 撤销后节点 = 节点.读取节点(已确认节点, 后继令牌);
            const auto 撤销后主信息 = 主信息.读取主信息(已确认主信息, 后继令牌);
            const bool 节点记录不变 = 撤销前节点 && 撤销后节点
                && 撤销前节点->节点编号 == 撤销后节点->节点编号
                && 撤销前节点->类型 == 撤销后节点->类型
                && 撤销前节点->主信息 == 撤销后节点->主信息
                && 撤销前节点->版本号 == 撤销后节点->版本号
                && 撤销前节点->状态 == 撤销后节点->状态
                && 撤销前节点->创建序号 == 撤销后节点->创建序号;
            const bool 主信息记录不变 = 撤销前主信息 && 撤销后主信息
                && 撤销前主信息->主信息编号 == 撤销后主信息->主信息编号
                && 撤销前主信息->版本号 == 撤销后主信息->版本号
                && 撤销前主信息->状态 == 撤销后主信息->状态
                && 撤销前主信息->拓扑锚点编号 == 撤销后主信息->拓扑锚点编号
                && 撤销前主信息->值容器 == 撤销后主信息->值容器;
            验收组[2] = 验收组[2]
                && 后继令牌.许可序号 != 原许可序号
                && 节点撤销结果 == 核心未发布候选操作状态::已拒绝
                && 主信息撤销结果 == 核心未发布候选操作状态::已拒绝
                && 节点记录不变 && 主信息记录不变;
        }

        {
            auto 独占许可 = 接线.取得独占许可(接线.运行期状态);
            验收组[4] = 独占许可.有效()
                && 节点.删除节点(已确认节点, 独占许可.读取令牌())
                && 主信息.删除主信息(已确认主信息, 独占许可.读取令牌())
                && !节点.读取节点(已确认节点, 独占许可.读取令牌()).has_value()
                && !主信息.读取主信息(已确认主信息, 独占许可.读取令牌()).has_value();
        }

        主信息仓库 其它主信息(1586, 接线);
        节点仓库 其它节点(主信息, 2586, 接线);
        std::optional<主信息未发布候选> 过期候选;
        主信息句柄 过期主信息;
        结构事务令牌 过期令牌;
        bool 当前令牌拒绝完整 = false;
        {
            auto 许可 = 接线.取得共享许可(接线.运行期状态);
            if (!许可.有效()) throw std::logic_error("未发布身份候选令牌拒绝自检无法取得共享许可");
            const auto& 令牌 = 许可.读取令牌();
            auto 主候选 = 主信息.创建主信息未发布候选(令牌);
            auto 节候选 = 主候选
                ? 节点.创建节点未发布候选(节点类型::基础信息, 主候选->读取主信息(), 令牌)
                : std::nullopt;
            const auto 伪造令牌 = 结构事务令牌{
                令牌.域编号,
                令牌.运行期纪元,
                令牌.许可序号 + 100,
                令牌.类型};
            const auto 错域令牌 = 结构事务令牌{
                令牌.域编号 + 1,
                令牌.运行期纪元,
                令牌.许可序号,
                令牌.类型};
            const auto 错纪元令牌 = 结构事务令牌{
                令牌.域编号,
                令牌.运行期纪元 + 1,
                令牌.许可序号,
                令牌.类型};
            std::atomic<bool> 跨线程拒绝 = false;
            if (节候选) {
                std::thread 其它线程([&] {
                    跨线程拒绝.store(
                        节点.撤销未发布候选(*节候选, 令牌) == 核心未发布候选操作状态::已拒绝);
                });
                其它线程.join();
            }
            当前令牌拒绝完整 = 主候选 && 节候选
                && 其它主信息.撤销未发布候选(*主候选, 令牌) == 核心未发布候选操作状态::已拒绝
                && 其它节点.撤销未发布候选(*节候选, 令牌) == 核心未发布候选操作状态::已拒绝
                && 主信息.撤销未发布候选(*主候选, 伪造令牌) == 核心未发布候选操作状态::已拒绝
                && 主信息.撤销未发布候选(*主候选, 错域令牌) == 核心未发布候选操作状态::已拒绝
                && 主信息.撤销未发布候选(*主候选, 错纪元令牌) == 核心未发布候选操作状态::已拒绝
                && 跨线程拒绝.load()
                && 节点.撤销未发布候选(*节候选, 令牌) == 核心未发布候选操作状态::已完成
                && 主信息.撤销未发布候选(*主候选, 令牌) == 核心未发布候选操作状态::已完成;

            auto 新过期候选 = 主信息.创建主信息未发布候选(令牌);
            if (新过期候选) {
                过期主信息 = 新过期候选->读取主信息();
                过期令牌 = 令牌;
                过期候选.emplace(std::move(*新过期候选));
            }
        }
        const bool 过期拒绝 = 过期候选
            && 主信息.撤销未发布候选(*过期候选, 过期令牌) == 核心未发布候选操作状态::已拒绝;
        bool 过期材料已清理 = false;
        {
            auto 独占许可 = 接线.取得独占许可(接线.运行期状态);
            过期材料已清理 = 独占许可.有效()
                && 主信息.删除主信息(过期主信息, 独占许可.读取令牌());
        }
        验收组[5] = 当前令牌拒绝完整 && 过期拒绝 && 过期材料已清理;

        节点句柄 组合目标节点;
        主信息句柄 组合目标主信息;
        {
            auto 许可 = 接线.取得共享许可(接线.运行期状态);
            if (!许可.有效()) throw std::logic_error("未发布身份候选组合顺序自检无法取得共享许可");
            const auto& 令牌 = 许可.读取令牌();
            auto 主候选 = 主信息.创建主信息未发布候选(令牌);
            auto 节候选 = 主候选
                ? 节点.创建节点未发布候选(节点类型::基础信息, 主候选->读取主信息(), 令牌)
                : std::nullopt;
            组合目标主信息 = 主信息.创建主信息(令牌);
            组合目标节点 = 节点.创建节点(节点类型::特征, 组合目标主信息, 令牌);
            const auto 本次关系 = 节候选
                ? 关系.创建关系(关系类型::引用, 节候选->读取节点(), 组合目标节点, 0, 令牌)
                : 关系句柄{};
            const auto 逆序清理 = [&](关系句柄 待清关系) {
                if (!关系.删除关系(待清关系, 令牌)) return false;
                if (节点.撤销未发布候选(*节候选, 令牌) != 核心未发布候选操作状态::已完成) return false;
                return 主信息.撤销未发布候选(*主候选, 令牌) == 核心未发布候选操作状态::已完成;
            };
            const bool 关系失败未推进 = 主候选 && 节候选 && 句柄有效(本次关系)
                && !逆序清理({})
                && 节点.读取节点(节候选->读取节点(), 令牌).has_value()
                && 主信息.读取主信息(主候选->读取主信息(), 令牌).has_value()
                && 关系.读取关系(本次关系, 令牌).has_value();
            验收组[7] = 关系失败未推进 && 逆序清理(本次关系)
                && !关系.读取关系(本次关系, 令牌).has_value();
        }
        {
            auto 独占许可 = 接线.取得独占许可(接线.运行期状态);
            if (独占许可.有效()) {
                (void)节点.删除节点(组合目标节点, 独占许可.读取令牌());
                (void)主信息.删除主信息(组合目标主信息, 独占许可.读取令牌());
            }
        }

        验收组[10] = true;

        主信息仓库 未接域主信息(1587);
        节点仓库 未接域节点(未接域主信息, 2587);
        const auto 旧主信息 = 未接域主信息.创建主信息();
        const auto 旧节点 = 未接域节点.创建节点(节点类型::基础信息, 旧主信息);
        验收组[11] = 句柄有效(旧主信息) && 句柄有效(旧节点)
            && !未接域主信息.创建主信息未发布候选({}).has_value()
            && 未接域节点.删除节点(旧节点)
            && 未接域主信息.删除主信息(旧主信息);
    } catch (...) {
    }

    std::size_t 失败数量 = 0;
    for (const bool 通过 : 验收组) if (!通过) ++失败数量;
    return {"CORE-UNPUBLISHED-S1", "共享写入未发布身份候选", 失败数量 == 0, 验收组.size(), 失败数量};
}

}
