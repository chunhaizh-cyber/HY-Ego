// 规则：本模块只验证隔离节点直接身份结构事务，不得进入生产依赖方向。
module;

#include "句柄.h"

#include <algorithm>
#include <array>
#include <cstddef>
#include <cstdint>
#include <iostream>
#include <span>
#include <type_traits>
#include <utility>
#include <vector>

export module 海中鱼巣.核心.自检.节点直接身份结构写入;

import 海中鱼巣.核心.仓库.节点直接身份;
import 海中鱼巣.核心.仓库.正式关系;
import 海中鱼巣.核心.仓库.可重建索引;
import 海中鱼巣.核心.会话.节点直接身份结构写入;
import 海中鱼巣.核心.执行器.节点直接身份结构写入;
import 海中鱼巣.核心.冻结.节点直接身份结构;

namespace 海中鱼巣::节点直接身份结构写入自检内部 {

bool 允许自检关系(
    节点类型,
    节点类型,
    std::int64_t) noexcept {
    return true;
}

完整正式关系准入表 形成完整准入表() {
    完整正式关系准入表 表;
    for (std::size_t 序号 = 0; 序号 < 表.规则组.size(); ++序号) {
        表.规则组[序号] = {
            static_cast<关系类型>(序号),
            0x4E54'5031'0000'0001ULL + 序号,
            1,
            true,
            true,
            true,
            &允许自检关系};
    }
    return 表;
}

节点稳定主键 形成稳定主键(
    节点稳定主键命名域 命名域,
    std::uint64_t 键值) noexcept {
    return {static_cast<std::uint64_t>(命名域), 键值};
}

struct 隔离夹具 {
    explicit 隔离夹具(std::uint64_t 仓库基数)
        : 节点(仓库基数),
          关系(节点, 形成完整准入表(), 仓库基数 + 1),
          索引(节点, 关系),
          执行器(&事务域, &节点, &关系, &索引) {
    }

    节点直接身份仓库 节点;
    正式关系仓库 关系;
    可重建索引仓库 索引;
    节点直接身份结构事务域 事务域;
    节点直接身份结构写入执行器 执行器;
};

enum class 参与者故障点 : std::uint8_t {
    无,
    准备,
    确认,
    撤销
};

template <int 类型标识>
class 强类型自检参与者 final : public 节点直接身份结构写入事务参与者 {
public:
    强类型自检参与者(
        std::vector<int>* 顺序,
        参与者故障点 故障点) noexcept
        : 顺序_(顺序), 故障点_(故障点) {
    }

    void 绑定候选(
        节点句柄 节点,
        节点类型 类型,
        节点稳定主键 稳定主键) noexcept {
        节点_ = 节点;
        类型_ = 类型;
        稳定主键_ = 稳定主键;
    }

    bool 已发布() const noexcept { return 已发布_; }
    bool 已撤销() const noexcept { return 已撤销_; }

private:
    节点直接身份结构写入结果 准备提交(
        const 节点直接身份结构提交准备只读视图& 视图) override {
        顺序_->push_back(类型标识 * 10 + 1);
        const auto 候选类型 = 视图.读取候选节点类型(节点_);
        const auto 候选主键 = 视图.读取候选节点稳定主键(节点_);
        if (故障点_ == 参与者故障点::准备
            || !视图.节点是本会话候选(节点_)
            || !候选类型.has_value() || *候选类型 != 类型_
            || !候选主键.has_value()
            || 候选主键->命名域 != 稳定主键_.命名域
            || 候选主键->键值 != 稳定主键_.键值) {
            return {节点直接身份结构写入状态::内部不一致, 0, 0, 0};
        }
        return {节点直接身份结构写入状态::候选已确认, 0, 0, 0};
    }

    节点直接身份结构写入结果 确认待发布() override {
        顺序_->push_back(类型标识 * 10 + 2);
        if (故障点_ == 参与者故障点::确认) {
            return {节点直接身份结构写入状态::内部不一致, 0, 0, 0};
        }
        return {节点直接身份结构写入状态::候选已确认, 0, 0, 0};
    }

    void 完成发布() noexcept override {
        顺序_->push_back(类型标识 * 10 + 3);
        已发布_ = true;
    }

    节点直接身份结构写入结果 完成撤销() override {
        顺序_->push_back(类型标识 * 10 + 4);
        已撤销_ = true;
        if (故障点_ == 参与者故障点::撤销) {
            return {节点直接身份结构写入状态::内部不一致, 0, 0, 0};
        }
        return {节点直接身份结构写入状态::候选已撤销, 0, 0, 0};
    }

    std::vector<int>* 顺序_ = nullptr;
    参与者故障点 故障点_ = 参与者故障点::无;
    节点句柄 节点_;
    节点类型 类型_ = 节点类型::未分类;
    节点稳定主键 稳定主键_;
    bool 已发布_ = false;
    bool 已撤销_ = false;
};

template <typename 类型>
concept 含主信息字段 = requires(const 类型& 值) { 值.主信息; };

template <typename 类型>
concept 含仓库字段 = requires(const 类型& 值) { 值.仓库; };

template <typename 类型>
concept 含令牌字段 = requires(const 类型& 值) { 值.令牌; };

template <typename 类型>
concept 含可变账字段 = requires(类型& 值) { 值.可变账; };

static_assert(!std::is_same_v<强类型自检参与者<1>, 强类型自检参与者<2>>);
static_assert(!std::is_default_constructible_v<节点直接身份结构提交准备只读视图>);
static_assert(!std::is_copy_constructible_v<节点直接身份结构提交准备只读视图>);
static_assert(!含主信息字段<节点直接身份结构提交准备只读视图>);
static_assert(!含仓库字段<节点直接身份结构提交准备只读视图>);
static_assert(!含令牌字段<节点直接身份结构提交准备只读视图>);
static_assert(!含可变账字段<节点直接身份结构提交准备只读视图>);
static_assert(!含主信息字段<节点直接身份记录>);
static_assert(!含主信息字段<冻结节点直接身份记录>);
static_assert(std::is_aggregate_v<节点直接身份记录>);
static_assert(std::is_aggregate_v<正式关系记录>);
static_assert(std::is_aggregate_v<可重建索引记录>);

bool 验证稳定主键与幂等冲突() {
    隔离夹具 夹具(0x3391);
    const auto 主键一 = 形成稳定主键(节点稳定主键命名域::文章身份, 1);
    const auto 主键二 = 形成稳定主键(节点稳定主键命名域::文章身份, 2);
    节点句柄 撤销节点;
    const auto 撤销结果 = 夹具.执行器.执行([&](节点直接身份结构写入会话& 会话) {
        const auto 创建 = 会话.创建节点候选(节点类型::文章, 主键一);
        if (创建.值.has_value()) {
            撤销节点 = *创建.值;
            (void)会话.读取节点(撤销节点);
        }
        会话.请求撤销();
    });

    节点句柄 当前节点;
    节点直接身份记录 当前记录;
    const auto 提交结果 = 夹具.执行器.执行([&](节点直接身份结构写入会话& 会话) {
        const auto 创建 = 会话.创建节点候选(节点类型::文章, 主键二);
        if (创建.值.has_value()) {
            当前节点 = *创建.值;
            const auto 记录 = 会话.读取节点(当前节点);
            if (记录.has_value()) 当前记录 = *记录;
        }
        会话.请求提交();
    });

    节点直接身份结构写入状态 幂等状态 = 节点直接身份结构写入状态::内部不一致;
    const auto 幂等结果 = 夹具.执行器.执行([&](节点直接身份结构写入会话& 会话) {
        const auto 创建 = 会话.创建节点候选(节点类型::文章, 主键二);
        幂等状态 = 创建.操作.状态;
        会话.请求提交();
    });

    节点直接身份结构写入状态 历史复用状态 = 节点直接身份结构写入状态::内部不一致;
    (void)夹具.执行器.执行([&](节点直接身份结构写入会话& 会话) {
        历史复用状态 = 会话.创建节点候选(节点类型::文章, 主键一).操作.状态;
        会话.请求撤销();
    });

    节点直接身份结构写入状态 异义状态 = 节点直接身份结构写入状态::内部不一致;
    (void)夹具.执行器.执行([&](节点直接身份结构写入会话& 会话) {
        异义状态 = 会话.创建节点候选(节点类型::段落, 主键二).操作.状态;
        会话.请求撤销();
    });

    节点直接身份结构写入状态 未知域状态 = 节点直接身份结构写入状态::内部不一致;
    (void)夹具.执行器.执行([&](节点直接身份结构写入会话& 会话) {
        未知域状态 = 会话.创建节点候选(
            节点类型::文章, {0x4E53'4B59'FFFF'FFFFULL, 1}).操作.状态;
        会话.请求撤销();
    });

    const auto 历史读回 = 夹具.节点.读取稳定主键当前身份(主键一);
    const auto 当前读回 = 夹具.节点.读取稳定主键当前身份(主键二);
    return 稳定主键有效(主键一)
        && 主键一 != 主键二
        && 节点稳定主键命名域ABI版本 == 1
        && static_cast<std::uint32_t>(节点类型::文章) == 16
        && static_cast<std::uint32_t>(节点类型::子句) == 19
        && static_cast<std::uint32_t>(关系类型::状态事实角色) == 19
        && static_cast<std::uint32_t>(关系类型::方法生命周期) == 23
        && 撤销结果.状态 == 节点直接身份结构写入状态::候选已撤销
        && !夹具.节点.读取节点(撤销节点).has_value()
        && 提交结果.状态 == 节点直接身份结构写入状态::已提交
        && 幂等状态 == 节点直接身份结构写入状态::幂等读回
        && 幂等结果.状态 == 节点直接身份结构写入状态::幂等读回
        && 历史复用状态 == 节点直接身份结构写入状态::身份冲突
        && 异义状态 == 节点直接身份结构写入状态::入口拒绝
        && 未知域状态 == 节点直接身份结构写入状态::入口拒绝
        && 夹具.节点.读取命名域高水位(节点稳定主键命名域::文章身份) == 2
        && 历史读回.状态 == 稳定主键当前身份状态::历史占用
        && 当前读回.状态 == 稳定主键当前身份状态::当前有效
        && 当前记录.节点编号 == 当前节点.节点编号
        && 当前记录.稳定主键 == 主键二
        && 当前记录.类型 == 节点类型::文章
        && 当前记录.版本号 == 1
        && 当前记录.状态 == 记录状态::有效
        && 当前记录.创建序号 != 0
        && 夹具.节点.有效节点数量() == 1;
}

struct 主路径证据 {
    bool 节点关系索引通过 = false;
    bool 双参与者通过 = false;
    bool 读取隔离通过 = false;
    bool 冻结通过 = false;
    bool 索引可重建通过 = false;
};

主路径证据 运行主路径() {
    隔离夹具 夹具(0x3392);
    std::vector<int> 参与顺序;
    强类型自检参与者<1> 参与者甲(&参与顺序, 参与者故障点::无);
    强类型自检参与者<2> 参与者乙(&参与顺序, 参与者故障点::无);
    std::array<节点直接身份结构写入事务参与者*, 2> 参与者组{&参与者甲, &参与者乙};
    const auto 主键甲 = 形成稳定主键(节点稳定主键命名域::文章身份, 1);
    const auto 主键乙 = 形成稳定主键(节点稳定主键命名域::文章身份, 2);
    节点句柄 节点甲;
    节点句柄 节点乙;
    std::vector<关系句柄> 关系组;
    const 索引物理键 物理键{0x3392, 1, 1, 1, 1};
    可重建索引记录 索引记录;
    bool 写中普通读取不可见 = false;
    bool 写中读取许可不可得 = false;
    bool 全部形成 = true;

    const auto 执行结果 = 夹具.执行器.执行(
        [&](节点直接身份结构写入会话& 会话) {
            const auto 创建甲 = 会话.创建节点候选(节点类型::文章, 主键甲);
            const auto 创建乙 = 会话.创建节点候选(节点类型::文章, 主键乙);
            全部形成 = 创建甲.成功() && 创建乙.成功();
            if (!全部形成) {
                会话.请求撤销();
                return;
            }
            节点甲 = *创建甲.值;
            节点乙 = *创建乙.值;
            参与者甲.绑定候选(节点甲, 节点类型::文章, 主键甲);
            参与者乙.绑定候选(节点乙, 节点类型::文章, 主键乙);
            全部形成 = 会话.读取节点(节点甲).has_value()
                && 会话.读取节点(节点乙).has_value();
            写中普通读取不可见 = !夹具.节点.读取节点(节点甲).has_value();
            auto 写中读取许可 = 夹具.事务域.取得读取许可();
            写中读取许可不可得 = !写中读取许可.有效();
            for (std::uint32_t 数值 = 0; 数值 < 正式关系类型ABI数量; ++数值) {
                const auto 创建关系 = 会话.创建关系候选(
                    static_cast<关系类型>(数值), 节点甲, 节点乙, 数值);
                if (!创建关系.成功()) {
                    全部形成 = false;
                    break;
                }
                关系组.push_back(*创建关系.值);
                全部形成 = 会话.读取关系(关系组.back()).has_value() && 全部形成;
            }
            索引记录 = {物理键, 索引目标种类::节点, 节点甲, {}};
            const auto 创建索引 = 会话.创建索引候选(索引记录);
            全部形成 = 创建索引.成功()
                && 会话.读取索引物理键(物理键).has_value()
                && 全部形成;
            if (全部形成) 会话.请求提交(); else 会话.请求撤销();
        },
        std::span<节点直接身份结构写入事务参与者* const>(参与者组));

    auto 发布后读取许可 = 夹具.事务域.取得读取许可();
    const auto 发布关系列表 = 夹具.关系.读取全部关系审计();
    const auto 未知写前数量 = 发布关系列表.size();
    const auto 未知结果 = 夹具.关系.结构化创建关系未发布候选(
        static_cast<关系类型>(24), 节点甲, 节点乙, 0, 0x3392);
    const auto 未知写后数量 = 夹具.关系.读取全部关系审计().size();
    const bool 清空成功 = 夹具.索引.清空可重建索引(0x3392);
    const bool 清空后无命中 = !夹具.索引.读取索引物理键(物理键).has_value();
    const bool 重建成功 = 夹具.索引.从权威记录重建({索引记录}, 0x3392);
    const bool 重建后命中 = 夹具.索引.读取索引物理键(物理键).has_value();
    const auto 冻结 = 冻结节点直接身份结构(夹具.节点, 夹具.关系, 夹具.索引);

    主路径证据 证据;
    证据.节点关系索引通过 = 执行结果.状态 == 节点直接身份结构写入状态::已提交
        && 全部形成
        && 夹具.节点.有效节点数量() == 2
        && 发布关系列表.size() == 正式关系类型ABI数量
        && 未知结果.状态 == 正式关系操作状态::入口拒绝_未知关系类型
        && 未知写前数量 == 未知写后数量
        && 重建后命中;
    证据.双参与者通过 = 参与者甲.已发布() && 参与者乙.已发布()
        && 参与顺序 == std::vector<int>({11, 21, 12, 22, 13, 23});
    证据.读取隔离通过 = 写中普通读取不可见
        && 写中读取许可不可得
        && 发布后读取许可.有效()
        && 夹具.节点.读取节点(节点甲).has_value();
    证据.冻结通过 = 冻结.节点.记录组.size() == 2
        && 冻结.关系.有效失效与历史记录组.size() == 正式关系类型ABI数量
        && 冻结.索引.可从权威结构重建
        && 冻结.索引.记录组.size() == 1
        && 冻结.节点.记录组.front().稳定主键.命名域 != 0;
    证据.索引可重建通过 = 清空成功 && 清空后无命中 && 重建成功 && 重建后命中
        && 夹具.节点.有效节点数量() == 2
        && 夹具.关系.读取全部关系审计().size() == 正式关系类型ABI数量;
    return 证据;
}

bool 形成单事务完整写集(
    隔离夹具& 夹具,
    节点直接身份结构写入会话& 会话,
    节点句柄& 节点甲,
    节点句柄& 节点乙,
    强类型自检参与者<1>& 参与者甲,
    强类型自检参与者<2>& 参与者乙) {
    const auto 主键甲 = 形成稳定主键(节点稳定主键命名域::文章身份, 1);
    const auto 主键乙 = 形成稳定主键(节点稳定主键命名域::文章身份, 2);
    const auto 创建甲 = 会话.创建节点候选(节点类型::文章, 主键甲);
    const auto 创建乙 = 会话.创建节点候选(节点类型::文章, 主键乙);
    if (!创建甲.成功() || !创建乙.成功()) return false;
    节点甲 = *创建甲.值;
    节点乙 = *创建乙.值;
    参与者甲.绑定候选(节点甲, 节点类型::文章, 主键甲);
    参与者乙.绑定候选(节点乙, 节点类型::文章, 主键乙);
    if (!会话.读取节点(节点甲).has_value() || !会话.读取节点(节点乙).has_value()) return false;
    const auto 关系 = 会话.创建关系候选(关系类型::普通父子, 节点甲, 节点乙, 0);
    if (!关系.成功() || !会话.读取关系(*关系.值).has_value()) return false;
    const 索引物理键 键{0x3393, 1, 1, 1, 1};
    const auto 索引 = 会话.创建索引候选({键, 索引目标种类::节点, 节点甲, {}});
    if (!索引.成功() || !会话.读取索引物理键(键).has_value()) return false;
    return true;
}

bool 验证逆序撤销() {
    auto 运行故障 = [](参与者故障点 乙故障, const std::vector<int>& 预期顺序) {
        隔离夹具 夹具(乙故障 == 参与者故障点::准备 ? 0x3393 : 0x3394);
        std::vector<int> 顺序;
        强类型自检参与者<1> 参与者甲(&顺序, 参与者故障点::无);
        强类型自检参与者<2> 参与者乙(&顺序, 乙故障);
        std::array<节点直接身份结构写入事务参与者*, 2> 参与者组{&参与者甲, &参与者乙};
        节点句柄 节点甲;
        节点句柄 节点乙;
        bool 写集完整 = false;
        const auto 结果 = 夹具.执行器.执行(
            [&](节点直接身份结构写入会话& 会话) {
                写集完整 = 形成单事务完整写集(
                    夹具, 会话, 节点甲, 节点乙, 参与者甲, 参与者乙);
                if (写集完整) 会话.请求提交(); else 会话.请求撤销();
            },
            std::span<节点直接身份结构写入事务参与者* const>(参与者组));
        return 写集完整
            && 结果.状态 == 节点直接身份结构写入状态::内部不一致
            && 参与者甲.已撤销() && 参与者乙.已撤销()
            && 顺序 == 预期顺序
            && 夹具.节点.有效节点数量() == 0
            && 夹具.关系.读取全部关系审计().empty()
            && 夹具.索引.导出可丢弃加速材料().记录组.empty()
            && !夹具.事务域.已隔离();
    };
    return 运行故障(参与者故障点::准备, {11, 21, 24, 14})
        && 运行故障(参与者故障点::确认, {11, 21, 12, 22, 24, 14});
}

bool 验证撤销失败隔离() {
    隔离夹具 夹具(0x3395);
    std::vector<int> 顺序;
    强类型自检参与者<1> 参与者(&顺序, 参与者故障点::撤销);
    节点句柄 节点;
    const auto 结果 = 夹具.执行器.执行(
        [&](节点直接身份结构写入会话& 会话) {
            const auto 主键 = 形成稳定主键(节点稳定主键命名域::文章身份, 1);
            const auto 创建 = 会话.创建节点候选(节点类型::文章, 主键);
            if (创建.值.has_value()) {
                节点 = *创建.值;
                参与者.绑定候选(节点, 节点类型::文章, 主键);
                (void)会话.读取节点(节点);
            }
            会话.请求撤销();
        },
        参与者);
    const auto 后继结果 = 夹具.执行器.执行(
        [](节点直接身份结构写入会话& 会话) { 会话.请求撤销(); });
    auto 读取许可 = 夹具.事务域.取得读取许可();
    return 结果.状态 == 节点直接身份结构写入状态::内部不一致
        && 参与者.已撤销()
        && 夹具.事务域.已隔离()
        && 后继结果.状态 == 节点直接身份结构写入状态::许可拒绝
        && !读取许可.有效()
        && !夹具.节点.读取节点(节点).has_value();
}

bool 验证关系反向读取与会话视图() {
    隔离夹具 夹具(0x3741);
    节点句柄 节点甲;
    节点句柄 节点乙;
    节点句柄 节点丙;
    关系句柄 入向甲;
    关系句柄 入向丙;
    关系句柄 自关系;
    const auto 自关系类型 = static_cast<关系类型>(1);
    bool 初始写集完整 = false;
    const auto 初始结果 = 夹具.执行器.执行([&](节点直接身份结构写入会话& 会话) {
        const auto 创建甲 = 会话.创建节点候选(
            节点类型::文章, 形成稳定主键(节点稳定主键命名域::文章身份, 1));
        const auto 创建乙 = 会话.创建节点候选(
            节点类型::文章, 形成稳定主键(节点稳定主键命名域::文章身份, 2));
        const auto 创建丙 = 会话.创建节点候选(
            节点类型::文章, 形成稳定主键(节点稳定主键命名域::文章身份, 3));
        初始写集完整 = 创建甲.成功() && 创建乙.成功() && 创建丙.成功();
        if (!初始写集完整) {
            会话.请求撤销();
            return;
        }
        节点甲 = *创建甲.值;
        节点乙 = *创建乙.值;
        节点丙 = *创建丙.值;
        初始写集完整 = 会话.读取节点(节点甲).has_value()
            && 会话.读取节点(节点乙).has_value()
            && 会话.读取节点(节点丙).has_value();
        const auto 创建入向甲 = 会话.创建关系候选(
            关系类型::普通父子, 节点甲, 节点乙, 7);
        const auto 创建入向丙 = 会话.创建关系候选(
            关系类型::普通父子, 节点丙, 节点乙, 7);
        const auto 创建自关系 = 会话.创建关系候选(
            自关系类型, 节点乙, 节点乙, 9);
        初始写集完整 = 初始写集完整 && 创建入向甲.成功()
            && 创建入向丙.成功() && 创建自关系.成功();
        if (初始写集完整) {
            入向甲 = *创建入向甲.值;
            入向丙 = *创建入向丙.值;
            自关系 = *创建自关系.值;
            初始写集完整 = 会话.读取关系(入向甲).has_value()
                && 会话.读取关系(入向丙).has_value()
                && 会话.读取关系(自关系).has_value();
        }
        if (初始写集完整) 会话.请求提交(); else 会话.请求撤销();
    });
    if (!初始写集完整
        || 初始结果.状态 != 节点直接身份结构写入状态::已提交) {
        return false;
    }

    const auto 已发布入向 = 夹具.关系.读取指向有效关系组(
        节点乙, 关系类型::普通父子);
    const auto 已发布相关 = 夹具.关系.读取相关有效关系组(
        节点乙, 关系类型::普通父子);
    const auto 已发布角色 = 夹具.关系.读取有效类型角色关系组(
        关系类型::普通父子, 7);
    const auto 已发布自关系 = 夹具.关系.读取相关有效关系组(
        节点乙, 自关系类型);
    const bool 已发布矩阵通过 = 已发布入向.size() == 2
        && 已发布相关.size() == 2
        && 已发布角色.size() == 2
        && 已发布自关系.size() == 1
        && 已发布入向[0].关系编号 < 已发布入向[1].关系编号
        && 已发布自关系.front().关系编号 == 自关系.关系编号
        && 夹具.关系.读取有效类型角色关系组(
            static_cast<关系类型>(正式关系类型ABI数量), 7).empty();

    bool 候选视图通过 = false;
    const auto 候选撤销结果 = 夹具.执行器.执行([&](节点直接身份结构写入会话& 会话) {
        const auto 失效 = 会话.失效关系候选(入向甲);
        const auto 重挂 = 会话.重挂关系候选(入向丙, 节点丙, 节点甲);
        const auto 新建 = 会话.创建关系候选(
            关系类型::普通父子, 节点甲, 节点乙, 7);
        if (!失效.成功() || !重挂.成功() || !新建.成功()) {
            会话.请求撤销();
            return;
        }
        const auto 指向乙 = 会话.读取指向有效关系组(
            节点乙, 关系类型::普通父子);
        const auto 相关甲 = 会话.读取相关有效关系组(
            节点甲, 关系类型::普通父子);
        const auto 角色组 = 会话.读取有效类型角色关系组(
            关系类型::普通父子, 7);
        候选视图通过 = 指向乙.size() == 1
            && 指向乙.front().关系编号 == 新建.值->关系编号
            && 相关甲.size() == 2 && 角色组.size() == 2
            && 相关甲[0].关系编号 < 相关甲[1].关系编号
            && std::none_of(角色组.begin(), 角色组.end(), [&](const auto& 记录) {
                return 记录.关系编号 == 入向甲.关系编号;
            });
        会话.请求撤销();
    });
    const auto 撤销后入向 = 夹具.关系.读取指向有效关系组(
        节点乙, 关系类型::普通父子);
    return 已发布矩阵通过 && 候选视图通过
        && 候选撤销结果.状态 == 节点直接身份结构写入状态::候选已撤销
        && 撤销后入向.size() == 2
        && 撤销后入向[0].关系编号 == 入向甲.关系编号
        && 撤销后入向[1].关系编号 == 入向丙.关系编号;
}

bool 验证索引移除与节点删除原子能力() {
    隔离夹具 夹具(0x3742);
    节点句柄 节点甲;
    节点句柄 节点乙;
    关系句柄 关系;
    const 索引物理键 甲键{0x3742, 1, 1, 1, 1};
    const 索引物理键 乙键{0x3742, 1, 1, 1, 2};
    bool 初始写集完整 = false;
    const auto 初始结果 = 夹具.执行器.执行([&](节点直接身份结构写入会话& 会话) {
        const auto 创建甲 = 会话.创建节点候选(
            节点类型::文章, 形成稳定主键(节点稳定主键命名域::文章身份, 1));
        const auto 创建乙 = 会话.创建节点候选(
            节点类型::文章, 形成稳定主键(节点稳定主键命名域::文章身份, 2));
        初始写集完整 = 创建甲.成功() && 创建乙.成功();
        if (!初始写集完整) {
            会话.请求撤销();
            return;
        }
        节点甲 = *创建甲.值;
        节点乙 = *创建乙.值;
        初始写集完整 = 会话.读取节点(节点甲).has_value()
            && 会话.读取节点(节点乙).has_value();
        const auto 创建关系 = 会话.创建关系候选(
            关系类型::普通父子, 节点甲, 节点乙, 0);
        const auto 创建甲索引 = 会话.创建索引候选(
            {甲键, 索引目标种类::节点, 节点甲, {}});
        const auto 创建乙索引 = 会话.创建索引候选(
            {乙键, 索引目标种类::节点, 节点乙, {}});
        初始写集完整 = 初始写集完整 && 创建关系.成功()
            && 创建甲索引.成功() && 创建乙索引.成功();
        if (初始写集完整) {
            关系 = *创建关系.值;
            初始写集完整 = 会话.读取关系(关系).has_value()
                && 会话.读取索引物理键(甲键).has_value()
                && 会话.读取索引物理键(乙键).has_value();
        }
        if (初始写集完整) 会话.请求提交(); else 会话.请求撤销();
    });
    if (!初始写集完整
        || 初始结果.状态 != 节点直接身份结构写入状态::已提交) {
        return false;
    }

    节点直接身份结构写入状态 引用拒绝状态 =
        节点直接身份结构写入状态::内部不一致;
    (void)夹具.执行器.执行([&](节点直接身份结构写入会话& 会话) {
        引用拒绝状态 = 会话.删除节点候选(节点甲).操作.状态;
        会话.请求撤销();
    });

    节点直接身份结构写入状态 索引引用拒绝状态 =
        节点直接身份结构写入状态::内部不一致;
    bool 撤销写集完整 = false;
    const auto 撤销结果 = 夹具.执行器.执行([&](节点直接身份结构写入会话& 会话) {
        const auto 失效 = 会话.失效关系候选(关系);
        if (失效.成功()) (void)会话.读取关系审计(*失效.值);
        索引引用拒绝状态 = 会话.删除节点候选(节点乙).操作.状态;
        const auto 移除 = 会话.移除索引候选(乙键);
        const auto 删除 = 会话.删除节点候选(节点乙);
        撤销写集完整 = 失效.成功() && 移除.成功() && 删除.成功()
            && !会话.读取索引物理键(乙键).has_value()
            && !会话.读取节点(节点乙).has_value();
        会话.请求撤销();
    });
    const bool 撤销恢复通过 = 撤销写集完整
        && 撤销结果.状态 == 节点直接身份结构写入状态::候选已撤销
        && 夹具.节点.读取节点(节点乙).has_value()
        && 夹具.索引.读取索引物理键(乙键).has_value()
        && 夹具.关系.读取关系(关系).has_value();

    节点句柄 删除后节点;
    关系句柄 失效后关系;
    bool 退役写集完整 = false;
    const auto 退役结果 = 夹具.执行器.执行([&](节点直接身份结构写入会话& 会话) {
        const auto 失效 = 会话.失效关系候选(关系);
        if (失效.成功()) {
            失效后关系 = *失效.值;
            (void)会话.读取关系审计(失效后关系);
        }
        const auto 移除 = 会话.移除索引候选(甲键);
        const auto 删除 = 会话.删除节点候选(节点甲);
        if (删除.值.has_value()) 删除后节点 = *删除.值;
        退役写集完整 = 失效.成功() && 移除.成功() && 删除.成功()
            && !会话.读取索引物理键(甲键).has_value()
            && !会话.读取节点(节点甲).has_value()
            && 会话.读取相关有效关系组(
                节点甲, 关系类型::普通父子).empty();
        if (退役写集完整) 会话.请求提交(); else 会话.请求撤销();
    });
    const auto 关系审计 = 夹具.关系.读取关系审计(失效后关系);
    const auto 节点审计 = 夹具.节点.读取节点审计(删除后节点);
    const bool 发布读回通过 = 退役写集完整
        && 退役结果.状态 == 节点直接身份结构写入状态::已提交
        && !夹具.节点.读取节点(节点甲).has_value()
        && 节点审计.has_value() && 节点审计->状态 == 记录状态::已删除
        && !夹具.关系.读取关系(失效后关系).has_value()
        && 关系审计.has_value()
        && 关系审计->当前记录.状态 == 记录状态::已失效
        && 关系审计->历史记录组.size() == 1
        && !夹具.索引.读取索引物理键(甲键).has_value();

    节点直接身份结构写入状态 幂等移除状态 =
        节点直接身份结构写入状态::内部不一致;
    const auto 幂等移除结果 = 夹具.执行器.执行(
        [&](节点直接身份结构写入会话& 会话) {
            幂等移除状态 = 会话.移除索引候选(甲键).操作.状态;
            会话.请求提交();
        });
    return 引用拒绝状态 == 节点直接身份结构写入状态::入口拒绝
        && 索引引用拒绝状态 == 节点直接身份结构写入状态::入口拒绝
        && 撤销恢复通过 && 发布读回通过
        && 幂等移除状态 == 节点直接身份结构写入状态::幂等读回
        && 幂等移除结果.状态 == 节点直接身份结构写入状态::幂等读回;
}

bool 验证视图与值式边界() {
    return !std::is_default_constructible_v<节点直接身份结构提交准备只读视图>
        && !std::is_copy_constructible_v<节点直接身份结构提交准备只读视图>
        && !含主信息字段<节点直接身份结构提交准备只读视图>
        && !含仓库字段<节点直接身份结构提交准备只读视图>
        && !含令牌字段<节点直接身份结构提交准备只读视图>
        && !含可变账字段<节点直接身份结构提交准备只读视图>
        && !含主信息字段<节点直接身份记录>
        && !含主信息字段<冻结节点直接身份记录>;
}

bool 验证新域隔离() {
    隔离夹具 未接入夹具(0x3396);
    return 未接入夹具.节点.有效节点数量() == 0
        && 未接入夹具.关系.读取全部关系审计().empty()
        && 未接入夹具.索引.导出可丢弃加速材料().记录组.empty()
        && !未接入夹具.事务域.已隔离();
}

} // namespace 海中鱼巣::节点直接身份结构写入自检内部

export namespace 海中鱼巣 {

struct 节点直接身份结构写入自检报告 {
    std::array<bool, 15> 验收{};
    bool 总通过 = false;
    std::size_t 失败数量 = 15;
};

节点直接身份结构写入自检报告 运行节点直接身份结构写入自检() {
    using namespace 节点直接身份结构写入自检内部;
    节点直接身份结构写入自检报告 报告;
    const bool 稳定主键与幂等冲突通过 = 验证稳定主键与幂等冲突();
    const auto 主路径 = 运行主路径();
    const bool 逆序撤销通过 = 验证逆序撤销();
    const bool 撤销失败隔离通过 = 验证撤销失败隔离();
    const bool 关系反向读取与会话视图通过 = 验证关系反向读取与会话视图();
    const bool 索引移除与节点删除通过 = 验证索引移除与节点删除原子能力();
    const bool 视图与值式边界通过 = 验证视图与值式边界();
    const bool 新域隔离通过 = 验证新域隔离();

    报告.验收 = {
        稳定主键与幂等冲突通过,
        稳定主键与幂等冲突通过,
        稳定主键与幂等冲突通过,
        视图与值式边界通过,
        主路径.节点关系索引通过 && 主路径.索引可重建通过
            && 关系反向读取与会话视图通过 && 索引移除与节点删除通过,
        视图与值式边界通过,
        主路径.双参与者通过,
        逆序撤销通过,
        撤销失败隔离通过,
        主路径.读取隔离通过,
        主路径.冻结通过,
        视图与值式边界通过,
        稳定主键与幂等冲突通过 && 主路径.节点关系索引通过
            && 逆序撤销通过 && 撤销失败隔离通过
            && 关系反向读取与会话视图通过 && 索引移除与节点删除通过,
        正式关系类型ABI数量 == 24 && 节点稳定主键命名域ABI版本 == 1,
        新域隔离通过};
    报告.失败数量 = static_cast<std::size_t>(std::count(
        报告.验收.begin(), 报告.验收.end(), false));
    报告.总通过 = 报告.失败数量 == 0;

    constexpr std::array<const char*, 15> 名称组{
        "P1-A01 稳定主键与高水位",
        "P1-A02 节点记录精确字段",
        "P1-A03 幂等与冲突零写",
        "P1-A04 不读取旧主信息",
        "P1-A05 关系ABI与可重建索引",
        "P1-A06 提交准备只读视图",
        "P1-A07 双强类型参与者",
        "P1-A08 固定逆序撤销",
        "P1-A09 撤销失败事务域隔离",
        "P1-A10 独占许可可见点",
        "P1-A11 值式冻结边界",
        "P1-A12 无通用载荷容器",
        "P1-A13 完整自检故障矩阵",
        "P1-A14 ABI与模块合同",
        "P1-A15 新旧域零互通"};
    for (std::size_t 序号 = 0; 序号 < 报告.验收.size(); ++序号) {
        std::cout << 名称组[序号] << ": " << (报告.验收[序号] ? "通过" : "失败") << '\n';
    }
    return 报告;
}

}
