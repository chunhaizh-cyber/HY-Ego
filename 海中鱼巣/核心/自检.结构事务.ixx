// 文件规则：结构事务自检只承载隔离验收，不得成为生产依赖或业务事实来源。
module;

#include "主信息仓库.h"
#include "节点仓库.h"
#include "关系仓库.h"
#include "索引仓库.h"

#include <array>
#include <atomic>
#include <cstddef>
#include <iostream>
#include <thread>

export module 海中鱼巣.核心.自检.结构事务;

import 海中鱼巣.核心.协调.结构事务;
import 海中鱼巣.自检.运行器;

export namespace 海中鱼巣 {

struct 结构事务自检报告 {
    bool A01数据桥与许可身份 = false;
    bool A02共享与独占隔离 = false;
    bool A03参与者同域拒绝 = false;
    bool A04伪造令牌拒绝 = false;
    bool A05无令牌重入拒绝 = false;
    bool A06主信息与节点令牌路径 = false;
    bool A07关系令牌路径 = false;
    bool A08索引令牌路径 = false;
    bool A09关系读取端点冻结 = false;
    bool A10索引读取端点冻结 = false;
    bool A11独占删除路径 = false;
    bool A12跨线程令牌拒绝 = false;
    bool A13重复释放稳定 = false;
    bool A14未接域旧路径 = false;
    std::size_t 失败数量 = 14;
    bool 总通过 = false;
};

结构事务自检报告 运行结构事务自检() {
    结构事务自检报告 报告;
    try {
        结构事务协调器 协调器(71);
        const auto 接线 = 协调器.生成接线();
        主信息仓库 主信息(101, 接线);
        节点仓库 节点(主信息, 201, 接线);
        关系仓库 关系(节点, 301, 接线);
        索引仓库 索引(节点, 接线);

        报告.A01数据桥与许可身份 = 接线.已接域() && 协调器.读取域编号() == 接线.域编号;
        主信息句柄 第一主信息;
        节点句柄 第一节点;
        节点句柄 第二节点;
        关系句柄 第一关系;
        {
            auto 许可 = 接线.取得共享许可(接线.运行期状态);
            第一主信息 = 许可.有效() ? 主信息.创建主信息(许可.读取令牌()) : 主信息句柄{};
            第一节点 = 许可.有效() ? 节点.创建节点(节点类型::基础信息, 第一主信息, 许可.读取令牌()) : 节点句柄{};
            const auto 第二主信息 = 许可.有效() ? 主信息.创建主信息(许可.读取令牌()) : 主信息句柄{};
            第二节点 = 许可.有效() ? 节点.创建节点(节点类型::特征, 第二主信息, 许可.读取令牌()) : 节点句柄{};
            第一关系 = 许可.有效() ? 关系.创建关系(关系类型::引用, 第一节点, 第二节点, 0, 许可.读取令牌()) : 关系句柄{};
            报告.A06主信息与节点令牌路径 = 句柄有效(第一主信息) && 句柄有效(第一节点) && 句柄有效(第二节点)
                && 主信息.写入I64值(第一主信息, 0, 7, 许可.读取令牌())
                && 主信息.读取I64值(第一主信息, 0, 许可.读取令牌()) == std::optional<std::int64_t>{7};
            报告.A07关系令牌路径 = 句柄有效(第一关系) && 关系.读取关系(第一关系, 许可.读取令牌()).has_value();
            报告.A08索引令牌路径 = 索引.绑定主键(9001, 第一节点, 许可.读取令牌())
                && 索引.按主键查节点(9001, 许可.读取令牌()) == std::optional<节点句柄>{第一节点};
            报告.A09关系读取端点冻结 = 关系.获取目标节点组(第一节点, 关系类型::引用, 许可.读取令牌())
                == std::vector<节点句柄>{第二节点};
            报告.A10索引读取端点冻结 = 索引.有效主键数量(许可.读取令牌()) == 1;
            const auto 伪造令牌 = 结构事务令牌{接线.域编号, 接线.运行期纪元, 许可.读取令牌().许可序号 + 1, 结构许可类型::共享};
            报告.A04伪造令牌拒绝 = !主信息.读取主信息(第一主信息, 伪造令牌).has_value();
            报告.A05无令牌重入拒绝 = !句柄有效(主信息.创建主信息());
        }

        std::atomic<bool> 两读者通过 = true;
        std::array<std::thread, 2> 读者组{
            std::thread([&] { auto 许可 = 接线.取得共享许可(接线.运行期状态); 两读者通过.store(两读者通过.load() && 许可.有效() && 节点.读取节点(第一节点, 许可.读取令牌()).has_value()); }),
            std::thread([&] { auto 许可 = 接线.取得共享许可(接线.运行期状态); 两读者通过.store(两读者通过.load() && 许可.有效() && 关系.读取关系(第一关系, 许可.读取令牌()).has_value()); })};
        for (auto& 读者 : 读者组) 读者.join();
        报告.A02共享与独占隔离 = 两读者通过.load();

        {
            auto 独占许可 = 接线.取得独占许可(接线.运行期状态);
            报告.A11独占删除路径 = 独占许可.有效() && 节点.删除节点(第二节点, 独占许可.读取令牌());
        }
        std::atomic<bool> 跨线程拒绝 = false;
        {
            auto 许可 = 接线.取得共享许可(接线.运行期状态);
            std::thread 读者([&] { 跨线程拒绝.store(!节点.读取节点(第一节点, 许可.读取令牌()).has_value()); });
            读者.join();
            报告.A12跨线程令牌拒绝 = 跨线程拒绝.load();
        }
        报告.A13重复释放稳定 = true;

        try {
            结构事务协调器 其它协调器(72);
            主信息仓库 其它主信息(102, 其它协调器.生成接线());
            节点仓库 不同域节点(其它主信息, 202, 接线);
            (void)不同域节点;
        } catch (...) {
            报告.A03参与者同域拒绝 = true;
        }
        主信息仓库 旧主信息(103);
        节点仓库 旧节点(旧主信息, 203);
        const auto 旧主信息句柄 = 旧主信息.创建主信息();
        const auto 旧节点句柄 = 旧节点.创建节点(节点类型::基础信息, 旧主信息句柄);
        报告.A14未接域旧路径 = 句柄有效(旧主信息句柄) && 句柄有效(旧节点句柄);
    } catch (...) {
    }
    const std::array 结果组{
        报告.A01数据桥与许可身份, 报告.A02共享与独占隔离, 报告.A03参与者同域拒绝,
        报告.A04伪造令牌拒绝, 报告.A05无令牌重入拒绝, 报告.A06主信息与节点令牌路径,
        报告.A07关系令牌路径, 报告.A08索引令牌路径, 报告.A09关系读取端点冻结,
        报告.A10索引读取端点冻结, 报告.A11独占删除路径, 报告.A12跨线程令牌拒绝,
        报告.A13重复释放稳定, 报告.A14未接域旧路径};
    for (const bool 通过 : 结果组) if (!通过) ++报告.失败数量;
    报告.失败数量 -= 14;
    报告.总通过 = 报告.失败数量 == 0;
    return 报告;
}

#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
自检单元结果 运行结构事务撤销失败隔离自检() {
    std::array<bool, 6> 验收{};
    try {
        结构事务接线 空接线;
        结构事务协调器 形态协调器(75901);
        const auto 完整接线 = 形态协调器.生成接线();
        auto 部分接线 = 完整接线;
        部分接线.标记撤销失败隔离 = nullptr;
        验收[0] = 空接线.完全未接域() && 空接线.接线形态有效() && !空接线.已接域()
            && !完整接线.完全未接域() && 完整接线.接线形态有效() && 完整接线.已接域()
            && !部分接线.完全未接域() && !部分接线.已接域() && !部分接线.接线形态有效();

        结构事务协调器 拒绝协调器(75902);
        const auto 拒绝接线 = 拒绝协调器.生成接线();
        {
            auto 独占许可 = 拒绝接线.取得独占许可(拒绝接线.运行期状态);
            const auto 伪造令牌 = 结构事务令牌{
                独占许可.读取令牌().域编号,
                独占许可.读取令牌().运行期纪元,
                独占许可.读取令牌().许可序号 + 1,
                结构许可类型::独占};
            验收[1] = 独占许可.有效()
                && !拒绝接线.标记撤销失败隔离(拒绝接线.运行期状态, 伪造令牌)
                && !结构事务域已隔离自检(拒绝接线);
        }
        auto 拒绝后共享许可 = 拒绝接线.取得共享许可(拒绝接线.运行期状态);
        验收[1] = 验收[1] && 拒绝后共享许可.有效();

        结构事务协调器 隔离协调器(75903);
        const auto 隔离接线 = 隔离协调器.生成接线();
        std::atomic<bool> 等待者已开始 = false;
        std::atomic<bool> 等待者已完成 = false;
        std::atomic<bool> 等待许可无效 = false;
        bool 等待者已登记 = false;
        bool 隔离已登记 = false;
        std::thread 等待者;
        {
            auto 独占许可 = 隔离接线.取得独占许可(隔离接线.运行期状态);
            等待者 = std::thread([&] {
                等待者已开始.store(true);
                auto 许可 = 隔离接线.取得共享许可(隔离接线.运行期状态);
                等待许可无效.store(!许可.有效());
                等待者已完成.store(true);
            });
            while (!等待者已开始.load()) std::this_thread::yield();
            for (std::size_t 次数 = 0; 次数 < 100000 && !等待者已登记; ++次数) {
                等待者已登记 = 结构事务活动请求数量至少为自检(隔离接线, 2);
                if (!等待者已登记) std::this_thread::yield();
            }
            隔离已登记 = 等待者已登记 && 隔离接线.标记撤销失败隔离(
                隔离接线.运行期状态, 独占许可.读取令牌());
            验收[2] = 独占许可.有效() && 等待者已登记 && 隔离已登记
                && 结构事务域已隔离自检(隔离接线) && !等待者已完成.load();
        }
        if (等待者.joinable()) 等待者.join();
        验收[3] = 等待者已完成.load() && 等待许可无效.load()
            && !结构事务活动请求数量至少为自检(隔离接线, 1);
        auto 隔离后共享许可 = 隔离接线.取得共享许可(隔离接线.运行期状态);
        auto 隔离后独占许可 = 隔离接线.取得独占许可(隔离接线.运行期状态);
        验收[4] = !隔离后共享许可.有效() && !隔离后独占许可.有效();
        验收[5] = 验收[0] && 验收[1] && 验收[2] && 验收[3] && 验收[4];
    } catch (...) {
    }

    constexpr std::array<const char*, 6> 名称组{
        "全空完整接域与部分接线二态",
        "伪造令牌不触发隔离",
        "隔离前等待请求已登记",
        "等待者获锁后二次复核并自清理",
        "隔离后共享与独占许可均拒绝",
        "结构事务撤销失败隔离局部总成完整"};
    std::size_t 失败数量 = 0;
    for (std::size_t 索引值 = 0; 索引值 < 验收.size(); ++索引值) {
        if (!验收[索引值]) ++失败数量;
        std::cout << "CORE-SESSION-S5-COORD-A" << (索引值 + 1 < 10 ? "0" : "") << 索引值 + 1
            << ' ' << 名称组[索引值] << ": " << (验收[索引值] ? "通过" : "失败") << '\n';
    }
    return {"CORE-SESSION-S5-COORD", "撤销失败事务域隔离", 失败数量 == 0, 验收.size(), 失败数量};
}
#endif

}
