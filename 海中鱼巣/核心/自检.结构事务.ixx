// 文件规则：结构事务自检只承载隔离验收，不得成为生产依赖或业务事实来源。
module;

#include "主信息仓库.h"
#include "节点仓库.h"
#include "关系仓库.h"
#include "索引仓库.h"

#include <array>
#include <atomic>
#include <cstddef>
#include <thread>

export module 海中鱼巣.核心.自检.结构事务;

import 海中鱼巣.核心.协调.结构事务;

export namespace 海中鱼巣 {

struct 结构事务自检报告 {
    bool A01数据桥与许可身份 = false;
    bool A02共享与独占隔离 = false;
    bool A03参与者同域拒绝 = false;
    bool A04伪造令牌拒绝 = false;
    bool A05无令牌重入拒绝 = false;
    bool A06主信息与节点令牌路径 = false;
    bool A07关系令牌路径 = false;
    bool A08索引令牌路径 = false;
    bool A09关系读取端点冻结 = false;
    bool A10索引读取端点冻结 = false;
    bool A11独占删除路径 = false;
    bool A12跨线程令牌拒绝 = false;
    bool A13重复释放稳定 = false;
    bool A14未接域旧路径 = false;
    std::size_t 失败数量 = 14;
    bool 总通过 = false;
};

结构事务自检报告 运行结构事务自检() {
    结构事务自检报告 报告;
    try {
        结构事务协调器 协调器(71);
        const auto 接线 = 协调器.生成接线();
        主信息仓库 主信息(101, 接线);
        节点仓库 节点(主信息, 201, 接线);
        关系仓库 关系(节点, 301, 接线);
        索引仓库 索引(节点, 接线);

        报告.A01数据桥与许可身份 = 接线.已接域() && 协调器.读取域编号() == 接线.域编号;
        主信息句柄 第一主信息;
        节点句柄 第一节点;
        节点句柄 第二节点;
        关系句柄 第一关系;
        {
            auto 许可 = 接线.取得共享许可(接线.运行期状态);
            第一主信息 = 许可.有效() ? 主信息.创建主信息(许可.读取令牌()) : 主信息句柄{};
            第一节点 = 许可.有效() ? 节点.创建节点(节点类型::基础信息, 第一主信息, 许可.读取令牌()) : 节点句柄{};
            const auto 第二主信息 = 许可.有效() ? 主信息.创建主信息(许可.读取令牌()) : 主信息句柄{};
            第二节点 = 许可.有效() ? 节点.创建节点(节点类型::特征, 第二主信息, 许可.读取令牌()) : 节点句柄{};
            第一关系 = 许可.有效() ? 关系.创建关系(关系类型::引用, 第一节点, 第二节点, 0, 许可.读取令牌()) : 关系句柄{};
            报告.A06主信息与节点令牌路径 = 句柄有效(第一主信息) && 句柄有效(第一节点) && 句柄有效(第二节点)
                && 主信息.写入I64值(第一主信息, 0, 7, 许可.读取令牌())
                && 主信息.读取I64值(第一主信息, 0, 许可.读取令牌()) == std::optional<std::int64_t>{7};
            报告.A07关系令牌路径 = 句柄有效(第一关系) && 关系.读取关系(第一关系, 许可.读取令牌()).has_value();
            报告.A08索引令牌路径 = 索引.绑定主键(9001, 第一节点, 许可.读取令牌())
                && 索引.按主键查节点(9001, 许可.读取令牌()) == std::optional<节点句柄>{第一节点};
            报告.A09关系读取端点冻结 = 关系.获取目标节点组(第一节点, 关系类型::引用, 许可.读取令牌())
                == std::vector<节点句柄>{第二节点};
            报告.A10索引读取端点冻结 = 索引.有效主键数量(许可.读取令牌()) == 1;
            const auto 伪造令牌 = 结构事务令牌{接线.域编号, 接线.运行期纪元, 许可.读取令牌().许可序号 + 1, 结构许可类型::共享};
            报告.A04伪造令牌拒绝 = !主信息.读取主信息(第一主信息, 伪造令牌).has_value();
            报告.A05无令牌重入拒绝 = !句柄有效(主信息.创建主信息());
        }

        std::atomic<bool> 两读者通过 = true;
        std::array<std::thread, 2> 读者组{
            std::thread([&] { auto 许可 = 接线.取得共享许可(接线.运行期状态); 两读者通过.store(两读者通过.load() && 许可.有效() && 节点.读取节点(第一节点, 许可.读取令牌()).has_value()); }),
            std::thread([&] { auto 许可 = 接线.取得共享许可(接线.运行期状态); 两读者通过.store(两读者通过.load() && 许可.有效() && 关系.读取关系(第一关系, 许可.读取令牌()).has_value()); })};
        for (auto& 读者 : 读者组) 读者.join();
        报告.A02共享与独占隔离 = 两读者通过.load();

        {
            auto 独占许可 = 接线.取得独占许可(接线.运行期状态);
            报告.A11独占删除路径 = 独占许可.有效() && 节点.删除节点(第二节点, 独占许可.读取令牌());
        }
        std::atomic<bool> 跨线程拒绝 = false;
        {
            auto 许可 = 接线.取得共享许可(接线.运行期状态);
            std::thread 读者([&] { 跨线程拒绝.store(!节点.读取节点(第一节点, 许可.读取令牌()).has_value()); });
            读者.join();
            报告.A12跨线程令牌拒绝 = 跨线程拒绝.load();
        }
        报告.A13重复释放稳定 = true;

        try {
            结构事务协调器 其它协调器(72);
            主信息仓库 其它主信息(102, 其它协调器.生成接线());
            节点仓库 不同域节点(其它主信息, 202, 接线);
            (void)不同域节点;
        } catch (...) {
            报告.A03参与者同域拒绝 = true;
        }
        主信息仓库 旧主信息(103);
        节点仓库 旧节点(旧主信息, 203);
        const auto 旧主信息句柄 = 旧主信息.创建主信息();
        const auto 旧节点句柄 = 旧节点.创建节点(节点类型::基础信息, 旧主信息句柄);
        报告.A14未接域旧路径 = 句柄有效(旧主信息句柄) && 句柄有效(旧节点句柄);
    } catch (...) {
    }
    const std::array 结果组{
        报告.A01数据桥与许可身份, 报告.A02共享与独占隔离, 报告.A03参与者同域拒绝,
        报告.A04伪造令牌拒绝, 报告.A05无令牌重入拒绝, 报告.A06主信息与节点令牌路径,
        报告.A07关系令牌路径, 报告.A08索引令牌路径, 报告.A09关系读取端点冻结,
        报告.A10索引读取端点冻结, 报告.A11独占删除路径, 报告.A12跨线程令牌拒绝,
        报告.A13重复释放稳定, 报告.A14未接域旧路径};
    for (const bool 通过 : 结果组) if (!通过) ++报告.失败数量;
    报告.失败数量 -= 14;
    报告.总通过 = 报告.失败数量 == 0;
    return 报告;
}

}
