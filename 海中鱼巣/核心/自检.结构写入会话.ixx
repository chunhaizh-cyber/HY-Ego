// 文件规则：结构写入会话自检只承载隔离、提交和精确撤销验收，不得成为生产依赖。
module;

#include "主信息仓库.h"
#include "节点仓库.h"
#include "关系仓库.h"
#include "索引仓库.h"

#include <algorithm>
#include <array>
#include <atomic>
#include <chrono>
#include <cstddef>
#include <iostream>
#include <limits>
#include <optional>
#include <span>
#include <stdexcept>
#include <thread>
#include <type_traits>
#include <utility>
#include <vector>

export module 海中鱼巣.核心.自检.结构写入会话;

import 海中鱼巣.核心.协调.结构事务;
import 海中鱼巣.核心.执行器.结构写入;
import 海中鱼巣.自检.运行器;

export namespace 海中鱼巣 {

namespace 结构写入会话自检内部 {

struct 结构数量 {
    std::uint64_t 节点 = 0;
    std::uint64_t 关系 = 0;
    std::uint64_t 索引 = 0;

    bool operator==(const 结构数量&) const = default;
};

#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
enum class 原子收口参与者模式 : std::uint8_t {
    正常,
    准备拒绝,
    准备抛出,
    确认拒绝,
    确认抛出,
    撤销拒绝,
    撤销抛出
};

class 原子收口自检参与者 final : public 结构写入事务参与者 {
public:
    explicit 原子收口自检参与者(
        原子收口参与者模式 模式 = 原子收口参与者模式::正常,
        std::size_t 登记序号 = 0,
        std::vector<std::size_t>* 顺序记录 = nullptr)
        : 模式_(模式), 登记序号_(登记序号), 顺序记录_(顺序记录) {
    }

    bool 已准备 = false;
    bool 已确认 = false;
    bool 已发布 = false;
    bool 已尝试撤销 = false;

private:
    结构写入结果 准备提交(const 结构提交准备只读视图&) override {
        已准备 = true;
        记录动作(10);
        if (模式_ == 原子收口参与者模式::准备抛出) throw std::runtime_error("F07参与者准备抛出");
        return 模式_ == 原子收口参与者模式::准备拒绝
            ? 结构写入结果{结构写入状态::许可拒绝, 0, 0, 0}
            : 结构写入结果{结构写入状态::候选已确认, 0, 0, 0};
    }

    结构写入结果 确认待发布() override {
        已确认 = true;
        记录动作(20);
        if (模式_ == 原子收口参与者模式::确认抛出) throw std::runtime_error("F08参与者确认抛出");
        return 模式_ == 原子收口参与者模式::确认拒绝
            ? 结构写入结果{结构写入状态::许可拒绝, 0, 0, 0}
            : 结构写入结果{结构写入状态::候选已确认, 0, 0, 0};
    }

    void 完成发布() noexcept override {
        已发布 = true;
        记录动作(40);
    }

    结构写入结果 完成撤销() override {
        已尝试撤销 = true;
        记录动作(30);
        if (模式_ == 原子收口参与者模式::撤销抛出) throw std::runtime_error("R01参与者撤销抛出");
        return 模式_ == 原子收口参与者模式::撤销拒绝
            ? 结构写入结果{结构写入状态::内部不一致, 0, 0, 0}
            : 结构写入结果{结构写入状态::候选已撤销, 0, 0, 0};
    }

    void 记录动作(std::size_t 动作) noexcept {
        if (顺序记录_ == nullptr) return;
        try {
            顺序记录_->push_back(动作 + 登记序号_);
        } catch (...) {
        }
    }

    原子收口参与者模式 模式_;
    std::size_t 登记序号_ = 0;
    std::vector<std::size_t>* 顺序记录_ = nullptr;
};

bool 关系记录逐字段相同(const 关系记录& 左, const 关系记录& 右) {
    return 左.关系编号 == 右.关系编号
        && 左.类型 == 右.类型
        && 左.源节点 == 右.源节点
        && 左.目标节点 == 右.目标节点
        && 左.顺序号 == 右.顺序号
        && 左.版本号 == 右.版本号
        && 左.状态 == 右.状态;
}

bool 运行原子故障场景(
    std::uint64_t 域编号,
    const 结构写入故障自检配置& 配置,
    原子收口参与者模式 参与者模式,
    结构写入状态 预期状态,
    bool 预期隔离) {
    结构事务协调器 协调器(域编号);
    const auto 接线 = 协调器.生成接线();
    主信息仓库 主信息(域编号 * 10 + 1, 接线);
    节点仓库 节点(主信息, 域编号 * 10 + 2, 接线);
    关系仓库 关系(节点, 域编号 * 10 + 3, 接线);
    索引仓库 索引(节点, 接线);
    结构写入执行器 执行器(接线, &主信息, &节点, &关系, &索引);

    std::array<主信息句柄, 3> 基线主信息{};
    std::array<节点句柄, 3> 基线节点{};
    关系句柄 基线关系;
    const auto 基线结果 = 执行器.执行([&](结构写入会话& 会话) {
        for (std::size_t 索引值 = 0; 索引值 < 基线节点.size(); ++索引值) {
            const auto 主结果 = 会话.创建主信息候选();
            if (!主结果.成功() || !主结果.值.has_value()) return;
            基线主信息[索引值] = *主结果.值;
            const auto 节点结果 = 会话.创建节点候选(节点类型::基础信息, 基线主信息[索引值]);
            if (!节点结果.成功() || !节点结果.值.has_value()) return;
            基线节点[索引值] = *节点结果.值;
        }
        const auto 关系结果 = 会话.创建关系(
            关系类型::引用, 基线节点[0], 基线节点[1]);
        if (!关系结果.成功() || !关系结果.值.has_value()) return;
        基线关系 = *关系结果.值;
        bool 已读回 = 会话.关系可读(基线关系);
        for (const auto& 主信息值 : 基线主信息) 已读回 = 会话.主信息可读(主信息值) && 已读回;
        for (const auto& 节点值 : 基线节点) 已读回 = 会话.节点可读(节点值) && 已读回;
        if (已读回) (void)会话.请求提交();
    });
    const auto 基线关系记录 = 关系.读取关系审计(基线关系);
    if (基线结果.状态 != 结构写入状态::已提交 || !基线关系记录.has_value()) return false;

    const 结构数量 前态{节点.有效节点数量(), 关系.有效关系数量(), 索引.有效主键数量()};
    原子收口自检参与者 参与者(参与者模式);
    std::array<主信息句柄, 2> 候选主信息{};
    std::array<节点句柄, 2> 候选节点{};
    关系句柄 候选关系;
    关系句柄 关系写后;
    const std::uint64_t 候选主键 = 域编号 * 1000 + 1;
    bool 候选已完整读回 = false;
    const auto 结果 = 执行器.执行原子收口故障自检(
        [&](结构写入会话& 会话) {
            for (std::size_t 索引值 = 0; 索引值 < 候选节点.size(); ++索引值) {
                const auto 主结果 = 会话.创建主信息候选();
                if (!主结果.成功() || !主结果.值.has_value()) return;
                候选主信息[索引值] = *主结果.值;
                const auto 节点结果 = 会话.创建节点候选(
                    索引值 == 0 ? 节点类型::状态 : 节点类型::特征,
                    候选主信息[索引值]);
                if (!节点结果.成功() || !节点结果.值.has_value()) return;
                候选节点[索引值] = *节点结果.值;
            }
            const auto 新关系 = 会话.创建关系(
                关系类型::引用, 候选节点[0], 候选节点[1]);
            const auto 绑定 = 会话.绑定主键(候选主键, 候选节点[0]);
            const auto 重挂 = 会话.重挂已发布关系(
                基线关系, 基线节点[0], 基线节点[2]);
            if (!新关系.成功() || !新关系.值.has_value() || !绑定.成功()
                || !重挂.成功() || !重挂.值.has_value()) return;
            候选关系 = *新关系.值;
            关系写后 = *重挂.值;
            候选已完整读回 = 会话.主信息可读(候选主信息[0])
                && 会话.主信息可读(候选主信息[1])
                && 会话.节点可读(候选节点[0])
                && 会话.节点可读(候选节点[1])
                && 会话.关系可读(候选关系)
                && 会话.主键绑定匹配(候选主键, 候选节点[0])
                && 会话.读取关系审计(关系写后).has_value();
            if (候选已完整读回) (void)会话.请求提交();
        },
        参与者,
        配置);

    if (结果.状态 != 预期状态 || !候选已完整读回 || 参与者.已发布) return false;
    if (预期隔离) {
        const auto 拒绝前序号 = 读取结构事务下个许可序号自检(接线);
        auto 隔离后共享 = 接线.取得共享许可(接线.运行期状态);
        auto 隔离后独占 = 接线.取得独占许可(接线.运行期状态);
        const auto 拒绝后序号 = 读取结构事务下个许可序号自检(接线);
        return 参与者.已尝试撤销 && 结构事务域已隔离自检(接线)
            && !隔离后共享.有效() && !隔离后独占.有效()
            && 拒绝前序号 != 0 && 拒绝后序号 == 拒绝前序号;
    }

    const 结构数量 后态{节点.有效节点数量(), 关系.有效关系数量(), 索引.有效主键数量()};
    const auto 恢复关系 = 关系.读取关系审计(基线关系);
    return 参与者.已尝试撤销 && 前态 == 后态
        && !主信息.读取主信息(候选主信息[0]).has_value()
        && !主信息.读取主信息(候选主信息[1]).has_value()
        && !节点.读取节点(候选节点[0]).has_value()
        && !节点.读取节点(候选节点[1]).has_value()
        && !关系.读取关系(候选关系).has_value()
        && !关系.读取关系审计(关系写后).has_value()
        && !索引.按主键查节点(候选主键).has_value()
        && 恢复关系.has_value()
        && 关系记录逐字段相同(*恢复关系, *基线关系记录);
}

struct 多参与者收口场景证据 {
    结构写入状态 状态 = 结构写入状态::入口拒绝;
    std::vector<std::size_t> 顺序;
    bool 已发布完整结构 = false;
    bool 已撤销为零结构 = false;
    bool 已隔离 = false;
};

多参与者收口场景证据 运行多参与者收口场景(
    std::uint64_t 域编号,
    原子收口参与者模式 第一模式,
    原子收口参与者模式 第二模式,
    const 结构写入故障自检配置* 故障配置 = nullptr) {
    结构事务协调器 协调器(域编号);
    const auto 接线 = 协调器.生成接线();
    主信息仓库 主信息(域编号 * 10 + 1, 接线);
    节点仓库 节点(主信息, 域编号 * 10 + 2, 接线);
    关系仓库 关系(节点, 域编号 * 10 + 3, 接线);
    索引仓库 索引(节点, 接线);
    结构写入执行器 执行器(接线, &主信息, &节点, &关系, &索引);

    多参与者收口场景证据 证据;
    证据.顺序.reserve(8);
    原子收口自检参与者 第一参与者(第一模式, 0, &证据.顺序);
    原子收口自检参与者 第二参与者(第二模式, 1, &证据.顺序);
    std::array<结构写入事务参与者*, 2> 参与者组{&第一参与者, &第二参与者};
    主信息句柄 候选主信息;
    节点句柄 候选节点;
    const std::uint64_t 主键 = 域编号 * 1000 + 1;
    const auto 业务回调 = [&](结构写入会话& 会话) {
        const auto 主结果 = 会话.创建主信息候选();
        if (!主结果.成功() || !主结果.值.has_value()) return;
        候选主信息 = *主结果.值;
        const auto 节点结果 = 会话.创建节点候选(节点类型::特征, 候选主信息);
        if (!节点结果.成功() || !节点结果.值.has_value()) return;
        候选节点 = *节点结果.值;
        if (!会话.绑定主键(主键, 候选节点).成功()) return;
        if (!会话.主信息可读(候选主信息)
            || !会话.节点可读(候选节点)
            || !会话.主键绑定匹配(主键, 候选节点)) return;
        (void)会话.请求提交();
    };
    const auto 结果 = 故障配置 == nullptr
        ? 执行器.执行(
            业务回调,
            std::span<结构写入事务参与者* const>(参与者组))
        : 执行器.执行原子收口故障自检(
            业务回调,
            std::span<结构写入事务参与者* const>(参与者组),
            *故障配置);
    证据.状态 = 结果.状态;
    证据.已发布完整结构 = 主信息.读取主信息(候选主信息).has_value()
        && 节点.读取节点(候选节点).has_value()
        && 索引.按主键查节点(主键) == std::optional<节点句柄>{候选节点};
    证据.已撤销为零结构 = !主信息.读取主信息(候选主信息).has_value()
        && !节点.读取节点(候选节点).has_value()
        && 节点.有效节点数量() == 0
        && 索引.有效主键数量() == 0;
    证据.已隔离 = 结构事务域已隔离自检(接线);
    return 证据;
}
#endif

}

自检单元结果 运行核心多参与者结构写入收口自检();

自检单元结果 运行结构写入会话自检() {
    using namespace 结构写入会话自检内部;

    static_assert(!std::is_default_constructible_v<结构写入会话>);
    static_assert(!std::is_copy_constructible_v<结构写入会话>);
    static_assert(!std::is_copy_assignable_v<结构写入会话>);
    static_assert(!std::is_move_constructible_v<结构写入会话>);
    static_assert(!std::is_move_assignable_v<结构写入会话>);
    static_assert(std::is_same_v<
        decltype(std::declval<结构写入会话&>().创建主信息候选()),
        带值结构写入结果<主信息句柄>>);
    static_assert(std::is_same_v<
        decltype(std::declval<结构写入会话&>().创建节点候选(节点类型::基础信息, 主信息句柄{})),
        带值结构写入结果<节点句柄>>);

    std::array<bool, 12> 验收{};
    try {
        结构事务协调器 协调器(710);
        const auto 接线 = 协调器.生成接线();
        主信息仓库 主信息(7101, 接线);
        节点仓库 节点(主信息, 7102, 接线);
        关系仓库 关系(节点, 7103, 接线);
        索引仓库 索引(节点, 接线);
        结构写入执行器 执行器(接线, &主信息, &节点, &关系, &索引);

        const auto 读取数量 = [&] {
            return 结构数量{节点.有效节点数量(), 关系.有效关系数量(), 索引.有效主键数量()};
        };

        验收[0] = 接线.已接域() && 执行器.有效();

        const auto 无效前 = 读取数量();
        bool 无效回调已运行 = false;
        结构写入执行器 无接线执行器({}, &主信息, &节点, &关系, &索引);
        const auto 无接线结果 = 无接线执行器.执行([&](结构写入会话&) { 无效回调已运行 = true; });
        结构写入执行器 缺仓库执行器(接线, &主信息, &节点, nullptr, &索引);
        const auto 缺仓库结果 = 缺仓库执行器.执行([&](结构写入会话&) { 无效回调已运行 = true; });
        验收[1] = 无接线结果.状态 == 结构写入状态::入口拒绝
            && 缺仓库结果.状态 == 结构写入状态::入口拒绝
            && !无效回调已运行 && 读取数量() == 无效前;

        bool 同线程共享重入已拒绝 = false;
        bool 同线程独占重入已拒绝 = false;
        const auto 单许可结果 = 执行器.执行([&](结构写入会话& 会话) {
            auto 共享重入 = 接线.取得共享许可(接线.运行期状态);
            auto 独占重入 = 接线.取得独占许可(接线.运行期状态);
            同线程共享重入已拒绝 = !共享重入.有效();
            同线程独占重入已拒绝 = !独占重入.有效();
            (void)会话.请求撤销();
        });
        验收[2] = 同线程共享重入已拒绝 && 同线程独占重入已拒绝
            && 单许可结果.状态 == 结构写入状态::候选已撤销;

        验收[3] = !std::is_default_constructible_v<结构写入会话>
            && !std::is_copy_constructible_v<结构写入会话>
            && !std::is_move_constructible_v<结构写入会话>;
        主信息句柄 未读回主信息;
        节点句柄 未读回节点;
        bool 未读回提交已拒绝 = false;
        const auto 未读回结果 = 执行器.执行([&](结构写入会话& 会话) {
            const auto 主结果 = 会话.创建主信息候选();
            if (!主结果.成功()) return;
            未读回主信息 = *主结果.值;
            const auto 节点结果 = 会话.创建节点候选(节点类型::基础信息, 未读回主信息);
            if (!节点结果.成功()) return;
            未读回节点 = *节点结果.值;
            未读回提交已拒绝 = !会话.请求提交();
        });
        验收[4] = std::is_same_v<
            decltype(std::declval<结构写入会话&>().创建主信息候选()),
            带值结构写入结果<主信息句柄>>
            && 未读回提交已拒绝 && 未读回结果.状态 == 结构写入状态::入口拒绝
            && !主信息.读取主信息(未读回主信息).has_value()
            && !节点.读取节点(未读回节点).has_value();

        主信息句柄 提交主信息甲;
        主信息句柄 提交主信息乙;
        节点句柄 提交节点甲;
        节点句柄 提交节点乙;
        关系句柄 提交关系;
        bool 提交内读回 = false;
        const auto 提交结果 = 执行器.执行([&](结构写入会话& 会话) {
            const auto 主甲 = 会话.创建主信息候选();
            const auto 主乙 = 会话.创建主信息候选();
            if (!主甲.成功() || !主乙.成功()) return;
            提交主信息甲 = *主甲.值;
            提交主信息乙 = *主乙.值;
            const auto 节甲 = 会话.创建节点候选(节点类型::基础信息, 提交主信息甲);
            const auto 节乙 = 会话.创建节点候选(节点类型::特征, 提交主信息乙);
            if (!节甲.成功() || !节乙.成功()) return;
            提交节点甲 = *节甲.值;
            提交节点乙 = *节乙.值;
            const auto 关系结果 = 会话.创建关系(关系类型::引用, 提交节点甲, 提交节点乙);
            const auto 索引结果 = 会话.绑定主键(710001, 提交节点甲);
            if (!关系结果.成功() || !索引结果.成功()) return;
            提交关系 = *关系结果.值;
            提交内读回 = 会话.主信息可读(提交主信息甲) && 会话.主信息可读(提交主信息乙)
                && 会话.节点可读(提交节点甲) && 会话.节点可读(提交节点乙)
                && 会话.关系可读(提交关系) && 会话.主键绑定匹配(710001, 提交节点甲);
            if (提交内读回) (void)会话.请求提交();
        });
        验收[5] = 句柄有效(提交关系) && 提交内读回
            && 索引.按主键查节点(710001) == std::optional<节点句柄>{提交节点甲};
        验收[6] = 提交结果.状态 == 结构写入状态::已提交
            && 主信息.读取主信息(提交主信息甲).has_value()
            && 主信息.读取主信息(提交主信息乙).has_value()
            && 节点.读取节点(提交节点甲).has_value()
            && 节点.读取节点(提交节点乙).has_value()
            && 关系.读取关系(提交关系).has_value();

        const auto 撤销前 = 读取数量();
        主信息句柄 撤销主信息甲;
        主信息句柄 撤销主信息乙;
        节点句柄 撤销节点甲;
        节点句柄 撤销节点乙;
        关系句柄 撤销关系;
        const auto 撤销结果 = 执行器.执行([&](结构写入会话& 会话) {
            const auto 主甲 = 会话.创建主信息候选();
            const auto 主乙 = 会话.创建主信息候选();
            if (!主甲.成功() || !主乙.成功()) return;
            撤销主信息甲 = *主甲.值;
            撤销主信息乙 = *主乙.值;
            const auto 节甲 = 会话.创建节点候选(节点类型::基础信息, 撤销主信息甲);
            const auto 节乙 = 会话.创建节点候选(节点类型::特征, 撤销主信息乙);
            if (!节甲.成功() || !节乙.成功()) return;
            撤销节点甲 = *节甲.值;
            撤销节点乙 = *节乙.值;
            const auto 关系结果 = 会话.创建关系(关系类型::引用, 撤销节点甲, 撤销节点乙);
            if (!关系结果.成功() || !会话.绑定主键(710002, 撤销节点甲).成功()) return;
            撤销关系 = *关系结果.值;
            (void)会话.请求撤销();
        });
        验收[7] = 撤销结果.状态 == 结构写入状态::候选已撤销 && 读取数量() == 撤销前
            && !主信息.读取主信息(撤销主信息甲).has_value()
            && !主信息.读取主信息(撤销主信息乙).has_value()
            && !节点.读取节点(撤销节点甲).has_value()
            && !节点.读取节点(撤销节点乙).has_value()
            && !关系.读取关系(撤销关系).has_value()
            && !索引.按主键查节点(710002).has_value();

        const auto 异常前 = 读取数量();
        主信息句柄 异常主信息;
        节点句柄 异常节点甲;
        节点句柄 异常节点乙;
        关系句柄 异常关系;
        const auto 异常结果 = 执行器.执行([&](结构写入会话& 会话) {
            const auto 主甲 = 会话.创建主信息候选();
            const auto 主乙 = 会话.创建主信息候选();
            if (!主甲.成功() || !主乙.成功()) throw std::runtime_error("候选创建失败");
            异常主信息 = *主甲.值;
            const auto 节甲 = 会话.创建节点候选(节点类型::基础信息, *主甲.值);
            const auto 节乙 = 会话.创建节点候选(节点类型::特征, *主乙.值);
            if (!节甲.成功() || !节乙.成功()) throw std::runtime_error("节点创建失败");
            异常节点甲 = *节甲.值;
            异常节点乙 = *节乙.值;
            const auto 关系结果 = 会话.创建关系(关系类型::引用, 异常节点甲, 异常节点乙);
            if (!关系结果.成功() || !会话.绑定主键(710003, 异常节点甲).成功()) {
                throw std::runtime_error("关系索引创建失败");
            }
            异常关系 = *关系结果.值;
            throw std::runtime_error("故障注入");
        });
        验收[8] = 异常结果.状态 == 结构写入状态::内部不一致 && 读取数量() == 异常前
            && !主信息.读取主信息(异常主信息).has_value()
            && !节点.读取节点(异常节点甲).has_value()
            && !节点.读取节点(异常节点乙).has_value()
            && !关系.读取关系(异常关系).has_value()
            && !索引.按主键查节点(710003).has_value();

        主信息句柄 隔离主信息;
        节点句柄 隔离节点;
        std::atomic<bool> 跨线程会话已拒绝 = false;
        std::atomic<bool> 读者已开始 = false;
        std::atomic<bool> 读者已完成 = false;
        std::atomic<bool> 读者最终可读 = false;
        bool 许可释放前未完成 = false;
        bool 同线程无令牌已拒绝 = false;
        bool 会话内令牌可读 = false;
        std::thread 等待读者;
        const auto 隔离结果 = 执行器.执行([&](结构写入会话& 会话) {
            const auto 主结果 = 会话.创建主信息候选();
            if (!主结果.成功()) return;
            隔离主信息 = *主结果.值;
            const auto 节点结果 = 会话.创建节点候选(节点类型::基础信息, 隔离主信息);
            if (!节点结果.成功()) return;
            隔离节点 = *节点结果.值;

            std::thread 跨线程调用([&] { 跨线程会话已拒绝.store(!会话.节点可读(隔离节点)); });
            跨线程调用.join();
            会话内令牌可读 = 会话.主信息可读(隔离主信息) && 会话.节点可读(隔离节点);
            同线程无令牌已拒绝 = !节点.读取节点(隔离节点).has_value();

            等待读者 = std::thread([&] {
                读者已开始.store(true);
                读者最终可读.store(节点.读取节点(隔离节点).has_value());
                读者已完成.store(true);
            });
            while (!读者已开始.load()) std::this_thread::yield();
            std::this_thread::sleep_for(std::chrono::milliseconds(40));
            许可释放前未完成 = !读者已完成.load();
            if (会话内令牌可读 && 同线程无令牌已拒绝 && 许可释放前未完成) {
                (void)会话.请求提交();
            }
        });
        if (等待读者.joinable()) 等待读者.join();
        验收[9] = 隔离结果.状态 == 结构写入状态::已提交
            && 跨线程会话已拒绝.load() && 会话内令牌可读 && 同线程无令牌已拒绝
            && 许可释放前未完成 && 读者已完成.load() && 读者最终可读.load();

        验收[10] = std::is_same_v<
            decltype(std::declval<结构写入会话&>().绑定主键(0, 节点句柄{})),
            结构写入结果>
            && !std::is_move_constructible_v<结构写入会话>;

        auto 回归许可 = 接线.取得共享许可(接线.运行期状态);
        验收[11] = 回归许可.有效()
            && 节点.读取节点(提交节点甲, 回归许可.读取令牌()).has_value()
            && 节点.读取节点(隔离节点, 回归许可.读取令牌()).has_value()
            && 关系.读取关系(提交关系, 回归许可.读取令牌()).has_value()
            && 索引.按主键查节点(710001, 回归许可.读取令牌())
                == std::optional<节点句柄>{提交节点甲};
    } catch (...) {
    }

    constexpr std::array<const char*, 12> 名称组{
        "三个真模块与有效同域接线",
        "无效接线和缺仓库写前拒绝",
        "一次独占许可与同线程重入拒绝",
        "会话不可默认构造复制移动",
        "候选对象不从窄结果泄露",
        "关系句柄与索引完整绑定对",
        "正常提交确认与释放后读回",
        "显式撤销精确逆序无残留",
        "异常撤销精确逆序并释放许可",
        "独占隔离无令牌与跨线程拒绝",
        "公开能力面不含原始令牌逃生口",
        "既有结构事务和仓库合同回归"};
    std::size_t 失败数量 = 0;
    for (std::size_t 索引值 = 0; 索引值 < 验收.size(); ++索引值) {
        if (!验收[索引值]) ++失败数量;
        std::cout << "SERVICE-DATA-S1-A" << (索引值 + 1 < 10 ? "0" : "") << 索引值 + 1
            << ' ' << 名称组[索引值] << ": " << (验收[索引值] ? "通过" : "失败") << '\n';
    }
    return {"SERVICE-DATA-S1", "不透明结构写入会话与执行器", 失败数量 == 0, 验收.size(), 失败数量};
}

自检单元结果 运行结构写入会话材料能力自检(
    bool 既有会话回归通过,
    bool 存在场景回归通过) {
    using namespace 结构写入会话自检内部;

    static_assert(std::is_same_v<
        decltype(std::declval<结构写入会话&>().写入候选I64值(主信息句柄{}, 0, 0)),
        结构写入结果>);
    static_assert(std::is_same_v<
        decltype(std::declval<结构写入会话&>().候选I64值匹配(主信息句柄{}, 0, 0)),
        bool>);
    static_assert(std::is_same_v<
        decltype(std::declval<const 结构写入会话&>().读取节点类型(节点句柄{})),
        std::optional<节点类型>>);
    static_assert(std::is_same_v<
        decltype(std::declval<const 结构写入会话&>().读取节点主信息(节点句柄{})),
        std::optional<主信息句柄>>);
    static_assert(std::is_same_v<
        decltype(std::declval<const 结构写入会话&>().读取I64值(主信息句柄{}, 0)),
        std::optional<std::int64_t>>);
    static_assert(std::is_same_v<
        decltype(std::declval<const 结构写入会话&>().读取关系记录组(节点句柄{}, 关系类型::引用)),
        std::vector<关系记录>>);

    std::array<bool, 14> 验收{};
    try {
        结构事务协调器 协调器(725);
        const auto 接线 = 协调器.生成接线();
        主信息仓库 主信息(72501, 接线);
        节点仓库 节点(主信息, 72502, 接线);
        关系仓库 关系(节点, 72503, 接线);
        索引仓库 索引(节点, 接线);
        结构写入执行器 执行器(接线, &主信息, &节点, &关系, &索引);

        const auto 读取数量 = [&] {
            return 结构数量{节点.有效节点数量(), 关系.有效关系数量(), 索引.有效主键数量()};
        };

        验收[0] = 接线.已接域() && 执行器.有效()
            && !std::is_default_constructible_v<结构写入会话>
            && !std::is_copy_constructible_v<结构写入会话>
            && !std::is_move_constructible_v<结构写入会话>;

        主信息句柄 既有主信息;
        const auto 既有主信息结果 = 执行器.执行([&](结构写入会话& 会话) {
            const auto 结果 = 会话.创建主信息候选();
            if (!结果.成功()) return;
            既有主信息 = *结果.值;
            if (会话.主信息可读(既有主信息)) (void)会话.请求提交();
        });
        主信息句柄 前序候选;
        const auto 前序候选结果 = 执行器.执行([&](结构写入会话& 会话) {
            const auto 结果 = 会话.创建主信息候选();
            if (结果.成功()) 前序候选 = *结果.值;
        });
        结构写入结果 既有写入;
        结构写入结果 前序写入;
        const auto 非自有写入结果 = 执行器.执行([&](结构写入会话& 会话) {
            既有写入 = 会话.写入候选I64值(既有主信息, 0, 101);
            前序写入 = 会话.写入候选I64值(前序候选, 0, 102);
            (void)会话.请求撤销();
        });
        验收[1] = 既有主信息结果.状态 == 结构写入状态::已提交
            && 前序候选结果.状态 == 结构写入状态::入口拒绝
            && 非自有写入结果.状态 == 结构写入状态::候选已撤销
            && 既有写入.状态 == 结构写入状态::入口拒绝
            && 前序写入.状态 == 结构写入状态::入口拒绝
            && !主信息.读取I64值(既有主信息, 0).has_value()
            && !主信息.读取主信息(前序候选).has_value();

        主信息句柄 幂等主信息;
        结构写入结果 首次值写入;
        结构写入结果 重复同值写入;
        结构写入结果 重复异值写入;
        bool 幂等值已匹配 = false;
        const auto 幂等写入结果 = 执行器.执行([&](结构写入会话& 会话) {
            const auto 结果 = 会话.创建主信息候选();
            if (!结果.成功()) return;
            幂等主信息 = *结果.值;
            首次值写入 = 会话.写入候选I64值(幂等主信息, 1, 111);
            重复同值写入 = 会话.写入候选I64值(幂等主信息, 1, 111);
            重复异值写入 = 会话.写入候选I64值(幂等主信息, 1, 112);
            幂等值已匹配 = 会话.候选I64值匹配(幂等主信息, 1, 111);
            if (会话.主信息可读(幂等主信息) && 幂等值已匹配) (void)会话.请求提交();
        });
        验收[2] = 首次值写入.状态 == 结构写入状态::已提交
            && 重复同值写入.状态 == 结构写入状态::幂等读回
            && 重复异值写入.状态 == 结构写入状态::入口拒绝
            && 幂等值已匹配 && 幂等写入结果.状态 == 结构写入状态::已提交
            && 主信息.读取I64值(幂等主信息, 1) == std::optional<std::int64_t>{111};

        主信息句柄 未匹配主信息;
        bool 未匹配提交已拒绝 = false;
        const auto 未匹配结果 = 执行器.执行([&](结构写入会话& 会话) {
            const auto 结果 = 会话.创建主信息候选();
            if (!结果.成功()) return;
            未匹配主信息 = *结果.值;
            if (!会话.写入候选I64值(未匹配主信息, 0, 201).成功()) return;
            if (!会话.主信息可读(未匹配主信息)) return;
            未匹配提交已拒绝 = !会话.请求提交();
        });
        验收[3] = 未匹配提交已拒绝 && 未匹配结果.状态 == 结构写入状态::入口拒绝
            && !主信息.读取主信息(未匹配主信息).has_value()
            && !主信息.读取I64值(未匹配主信息, 0).has_value();

        主信息句柄 材料主信息;
        节点句柄 材料节点;
        bool 多槽位同令牌读回 = false;
        const auto 多槽位结果 = 执行器.执行([&](结构写入会话& 会话) {
            const auto 主结果 = 会话.创建主信息候选();
            if (!主结果.成功()) return;
            材料主信息 = *主结果.值;
            const auto 节点结果 = 会话.创建节点候选(节点类型::状态, 材料主信息);
            if (!节点结果.成功()) return;
            材料节点 = *节点结果.值;
            const auto 写零 = 会话.写入候选I64值(材料主信息, 0, -12);
            const auto 写三 = 会话.写入候选I64值(材料主信息, 3, 44);
            多槽位同令牌读回 = 写零.成功() && 写三.成功()
                && 会话.候选I64值匹配(材料主信息, 0, -12)
                && 会话.候选I64值匹配(材料主信息, 3, 44)
                && 会话.读取I64值(材料主信息, 0) == std::optional<std::int64_t>{-12}
                && 会话.读取I64值(材料主信息, 3) == std::optional<std::int64_t>{44}
                && 会话.主信息可读(材料主信息) && 会话.节点可读(材料节点);
            if (多槽位同令牌读回) (void)会话.请求提交();
        });
        验收[4] = 多槽位结果.状态 == 结构写入状态::已提交 && 多槽位同令牌读回
            && 主信息.读取I64值(材料主信息, 0) == std::optional<std::int64_t>{-12}
            && 主信息.读取I64值(材料主信息, 3) == std::optional<std::int64_t>{44};

        const auto 收口前 = 读取数量();
        主信息句柄 显式撤销主信息;
        const auto 显式撤销结果 = 执行器.执行([&](结构写入会话& 会话) {
            const auto 结果 = 会话.创建主信息候选();
            if (!结果.成功()) return;
            显式撤销主信息 = *结果.值;
            if (!会话.写入候选I64值(显式撤销主信息, 0, 301).成功()) return;
            if (!会话.候选I64值匹配(显式撤销主信息, 0, 301)) return;
            (void)会话.请求撤销();
        });
        主信息句柄 无决定主信息;
        const auto 无决定结果 = 执行器.执行([&](结构写入会话& 会话) {
            const auto 结果 = 会话.创建主信息候选();
            if (!结果.成功()) return;
            无决定主信息 = *结果.值;
            if (!会话.写入候选I64值(无决定主信息, 0, 302).成功()) return;
            (void)会话.候选I64值匹配(无决定主信息, 0, 302);
        });
        主信息句柄 失败主信息;
        结构写入结果 失败写入;
        const auto 写入失败结果 = 执行器.执行([&](结构写入会话& 会话) {
            const auto 结果 = 会话.创建主信息候选();
            if (!结果.成功()) return;
            失败主信息 = *结果.值;
            失败写入 = 会话.写入候选I64值(
                失败主信息, std::numeric_limits<std::uint64_t>::max(), 303);
        });
        主信息句柄 异常主信息;
        const auto 异常结果 = 执行器.执行([&](结构写入会话& 会话) {
            const auto 结果 = 会话.创建主信息候选();
            if (!结果.成功()) throw std::runtime_error("主信息候选创建失败");
            异常主信息 = *结果.值;
            if (!会话.写入候选I64值(异常主信息, 0, 304).成功()) {
                throw std::runtime_error("候选值写入失败");
            }
            throw std::runtime_error("候选值异常收口故障注入");
        });
        验收[5] = 显式撤销结果.状态 == 结构写入状态::候选已撤销
            && 无决定结果.状态 == 结构写入状态::入口拒绝
            && 失败写入.状态 == 结构写入状态::内部不一致
            && 写入失败结果.状态 == 结构写入状态::内部不一致
            && 异常结果.状态 == 结构写入状态::内部不一致
            && 读取数量() == 收口前
            && !主信息.读取主信息(显式撤销主信息).has_value()
            && !主信息.读取主信息(无决定主信息).has_value()
            && !主信息.读取主信息(失败主信息).has_value()
            && !主信息.读取主信息(异常主信息).has_value();

        std::optional<节点类型> 读取类型;
        std::optional<主信息句柄> 读取主信息锚点;
        std::optional<std::int64_t> 读取值;
        const auto 材料读取结果 = 执行器.执行([&](结构写入会话& 会话) {
            读取类型 = 会话.读取节点类型(材料节点);
            读取主信息锚点 = 会话.读取节点主信息(材料节点);
            读取值 = 会话.读取I64值(材料主信息, 3);
            (void)会话.请求撤销();
        });
        验收[6] = 材料读取结果.状态 == 结构写入状态::候选已撤销
            && 读取类型 == std::optional<节点类型>{节点类型::状态}
            && 读取主信息锚点 == std::optional<主信息句柄>{材料主信息}
            && 读取值 == std::optional<std::int64_t>{44};

        主信息句柄 目标主信息甲;
        主信息句柄 目标主信息乙;
        节点句柄 目标节点甲;
        节点句柄 目标节点乙;
        关系句柄 关系甲;
        关系句柄 关系乙;
        bool 关系材料稳定 = false;
        const auto 关系材料结果 = 执行器.执行([&](结构写入会话& 会话) {
            const auto 主甲 = 会话.创建主信息候选();
            const auto 主乙 = 会话.创建主信息候选();
            if (!主甲.成功() || !主乙.成功()) return;
            目标主信息甲 = *主甲.值;
            目标主信息乙 = *主乙.值;
            const auto 节甲 = 会话.创建节点候选(节点类型::动态, 目标主信息甲);
            const auto 节乙 = 会话.创建节点候选(节点类型::因果引用, 目标主信息乙);
            if (!节甲.成功() || !节乙.成功()) return;
            目标节点甲 = *节甲.值;
            目标节点乙 = *节乙.值;
            const auto 写关系甲 = 会话.创建关系(关系类型::引用, 材料节点, 目标节点甲, 20);
            const auto 写关系乙 = 会话.创建关系(关系类型::引用, 材料节点, 目标节点乙, 10);
            if (!写关系甲.成功() || !写关系乙.成功()) return;
            关系甲 = *写关系甲.值;
            关系乙 = *写关系乙.值;
            const auto 记录组 = 会话.读取关系记录组(材料节点, 关系类型::引用);
            关系材料稳定 = 记录组.size() == 2
                && 记录组[0].关系编号 == 关系甲.关系编号
                && 记录组[1].关系编号 == 关系乙.关系编号
                && 记录组[0].关系编号 < 记录组[1].关系编号
                && 记录组[0].源节点 == 材料节点 && 记录组[0].目标节点 == 目标节点甲
                && 记录组[1].源节点 == 材料节点 && 记录组[1].目标节点 == 目标节点乙
                && 会话.关系可读(关系甲) && 会话.关系可读(关系乙)
                && 会话.主信息可读(目标主信息甲) && 会话.主信息可读(目标主信息乙)
                && 会话.节点可读(目标节点甲) && 会话.节点可读(目标节点乙);
            if (关系材料稳定) (void)会话.请求提交();
        });
        验收[7] = 关系材料结果.状态 == 结构写入状态::已提交 && 关系材料稳定
            && 关系.读取关系(关系甲).has_value() && 关系.读取关系(关系乙).has_value();

        节点句柄 过期节点 = 材料节点;
        ++过期节点.版本号;
        节点句柄 错仓节点 = 材料节点;
        ++错仓节点.仓库编号;
        主信息句柄 过期主信息 = 材料主信息;
        ++过期主信息.版本号;
        std::atomic<bool> 跨线程窄入口已拒绝 = false;
        bool 决定后读取已拒绝 = false;
        const auto 拒绝结果 = 执行器.执行([&](结构写入会话& 会话) {
            const bool 当前线程拒绝 = !会话.读取节点类型({}).has_value()
                && !会话.读取节点主信息(过期节点).has_value()
                && !会话.读取节点类型(错仓节点).has_value()
                && !会话.读取I64值(过期主信息, 0).has_value()
                && 会话.读取关系记录组({}, 关系类型::引用).empty()
                && 会话.读取关系记录组(材料节点, static_cast<关系类型>(999)).empty()
                && 会话.写入候选I64值({}, 0, 0).状态 == 结构写入状态::入口拒绝;
            std::thread 跨线程([&] {
                跨线程窄入口已拒绝.store(
                    !会话.读取节点类型(材料节点).has_value()
                    && !会话.读取节点主信息(材料节点).has_value()
                    && !会话.读取I64值(材料主信息, 0).has_value()
                    && 会话.读取关系记录组(材料节点, 关系类型::引用).empty()
                    && 会话.写入候选I64值(材料主信息, 0, 0).状态 == 结构写入状态::入口拒绝);
            });
            跨线程.join();
            if (!当前线程拒绝 || !跨线程窄入口已拒绝.load()) return;
            (void)会话.请求撤销();
            决定后读取已拒绝 = !会话.读取节点类型(材料节点).has_value()
                && !会话.读取I64值(材料主信息, 0).has_value()
                && 会话.读取关系记录组(材料节点, 关系类型::引用).empty();
        });
        验收[8] = 拒绝结果.状态 == 结构写入状态::候选已撤销
            && 跨线程窄入口已拒绝.load() && 决定后读取已拒绝;

        主信息句柄 隔离值主信息;
        节点句柄 隔离值节点;
        std::atomic<bool> 共享读者已开始 = false;
        std::atomic<bool> 共享读者已完成 = false;
        std::atomic<bool> 共享读者最终可读 = false;
        bool 许可释放前未完成 = false;
        bool 同线程无令牌重入已拒绝 = false;
        std::thread 共享读者;
        const auto 隔离值结果 = 执行器.执行([&](结构写入会话& 会话) {
            const auto 主结果 = 会话.创建主信息候选();
            if (!主结果.成功()) return;
            隔离值主信息 = *主结果.值;
            const auto 节点结果 = 会话.创建节点候选(节点类型::状态, 隔离值主信息);
            if (!节点结果.成功()) return;
            隔离值节点 = *节点结果.值;
            if (!会话.写入候选I64值(隔离值主信息, 0, 55).成功()
                || !会话.候选I64值匹配(隔离值主信息, 0, 55)
                || !会话.主信息可读(隔离值主信息)
                || !会话.节点可读(隔离值节点)) return;
            同线程无令牌重入已拒绝 = !主信息.读取I64值(隔离值主信息, 0).has_value()
                && !节点.读取节点(隔离值节点).has_value();
            共享读者 = std::thread([&] {
                共享读者已开始.store(true);
                共享读者最终可读.store(
                    主信息.读取I64值(隔离值主信息, 0) == std::optional<std::int64_t>{55}
                    && 节点.读取节点(隔离值节点).has_value());
                共享读者已完成.store(true);
            });
            while (!共享读者已开始.load()) std::this_thread::yield();
            std::this_thread::sleep_for(std::chrono::milliseconds(40));
            许可释放前未完成 = !共享读者已完成.load();
            if (同线程无令牌重入已拒绝 && 许可释放前未完成) (void)会话.请求提交();
        });
        if (共享读者.joinable()) 共享读者.join();
        验收[9] = 隔离值结果.状态 == 结构写入状态::已提交
            && 同线程无令牌重入已拒绝 && 许可释放前未完成
            && 共享读者已完成.load() && 共享读者最终可读.load();

        验收[10] = std::is_same_v<
            decltype(std::declval<结构写入会话&>().创建关系(
                关系类型::引用, 节点句柄{}, 节点句柄{})),
            带值结构写入结果<关系句柄>>
            && std::is_same_v<
                decltype(std::declval<结构写入会话&>().绑定主键(0, 节点句柄{})),
                结构写入结果>
            && !std::is_move_constructible_v<结构写入会话>;
        验收[11] = 既有会话回归通过;
        验收[12] = 存在场景回归通过;
        验收[13] = true;
        for (std::size_t 索引值 = 0; 索引值 < 13; ++索引值) {
            验收[13] = 验收[13] && 验收[索引值];
        }
    } catch (...) {
    }

    constexpr std::array<const char*, 14> 名称组{
        "公开窄能力和值式签名",
        "仅本会话候选允许值写入",
        "同槽同值幂等异值拒绝",
        "候选值未读回拒绝提交",
        "多槽位写入匹配并提交",
        "撤销无决定失败异常无残留",
        "节点主信息和值材料同令牌读取",
        "关系记录组稳定且完整句柄可复核",
        "无效过期错仓跨线程和决定后拒绝",
        "独占隔离与无令牌重入拒绝",
        "执行器仓库事务公开合同未扩张",
        "SERVICE-DATA-S1-A01至A12回归",
        "EXIST-SCENE-S1-A01至A16回归",
        "CORE-SESSION-S2局部总成完整"};
    std::size_t 失败数量 = 0;
    for (std::size_t 索引值 = 0; 索引值 < 验收.size(); ++索引值) {
        if (!验收[索引值]) ++失败数量;
        std::cout << "CORE-SESSION-S2-A" << (索引值 + 1 < 10 ? "0" : "") << 索引值 + 1
            << ' ' << 名称组[索引值] << ": " << (验收[索引值] ? "通过" : "失败") << '\n';
    }
    return {"CORE-SESSION-S2", "不透明结构写入会话材料能力扩展", 失败数量 == 0, 验收.size(), 失败数量};
}

#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
自检单元结果 运行结构写入会话概念图只读材料扩展自检(
    bool 会话材料回归通过,
    bool 语义基础回归通过) {
    using namespace 结构写入会话自检内部;

    static_assert(std::is_same_v<
        decltype(std::declval<const 结构写入会话&>().读取节点主键组(节点句柄{})),
        std::vector<std::uint64_t>>);
    static_assert(std::is_same_v<
        decltype(std::declval<const 结构写入会话&>().读取来源关系记录组(
            节点句柄{}, 关系类型::引用)),
        std::vector<关系记录>>);
    static_assert(!std::is_pointer_v<
        decltype(std::declval<const 结构写入会话&>().读取节点主键组(节点句柄{}))>);
    static_assert(!std::is_pointer_v<
        decltype(std::declval<const 结构写入会话&>().读取来源关系记录组(
            节点句柄{}, 关系类型::引用))>);

    std::array<bool, 12> 验收{};
    try {
        constexpr std::uint64_t 关系仓库编号 = 75203;
        结构事务协调器 协调器(752);
        const auto 接线 = 协调器.生成接线();
        主信息仓库 主信息(75201, 接线);
        节点仓库 节点(主信息, 75202, 接线);
        关系仓库 关系(节点, 关系仓库编号, 接线);
        索引仓库 索引(节点, 接线);
        结构写入执行器 执行器(接线, &主信息, &节点, &关系, &索引);

        const auto 读取数量 = [&] {
            return 结构数量{节点.有效节点数量(), 关系.有效关系数量(), 索引.有效主键数量()};
        };
        const auto 记录匹配 = [](const 关系记录& 记录, 关系句柄 句柄,
                                   节点句柄 源节点, 节点句柄 目标节点) {
            return 句柄有效(句柄) && 记录.关系编号 == 句柄.关系编号
                && 记录.版本号 == 句柄.版本号 && 记录.状态 == 记录状态::有效
                && 记录.类型 == 关系类型::引用 && 记录.源节点 == 源节点
                && 记录.目标节点 == 目标节点;
        };
        const auto 记录相同 = [](const 关系记录& 左, const 关系记录& 右) {
            return 左.关系编号 == 右.关系编号 && 左.版本号 == 右.版本号
                && 左.状态 == 右.状态 && 左.类型 == 右.类型
                && 左.源节点 == 右.源节点 && 左.目标节点 == 右.目标节点
                && 左.顺序号 == 右.顺序号;
        };

        验收[0] = 接线.已接域() && 执行器.有效()
            && std::is_same_v<
                decltype(std::declval<const 结构写入会话&>().读取节点主键组(节点句柄{})),
                std::vector<std::uint64_t>>
            && std::is_same_v<
                decltype(std::declval<const 结构写入会话&>().读取来源关系记录组(
                    节点句柄{}, 关系类型::引用)),
                std::vector<关系记录>>;

        const auto 创建前 = 读取数量();
        主信息句柄 主信息甲;
        主信息句柄 主信息乙;
        主信息句柄 主信息丙;
        主信息句柄 主信息丁;
        节点句柄 节点甲;
        节点句柄 节点乙;
        节点句柄 节点丙;
        节点句柄 节点丁;
        关系句柄 关系甲乙;
        关系句柄 关系丁乙;
        关系句柄 关系乙丙;
        std::vector<std::uint64_t> 甲主键组;
        std::vector<std::uint64_t> 乙主键组;
        std::vector<关系记录> 甲正向组;
        std::vector<关系记录> 甲来源组;
        std::vector<关系记录> 乙正向组;
        std::vector<关系记录> 乙来源组;
        std::vector<关系记录> 丙来源组;
        bool 创建内完整 = false;
        const auto 创建结果 = 执行器.执行([&](结构写入会话& 会话) {
            const auto 创建节点 = [&](主信息句柄& 主信息输出, 节点句柄& 节点输出) {
                const auto 主结果 = 会话.创建主信息候选();
                if (!主结果.成功() || !主结果.值.has_value()) return false;
                主信息输出 = *主结果.值;
                const auto 节点结果 = 会话.创建节点候选(节点类型::基础信息, 主信息输出);
                if (!节点结果.成功() || !节点结果.值.has_value()) return false;
                节点输出 = *节点结果.值;
                return 会话.主信息可读(主信息输出) && 会话.节点可读(节点输出);
            };
            if (!创建节点(主信息甲, 节点甲) || !创建节点(主信息乙, 节点乙)
                || !创建节点(主信息丙, 节点丙) || !创建节点(主信息丁, 节点丁)) return;
            const auto 键甲 = 会话.绑定主键(752001, 节点甲);
            const auto 键乙一 = 会话.绑定主键(752002, 节点乙);
            const auto 键乙二 = 会话.绑定主键(752003, 节点乙);
            const auto 键丙 = 会话.绑定主键(752004, 节点丙);
            if (!键甲.成功() || !键乙一.成功() || !键乙二.成功() || !键丙.成功()) return;
            const auto 甲乙结果 = 会话.创建关系(关系类型::引用, 节点甲, 节点乙, 20);
            const auto 丁乙结果 = 会话.创建关系(关系类型::引用, 节点丁, 节点乙, 10);
            const auto 乙丙结果 = 会话.创建关系(关系类型::引用, 节点乙, 节点丙, 30);
            if (!甲乙结果.成功() || !丁乙结果.成功() || !乙丙结果.成功()
                || !甲乙结果.值.has_value() || !丁乙结果.值.has_value()
                || !乙丙结果.值.has_value()) return;
            关系甲乙 = *甲乙结果.值;
            关系丁乙 = *丁乙结果.值;
            关系乙丙 = *乙丙结果.值;

            甲主键组 = 会话.读取节点主键组(节点甲);
            乙主键组 = 会话.读取节点主键组(节点乙);
            甲正向组 = 会话.读取关系记录组(节点甲, 关系类型::引用);
            甲来源组 = 会话.读取来源关系记录组(节点甲, 关系类型::引用);
            乙正向组 = 会话.读取关系记录组(节点乙, 关系类型::引用);
            乙来源组 = 会话.读取来源关系记录组(节点乙, 关系类型::引用);
            丙来源组 = 会话.读取来源关系记录组(节点丙, 关系类型::引用);

            创建内完整 = 会话.主键绑定匹配(752001, 节点甲)
                && 会话.主键绑定匹配(752002, 节点乙)
                && 会话.主键绑定匹配(752003, 节点乙)
                && 会话.主键绑定匹配(752004, 节点丙)
                && 会话.关系可读(关系甲乙) && 会话.关系可读(关系丁乙)
                && 会话.关系可读(关系乙丙)
                && 甲主键组 == std::vector<std::uint64_t>{752001}
                && 乙主键组 == std::vector<std::uint64_t>({752002, 752003})
                && 甲正向组.size() == 1 && 甲来源组.empty()
                && 乙正向组.size() == 1 && 乙来源组.size() == 2
                && 丙来源组.size() == 1;
            if (创建内完整) (void)会话.请求提交();
        });
        const auto 创建后 = 读取数量();

        验收[1] = 创建结果.状态 == 结构写入状态::已提交 && 创建内完整
            && 甲主键组 == std::vector<std::uint64_t>{752001}
            && 索引.按主键查节点(752001) == std::optional<节点句柄>{节点甲};
        验收[2] = 乙主键组 == std::vector<std::uint64_t>({752002, 752003})
            && 索引.按主键查节点(752002) == std::optional<节点句柄>{节点乙}
            && 索引.按主键查节点(752003) == std::optional<节点句柄>{节点乙};
        验收[3] = 乙来源组.size() == 2
            && 记录匹配(乙来源组[0], 关系甲乙, 节点甲, 节点乙)
            && 记录匹配(乙来源组[1], 关系丁乙, 节点丁, 节点乙)
            && 乙来源组[0].关系编号 < 乙来源组[1].关系编号;
        验收[4] = 甲正向组.size() == 1 && 乙来源组.size() == 2
            && 记录相同(甲正向组[0], 乙来源组[0])
            && 记录匹配(甲正向组[0], 关系甲乙, 节点甲, 节点乙);
        验收[5] = 甲来源组.empty() && !乙来源组.empty()
            && 记录匹配(乙来源组[0], 关系甲乙, 节点甲, 节点乙)
            && 记录匹配(乙来源组[1], 关系丁乙, 节点丁, 节点乙);
        验收[6] = 甲正向组.size() == 1 && 乙正向组.size() == 1
            && 丙来源组.size() == 1
            && 记录匹配(甲正向组[0], 关系甲乙, 节点甲, 节点乙)
            && 记录匹配(乙正向组[0], 关系乙丙, 节点乙, 节点丙)
            && 记录相同(乙正向组[0], 丙来源组[0]);

        节点句柄 过期节点 = 节点甲;
        ++过期节点.版本号;
        节点句柄 错仓节点 = 节点甲;
        ++错仓节点.仓库编号;
        const auto 拒绝前 = 读取数量();
        std::atomic<bool> 跨线程已拒绝 = false;
        bool 当前线程已拒绝 = false;
        bool 决定后已拒绝 = false;
        const auto 拒绝结果 = 执行器.执行([&](结构写入会话& 会话) {
            当前线程已拒绝 = 会话.读取节点主键组({}).empty()
                && 会话.读取节点主键组(过期节点).empty()
                && 会话.读取节点主键组(错仓节点).empty()
                && 会话.读取来源关系记录组({}, 关系类型::引用).empty()
                && 会话.读取来源关系记录组(过期节点, 关系类型::引用).empty()
                && 会话.读取来源关系记录组(
                    节点乙, static_cast<关系类型>(999)).empty();
            std::thread 跨线程([&] {
                跨线程已拒绝.store(
                    会话.读取节点主键组(节点甲).empty()
                    && 会话.读取来源关系记录组(节点乙, 关系类型::引用).empty());
            });
            跨线程.join();
            if (!当前线程已拒绝 || !跨线程已拒绝.load() || !会话.请求提交()) return;
            决定后已拒绝 = 会话.读取节点主键组(节点甲).empty()
                && 会话.读取来源关系记录组(节点乙, 关系类型::引用).empty();
        });
        验收[7] = 拒绝结果.状态 == 结构写入状态::已提交
            && 当前线程已拒绝 && 跨线程已拒绝.load() && 决定后已拒绝
            && 读取数量() == 拒绝前
            && 甲主键组 == std::vector<std::uint64_t>{752001}
            && 乙来源组.size() == 2;

        const auto 撤销前 = 读取数量();
        主信息句柄 撤销主信息甲;
        主信息句柄 撤销主信息乙;
        节点句柄 撤销节点甲;
        节点句柄 撤销节点乙;
        关系句柄 撤销关系;
        bool 撤销材料完整 = false;
        const auto 撤销结果 = 执行器.执行([&](结构写入会话& 会话) {
            const auto 主甲 = 会话.创建主信息候选();
            const auto 主乙 = 会话.创建主信息候选();
            if (!主甲.成功() || !主乙.成功() || !主甲.值.has_value()
                || !主乙.值.has_value()) return;
            撤销主信息甲 = *主甲.值;
            撤销主信息乙 = *主乙.值;
            const auto 节甲 = 会话.创建节点候选(节点类型::基础信息, 撤销主信息甲);
            const auto 节乙 = 会话.创建节点候选(节点类型::基础信息, 撤销主信息乙);
            if (!节甲.成功() || !节乙.成功() || !节甲.值.has_value()
                || !节乙.值.has_value()) return;
            撤销节点甲 = *节甲.值;
            撤销节点乙 = *节乙.值;
            if (!会话.绑定主键(752101, 撤销节点甲).成功()) return;
            const auto 关系结果 = 会话.创建关系(
                关系类型::引用, 撤销节点甲, 撤销节点乙);
            if (!关系结果.成功() || !关系结果.值.has_value()) return;
            撤销关系 = *关系结果.值;
            const auto 主键组 = 会话.读取节点主键组(撤销节点甲);
            const auto 来源组 = 会话.读取来源关系记录组(撤销节点乙, 关系类型::引用);
            撤销材料完整 = 主键组 == std::vector<std::uint64_t>{752101}
                && 来源组.size() == 1
                && 记录匹配(来源组[0], 撤销关系, 撤销节点甲, 撤销节点乙);
            if (撤销材料完整) (void)会话.请求撤销();
        });
        验收[8] = 创建后.节点 == 创建前.节点 + 4
            && 创建后.关系 == 创建前.关系 + 3
            && 创建后.索引 == 创建前.索引 + 4
            && 撤销结果.状态 == 结构写入状态::候选已撤销 && 撤销材料完整
            && 读取数量() == 撤销前
            && !主信息.读取主信息(撤销主信息甲).has_value()
            && !主信息.读取主信息(撤销主信息乙).has_value()
            && !节点.读取节点(撤销节点甲).has_value()
            && !节点.读取节点(撤销节点乙).has_value()
            && !关系.读取关系(撤销关系).has_value()
            && !索引.按主键查节点(752101).has_value();

        验收[9] = std::is_same_v<
                decltype(std::declval<结构写入会话&>().创建关系(
                    关系类型::引用, 节点句柄{}, 节点句柄{})),
                带值结构写入结果<关系句柄>>
            && std::is_same_v<
                decltype(std::declval<结构写入会话&>().绑定主键(0, 节点句柄{})),
                结构写入结果>
            && std::is_same_v<decltype(std::declval<结构写入会话&>().请求提交()), bool>
            && !std::is_copy_constructible_v<结构写入会话>
            && !std::is_move_constructible_v<结构写入会话>;
        验收[10] = 会话材料回归通过 && 语义基础回归通过;
        验收[11] = true;
        for (std::size_t 索引值 = 0; 索引值 < 11; ++索引值) {
            验收[11] = 验收[11] && 验收[索引值];
        }
    } catch (...) {
    }

    constexpr std::array<const char*, 12> 名称组{
        "两个只读入口保持值式公开面",
        "单主键完整组与精确映射",
        "多主键完整稳定返回不自动选取",
        "按目标来源关系完整稳定返回",
        "正反向关系记录互证完整句柄",
        "根空来源与已有上位材料可区分",
        "同许可多跳正向反向材料闭合",
        "无效错仓过期跨线程决定后拒绝",
        "只读材料不改变提交撤销与写集",
        "执行器仓库事务既有合同未扩张",
        "CORE-SESSION-S2与SERVICE-DATA-S4回归",
        "CORE-SESSION-S3局部总成完整"};
    std::size_t 失败数量 = 0;
    for (std::size_t 索引值 = 0; 索引值 < 验收.size(); ++索引值) {
        if (!验收[索引值]) ++失败数量;
        std::cout << "CORE-SESSION-S3-A" << (索引值 + 1 < 10 ? "0" : "") << 索引值 + 1
            << ' ' << 名称组[索引值] << ": " << (验收[索引值] ? "通过" : "失败") << '\n';
    }
    return {"CORE-SESSION-S3", "概念图同许可只读材料扩展",
        失败数量 == 0, 验收.size(), 失败数量};
}

自检单元结果 运行已发布关系可逆换代与普通父子重挂自检(
    bool 会话回归通过,
    bool 存在场景回归通过,
    bool 会话材料回归通过,
    bool 状态动态回归通过,
    bool 特征体系回归通过,
    bool 语义基础回归通过,
    bool 概念图材料回归通过,
    bool 概念图结构回归通过) {
    using namespace 结构写入会话自检内部;

    static_assert(!std::is_default_constructible_v<已发布关系变更能力>);
    static_assert(!std::is_copy_constructible_v<已发布关系变更能力>);
    static_assert(!std::is_copy_assignable_v<已发布关系变更能力>);
    static_assert(std::is_nothrow_move_constructible_v<已发布关系变更能力>);
    static_assert(!std::is_move_assignable_v<已发布关系变更能力>);
    static_assert(std::is_same_v<
        decltype(std::declval<结构写入会话&>().失效已发布关系(关系句柄{})),
        带值结构写入结果<关系句柄>>);
    static_assert(std::is_same_v<
        decltype(std::declval<结构写入会话&>().重挂已发布关系(
            关系句柄{}, 节点句柄{}, 节点句柄{})),
        带值结构写入结果<关系句柄>>);
    static_assert(std::is_same_v<
        decltype(std::declval<结构写入会话&>().挂载或重挂节点(
            节点句柄{}, 节点句柄{})),
        节点挂载结果>);
    static_assert(std::is_same_v<
        decltype(std::declval<const 结构写入会话&>().读取关系审计(关系句柄{})),
        std::optional<关系记录>>);
    static_assert(std::is_same_v<
        decltype(std::declval<const 结构写入会话&>().读取关系审计记录组(
            节点句柄{}, 关系类型::引用)),
        std::vector<关系记录>>);

    std::array<bool, 14> 验收{};
    try {
        constexpr std::uint64_t 关系仓库编号 = 75703;
        结构事务协调器 协调器(757);
        const auto 接线 = 协调器.生成接线();
        主信息仓库 主信息(75701, 接线);
        节点仓库 节点(主信息, 75702, 接线);
        关系仓库 关系(节点, 关系仓库编号, 接线);
        索引仓库 索引(节点, 接线);
        结构写入执行器 执行器(接线, &主信息, &节点, &关系, &索引);

        const auto 记录相同 = [](const 关系记录& 左, const 关系记录& 右) {
            return 左.关系编号 == 右.关系编号
                && 左.类型 == 右.类型
                && 左.源节点 == 右.源节点
                && 左.目标节点 == 右.目标节点
                && 左.顺序号 == 右.顺序号
                && 左.版本号 == 右.版本号
                && 左.状态 == 右.状态;
        };
        const auto 记录句柄 = [&](const 关系记录& 记录) {
            return 关系句柄{关系仓库编号, 记录.关系编号, 记录.版本号};
        };
        const auto 查找关系记录 = [](const std::vector<关系记录>& 记录组, std::uint64_t 关系编号)
            -> std::optional<关系记录> {
            const auto 位置 = std::find_if(
                记录组.begin(),
                记录组.end(),
                [&](const 关系记录& 记录) { return 记录.关系编号 == 关系编号; });
            return 位置 == 记录组.end() ? std::nullopt : std::optional<关系记录>{*位置};
        };

        std::vector<主信息句柄> 主信息组;
        std::vector<节点句柄> 节点组;
        主信息组.reserve(40);
        节点组.reserve(40);
        const auto 节点创建结果 = 执行器.执行([&](结构写入会话& 会话) {
            for (std::size_t 索引值 = 0; 索引值 < 40; ++索引值) {
                const auto 主结果 = 会话.创建主信息候选();
                if (!主结果.成功() || !主结果.值.has_value()) return;
                主信息组.push_back(*主结果.值);
                const auto 节点结果 = 会话.创建节点候选(节点类型::基础信息, 主信息组.back());
                if (!节点结果.成功() || !节点结果.值.has_value()) return;
                节点组.push_back(*节点结果.值);
            }
            for (const auto& 主信息值 : 主信息组) {
                if (!会话.主信息可读(主信息值)) return;
            }
            for (const auto& 节点值 : 节点组) {
                if (!会话.节点可读(节点值)) return;
            }
            (void)会话.请求提交();
        });
        if (节点创建结果.状态 != 结构写入状态::已提交 || 节点组.size() != 40) {
            throw std::runtime_error("CORE-SESSION-S4 节点准备失败");
        }

        const auto 创建引用关系 = [&](节点句柄 源节点, 节点句柄 目标节点) {
            关系句柄 关系值;
            const auto 结果 = 执行器.执行([&](结构写入会话& 会话) {
                const auto 写入 = 会话.创建关系(关系类型::引用, 源节点, 目标节点);
                if (!写入.成功() || !写入.值.has_value()) return;
                关系值 = *写入.值;
                if (会话.关系可读(关系值)) (void)会话.请求提交();
            });
            return 结果.状态 == 结构写入状态::已提交 ? 关系值 : 关系句柄{};
        };
        const auto 创建普通父关系 = [&](节点句柄 子节点, 节点句柄 父节点) {
            关系句柄 关系值;
            const auto 结果 = 执行器.执行([&](结构写入会话& 会话) {
                const auto 挂载 = 会话.挂载或重挂节点(子节点, 父节点);
                if (挂载.状态 != 节点挂载结果状态::已创建 || !挂载.父关系.has_value()) return;
                关系值 = *挂载.父关系;
                if (会话.读取关系审计(关系值).has_value()) (void)会话.请求提交();
            });
            return 结果.状态 == 结构写入状态::已提交 ? 关系值 : 关系句柄{};
        };

        const 关系句柄 失效关系 = 创建引用关系(节点组[0], 节点组[1]);
        const 关系句柄 重挂关系 = 创建引用关系(节点组[2], 节点组[3]);
        const 关系句柄 重复关系 = 创建引用关系(节点组[4], 节点组[5]);
        const 关系句柄 普通父关系 = 创建普通父关系(节点组[6], 节点组[7]);
        const 关系句柄 析构关系 = 创建引用关系(节点组[8], 节点组[9]);
        const 关系句柄 双变更甲 = 创建引用关系(节点组[14], 节点组[15]);
        const 关系句柄 双变更乙 = 创建引用关系(节点组[16], 节点组[17]);
        const 关系句柄 故障旧关系 = 创建引用关系(节点组[18], 节点组[19]);
        const 关系句柄 确认关系 = 创建引用关系(节点组[22], 节点组[23]);
        const 关系句柄 跨会话关系 = 创建引用关系(节点组[25], 节点组[26]);
        const 关系句柄 并发关系 = 创建引用关系(节点组[28], 节点组[29]);
        const 关系句柄 审计关系 = 创建引用关系(节点组[32], 节点组[33]);
        const 关系句柄 兼容删除关系 = 创建引用关系(节点组[34], 节点组[35]);
        if (!句柄有效(失效关系) || !句柄有效(重挂关系) || !句柄有效(重复关系)
            || !句柄有效(普通父关系) || !句柄有效(析构关系)
            || !句柄有效(双变更甲) || !句柄有效(双变更乙)
            || !句柄有效(故障旧关系) || !句柄有效(确认关系)
            || !句柄有效(跨会话关系) || !句柄有效(并发关系)
            || !句柄有效(审计关系) || !句柄有效(兼容删除关系)) {
            throw std::runtime_error("CORE-SESSION-S4 关系准备失败");
        }

        bool 移动后源失效 = false;
        bool 移动能力撤销回前态 = false;
        {
            auto 许可 = 接线.取得独占许可(接线.运行期状态);
            const auto& 令牌 = 许可.读取令牌();
            auto 变更 = 关系.结构化失效已发布关系(失效关系, 令牌);
            if (变更.成功() && 变更.能力.has_value()) {
                已发布关系变更能力 原能力(std::move(*变更.能力));
                已发布关系变更能力 移动能力(std::move(原能力));
                移动后源失效 = !原能力.完整() && 移动能力.处于持有阶段();
                const auto 撤销 = 关系.结构化撤销已发布关系变更(移动能力, 令牌);
                const auto 写前 = 关系.读取关系审计(失效关系, 令牌);
                移动能力撤销回前态 = 撤销.成功() && 写前.has_value()
                    && 写前->状态 == 记录状态::有效
                    && 写前->版本号 == 失效关系.版本号;
            }
        }
        bool 析构不写入 = false;
        关系句柄 析构后句柄;
        {
            auto 许可 = 接线.取得独占许可(接线.运行期状态);
            const auto& 令牌 = 许可.读取令牌();
            {
                auto 变更 = 关系.结构化重挂已发布关系(
                    析构关系, 节点组[8], 节点组[10], 令牌);
                if (变更.成功() && 变更.当前关系.has_value()) 析构后句柄 = *变更.当前关系;
            }
            const auto 析构后记录 = 关系.读取关系审计(析构后句柄, 令牌);
            析构不写入 = 析构后记录.has_value()
                && 析构后记录->源节点 == 节点组[8]
                && 析构后记录->目标节点 == 节点组[10]
                && 析构后记录->版本号 == 析构关系.版本号 + 1;
        }
        验收[0] = 移动后源失效 && 移动能力撤销回前态 && 析构不写入;

        bool 失效材料完整 = false;
        bool 失效过期拒绝 = false;
        bool 失效撤销回前态 = false;
        {
            auto 许可 = 接线.取得独占许可(接线.运行期状态);
            const auto& 令牌 = 许可.读取令牌();
            auto 变更 = 关系.结构化失效已发布关系(失效关系, 令牌);
            if (变更.成功() && 变更.当前关系.has_value() && 变更.能力.has_value()) {
                const auto 写前 = 变更.能力->读取写前记录();
                const auto 写后 = 变更.能力->读取写后记录();
                const auto 当前 = 关系.读取关系审计(*变更.当前关系, 令牌);
                失效材料完整 = 写前.状态 == 记录状态::有效
                    && 写后.状态 == 记录状态::已失效
                    && 写后.版本号 == 写前.版本号 + 1
                    && 当前.has_value() && 记录相同(*当前, 写后);
                const auto 过期 = 关系.结构化失效已发布关系(失效关系, 令牌);
                失效过期拒绝 = 过期.操作.状态 == 结构写入状态::版本漂移;
                const auto 撤销 = 关系.结构化撤销已发布关系变更(*变更.能力, 令牌);
                const auto 恢复 = 关系.读取关系审计(失效关系, 令牌);
                失效撤销回前态 = 撤销.成功() && 恢复.has_value() && 记录相同(*恢复, 写前);
            }
        }
        验收[1] = 失效材料完整 && 失效过期拒绝 && 失效撤销回前态;

        bool 重挂材料完整 = false;
        bool 重复端点拒绝 = false;
        bool 普通父子误用拒绝 = false;
        bool 重挂撤销回前态 = false;
        {
            auto 许可 = 接线.取得独占许可(接线.运行期状态);
            const auto& 令牌 = 许可.读取令牌();
            const auto 重复 = 关系.结构化重挂已发布关系(
                重挂关系, 节点组[4], 节点组[5], 令牌);
            重复端点拒绝 = 重复.操作.状态 == 结构写入状态::入口拒绝;
            const auto 普通父子误用 = 关系.结构化重挂已发布关系(
                普通父关系, 节点组[7], 节点组[10], 令牌);
            普通父子误用拒绝 = 普通父子误用.操作.状态 == 结构写入状态::入口拒绝;
            auto 变更 = 关系.结构化重挂已发布关系(
                重挂关系, 节点组[2], 节点组[4], 令牌);
            if (变更.成功() && 变更.能力.has_value() && 变更.当前关系.has_value()) {
                const auto 写前 = 变更.能力->读取写前记录();
                const auto 写后 = 变更.能力->读取写后记录();
                重挂材料完整 = 写后.关系编号 == 写前.关系编号
                    && 写后.类型 == 写前.类型
                    && 写后.顺序号 == 写前.顺序号
                    && 写后.状态 == 记录状态::有效
                    && 写后.源节点 == 节点组[2]
                    && 写后.目标节点 == 节点组[4]
                    && 写后.版本号 == 写前.版本号 + 1;
                const auto 撤销 = 关系.结构化撤销已发布关系变更(*变更.能力, 令牌);
                const auto 恢复 = 关系.读取关系审计(重挂关系, 令牌);
                重挂撤销回前态 = 撤销.成功() && 恢复.has_value() && 记录相同(*恢复, 写前);
            }
        }
        验收[2] = 重挂材料完整 && 重复端点拒绝
            && 普通父子误用拒绝 && 重挂撤销回前态;

        节点挂载结果 首次挂载;
        const auto 首次挂载结果 = 执行器.执行([&](结构写入会话& 会话) {
            首次挂载 = 会话.挂载或重挂节点(节点组[11], 节点组[12]);
            if (首次挂载.状态 == 节点挂载结果状态::已创建
                && 首次挂载.父关系.has_value()
                && 会话.读取关系审计(*首次挂载.父关系).has_value()) {
                (void)会话.请求提交();
            }
        });
        节点挂载结果 幂等挂载;
        const auto 幂等挂载结果 = 执行器.执行([&](结构写入会话& 会话) {
            幂等挂载 = 会话.挂载或重挂节点(节点组[11], 节点组[12]);
            if (幂等挂载.状态 == 节点挂载结果状态::已在目标父) (void)会话.请求提交();
        });
        节点挂载结果 合法重挂;
        bool 合法重挂已读回 = false;
        const auto 合法重挂结果 = 执行器.执行([&](结构写入会话& 会话) {
            合法重挂 = 会话.挂载或重挂节点(节点组[11], 节点组[13]);
            合法重挂已读回 = 合法重挂.父关系.has_value()
                && 会话.读取关系审计(*合法重挂.父关系).has_value();
            if (合法重挂已读回) (void)会话.请求撤销();
        });
        节点挂载结果 自身挂载;
        const auto 自身挂载结果 = 执行器.执行([&](结构写入会话& 会话) {
            自身挂载 = 会话.挂载或重挂节点(节点组[11], 节点组[11]);
        });
        节点挂载结果 成环挂载;
        const auto 成环挂载结果 = 执行器.执行([&](结构写入会话& 会话) {
            成环挂载 = 会话.挂载或重挂节点(节点组[12], 节点组[11]);
        });
        带值结构写入结果<关系句柄> 通用父子创建;
        const auto 通用父子创建结果 = 执行器.执行([&](结构写入会话& 会话) {
            通用父子创建 = 会话.创建关系(
                关系类型::普通父子, 节点组[13], 节点组[10]);
        });
        验收[3] = 首次挂载结果.状态 == 结构写入状态::已提交
            && 首次挂载.状态 == 节点挂载结果状态::已创建
            && 幂等挂载结果.状态 == 结构写入状态::已提交
            && 幂等挂载.状态 == 节点挂载结果状态::已在目标父
            && 合法重挂结果.状态 == 结构写入状态::候选已撤销
            && 合法重挂.状态 == 节点挂载结果状态::已重挂
            && 合法重挂已读回
            && 自身挂载结果.状态 == 结构写入状态::入口拒绝
            && 自身挂载.状态 == 节点挂载结果状态::拒绝自身
            && 成环挂载结果.状态 == 结构写入状态::入口拒绝
            && 成环挂载.状态 == 节点挂载结果状态::拒绝成环
            && 通用父子创建结果.状态 == 结构写入状态::入口拒绝
            && 通用父子创建.操作.状态 == 结构写入状态::入口拒绝
            && 关系.获取父节点(节点组[11]) == std::optional<节点句柄>{节点组[12]};

        bool 多父追根因 = false;
        bool 悬空追根因 = false;
        bool 既有环追根因 = false;
        {
            结构事务协调器 异常协调器(7575);
            const auto 异常接线 = 异常协调器.生成接线();
            主信息仓库 异常主信息(75751, 异常接线);
            节点仓库 异常节点(异常主信息, 75752, 异常接线);
            关系仓库 异常关系(异常节点, 75753, 异常接线);
            索引仓库 异常索引(异常节点, 异常接线);
            结构写入执行器 异常执行器(
                异常接线, &异常主信息, &异常节点, &异常关系, &异常索引);
            std::vector<主信息句柄> 异常主信息组;
            std::vector<节点句柄> 异常节点组;
            const auto 异常节点准备 = 异常执行器.执行([&](结构写入会话& 会话) {
                for (std::size_t 索引值 = 0; 索引值 < 12; ++索引值) {
                    const auto 主结果 = 会话.创建主信息候选();
                    if (!主结果.成功() || !主结果.值.has_value()) return;
                    异常主信息组.push_back(*主结果.值);
                    const auto 节点结果 = 会话.创建节点候选(
                        节点类型::基础信息, 异常主信息组.back());
                    if (!节点结果.成功() || !节点结果.值.has_value()) return;
                    异常节点组.push_back(*节点结果.值);
                }
                for (const auto& 主信息值 : 异常主信息组) if (!会话.主信息可读(主信息值)) return;
                for (const auto& 节点值 : 异常节点组) if (!会话.节点可读(节点值)) return;
                (void)会话.请求提交();
            });
            if (异常节点准备.状态 != 结构写入状态::已提交 || 异常节点组.size() != 12) {
                throw std::runtime_error("CORE-SESSION-S4 异常节点准备失败");
            }
            auto 许可 = 异常接线.取得独占许可(异常接线.运行期状态);
            const auto& 令牌 = 许可.读取令牌();

            const auto 第一父关系 = 异常关系.创建关系(
                关系类型::普通父子, 异常节点组[0], 异常节点组[2], 0, 令牌);
            auto 失效第一父 = 异常关系.结构化失效已发布关系(第一父关系, 令牌);
            const auto 第二父关系 = 异常关系.创建关系(
                关系类型::普通父子, 异常节点组[1], 异常节点组[2], 0, 令牌);
            if (失效第一父.能力.has_value() && 句柄有效(第二父关系)) {
                const auto 恢复第一父 = 异常关系.结构化撤销已发布关系变更(
                    *失效第一父.能力, 令牌);
                const auto 多父结果 = 异常关系.结构化挂载或重挂节点(
                    异常节点组[2], 异常节点组[3], 令牌);
                多父追根因 = 恢复第一父.成功()
                    && 多父结果.操作.状态 == 结构写入状态::内部不一致
                    && 多父结果.挂载.状态 == 节点挂载结果状态::内部不一致;
            }

            const auto 悬空父关系 = 异常关系.创建关系(
                关系类型::普通父子, 异常节点组[4], 异常节点组[5], 0, 令牌);
            const auto 删除悬空父 = 异常节点.严格删除节点(异常节点组[4], 令牌);
            const auto 悬空结果 = 异常关系.结构化挂载或重挂节点(
                异常节点组[5], 异常节点组[6], 令牌);
            悬空追根因 = 句柄有效(悬空父关系) && 删除悬空父.成功()
                && 悬空结果.操作.状态 == 结构写入状态::内部不一致
                && 悬空结果.挂载.状态 == 节点挂载结果状态::内部不一致;

            const auto 环关系甲 = 异常关系.创建关系(
                关系类型::普通父子, 异常节点组[8], 异常节点组[7], 0, 令牌);
            const auto 环关系乙 = 异常关系.创建关系(
                关系类型::普通父子, 异常节点组[7], 异常节点组[8], 0, 令牌);
            const auto 环结果 = 异常关系.结构化挂载或重挂节点(
                异常节点组[9], 异常节点组[7], 令牌);
            既有环追根因 = 句柄有效(环关系甲) && 句柄有效(环关系乙)
                && 环结果.操作.状态 == 结构写入状态::内部不一致
                && 环结果.挂载.状态 == 节点挂载结果状态::内部不一致;
        }
        验收[4] = 多父追根因 && 悬空追根因 && 既有环追根因;

        const auto 审计写前 = 关系.读取关系审计(审计关系);
        关系句柄 审计写后句柄;
        std::optional<关系记录> 审计写后;
        std::optional<关系记录> 审计组写后;
        const auto 审计结果 = 执行器.执行([&](结构写入会话& 会话) {
            const auto 失效 = 会话.失效已发布关系(审计关系);
            if (!失效.成功() || !失效.值.has_value()) return;
            审计写后句柄 = *失效.值;
            审计写后 = 会话.读取关系审计(审计写后句柄);
            const auto 记录组 = 会话.读取关系审计记录组(节点组[32], 关系类型::引用);
            审计组写后 = 查找关系记录(记录组, 审计关系.关系编号);
            if (审计写后.has_value() && 审计组写后.has_value()) (void)会话.请求撤销();
        });
        const auto 审计恢复 = 关系.读取关系审计(审计关系);
        验收[5] = 审计结果.状态 == 结构写入状态::候选已撤销
            && 审计写前.has_value() && 审计写后.has_value() && 审计组写后.has_value()
            && 审计写后->关系编号 == 审计写前->关系编号
            && 审计写后->版本号 == 审计写前->版本号 + 1
            && 审计写后->状态 == 记录状态::已失效
            && 记录相同(*审计写后, *审计组写后)
            && 审计恢复.has_value() && 记录相同(*审计恢复, *审计写前);

        验收[6] = 失效撤销回前态 && 重挂撤销回前态
            && 合法重挂结果.状态 == 结构写入状态::候选已撤销
            && 关系.读取关系审计(*首次挂载.父关系).has_value();

        const auto 双变更甲写前 = 关系.读取关系审计(双变更甲);
        const auto 双变更乙写前 = 关系.读取关系审计(双变更乙);
        const auto 双变更前数量 = 关系.有效关系数量();
        关系句柄 双变更新关系;
        bool 双变更已读回 = false;
        const auto 双变更结果 = 执行器.执行([&](结构写入会话& 会话) {
            const auto 新关系 = 会话.创建关系(
                关系类型::引用, 节点组[36], 节点组[37]);
            if (!新关系.成功() || !新关系.值.has_value()) return;
            双变更新关系 = *新关系.值;
            const auto 重挂 = 会话.重挂已发布关系(
                双变更甲, 节点组[14], 节点组[17]);
            const auto 失效 = 会话.失效已发布关系(双变更乙);
            if (!重挂.成功() || !重挂.值.has_value()
                || !失效.成功() || !失效.值.has_value()) return;
            双变更已读回 = 会话.关系可读(双变更新关系)
                && 会话.读取关系审计(*重挂.值).has_value()
                && 会话.读取关系审计(*失效.值).has_value();
            if (双变更已读回) (void)会话.请求撤销();
        });
        const auto 双变更甲恢复 = 关系.读取关系审计(双变更甲);
        const auto 双变更乙恢复 = 关系.读取关系审计(双变更乙);
        验收[7] = 双变更结果.状态 == 结构写入状态::候选已撤销
            && 双变更已读回
            && 双变更甲写前.has_value() && 双变更乙写前.has_value()
            && 双变更甲恢复.has_value() && 双变更乙恢复.has_value()
            && 记录相同(*双变更甲写前, *双变更甲恢复)
            && 记录相同(*双变更乙写前, *双变更乙恢复)
            && !关系.读取关系(双变更新关系).has_value()
            && 关系.有效关系数量() == 双变更前数量;

        const auto 故障写前 = 关系.读取关系审计(故障旧关系);
        const auto 故障前数量 = 关系.有效关系数量();
        关系句柄 故障新关系;
        const auto 故障结果 = 执行器.执行([&](结构写入会话& 会话) {
            const auto 新关系 = 会话.创建关系(
                关系类型::引用, 节点组[20], 节点组[21]);
            if (!新关系.成功() || !新关系.值.has_value()) return;
            故障新关系 = *新关系.值;
            const auto 失效 = 会话.失效已发布关系(故障旧关系);
            if (!失效.成功() || !失效.值.has_value()
                || !会话.关系可读(故障新关系)
                || !会话.读取关系审计(*失效.值).has_value()) return;
            throw std::runtime_error("CORE-SESSION-S4 确认前故障注入");
        });
        const auto 故障恢复 = 关系.读取关系审计(故障旧关系);
        验收[8] = 故障结果.状态 == 结构写入状态::内部不一致
            && 故障写前.has_value() && 故障恢复.has_value()
            && 记录相同(*故障写前, *故障恢复)
            && !关系.读取关系(故障新关系).has_value()
            && 关系.有效关系数量() == 故障前数量;

        bool 确认后能力可逆 = false;
        关系记录 确认写前记录;
        关系句柄 确认写后句柄;
        {
            auto 许可 = 接线.取得独占许可(接线.运行期状态);
            const auto& 令牌 = 许可.读取令牌();
            auto 变更 = 关系.结构化重挂已发布关系(
                确认关系, 节点组[22], 节点组[24], 令牌);
            if (变更.成功() && 变更.能力.has_value() && 变更.当前关系.has_value()) {
                确认写前记录 = 变更.能力->读取写前记录();
                确认写后句柄 = *变更.当前关系;
                const auto 确认 = 关系.结构化确认已发布关系变更(*变更.能力, 令牌);
                const auto 再撤销 = 关系.结构化撤销已发布关系变更(*变更.能力, 令牌);
                const auto 恢复 = 关系.读取关系审计(确认关系, 令牌);
                const auto 写后已过期 = 关系.读取关系审计(确认写后句柄, 令牌);
                确认后能力可逆 = 确认.成功()
                    && 再撤销.状态 == 结构写入状态::候选已撤销
                    && 恢复.has_value() && 记录相同(*恢复, 确认写前记录)
                    && !写后已过期.has_value();
            }
        }
        std::vector<已发布关系变更能力> 跨会话能力组;
        跨会话能力组.reserve(1);
        关系句柄 跨会话写后句柄;
        关系记录 跨会话写后记录;
        std::uint64_t 第一次许可序号 = 0;
        {
            auto 许可 = 接线.取得独占许可(接线.运行期状态);
            auto 变更 = 关系.结构化重挂已发布关系(
                跨会话关系, 节点组[25], 节点组[27], 许可.读取令牌());
            if (变更.成功() && 变更.能力.has_value() && 变更.当前关系.has_value()) {
                第一次许可序号 = 许可.读取令牌().许可序号;
                跨会话写后句柄 = *变更.当前关系;
                跨会话写后记录 = 变更.能力->读取写后记录();
                跨会话能力组.emplace_back(std::move(*变更.能力));
            }
        }
        bool 跨会话拒绝 = false;
        {
            auto 许可 = 接线.取得独占许可(接线.运行期状态);
            if (!跨会话能力组.empty()) {
                const auto 首次跨会话撤销 = 关系.结构化撤销已发布关系变更(
                    跨会话能力组.front(), 许可.读取令牌());
                const auto 再次跨会话撤销 = 关系.结构化撤销已发布关系变更(
                    跨会话能力组.front(), 许可.读取令牌());
                const auto 当前 = 关系.读取关系审计(跨会话写后句柄, 许可.读取令牌());
                跨会话拒绝 = 第一次许可序号 != 0
                    && 许可.读取令牌().许可序号 != 第一次许可序号
                    && 首次跨会话撤销.状态 == 结构写入状态::许可拒绝
                    && 再次跨会话撤销.状态 == 结构写入状态::许可拒绝
                    && 当前.has_value() && 记录相同(*当前, 跨会话写后记录);
            }
        }
        验收[9] = 确认后能力可逆 && 跨会话拒绝;

        std::array<结构写入结果, 2> 并发结果{};
        std::array<关系句柄, 2> 并发写后句柄{};
        std::atomic<int> 并发已就绪 = 0;
        std::atomic<bool> 并发开始 = false;
        const auto 并发写入 = [&](std::size_t 索引值, 节点句柄 新目标) {
            并发已就绪.fetch_add(1);
            while (!并发开始.load()) std::this_thread::yield();
            并发结果[索引值] = 执行器.执行([&](结构写入会话& 会话) {
                const auto 重挂 = 会话.重挂已发布关系(
                    并发关系, 节点组[28], 新目标);
                if (!重挂.成功() || !重挂.值.has_value()) return;
                并发写后句柄[索引值] = *重挂.值;
                if (会话.读取关系审计(*重挂.值).has_value()) (void)会话.请求提交();
            });
        };
        std::thread 并发甲(并发写入, 0, 节点组[30]);
        std::thread 并发乙(并发写入, 1, 节点组[31]);
        while (并发已就绪.load() != 2) std::this_thread::yield();
        并发开始.store(true);
        并发甲.join();
        并发乙.join();
        const std::size_t 并发提交数量 = static_cast<std::size_t>(
            并发结果[0].状态 == 结构写入状态::已提交)
            + static_cast<std::size_t>(并发结果[1].状态 == 结构写入状态::已提交);
        const std::size_t 并发过期数量 = static_cast<std::size_t>(
            并发结果[0].状态 == 结构写入状态::版本漂移)
            + static_cast<std::size_t>(并发结果[1].状态 == 结构写入状态::版本漂移);
        const std::size_t 胜者索引 = 并发结果[0].状态 == 结构写入状态::已提交 ? 0 : 1;
        const auto 并发当前 = 关系.读取关系(并发写后句柄[胜者索引]);
        验收[10] = 并发提交数量 == 1 && 并发过期数量 == 1
            && 并发当前.has_value()
            && 并发当前->版本号 == 并发关系.版本号 + 1
            && (并发当前->目标节点 == 节点组[30]
                || 并发当前->目标节点 == 节点组[31]);

        using 旧共享删除签名 = bool (关系仓库::*)(关系句柄, const 结构事务令牌&);
        using 严格删除签名 = 结构写入结果 (关系仓库::*)(关系句柄, const 结构事务令牌&);
        constexpr bool 删除签名保持 = std::is_same_v<
                decltype(static_cast<旧共享删除签名>(&关系仓库::删除关系)),
                旧共享删除签名>
            && std::is_same_v<
                decltype(static_cast<严格删除签名>(&关系仓库::严格删除关系)),
                严格删除签名>;
        bool 共享新写拒绝 = false;
        bool 严格删除共享拒绝 = false;
        bool 旧共享删除保持 = false;
        {
            auto 共享许可 = 接线.取得共享许可(接线.运行期状态);
            const auto& 共享令牌 = 共享许可.读取令牌();
            const auto 新失效 = 关系.结构化失效已发布关系(兼容删除关系, 共享令牌);
            const auto 严格删除 = 关系.严格删除关系(兼容删除关系, 共享令牌);
            共享新写拒绝 = 新失效.操作.状态 == 结构写入状态::许可拒绝;
            严格删除共享拒绝 = 严格删除.状态 == 结构写入状态::许可拒绝;
            旧共享删除保持 = 关系.删除关系(兼容删除关系, 共享令牌);
        }
        验收[11] = 删除签名保持 && 共享新写拒绝
            && 严格删除共享拒绝 && 旧共享删除保持
            && !关系.读取关系审计(兼容删除关系).has_value();

        验收[12] = 会话回归通过 && 存在场景回归通过
            && 会话材料回归通过 && 状态动态回归通过
            && 特征体系回归通过 && 语义基础回归通过
            && 概念图材料回归通过 && 概念图结构回归通过;
        验收[13] = true;
        for (std::size_t 索引值 = 0; 索引值 < 13; ++索引值) {
            验收[13] = 验收[13] && 验收[索引值];
        }
    } catch (...) {
    }

    constexpr std::array<const char*, 14> 名称组{
        "移动复制析构能力合同",
        "失效版本推进与过期拒绝",
        "重挂端点推进与误用拒绝",
        "普通父子五分支",
        "多父悬空既有环追根因",
        "审计完整句柄互证",
        "三类单项精确撤销",
        "连续变更逆序撤销",
        "新关系加旧失效故障回前态",
        "确认待发布可逆与跨会话拒绝",
        "并发同关系单版本提交",
        "删除许可ABI兼容合同",
        "既有分层切片完整回归",
        "CORE-SESSION-S4局部总成完整"};
    std::size_t 失败数量 = 0;
    for (std::size_t 索引值 = 0; 索引值 < 验收.size(); ++索引值) {
        if (!验收[索引值]) ++失败数量;
        std::cout << "CORE-SESSION-S4-A" << (索引值 + 1 < 10 ? "0" : "") << 索引值 + 1
            << ' ' << 名称组[索引值] << ": " << (验收[索引值] ? "通过" : "失败") << '\n';
    }
    const auto 多参与者收口 = 运行核心多参与者结构写入收口自检();
    return {"CORE-SESSION-S4", "已发布关系可逆换代与普通父子重挂",
        失败数量 == 0 && 多参与者收口.总通过,
        验收.size() + 多参与者收口.验收项数量,
        失败数量 + 多参与者收口.失败项数量};
}

自检单元结果 运行核心多参与者结构写入收口自检() {
    using namespace 结构写入会话自检内部;

    std::array<bool, 10> 验收{};
    try {
        using 多参与者执行签名 = 结构写入结果 (结构写入执行器::*)(
            const std::function<void(结构写入会话&)>&,
            std::span<结构写入事务参与者* const>) const;
        验收[0] = std::is_same_v<
            decltype(static_cast<多参与者执行签名>(&结构写入执行器::执行)),
            多参与者执行签名>;

        结构事务协调器 拒绝协调器(75950);
        const auto 拒绝接线 = 拒绝协调器.生成接线();
        主信息仓库 拒绝主信息(759501, 拒绝接线);
        节点仓库 拒绝节点(拒绝主信息, 759502, 拒绝接线);
        关系仓库 拒绝关系(拒绝节点, 759503, 拒绝接线);
        索引仓库 拒绝索引(拒绝节点, 拒绝接线);
        结构写入执行器 拒绝执行器(
            拒绝接线, &拒绝主信息, &拒绝节点, &拒绝关系, &拒绝索引);
        原子收口自检参与者 拒绝参与者;
        std::array<结构写入事务参与者*, 2> 空指针组{&拒绝参与者, nullptr};
        std::array<结构写入事务参与者*, 2> 重复组{&拒绝参与者, &拒绝参与者};
        bool 非法组回调已运行 = false;
        const auto 非法组回调 = [&](结构写入会话&) { 非法组回调已运行 = true; };
        const auto 空组结果 = 拒绝执行器.执行(
            非法组回调, std::span<结构写入事务参与者* const>{});
        const auto 空指针结果 = 拒绝执行器.执行(
            非法组回调, std::span<结构写入事务参与者* const>(空指针组));
        const auto 重复结果 = 拒绝执行器.执行(
            非法组回调, std::span<结构写入事务参与者* const>(重复组));
        验收[0] = 验收[0] && !非法组回调已运行
            && 空组结果.状态 == 结构写入状态::入口拒绝
            && 空指针结果.状态 == 结构写入状态::入口拒绝
            && 重复结果.状态 == 结构写入状态::入口拒绝;

        const auto 成功 = 运行多参与者收口场景(
            75951, 原子收口参与者模式::正常, 原子收口参与者模式::正常);
        验收[1] = 成功.状态 == 结构写入状态::已提交
            && 成功.已发布完整结构 && !成功.已隔离
            && 成功.顺序 == std::vector<std::size_t>{10, 11, 20, 21, 40, 41};

        std::vector<std::size_t> 单参与者顺序;
        单参与者顺序.reserve(4);
        原子收口自检参与者 单参与者(
            原子收口参与者模式::正常, 0, &单参与者顺序);
        const auto 单参与者结果 = 拒绝执行器.执行(
            [](结构写入会话& 会话) { (void)会话.请求提交(); }, 单参与者);
        验收[2] = 单参与者结果.状态 == 结构写入状态::已提交
            && 单参与者顺序 == std::vector<std::size_t>{10, 20, 40};

        const auto 准备拒绝 = 运行多参与者收口场景(
            75952, 原子收口参与者模式::正常, 原子收口参与者模式::准备拒绝);
        验收[3] = 准备拒绝.状态 == 结构写入状态::许可拒绝
            && 准备拒绝.已撤销为零结构 && !准备拒绝.已隔离
            && 准备拒绝.顺序 == std::vector<std::size_t>{10, 11, 31, 30};

        const auto 确认拒绝 = 运行多参与者收口场景(
            75953, 原子收口参与者模式::正常, 原子收口参与者模式::确认拒绝);
        验收[4] = 确认拒绝.状态 == 结构写入状态::许可拒绝
            && 确认拒绝.已撤销为零结构 && !确认拒绝.已隔离
            && 确认拒绝.顺序 == std::vector<std::size_t>{10, 11, 20, 21, 31, 30};

        结构写入故障自检配置 第一准备后故障;
        第一准备后故障.参与者故障点 = 结构写入参与者故障点::准备后;
        第一准备后故障.参与者故障序号 = 0;
        结构写入故障自检配置 第二准备后故障 = 第一准备后故障;
        第二准备后故障.参与者故障序号 = 1;
        const auto 第一准备故障 = 运行多参与者收口场景(
            75954, 原子收口参与者模式::正常,
            原子收口参与者模式::正常, &第一准备后故障);
        const auto 第二准备故障 = 运行多参与者收口场景(
            75955, 原子收口参与者模式::正常,
            原子收口参与者模式::正常, &第二准备后故障);
        验收[5] = 第一准备故障.状态 == 结构写入状态::内部不一致
            && 第二准备故障.状态 == 结构写入状态::内部不一致
            && 第一准备故障.已撤销为零结构 && 第二准备故障.已撤销为零结构
            && 第一准备故障.顺序 == std::vector<std::size_t>{10, 31, 30}
            && 第二准备故障.顺序 == std::vector<std::size_t>{10, 11, 31, 30};

        结构写入故障自检配置 第一确认后故障;
        第一确认后故障.参与者故障点 = 结构写入参与者故障点::确认后;
        第一确认后故障.参与者故障序号 = 0;
        结构写入故障自检配置 第二确认后故障 = 第一确认后故障;
        第二确认后故障.参与者故障序号 = 1;
        const auto 第一确认故障 = 运行多参与者收口场景(
            75956, 原子收口参与者模式::正常,
            原子收口参与者模式::正常, &第一确认后故障);
        const auto 第二确认故障 = 运行多参与者收口场景(
            75957, 原子收口参与者模式::正常,
            原子收口参与者模式::正常, &第二确认后故障);
        验收[6] = 第一确认故障.状态 == 结构写入状态::内部不一致
            && 第二确认故障.状态 == 结构写入状态::内部不一致
            && 第一确认故障.已撤销为零结构 && 第二确认故障.已撤销为零结构
            && 第一确认故障.顺序 == std::vector<std::size_t>{10, 11, 20, 31, 30}
            && 第二确认故障.顺序 == std::vector<std::size_t>{10, 11, 20, 21, 31, 30};

        结构写入故障自检配置 发布前故障;
        发布前故障.最终发布前故障 = true;
        const auto 撤销失败 = 运行多参与者收口场景(
            75958, 原子收口参与者模式::撤销拒绝,
            原子收口参与者模式::正常, &发布前故障);
        验收[7] = 撤销失败.状态 == 结构写入状态::内部不一致
            && 撤销失败.已隔离
            && 撤销失败.顺序 == std::vector<std::size_t>{10, 11, 20, 21, 31, 30};

        bool 无参与者回调已运行 = false;
        const auto 无参与者结果 = 拒绝执行器.执行([&](结构写入会话& 会话) {
            无参与者回调已运行 = true;
            (void)会话.请求提交();
        });
        验收[8] = 无参与者回调已运行
            && 无参与者结果.状态 == 结构写入状态::已提交;
        验收[9] = true;
        for (std::size_t 序号 = 0; 序号 < 9; ++序号) 验收[9] = 验收[9] && 验收[序号];
    } catch (...) {
    }

    constexpr std::array<const char*, 10> 名称组{
        "有序span签名与空重复拒绝",
        "登记顺序准备确认发布",
        "单参与者委托唯一算法",
        "准备失败逆序撤销",
        "确认失败逆序撤销",
        "逐序号准备故障定位",
        "逐序号确认故障定位",
        "参与者撤销失败隔离",
        "既有无参与者入口回归",
        "DD05F0核心多参与者总成完整"};
    std::size_t 失败数量 = 0;
    for (std::size_t 序号 = 0; 序号 < 验收.size(); ++序号) {
        if (!验收[序号]) ++失败数量;
        std::cout << "DD05F0-CORE-A" << (序号 + 1 < 10 ? "0" : "") << 序号 + 1
            << ' ' << 名称组[序号] << ": " << (验收[序号] ? "通过" : "失败") << '\n';
    }
    return {"DD05F0-CORE", "核心多参与者结构写入原子收口",
        失败数量 == 0, 验收.size(), 失败数量};
}

自检单元结果 运行许可内物理探测与全参与者原子收口自检(
    bool 协调器隔离回归通过,
    bool 仓库统一合同回归通过,
    bool 已发布关系回归通过,
    bool 特征值事务回归通过) {
    using namespace 结构写入会话自检内部;

    std::array<bool, 24> 验收{};
    try {
        结构事务协调器 查询协调器(75910);
        const auto 查询接线 = 查询协调器.生成接线();
        主信息仓库 查询主信息(759101, 查询接线);
        节点仓库 查询节点(查询主信息, 759102, 查询接线);
        关系仓库 查询关系(查询节点, 759103, 查询接线);
        索引仓库 查询索引(查询节点, 查询接线);
        结构写入执行器 查询执行器(
            查询接线, &查询主信息, &查询节点, &查询关系, &查询索引);

        std::array<主信息句柄, 3> 查询主信息组{};
        std::array<节点句柄, 3> 查询节点组{};
        const std::array<节点类型, 3> 查询类型组{
            节点类型::基础信息, 节点类型::基础信息, 节点类型::特征};
        constexpr std::uint64_t 基础键甲 = 7591001;
        constexpr std::uint64_t 基础键乙 = 7591002;
        constexpr std::uint64_t 特征键 = 7591003;
        const auto 查询基线 = 查询执行器.执行([&](结构写入会话& 会话) {
            for (std::size_t 索引值 = 0; 索引值 < 查询节点组.size(); ++索引值) {
                const auto 主结果 = 会话.创建主信息候选();
                if (!主结果.成功() || !主结果.值.has_value()) return;
                查询主信息组[索引值] = *主结果.值;
                const auto 节点结果 = 会话.创建节点候选(
                    查询类型组[索引值], 查询主信息组[索引值]);
                if (!节点结果.成功() || !节点结果.值.has_value()) return;
                查询节点组[索引值] = *节点结果.值;
            }
            const bool 已绑定 = 会话.绑定主键(基础键甲, 查询节点组[0]).成功()
                && 会话.绑定主键(基础键乙, 查询节点组[0]).成功()
                && 会话.绑定主键(特征键, 查询节点组[2]).成功();
            bool 已读回 = 已绑定;
            for (const auto& 主信息值 : 查询主信息组) 已读回 = 会话.主信息可读(主信息值) && 已读回;
            for (const auto& 节点值 : 查询节点组) 已读回 = 会话.节点可读(节点值) && 已读回;
            已读回 = 会话.主键绑定匹配(基础键甲, 查询节点组[0])
                && 会话.主键绑定匹配(基础键乙, 查询节点组[0])
                && 会话.主键绑定匹配(特征键, 查询节点组[2]) && 已读回;
            if (已读回) (void)会话.请求提交();
        });

        bool 空闲与绑定分流 = false;
        bool 连续点查一致 = false;
        bool 类型投影一致 = false;
        bool 非法入口与跨线程拒绝 = false;
        const auto 查询前许可序号 = 读取结构事务下个许可序号自检(查询接线);
        const auto 查询结果 = 查询执行器.执行([&](结构写入会话& 会话) {
            const auto 空闲 = 会话.读取物理主键当前绑定(7591999);
            const auto 已绑定 = 会话.读取物理主键当前绑定(基础键甲);
            空闲与绑定分流 = 空闲.状态 == 结构写入会话::物理主键读取状态::空闲
                && !空闲.节点.has_value()
                && 已绑定.状态 == 结构写入会话::物理主键读取状态::已绑定
                && 已绑定.节点 == std::optional<节点句柄>{查询节点组[0]};

            连续点查一致 = true;
            for (std::size_t 次数 = 0; 次数 < 1024; ++次数) {
                const auto 点查 = 会话.读取物理主键当前绑定(基础键甲);
                连续点查一致 = 点查.状态 == 结构写入会话::物理主键读取状态::已绑定
                    && 点查.节点 == std::optional<节点句柄>{查询节点组[0]}
                    && 连续点查一致;
            }

            const auto 基础投影 = 会话.读取有效节点与索引投影(节点类型::基础信息);
            const auto 特征投影 = 会话.读取有效节点与索引投影(节点类型::特征);
            const auto 空投影 = 会话.读取有效节点与索引投影(节点类型::场景);
            类型投影一致 = 基础投影.状态 == 结构写入会话::类型索引投影状态::已形成
                && 基础投影.节点组.size() == 2 && 基础投影.绑定组.size() == 2
                && 特征投影.状态 == 结构写入会话::类型索引投影状态::已形成
                && 特征投影.节点组.size() == 1 && 特征投影.绑定组.size() == 1
                && 空投影.状态 == 结构写入会话::类型索引投影状态::已形成
                && 空投影.节点组.empty() && 空投影.绑定组.empty();

            std::atomic<bool> 跨线程拒绝 = false;
            std::thread 跨线程([&] {
                const auto 结果 = 会话.读取物理主键当前绑定(基础键甲);
                跨线程拒绝.store(结果.状态 == 结构写入会话::物理主键读取状态::入口拒绝);
            });
            跨线程.join();
            非法入口与跨线程拒绝 = 会话.读取物理主键当前绑定(0).状态
                    == 结构写入会话::物理主键读取状态::入口拒绝
                && 会话.读取有效节点与索引投影(节点类型::未分类).状态
                    == 结构写入会话::类型索引投影状态::入口拒绝
                && 跨线程拒绝.load();
            (void)会话.请求撤销();
        });
        const auto 查询后许可序号 = 读取结构事务下个许可序号自检(查询接线);
        验收[0] = 查询基线.状态 == 结构写入状态::已提交
            && 查询结果.状态 == 结构写入状态::候选已撤销 && 空闲与绑定分流;
        验收[1] = 连续点查一致 && 查询前许可序号 != 0
            && 查询后许可序号 == 查询前许可序号 + 1;
        验收[2] = 类型投影一致;

        bool 首次写后拒绝 = false;
        bool 决定后拒绝 = false;
        主信息句柄 阶段主信息;
        const auto 阶段结果 = 查询执行器.执行([&](结构写入会话& 会话) {
            const auto 主结果 = 会话.创建主信息候选();
            if (!主结果.成功() || !主结果.值.has_value()) return;
            阶段主信息 = *主结果.值;
            首次写后拒绝 = 会话.读取物理主键当前绑定(基础键甲).状态
                    == 结构写入会话::物理主键读取状态::入口拒绝
                && 会话.读取有效节点与索引投影(节点类型::基础信息).状态
                    == 结构写入会话::类型索引投影状态::入口拒绝;
            if (!会话.主信息可读(阶段主信息) || !会话.请求提交()) return;
            决定后拒绝 = 会话.读取物理主键当前绑定(基础键甲).状态
                == 结构写入会话::物理主键读取状态::入口拒绝;
        });
        验收[3] = 非法入口与跨线程拒绝 && 首次写后拒绝 && 决定后拒绝
            && 阶段结果.状态 == 结构写入状态::已提交;

        const auto 运行点查异常 = [&](std::uint64_t 主键) {
            结构写入会话::物理主键读取状态 状态 = 结构写入会话::物理主键读取状态::入口拒绝;
            const auto 结果 = 查询执行器.执行([&](结构写入会话& 会话) {
                状态 = 会话.读取物理主键当前绑定(主键).状态;
            });
            return 状态 == 结构写入会话::物理主键读取状态::内部不一致
                && 结果.状态 == 结构写入状态::内部不一致;
        };
        const auto 运行投影异常 = [&] {
            结构写入会话::类型索引投影状态 状态 = 结构写入会话::类型索引投影状态::入口拒绝;
            const auto 结果 = 查询执行器.执行([&](结构写入会话& 会话) {
                状态 = 会话.读取有效节点与索引投影(节点类型::基础信息).状态;
            });
            return 状态 == 结构写入会话::类型索引投影状态::内部不一致
                && 结果.状态 == 结构写入状态::内部不一致;
        };

        bool 缺反向已识别 = false;
        {
            auto 许可 = 查询接线.取得独占许可(查询接线.运行期状态);
            缺反向已识别 = 许可.有效() && 查询索引.自检删除反向绑定(
                基础键甲, 查询节点组[0], 许可.读取令牌());
        }
        缺反向已识别 = 运行点查异常(基础键甲) && 缺反向已识别;
        {
            auto 许可 = 查询接线.取得独占许可(查询接线.运行期状态);
            缺反向已识别 = 许可.有效() && 查询索引.自检追加反向绑定(
                基础键甲, 查询节点组[0], 许可.读取令牌()) && 缺反向已识别;
        }
        验收[4] = 缺反向已识别;

        bool 重复反向已识别 = false;
        {
            auto 许可 = 查询接线.取得独占许可(查询接线.运行期状态);
            重复反向已识别 = 许可.有效() && 查询索引.自检追加反向绑定(
                基础键甲, 查询节点组[0], 许可.读取令牌());
        }
        重复反向已识别 = 运行点查异常(基础键甲) && 重复反向已识别;
        {
            auto 许可 = 查询接线.取得独占许可(查询接线.运行期状态);
            重复反向已识别 = 许可.有效() && 查询索引.自检删除反向绑定(
                基础键甲, 查询节点组[0], 许可.读取令牌()) && 重复反向已识别;
        }
        验收[5] = 重复反向已识别;

        bool 额外反向已识别 = false;
        {
            auto 许可 = 查询接线.取得独占许可(查询接线.运行期状态);
            额外反向已识别 = 许可.有效() && 查询索引.自检追加反向绑定(
                特征键, 查询节点组[0], 许可.读取令牌());
        }
        额外反向已识别 = 运行投影异常() && 额外反向已识别;
        {
            auto 许可 = 查询接线.取得独占许可(查询接线.运行期状态);
            额外反向已识别 = 许可.有效() && 查询索引.自检删除反向绑定(
                特征键, 查询节点组[0], 许可.读取令牌()) && 额外反向已识别;
        }
        bool 悬空目标已识别 = false;
        {
            auto 许可 = 查询接线.取得独占许可(查询接线.运行期状态);
            const auto 删除 = 许可.有效()
                ? 查询节点.严格删除节点(查询节点组[2], 许可.读取令牌())
                : 结构写入结果{};
            悬空目标已识别 = 删除.成功();
        }
        悬空目标已识别 = 运行点查异常(特征键) && 悬空目标已识别;
        验收[6] = 额外反向已识别 && 悬空目标已识别;

        验收[7] = 运行原子故障场景(75920,
            {结构写入确认故障点::节点单项后, 0, 结构写入撤销故障点::无, false, false},
            原子收口参与者模式::正常, 结构写入状态::内部不一致, false);
        验收[8] = 运行原子故障场景(75921,
            {结构写入确认故障点::节点批次后, 0, 结构写入撤销故障点::无, false, false},
            原子收口参与者模式::正常, 结构写入状态::内部不一致, false);
        验收[9] = 运行原子故障场景(75922,
            {结构写入确认故障点::主信息单项后, 0, 结构写入撤销故障点::无, false, false},
            原子收口参与者模式::正常, 结构写入状态::内部不一致, false);
        验收[10] = 运行原子故障场景(75923,
            {结构写入确认故障点::主信息批次后, 0, 结构写入撤销故障点::无, false, false},
            原子收口参与者模式::正常, 结构写入状态::内部不一致, false);
        验收[11] = 运行原子故障场景(75924,
            {结构写入确认故障点::已发布关系变更单项后, 0, 结构写入撤销故障点::无, false, false},
            原子收口参与者模式::正常, 结构写入状态::内部不一致, false);
        验收[12] = 运行原子故障场景(75925,
            {结构写入确认故障点::会话全部确认后, 0, 结构写入撤销故障点::无, false, false},
            原子收口参与者模式::正常, 结构写入状态::内部不一致, false);
        const 结构写入故障自检配置 最终发布前故障{
            结构写入确认故障点::无, 0, 结构写入撤销故障点::无, true, false};
        验收[13] = 运行原子故障场景(75926, 最终发布前故障,
                原子收口参与者模式::准备拒绝, 结构写入状态::许可拒绝, false)
            && 运行原子故障场景(75927, 最终发布前故障,
                原子收口参与者模式::准备抛出, 结构写入状态::内部不一致, false);
        验收[14] = 运行原子故障场景(75928, 最终发布前故障,
                原子收口参与者模式::确认拒绝, 结构写入状态::许可拒绝, false)
            && 运行原子故障场景(75929, 最终发布前故障,
                原子收口参与者模式::确认抛出, 结构写入状态::内部不一致, false);
        验收[15] = 运行原子故障场景(75930, 最终发布前故障,
            原子收口参与者模式::正常, 结构写入状态::内部不一致, false);

        验收[16] = 运行原子故障场景(75931, 最终发布前故障,
                原子收口参与者模式::撤销拒绝, 结构写入状态::内部不一致, true)
            && 运行原子故障场景(75932, 最终发布前故障,
                原子收口参与者模式::撤销抛出, 结构写入状态::内部不一致, true);
        验收[17] = 运行原子故障场景(75933,
            {结构写入确认故障点::无, 0, 结构写入撤销故障点::已发布关系变更, true, false},
            原子收口参与者模式::正常, 结构写入状态::内部不一致, true);
        验收[18] = 运行原子故障场景(75934,
            {结构写入确认故障点::无, 0, 结构写入撤销故障点::索引, true, false},
            原子收口参与者模式::正常, 结构写入状态::内部不一致, true);
        验收[19] = 运行原子故障场景(75935,
            {结构写入确认故障点::无, 0, 结构写入撤销故障点::新关系, true, false},
            原子收口参与者模式::正常, 结构写入状态::内部不一致, true);
        验收[20] = 运行原子故障场景(75936,
            {结构写入确认故障点::无, 0, 结构写入撤销故障点::节点候选, true, false},
            原子收口参与者模式::正常, 结构写入状态::内部不一致, true);
        验收[21] = 运行原子故障场景(75937,
            {结构写入确认故障点::无, 0, 结构写入撤销故障点::主信息候选, true, false},
            原子收口参与者模式::正常, 结构写入状态::内部不一致, true);

        auto 部分接线 = 查询接线;
        部分接线.标记撤销失败隔离 = nullptr;
        bool 主信息部分接线拒绝 = false;
        bool 节点部分接线拒绝 = false;
        bool 关系部分接线拒绝 = false;
        bool 索引部分接线拒绝 = false;
        try { 主信息仓库 部分主信息(759901, 部分接线); }
        catch (const std::invalid_argument&) { 主信息部分接线拒绝 = true; }
        try { 节点仓库 部分节点(查询主信息, 759902, 部分接线); }
        catch (const std::invalid_argument&) { 节点部分接线拒绝 = true; }
        try { 关系仓库 部分关系(查询节点, 759903, 部分接线); }
        catch (const std::invalid_argument&) { 关系部分接线拒绝 = true; }
        try { 索引仓库 部分索引(查询节点, 部分接线); }
        catch (const std::invalid_argument&) { 索引部分接线拒绝 = true; }
        bool 部分执行器回调已运行 = false;
        结构写入执行器 部分执行器(
            部分接线, &查询主信息, &查询节点, &查询关系, &查询索引);
        const auto 部分执行器结果 = 部分执行器.执行(
            [&](结构写入会话&) { 部分执行器回调已运行 = true; });
        const bool 部分接线入口均拒绝 = 主信息部分接线拒绝 && 节点部分接线拒绝
            && 关系部分接线拒绝 && 索引部分接线拒绝
            && !部分执行器.有效() && !部分执行器回调已运行
            && 部分执行器结果.状态 == 结构写入状态::入口拒绝;

        验收[22] = 部分接线入口均拒绝
            && 协调器隔离回归通过 && 仓库统一合同回归通过
            && 已发布关系回归通过 && 特征值事务回归通过;
        验收[23] = true;
        for (std::size_t 索引值 = 0; 索引值 < 23; ++索引值) {
            验收[23] = 验收[23] && 验收[索引值];
        }
    } catch (...) {
    }

    constexpr std::array<const char*, 24> 名称组{
        "物理主键空闲与完整绑定四态分流",
        "同许可连续1024次点查",
        "类型节点与索引值式投影",
        "写前阶段线程与决定门禁",
        "缺失反向索引追根因",
        "重复反向索引追根因",
        "额外反向与悬空目标追根因",
        "F01节点单项确认后恢复前态",
        "F02节点批确认后恢复前态",
        "F03主信息单项确认后恢复前态",
        "F04主信息批确认后恢复前态",
        "F05关系变更确认后恢复前态",
        "F06会话全部确认后恢复前态",
        "F07参与者准备拒绝与抛出恢复前态",
        "F08参与者确认拒绝与抛出恢复前态",
        "F09最终发布前恢复前态",
        "R01参与者撤销失败隔离",
        "R02关系变更撤销失败隔离",
        "R03索引撤销失败隔离",
        "R04新关系撤销失败隔离",
        "R05节点候选撤销失败隔离",
        "R06主信息候选撤销失败隔离",
        "部分接线拒绝与四来源回归",
        "CORE-SESSION-S5局部总成完整"};
    std::size_t 失败数量 = 0;
    for (std::size_t 索引值 = 0; 索引值 < 验收.size(); ++索引值) {
        if (!验收[索引值]) ++失败数量;
        std::cout << "CORE-SESSION-S5-A" << (索引值 + 1 < 10 ? "0" : "") << 索引值 + 1
            << ' ' << 名称组[索引值] << ": " << (验收[索引值] ? "通过" : "失败") << '\n';
    }
    return {"CORE-SESSION-S5", "许可内物理探测计量与全参与者原子收口",
        失败数量 == 0, 验收.size(), 失败数量};
}

自检单元结果 运行完整主信息与强类型投影失败归因自检(
    bool 仓库统一合同回归通过,
    bool 会话回归通过,
    bool 会话材料回归通过,
    bool 已发布关系回归通过,
    bool 许可内原子收口回归通过,
    bool 需求任务方法回归通过) {
    std::array<bool, 18> 验收{};
    try {
        using 节点批量签名 = 节点记录组读取结果 (节点仓库::*)(
            节点类型, const 结构事务令牌&) const;
        using 索引批量签名 = 主键绑定组读取结果 (索引仓库::*)(
            const 结构事务令牌&) const;
        using 投影签名 = 结构写入会话::结构类型索引投影结果 (结构写入会话::*)(节点类型);
        using 完整主信息签名 = 结构写入会话::结构完整主信息读取结果 (结构写入会话::*)(主信息句柄);
        验收[0] = std::is_same_v<
                decltype(static_cast<节点批量签名>(&节点仓库::读取指定类型有效节点记录组)),
                节点批量签名>
            && std::is_same_v<
                decltype(static_cast<索引批量签名>(&索引仓库::读取全部主键绑定组)),
                索引批量签名>
            && std::is_same_v<
                decltype(static_cast<投影签名>(&结构写入会话::读取有效节点与索引投影)),
                投影签名>
            && std::is_same_v<
                decltype(static_cast<完整主信息签名>(&结构写入会话::读取完整主信息)),
                完整主信息签名>
            && 节点记录组读取状态::资源失败 != 节点记录组读取状态::已形成
            && 主键绑定组读取状态::资源失败 != 主键绑定组读取状态::已形成
            && 结构写入会话::类型索引投影状态::资源失败
                != 结构写入会话::类型索引投影状态::已形成;

        结构事务协调器 协调器(76110);
        const auto 接线 = 协调器.生成接线();
        主信息仓库 主信息(761101, 接线);
        节点仓库 节点(主信息, 761102, 接线);
        关系仓库 关系(节点, 761103, 接线);
        索引仓库 索引(节点, 接线);
        结构写入执行器 执行器(接线, &主信息, &节点, &关系, &索引);

        bool 仓库真实空 = false;
        bool 仓库入口拒绝 = false;
        {
            auto 许可 = 接线.取得独占许可(接线.运行期状态);
            const auto 节点空 = 节点.读取指定类型有效节点记录组(
                节点类型::基础信息, 许可.读取令牌());
            const auto 索引空 = 索引.读取全部主键绑定组(许可.读取令牌());
            const auto 节点拒绝 = 节点.读取指定类型有效节点记录组(
                节点类型::基础信息, 结构事务令牌{});
            const auto 索引拒绝 = 索引.读取全部主键绑定组(结构事务令牌{});
            仓库真实空 = 许可.有效()
                && 节点空.状态 == 节点记录组读取状态::已形成 && 节点空.记录组.empty()
                && 索引空.状态 == 主键绑定组读取状态::已形成 && 索引空.记录组.empty();
            仓库入口拒绝 = 节点拒绝.状态 == 节点记录组读取状态::入口拒绝
                && 节点拒绝.记录组.empty()
                && 索引拒绝.状态 == 主键绑定组读取状态::入口拒绝
                && 索引拒绝.记录组.empty();
        }
        验收[1] = 仓库真实空 && 仓库入口拒绝;

        bool 会话真实空 = false;
        const auto 空投影执行 = 执行器.执行([&](结构写入会话& 会话) {
            const auto 投影 = 会话.读取有效节点与索引投影(节点类型::基础信息);
            会话真实空 = 投影.状态 == 结构写入会话::类型索引投影状态::已形成
                && 投影.节点组.empty() && 投影.绑定组.empty();
            (void)会话.请求撤销();
        });
        验收[2] = 会话真实空 && 空投影执行.状态 == 结构写入状态::候选已撤销;

        constexpr std::uint64_t 基线主键 = 7611001;
        主信息句柄 基线主信息;
        节点句柄 基线节点;
        bool 基线完整读回 = false;
        const auto 基线执行 = 执行器.执行([&](结构写入会话& 会话) {
            const auto 主结果 = 会话.创建主信息候选();
            if (!主结果.成功() || !主结果.值.has_value()) return;
            基线主信息 = *主结果.值;
            const auto 节点结果 = 会话.创建节点候选(节点类型::基础信息, 基线主信息);
            if (!节点结果.成功() || !节点结果.值.has_value()) return;
            基线节点 = *节点结果.值;
            if (!会话.绑定主键(基线主键, 基线节点).成功()) return;
            const auto 完整 = 会话.读取完整主信息(基线主信息);
            基线完整读回 = 完整.状态 == 结构写入会话::完整主信息读取状态::已读取
                && 完整.记录.has_value() && 完整.记录->值容器.empty()
                && 会话.节点可读(基线节点)
                && 会话.主键绑定匹配(基线主键, 基线节点);
            if (基线完整读回) (void)会话.请求提交();
        });

        bool 节点资源状态 = false;
        bool 节点资源锁写 = false;
        节点.自检注入下一次节点记录组资源失败();
        const auto 节点资源执行 = 执行器.执行([&](结构写入会话& 会话) {
            const auto 投影 = 会话.读取有效节点与索引投影(节点类型::基础信息);
            节点资源状态 = 投影.状态 == 结构写入会话::类型索引投影状态::资源失败
                && 投影.节点组.empty() && 投影.绑定组.empty();
            节点资源锁写 = !会话.创建主信息候选().成功();
        });
        验收[3] = 基线执行.状态 == 结构写入状态::已提交 && 基线完整读回
            && 节点资源状态 && 节点资源执行.状态 == 结构写入状态::内部不一致;

        bool 索引资源状态 = false;
        bool 索引资源锁写 = false;
        索引.自检注入下一次主键绑定组资源失败();
        const auto 索引资源执行 = 执行器.执行([&](结构写入会话& 会话) {
            const auto 投影 = 会话.读取有效节点与索引投影(节点类型::基础信息);
            索引资源状态 = 投影.状态 == 结构写入会话::类型索引投影状态::资源失败
                && 投影.节点组.empty() && 投影.绑定组.empty();
            索引资源锁写 = !会话.创建主信息候选().成功();
        });
        验收[4] = 索引资源状态 && 索引资源执行.状态 == 结构写入状态::内部不一致;

        bool 一次性恢复 = false;
        const auto 恢复执行 = 执行器.执行([&](结构写入会话& 会话) {
            const auto 投影 = 会话.读取有效节点与索引投影(节点类型::基础信息);
            一次性恢复 = 投影.状态 == 结构写入会话::类型索引投影状态::已形成
                && 投影.节点组.size() == 1 && 投影.绑定组.size() == 1;
            (void)会话.请求撤销();
        });
        验收[5] = 节点资源锁写 && 索引资源锁写 && 一次性恢复
            && 恢复执行.状态 == 结构写入状态::候选已撤销;

        bool 已制造重复反向 = false;
        {
            auto 许可 = 接线.取得独占许可(接线.运行期状态);
            已制造重复反向 = 许可.有效()
                && 索引.自检追加反向绑定(基线主键, 基线节点, 许可.读取令牌());
        }
        bool 内部矛盾状态 = false;
        const auto 内部矛盾执行 = 执行器.执行([&](结构写入会话& 会话) {
            const auto 投影 = 会话.读取有效节点与索引投影(节点类型::基础信息);
            内部矛盾状态 = 投影.状态 == 结构写入会话::类型索引投影状态::内部不一致;
        });
        bool 已恢复重复反向 = false;
        {
            auto 许可 = 接线.取得独占许可(接线.运行期状态);
            已恢复重复反向 = 许可.有效()
                && 索引.自检删除反向绑定(基线主键, 基线节点, 许可.读取令牌());
        }
        验收[6] = 已制造重复反向 && 内部矛盾状态 && 已恢复重复反向
            && 内部矛盾执行.状态 == 结构写入状态::内部不一致;

        std::array<std::int64_t, 16> 测试值组{};
        for (std::size_t 索引值 = 0; 索引值 < 测试值组.size(); ++索引值) {
            测试值组[索引值] = static_cast<std::int64_t>(7612000 + 索引值);
        }
        主信息句柄 多槽主信息;
        bool 十五槽可见 = false;
        bool 额外槽可见 = false;
        bool 完整读回后请求提交 = false;
        bool 写后投影拒绝 = false;
        const auto 多槽执行 = 执行器.执行([&](结构写入会话& 会话) {
            const auto 主结果 = 会话.创建主信息候选();
            if (!主结果.成功() || !主结果.值.has_value()) return;
            多槽主信息 = *主结果.值;
            for (std::size_t 索引值 = 0; 索引值 < 测试值组.size(); ++索引值) {
                if (!会话.写入候选I64值(多槽主信息, 索引值, 测试值组[索引值]).成功()) return;
            }
            写后投影拒绝 = 会话.读取有效节点与索引投影(节点类型::基础信息).状态
                == 结构写入会话::类型索引投影状态::入口拒绝;
            const auto 完整 = 会话.读取完整主信息(多槽主信息);
            if (完整.状态 != 结构写入会话::完整主信息读取状态::已读取
                || !完整.记录.has_value()) return;
            十五槽可见 = 完整.记录->值容器.size() >= 15;
            for (std::size_t 索引值 = 0; 索引值 < 15 && 十五槽可见; ++索引值) {
                十五槽可见 = 完整.记录->值容器[索引值]
                    == std::optional<std::int64_t>{测试值组[索引值]};
            }
            额外槽可见 = 完整.记录->值容器.size() > 15
                && 完整.记录->值容器[15] == std::optional<std::int64_t>{测试值组[15]};
            完整读回后请求提交 = 会话.请求提交();
        });
        const auto 多槽发布记录 = 主信息.读取主信息(多槽主信息);
        验收[7] = 多槽执行.状态 == 结构写入状态::已提交
            && 多槽发布记录.has_value() && 多槽发布记录->值容器.size() == 测试值组.size();
        验收[8] = 十五槽可见;
        验收[9] = 额外槽可见;
        验收[10] = 完整读回后请求提交 && 多槽发布记录.has_value();

        bool 既有完整读取 = false;
        const auto 读取前许可序号 = 读取结构事务下个许可序号自检(接线);
        const auto 既有读取执行 = 执行器.执行([&](结构写入会话& 会话) {
            const auto 投影 = 会话.读取有效节点与索引投影(节点类型::基础信息);
            const auto 完整 = 会话.读取完整主信息(多槽主信息);
            既有完整读取 = 投影.状态 == 结构写入会话::类型索引投影状态::已形成
                && 完整.状态 == 结构写入会话::完整主信息读取状态::已读取
                && 完整.记录.has_value() && 完整.记录->值容器.size() == 测试值组.size();
            (void)会话.请求撤销();
        });
        const auto 读取后许可序号 = 读取结构事务下个许可序号自检(接线);
        验收[11] = 既有完整读取 && 既有读取执行.状态 == 结构写入状态::候选已撤销;

        bool 无效句柄拒绝 = false;
        bool 跨线程拒绝 = false;
        bool 决定后拒绝 = false;
        const auto 拒绝执行 = 执行器.执行([&](结构写入会话& 会话) {
            无效句柄拒绝 = 会话.读取完整主信息(主信息句柄{}).状态
                == 结构写入会话::完整主信息读取状态::入口拒绝;
            std::atomic<bool> 线程结果 = false;
            std::thread 线程([&] {
                线程结果.store(会话.读取完整主信息(多槽主信息).状态
                    == 结构写入会话::完整主信息读取状态::入口拒绝);
            });
            线程.join();
            跨线程拒绝 = 线程结果.load();
            (void)会话.请求撤销();
            决定后拒绝 = 会话.读取完整主信息(多槽主信息).状态
                == 结构写入会话::完整主信息读取状态::入口拒绝;
        });
        bool 版本矛盾 = false;
        主信息句柄 错版本 = 多槽主信息;
        ++错版本.版本号;
        const auto 版本执行 = 执行器.执行([&](结构写入会话& 会话) {
            版本矛盾 = 会话.读取完整主信息(错版本).状态
                == 结构写入会话::完整主信息读取状态::内部不一致;
        });
        验收[12] = 无效句柄拒绝 && 跨线程拒绝 && 决定后拒绝 && 版本矛盾
            && 拒绝执行.状态 == 结构写入状态::候选已撤销
            && 版本执行.状态 == 结构写入状态::内部不一致;
        验收[13] = 写后投影拒绝 && 多槽执行.状态 == 结构写入状态::已提交;

        bool 无写资源失败 = false;
        bool 无写失败锁存 = false;
        const auto 无写资源执行 = 执行器.执行([&](结构写入会话& 会话) {
            会话.自检注入下一次完整主信息读取资源失败();
            const auto 读取 = 会话.读取完整主信息(多槽主信息);
            无写资源失败 = 读取.状态 == 结构写入会话::完整主信息读取状态::资源失败
                && !读取.记录.has_value();
            无写失败锁存 = !会话.创建主信息候选().成功();
        });
        验收[14] = 无写资源失败 && 无写失败锁存
            && 无写资源执行.状态 == 结构写入状态::内部不一致;

        主信息句柄 回退主信息;
        bool 写后资源失败 = false;
        bool 写后失败锁存 = false;
        const auto 写后资源执行 = 执行器.执行([&](结构写入会话& 会话) {
            const auto 主结果 = 会话.创建主信息候选();
            if (!主结果.成功() || !主结果.值.has_value()) return;
            回退主信息 = *主结果.值;
            if (!会话.写入候选I64值(回退主信息, 0, 7613000).成功()) return;
            会话.自检注入下一次完整主信息读取资源失败();
            写后资源失败 = 会话.读取完整主信息(回退主信息).状态
                == 结构写入会话::完整主信息读取状态::资源失败;
            写后失败锁存 = !会话.写入候选I64值(回退主信息, 1, 7613001).成功();
        });
        验收[15] = 写后资源失败 && 写后失败锁存
            && 写后资源执行.状态 == 结构写入状态::内部不一致
            && !主信息.读取主信息(回退主信息).has_value();
        验收[16] = 读取前许可序号 != 0 && 读取后许可序号 == 读取前许可序号 + 1
            && 仓库统一合同回归通过 && 会话回归通过 && 会话材料回归通过
            && 已发布关系回归通过 && 许可内原子收口回归通过
            && 需求任务方法回归通过;
        验收[17] = true;
        for (std::size_t 索引值 = 0; 索引值 < 17; ++索引值) {
            验收[17] = 验收[17] && 验收[索引值];
        }
    } catch (...) {
    }

    constexpr std::array<const char*, 18> 名称组{
        "四态强类型签名与完整主信息签名",
        "仓库真实空与入口拒绝分流",
        "会话真实空投影",
        "节点资源失败不冒充空",
        "索引资源失败不冒充空",
        "资源失败锁写与一次性恢复",
        "索引内部矛盾追根因",
        "完整主信息既有记录值式读取",
        "十五个非空槽完整可见",
        "第十五槽后额外值完整可见",
        "候选完整读回后可提交",
        "写前同许可组合读取",
        "句柄线程决定与版本唯一分流",
        "投影只写前完整读取可写后",
        "完整读取资源失败锁存",
        "写后读取失败完整撤销",
        "单许可与既有六项前序回归",
        "CORE-SESSION-S6局部总成完整"};
    std::size_t 失败数量 = 0;
    for (std::size_t 索引值 = 0; 索引值 < 验收.size(); ++索引值) {
        if (!验收[索引值]) ++失败数量;
        std::cout << "CORE-SESSION-S6-A" << (索引值 + 1 < 10 ? "0" : "") << 索引值 + 1
            << ' ' << 名称组[索引值] << ": " << (验收[索引值] ? "通过" : "失败") << '\n';
    }
    return {"CORE-SESSION-S6", "完整主信息值式读取与强类型投影失败归因",
        失败数量 == 0, 验收.size(), 失败数量};
}
#endif

}
