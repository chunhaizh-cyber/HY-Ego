// 文件规则：索引所有者声明自检只验证稳定值合同、精确绑定和键保留，不进入生产依赖方向。
module;

#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
#include "主信息仓库.h"
#include "节点仓库.h"
#include "索引仓库.h"
#include "索引所有权.数据.h"

#include <algorithm>
#include <array>
#include <cstddef>
#include <cstdint>
#include <iostream>
#include <set>
#include <stdexcept>
#include <type_traits>
#endif

export module 海中鱼巣.核心.自检.索引所有者声明;

#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
import 海中鱼巣.核心.协调.结构事务;
import 海中鱼巣.自检.运行器;

export namespace 海中鱼巣 {

自检单元结果 运行索引所有者声明自检() {
    std::array<bool, 19> 验收{};
    try {
        constexpr std::array 所有者组{
            索引所有者::存在场景,
            索引所有者::状态动态,
            索引所有者::特征体系,
            索引所有者::语素基础,
            索引所有者::轻量因果,
            索引所有者::需求任务方法,
            索引所有者::用途观察};
        std::set<std::uint32_t> 命名域组;
        bool 声明全部完整 = true;
        for (const auto 所有者 : 所有者组) {
            const auto 声明 = 形成索引所有者声明(所有者);
            声明全部完整 = 声明全部完整 && 声明.显式完整();
            命名域组.insert(声明.命名域);
        }
        验收[0] = std::is_standard_layout_v<索引所有者声明>
            && std::is_standard_layout_v<索引绑定请求>;
        验收[1] = 声明全部完整 && 命名域组.size() == 所有者组.size();

        const auto O1声明 = 形成索引所有者声明(索引所有者::用途观察);
        验收[8] = O1声明.命名域 == 0x4F31'5332U
            && O1声明.所有者格式版本 == 1 && O1声明.探测规则版本 == 1
            && O1声明.规范身份字节数 == 36 && O1声明.最大探测次数 == 1024;
        验收[13] = 形成未知兼容索引所有者声明().未知兼容完整()
            && !形成未知兼容索引所有者声明().显式完整();

        结构事务协调器 协调器(970);
        const auto 接线 = 协调器.生成接线();
        主信息仓库 主信息(1970, 接线);
        节点仓库 节点(主信息, 2970, 接线);
        索引仓库 索引(节点, 接线);
        auto 许可 = 接线.取得独占许可(接线.运行期状态);
        if (!许可.有效()) throw std::logic_error("索引所有者声明自检无法取得独占许可");
        const auto& 令牌 = 许可.读取令牌();

        auto 主信息候选 = 主信息.结构化创建主信息未发布候选(令牌);
        if (!主信息候选.成功() || !主信息候选.值.has_value()) {
            throw std::logic_error("索引所有者声明自检无法创建主信息候选");
        }
        auto 节点候选 = 节点.结构化创建节点未发布候选(
            节点类型::基础信息, 主信息候选.值->读取主信息(), 令牌);
        if (!节点候选.成功() || !节点候选.值.has_value()) {
            throw std::logic_error("索引所有者声明自检无法创建节点候选");
        }
        const auto 目标 = 节点候选.值->读取节点();

        std::array<索引绑定请求, 所有者组.size()> 请求组{};
        bool 全部已绑定 = true;
        for (std::size_t 序号 = 0; 序号 < 所有者组.size(); ++序号) {
            请求组[序号] = 形成索引绑定请求(970'100 + 序号, 目标, 所有者组[序号]);
            全部已绑定 = 全部已绑定 && 请求组[序号].显式完整()
                && 索引.结构化绑定主键(请求组[序号], 令牌).改变了结构();
        }
        验收[2] = 全部已绑定;

        const auto 重复 = 索引.结构化绑定主键(请求组[0], 令牌);
        auto 冲突请求 = 请求组[0];
        冲突请求.所有者声明 = 形成索引所有者声明(索引所有者::状态动态);
        const auto 冲突 = 索引.结构化绑定主键(冲突请求, 令牌);
        const auto 冲突后记录 = 索引.读取主键绑定记录(请求组[0].最终物理键, 令牌);
        验收[3] = 重复.状态 == 结构写入状态::幂等读回
            && 冲突.状态 == 结构写入状态::入口拒绝
            && 冲突后记录 == std::optional<主键绑定记录>{主键绑定记录{
                请求组[0].最终物理键, 目标, 请求组[0].所有者声明, 0}};

        const auto 全部绑定 = 索引.读取全部主键绑定组(令牌);
        const auto 未知数量 = std::count_if(
            全部绑定.记录组.cbegin(), 全部绑定.记录组.cend(),
            [](const 主键绑定记录& 记录) {
                return 记录.所有者声明.所有者 == 索引所有者::未知兼容;
            });
        验收[4] = 全部绑定.状态 == 主键绑定组读取状态::已形成
            && 全部绑定.记录组.size() == 所有者组.size() && 未知数量 == 0;
        验收[6] = std::all_of(
            全部绑定.记录组.cbegin(), 全部绑定.记录组.cend(),
            [](const 主键绑定记录& 记录) { return 记录.完整(); });
        验收[7] = std::all_of(
            请求组.cbegin(), 请求组.cend(),
            [](const 索引绑定请求& 请求) {
                return 请求.所有者声明.所有者 != 索引所有者::未知兼容
                    && 请求.探测序号 < 请求.所有者声明.最大探测次数;
            });

        const auto 越界请求 = 形成索引绑定请求(
            970'200, 目标, 索引所有者::用途观察, O1声明.最大探测次数);
        验收[9] = !越界请求.显式完整()
            && 索引.结构化绑定主键(越界请求, 令牌).状态 == 结构写入状态::入口拒绝;

        const bool 删除永久键 = 索引.删除主键(请求组[0].最终物理键, 令牌);
        const auto 重绑永久键 = 索引.结构化绑定主键(请求组[0], 令牌);
        验收[10] = 删除永久键 && 重绑永久键.状态 == 结构写入状态::入口拒绝
            && !索引.按主键查节点(请求组[0].最终物理键, 令牌).has_value();

        const auto 严格删除 = 索引.严格删除主键(
            请求组[1].最终物理键, 目标, 令牌);
        const auto 回滚后重绑 = 索引.结构化绑定主键(请求组[1], 令牌);
        验收[12] = 严格删除.成功() && 回滚后重绑.改变了结构();

        constexpr std::uint64_t 兼容键 = 970'300;
        const auto 兼容绑定 = 索引.结构化绑定主键(兼容键, 目标, 令牌);
        const auto 兼容记录 = 索引.读取主键绑定记录(兼容键, 令牌);
        const bool 兼容删除 = 索引.删除主键(兼容键, 令牌);
        const auto 兼容重绑 = 索引.结构化绑定主键(兼容键, 目标, 令牌);
        验收[5] = 兼容绑定.改变了结构() && 兼容记录.has_value()
            && 兼容记录->所有者声明.所有者 == 索引所有者::未知兼容
            && 兼容删除 && 兼容重绑.改变了结构();

        const auto 排序读回 = 索引.读取全部主键绑定组(令牌);
        验收[11] = 排序读回.状态 == 主键绑定组读取状态::已形成
            && std::is_sorted(
                排序读回.记录组.cbegin(), 排序读回.记录组.cend(),
                [](const 主键绑定记录& 左, const 主键绑定记录& 右) {
                    if (左.主键 != 右.主键) return 左.主键 < 右.主键;
                    return static_cast<std::uint16_t>(左.所有者声明.所有者)
                        < static_cast<std::uint16_t>(右.所有者声明.所有者);
                });
        验收[14] = O1声明.键保留策略 == 索引键保留策略::删除后永久保留;
        验收[15] = 索引.有效主键数量(令牌) == 排序读回.记录组.size();
        验收[16] = 索引.读取节点主键组(目标, 令牌).size() == 排序读回.记录组.size();
        验收[17] = 全部绑定.记录组.front().所有者声明.显式完整();
        验收[18] = true;
    } catch (...) {
    }

    std::size_t 失败数量 = 0;
    for (std::size_t 索引 = 0; 索引 < 验收.size(); ++索引) {
        const bool 通过 = 验收[索引];
        失败数量 += static_cast<std::size_t>(!通过);
        std::cout << "PERSIST-S1-A0-A" << (索引 + 1 < 10 ? "0" : "") << (索引 + 1)
            << '=' << (通过 ? 1 : 0) << '\n';
    }
    return {"PERSIST-S1-A0", "索引所有者命名域与键保留合同", 失败数量 == 0, 验收.size(), 失败数量};
}

}
#endif
