// 文件规则：任务管理线程只接收和排队任务请求材料；不得执行方法、裁决任务结果、写业务结构或定义其他线程角色。
module;

#include "../核心/句柄.h"

#include <atomic>
#include <cstddef>
#include <cstdint>
#include <deque>
#include <functional>
#include <mutex>
#include <optional>
#include <thread>
#include <unordered_map>
#include <utility>

export module 海中鱼巣.线程.任务管理线程;

import 海中鱼巣.线程.运行消息协议;
import 海中鱼巣.线程.有界运行消息队列;
import 海中鱼巣.线程.协议.任务执行请求;

export namespace 海中鱼巣 {

enum class 任务管理线程状态 : std::uint32_t {
    未启动 = 0,
    运行中 = 1,
    正在停止 = 2,
    已停止 = 3,
    启动失败 = 4
};

enum class 任务管理线程拒绝原因 : std::uint32_t {
    无 = 0,
    重复启动 = 1,
    队列容量为零 = 2,
    未启动 = 3,
    停止消息失败 = 4,
    非任务执行请求 = 5,
    请求入队失败 = 6
};

struct 任务管理线程操作结果 {
    bool 成功 = false;
    bool 局部失败 = true;
    bool 写业务事实 = false;
    任务管理线程拒绝原因 拒绝原因 = 任务管理线程拒绝原因::无;
};

enum class 强类型任务执行请求队列状态 : std::uint8_t {
    已拒绝 = 0,
    已预留 = 1,
    已确认 = 2,
    已撤销 = 3,
    已取出 = 4,
    精确重复 = 5,
    无请求 = 6,
    内部不一致 = 7
};

enum class 强类型任务执行请求队列拒绝原因 : std::uint8_t {
    无 = 0,
    请求无效 = 1,
    管理线程未运行 = 2,
    队列已停止 = 3,
    容量为零 = 4,
    队列已满 = 5,
    请求已过期 = 6,
    请求编号冲突 = 7,
    幂等键冲突 = 8,
    任务序号倒退 = 9,
    任务序号冲突 = 10,
    候选能力无效 = 11,
    候选状态冲突 = 12
};

class 任务管理线程;

class 强类型任务执行请求候选 final {
public:
    强类型任务执行请求候选() = delete;
    强类型任务执行请求候选(const 强类型任务执行请求候选&) = delete;
    强类型任务执行请求候选& operator=(const 强类型任务执行请求候选&) = delete;

    强类型任务执行请求候选(强类型任务执行请求候选&& 其他) noexcept;
    强类型任务执行请求候选& operator=(强类型任务执行请求候选&& 其他) noexcept;
    ~强类型任务执行请求候选();

    bool 有效() const noexcept {
        return 所有者_ != nullptr && 请求编号_ != 0 && 预留代次_ != 0 && !已决定_;
    }

    std::uint64_t 读取请求编号() const noexcept { return 请求编号_; }
    std::uint64_t 读取预留代次() const noexcept { return 预留代次_; }

private:
    friend class 任务管理线程;

    强类型任务执行请求候选(
        任务管理线程* 所有者,
        std::uint64_t 请求编号,
        std::uint64_t 预留代次) noexcept
        : 所有者_(所有者), 请求编号_(请求编号), 预留代次_(预留代次) {
    }

    void 置为已决定() noexcept {
        所有者_ = nullptr;
        请求编号_ = 0;
        预留代次_ = 0;
        已决定_ = true;
    }

    任务管理线程* 所有者_ = nullptr;
    std::uint64_t 请求编号_ = 0;
    std::uint64_t 预留代次_ = 0;
    bool 已决定_ = false;
};

struct 强类型任务执行请求准备结果 {
    强类型任务执行请求队列状态 状态 = 强类型任务执行请求队列状态::已拒绝;
    强类型任务执行请求队列拒绝原因 拒绝原因 =
        强类型任务执行请求队列拒绝原因::无;
    std::optional<强类型任务执行请求候选> 候选;
};

struct 强类型任务执行请求操作结果 {
    强类型任务执行请求队列状态 状态 = 强类型任务执行请求队列状态::已拒绝;
    强类型任务执行请求队列拒绝原因 拒绝原因 =
        强类型任务执行请求队列拒绝原因::无;

    bool 成功() const noexcept {
        return 状态 == 强类型任务执行请求队列状态::已确认
            || 状态 == 强类型任务执行请求队列状态::已撤销;
    }
};

struct 强类型任务执行请求取出结果 {
    强类型任务执行请求队列状态 状态 = 强类型任务执行请求队列状态::无请求;
    bool 队列已停止 = false;
    std::optional<任务执行冻结请求> 请求;
};

struct 强类型任务执行请求队列快照 {
    std::uint64_t 容量 = 0;
    std::uint64_t 预留数量 = 0;
    std::uint64_t 可消费数量 = 0;
    std::uint64_t 已见请求数量 = 0;
    std::uint64_t 已见幂等键数量 = 0;
    std::uint64_t 同任务顺序数量 = 0;
    bool 已停止 = false;
};

class 任务管理线程 {
public:
    explicit 任务管理线程(std::uint64_t 调度队列容量)
        : 任务管理线程(调度队列容量, 调度队列容量) {
    }

    任务管理线程(
        std::uint64_t 调度队列容量,
        std::uint64_t 强类型请求队列容量)
        : 任务调度队列(调度队列容量),
          强类型请求容量上限(强类型请求队列容量) {
    }

    ~任务管理线程() {
        {
            std::lock_guard<std::mutex> 锁(强类型请求队列锁);
            强类型请求停止锁存 = true;
        }
        请求停止.store(true);
        if (线程.joinable()) {
            线程.join();
        }
    }

    任务管理线程(const 任务管理线程&) = delete;
    任务管理线程& operator=(const 任务管理线程&) = delete;

    任务管理线程状态 当前状态() const {
        return 状态.load();
    }

    bool 线程已进入() const {
        return 已进入.load();
    }

    bool 线程可收口() const {
        return !线程.joinable();
    }

    const 有界运行消息队列& 只读任务调度队列() const {
        return 任务调度队列;
    }

    强类型任务执行请求准备结果 准备强类型任务执行请求(
        const 任务执行冻结请求& 请求) {
        if (!冻结任务执行请求完整(请求)) {
            return 拒绝强类型请求准备(强类型任务执行请求队列拒绝原因::请求无效);
        }
        std::lock_guard<std::mutex> 锁(强类型请求队列锁);
        if (状态.load() != 任务管理线程状态::运行中) {
            return 拒绝强类型请求准备(
                强类型任务执行请求队列拒绝原因::管理线程未运行);
        }
        if (强类型请求停止锁存) {
            return 拒绝强类型请求准备(强类型任务执行请求队列拒绝原因::队列已停止);
        }
        if (强类型请求容量上限 == 0) {
            return 拒绝强类型请求准备(强类型任务执行请求队列拒绝原因::容量为零);
        }
        if (请求.调度请求.排队时间戳 > 请求.调度请求.截止时间戳) {
            return 拒绝强类型请求准备(强类型任务执行请求队列拒绝原因::请求已过期);
        }

        const auto 请求位置 = 强类型请求记录.find(请求.调度请求.请求编号);
        if (请求位置 != 强类型请求记录.end()) {
            return 冻结任务执行请求相同(请求位置->second.请求, 请求)
                ? 强类型任务执行请求准备结果{
                    强类型任务执行请求队列状态::精确重复,
                    强类型任务执行请求队列拒绝原因::无, std::nullopt}
                : 拒绝强类型请求准备(
                    强类型任务执行请求队列拒绝原因::请求编号冲突);
        }
        const auto 幂等位置 = 强类型幂等请求编号.find(请求.调度请求.幂等键);
        if (幂等位置 != 强类型幂等请求编号.end()) {
            const auto 既有 = 强类型请求记录.find(幂等位置->second);
            if (既有 == 强类型请求记录.end()) {
                return {强类型任务执行请求队列状态::内部不一致,
                    强类型任务执行请求队列拒绝原因::候选状态冲突, std::nullopt};
            }
            return 冻结任务执行请求相同(既有->second.请求, 请求)
                ? 强类型任务执行请求准备结果{
                    强类型任务执行请求队列状态::精确重复,
                    强类型任务执行请求队列拒绝原因::无, std::nullopt}
                : 拒绝强类型请求准备(
                    强类型任务执行请求队列拒绝原因::幂等键冲突);
        }
        const auto 顺序位置 = 强类型同任务最新序号.find(请求.调度请求.任务);
        if (顺序位置 != 强类型同任务最新序号.end()) {
            if (请求.调度请求.任务序号 < 顺序位置->second) {
                return 拒绝强类型请求准备(
                    强类型任务执行请求队列拒绝原因::任务序号倒退);
            }
            if (请求.调度请求.任务序号 == 顺序位置->second) {
                return 拒绝强类型请求准备(
                    强类型任务执行请求队列拒绝原因::任务序号冲突);
            }
        }
        if (强类型活跃请求数量 >= 强类型请求容量上限) {
            return 拒绝强类型请求准备(强类型任务执行请求队列拒绝原因::队列已满);
        }

        ++强类型预留代次;
        if (强类型预留代次 == 0) ++强类型预留代次;
        强类型请求记录.emplace(
            请求.调度请求.请求编号,
            强类型请求内部记录{请求, 强类型预留代次, 强类型请求内部状态::已预留});
        强类型幂等请求编号.emplace(请求.调度请求.幂等键, 请求.调度请求.请求编号);
        强类型同任务最新序号[请求.调度请求.任务] = 请求.调度请求.任务序号;
        ++强类型活跃请求数量;

        强类型任务执行请求准备结果 输出;
        输出.状态 = 强类型任务执行请求队列状态::已预留;
        输出.候选 = 强类型任务执行请求候选(
            this, 请求.调度请求.请求编号, 强类型预留代次);
        return 输出;
    }

    强类型任务执行请求操作结果 确认强类型任务执行请求(
        强类型任务执行请求候选& 候选) {
        std::lock_guard<std::mutex> 锁(强类型请求队列锁);
        if (!候选.有效() || 候选.所有者_ != this) {
            return 拒绝强类型请求操作(强类型任务执行请求队列拒绝原因::候选能力无效);
        }
        const auto 位置 = 强类型请求记录.find(候选.请求编号_);
        if (位置 == 强类型请求记录.end()
            || 位置->second.预留代次 != 候选.预留代次_
            || 位置->second.状态 != 强类型请求内部状态::已预留) {
            return 拒绝强类型请求操作(强类型任务执行请求队列拒绝原因::候选状态冲突);
        }
        位置->second.状态 = 强类型请求内部状态::已确认;
        强类型可消费请求.push_back(候选.请求编号_);
        候选.置为已决定();
        return {强类型任务执行请求队列状态::已确认,
            强类型任务执行请求队列拒绝原因::无};
    }

    强类型任务执行请求操作结果 撤销强类型任务执行请求(
        强类型任务执行请求候选& 候选) {
        std::lock_guard<std::mutex> 锁(强类型请求队列锁);
        if (!候选.有效() || 候选.所有者_ != this) {
            return 拒绝强类型请求操作(强类型任务执行请求队列拒绝原因::候选能力无效);
        }
        if (!撤销强类型请求_已锁定(候选.请求编号_, 候选.预留代次_)) {
            return 拒绝强类型请求操作(强类型任务执行请求队列拒绝原因::候选状态冲突);
        }
        候选.置为已决定();
        return {强类型任务执行请求队列状态::已撤销,
            强类型任务执行请求队列拒绝原因::无};
    }

    强类型任务执行请求取出结果 取出强类型任务执行请求() {
        std::lock_guard<std::mutex> 锁(强类型请求队列锁);
        const bool 已停止 = 强类型请求停止锁存
            || 状态.load() == 任务管理线程状态::正在停止
            || 状态.load() == 任务管理线程状态::已停止;
        if (强类型可消费请求.empty()) {
            return {强类型任务执行请求队列状态::无请求, 已停止, std::nullopt};
        }
        const auto 请求编号 = 强类型可消费请求.front();
        强类型可消费请求.pop_front();
        const auto 位置 = 强类型请求记录.find(请求编号);
        if (位置 == 强类型请求记录.end()
            || 位置->second.状态 != 强类型请求内部状态::已确认
            || 强类型活跃请求数量 == 0) {
            return {强类型任务执行请求队列状态::内部不一致, 已停止, std::nullopt};
        }
        位置->second.状态 = 强类型请求内部状态::已消费;
        --强类型活跃请求数量;
        return {强类型任务执行请求队列状态::已取出, 已停止, 位置->second.请求};
    }

    强类型任务执行请求队列快照 读取强类型任务执行队列快照() const {
        std::lock_guard<std::mutex> 锁(强类型请求队列锁);
        std::uint64_t 预留数量 = 0;
        for (const auto& [编号, 记录] : 强类型请求记录) {
            (void)编号;
            if (记录.状态 == 强类型请求内部状态::已预留) ++预留数量;
        }
        return {
            强类型请求容量上限,
            预留数量,
            static_cast<std::uint64_t>(强类型可消费请求.size()),
            static_cast<std::uint64_t>(强类型请求记录.size()),
            static_cast<std::uint64_t>(强类型幂等请求编号.size()),
            static_cast<std::uint64_t>(强类型同任务最新序号.size()),
            强类型请求停止锁存
                || 状态.load() == 任务管理线程状态::正在停止
                || 状态.load() == 任务管理线程状态::已停止
        };
    }

    任务管理线程操作结果 启动() {
        if (状态.load() == 任务管理线程状态::运行中) {
            return 拒绝(任务管理线程拒绝原因::重复启动);
        }
        if (任务调度队列.容量() == 0) {
            状态.store(任务管理线程状态::启动失败);
            return 拒绝(任务管理线程拒绝原因::队列容量为零);
        }

        {
            std::lock_guard<std::mutex> 锁(强类型请求队列锁);
            强类型请求停止锁存 = false;
        }
        请求停止.store(false);
        已进入.store(false);
        状态.store(任务管理线程状态::运行中);
        线程 = std::thread([this]() {
            已进入.store(true);
            while (!请求停止.load()) {
                std::this_thread::yield();
            }
        });
        return {true, false, false, 任务管理线程拒绝原因::无};
    }

    任务管理线程操作结果 发送任务执行请求(const 运行消息& 请求消息) {
        if (状态.load() != 任务管理线程状态::运行中) {
            return 拒绝(任务管理线程拒绝原因::未启动);
        }
        if (请求消息.类型 != 运行消息类型::任务执行请求) {
            return 拒绝(任务管理线程拒绝原因::非任务执行请求);
        }
        const auto 入队 = 任务调度队列.入队(请求消息);
        if (!入队.已入队) {
            return 拒绝(任务管理线程拒绝原因::请求入队失败);
        }
        return {true, false, false, 任务管理线程拒绝原因::无};
    }

    出队结果 取出任务执行请求() {
        if (状态.load() != 任务管理线程状态::运行中) {
            return {};
        }
        return 任务调度队列.出队();
    }

    任务管理线程操作结果 请求停止并发送停止消息(
        std::uint64_t 停止消息编号, std::uint64_t 停止时间戳) {
        if (状态.load() == 任务管理线程状态::未启动) {
            return 拒绝(任务管理线程拒绝原因::未启动);
        }

        bool 原停止锁存 = false;
        {
            std::lock_guard<std::mutex> 锁(强类型请求队列锁);
            原停止锁存 = 强类型请求停止锁存;
            强类型请求停止锁存 = true;
        }

        运行消息 停止消息;
        停止消息.消息编号 = 停止消息编号;
        停止消息.类型 = 运行消息类型::停止;
        停止消息.来源角色 = 运行线程角色::运行宿主;
        停止消息.目标角色 = 运行线程角色::任务管理;
        停止消息.发生时间戳 = 停止时间戳;
        停止消息.优先级 = 运行消息优先级::停止;
        停止消息.幂等键 = 停止消息编号;
        停止消息.材料摘要 = 停止消息编号;
        停止消息.只读材料说明 = true;
        停止消息.承载机器事实 = false;

        const auto 入队 = 任务调度队列.入队(停止消息);
        if (!入队.已入队) {
            std::lock_guard<std::mutex> 锁(强类型请求队列锁);
            强类型请求停止锁存 = 原停止锁存;
            return 拒绝(任务管理线程拒绝原因::停止消息失败);
        }

        状态.store(任务管理线程状态::正在停止);
        请求停止.store(true);
        return {true, false, false, 任务管理线程拒绝原因::无};
    }

    任务管理线程操作结果 收口等待() {
        if (线程.joinable()) {
            线程.join();
        }
        if (状态.load() == 任务管理线程状态::正在停止
            || 状态.load() == 任务管理线程状态::运行中) {
            状态.store(任务管理线程状态::已停止);
        }
        return {true, false, false, 任务管理线程拒绝原因::无};
    }

private:
    friend class 强类型任务执行请求候选;

    enum class 强类型请求内部状态 : std::uint8_t {
        已预留 = 1,
        已确认 = 2,
        已消费 = 3
    };

    struct 强类型请求内部记录 {
        任务执行冻结请求 请求;
        std::uint64_t 预留代次 = 0;
        强类型请求内部状态 状态 = 强类型请求内部状态::已预留;
    };

    struct 强类型任务句柄哈希 {
        std::size_t operator()(const 节点句柄& 句柄) const noexcept {
            std::size_t 结果 = std::hash<std::uint64_t>{}(句柄.仓库编号);
            结果 ^= std::hash<std::uint64_t>{}(句柄.节点编号)
                + static_cast<std::size_t>(0x9e3779b9U) + (结果 << 6U) + (结果 >> 2U);
            结果 ^= std::hash<std::uint32_t>{}(句柄.版本号)
                + static_cast<std::size_t>(0x9e3779b9U) + (结果 << 6U) + (结果 >> 2U);
            return 结果;
        }
    };

    struct 强类型任务句柄相等 {
        bool operator()(const 节点句柄& 左, const 节点句柄& 右) const noexcept {
            return 左 == 右;
        }
    };

    有界运行消息队列 任务调度队列;
    std::uint64_t 强类型请求容量上限 = 0;
    mutable std::mutex 强类型请求队列锁;
    std::unordered_map<std::uint64_t, 强类型请求内部记录> 强类型请求记录;
    std::unordered_map<std::uint64_t, std::uint64_t> 强类型幂等请求编号;
    std::unordered_map<节点句柄, std::uint64_t,
        强类型任务句柄哈希, 强类型任务句柄相等> 强类型同任务最新序号;
    std::deque<std::uint64_t> 强类型可消费请求;
    std::uint64_t 强类型预留代次 = 0;
    std::uint64_t 强类型活跃请求数量 = 0;
    bool 强类型请求停止锁存 = false;
    std::atomic<任务管理线程状态> 状态 = 任务管理线程状态::未启动;
    std::atomic<bool> 请求停止 = false;
    std::atomic<bool> 已进入 = false;
    std::thread 线程;

    任务管理线程操作结果 拒绝(任务管理线程拒绝原因 原因) const {
        return {false, true, false, 原因};
    }

    static 强类型任务执行请求准备结果 拒绝强类型请求准备(
        强类型任务执行请求队列拒绝原因 原因) {
        return {强类型任务执行请求队列状态::已拒绝, 原因, std::nullopt};
    }

    static 强类型任务执行请求操作结果 拒绝强类型请求操作(
        强类型任务执行请求队列拒绝原因 原因) noexcept {
        return {强类型任务执行请求队列状态::已拒绝, 原因};
    }

    bool 撤销强类型请求_已锁定(
        std::uint64_t 请求编号,
        std::uint64_t 预留代次) {
        const auto 位置 = 强类型请求记录.find(请求编号);
        if (位置 == 强类型请求记录.end()
            || 位置->second.预留代次 != 预留代次
            || 位置->second.状态 != 强类型请求内部状态::已预留
            || 强类型活跃请求数量 == 0) return false;
        const auto 任务 = 位置->second.请求.调度请求.任务;
        const auto 幂等键 = 位置->second.请求.调度请求.幂等键;
        强类型幂等请求编号.erase(幂等键);
        强类型请求记录.erase(位置);
        --强类型活跃请求数量;
        重新计算任务最新序号_已锁定(任务);
        return true;
    }

    void 重新计算任务最新序号_已锁定(节点句柄 任务) {
        std::uint64_t 最新序号 = 0;
        for (const auto& [编号, 记录] : 强类型请求记录) {
            (void)编号;
            if (记录.请求.调度请求.任务 == 任务
                && 记录.请求.调度请求.任务序号 > 最新序号) {
                最新序号 = 记录.请求.调度请求.任务序号;
            }
        }
        if (最新序号 == 0) {
            强类型同任务最新序号.erase(任务);
        } else {
            强类型同任务最新序号[任务] = 最新序号;
        }
    }

    void 析构撤销强类型请求(
        std::uint64_t 请求编号,
        std::uint64_t 预留代次) noexcept {
        std::lock_guard<std::mutex> 锁(强类型请求队列锁);
        (void)撤销强类型请求_已锁定(请求编号, 预留代次);
    }
};

inline 强类型任务执行请求候选::强类型任务执行请求候选(
    强类型任务执行请求候选&& 其他) noexcept
    : 所有者_(其他.所有者_), 请求编号_(其他.请求编号_),
      预留代次_(其他.预留代次_), 已决定_(其他.已决定_) {
    其他.所有者_ = nullptr;
    其他.请求编号_ = 0;
    其他.预留代次_ = 0;
    其他.已决定_ = true;
}

inline 强类型任务执行请求候选& 强类型任务执行请求候选::operator=(
    强类型任务执行请求候选&& 其他) noexcept {
    if (this == &其他) return *this;
    if (有效()) 所有者_->析构撤销强类型请求(请求编号_, 预留代次_);
    所有者_ = 其他.所有者_;
    请求编号_ = 其他.请求编号_;
    预留代次_ = 其他.预留代次_;
    已决定_ = 其他.已决定_;
    其他.所有者_ = nullptr;
    其他.请求编号_ = 0;
    其他.预留代次_ = 0;
    其他.已决定_ = true;
    return *this;
}

inline 强类型任务执行请求候选::~强类型任务执行请求候选() {
    if (有效()) 所有者_->析构撤销强类型请求(请求编号_, 预留代次_);
}

}
