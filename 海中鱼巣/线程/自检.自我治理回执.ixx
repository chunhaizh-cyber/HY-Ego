        && 自我治理第三切片乙顺序消息.来源任务序号 == 3;
    const bool 自我治理第三切片乙验收七结构不变 =
        结构数量相同(自我治理第三切片乙前结构数量, 自我治理第三切片乙后结构数量)
        && 结构数量相同(
            自我治理第三切片乙前运行期结构数量,
            自我治理第三切片乙后运行期结构数量)
        && 自我治理第三切片乙前运行期任务材料.当前生命周期.关系.关系
            == 自我治理第三切片乙后运行期任务材料.当前生命周期.关系.关系
        && 自我治理第三切片乙前运行期任务材料.当前生命周期.版本
            == 自我治理第三切片乙后运行期任务材料.当前生命周期.版本
        && 自我治理第三切片乙前运行期任务材料.当前选择.has_value()
        && 自我治理第三切片乙后运行期任务材料.当前选择.has_value()
        && 自我治理第三切片乙前运行期任务材料.当前选择->方法
            == 自我治理第三切片乙后运行期任务材料.当前选择->方法
        && !自我治理第三切片乙前运行期任务材料.实际结果状态.has_value()
        && !自我治理第三切片乙后运行期任务材料.实际结果状态.has_value()
        && 自我治理第三切片乙前主信息观察.可读数量
            == 自我治理第三切片乙后主信息观察.可读数量
        && 自我治理第三切片乙前主信息观察.内容签名
            == 自我治理第三切片乙后主信息观察.内容签名
        && 自我治理第三切片乙前选择方法.has_value()
        && 自我治理第三切片乙后选择方法.has_value()
        && 自我治理第三切片乙前选择方法.value() == 方法节点
        && 自我治理第三切片乙后选择方法.value() == 方法节点;
    const bool 自我治理第三切片乙验收八禁止越权 =
        自我治理第三切片乙结果消息.来源角色
            == 海中鱼巣::自我治理来源角色::任务管理上行桥
        && 自我治理第三切片乙结果消息.来源服务
            == 海中鱼巣::自我治理服务角色::任务桥边界
        && 自我治理第三切片乙结果消息.目标服务
            == 海中鱼巣::自我治理服务角色::任务
        && 自我治理第三切片乙许可消息.目标服务
            == 海中鱼巣::自我治理服务角色::方法
        && 自我治理第三切片乙结果消息.材料性质
            == 海中鱼巣::自我治理材料性质::非权威回执;
    const bool 自我治理第三切片乙验收九桥接停止 =
        自我治理第三切片乙停止待处理发布.状态
            == 海中鱼巣::强类型任务结果回执发布状态::已发布
        && 自我治理第三切片乙桥停止
            == 海中鱼巣::任务管理上行停止结果::已停止接收
        && 自我治理第三切片乙桥重复停止
            == 海中鱼巣::任务管理上行停止结果::已经停止
        && 自我治理第三切片乙停止后处理.拒绝原因
            == 海中鱼巣::任务管理上行拒绝原因::桥已停止
        && 自我治理第三切片乙桥停止前工作快照.待处理数量 == 1
        && 自我治理第三切片乙桥停止后工作快照.待处理数量 == 1
        && 自我治理第三切片乙桥停止前邮箱快照.待处理数量
            == 自我治理第三切片乙桥停止后邮箱快照.待处理数量
        && 自我治理第三切片乙桥停止前邮箱快照.已见幂等键数量
            == 自我治理第三切片乙桥停止后邮箱快照.已见幂等键数量
        && 自我治理第三切片乙邮箱停止
            == 海中鱼巣::自我治理停止结果::已停止并唤醒
        && 自我治理第三切片乙最终邮箱快照.状态
            == 海中鱼巣::自我治理邮箱状态::已停止
        && 自我治理第三切片乙工作停止.成功
        && 自我治理第三切片乙管理停止.成功
        && 自我治理第三切片乙重复工作停止.成功
        && 自我治理第三切片乙重复管理停止.成功
        && 自我治理第三切片乙工作收口.成功
        && 自我治理第三切片乙管理收口.成功
        && 自我治理第三切片乙重复工作收口.成功
        && 自我治理第三切片乙重复管理收口.成功;
    const bool 自我治理第三切片乙回执复核与治理消息转换通过 =
        自我治理第三切片乙验收一强类型取出
        && 自我治理第三切片乙验收二领域只读复核
        && 自我治理第三切片乙验收三许可预判边界
        && 自我治理第三切片乙验收四消息转换
        && 自我治理第三切片乙验收五唯一邮箱
        && 自我治理第三切片乙验收六同任务顺序
        && 自我治理第三切片乙验收七结构不变
        && 自我治理第三切片乙验收八禁止越权
        && 自我治理第三切片乙验收九桥接停止;

    std::cout << "SELF-GOV-S3B 回执复核许可预判与治理消息转换: "
        << (自我治理第三切片乙回执复核与治理消息转换通过 ? "通过" : "失败") << '\n';
    输出验收项("SELF-GOV-S3B-A1", "强类型回执逐条取出", 自我治理第三切片乙验收一强类型取出);
    std::cout << '\n';
    输出验收项("SELF-GOV-S3B-A2", "领域公开入口只读复核", 自我治理第三切片乙验收二领域只读复核);
    std::cout << '\n';
    输出验收项("SELF-GOV-S3B-A3", "许可预判只形成候选", 自我治理第三切片乙验收三许可预判边界);
    std::cout << '\n';
    输出验收项("SELF-GOV-S3B-A4", "回执字段与句柄版本无损转换", 自我治理第三切片乙验收四消息转换);
    std::cout << '\n';
    输出验收项("SELF-GOV-S3B-A5", "治理消息只进入唯一邮箱", 自我治理第三切片乙验收五唯一邮箱);
    std::cout << '\n';
    输出验收项("SELF-GOV-S3B-A6", "同任务顺序保持", 自我治理第三切片乙验收六同任务顺序);
    std::cout << '\n';
    输出验收项("SELF-GOV-S3B-A7", "桥接前后权威结构不变", 自我治理第三切片乙验收七结构不变);
    std::cout << '\n';
    输出验收项("SELF-GOV-S3B-A8", "无仓库与领域写入越权", 自我治理第三切片乙验收八禁止越权);
    std::cout << '\n';
    输出验收项("SELF-GOV-S3B-A9", "停止后不再取出上行回执", 自我治理第三切片乙验收九桥接停止);
    std::cout << '\n';

    自我治理回执自检报告 报告;
    报告.自我治理第三切片乙验收一强类型取出 = 自我治理第三切片乙验收一强类型取出;
    报告.自我治理第三切片乙验收二领域只读复核 = 自我治理第三切片乙验收二领域只读复核;
    报告.自我治理第三切片乙验收三许可预判边界 = 自我治理第三切片乙验收三许可预判边界;
    报告.自我治理第三切片乙验收四消息转换 = 自我治理第三切片乙验收四消息转换;
    报告.自我治理第三切片乙验收五唯一邮箱 = 自我治理第三切片乙验收五唯一邮箱;
    报告.自我治理第三切片乙验收六同任务顺序 = 自我治理第三切片乙验收六同任务顺序;
    报告.自我治理第三切片乙验收七结构不变 = 自我治理第三切片乙验收七结构不变;
    报告.自我治理第三切片乙验收八禁止越权 = 自我治理第三切片乙验收八禁止越权;
    报告.自我治理第三切片乙验收九桥接停止 = 自我治理第三切片乙验收九桥接停止;
    报告.总通过 = 自我治理第三切片乙回执复核与治理消息转换通过;
    报告.失败数量 = static_cast<std::size_t>(!报告.自我治理第三切片乙验收一强类型取出) +
        static_cast<std::size_t>(!报告.自我治理第三切片乙验收二领域只读复核) +
        static_cast<std::size_t>(!报告.自我治理第三切片乙验收三许可预判边界) +
        static_cast<std::size_t>(!报告.自我治理第三切片乙验收四消息转换) +
        static_cast<std::size_t>(!报告.自我治理第三切片乙验收五唯一邮箱) +
        static_cast<std::size_t>(!报告.自我治理第三切片乙验收六同任务顺序) +
        static_cast<std::size_t>(!报告.自我治理第三切片乙验收七结构不变) +
        static_cast<std::size_t>(!报告.自我治理第三切片乙验收八禁止越权) +
        static_cast<std::size_t>(!报告.自我治理第三切片乙验收九桥接停止);
    return 报告;
}

} // namespace 海中鱼巣
