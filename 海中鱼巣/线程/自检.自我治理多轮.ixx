    自我治理第五切片生产者甲.join();
    自我治理第五切片生产者乙.join();
    const bool 自我治理第五切片生产者已收口 =
        !自我治理第五切片生产者甲.joinable()
        && !自我治理第五切片生产者乙.joinable();
