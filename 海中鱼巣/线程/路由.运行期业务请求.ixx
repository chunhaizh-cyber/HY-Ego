// 文件规则：运行期业务请求路由只做八类强类型同步分派，不创建线程、不持事务能力、不重试。
module;

#include <cstdint>
#include <type_traits>
#include <utility>
#include <variant>

export module 海中鱼巣.线程.路由.运行期业务请求;

import 海中鱼巣.领域.数据操作.存在场景;
import 海中鱼巣.领域.数据操作.状态动态;
import 海中鱼巣.领域.数据操作.特征体系;
import 海中鱼巣.领域.数据操作.语素基础;
import 海中鱼巣.领域.组合.存在场景;
import 海中鱼巣.领域.组合.状态动态;
import 海中鱼巣.领域.组合.特征状态;
import 海中鱼巣.领域.组合.语素概念入口;
import 海中鱼巣.领域.服务.语素;
import 海中鱼巣.领域.组合.概念结构发布;
import 海中鱼巣.领域.组合.需求任务方法;
import 海中鱼巣.领域.组合.运行期业务操作;

export namespace 海中鱼巣 {

enum class 运行期业务路由状态 : std::uint8_t {
    已分派 = 1,
    请求类型拒绝 = 2,
    请求载荷拒绝 = 3,
    业务逻辑内返回 = 4,
    内部不一致 = 5
};

using 运行期业务请求 = std::variant<
    std::monostate,
    已有场景创建并接纳实际存在请求,
    创建状态并记录动态请求,
    创建槽位并发布初始状态请求,
    创建语素概念入口请求,
    发布概念结构请求,
    创建需求并承接任务请求,
    召回并提交唯一选择请求,
    完成任务并独立结算请求>;

using 运行期业务结果 = std::variant<
    std::monostate,
    存在场景业务结果,
    状态动态业务结果,
    特征体系业务结果,
    语义基础业务结果,
    概念结构发布结果,
    创建需求并承接任务结果,
    召回并提交唯一选择结果,
    完成任务并独立结算结果>;

struct 运行期业务路由结果 {
    运行期业务路由状态 状态 = 运行期业务路由状态::请求类型拒绝;
    运行期业务结果 业务结果;

    bool 已分派() const noexcept {
        return 状态 == 运行期业务路由状态::已分派
            && 业务结果.index() != 0;
    }
};

class 运行期业务请求路由 final {
public:
    运行期业务请求路由() = default;

    explicit 运行期业务请求路由(const 运行期业务操作组合器& 业务操作)
        : 业务操作_(&业务操作) {
    }

    bool 有效() const noexcept {
        return 业务操作_ != nullptr && 业务操作_->完整();
    }

    运行期业务路由结果 路由(const 运行期业务请求& 请求) const {
        if (!有效()) return {运行期业务路由状态::内部不一致, {}};
        if (请求.valueless_by_exception() || 请求.index() == 0) {
            return {运行期业务路由状态::请求类型拒绝, {}};
        }

        switch (请求.index()) {
        case 1:
            return 分派(
                std::get<已有场景创建并接纳实际存在请求>(请求),
                &运行期业务操作组合器::在已有场景中创建并接纳实际存在);
        case 2:
            return 分派(
                std::get<创建状态并记录动态请求>(请求),
                &运行期业务操作组合器::创建状态并记录动态);
        case 3:
            return 分派(
                std::get<创建槽位并发布初始状态请求>(请求),
                &运行期业务操作组合器::创建槽位并发布初始状态);
        case 4:
            return 分派(
                std::get<创建语素概念入口请求>(请求),
                &运行期业务操作组合器::创建语素概念入口);
        case 5:
            return 分派(
                std::get<发布概念结构请求>(请求),
                &运行期业务操作组合器::发布概念结构);
        case 6:
            return 分派(
                std::get<创建需求并承接任务请求>(请求),
                &运行期业务操作组合器::创建需求并承接任务);
        case 7:
            return 分派(
                std::get<召回并提交唯一选择请求>(请求),
                &运行期业务操作组合器::召回并提交唯一选择);
        case 8:
            return 分派(
                std::get<完成任务并独立结算请求>(请求),
                &运行期业务操作组合器::完成任务并独立结算);
        default:
            return {运行期业务路由状态::请求类型拒绝, {}};
        }
    }

private:
    template <class 请求类型, class 结果类型>
    运行期业务路由结果 分派(
        const 请求类型& 请求,
        结果类型 (运行期业务操作组合器::*入口)(const 请求类型&) const) const {
        if (!运行期业务操作组合器::请求完整(请求)) {
            return {运行期业务路由状态::请求载荷拒绝, {}};
        }
        auto 结果 = (业务操作_->*入口)(请求);
        const auto 状态 = 分类结果(结果);
        return {状态, 运行期业务结果{
            std::in_place_type<结果类型>, std::move(结果)}};
    }

    static 运行期业务路由状态 分类通用结果(
        bool 成功,
        bool 内部不一致) noexcept {
        if (内部不一致) return 运行期业务路由状态::内部不一致;
        return 成功
            ? 运行期业务路由状态::已分派
            : 运行期业务路由状态::业务逻辑内返回;
    }

    static 运行期业务路由状态 分类结果(
        const 存在场景业务结果& 结果) noexcept {
        return 分类通用结果(
            结果.成功(), 结果.状态 == 存在场景业务状态::内部不一致);
    }

    static 运行期业务路由状态 分类结果(
        const 状态动态业务结果& 结果) noexcept {
        return 分类通用结果(
            结果.成功(), 结果.状态 == 状态动态业务状态::内部不一致);
    }

    static 运行期业务路由状态 分类结果(
        const 特征体系业务结果& 结果) noexcept {
        return 分类通用结果(
            结果.成功(), 结果.状态 == 特征体系业务状态::内部不一致);
    }

    static 运行期业务路由状态 分类结果(
        const 语义基础业务结果& 结果) noexcept {
        return 分类通用结果(
            结果.成功(), 结果.状态 == 语义基础业务状态::内部不一致);
    }

    static 运行期业务路由状态 分类结果(
        const 概念结构发布结果& 结果) noexcept {
        const bool 内部不一致 =
            结果.根角色.状态 == 概念图结构读取状态::内部不一致
            || 结果.关系结果.状态 == 概念图结构业务状态::内部不一致;
        return 分类通用结果(结果.成功(), 内部不一致);
    }

    static 运行期业务路由状态 分类结果(
        const 创建需求并承接任务结果& 结果) noexcept {
        const bool 内部不一致 =
            结果.需求.状态 == 需求任务方法业务状态::内部不一致
            || 结果.任务.状态 == 需求任务方法业务状态::内部不一致;
        return 分类通用结果(结果.成功(), 内部不一致);
    }

    static 运行期业务路由状态 分类结果(
        const 召回并提交唯一选择结果& 结果) noexcept {
        const bool 内部不一致 = 结果.召回.状态 == 方法召回状态::内部不一致
            || 结果.选择.状态 == 需求任务方法业务状态::内部不一致;
        return 分类通用结果(结果.成功(), 内部不一致);
    }

    static 运行期业务路由状态 分类结果(
        const 完成任务并独立结算结果& 结果) noexcept {
        const bool 内部不一致 =
            结果.完成.状态 == 需求任务方法业务状态::内部不一致
            || 结果.结算.状态 == 需求任务方法业务状态::内部不一致;
        return 分类通用结果(结果.全部成功(), 内部不一致);
    }

    const 运行期业务操作组合器* 业务操作_ = nullptr;
};

static_assert(std::variant_size_v<运行期业务请求> == 9);
static_assert(std::variant_size_v<运行期业务结果> == 9);

}
