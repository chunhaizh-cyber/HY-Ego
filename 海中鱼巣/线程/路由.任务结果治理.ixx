// 文件规则：任务结果治理路由只在工作线程锁外准入回执并调用窄组合器；不得持有业务服务或事务能力。
module;

#include <cstdint>

export module 海中鱼巣.线程.路由.任务结果治理;

import 海中鱼巣.领域.组合.任务结果结算;
import 海中鱼巣.线程.任务结果回执协议;
import 海中鱼巣.线程.任务工作线程;

export namespace 海中鱼巣 {

enum class 任务结果治理路由状态 : std::uint8_t {
    入口拒绝 = 0,
    回执协议拒绝 = 1,
    无可处理回执 = 2,
    已处理 = 3,
    内部不一致 = 4
};

struct 任务结果治理路由结果 {
    任务结果治理路由状态 状态 = 任务结果治理路由状态::入口拒绝;
    bool 队列已停止 = false;
    任务结果回执准入结果 协议结果;
    任务结果治理结果 治理结果;

    bool 已处理() const noexcept {
        return 状态 == 任务结果治理路由状态::已处理;
    }
};

class 任务结果治理路由 final {
public:
    explicit 任务结果治理路由(任务结果结算组合器& 组合器)
        : 组合器_(组合器) {
    }

    任务结果治理路由结果 处理显式回执(
        const 任务结果治理请求& 请求) const {
        任务结果治理路由结果 输出;
        输出.协议结果 = 复核任务结果回执材料(
            请求.回执, 任务结果回执准入上下文{请求.参数.当前时间戳});
        if (请求.回执.材料性质 != 任务结果回执材料性质::非权威任务执行结果证据
            || 输出.协议结果.状态 == 任务结果回执准入状态::已拒绝) {
            输出.状态 = 任务结果治理路由状态::回执协议拒绝;
            return 输出;
        }
        if (输出.协议结果.状态 != 任务结果回执准入状态::可准入) {
            输出.状态 = 任务结果治理路由状态::内部不一致;
            return 输出;
        }
        输出.治理结果 = 组合器_.处理任务执行结果(请求);
        输出.状态 = 输出.治理结果.状态 == 任务结果治理状态::内部不一致
            ? 任务结果治理路由状态::内部不一致
            : 任务结果治理路由状态::已处理;
        return 输出;
    }

    任务结果治理路由结果 处理工作线程一条回执(
        任务工作线程& 工作线程,
        const 任务结果治理参数& 参数) const {
        const auto 取出 = 工作线程.取出一条任务结果回执();
        if (!取出.有回执) {
            任务结果治理路由结果 输出;
            输出.状态 = 任务结果治理路由状态::无可处理回执;
            输出.队列已停止 = 取出.队列已停止;
            return 输出;
        }
        auto 输出 = 处理显式回执({取出.回执, 参数});
        输出.队列已停止 = 取出.队列已停止;
        return 输出;
    }

private:
    任务结果结算组合器& 组合器_;
};

}
