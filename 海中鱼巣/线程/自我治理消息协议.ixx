// 文件规则：自我治理消息协议只定义非权威只读材料和值复核；不得调用领域入口、写机器结构或管理并发承载。
module;

#include "../核心/句柄.h"

#include <cstdint>
#include <optional>

export module 海中鱼巣.线程.自我治理消息协议;

export namespace 海中鱼巣 {

inline constexpr std::uint32_t 自我治理协议版本 = 1;

enum class 自我治理消息类型 : std::uint32_t {
    未知 = 0,
    任务结果复核请求 = 1,
    派生需求请求 = 2,
    观察材料准入请求 = 3,
    执行前许可预判请求 = 4,
    自检缺口候选 = 5,
    缓存刷新请求 = 6,
    事件日志请求 = 7,
    停止请求 = 8
};

enum class 自我治理来源角色 : std::uint32_t {
    未知 = 0,
    运行宿主 = 1,
    任务管理上行桥 = 2,
    任务需求分析入口 = 3,
    外部材料适配入口 = 4,
    已确认自检入口 = 5,
    领域落账观察桥 = 6
};

enum class 自我治理服务角色 : std::uint32_t {
    未知 = 0,
    运行边界 = 1,
    任务桥边界 = 2,
    需求分析边界 = 3,
    材料适配边界 = 4,
    自检边界 = 5,
    领域观察边界 = 6,
    治理边界 = 7,
    存在 = 8,
    场景 = 9,
    特征 = 10,
    状态 = 11,
    动态 = 12,
    因果 = 13,
    需求 = 14,
    任务 = 15,
    方法 = 16,
    统计 = 17,
    日志边界 = 18
};

enum class 自我治理消息优先级 : std::uint32_t {
    未知 = 0,
    低 = 1,
    普通 = 2,
    高 = 3,
    停止 = 4
};

enum class 自我治理只读材料类型 : std::uint32_t {
    未知 = 0,
    任务结果材料 = 1,
    需求派生材料 = 2,
    观察输入材料 = 3,
    许可预判材料 = 4,
    自检缺口材料 = 5,
    缓存观察材料 = 6,
    事件审计材料 = 7,
    停止信号材料 = 8
};

enum class 自我治理材料性质 : std::uint32_t {
    未知 = 0,
    非权威请求 = 1,
    非权威回执 = 2,
    非权威候选 = 3,
    非权威观察 = 4,
    生命周期信号 = 5,
    机器事实声明 = 6,
    执行许可声明 = 7
};

enum class 自我治理过期策略 : std::uint32_t {
    未知 = 0,
    永不过期 = 1,
    截止时间 = 2
};

enum class 自我治理准入状态 : std::uint32_t {
    已拒绝 = 0,
    可准入 = 1,
    重复材料 = 2,
    内部不一致 = 3
};

enum class 自我治理拒绝原因 : std::uint32_t {
    无 = 0,
    协议版本不匹配 = 1,
    消息编号无效 = 2,
    消息类型未知 = 3,
    来源角色未知 = 4,
    来源服务未知 = 5,
    目标服务未知 = 6,
    发生时间戳无效 = 7,
    优先级未知 = 8,
    幂等键无效 = 9,
    批次编号无效 = 10,
    材料摘要无效 = 11,
    材料类型未知 = 12,
    材料性质未知 = 13,
    材料性质越权 = 14,
    过期策略未知 = 15,
    当前时间戳无效 = 16,
    截止时间缺失 = 17,
    材料已过期 = 18,
    句柄形状无效 = 19,
    来源与消息类型不匹配 = 20,
    目标服务与消息类型不匹配 = 21,
    材料类型与消息类型不匹配 = 22,
    材料性质与消息类型不匹配 = 23,
    必填句柄缺失 = 24,
    特征定义与实例槽位相同 = 25,
    任务序号缺失 = 26,
    停止来源无效 = 27,
    停止优先级无效 = 28,
    普通消息冒用停止优先级 = 29,
    停止消息携带业务材料 = 30,
    幂等键冲突 = 31,
    同一任务序号倒退 = 32,
    重复材料 = 33,
    准入上下文不一致 = 34,
    句柄当前版本不匹配 = 35,
    节点类型不匹配 = 36,
    任务授权关系不满足 = 37,
    任务承接状态不满足 = 38,
    任务选择方法关系不满足 = 39
};

struct 自我治理只读材料句柄组 {
    节点句柄 主体;
    节点句柄 场景;
    节点句柄 目标宿主;
    节点句柄 目标需求;
    节点句柄 目标任务;
    节点句柄 目标方法;
    节点句柄 目标动作入口;
    节点句柄 目标材料;
    节点句柄 目标特征定义;
    节点句柄 实例特征槽位;
    节点句柄 当前特征状态材料;
    节点句柄 目标状态;
    节点句柄 实际结果状态;
    节点句柄 动态证据;
};

struct 自我治理消息 {
    std::uint32_t 协议版本 = 自我治理协议版本;
    std::uint64_t 治理消息编号 = 0;
    自我治理消息类型 类型 = 自我治理消息类型::未知;
    自我治理来源角色 来源角色 = 自我治理来源角色::未知;
    自我治理服务角色 来源服务 = 自我治理服务角色::未知;
    自我治理服务角色 目标服务 = 自我治理服务角色::未知;
    std::uint64_t 发生时间戳 = 0;
    自我治理消息优先级 优先级 = 自我治理消息优先级::未知;
    std::uint64_t 幂等键 = 0;
    std::uint64_t 来源任务序号 = 0;
    std::uint64_t 批次编号 = 0;
    std::uint64_t 非权威材料摘要 = 0;
    自我治理只读材料类型 材料类型 = 自我治理只读材料类型::未知;
    自我治理材料性质 材料性质 = 自我治理材料性质::未知;
    自我治理过期策略 过期策略 = 自我治理过期策略::未知;
    std::uint64_t 截止时间戳 = 0;
    自我治理只读材料句柄组 句柄组;
};

struct 自我治理准入上下文 {
    std::uint64_t 当前时间戳 = 0;
    std::optional<自我治理消息> 同幂等键既有消息;
    节点句柄 同任务目标;
    std::uint64_t 同任务最新序号 = 0;
};

struct 自我治理准入结果 {
    自我治理准入状态 状态 = 自我治理准入状态::已拒绝;
    自我治理拒绝原因 拒绝原因 = 自我治理拒绝原因::无;
};

inline bool 自我治理句柄为空(const 节点句柄& 句柄) {
    return 句柄.仓库编号 == 0 && 句柄.节点编号 == 0 && 句柄.版本号 == 0;
}

inline bool 自我治理可选句柄形状有效(const 节点句柄& 句柄) {
    return 自我治理句柄为空(句柄) || 句柄有效(句柄);
}

inline bool 自我治理句柄组相同(
    const 自我治理只读材料句柄组& 左,
    const 自我治理只读材料句柄组& 右) {
    return 左.主体 == 右.主体
        && 左.场景 == 右.场景
        && 左.目标宿主 == 右.目标宿主
        && 左.目标需求 == 右.目标需求
        && 左.目标任务 == 右.目标任务
        && 左.目标方法 == 右.目标方法
        && 左.目标动作入口 == 右.目标动作入口
        && 左.目标材料 == 右.目标材料
        && 左.目标特征定义 == 右.目标特征定义
        && 左.实例特征槽位 == 右.实例特征槽位
        && 左.当前特征状态材料 == 右.当前特征状态材料
        && 左.目标状态 == 右.目标状态
        && 左.实际结果状态 == 右.实际结果状态
        && 左.动态证据 == 右.动态证据;
}

inline bool 自我治理消息相同(const 自我治理消息& 左, const 自我治理消息& 右) {
    return 左.协议版本 == 右.协议版本
        && 左.治理消息编号 == 右.治理消息编号
        && 左.类型 == 右.类型
        && 左.来源角色 == 右.来源角色
        && 左.来源服务 == 右.来源服务
        && 左.目标服务 == 右.目标服务
        && 左.发生时间戳 == 右.发生时间戳
        && 左.优先级 == 右.优先级
        && 左.幂等键 == 右.幂等键
        && 左.来源任务序号 == 右.来源任务序号
        && 左.批次编号 == 右.批次编号
        && 左.非权威材料摘要 == 右.非权威材料摘要
        && 左.材料类型 == 右.材料类型
        && 左.材料性质 == 右.材料性质
        && 左.过期策略 == 右.过期策略
        && 左.截止时间戳 == 右.截止时间戳
        && 自我治理句柄组相同(左.句柄组, 右.句柄组);
}

inline 自我治理准入结果 拒绝自我治理消息(自我治理拒绝原因 原因) {
    return {自我治理准入状态::已拒绝, 原因};
}

inline 自我治理准入结果 标记自我治理内部不一致(自我治理拒绝原因 原因) {
    return {自我治理准入状态::内部不一致, 原因};
}

inline bool 自我治理消息类型有效(自我治理消息类型 类型) {
    switch (类型) {
    case 自我治理消息类型::任务结果复核请求:
    case 自我治理消息类型::派生需求请求:
    case 自我治理消息类型::观察材料准入请求:
    case 自我治理消息类型::执行前许可预判请求:
    case 自我治理消息类型::自检缺口候选:
    case 自我治理消息类型::缓存刷新请求:
    case 自我治理消息类型::事件日志请求:
    case 自我治理消息类型::停止请求:
        return true;
    default:
        return false;
    }
}

inline bool 自我治理来源角色有效(自我治理来源角色 角色) {
    switch (角色) {
    case 自我治理来源角色::运行宿主:
    case 自我治理来源角色::任务管理上行桥:
    case 自我治理来源角色::任务需求分析入口:
    case 自我治理来源角色::外部材料适配入口:
    case 自我治理来源角色::已确认自检入口:
    case 自我治理来源角色::领域落账观察桥:
        return true;
    default:
        return false;
    }
}

inline bool 自我治理服务角色有效(自我治理服务角色 角色) {
    switch (角色) {
    case 自我治理服务角色::运行边界:
    case 自我治理服务角色::任务桥边界:
    case 自我治理服务角色::需求分析边界:
    case 自我治理服务角色::材料适配边界:
    case 自我治理服务角色::自检边界:
    case 自我治理服务角色::领域观察边界:
    case 自我治理服务角色::治理边界:
    case 自我治理服务角色::存在:
    case 自我治理服务角色::场景:
    case 自我治理服务角色::特征:
    case 自我治理服务角色::状态:
    case 自我治理服务角色::动态:
    case 自我治理服务角色::因果:
    case 自我治理服务角色::需求:
    case 自我治理服务角色::任务:
    case 自我治理服务角色::方法:
    case 自我治理服务角色::统计:
    case 自我治理服务角色::日志边界:
        return true;
    default:
        return false;
    }
}

inline bool 自我治理消息优先级有效(自我治理消息优先级 优先级) {
    switch (优先级) {
    case 自我治理消息优先级::低:
    case 自我治理消息优先级::普通:
    case 自我治理消息优先级::高:
    case 自我治理消息优先级::停止:
        return true;
    default:
        return false;
    }
}

inline bool 自我治理材料类型有效(自我治理只读材料类型 类型) {
    switch (类型) {
    case 自我治理只读材料类型::任务结果材料:
    case 自我治理只读材料类型::需求派生材料:
    case 自我治理只读材料类型::观察输入材料:
    case 自我治理只读材料类型::许可预判材料:
    case 自我治理只读材料类型::自检缺口材料:
    case 自我治理只读材料类型::缓存观察材料:
    case 自我治理只读材料类型::事件审计材料:
    case 自我治理只读材料类型::停止信号材料:
        return true;
    default:
        return false;
    }
}

inline bool 自我治理材料性质有效(自我治理材料性质 性质) {
    switch (性质) {
    case 自我治理材料性质::非权威请求:
    case 自我治理材料性质::非权威回执:
    case 自我治理材料性质::非权威候选:
    case 自我治理材料性质::非权威观察:
    case 自我治理材料性质::生命周期信号:
    case 自我治理材料性质::机器事实声明:
    case 自我治理材料性质::执行许可声明:
        return true;
    default:
        return false;
    }
}

inline bool 自我治理过期策略有效(自我治理过期策略 策略) {
    return 策略 == 自我治理过期策略::永不过期
        || 策略 == 自我治理过期策略::截止时间;
}

inline bool 自我治理基础服务目标有效(自我治理服务角色 角色) {
    return 角色 == 自我治理服务角色::存在
        || 角色 == 自我治理服务角色::场景
        || 角色 == 自我治理服务角色::特征
        || 角色 == 自我治理服务角色::状态
        || 角色 == 自我治理服务角色::动态
        || 角色 == 自我治理服务角色::因果;
}

inline bool 自我治理全部句柄为空(const 自我治理只读材料句柄组& 句柄组) {
    return 自我治理句柄为空(句柄组.主体)
        && 自我治理句柄为空(句柄组.场景)
        && 自我治理句柄为空(句柄组.目标宿主)
        && 自我治理句柄为空(句柄组.目标需求)
        && 自我治理句柄为空(句柄组.目标任务)
        && 自我治理句柄为空(句柄组.目标方法)
        && 自我治理句柄为空(句柄组.目标动作入口)
        && 自我治理句柄为空(句柄组.目标材料)
        && 自我治理句柄为空(句柄组.目标特征定义)
        && 自我治理句柄为空(句柄组.实例特征槽位)
        && 自我治理句柄为空(句柄组.当前特征状态材料)
        && 自我治理句柄为空(句柄组.目标状态)
        && 自我治理句柄为空(句柄组.实际结果状态)
        && 自我治理句柄为空(句柄组.动态证据);
}

inline bool 自我治理全部句柄形状有效(const 自我治理只读材料句柄组& 句柄组) {
    return 自我治理可选句柄形状有效(句柄组.主体)
        && 自我治理可选句柄形状有效(句柄组.场景)
        && 自我治理可选句柄形状有效(句柄组.目标宿主)
        && 自我治理可选句柄形状有效(句柄组.目标需求)
        && 自我治理可选句柄形状有效(句柄组.目标任务)
        && 自我治理可选句柄形状有效(句柄组.目标方法)
        && 自我治理可选句柄形状有效(句柄组.目标动作入口)
        && 自我治理可选句柄形状有效(句柄组.目标材料)
        && 自我治理可选句柄形状有效(句柄组.目标特征定义)
        && 自我治理可选句柄形状有效(句柄组.实例特征槽位)
        && 自我治理可选句柄形状有效(句柄组.当前特征状态材料)
        && 自我治理可选句柄形状有效(句柄组.目标状态)
        && 自我治理可选句柄形状有效(句柄组.实际结果状态)
        && 自我治理可选句柄形状有效(句柄组.动态证据);
}

inline 自我治理拒绝原因 复核自我治理路由与材料(const 自我治理消息& 消息) {
    const auto 来源匹配 = [&消息](自我治理来源角色 角色, 自我治理服务角色 服务) {
        return 消息.来源角色 == 角色 && 消息.来源服务 == 服务;
    };
    const auto 材料匹配 = [&消息](自我治理只读材料类型 类型, 自我治理材料性质 性质) {
        return 消息.材料类型 == 类型 && 消息.材料性质 == 性质;
    };

    switch (消息.类型) {
    case 自我治理消息类型::任务结果复核请求:
        if (!来源匹配(自我治理来源角色::任务管理上行桥, 自我治理服务角色::任务桥边界)) {
            return 自我治理拒绝原因::来源与消息类型不匹配;
        }
        if (消息.目标服务 != 自我治理服务角色::任务) {
            return 自我治理拒绝原因::目标服务与消息类型不匹配;
        }
        if (!材料匹配(自我治理只读材料类型::任务结果材料, 自我治理材料性质::非权威回执)) {
            return 消息.材料类型 != 自我治理只读材料类型::任务结果材料
                ? 自我治理拒绝原因::材料类型与消息类型不匹配
                : 自我治理拒绝原因::材料性质与消息类型不匹配;
        }
        break;
    case 自我治理消息类型::派生需求请求:
        if (!来源匹配(自我治理来源角色::任务需求分析入口, 自我治理服务角色::需求分析边界)) {
            return 自我治理拒绝原因::来源与消息类型不匹配;
        }
        if (消息.目标服务 != 自我治理服务角色::需求) {
            return 自我治理拒绝原因::目标服务与消息类型不匹配;
        }
        if (!材料匹配(自我治理只读材料类型::需求派生材料, 自我治理材料性质::非权威候选)) {
            return 消息.材料类型 != 自我治理只读材料类型::需求派生材料
                ? 自我治理拒绝原因::材料类型与消息类型不匹配
                : 自我治理拒绝原因::材料性质与消息类型不匹配;
        }
        break;
    case 自我治理消息类型::观察材料准入请求:
        if (!(来源匹配(自我治理来源角色::外部材料适配入口, 自我治理服务角色::材料适配边界)
            || 来源匹配(自我治理来源角色::任务管理上行桥, 自我治理服务角色::任务桥边界))) {
            return 自我治理拒绝原因::来源与消息类型不匹配;
        }
        if (!自我治理基础服务目标有效(消息.目标服务)) {
            return 自我治理拒绝原因::目标服务与消息类型不匹配;
        }
        if (!材料匹配(自我治理只读材料类型::观察输入材料, 自我治理材料性质::非权威观察)) {
            return 消息.材料类型 != 自我治理只读材料类型::观察输入材料
                ? 自我治理拒绝原因::材料类型与消息类型不匹配
                : 自我治理拒绝原因::材料性质与消息类型不匹配;
        }
        break;
    case 自我治理消息类型::执行前许可预判请求:
        if (!来源匹配(自我治理来源角色::任务管理上行桥, 自我治理服务角色::任务桥边界)) {
            return 自我治理拒绝原因::来源与消息类型不匹配;
        }
        if (消息.目标服务 != 自我治理服务角色::任务
            && 消息.目标服务 != 自我治理服务角色::方法) {
            return 自我治理拒绝原因::目标服务与消息类型不匹配;
        }
        if (!材料匹配(自我治理只读材料类型::许可预判材料, 自我治理材料性质::非权威请求)) {
            return 消息.材料类型 != 自我治理只读材料类型::许可预判材料
                ? 自我治理拒绝原因::材料类型与消息类型不匹配
                : 自我治理拒绝原因::材料性质与消息类型不匹配;
        }
        break;
    case 自我治理消息类型::自检缺口候选:
        if (!来源匹配(自我治理来源角色::已确认自检入口, 自我治理服务角色::自检边界)) {
            return 自我治理拒绝原因::来源与消息类型不匹配;
        }
        if (消息.目标服务 != 自我治理服务角色::治理边界) {
            return 自我治理拒绝原因::目标服务与消息类型不匹配;
        }
        if (!材料匹配(自我治理只读材料类型::自检缺口材料, 自我治理材料性质::非权威候选)) {
            return 消息.材料类型 != 自我治理只读材料类型::自检缺口材料
                ? 自我治理拒绝原因::材料类型与消息类型不匹配
                : 自我治理拒绝原因::材料性质与消息类型不匹配;
        }
        break;
    case 自我治理消息类型::缓存刷新请求:
        if (!来源匹配(自我治理来源角色::领域落账观察桥, 自我治理服务角色::领域观察边界)) {
            return 自我治理拒绝原因::来源与消息类型不匹配;
        }
        if (消息.目标服务 != 自我治理服务角色::统计) {
            return 自我治理拒绝原因::目标服务与消息类型不匹配;
        }
        if (!材料匹配(自我治理只读材料类型::缓存观察材料, 自我治理材料性质::非权威观察)) {
            return 消息.材料类型 != 自我治理只读材料类型::缓存观察材料
                ? 自我治理拒绝原因::材料类型与消息类型不匹配
                : 自我治理拒绝原因::材料性质与消息类型不匹配;
        }
        break;
    case 自我治理消息类型::事件日志请求:
        if (!来源匹配(自我治理来源角色::领域落账观察桥, 自我治理服务角色::领域观察边界)) {
            return 自我治理拒绝原因::来源与消息类型不匹配;
        }
        if (消息.目标服务 != 自我治理服务角色::日志边界) {
            return 自我治理拒绝原因::目标服务与消息类型不匹配;
        }
        if (!材料匹配(自我治理只读材料类型::事件审计材料, 自我治理材料性质::非权威观察)) {
            return 消息.材料类型 != 自我治理只读材料类型::事件审计材料
                ? 自我治理拒绝原因::材料类型与消息类型不匹配
                : 自我治理拒绝原因::材料性质与消息类型不匹配;
        }
        break;
    case 自我治理消息类型::停止请求:
        if (!来源匹配(自我治理来源角色::运行宿主, 自我治理服务角色::运行边界)) {
            return 自我治理拒绝原因::停止来源无效;
        }
        if (消息.目标服务 != 自我治理服务角色::治理边界) {
            return 自我治理拒绝原因::目标服务与消息类型不匹配;
        }
        if (!材料匹配(自我治理只读材料类型::停止信号材料, 自我治理材料性质::生命周期信号)) {
            return 消息.材料类型 != 自我治理只读材料类型::停止信号材料
                ? 自我治理拒绝原因::材料类型与消息类型不匹配
                : 自我治理拒绝原因::材料性质与消息类型不匹配;
        }
        break;
    default:
        return 自我治理拒绝原因::消息类型未知;
    }
    return 自我治理拒绝原因::无;
}

inline 自我治理拒绝原因 复核自我治理必填材料(const 自我治理消息& 消息) {
    const auto& 句柄 = 消息.句柄组;
    switch (消息.类型) {
    case 自我治理消息类型::任务结果复核请求:
        if (!句柄有效(句柄.目标任务)
            || !句柄有效(句柄.实际结果状态)
            || !句柄有效(句柄.动态证据)) {
            return 自我治理拒绝原因::必填句柄缺失;
        }
        if (消息.来源任务序号 == 0) {
            return 自我治理拒绝原因::任务序号缺失;
        }
        break;
    case 自我治理消息类型::派生需求请求:
        if (!句柄有效(句柄.目标宿主)
            || !句柄有效(句柄.目标特征定义)
            || !句柄有效(句柄.实例特征槽位)
            || !句柄有效(句柄.当前特征状态材料)
            || !句柄有效(句柄.目标状态)) {
            return 自我治理拒绝原因::必填句柄缺失;
        }
        if (句柄.目标特征定义 == 句柄.实例特征槽位) {
            return 自我治理拒绝原因::特征定义与实例槽位相同;
        }
        break;
    case 自我治理消息类型::观察材料准入请求:
    case 自我治理消息类型::自检缺口候选:
        if (!句柄有效(句柄.主体)
            || !句柄有效(句柄.场景)
            || !句柄有效(句柄.目标材料)) {
            return 自我治理拒绝原因::必填句柄缺失;
        }
        break;
    case 自我治理消息类型::执行前许可预判请求:
        if (!句柄有效(句柄.目标任务)
            || !句柄有效(句柄.目标方法)
            || !句柄有效(句柄.目标动作入口)) {
            return 自我治理拒绝原因::必填句柄缺失;
        }
        if (消息.来源任务序号 == 0) {
            return 自我治理拒绝原因::任务序号缺失;
        }
        break;
    case 自我治理消息类型::缓存刷新请求:
        if (!句柄有效(句柄.目标需求)
            && !句柄有效(句柄.目标任务)
            && !句柄有效(句柄.目标材料)) {
            return 自我治理拒绝原因::必填句柄缺失;
        }
        break;
    case 自我治理消息类型::事件日志请求:
        if (!句柄有效(句柄.目标需求)
            && !句柄有效(句柄.目标任务)
            && !句柄有效(句柄.动态证据)
            && !句柄有效(句柄.目标材料)) {
            return 自我治理拒绝原因::必填句柄缺失;
        }
        break;
    case 自我治理消息类型::停止请求:
        if (!自我治理全部句柄为空(句柄) || 消息.来源任务序号 != 0) {
            return 自我治理拒绝原因::停止消息携带业务材料;
        }
        break;
    default:
        return 自我治理拒绝原因::消息类型未知;
    }
    return 自我治理拒绝原因::无;
}

inline 自我治理准入结果 复核自我治理消息(
    const 自我治理消息& 消息,
    const 自我治理准入上下文& 上下文) {
    if (消息.协议版本 != 自我治理协议版本) {
        return 拒绝自我治理消息(自我治理拒绝原因::协议版本不匹配);
    }
    if (消息.治理消息编号 == 0) {
        return 拒绝自我治理消息(自我治理拒绝原因::消息编号无效);
    }
    if (!自我治理消息类型有效(消息.类型)) {
        return 拒绝自我治理消息(自我治理拒绝原因::消息类型未知);
    }
    if (!自我治理来源角色有效(消息.来源角色)) {
        return 拒绝自我治理消息(自我治理拒绝原因::来源角色未知);
    }
    if (!自我治理服务角色有效(消息.来源服务)) {
        return 拒绝自我治理消息(自我治理拒绝原因::来源服务未知);
    }
    if (!自我治理服务角色有效(消息.目标服务)) {
        return 拒绝自我治理消息(自我治理拒绝原因::目标服务未知);
    }
    if (消息.发生时间戳 == 0) {
        return 拒绝自我治理消息(自我治理拒绝原因::发生时间戳无效);
    }
    if (!自我治理消息优先级有效(消息.优先级)) {
        return 拒绝自我治理消息(自我治理拒绝原因::优先级未知);
    }
    if (消息.幂等键 == 0) {
        return 拒绝自我治理消息(自我治理拒绝原因::幂等键无效);
    }
    if (消息.批次编号 == 0) {
        return 拒绝自我治理消息(自我治理拒绝原因::批次编号无效);
    }
    if (消息.非权威材料摘要 == 0) {
        return 拒绝自我治理消息(自我治理拒绝原因::材料摘要无效);
    }
    if (!自我治理材料类型有效(消息.材料类型)) {
        return 拒绝自我治理消息(自我治理拒绝原因::材料类型未知);
    }
    if (!自我治理材料性质有效(消息.材料性质)) {
        return 拒绝自我治理消息(自我治理拒绝原因::材料性质未知);
    }
    if (消息.材料性质 == 自我治理材料性质::机器事实声明
        || 消息.材料性质 == 自我治理材料性质::执行许可声明) {
        return 拒绝自我治理消息(自我治理拒绝原因::材料性质越权);
    }
    if (!自我治理过期策略有效(消息.过期策略)) {
        return 拒绝自我治理消息(自我治理拒绝原因::过期策略未知);
    }
    if (消息.过期策略 == 自我治理过期策略::截止时间) {
        if (上下文.当前时间戳 == 0) {
            return 拒绝自我治理消息(自我治理拒绝原因::当前时间戳无效);
        }
        if (消息.截止时间戳 == 0) {
            return 拒绝自我治理消息(自我治理拒绝原因::截止时间缺失);
        }
        if (上下文.当前时间戳 > 消息.截止时间戳) {
            return 拒绝自我治理消息(自我治理拒绝原因::材料已过期);
        }
    }
    if (!自我治理全部句柄形状有效(消息.句柄组)) {
        return 拒绝自我治理消息(自我治理拒绝原因::句柄形状无效);
    }
    if (消息.类型 == 自我治理消息类型::停止请求) {
        if (消息.优先级 != 自我治理消息优先级::停止) {
            return 拒绝自我治理消息(自我治理拒绝原因::停止优先级无效);
        }
    } else if (消息.优先级 == 自我治理消息优先级::停止) {
        return 拒绝自我治理消息(自我治理拒绝原因::普通消息冒用停止优先级);
    }

    const auto 路由拒绝 = 复核自我治理路由与材料(消息);
    if (路由拒绝 != 自我治理拒绝原因::无) {
        return 拒绝自我治理消息(路由拒绝);
    }
    const auto 必填材料拒绝 = 复核自我治理必填材料(消息);
    if (必填材料拒绝 != 自我治理拒绝原因::无) {
        return 拒绝自我治理消息(必填材料拒绝);
    }

    if (上下文.同幂等键既有消息.has_value()) {
        const auto& 既有消息 = 上下文.同幂等键既有消息.value();
        if (既有消息.幂等键 != 消息.幂等键) {
            return 标记自我治理内部不一致(自我治理拒绝原因::准入上下文不一致);
        }
        if (自我治理消息相同(既有消息, 消息)) {
            return {自我治理准入状态::重复材料, 自我治理拒绝原因::重复材料};
        }
        return 拒绝自我治理消息(自我治理拒绝原因::幂等键冲突);
    }

    if (上下文.同任务最新序号 != 0) {
        if (!句柄有效(上下文.同任务目标)
            || !句柄有效(消息.句柄组.目标任务)
            || !(上下文.同任务目标 == 消息.句柄组.目标任务)) {
            return 标记自我治理内部不一致(自我治理拒绝原因::准入上下文不一致);
        }
        if (消息.来源任务序号 != 0
            && 消息.来源任务序号 < 上下文.同任务最新序号) {
            return 拒绝自我治理消息(自我治理拒绝原因::同一任务序号倒退);
        }
    }
    return {自我治理准入状态::可准入, 自我治理拒绝原因::无};
}

}
