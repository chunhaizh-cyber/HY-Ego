// 文件规则：概念命名治理上行桥只读复核单个待命名请求并提交非权威治理消息；不得创建需求、绑定名称或管理线程。
module;

#include "../领域/概念图服务.h"
#include "../领域/语素服务.h"

#include <cstdint>
#include <optional>
#include <utility>

export module 海中鱼巣.线程.上行桥.概念命名治理;

import 海中鱼巣.线程.自我治理消息协议;
import 海中鱼巣.线程.有界自我治理队列;

export namespace 海中鱼巣 {

enum class 概念命名上行状态 : std::uint32_t {
    已拒绝 = 0,
    已提交 = 1,
    重复材料 = 2,
    请求已过期 = 3,
    内部不一致 = 4
};

enum class 概念命名上行拒绝原因 : std::uint32_t {
    无 = 0,
    当前时间戳无效 = 1,
    截止时间无效 = 2,
    批次编号无效 = 3,
    待命名材料无效 = 4,
    当前请求不存在 = 5,
    概念漂移 = 6,
    活动版本漂移 = 7,
    根类别漂移 = 8,
    目标已有名称 = 9,
    确定性标识无效 = 10,
    邮箱拒绝 = 11,
    邮箱内部不一致 = 12
};

struct 概念命名上行结果 {
    概念命名上行状态 状态 = 概念命名上行状态::已拒绝;
    概念命名上行拒绝原因 拒绝原因 = 概念命名上行拒绝原因::无;
    概念待命名请求材料 交付请求;
    std::optional<概念待命名请求材料> 当前请求;
    自我治理消息 治理消息;
    自我治理提交结果 邮箱结果;

    bool 逻辑内返回() const {
        return 状态 == 概念命名上行状态::已拒绝
            || 状态 == 概念命名上行状态::重复材料
            || 状态 == 概念命名上行状态::请求已过期;
    }
};

class 概念命名治理上行桥 {
public:
    概念命名治理上行桥(
        const 概念图服务& 概念图,
        const 语素服务& 语素,
        有界自我治理邮箱& 治理邮箱)
        : 概念图_(概念图),
          语素_(语素),
          治理邮箱_(治理邮箱) {
    }

    概念命名治理上行桥(const 概念命名治理上行桥&) = delete;
    概念命名治理上行桥& operator=(const 概念命名治理上行桥&) = delete;

    概念命名上行结果 提交待命名请求(
        const 概念待命名请求材料& 请求,
        std::uint64_t 当前时间戳,
        std::uint64_t 截止时间戳,
        std::uint64_t 批次编号) const {
        if (当前时间戳 == 0) {
            return 拒绝(请求, 概念命名上行拒绝原因::当前时间戳无效);
        }
        if (截止时间戳 == 0 || 截止时间戳 <= 当前时间戳) {
            return {
                概念命名上行状态::请求已过期,
                概念命名上行拒绝原因::截止时间无效,
                请求, std::nullopt, {}, {}
            };
        }
        if (批次编号 == 0) {
            return 拒绝(请求, 概念命名上行拒绝原因::批次编号无效);
        }
        if (!请求.完整()) {
            return 拒绝(请求, 概念命名上行拒绝原因::待命名材料无效);
        }

        const auto 当前请求 = 概念图_.读取待命名请求(请求.概念, 语素_);
        if (!当前请求.has_value()) {
            const auto 名称入口组 = 语素_.读取概念名称入口组(请求.概念);
            return 拒绝(
                请求,
                名称入口组.empty()
                    ? 概念命名上行拒绝原因::当前请求不存在
                    : 概念命名上行拒绝原因::目标已有名称);
        }
        if (!(当前请求->概念 == 请求.概念)) {
            return 拒绝(请求, 概念命名上行拒绝原因::概念漂移, 当前请求);
        }
        if (当前请求->根类别 != 请求.根类别) {
            return 拒绝(请求, 概念命名上行拒绝原因::根类别漂移, 当前请求);
        }
        if (当前请求->活动图版本 != 请求.活动图版本) {
            return 拒绝(请求, 概念命名上行拒绝原因::活动版本漂移, 当前请求);
        }
        if (当前请求->原因 != 请求.原因 || !当前请求->完整()) {
            return {
                概念命名上行状态::内部不一致,
                概念命名上行拒绝原因::待命名材料无效,
                请求, 当前请求, {}, {}
            };
        }

        const auto 治理消息 = 构造治理消息(
            当前请求.value(), 当前时间戳, 截止时间戳, 批次编号);
        if (治理消息.治理消息编号 == 0
            || 治理消息.幂等键 == 0
            || 治理消息.非权威材料摘要 == 0) {
            return {
                概念命名上行状态::内部不一致,
                概念命名上行拒绝原因::确定性标识无效,
                请求, 当前请求, {}, {}
            };
        }

        const auto 邮箱结果 = 治理邮箱_.提交(治理消息, 当前时间戳);
        if (邮箱结果.状态 == 自我治理提交状态::已提交) {
            return {
                概念命名上行状态::已提交,
                概念命名上行拒绝原因::无,
                请求, 当前请求, 治理消息, 邮箱结果
            };
        }
        if (邮箱结果.状态 == 自我治理提交状态::重复材料) {
            return {
                概念命名上行状态::重复材料,
                概念命名上行拒绝原因::无,
                请求, 当前请求, 治理消息, 邮箱结果
            };
        }
        if (邮箱结果.状态 == 自我治理提交状态::内部不一致) {
            return {
                概念命名上行状态::内部不一致,
                概念命名上行拒绝原因::邮箱内部不一致,
                请求, 当前请求, 治理消息, 邮箱结果
            };
        }
        return {
            概念命名上行状态::已拒绝,
            概念命名上行拒绝原因::邮箱拒绝,
            请求, 当前请求, 治理消息, 邮箱结果
        };
    }

private:
    static constexpr std::uint64_t 消息编号用途域 = 0x434E'4D53'0000'0002ULL;
    static constexpr std::uint64_t 幂等键用途域 = 0x434E'4944'0000'0002ULL;
    static constexpr std::uint64_t 材料摘要用途域 = 0x434E'5355'0000'0002ULL;

    static 概念命名上行结果 拒绝(
        const 概念待命名请求材料& 请求,
        概念命名上行拒绝原因 原因,
        std::optional<概念待命名请求材料> 当前请求 = std::nullopt) {
        return {
            概念命名上行状态::已拒绝,
            原因,
            请求,
            std::move(当前请求),
            {}, {}
        };
    }

    static std::uint64_t 混入无符号值(std::uint64_t 哈希值, std::uint64_t 值) {
        constexpr std::uint64_t 素数 = 1099511628211ULL;
        for (std::uint32_t 字节索引 = 0; 字节索引 < 8; ++字节索引) {
            哈希值 ^= 值 & 0xFFULL;
            哈希值 *= 素数;
            值 >>= 8U;
        }
        return 哈希值;
    }

    static std::uint64_t 构造确定性标识(
        std::uint64_t 用途域,
        const 节点句柄& 概念,
        std::uint64_t 活动图版本) {
        std::uint64_t 哈希值 = 14695981039346656037ULL;
        哈希值 = 混入无符号值(哈希值, 用途域);
        哈希值 = 混入无符号值(哈希值, 概念.仓库编号);
        哈希值 = 混入无符号值(哈希值, 概念.节点编号);
        哈希值 = 混入无符号值(哈希值, 概念.版本号);
        哈希值 = 混入无符号值(哈希值, 活动图版本);
        return 哈希值 == 0 ? 用途域 : 哈希值;
    }

    static 自我治理消息 构造治理消息(
        const 概念待命名请求材料& 请求,
        std::uint64_t 当前时间戳,
        std::uint64_t 截止时间戳,
        std::uint64_t 批次编号) {
        自我治理消息 消息;
        消息.治理消息编号 = 构造确定性标识(消息编号用途域, 请求.概念, 请求.活动图版本);
        消息.类型 = 自我治理消息类型::概念待命名请求;
        消息.来源角色 = 自我治理来源角色::概念图观察入口;
        消息.来源服务 = 自我治理服务角色::概念图;
        消息.目标服务 = 自我治理服务角色::需求;
        消息.发生时间戳 = 当前时间戳;
        消息.优先级 = 自我治理消息优先级::普通;
        消息.幂等键 = 构造确定性标识(幂等键用途域, 请求.概念, 请求.活动图版本);
        消息.来源材料版本 = 请求.活动图版本;
        消息.批次编号 = 批次编号;
        消息.非权威材料摘要 = 构造确定性标识(材料摘要用途域, 请求.概念, 请求.活动图版本);
        消息.材料类型 = 自我治理只读材料类型::概念待命名材料;
        消息.材料性质 = 自我治理材料性质::非权威候选;
        消息.过期策略 = 自我治理过期策略::截止时间;
        消息.截止时间戳 = 截止时间戳;
        消息.句柄组.目标概念 = 请求.概念;
        return 消息;
    }

    const 概念图服务& 概念图_;
    const 语素服务& 语素_;
    有界自我治理邮箱& 治理邮箱_;
};

}
