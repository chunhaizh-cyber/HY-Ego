// 文件规则：概念命名需求自检只承载隔离事务与并发验收，不得成为生产依赖或机器事实来源。
module;

#include "../核心/主信息仓库.h"
#include "../核心/节点仓库.h"
#include "../核心/关系仓库.h"
#include "../核心/索引仓库.h"
#include "../领域/概念图服务.h"
#include "../领域/需求服务.h"
#include "../领域/状态服务.h"
#include "../领域/语素服务.h"

#include <array>
#include <atomic>
#include <cstddef>
#include <cstdint>
#include <iostream>
#include <optional>
#include <thread>
#include <vector>

export module 海中鱼巣.线程.自检.概念命名需求;

import 海中鱼巣.自检.运行器;
import 海中鱼巣.核心.协调.结构事务;
import 海中鱼巣.线程.路由.概念命名治理;
import 海中鱼巣.线程.自我治理消息协议;

export namespace 海中鱼巣 {

namespace 概念命名需求自检内部 {

自我治理消息 构造消息(节点句柄 概念, std::uint64_t 活动版本, std::uint64_t 编号) {
    自我治理消息 消息;
    消息.治理消息编号 = 编号;
    消息.类型 = 自我治理消息类型::概念待命名请求;
    消息.来源角色 = 自我治理来源角色::概念图观察入口;
    消息.来源服务 = 自我治理服务角色::概念图;
    消息.目标服务 = 自我治理服务角色::需求;
    消息.发生时间戳 = 10;
    消息.优先级 = 自我治理消息优先级::普通;
    消息.幂等键 = 编号 + 1000;
    消息.来源材料版本 = 活动版本;
    消息.批次编号 = 1;
    消息.非权威材料摘要 = 编号 + 2000;
    消息.材料类型 = 自我治理只读材料类型::概念待命名材料;
    消息.材料性质 = 自我治理材料性质::非权威候选;
    消息.过期策略 = 自我治理过期策略::截止时间;
    消息.截止时间戳 = 100;
    消息.句柄组.目标概念 = 概念;
    return 消息;
}

}

自检单元结果 运行概念命名需求自检() {
    结构事务协调器 协调器(213);
    const auto 接线 = 协调器.生成接线();
    主信息仓库 主信息(213, 接线);
    节点仓库 节点(主信息, 213, 接线);
    关系仓库 关系(节点, 213, 接线);
    索引仓库 索引(节点, 接线);
    语素服务 语素(主信息, 节点, 关系, 索引);
    状态服务 状态(主信息, 节点, 关系);
    需求服务 需求(主信息, 节点, 关系, 接线);
    概念图服务 概念图(节点, 关系);

    const auto 创建节点 = [&](节点类型 类型) {
        const auto 主信息值 = 主信息.创建主信息();
        return 节点.创建节点(类型, 主信息值);
    };
    const auto 主体 = 创建节点(节点类型::存在);
    const auto 目标宿主 = 创建节点(节点类型::存在);
    const auto 场景 = 创建节点(节点类型::场景);
    const auto 命名目标状态 = 状态.创建抽象状态(1);
    const auto 服务目标状态 = 状态.创建抽象状态(10);
    const auto 服务根 = 需求.创建需求();
    const bool 服务根完整 = 句柄有效(服务根)
        && 句柄有效(关系.创建关系(关系类型::引用, 服务根, 主体, 1))
        && 句柄有效(关系.创建关系(关系类型::引用, 服务根, 目标宿主, 2))
        && 句柄有效(关系.创建关系(关系类型::引用, 服务根, 场景, 3))
        && 句柄有效(关系.创建关系(关系类型::模板, 服务根, 服务目标状态));

    const std::array 根类型组{
        节点类型::存在, 节点类型::动态, 节点类型::二次特征, 节点类型::因果引用};
    const std::array 根类别组{
        概念根类别::存在, 概念根类别::动态, 概念根类别::关系, 概念根类别::因果};
    std::array<节点句柄, 4> 根组{};
    bool 根登记完成 = true;
    for (std::size_t 索引值 = 0; 索引值 < 根组.size(); ++索引值) {
        根组[索引值] = 创建节点(根类型组[索引值]);
        const auto 登记 = 概念图.登记概念根({根类别组[索引值], 100 + 索引值, 根组[索引值]});
        根登记完成 = 根登记完成 && 登记 == std::optional<节点句柄>{根组[索引值]};
    }
    const auto 活跃状态 = 状态.创建抽象状态(
        static_cast<std::int64_t>(概念生命周期阶段::活跃));
    const auto 冷却状态 = 状态.创建抽象状态(
        static_cast<std::int64_t>(概念生命周期阶段::冷却));
    const auto 退役状态 = 状态.创建抽象状态(
        static_cast<std::int64_t>(概念生命周期阶段::退役));
    const bool 生命周期就绪 =
        概念图.登记生命周期状态(概念生命周期阶段::活跃, 活跃状态, 状态).has_value()
        && 概念图.登记生命周期状态(概念生命周期阶段::冷却, 冷却状态, 状态).has_value()
        && 概念图.登记生命周期状态(概念生命周期阶段::退役, 退役状态, 状态).has_value()
        && 概念图.初始化活动概念生命周期()
        && 概念图.初始化活动图基础版本() == std::optional<std::uint64_t>{1};

    const auto 参数 = [&](节点句柄 目标概念) {
        return 概念命名需求参数{主体, 目标宿主, 场景, 命名目标状态, 目标概念, 服务根};
    };
    概念命名治理路由 路由(概念图, 语素, 需求, 接线);
    const auto 活动版本 = 概念图.读取活动图版本();
    const auto 创建前节点数 = 节点.有效节点数量();
    const auto 创建前关系数 = 关系.有效关系数量();
    auto 错误消息 = 概念命名需求自检内部::构造消息(根组[0], 活动版本, 1);
    错误消息.协议版本 = 1;
    const auto 错误结果 = 路由.处理(错误消息, 10, 参数(根组[0]));
    const bool A01写前拒绝 = 错误结果.状态 == 概念命名治理路由状态::已拒绝
        && 节点.有效节点数量() == 创建前节点数
        && 关系.有效关系数量() == 创建前关系数;

    const auto 首次结果 = 路由.处理(
        概念命名需求自检内部::构造消息(根组[0], 活动版本, 2), 10, 参数(根组[0]));
    const auto 首次后节点数 = 节点.有效节点数量();
    const auto 首次后关系数 = 关系.有效关系数量();
    const auto 复用结果 = 路由.处理(
        概念命名需求自检内部::构造消息(根组[0], 活动版本, 3), 10, 参数(根组[0]));
    const bool A02目标关系读取 = 首次结果.成功()
        && 关系.获取来源节点组(根组[0], 关系类型::需求目标概念).size() == 1;
    const bool A03未完成分类 = 首次结果.需求材料.状态 == 概念命名需求状态::已创建
        && 复用结果.需求材料.状态 == 概念命名需求状态::已复用;
    const bool A04完整创建 = 首次结果.成功()
        && 需求.读取需求承接材料(首次结果.需求材料.需求).has_value();
    const bool A05幂等复用 = 复用结果.成功()
        && 复用结果.需求材料.需求 == 首次结果.需求材料.需求
        && 节点.有效节点数量() == 首次后节点数
        && 关系.有效关系数量() == 首次后关系数;

    std::atomic<std::size_t> 同概念成功数{0};
    std::vector<std::thread> 同概念线程组;
    for (std::size_t 索引值 = 0; 索引值 < 50; ++索引值) {
        同概念线程组.emplace_back([&, 索引值]() {
            const auto 结果 = 路由.处理(
                概念命名需求自检内部::构造消息(根组[1], 活动版本, 100 + 索引值),
                10,
                参数(根组[1]));
            if (结果.成功()) ++同概念成功数;
        });
    }
    for (auto& 线程 : 同概念线程组) 线程.join();
    const auto 动态根需求组 = 关系.获取来源节点组(根组[1], 关系类型::需求目标概念);
    const bool A07同概念并发 = 同概念成功数 == 50 && 动态根需求组.size() == 1;

    std::array<概念命名治理路由结果, 2> 不同结果;
    std::thread 不同甲([&]() {
        不同结果[0] = 路由.处理(
            概念命名需求自检内部::构造消息(根组[2], 活动版本, 300), 10, 参数(根组[2]));
    });
    std::thread 不同乙([&]() {
        不同结果[1] = 路由.处理(
            概念命名需求自检内部::构造消息(根组[3], 活动版本, 301), 10, 参数(根组[3]));
    });
    不同甲.join();
    不同乙.join();
    const bool A08不同概念并发 = 不同结果[0].成功() && 不同结果[1].成功()
        && 不同结果[0].需求材料.需求 != 不同结果[1].需求材料.需求;

    const auto 建立重复需求 = [&](节点句柄 概念) {
        const auto 重复需求 = 需求.创建需求();
        return 句柄有效(重复需求)
            && 句柄有效(关系.创建关系(关系类型::引用, 重复需求, 主体, 1))
            && 句柄有效(关系.创建关系(关系类型::引用, 重复需求, 目标宿主, 2))
            && 句柄有效(关系.创建关系(关系类型::引用, 重复需求, 场景, 3))
            && 句柄有效(关系.创建关系(关系类型::模板, 重复需求, 命名目标状态))
            && 句柄有效(关系.创建关系(关系类型::需求目标概念, 重复需求, 概念))
            && 关系.挂载或重挂节点(重复需求, 服务根).关系已确定();
    };
    const bool 重复已建立 = 建立重复需求(根组[3]);
    const auto 多需求结果 = 路由.处理(
        概念命名需求自检内部::构造消息(根组[3], 活动版本, 400), 10, 参数(根组[3]));
    const bool A06多需求追根因 = 重复已建立
        && 多需求结果.状态 == 概念命名治理路由状态::内部不一致
        && !多需求结果.成功();

    const auto 失败前节点数 = 节点.有效节点数量();
    const auto 失败前关系数 = 关系.有效关系数量();
    auto 无效参数 = 参数(根组[2]);
    无效参数.目标状态 = {};
    const auto 无效参数结果 = 路由.处理(
        概念命名需求自检内部::构造消息(根组[2], 活动版本, 500), 10, 无效参数);
    const bool A11失败结构不变 = !无效参数结果.成功()
        && 节点.有效节点数量() == 失败前节点数
        && 关系.有效关系数量() == 失败前关系数;
    const auto 过期结果 = 路由.处理(
        概念命名需求自检内部::构造消息(根组[2], 活动版本 + 1, 501), 10, 参数(根组[2]));
    const bool A12令牌重读拒绝 = 过期结果.状态 == 概念命名治理路由状态::请求已变化;
    const bool A09许可锁序 = 根登记完成 && 生命周期就绪 && 首次结果.成功();
    const bool A10完整读回 = 首次结果.需求材料.参数.主体 == 主体
        && 首次结果.需求材料.参数.目标宿主 == 目标宿主
        && 首次结果.需求材料.参数.场景 == 场景
        && 首次结果.需求材料.参数.目标状态 == 命名目标状态
        && 首次结果.需求材料.参数.目标概念 == 根组[0]
        && 首次结果.需求材料.参数.服务根需求 == 服务根;
    const bool A13既有边界 = 服务根完整 && 根登记完成 && 生命周期就绪;
    const bool A14模块边界 = 接线.已接域() && 活动版本 == 1;

    const std::array 结果组{A01写前拒绝, A02目标关系读取, A03未完成分类, A04完整创建,
        A05幂等复用, A06多需求追根因, A07同概念并发, A08不同概念并发,
        A09许可锁序, A10完整读回, A11失败结构不变, A12令牌重读拒绝,
        A13既有边界, A14模块边界};
    std::size_t 失败数量 = 0;
    for (std::size_t 索引值 = 0; 索引值 < 结果组.size(); ++索引值) {
        if (!结果组[索引值]) ++失败数量;
        std::cout << "CONCEPT-NAMING-S3-A" << (索引值 + 1) << ": "
            << (结果组[索引值] ? "通过" : "失败") << '\n';
    }
    return {"CONCEPT-NAMING-S3", "概念命名需求", 失败数量 == 0, 结果组.size(), 失败数量};
}

}
