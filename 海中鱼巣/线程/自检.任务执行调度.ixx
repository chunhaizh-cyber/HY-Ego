        const auto 矛盾后快照 = 工作线程.读取强类型任务回执快照();
        验收[13] = 新路径前旧回执数量 == 新路径后旧回执数量
            && 矛盾发布.状态 == 强类型任务结果回执发布状态::已拒绝
            && 矛盾发布.协议结果.拒绝原因 == 任务结果回执拒绝原因::来源执行请求不一致
            && 矛盾前快照.待处理数量 == 矛盾后快照.待处理数量;

        const auto 需求读回 = 需求服务.读取需求(需求);
        验收[14] = 新回执取出.有回执
            && 新回执取出.回执.材料性质
                == 任务结果回执材料性质::非权威任务执行结果证据
            && 新回执取出.回执.来源执行请求.has_value()
            && 冻结任务执行请求相同(
