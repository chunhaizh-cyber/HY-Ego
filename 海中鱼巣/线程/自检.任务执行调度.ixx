            && 旧运行消费.需要领域服务复核;

        const auto 工作停止 = 工作线程.请求停止并发送停止消息(新主键(), 新时间());
        const auto 管理停止 = 管理线程.请求停止并发送停止消息(新主键(), 新时间());
        const auto 工作收口 = 工作线程.收口等待();
        const auto 管理收口 = 管理线程.收口等待();
        const auto 候选停止 = 候选管理线程.请求停止并发送停止消息(新主键(), 新时间());
        const auto 候选收口 = 候选管理线程.收口等待();
        验收[17] = 管理启动.成功 && 工作启动.成功
            && 工作停止.成功 && 管理停止.成功
            && 工作收口.成功 && 管理收口.成功
            && 候选停止.成功 && 候选收口.成功
            && 工作线程.线程可收口() && 管理线程.线程可收口()
            && 候选管理线程.线程可收口();
    } catch (...) {
    }

    constexpr std::array<const char*, 18> 名称组{
        "A01 四个真模块与生产自检分离",
        "A02 生产公开面不承载事务与仓库能力",
        "A03 完整冻结双向授权选择动作与关系17证据",
        "A04 非法参数稳定键跨场景旧引用与缺槽写前拒绝",
