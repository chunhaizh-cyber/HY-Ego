        const auto 零容量拒绝 = 零容量管理线程.准备强类型任务执行请求(冻结);
        const auto 零容量停止 = 零容量管理线程.请求停止并发送停止消息(新主键(), 新时间());
        const auto 零容量收口 = 零容量管理线程.收口等待();
        const auto 边界后任务 = 任务服务.读取任务(任务);
        验收[5] = 边界启动.成功 && 精确重复.状态 == 强类型任务执行请求队列状态::精确重复
            && 请求号冲突.拒绝原因 == 强类型任务执行请求队列拒绝原因::请求编号冲突
            && 幂等冲突.拒绝原因 == 强类型任务执行请求队列拒绝原因::幂等键冲突
            && 容量拒绝.拒绝原因 == 强类型任务执行请求队列拒绝原因::队列已满
            && 边界撤销.成功()
            && 过期拒绝.拒绝原因 == 强类型任务执行请求队列拒绝原因::请求已过期
            && 锚点确认.状态 == 强类型任务执行请求队列状态::已确认
            && 锚点取出.状态 == 强类型任务执行请求队列状态::已取出
            && 倒退拒绝.拒绝原因 == 强类型任务执行请求队列拒绝原因::任务序号倒退
            && 同序拒绝.拒绝原因 == 强类型任务执行请求队列拒绝原因::任务序号冲突
            && 边界停止.成功
            && (停止拒绝.拒绝原因 == 强类型任务执行请求队列拒绝原因::队列已停止
                || 停止拒绝.拒绝原因 == 强类型任务执行请求队列拒绝原因::管理线程未运行)
            && 边界收口.成功 && 零容量启动.成功
            && 零容量拒绝.拒绝原因 == 强类型任务执行请求队列拒绝原因::容量为零
            && 零容量停止.成功 && 零容量收口.成功
            && 边界后任务.当前生命周期.阶段 == 分层任务生命周期阶段::筹办中;

        const auto 初始状态 = 任务服务.读取任务(任务).当前生命周期.状态;
        const auto 故障一请求 = 使用已有前状态记录动态请求{
            初始状态, 新主键(), 新主键(), 新时间(), 20,
            创建结果.需求.材料.目标状态, 动作.规格.身份.节点};
        const auto 故障一前 = 读取数量();
        const auto 故障一 = 状态动态.执行已有前状态固定故障自检(故障一请求, 1);
        const auto 故障一后状态 = 状态数据操作.读取主键状态材料(故障一请求.后状态幂等主键);
        const auto 故障一后动态 = 状态数据操作.读取主键动态材料(故障一请求.动态幂等主键);
        const auto 故障一后 = 读取数量();
        const auto 故障二请求 = 使用已有前状态记录动态请求{
            初始状态, 新主键(), 新主键(), 新时间(), 20,
            创建结果.需求.材料.目标状态, 动作.规格.身份.节点};
        const auto 故障二前 = 读取数量();
        const auto 故障二 = 状态动态.执行已有前状态固定故障自检(故障二请求, 2);
        const auto 故障二后状态 = 状态数据操作.读取主键状态材料(故障二请求.后状态幂等主键);
        const auto 故障二后动态 = 状态数据操作.读取主键动态材料(故障二请求.动态幂等主键);
        const auto 故障二后 = 读取数量();
        验收[12] = 故障一.故障已命中 && 故障一.已执行写点 == 1
            && !故障一后状态.当前可读() && !故障一后动态.当前可读()
            && 故障一前 == 故障一后 && 故障二.故障已命中
            && 故障二.已执行写点 == 2
            && !故障二后状态.当前可读() && !故障二后动态.当前可读()
            && 故障二前 == 故障二后;

        任务管理线程 管理线程(16, 16);
        任务工作线程 工作线程(管理线程, 16, 16);
        任务执行调度路由 调度路由(管理线程, 执行组合器);
        const auto 管理启动 = 管理线程.启动();
        const auto 工作启动 = 工作线程.启动();

        auto 过期调度请求 = 形成调度请求(任务, 1);
        const auto 过期提交 = 调度路由.提交任务执行请求(过期调度请求);
        const auto 过期提交快照 = 管理线程.读取强类型任务执行队列快照();
        const auto 过期消费 = 工作线程.受控消费一条任务执行请求(
            调度路由, 过期调度请求.截止时间戳 + 1);
        const auto 过期任务读回 = 任务服务.读取任务(任务);
        const auto 过期回执快照 = 工作线程.读取强类型任务回执快照();
        验收[8] = 过期提交.已提交() && 过期提交快照.可消费数量 == 1
            && 过期消费.已处理 && !过期消费.已发布非权威回执
            && 过期消费.调度结果.状态 == 任务执行调度状态::已收口待重筹办
            && 过期任务读回.当前生命周期.阶段 == 分层任务生命周期阶段::待重筹办
            && 过期回执快照.待处理数量 == 0;

        const auto 重回筹办 = 任务服务.迁移生命周期({
            任务, 分层任务生命周期阶段::筹办中, 新主键(), 新时间()});
        const auto 重筹办召回 = 召回服务.召回({任务, 登记根.根.身份.节点, 1, 1});
        const auto 重筹办选择请求 = 召回服务.适配唯一建议(
            重筹办召回, 新主键(), 新主键());
        const auto 重筹办选择 = 重筹办选择请求.has_value()
            ? 任务服务.提交方法选择(*重筹办选择请求)
            : 任务提交结果{};
        const auto 正常调度请求 = 形成调度请求(任务, 2);
        const auto 正常冻结结果 = 执行组合器.冻结任务执行请求(正常调度请求);
        std::array<任务执行调度状态, 50> 并发状态{};
        std::vector<std::thread> 并发线程组;
        并发线程组.reserve(并发状态.size());
        for (std::size_t 索引号 = 0; 索引号 < 并发状态.size(); ++索引号) {
            并发线程组.emplace_back([&, 索引号] {
                并发状态[索引号] = 调度路由.提交任务执行请求(正常调度请求).状态;
            });
        }
        for (auto& 线程 : 并发线程组) 线程.join();
        std::size_t 已提交数量 = 0;
        std::size_t 逻辑内返回数量 = 0;
        for (const auto 状态 : 并发状态) {
            if (状态 == 任务执行调度状态::已提交) ++已提交数量;
            else if (状态 == 任务执行调度状态::精确重复
                || 状态 == 任务执行调度状态::入口拒绝
                || 状态 == 任务执行调度状态::当前性漂移) {
                ++逻辑内返回数量;
            }
        }
        const auto 并发后快照 = 管理线程.读取强类型任务执行队列快照();
        const auto 排队任务 = 任务服务.读取任务(任务);
        验收[6] = 重回筹办.成功() && 重筹办召回.有唯一建议()
            && 重筹办选择.成功() && 正常冻结结果.已冻结()
            && 已提交数量 == 1 && 逻辑内返回数量 == 49
            && 并发后快照.预留数量 == 0 && 并发后快照.可消费数量 == 1
            && 排队任务.当前生命周期.阶段 == 分层任务生命周期阶段::排队中;

        const auto 新路径前旧回执数量 = 工作线程.只读任务回执队列().数量();
        const auto 正常消费 = 工作线程.受控消费一条任务执行请求(
