        矛盾回执.回执编号 = 新主键();
        矛盾回执.幂等键 = 新主键();
        矛盾回执.句柄组.目标方法 = 主体;
        const auto 矛盾前快照 = 工作线程.读取强类型任务回执快照();
        const auto 矛盾发布 = 工作线程.发布强类型任务结果回执(
