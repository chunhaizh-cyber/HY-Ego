// 文件规则：任务执行调度自检只验证强类型请求、两阶段队列、受控执行和非权威回执，不进入生产依赖。
module;

#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
#include "../核心/主信息仓库.h"
#include "../核心/节点仓库.h"
#include "../核心/关系仓库.h"
#include "../核心/索引仓库.h"
#include "../领域/特征值服务.h"

#include <array>
#include <atomic>
#include <cstddef>
#include <cstdint>
#include <iostream>
#include <optional>
#include <thread>
#include <type_traits>
#include <utility>
#include <vector>
#endif

export module 海中鱼巣.线程.自检.任务执行调度;

#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
import 海中鱼巣.核心.协调.结构事务;
import 海中鱼巣.领域.数据操作.存在场景;
import 海中鱼巣.领域.数据操作.状态动态;
import 海中鱼巣.领域.数据操作.特征体系;
import 海中鱼巣.领域.数据操作.需求任务方法;
import 海中鱼巣.领域.服务.存在;
import 海中鱼巣.领域.服务.场景;
import 海中鱼巣.领域.服务.状态;
import 海中鱼巣.领域.服务.特征;
import 海中鱼巣.领域.服务.需求;
import 海中鱼巣.领域.服务.任务;
import 海中鱼巣.领域.服务.方法;
import 海中鱼巣.领域.服务.方法召回;
import 海中鱼巣.领域.组合.需求任务方法;
import 海中鱼巣.领域.组合.状态动态;
import 海中鱼巣.领域.组合.任务执行;
import 海中鱼巣.线程.运行消息协议;
import 海中鱼巣.线程.协议.任务执行请求;
import 海中鱼巣.线程.任务管理线程;
import 海中鱼巣.线程.任务工作线程;
import 海中鱼巣.线程.任务结果回执协议;
import 海中鱼巣.线程.路由.任务执行调度;
import 海中鱼巣.自检.运行器;

export namespace 海中鱼巣 {

namespace 任务执行调度自检内部 {

struct 结构数量 {
    std::uint64_t 节点 = 0;
    std::uint64_t 关系 = 0;
    std::uint64_t 主键 = 0;

    bool operator==(const 结构数量&) const = default;
};

bool 队列快照相同(
    const 强类型任务执行请求队列快照& 左,
    const 强类型任务执行请求队列快照& 右) noexcept {
    return 左.容量 == 右.容量 && 左.预留数量 == 右.预留数量
        && 左.可消费数量 == 右.可消费数量
        && 左.已见请求数量 == 右.已见请求数量
        && 左.已见幂等键数量 == 右.已见幂等键数量
        && 左.同任务顺序数量 == 右.同任务顺序数量
        && 左.已停止 == 右.已停止;
}

运行消息 形成旧运行请求(std::uint64_t 编号, std::uint64_t 任务序号) {
    运行消息 消息;
    消息.消息编号 = 编号;
    消息.类型 = 运行消息类型::任务执行请求;
    消息.来源角色 = 运行线程角色::任务管理;
    消息.目标角色 = 运行线程角色::任务工作;
    消息.目标任务 = 600;
    消息.目标材料 = 编号 + 6000;
    消息.句柄版本 = 1;
    消息.当前句柄版本 = 1;
    消息.发生时间戳 = 600000 + 编号;
    消息.优先级 = 运行消息优先级::普通;
    消息.幂等键 = 编号;
    消息.批次号 = 600;
    消息.材料摘要 = 编号 * 60;
    消息.任务编号 = 600;
    消息.任务序号 = 任务序号;
    消息.只读材料说明 = true;
    消息.承载机器事实 = false;
    return 消息;
}

}

自检单元结果 运行任务执行调度自检() {
    using namespace 任务执行调度自检内部;

    static_assert(任务执行请求协议版本 == 1);
    static_assert(static_cast<std::uint32_t>(关系类型::方法动作场景) == 17);
    static_assert(!std::is_default_constructible_v<强类型任务执行请求候选>);
    static_assert(!std::is_copy_constructible_v<强类型任务执行请求候选>);
    static_assert(!std::is_copy_assignable_v<强类型任务执行请求候选>);
    static_assert(std::is_move_constructible_v<强类型任务执行请求候选>);
    static_assert(std::is_move_assignable_v<强类型任务执行请求候选>);
    static_assert(std::is_same_v<
        decltype(std::declval<const 任务执行组合器&>().冻结任务执行请求(
            任务执行调度请求{})),
        任务执行组合结果>);
    static_assert(std::is_same_v<
        decltype(std::declval<任务管理线程&>().准备强类型任务执行请求(
            任务执行冻结请求{})),
        强类型任务执行请求准备结果>);
    static_assert(std::is_same_v<
        decltype(std::declval<任务工作线程&>().受控消费一条任务执行请求(
            std::declval<任务执行调度路由&>(), std::uint64_t{})),
        任务工作线程受控消费结果>);

    std::array<bool, 18> 验收{};
    try {
        constexpr std::uint64_t 关系仓库编号 = 6003;
        constexpr std::int64_t 动作入口状态值 = 1;
        结构事务协调器 协调器(600);
        const auto 接线 = 协调器.生成接线();
        主信息仓库 主信息(6001, 接线);
        节点仓库 节点(主信息, 6002, 接线);
        关系仓库 关系(节点, 关系仓库编号, 接线);
        索引仓库 索引(节点, 接线);
        特征值服务 特征值(主信息, 节点);

        存在场景数据操作 存在数据操作(
            接线, 主信息, 节点, 关系, 索引, 关系仓库编号);
        状态动态数据操作 状态数据操作(
            接线, 主信息, 节点, 关系, 索引, 关系仓库编号);
        特征体系数据操作 特征数据操作(
            接线, 主信息, 节点, 关系, 索引, 特征值, 关系仓库编号);
        需求任务方法数据操作 高级数据操作(
            接线, 主信息, 节点, 关系, 索引, 关系仓库编号,
            存在数据操作, 状态数据操作);

        存在业务服务 存在服务(存在数据操作);
        场景业务服务 场景服务(存在数据操作);
        状态业务服务 状态服务(状态数据操作);
        特征业务服务 特征服务(特征数据操作);
        需求业务服务 需求服务(高级数据操作, 状态服务);
        任务业务服务 任务服务(
            高级数据操作, 需求服务, 存在服务, 状态服务);
        方法业务服务 方法服务(高级数据操作, 存在服务, 状态服务);
        方法召回业务服务 召回服务(
            需求服务, 任务服务, 方法服务, 特征服务, 状态服务);
        需求任务方法组合器 需求任务组合器(需求服务, 任务服务, 召回服务);
        状态动态组合器 状态动态(状态服务, 状态数据操作);

        std::uint64_t 主键序号 = 0x0600'0000'0000'1000ULL;
        std::uint64_t 时间序号 = 600'000;
        const auto 新主键 = [&]() noexcept { return ++主键序号; };
        const auto 新时间 = [&]() noexcept { return ++时间序号; };
        const auto 读取数量 = [&]() noexcept {
            return 结构数量{
                节点.有效节点数量(), 关系.有效关系数量(),
                索引.有效主键数量()};
        };
        const auto 形成调度请求 = [&](节点句柄 任务, std::uint64_t 任务序号) {
            const auto 基准时间 = 时间序号 + 10;
            时间序号 = 基准时间 + 200;
            任务执行调度请求 请求;
            请求.请求编号 = 新主键();
            请求.幂等键 = 新主键();
            请求.任务序号 = 任务序号;
            请求.批次编号 = 600;
            请求.任务 = 任务;
            请求.创建时间戳 = 基准时间;
            请求.截止时间戳 = 基准时间 + 100;
            请求.排队生命周期幂等主键 = 新主键();
            请求.排队时间戳 = 基准时间 + 1;
            请求.执行生命周期幂等主键 = 新主键();
            请求.执行时间戳 = 基准时间 + 2;
            请求.待重筹办幂等主键 = 新主键();
            请求.待重筹办时间戳 = 基准时间 + 5;
            请求.实际状态幂等主键 = 新主键();
            请求.实际状态时间戳 = 基准时间 + 3;
            请求.实际状态值 = 20;
            请求.动态幂等主键 = 新主键();
            请求.回执编号 = 新主键();
            请求.回执幂等键 = 新主键();
            请求.回执时间戳 = 基准时间 + 4;
            return 请求;
        };

        const auto 主体结果 = 存在服务.创建实际存在({新主键()});
        const auto 场景结果 = 场景服务.创建场景({新主键()});
        const auto 主体 = 主体结果.存在;
        const auto 场景 = 场景结果.场景;
        const auto 接纳 = 场景服务.接纳已有存在({场景, 主体});
        const auto 特征定义结果 = 特征服务.创建特征定义({新主键()});
        const auto 特征定义 = 特征定义结果.定义.特征定义;
        const auto 特征槽位结果 = 特征服务.创建实例特征槽位({
            新主键(), 主体, 特征定义});
        const auto 特征当前值结果 = 特征服务.发布初始特征状态({
            新主键(), 特征槽位结果.槽位.实例槽位,
            {特征值原始类型::I64, std::int64_t{10}, {}, {}}});
        const auto 条件状态结果 = 状态服务.创建抽象状态({新主键(), 10});

        创建需求并承接任务请求 创建请求;
        创建请求.需求 = {
            新主键(), 新主键(), 主体, 主体, 场景, 特征定义,
            特征当前值结果.当前值.特征值节点, 20};
        创建请求.任务幂等主键 = 新主键();
        创建请求.任务虚拟存在幂等主键 = 新主键();
        创建请求.任务初始状态幂等主键 = 新主键();
        创建请求.任务创建时间戳 = 新时间();
        const auto 创建结果 = 需求任务组合器.创建需求并承接任务(创建请求);
        const auto 任务 = 创建结果.任务.材料.身份.节点;
        const auto 需求 = 创建结果.需求.材料.身份.节点;
        const auto 已承接 = 任务服务.迁移生命周期({
            任务, 分层任务生命周期阶段::已承接, 新主键(), 新时间()});
        const auto 筹办中 = 任务服务.迁移生命周期({
            任务, 分层任务生命周期阶段::筹办中, 新主键(), 新时间()});

        const auto 登记根 = 方法服务.创建登记根({
            新主键(), 新主键(), 新主键(), 新主键()});
        const auto 方法首 = 方法服务.创建方法首({
            新主键(), 新主键(), 新主键(), 登记根.根.身份.节点});
        const auto 条件 = 方法服务.创建条件({
            新主键(), 新主键(), 方法首.登记项.身份.节点,
            场景, 特征定义, 条件状态结果.状态材料.状态节点,
            特征当前值结果.当前值.原始值版本});
        const auto 结果规格 = 方法服务.创建结果({
            新主键(), 新主键(), 方法首.登记项.身份.节点,
            场景, 特征定义, 创建结果.需求.材料.目标状态,
            特征当前值结果.当前值.原始值版本});
        const auto 动作 = 方法服务.创建动作入口({
            新主键(), 新主键(), 新主键(), 方法首.登记项.身份.节点,
            场景, 场景, 动作入口状态值});
        const auto 召回 = 召回服务.召回({任务, 登记根.根.身份.节点, 1, 1});
        const auto 选择请求 = 召回服务.适配唯一建议(召回, 新主键(), 新主键());
        const auto 选择 = 选择请求.has_value()
            ? 任务服务.提交方法选择(*选择请求)
            : 任务提交结果{};
        const auto 稳定动作键 = 动作.规格.稳定动作键;
        任务执行组合器 执行组合器(
            任务服务, 方法服务, 状态动态, 稳定动作键);

        const bool 夹具完整 = 接线.已接域() && 存在数据操作.有效()
            && 状态数据操作.有效() && 特征数据操作.有效()
            && 高级数据操作.有效() && 主体结果.成功() && 场景结果.成功()
            && 接纳.成功() && 特征定义结果.成功() && 特征槽位结果.成功()
            && 特征当前值结果.成功() && 条件状态结果.成功()
            && 创建结果.成功() && 已承接.成功() && 筹办中.成功()
            && 登记根.成功() && 方法首.成功() && 条件.成功()
            && 结果规格.成功() && 动作.成功() && 召回.有唯一建议()
            && 选择.成功();

        const auto 初始调度请求 = 形成调度请求(任务, 1);
        const auto 冻结结果 = 执行组合器.冻结任务执行请求(初始调度请求);
        const auto 冻结 = 冻结结果.冻结请求.value_or(任务执行冻结请求{});
        const auto& 输入关系 = 冻结.动作材料.输入场景关系;
        const auto& 输出关系 = 冻结.动作材料.输出场景关系;
        验收[0] = 夹具完整 && 冻结结果.已冻结()
            && 复核任务执行调度请求(初始调度请求).成功();
        验收[1] = std::is_copy_constructible_v<任务执行冻结请求>
            && std::is_move_constructible_v<任务执行冻结请求>
            && !std::is_copy_constructible_v<任务管理线程>
            && !std::is_copy_constructible_v<任务工作线程>;
        验收[2] = 冻结任务执行请求完整(冻结)
            && 冻结.任务材料.当前选择.has_value()
            && 冻结.任务材料.当前生命周期.阶段 == 任务执行生命周期阶段::筹办中
            && 冻结.方法材料.生命周期 == 任务执行方法生命周期::活跃
            && 冻结.动作材料.稳定动作键 == 稳定动作键
            && 输入关系.类型 == 关系类型::方法动作场景
            && 输出关系.类型 == 关系类型::方法动作场景
            && 输入关系.源节点 == 冻结.动作材料.身份.节点
            && 输出关系.源节点 == 冻结.动作材料.身份.节点
            && 输入关系.目标节点 == 场景 && 输出关系.目标节点 == 场景
            && 输入关系.顺序号 == 1 && 输出关系.顺序号 == 2;

        const auto 非法前数量 = 读取数量();
        auto 错版本请求 = 初始调度请求;
        错版本请求.协议版本 = 0;
        任务执行组合器 错动作键组合器(任务服务, 方法服务, 状态动态, 2);
        auto 跨场景冻结 = 冻结;
        跨场景冻结.动作材料.输出场景 = 主体;
        auto 旧引用冻结 = 冻结;
        旧引用冻结.动作材料.输入场景关系.类型 = 关系类型::引用;
        auto 缺槽冻结 = 冻结;
        缺槽冻结.动作材料.输出场景关系 = {};
        const auto 错版本结果 = 执行组合器.冻结任务执行请求(错版本请求);
        const auto 错动作键结果 = 错动作键组合器.冻结任务执行请求(初始调度请求);
        验收[3] = !错版本结果.已冻结() && !错动作键结果.已冻结()
            && !冻结任务执行请求完整(跨场景冻结)
            && !冻结任务执行请求完整(旧引用冻结)
            && !冻结任务执行请求完整(缺槽冻结)
            && 冻结.动作材料.输入场景 == 场景
            && 冻结.动作材料.输出场景 == 场景
            && 读取数量() == 非法前数量;

        任务管理线程 候选管理线程(4, 4);
        const auto 候选管理启动 = 候选管理线程.启动();
        const auto 候选前快照 = 候选管理线程.读取强类型任务执行队列快照();
        bool 移动后源失效 = false;
        bool 移动后目标有效 = false;
        {
            auto 准备 = 候选管理线程.准备强类型任务执行请求(冻结);
            if (准备.候选.has_value()) {
                auto 移动一次 = std::move(*准备.候选);
                auto 移动两次 = std::move(移动一次);
                移动后源失效 = !移动一次.有效();
                移动后目标有效 = 移动两次.有效();
            }
        }
        const auto 候选析构后快照 = 候选管理线程.读取强类型任务执行队列快照();
        auto 显式准备 = 候选管理线程.准备强类型任务执行请求(冻结);
        const auto 显式撤销 = 显式准备.候选.has_value()
            ? 候选管理线程.撤销强类型任务执行请求(*显式准备.候选)
            : 强类型任务执行请求操作结果{};
        const auto 候选撤销后快照 = 候选管理线程.读取强类型任务执行队列快照();
        验收[4] = 候选管理启动.成功 && 移动后源失效 && 移动后目标有效
            && 候选析构后快照.预留数量 == 0
            && 候选析构后快照.可消费数量 == 0
            && 候选析构后快照.已见请求数量 == 0
            && 显式撤销.状态 == 强类型任务执行请求队列状态::已撤销
            && 队列快照相同(候选前快照, 候选撤销后快照);

        任务管理线程 边界管理线程(2, 1);
        const auto 边界启动 = 边界管理线程.启动();
        auto 边界准备 = 边界管理线程.准备强类型任务执行请求(冻结);
        const auto 精确重复 = 边界管理线程.准备强类型任务执行请求(冻结);
        auto 请求号冲突冻结 = 冻结;
        请求号冲突冻结.调度请求.幂等键 = 新主键();
        const auto 请求号冲突 = 边界管理线程.准备强类型任务执行请求(请求号冲突冻结);
        auto 幂等冲突冻结 = 冻结;
        幂等冲突冻结.调度请求.请求编号 = 新主键();
        const auto 幂等冲突 = 边界管理线程.准备强类型任务执行请求(幂等冲突冻结);
        auto 容量冻结 = 冻结;
        容量冻结.调度请求 = 形成调度请求(任务, 2);
        const auto 容量拒绝 = 边界管理线程.准备强类型任务执行请求(容量冻结);
        const auto 边界撤销 = 边界准备.候选.has_value()
