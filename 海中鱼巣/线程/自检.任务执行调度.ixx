        const auto 旧强类型取出 = 工作线程.取出一条任务结果回执();
        auto 降级回执 = 新回执取出.回执;
        降级回执.回执编号 = 新主键();
        降级回执.幂等键 = 新主键();
        降级回执.材料性质 = 任务结果回执材料性质::非权威执行结果证据;
        const auto 降级发布 = 工作线程.发布强类型任务结果回执(
