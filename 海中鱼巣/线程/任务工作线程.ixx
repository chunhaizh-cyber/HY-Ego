// 文件规则：任务工作线程只消费已准入请求并承载执行方提供的回执材料；不得裁决任务、需求或方法结果、写业务结构或定义其他线程角色。
module;

#include <atomic>
#include <cstdint>
#include <deque>
#include <functional>
#include <mutex>
#include <thread>
#include <unordered_map>
#include <utility>

export module 海中鱼巣.线程.任务工作线程;

import 海中鱼巣.线程.运行消息协议;
import 海中鱼巣.线程.任务结果回执协议;
import 海中鱼巣.线程.有界运行消息队列;
import 海中鱼巣.线程.任务管理线程;

export namespace 海中鱼巣 {

enum class 任务工作线程状态 : std::uint32_t {
    未启动 = 0,
    运行中 = 1,
    正在停止 = 2,
    已停止 = 3,
    启动失败 = 4
};

enum class 任务工作线程拒绝原因 : std::uint32_t {
    无 = 0,
    重复启动 = 1,
    队列容量为零 = 2,
    管理线程未启动 = 3,
    未启动 = 4,
    停止消息失败 = 5,
    非任务执行请求 = 6,
    回执入队失败 = 7,
    无请求材料 = 8,
    强类型回执容量为零 = 9
};

enum class 强类型任务结果回执发布状态 : std::uint32_t {
    已拒绝 = 0,
    已发布 = 1,
    重复材料 = 2,
    内部不一致 = 3
};

enum class 强类型任务结果回执队列拒绝原因 : std::uint32_t {
    无 = 0,
    工作线程未运行 = 1,
    工作线程已停止 = 2,
    容量为零 = 3,
    队列已满 = 4,
    协议拒绝 = 5,
    协议内部不一致 = 6,
    重复材料 = 7
};

struct 强类型任务结果回执发布结果 {
    强类型任务结果回执发布状态 状态 = 强类型任务结果回执发布状态::已拒绝;
    强类型任务结果回执队列拒绝原因 拒绝原因 = 强类型任务结果回执队列拒绝原因::无;
    任务结果回执准入结果 协议结果;
};

struct 强类型任务结果回执取出结果 {
    bool 有回执 = false;
    bool 队列已停止 = false;
    任务结果回执材料 回执;
};

struct 强类型任务结果回执队列快照 {
    std::uint64_t 容量 = 0;
    std::uint64_t 待处理数量 = 0;
    std::uint64_t 已见幂等键数量 = 0;
    std::uint64_t 同任务顺序数量 = 0;
    bool 已停止 = false;
};

struct 任务工作线程操作结果 {
    bool 成功 = false;
    bool 局部失败 = true;
    bool 写业务事实 = false;
    任务工作线程拒绝原因 拒绝原因 = 任务工作线程拒绝原因::无;
};

struct 任务工作线程消费结果 {
    bool 成功 = false;
    bool 局部失败 = true;
    bool 写业务事实 = false;
    bool 裸写仓库 = false;
    bool 裁决任务完成 = false;
    bool 裁决需求满足 = false;
    bool 裁决方法成功 = false;
    bool 需要领域服务复核 = true;
    任务工作线程拒绝原因 拒绝原因 = 任务工作线程拒绝原因::无;
    运行消息 请求消息;
    运行消息 回执消息;
};

class 任务工作线程 {
public:
    任务工作线程(任务管理线程& 管理线程, std::uint64_t 回执队列容量)
        : 任务工作线程(管理线程, 回执队列容量, 回执队列容量) {
    }

    任务工作线程(
        任务管理线程& 管理线程,
        std::uint64_t 回执队列容量,
        std::uint64_t 强类型回执队列容量)
        : 管理(管理线程),
          任务回执队列(回执队列容量),
          强类型回执容量上限(强类型回执队列容量) {
    }

    ~任务工作线程() {
        请求停止.store(true);
        if (线程.joinable()) {
            线程.join();
        }
    }

    任务工作线程(const 任务工作线程&) = delete;
    任务工作线程& operator=(const 任务工作线程&) = delete;

    任务工作线程状态 当前状态() const {
        return 状态.load();
    }

    bool 线程已进入() const {
        return 已进入.load();
    }

    bool 线程可收口() const {
        return !线程.joinable();
    }

    const 有界运行消息队列& 只读任务回执队列() const {
        return 任务回执队列;
    }

    强类型任务结果回执发布结果 发布强类型任务结果回执(
        const 任务结果回执材料& 回执,
        std::uint64_t 当前时间戳) {
        std::lock_guard<std::mutex> 锁(强类型回执队列锁);
        const auto 当前线程状态 = 状态.load();
        if (强类型回执停止锁存
            || 当前线程状态 == 任务工作线程状态::正在停止
            || 当前线程状态 == 任务工作线程状态::已停止) {
            return 拒绝强类型回执(强类型任务结果回执队列拒绝原因::工作线程已停止);
        }
        if (当前线程状态 != 任务工作线程状态::运行中) {
            return 拒绝强类型回执(强类型任务结果回执队列拒绝原因::工作线程未运行);
        }
        if (强类型回执容量上限 == 0) {
            return 拒绝强类型回执(强类型任务结果回执队列拒绝原因::容量为零);
        }

        const auto 准入上下文 = 构造强类型回执准入上下文(回执, 当前时间戳);
        const auto 协议结果 = 复核任务结果回执材料(回执, 准入上下文);
        if (协议结果.状态 == 任务结果回执准入状态::已拒绝) {
            return {强类型任务结果回执发布状态::已拒绝,
                强类型任务结果回执队列拒绝原因::协议拒绝, 协议结果};
        }
        if (协议结果.状态 == 任务结果回执准入状态::重复材料) {
            return {强类型任务结果回执发布状态::重复材料,
                强类型任务结果回执队列拒绝原因::重复材料, 协议结果};
        }
        if (协议结果.状态 == 任务结果回执准入状态::内部不一致
            || 协议结果.状态 != 任务结果回执准入状态::可准入) {
            return {强类型任务结果回执发布状态::内部不一致,
                强类型任务结果回执队列拒绝原因::协议内部不一致, 协议结果};
        }
        if (强类型任务回执队列.size() >= 强类型回执容量上限) {
            return {强类型任务结果回执发布状态::已拒绝,
                强类型任务结果回执队列拒绝原因::队列已满, 协议结果};
        }

        强类型任务回执队列.push_back(回执);
        记录强类型回执索引(回执);
        return {强类型任务结果回执发布状态::已发布,
            强类型任务结果回执队列拒绝原因::无, 协议结果};
    }

    强类型任务结果回执取出结果 取出一条任务结果回执() {
        std::lock_guard<std::mutex> 锁(强类型回执队列锁);
        const bool 已停止 = 强类型回执停止锁存
            || 状态.load() == 任务工作线程状态::正在停止
            || 状态.load() == 任务工作线程状态::已停止;
        if (强类型任务回执队列.empty()) {
            return {false, 已停止, {}};
        }

        auto 回执 = std::move(强类型任务回执队列.front());
        强类型任务回执队列.pop_front();
        return {true, 已停止, std::move(回执)};
    }

    强类型任务结果回执队列快照 读取强类型任务回执快照() const {
        std::lock_guard<std::mutex> 锁(强类型回执队列锁);
        return {
            强类型回执容量上限,
            static_cast<std::uint64_t>(强类型任务回执队列.size()),
            static_cast<std::uint64_t>(强类型已见幂等材料.size()),
            static_cast<std::uint64_t>(强类型同任务最新序号.size()),
            强类型回执停止锁存
                || 状态.load() == 任务工作线程状态::正在停止
                || 状态.load() == 任务工作线程状态::已停止
        };
    }

    任务工作线程操作结果 启动() {
        if (状态.load() == 任务工作线程状态::运行中) {
            return 拒绝(任务工作线程拒绝原因::重复启动);
        }
        if (管理.当前状态() != 任务管理线程状态::运行中) {
            状态.store(任务工作线程状态::启动失败);
            return 拒绝(任务工作线程拒绝原因::管理线程未启动);
        }
        if (任务回执队列.容量() == 0) {
            状态.store(任务工作线程状态::启动失败);
            return 拒绝(任务工作线程拒绝原因::队列容量为零);
        }
        if (强类型回执容量上限 == 0) {
            状态.store(任务工作线程状态::启动失败);
            return 拒绝(任务工作线程拒绝原因::强类型回执容量为零);
        }

        {
            std::lock_guard<std::mutex> 锁(强类型回执队列锁);
            强类型回执停止锁存 = false;
        }
        请求停止.store(false);
        已进入.store(false);
        状态.store(任务工作线程状态::运行中);
        线程 = std::thread([this]() {
            已进入.store(true);
            while (!请求停止.load()) {
                std::this_thread::yield();
            }
        });
        return {true, false, false, 任务工作线程拒绝原因::无};
    }

    任务工作线程消费结果 消费一次并生成回执(
        std::uint64_t 回执消息编号, std::uint64_t 回执时间戳) {
        if (状态.load() != 任务工作线程状态::运行中) {
            return 消费拒绝(任务工作线程拒绝原因::未启动);
        }

        const auto 出队 = 管理.取出任务执行请求();
        if (!出队.有消息) {
            return 消费拒绝(任务工作线程拒绝原因::无请求材料);
        }
        if (出队.消息.类型 != 运行消息类型::任务执行请求) {
            return 消费拒绝(任务工作线程拒绝原因::非任务执行请求);
        }

        运行消息 回执消息;
        回执消息.消息编号 = 回执消息编号;
        回执消息.类型 = 运行消息类型::结果回执;
        回执消息.来源角色 = 运行线程角色::任务工作;
        回执消息.目标角色 = 运行线程角色::任务管理;
        回执消息.目标任务 = 出队.消息.目标任务;
        回执消息.目标材料 = 出队.消息.目标材料;
        回执消息.句柄版本 = 出队.消息.句柄版本;
        回执消息.当前句柄版本 = 出队.消息.当前句柄版本;
        回执消息.发生时间戳 = 回执时间戳;
        回执消息.优先级 = 运行消息优先级::高;
        回执消息.幂等键 = 回执消息编号;
        回执消息.批次号 = 出队.消息.批次号;
        回执消息.材料摘要 = 回执消息编号 + 出队.消息.材料摘要;
        回执消息.任务编号 = 出队.消息.任务编号;
        回执消息.任务序号 = 出队.消息.任务序号;
        回执消息.只读材料说明 = true;
        回执消息.承载机器事实 = false;

        const auto 入队 = 任务回执队列.入队(回执消息);
        if (!入队.已入队) {
            return 消费拒绝(任务工作线程拒绝原因::回执入队失败);
        }

        return {true, false, false, false, false, false, false, true,
            任务工作线程拒绝原因::无, 出队.消息, 回执消息};
    }

    任务工作线程操作结果 请求停止并发送停止消息(
        std::uint64_t 停止消息编号, std::uint64_t 停止时间戳) {
        if (状态.load() == 任务工作线程状态::未启动) {
            return 拒绝(任务工作线程拒绝原因::未启动);
        }

        bool 原停止锁存 = false;
        {
            std::lock_guard<std::mutex> 锁(强类型回执队列锁);
            原停止锁存 = 强类型回执停止锁存;
            强类型回执停止锁存 = true;
        }

        运行消息 停止消息;
        停止消息.消息编号 = 停止消息编号;
        停止消息.类型 = 运行消息类型::停止;
        停止消息.来源角色 = 运行线程角色::运行宿主;
        停止消息.目标角色 = 运行线程角色::任务工作;
        停止消息.发生时间戳 = 停止时间戳;
        停止消息.优先级 = 运行消息优先级::停止;
        停止消息.幂等键 = 停止消息编号;
        停止消息.材料摘要 = 停止消息编号;
        停止消息.只读材料说明 = true;
        停止消息.承载机器事实 = false;

        const auto 入队 = 任务回执队列.入队(停止消息);
        if (!入队.已入队) {
            std::lock_guard<std::mutex> 锁(强类型回执队列锁);
            强类型回执停止锁存 = 原停止锁存;
            return 拒绝(任务工作线程拒绝原因::停止消息失败);
        }

        状态.store(任务工作线程状态::正在停止);
        请求停止.store(true);
        return {true, false, false, 任务工作线程拒绝原因::无};
    }

    任务工作线程操作结果 收口等待() {
        if (线程.joinable()) {
            线程.join();
        }
        if (状态.load() == 任务工作线程状态::正在停止
            || 状态.load() == 任务工作线程状态::运行中) {
            状态.store(任务工作线程状态::已停止);
        }
        return {true, false, false, 任务工作线程拒绝原因::无};
    }

private:
    struct 强类型回执任务句柄哈希 {
        std::size_t operator()(const 任务结果回执节点句柄& 句柄) const noexcept {
            std::size_t 结果 = std::hash<std::uint64_t>{}(句柄.仓库编号);
            结果 ^= std::hash<std::uint64_t>{}(句柄.节点编号)
                + static_cast<std::size_t>(0x9e3779b9U) + (结果 << 6U) + (结果 >> 2U);
            结果 ^= std::hash<std::uint32_t>{}(句柄.版本号)
                + static_cast<std::size_t>(0x9e3779b9U) + (结果 << 6U) + (结果 >> 2U);
            return 结果;
        }
    };

    struct 强类型回执任务句柄相等 {
        bool operator()(
            const 任务结果回执节点句柄& 左,
            const 任务结果回执节点句柄& 右) const noexcept {
            return 任务结果回执句柄相同(左, 右);
        }
    };

    任务管理线程& 管理;
    有界运行消息队列 任务回执队列;
    std::uint64_t 强类型回执容量上限 = 0;
    mutable std::mutex 强类型回执队列锁;
    std::deque<任务结果回执材料> 强类型任务回执队列;
    std::unordered_map<std::uint64_t, 任务结果回执材料> 强类型已见幂等材料;
    std::unordered_map<任务结果回执节点句柄, std::uint64_t,
        强类型回执任务句柄哈希, 强类型回执任务句柄相等> 强类型同任务最新序号;
    bool 强类型回执停止锁存 = false;
    std::atomic<任务工作线程状态> 状态 = 任务工作线程状态::未启动;
    std::atomic<bool> 请求停止 = false;
    std::atomic<bool> 已进入 = false;
    std::thread 线程;

    任务工作线程操作结果 拒绝(任务工作线程拒绝原因 原因) const {
        return {false, true, false, 原因};
    }

    任务工作线程消费结果 消费拒绝(任务工作线程拒绝原因 原因) const {
        return {false, true, false, false, false, false, false, true, 原因, {}, {}};
    }

    强类型任务结果回执发布结果 拒绝强类型回执(
        强类型任务结果回执队列拒绝原因 原因) const {
        return {强类型任务结果回执发布状态::已拒绝, 原因, {}};
    }

    任务结果回执准入上下文 构造强类型回执准入上下文(
        const 任务结果回执材料& 回执,
        std::uint64_t 当前时间戳) const {
        任务结果回执准入上下文 上下文;
        上下文.当前时间戳 = 当前时间戳;
        const auto 幂等位置 = 强类型已见幂等材料.find(回执.幂等键);
        if (幂等位置 != 强类型已见幂等材料.end()) {
            上下文.同幂等键既有材料 = 幂等位置->second;
        }
        if (!自我治理句柄为空(回执.句柄组.目标任务)
            && 自我治理可选句柄形状有效(回执.句柄组.目标任务)) {
            const auto 顺序位置 = 强类型同任务最新序号.find(回执.句柄组.目标任务);
            if (顺序位置 != 强类型同任务最新序号.end()) {
                上下文.同任务目标 = 回执.句柄组.目标任务;
                上下文.同任务最新序号 = 顺序位置->second;
            }
        }
        return 上下文;
    }

    void 记录强类型回执索引(const 任务结果回执材料& 回执) {
        强类型已见幂等材料.emplace(回执.幂等键, 回执);
        auto& 最新序号 = 强类型同任务最新序号[回执.句柄组.目标任务];
        if (回执.来源任务序号 > 最新序号) {
            最新序号 = 回执.来源任务序号;
        }
    }
};

}
