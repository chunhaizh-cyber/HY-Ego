// 文件规则：D455 采样材料上行桥只编排帧来源、专用缓存和标量运行消息；不得入队、写仓库或调用领域服务。
module;

#include <cstdint>
#include <memory>
#include <string>

export module 海中鱼巣.线程.上行桥.D455采样材料;
import 海中鱼巣.适配.协议.D455采样材料;
import 海中鱼巣.线程.缓存.D455帧材料;
import 海中鱼巣.线程.运行消息协议;

export namespace 海中鱼巣 {

enum class D455上行拒绝原因 : std::uint8_t {
    无 = 0,
    请求无效 = 1,
    采集拒绝 = 2,
    材料无效 = 3,
    批次不匹配 = 4,
    缓存拒绝 = 5,
    候选读回不一致 = 6,
    发布失败 = 7,
    普通读回不一致 = 8,
    精确撤销失败 = 9
};

struct D455材料上行请求 {
    std::uint64_t 消息编号 = 0;
    std::uint64_t 批次号 = 0;
    std::uint64_t 消息幂等键 = 0;
    运行线程角色 目标角色 = 运行线程角色::未知;
    std::uint64_t 当前宿主时间戳 = 0;
    std::uint32_t 采样超时毫秒 = 0;
};

struct D455材料上行结果 {
    bool 成功 = false;
    bool 追根因 = false;
    D455上行拒绝原因 拒绝原因 = D455上行拒绝原因::无;
    D455采集拒绝原因 采集拒绝原因 = D455采集拒绝原因::无;
    D455缓存拒绝原因 缓存拒绝原因 = D455缓存拒绝原因::无;
    D455帧材料句柄 材料句柄;
    运行消息 消息;
    std::shared_ptr<const D455同步帧材料> 材料;
};

class D455采样材料上行桥 {
public:
    D455采样材料上行桥(D455帧来源& 帧来源, D455帧材料缓存& 缓存) noexcept
        : 帧来源_(帧来源), 缓存_(缓存) {
    }

    D455材料上行结果 上行一次(const D455材料上行请求& 请求) {
        if (请求.消息编号 == 0
            || 请求.批次号 == 0
            || 请求.消息幂等键 == 0
            || 请求.目标角色 != 运行线程角色::任务管理
            || 请求.当前宿主时间戳 == 0
            || 请求.采样超时毫秒 == 0) {
            return {false, false, D455上行拒绝原因::请求无效};
        }

        const auto 采集结果 = 帧来源_.采样一次(请求.采样超时毫秒);
        if (!采集结果.成功) {
            D455材料上行结果 结果;
            结果.追根因 = 采集结果.追根因;
            结果.拒绝原因 = D455上行拒绝原因::采集拒绝;
            结果.采集拒绝原因 = 采集结果.拒绝原因;
            return 结果;
        }
        if (!采集结果.材料 || !D455同步帧材料有效(*采集结果.材料)) {
            return {false, true, D455上行拒绝原因::材料无效,
                D455采集拒绝原因::材料无效};
        }
        if (采集结果.材料->批次号 != 请求.批次号) {
            return {false, false, D455上行拒绝原因::批次不匹配};
        }

        auto 准备结果 = 缓存_.准备帧材料候选(
            采集结果.材料, 请求.当前宿主时间戳);
        if (!准备结果.成功 || !准备结果.候选.has_value()) {
            D455材料上行结果 结果;
            结果.追根因 = 准备结果.追根因;
            结果.拒绝原因 = D455上行拒绝原因::缓存拒绝;
            结果.缓存拒绝原因 = 准备结果.拒绝原因;
            return 结果;
        }

        const auto& 候选 = *准备结果.候选;
        const auto 候选读回 = 缓存_.读取候选(候选);
        if (!候选读回.成功
            || !候选读回.句柄.有效()
            || !候选读回.材料
            || 候选读回.字节数 != 计算D455同步帧字节数(*采集结果.材料)
            || !同一材料(*候选读回.材料, *采集结果.材料)) {
            return 撤销后返回(
                候选读回.句柄,
                D455上行拒绝原因::候选读回不一致,
                候选读回.拒绝原因);
        }

        运行消息 消息;
        消息.消息编号 = 请求.消息编号;
        消息.类型 = 运行消息类型::外部材料;
        消息.来源角色 = 运行线程角色::外设采样材料;
        消息.目标角色 = 请求.目标角色;
        消息.目标材料 = 候选读回.句柄.材料编号;
        消息.句柄版本 = 候选读回.句柄.版本;
        消息.当前句柄版本 = 候选读回.句柄.版本;
        消息.发生时间戳 = 候选读回.材料->宿主接收单调时间戳;
        消息.优先级 = 运行消息优先级::普通;
        消息.幂等键 = 请求.消息幂等键;
        消息.批次号 = 候选读回.材料->批次号;
        消息.材料摘要 = 计算D455材料摘要(*候选读回.材料);
        消息.只读材料说明 = true;
        消息.承载机器事实 = false;

        const auto 发布结果 = 缓存_.确认发布帧材料(候选);
        if (!发布结果.成功 || !(发布结果.句柄.材料编号 == 候选读回.句柄.材料编号
            && 发布结果.句柄.版本 == 候选读回.句柄.版本)) {
            return 撤销后返回(
                候选读回.句柄,
                D455上行拒绝原因::发布失败,
                发布结果.拒绝原因);
        }

        const auto 普通读回 = 缓存_.按编号版本读取(发布结果.句柄);
        if (!普通读回.成功
            || !普通读回.材料
            || !同一材料(*普通读回.材料, *候选读回.材料)
            || 消息.目标材料 != 普通读回.句柄.材料编号
            || 消息.句柄版本 != 普通读回.句柄.版本
            || 消息.批次号 != 普通读回.材料->批次号) {
            return 撤销后返回(
                发布结果.句柄,
                D455上行拒绝原因::普通读回不一致,
                普通读回.拒绝原因);
        }

        D455材料上行结果 结果;
        结果.成功 = true;
        结果.材料句柄 = 发布结果.句柄;
        结果.消息 = 消息;
        结果.材料 = 普通读回.材料;
        return 结果;
    }

    D455缓存变更结果 精确撤销已发布材料(D455帧材料句柄 句柄) {
        return 缓存_.精确撤销帧材料(句柄);
    }

private:
    static bool 同一材料(
        const D455同步帧材料& 左,
        const D455同步帧材料& 右) noexcept {
        return 左.设备身份.序列号 == 右.设备身份.序列号
            && 左.批次号 == 右.批次号
            && 左.标定版本摘要 == 右.标定版本摘要
            && 左.宿主接收单调时间戳 == 右.宿主接收单调时间戳
            && 左.彩色.源帧编号 == 右.彩色.源帧编号
            && 左.深度.源帧编号 == 右.深度.源帧编号
            && 左.左红外.源帧编号 == 右.左红外.源帧编号
            && 左.右红外.源帧编号 == 右.右红外.源帧编号
            && 计算D455同步帧字节数(左) == 计算D455同步帧字节数(右);
    }

    D455材料上行结果 撤销后返回(
        D455帧材料句柄 句柄,
        D455上行拒绝原因 原因,
        D455缓存拒绝原因 缓存原因) {
        D455材料上行结果 结果;
        结果.追根因 = true;
        结果.拒绝原因 = 原因;
        结果.缓存拒绝原因 = 缓存原因;
        结果.材料句柄 = 句柄;
        if (!句柄.有效()) {
            结果.拒绝原因 = D455上行拒绝原因::精确撤销失败;
            return 结果;
        }
        const auto 撤销结果 = 缓存_.精确撤销帧材料(句柄);
        if (!撤销结果.成功) {
            结果.拒绝原因 = D455上行拒绝原因::精确撤销失败;
            结果.缓存拒绝原因 = 撤销结果.拒绝原因;
        }
        return 结果;
    }

    D455帧来源& 帧来源_;
    D455帧材料缓存& 缓存_;
};

}
