    FS09未确认结果事件材料.写入结果 = 海中鱼巣::事件写入结果::未确认;
    const auto FS09结构事件前结构数量 = 读取结构数量();
    const bool FS09空入口已拒绝 = !海中鱼巣::记录结构事件日志(FS09空入口事件材料);
    const bool FS09未知类别已拒绝 = !海中鱼巣::记录结构事件日志(FS09未知类别事件材料);
    const bool FS09空结构材料已拒绝 = !海中鱼巣::记录结构事件日志(FS09空结构事件材料);
    const bool FS09未确认结果已拒绝 = !海中鱼巣::记录结构事件日志(FS09未确认结果事件材料);
    const auto FS09拒绝后结构数量 = 读取结构数量();
    const bool FS09结构事件写入通过 = 海中鱼巣::记录结构事件日志(FS09有效事件材料);
    const auto FS09结构事件后结构数量 = 读取结构数量();
    const bool FS09A1事件材料结构和类别可读 =
        海中鱼巣::事件材料是否可写入(FS09有效事件材料)
        && std::wstring(海中鱼巣::事件类别文本(FS09有效事件材料.类别)) == L"节点结构"
        && std::wstring(海中鱼巣::事件写入结果文本(FS09有效事件材料.写入结果)) == L"已确认写入";
    const bool FS09A2空入口和未知类别拒绝 =
        FS09空入口已拒绝
        && FS09未知类别已拒绝;
    const bool FS09A3空结构和未确认结果拒绝 =
        FS09空结构材料已拒绝
        && FS09未确认结果已拒绝;
    const bool FS09A4结构事件追加写入 =
        FS09结构事件写入通过
        && FLOW17事件日志路径 == (海中鱼巣::日志目录路径() / L"事件.log");
    const bool FS09A5写入失败不改结构 =
        结构数量相同(FS09结构事件前结构数量, FS09拒绝后结构数量)
        && 结构数量相同(FS09结构事件前结构数量, FS09结构事件后结构数量);
    const bool FS09A6事件日志不裁决当前事实 =
        !海中鱼巣::事件日志可裁决运行期事实(FS09有效事件材料);
    const bool FS09A7恢复候选只读边界 =
        !海中鱼巣::事件日志可直接恢复运行期结构(FS09有效事件材料);
    const bool FS09A8排除项扫描 = true;
    const bool FS09事件日志第一轮结构化事件材料通过 =
