    std::cout << '\n';
    输出验收项("THREAD-S4-A5", "事件日志失败不裁决机器事实", 线程四A5事件日志失败不裁决机器事实);
    std::cout << '\n';
    输出验收项("THREAD-S4-A6", "禁止 SQL/ADO/WebView/外设接入", 线程四A6禁止能力未接入);
    std::cout << '\n';
    输出验收项("THREAD-S5-A1", "外设采样材料线程可启动和停止", 线程五A1外设采样材料线程可启动停止);
    std::cout << '\n';
    输出验收项("THREAD-S5-A2", "空采样材料可入队", 线程五A2空采样材料可入队);
    std::cout << '\n';
    输出验收项("THREAD-S5-A3", "过期模拟材料可丢弃", 线程五A3过期模拟材料可丢弃);
    std::cout << '\n';
    输出验收项("THREAD-S5-A4", "材料不直接写世界事实", 线程五A4材料不直接写世界事实);
    std::cout << '\n';
    输出验收项("THREAD-S5-A5", "禁止 D455/体素/真实外设接入", 线程五A5禁止能力未接入);
    std::cout << '\n';
    输出验收项("THREAD-S6-A1", "停止收口", 线程六A1停止收口);
    std::cout << '\n';
    输出验收项("THREAD-S6-A2", "队列满载不写事实", 线程六A2队列满载不写事实);
    std::cout << '\n';
    输出验收项("THREAD-S6-A3", "幂等过期乱序拒绝", 线程六A3幂等过期乱序拒绝);
    std::cout << '\n';
    输出验收项("THREAD-S6-A4", "缓存非权威", 线程六A4缓存非权威);
    std::cout << '\n';
    输出验收项("THREAD-S6-A5", "日志不裁决", 线程六A5日志不裁决);
    std::cout << '\n';
    输出验收项("THREAD-S6-A6", "外部材料不入事实", 线程六A6外部材料不入事实);
    std::cout << '\n';
    输出验收项("THREAD-S6-A7", "防死锁入口无等待结构", 线程六A7防死锁入口无等待结构);
    std::cout << '\n';
    输出验收项("THREAD-S6-A8", "禁止能力未接入", 线程六A8禁止能力未接入);
    std::cout << '\n';
    const std::size_t 失败数量=static_cast<std::size_t>(!线程四A1缓存统计线程可启动停止)
        + static_cast<std::size_t>(!线程四A2缓存刷新消息局部拒绝)
        + static_cast<std::size_t>(!线程四A3清空缓存不改变权威结构)
        + static_cast<std::size_t>(!线程四A4事件日志线程可启动停止)
        + static_cast<std::size_t>(!线程四A5事件日志失败不裁决机器事实)
        + static_cast<std::size_t>(!线程四A6禁止能力未接入)
        + static_cast<std::size_t>(!线程五A1外设采样材料线程可启动停止)
        + static_cast<std::size_t>(!线程五A2空采样材料可入队)
        + static_cast<std::size_t>(!线程五A3过期模拟材料可丢弃)
        + static_cast<std::size_t>(!线程五A4材料不直接写世界事实)
        + static_cast<std::size_t>(!线程五A5禁止能力未接入)
        + static_cast<std::size_t>(!线程六A1停止收口)
        + static_cast<std::size_t>(!线程六A2队列满载不写事实)
        + static_cast<std::size_t>(!线程六A3幂等过期乱序拒绝)
        + static_cast<std::size_t>(!线程六A4缓存非权威)
        + static_cast<std::size_t>(!线程六A5日志不裁决)
        + static_cast<std::size_t>(!线程六A6外部材料不入事实)
        + static_cast<std::size_t>(!线程六A7防死锁入口无等待结构)
        + static_cast<std::size_t>(!线程六A8禁止能力未接入);
    return {"THREAD-S4-S6","运行线程后段",失败数量==0,19,失败数量};
}
