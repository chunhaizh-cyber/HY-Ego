// 文件规则：任务结果回执协议只定义强类型非权威结果证据和值复核；不得调用领域入口、写机器结构或承载裁决结论。
module;

#include <cstdint>
#include <optional>

export module 海中鱼巣.线程.任务结果回执协议;

import 海中鱼巣.线程.自我治理消息协议;
import 海中鱼巣.线程.协议.任务执行请求;

export namespace 海中鱼巣 {

inline constexpr std::uint32_t 任务结果回执协议版本 = 1;

using 任务结果回执节点句柄 = decltype(自我治理只读材料句柄组{}.目标任务);

enum class 任务结果回执材料性质 : std::uint32_t {
    未知 = 0,
    非权威执行结果证据 = 1,
    权威事实声明 = 2,
    权限结论声明 = 3,
    非权威任务执行结果证据 = 4
};

enum class 任务结果回执过期策略 : std::uint32_t {
    未知 = 0,
    永不过期 = 1,
    截止时间 = 2
};

enum class 任务结果回执准入状态 : std::uint32_t {
    已拒绝 = 0,
    可准入 = 1,
    重复材料 = 2,
    内部不一致 = 3
};

enum class 任务结果回执拒绝原因 : std::uint32_t {
    无 = 0,
    协议版本不匹配 = 1,
    回执编号无效 = 2,
    发生时间戳无效 = 3,
    幂等键无效 = 4,
    任务序号无效 = 5,
    批次编号无效 = 6,
    材料摘要无效 = 7,
    材料性质无效 = 8,
    只读材料标记缺失 = 9,
    材料越权承载事实 = 10,
    过期策略无效 = 11,
    当前时间戳无效 = 12,
    截止时间缺失 = 13,
    材料已过期 = 14,
    句柄形状无效 = 15,
    必填句柄缺失 = 16,
    幂等键冲突 = 17,
    同一任务序号倒退 = 18,
    准入上下文不一致 = 19,
    来源执行请求缺失 = 20,
    来源执行请求无效 = 21,
    来源执行请求不一致 = 22
};

struct 任务结果回执句柄组 {
    任务结果回执节点句柄 目标任务;
    任务结果回执节点句柄 实际结果状态;
    任务结果回执节点句柄 动态证据;
    任务结果回执节点句柄 目标方法;
    任务结果回执节点句柄 目标动作入口;
    任务结果回执节点句柄 场景;
    任务结果回执节点句柄 主体;
};

struct 任务结果回执材料 {
    std::uint32_t 协议版本 = 任务结果回执协议版本;
    std::uint64_t 回执编号 = 0;
    std::uint64_t 发生时间戳 = 0;
    std::uint64_t 幂等键 = 0;
    std::uint64_t 来源任务序号 = 0;
    std::uint64_t 批次编号 = 0;
    std::uint64_t 非权威材料摘要 = 0;
    任务结果回执材料性质 材料性质 = 任务结果回执材料性质::未知;
    任务结果回执过期策略 过期策略 = 任务结果回执过期策略::未知;
    std::uint64_t 截止时间戳 = 0;
    bool 只读材料说明 = true;
    bool 承载机器事实 = false;
    任务结果回执句柄组 句柄组;
    std::optional<任务执行冻结请求> 来源执行请求;
};

struct 任务结果回执准入上下文 {
    std::uint64_t 当前时间戳 = 0;
    std::optional<任务结果回执材料> 同幂等键既有材料;
    任务结果回执节点句柄 同任务目标;
    std::uint64_t 同任务最新序号 = 0;
};

struct 任务结果回执准入结果 {
    任务结果回执准入状态 状态 = 任务结果回执准入状态::已拒绝;
    任务结果回执拒绝原因 拒绝原因 = 任务结果回执拒绝原因::无;
};

inline bool 任务结果回执句柄相同(
    const 任务结果回执节点句柄& 左,
    const 任务结果回执节点句柄& 右) {
    return 左.仓库编号 == 右.仓库编号
        && 左.节点编号 == 右.节点编号
        && 左.版本号 == 右.版本号;
}

inline bool 任务结果回执句柄组相同(
    const 任务结果回执句柄组& 左,
    const 任务结果回执句柄组& 右) {
    return 任务结果回执句柄相同(左.目标任务, 右.目标任务)
        && 任务结果回执句柄相同(左.实际结果状态, 右.实际结果状态)
        && 任务结果回执句柄相同(左.动态证据, 右.动态证据)
        && 任务结果回执句柄相同(左.目标方法, 右.目标方法)
        && 任务结果回执句柄相同(左.目标动作入口, 右.目标动作入口)
        && 任务结果回执句柄相同(左.场景, 右.场景)
        && 任务结果回执句柄相同(左.主体, 右.主体);
}

inline bool 任务结果回执材料相同(
    const 任务结果回执材料& 左,
    const 任务结果回执材料& 右) {
    return 左.协议版本 == 右.协议版本
        && 左.回执编号 == 右.回执编号
        && 左.发生时间戳 == 右.发生时间戳
        && 左.幂等键 == 右.幂等键
        && 左.来源任务序号 == 右.来源任务序号
        && 左.批次编号 == 右.批次编号
        && 左.非权威材料摘要 == 右.非权威材料摘要
        && 左.材料性质 == 右.材料性质
        && 左.过期策略 == 右.过期策略
        && 左.截止时间戳 == 右.截止时间戳
        && 左.只读材料说明 == 右.只读材料说明
        && 左.承载机器事实 == 右.承载机器事实
        && 任务结果回执句柄组相同(左.句柄组, 右.句柄组)
        && 左.来源执行请求.has_value() == 右.来源执行请求.has_value()
        && (!左.来源执行请求.has_value()
            || 冻结任务执行请求相同(*左.来源执行请求, *右.来源执行请求));
}

inline bool 任务结果回执全部句柄形状有效(const 任务结果回执句柄组& 句柄组) {
    return 自我治理可选句柄形状有效(句柄组.目标任务)
        && 自我治理可选句柄形状有效(句柄组.实际结果状态)
        && 自我治理可选句柄形状有效(句柄组.动态证据)
        && 自我治理可选句柄形状有效(句柄组.目标方法)
        && 自我治理可选句柄形状有效(句柄组.目标动作入口)
        && 自我治理可选句柄形状有效(句柄组.场景)
        && 自我治理可选句柄形状有效(句柄组.主体);
}

inline bool 任务结果回执必填句柄齐全(const 任务结果回执句柄组& 句柄组) {
    return !自我治理句柄为空(句柄组.目标任务)
        && !自我治理句柄为空(句柄组.实际结果状态)
        && !自我治理句柄为空(句柄组.动态证据)
        && !自我治理句柄为空(句柄组.目标方法)
        && !自我治理句柄为空(句柄组.目标动作入口)
        && !自我治理句柄为空(句柄组.场景)
        && !自我治理句柄为空(句柄组.主体);
}

inline 任务结果回执准入结果 拒绝任务结果回执材料(任务结果回执拒绝原因 原因) {
    return {任务结果回执准入状态::已拒绝, 原因};
}

inline 任务结果回执准入结果 复核任务结果回执材料(
    const 任务结果回执材料& 材料,
    const 任务结果回执准入上下文& 上下文) {
    if (材料.协议版本 != 任务结果回执协议版本) {
        return 拒绝任务结果回执材料(任务结果回执拒绝原因::协议版本不匹配);
    }
    if (材料.回执编号 == 0) {
        return 拒绝任务结果回执材料(任务结果回执拒绝原因::回执编号无效);
    }
    if (材料.发生时间戳 == 0) {
        return 拒绝任务结果回执材料(任务结果回执拒绝原因::发生时间戳无效);
    }
    if (材料.幂等键 == 0) {
        return 拒绝任务结果回执材料(任务结果回执拒绝原因::幂等键无效);
    }
    if (材料.来源任务序号 == 0) {
        return 拒绝任务结果回执材料(任务结果回执拒绝原因::任务序号无效);
    }
    if (材料.批次编号 == 0) {
        return 拒绝任务结果回执材料(任务结果回执拒绝原因::批次编号无效);
    }
    if (材料.非权威材料摘要 == 0) {
        return 拒绝任务结果回执材料(任务结果回执拒绝原因::材料摘要无效);
    }
    if (材料.材料性质 != 任务结果回执材料性质::非权威执行结果证据
        && 材料.材料性质 != 任务结果回执材料性质::非权威任务执行结果证据) {
        return 拒绝任务结果回执材料(任务结果回执拒绝原因::材料性质无效);
    }
    if (!材料.只读材料说明) {
        return 拒绝任务结果回执材料(任务结果回执拒绝原因::只读材料标记缺失);
    }
    if (材料.承载机器事实) {
        return 拒绝任务结果回执材料(任务结果回执拒绝原因::材料越权承载事实);
    }
    if (材料.过期策略 != 任务结果回执过期策略::永不过期
        && 材料.过期策略 != 任务结果回执过期策略::截止时间) {
        return 拒绝任务结果回执材料(任务结果回执拒绝原因::过期策略无效);
    }
    if (上下文.当前时间戳 == 0) {
        return 拒绝任务结果回执材料(任务结果回执拒绝原因::当前时间戳无效);
    }
    if (材料.过期策略 == 任务结果回执过期策略::截止时间) {
        if (材料.截止时间戳 == 0) {
            return 拒绝任务结果回执材料(任务结果回执拒绝原因::截止时间缺失);
        }
        if (上下文.当前时间戳 > 材料.截止时间戳) {
            return 拒绝任务结果回执材料(任务结果回执拒绝原因::材料已过期);
        }
    }
    if (!任务结果回执全部句柄形状有效(材料.句柄组)) {
        return 拒绝任务结果回执材料(任务结果回执拒绝原因::句柄形状无效);
    }
    if (!任务结果回执必填句柄齐全(材料.句柄组)) {
        return 拒绝任务结果回执材料(任务结果回执拒绝原因::必填句柄缺失);
    }

    if (材料.材料性质 == 任务结果回执材料性质::非权威执行结果证据) {
        if (材料.来源执行请求.has_value()) {
            return 拒绝任务结果回执材料(任务结果回执拒绝原因::来源执行请求不一致);
        }
    } else {
        if (!材料.来源执行请求.has_value()) {
            return 拒绝任务结果回执材料(任务结果回执拒绝原因::来源执行请求缺失);
        }
        const auto& 来源 = *材料.来源执行请求;
        if (!冻结任务执行请求完整(来源)) {
            return 拒绝任务结果回执材料(任务结果回执拒绝原因::来源执行请求无效);
        }
        const auto& 请求 = 来源.调度请求;
        if (材料.回执编号 != 请求.回执编号
            || 材料.发生时间戳 != 请求.回执时间戳
            || 材料.幂等键 != 请求.回执幂等键
            || 材料.来源任务序号 != 请求.任务序号
            || 材料.批次编号 != 请求.批次编号
            || 材料.截止时间戳 != 请求.截止时间戳
            || !任务结果回执句柄相同(材料.句柄组.目标任务, 请求.任务)
            || !任务结果回执句柄相同(
                材料.句柄组.目标方法, 来源.方法材料.身份.节点)
            || !任务结果回执句柄相同(
                材料.句柄组.目标动作入口, 来源.动作材料.身份.节点)
            || !任务结果回执句柄相同(
                材料.句柄组.场景, 来源.任务材料.场景)
            || !任务结果回执句柄相同(
                材料.句柄组.主体, 来源.任务材料.虚拟存在)) {
            return 拒绝任务结果回执材料(任务结果回执拒绝原因::来源执行请求不一致);
        }
    }

    if (上下文.同幂等键既有材料.has_value()) {
        const auto& 既有材料 = 上下文.同幂等键既有材料.value();
        if (既有材料.幂等键 != 材料.幂等键) {
            return {任务结果回执准入状态::内部不一致,
                任务结果回执拒绝原因::准入上下文不一致};
        }
        if (任务结果回执材料相同(既有材料, 材料)) {
            return {任务结果回执准入状态::重复材料,
                任务结果回执拒绝原因::无};
        }
        return 拒绝任务结果回执材料(任务结果回执拒绝原因::幂等键冲突);
    }

    if (上下文.同任务最新序号 != 0) {
        if (自我治理句柄为空(上下文.同任务目标)
            || !自我治理可选句柄形状有效(上下文.同任务目标)
            || !任务结果回执句柄相同(上下文.同任务目标, 材料.句柄组.目标任务)) {
            return {任务结果回执准入状态::内部不一致,
                任务结果回执拒绝原因::准入上下文不一致};
        }
        if (材料.来源任务序号 < 上下文.同任务最新序号) {
            return 拒绝任务结果回执材料(任务结果回执拒绝原因::同一任务序号倒退);
        }
    } else if (!自我治理句柄为空(上下文.同任务目标)) {
        return {任务结果回执准入状态::内部不一致,
            任务结果回执拒绝原因::准入上下文不一致};
    }

    return {任务结果回执准入状态::可准入, 任务结果回执拒绝原因::无};
}

}
