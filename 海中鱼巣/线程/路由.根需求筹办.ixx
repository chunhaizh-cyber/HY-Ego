// 文件规则：根需求筹办路由只消费同一生产运行期租约的系统角色与 B0 业务面；不得接触传统服务、仓库或事务能力。
module;

#include "../生产治理闭环配置.数据.h"

#include <cstdint>
#include <optional>

export module 海中鱼巣.线程.路由.根需求筹办;

import 海中鱼巣.启动.运行期上下文;
import 海中鱼巣.领域.数据操作.需求任务方法;
import 海中鱼巣.领域.服务.需求;
import 海中鱼巣.领域.服务.任务;
import 海中鱼巣.领域.服务.方法;
import 海中鱼巣.领域.服务.方法召回;
import 海中鱼巣.领域.组合.需求任务方法;
import 海中鱼巣.领域.组合.任务执行;
import 海中鱼巣.领域.组合.运行期业务操作;
import 海中鱼巣.线程.协议.任务执行请求;

export namespace 海中鱼巣 {

enum class 根需求筹办状态 : std::uint8_t {
    入口拒绝 = 0,
    已冻结 = 1,
    根已满足 = 2,
    无候选 = 3,
    非唯一 = 4,
    当前性变化 = 5,
    内部不一致 = 6
};

struct 根需求筹办报告 {
    根需求筹办状态 状态 = 根需求筹办状态::入口拒绝;
    节点句柄 安全根需求;
    节点句柄 服务根需求;
    需求权威材料 根需求;
    任务权威材料 任务;
    方法登记项材料 方法;
    方法召回结果 召回;
    std::optional<任务方法选择材料> 选择;
    std::optional<任务执行冻结请求> 冻结请求;

    bool 完整() const noexcept {
        return 状态 == 根需求筹办状态::已冻结
            && 句柄有效(安全根需求) && 句柄有效(服务根需求)
            && 安全根需求 != 服务根需求 && 根需求.完整目标状态需求()
            && 根需求.身份.节点 == 安全根需求 && 任务.完整承接()
            && 任务.来源需求 == 安全根需求
            && 任务.当前生命周期.阶段 == 分层任务生命周期阶段::筹办中
            && 方法.完整() && 选择.has_value() && 选择->完整()
            && 选择->任务 == 任务.身份.节点
            && 选择->方法 == 方法.身份.节点
            && 冻结请求.has_value() && 冻结任务执行请求完整(*冻结请求);
    }
};

namespace 根需求筹办内部 {

inline 根需求筹办状态 映射召回状态(方法召回状态 状态) noexcept {
    switch (状态) {
    case 方法召回状态::无候选:
        return 根需求筹办状态::无候选;
    case 方法召回状态::非唯一建议:
        return 根需求筹办状态::非唯一;
    case 方法召回状态::内部不一致:
        return 根需求筹办状态::内部不一致;
    default:
        return 根需求筹办状态::当前性变化;
    }
}

inline bool 任务读回匹配(
    const 任务权威材料& 任务,
    节点句柄 来源需求,
    分层任务生命周期阶段 阶段) noexcept {
    return 任务.完整承接() && 任务.来源需求 == 来源需求
        && 任务.当前生命周期.阶段 == 阶段;
}

}

根需求筹办报告 筹办生产根需求(
    const 运行期上下文租约& 租约,
    const 生产治理闭环配置& 配置) {
    根需求筹办报告 报告;
    if (!配置.有效() || !租约.有效()) return 报告;
    const auto* 上下文 = 租约.读取();
    const auto 系统角色 = 上下文 ? 上下文->读取系统角色材料() : std::nullopt;
    const auto* 业务 = 上下文 ? 上下文->读取候选业务操作() : nullptr;
    if (!系统角色.has_value() || !系统角色->完整() || 业务 == nullptr
        || !业务->完整()) return 报告;

    const auto& 主体 = 系统角色->主体;
    报告.安全根需求 = 主体.安全根需求.根需求.节点;
    报告.服务根需求 = 主体.服务根需求.根需求.节点;
    if (配置.目标根角色 != 系统角色稳定键用途::安全根需求
        || !句柄有效(报告.安全根需求) || !句柄有效(报告.服务根需求)
        || 报告.安全根需求 == 报告.服务根需求) return 报告;

    报告.根需求 = 业务->读取需求(报告.安全根需求);
    const auto 服务根 = 业务->读取需求(报告.服务根需求);
    if (!报告.根需求.完整目标状态需求()
        || !服务根.完整目标状态需求()
        || 报告.根需求.身份.节点 != 报告.安全根需求
        || 服务根.身份.节点 != 报告.服务根需求) {
        报告.状态 = 根需求筹办状态::内部不一致;
        return 报告;
    }
    if (报告.根需求.当前结算 == 分层需求结算结论::已满足) {
        报告.状态 = 根需求筹办状态::根已满足;
        return 报告;
    }

    const auto 创建任务 = 业务->创建已有需求承接任务({
        配置.任务幂等主键, 配置.任务虚拟存在幂等主键,
        配置.任务初始状态幂等主键, 报告.安全根需求,
        配置.任务创建时间戳});
    if (!创建任务.成功() || !创建任务.材料.完整承接()) {
        报告.状态 = 创建任务.状态 == 需求任务方法业务状态::内部不一致
            ? 根需求筹办状态::内部不一致
            : 根需求筹办状态::当前性变化;
        return 报告;
    }
    const auto 任务 = 创建任务.材料.身份.节点;
    报告.任务 = 业务->读取任务(任务);
    if (!报告.任务.完整承接() || 报告.任务.来源需求 != 报告.安全根需求) {
        报告.状态 = 根需求筹办状态::内部不一致;
        return 报告;
    }

    if (报告.任务.当前生命周期.阶段 == 分层任务生命周期阶段::已创建) {
        const auto 已承接 = 业务->迁移任务生命周期({
            任务, 分层任务生命周期阶段::已承接,
            配置.已承接幂等材料编号, 配置.已承接时间戳});
        if (!已承接.成功()) {
            报告.状态 = 已承接.状态 == 需求任务方法业务状态::内部不一致
                ? 根需求筹办状态::内部不一致
                : 根需求筹办状态::当前性变化;
            return 报告;
        }
        报告.任务 = 业务->读取任务(任务);
    }
    if (报告.任务.当前生命周期.阶段 == 分层任务生命周期阶段::已承接) {
        const auto 筹办中 = 业务->迁移任务生命周期({
            任务, 分层任务生命周期阶段::筹办中,
            配置.筹办中幂等材料编号, 配置.筹办中时间戳});
        if (!筹办中.成功()) {
            报告.状态 = 筹办中.状态 == 需求任务方法业务状态::内部不一致
                ? 根需求筹办状态::内部不一致
                : 根需求筹办状态::当前性变化;
            return 报告;
        }
        报告.任务 = 业务->读取任务(任务);
    }
    if (!根需求筹办内部::任务读回匹配(
            报告.任务, 报告.安全根需求, 分层任务生命周期阶段::筹办中)) {
        报告.状态 = 根需求筹办状态::当前性变化;
        return 报告;
    }

    const auto 方法首 = 业务->创建方法首({
        配置.方法幂等主键, 配置.方法虚拟存在幂等主键,
        配置.方法角色状态幂等主键, 主体.方法登记根.节点});
    if (!方法首.成功() || !方法首.登记项.完整()) {
        报告.状态 = 方法首.状态 == 需求任务方法业务状态::内部不一致
            ? 根需求筹办状态::内部不一致
            : 根需求筹办状态::当前性变化;
        return 报告;
    }
    const auto 方法 = 方法首.登记项.身份.节点;
    const auto 方法结果 = 业务->创建方法结果({
        配置.方法结果幂等主键, 配置.方法结果角色状态幂等主键,
        方法, 主体.自我场景.节点, 主体.安全根需求.特征定义.节点,
        主体.安全根需求.目标状态.节点, 配置.方法规格来源版本});
    const auto 动作入口 = 业务->创建方法动作入口({
        配置.生产动作键, 配置.方法动作角色状态幂等主键,
        配置.方法动作入口状态幂等主键, 方法,
        主体.自我场景.节点, 主体.自我场景.节点,
        配置.方法动作入口状态值});
    报告.方法 = 业务->读取方法登记项(方法);
    if (!方法结果.成功() || !动作入口.成功() || !报告.方法.完整()
        || 报告.方法.身份.节点 != 方法) {
        报告.状态 = 方法结果.状态 == 需求任务方法业务状态::内部不一致
                || 动作入口.状态 == 需求任务方法业务状态::内部不一致
            ? 根需求筹办状态::内部不一致
            : 根需求筹办状态::当前性变化;
        return 报告;
    }

    if (!报告.任务.当前选择.has_value()) {
        const auto 选择结果 = 业务->召回并提交唯一选择({
            {任务, 主体.方法登记根.节点,
                配置.排序规则版本, 配置.召回请求规则版本},
            配置.选择记录幂等主键, 配置.选择幂等材料编号});
        报告.召回 = 选择结果.召回;
        if (!选择结果.成功()) {
            报告.状态 = 根需求筹办内部::映射召回状态(选择结果.召回.状态);
            return 报告;
        }
        报告.任务 = 业务->读取任务(任务);
    }
    if (!报告.任务.完整承接() || !报告.任务.当前选择.has_value()
        || !报告.任务.当前选择->完整()
        || 报告.任务.当前选择->方法 != 方法) {
        报告.状态 = 根需求筹办状态::内部不一致;
        return 报告;
    }
    报告.选择 = 报告.任务.当前选择;

    任务执行调度请求 调度;
    调度.请求编号 = 配置.执行请求编号;
    调度.幂等键 = 配置.执行请求幂等键;
    调度.任务序号 = 配置.任务序号;
    调度.批次编号 = 配置.批次编号;
    调度.任务 = 任务;
    调度.创建时间戳 = 配置.任务创建时间戳;
    调度.截止时间戳 = 配置.截止时间戳;
    调度.排队生命周期幂等主键 = 配置.排队生命周期幂等主键;
    调度.排队时间戳 = 配置.排队时间戳;
    调度.执行生命周期幂等主键 = 配置.执行生命周期幂等主键;
    调度.执行时间戳 = 配置.执行时间戳;
    调度.待重筹办幂等主键 = 配置.待重筹办幂等主键;
    调度.待重筹办时间戳 = 配置.待重筹办时间戳;
    调度.实际状态幂等主键 = 配置.实际状态幂等主键;
    调度.实际状态时间戳 = 配置.实际状态时间戳;
    调度.实际状态值 = 主体.安全根需求.目标值;
    调度.动态幂等主键 = 配置.动态幂等主键;
    调度.回执编号 = 配置.回执编号;
    调度.回执幂等键 = 配置.回执幂等键;
    调度.回执时间戳 = 配置.回执时间戳;
    const auto 冻结 = 业务->冻结任务执行请求(调度);
    if (!冻结.已冻结() || !冻结.冻结请求.has_value()
        || !冻结任务执行请求完整(*冻结.冻结请求)) {
        报告.状态 = 冻结.状态 == 任务执行组合状态::内部不一致
            ? 根需求筹办状态::内部不一致
            : 根需求筹办状态::当前性变化;
        return 报告;
    }
    报告.冻结请求 = 冻结.冻结请求;
    报告.状态 = 根需求筹办状态::已冻结;
    if (!报告.完整()) 报告.状态 = 根需求筹办状态::内部不一致;
    return 报告;
}

}
