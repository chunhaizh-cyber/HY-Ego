// 文件规则：运行期组合分层自检只验证隔离装配和无令牌同步路由，不进入生产依赖。
module;

#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
#include "核心/主信息仓库.h"
#include "核心/节点仓库.h"
#include "核心/关系仓库.h"
#include "核心/索引仓库.h"
#include "领域/特征值服务.h"

#include <algorithm>
#include <array>
#include <cstddef>
#include <cstdint>
#include <iostream>
#include <memory>
#include <type_traits>
#include <utility>
#include <variant>
#endif

export module 海中鱼巣.自检.运行期组合分层;

#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
import 海中鱼巣.核心.协调.结构事务;
import 海中鱼巣.领域.数据操作.存在场景;
import 海中鱼巣.领域.数据操作.状态动态;
import 海中鱼巣.领域.数据操作.特征体系;
import 海中鱼巣.领域.数据操作.语素基础;
import 海中鱼巣.领域.数据操作.轻量因果;
import 海中鱼巣.领域.数据操作.概念图结构;
import 海中鱼巣.领域.数据操作.需求任务方法;
import 海中鱼巣.领域.组合.存在场景;
import 海中鱼巣.领域.组合.状态动态;
import 海中鱼巣.领域.组合.特征状态;
import 海中鱼巣.领域.组合.语素概念入口;
import 海中鱼巣.领域.服务.语素;
import 海中鱼巣.领域.组合.概念结构发布;
import 海中鱼巣.领域.组合.需求任务方法;
import 海中鱼巣.领域.组合.运行期业务操作;
import 海中鱼巣.装配.运行期业务;
import 海中鱼巣.启动.运行期上下文;
import 海中鱼巣.线程.路由.运行期业务请求;
import 海中鱼巣.自检.运行器;

export namespace 海中鱼巣 {

namespace 运行期组合分层自检内部 {

struct 结构数量 {
    std::uint64_t 节点 = 0;
    std::uint64_t 关系 = 0;
    std::uint64_t 主键 = 0;

    bool operator==(const 结构数量&) const = default;
};

template <class 结果类型>
结果类型 读取结果或空(const 运行期业务路由结果& 路由结果) {
    const auto* 结果 = std::get_if<结果类型>(&路由结果.业务结果);
    return 结果 == nullptr ? 结果类型{} : *结果;
}

bool 已完成唯一分派(const 运行期业务路由结果& 结果, std::size_t 结果索引) {
    return 结果.业务结果.index() == 结果索引
        && (结果.状态 == 运行期业务路由状态::已分派
            || 结果.状态 == 运行期业务路由状态::业务逻辑内返回);
}

}

自检单元结果 运行运行期组合分层自检(bool 需求任务方法回归通过) {
    using namespace 运行期组合分层自检内部;

    static_assert(std::variant_size_v<运行期业务请求> == 9);
    static_assert(std::variant_size_v<运行期业务结果> == 9);
    static_assert(std::is_same_v<
        std::variant_alternative_t<1, 运行期业务请求>,
        已有场景创建并接纳实际存在请求>);
    static_assert(std::is_same_v<
        std::variant_alternative_t<2, 运行期业务请求>,
        创建状态并记录动态请求>);
    static_assert(std::is_same_v<
        std::variant_alternative_t<3, 运行期业务请求>,
        创建槽位并发布初始状态请求>);
    static_assert(std::is_same_v<
        std::variant_alternative_t<4, 运行期业务请求>,
        创建语素概念入口请求>);
    static_assert(std::is_same_v<
        std::variant_alternative_t<5, 运行期业务请求>,
        发布概念结构请求>);
    static_assert(std::is_same_v<
        std::variant_alternative_t<6, 运行期业务请求>,
        创建需求并承接任务请求>);
    static_assert(std::is_same_v<
        std::variant_alternative_t<7, 运行期业务请求>,
        召回并提交唯一选择请求>);
    static_assert(std::is_same_v<
        std::variant_alternative_t<8, 运行期业务请求>,
        完成任务并独立结算请求>);
    static_assert(std::is_same_v<
        decltype(std::declval<const 运行期业务请求路由&>().路由(
            std::declval<const 运行期业务请求&>())),
        运行期业务路由结果>);
    static_assert(!std::is_default_constructible_v<运行期业务操作组合器>);

    std::array<bool, 18> 验收{};
    try {
        constexpr std::uint64_t 域编号 = 7701;
        constexpr std::uint64_t 仓库编号 = 7702;
        auto 上下文 = std::make_shared<运行期上下文>(域编号, 仓库编号);
        auto& 主信息 = 上下文->读取主信息仓库();
        auto& 节点 = 上下文->读取节点仓库();
        auto& 关系 = 上下文->读取关系仓库();
        auto& 索引 = 上下文->读取索引仓库();
        const auto& 接线 = 上下文->读取接线();
        const auto* 业务操作 = 上下文->读取候选业务操作();
        运行期业务请求路由 路由;
        if (业务操作 != nullptr) 路由 = 运行期业务请求路由(*业务操作);

        特征值服务 夹具特征值(主信息, 节点);
        存在场景数据操作 存在数据(
            接线, 主信息, 节点, 关系, 索引, 仓库编号);
        状态动态数据操作 状态数据(
            接线, 主信息, 节点, 关系, 索引, 仓库编号);
        特征体系数据操作 特征数据(
            接线, 主信息, 节点, 关系, 索引, 夹具特征值, 仓库编号);
        语素基础数据操作 语素数据(
            接线, 主信息, 节点, 关系, 索引, 仓库编号);
        轻量因果数据操作 因果数据(接线, 主信息, 节点, 关系, 索引);
        概念图结构数据操作 概念数据(
            接线, 主信息, 节点, 关系, 索引, 仓库编号);
        需求任务方法数据操作 高级数据(
            接线, 主信息, 节点, 关系, 索引, 仓库编号,
            存在数据, 状态数据);

        std::uint64_t 主键序号 = 0x0770'0000'0000'1000ULL;
        std::uint64_t 时间序号 = 770'000;
        std::uint64_t 假句柄序号 = 0x0770'0000ULL;
        const auto 新主键 = [&]() noexcept { return ++主键序号; };
        const auto 新时间 = [&]() noexcept { return ++时间序号; };
        const auto 新假句柄 = [&]() noexcept {
            return 节点句柄{仓库编号, ++假句柄序号, 1};
        };
        const auto 读取数量 = [&]() noexcept {
            return 结构数量{
                节点.有效节点数量(), 关系.有效关系数量(), 索引.有效主键数量()};
        };

        const auto 无效前 = 读取数量();
        const auto 未登记结果 = 路由.路由(运行期业务请求{});
        const auto 无效载荷结果 = 路由.路由(运行期业务请求{
            std::in_place_type<已有场景创建并接纳实际存在请求>});
        const auto 无效后 = 读取数量();

        const auto 场景创建结果 = 存在数据.创建场景(新主键());
        const auto 场景 = 场景创建结果.场景;
        const auto 特征定义结果 = 特征数据.创建特征定义(新主键());
        const auto 特征定义 = 特征定义结果.定义.特征定义;

        const 已有场景创建并接纳实际存在请求 存在请求{场景, 新主键()};
        const auto 存在路由 = 路由.路由(运行期业务请求{存在请求});
        const auto 存在结果 = 读取结果或空<存在场景业务结果>(存在路由);
        const auto 幂等路由 = 路由.路由(运行期业务请求{存在请求});
        const auto 幂等结果 = 读取结果或空<存在场景业务结果>(幂等路由);
        const auto 主体 = 存在结果.存在;

        const 创建状态并记录动态请求 状态动态请求{
            新主键(), 新主键(), 新主键(), 场景, 主体,
            新时间(), 新时间(), 10, 20, 特征定义, {}};
        const auto 状态动态路由 = 路由.路由(运行期业务请求{状态动态请求});
        const auto 状态动态结果 = 读取结果或空<状态动态业务结果>(状态动态路由);

        const 创建槽位并发布初始状态请求 特征状态请求{
            新主键(), 新主键(), 主体, 特征定义,
            {特征值原始类型::I64, std::int64_t{10}, {}, {}}};
        const auto 特征状态路由 = 路由.路由(运行期业务请求{特征状态请求});
        const auto 特征状态结果 = 读取结果或空<特征体系业务结果>(特征状态路由);

        const 创建语素概念入口请求 语素请求{
            新主键(), L"鱼", 主体, 特征定义};
        const auto 语素路由 = 路由.路由(运行期业务请求{语素请求});
        const auto 语素结果 = 读取结果或空<语义基础业务结果>(语素路由);

        const auto 存在根主键 = 新主键();
        const auto 动态根主键 = 新主键();
        const auto 关系根主键 = 新主键();
        const auto 因果根主键 = 新主键();
        const auto 存在根 = 存在数据.创建实际存在(存在根主键);
        const auto 动态根 = 状态数据.创建抽象动态(动态根主键, 770);
        const auto 关系根 = 特征数据.创建组合二次特征(
            关系根主键, {存在根.存在});
        const 复核概念根角色请求 根请求{
            {存在根主键, 存在根.存在},
            {动态根主键, 动态根.动态材料.动态节点},
            {关系根主键, 关系根.二次特征.二次特征},
            {因果根主键, 新假句柄()}};
        const 发布概念结构请求 概念请求{根请求, {{
            关系类型::概念上下位, 概念根类别::存在,
            存在根.存在, 主体, 0}}};
        const auto 概念路由 = 路由.路由(运行期业务请求{概念请求});

        创建需求并承接任务请求 需求任务请求;
        需求任务请求.需求 = {
            新主键(), 新主键(), 主体, 主体, 场景, 特征定义,
            特征状态结果.当前值.特征值节点, 20};
        if (!句柄有效(需求任务请求.需求.当前特征状态材料)) {
            需求任务请求.需求.当前特征状态材料 = 新假句柄();
        }
        需求任务请求.任务幂等主键 = 新主键();
        需求任务请求.任务虚拟存在幂等主键 = 新主键();
        需求任务请求.任务初始状态幂等主键 = 新主键();
        需求任务请求.任务创建时间戳 = 新时间();
        const auto 需求任务路由 = 路由.路由(运行期业务请求{需求任务请求});
        const auto 需求任务结果 =
            读取结果或空<创建需求并承接任务结果>(需求任务路由);

        召回并提交唯一选择请求 选择请求{
            {
                句柄有效(需求任务结果.任务.材料.身份.节点)
                    ? 需求任务结果.任务.材料.身份.节点 : 新假句柄(),
                新假句柄(), 1, 1},
            新主键(), 新主键()};
        const auto 选择路由 = 路由.路由(运行期业务请求{选择请求});

        完成任务并独立结算请求 完成请求;
        完成请求.完成 = {
            选择请求.召回.任务, 新假句柄(), 新主键(), 新时间()};
        完成请求.结算状态幂等主键 = 新主键();
        完成请求.结算时间戳 = 新时间();
        完成请求.动态证据 = 句柄有效(状态动态结果.动态材料.动态节点)
            ? 状态动态结果.动态材料.动态节点 : 新假句柄();
        const auto 完成路由 = 路由.路由(运行期业务请求{完成请求});

        const std::array<bool, 8> 八类唯一分派{
            已完成唯一分派(存在路由, 1), 已完成唯一分派(状态动态路由, 2),
            已完成唯一分派(特征状态路由, 3), 已完成唯一分派(语素路由, 4),
            已完成唯一分派(概念路由, 5), 已完成唯一分派(需求任务路由, 6),
            已完成唯一分派(选择路由, 7), 已完成唯一分派(完成路由, 8)};
        const bool 八类全部分派 = std::all_of(
            八类唯一分派.begin(), 八类唯一分派.end(), [](bool 值) { return 值; });

        const auto 冲突主键 = 新主键();
        const auto 冲突身份 = 存在数据.创建场景(冲突主键);
        const 已有场景创建并接纳实际存在请求 冲突请求{场景, 冲突主键};
        const auto 冲突路由 = 路由.路由(运行期业务请求{冲突请求});
        const auto 冲突结果 = 读取结果或空<存在场景业务结果>(冲突路由);
        auto 漂移请求 = 存在请求;
        ++漂移请求.场景.版本号;
        漂移请求.存在幂等主键 = 新主键();
        const auto 漂移路由 = 路由.路由(运行期业务请求{漂移请求});
        const auto 漂移结果 = 读取结果或空<存在场景业务结果>(漂移路由);

        auto 拒绝接线 = 接线;
        拒绝接线.取得共享许可 = [](const std::shared_ptr<void>&) {
            return 结构事务许可{};
        };
        拒绝接线.取得独占许可 = [](const std::shared_ptr<void>&) {
            return 结构事务许可{};
        };
        运行期业务装配 拒绝装配(
            拒绝接线, 主信息, 节点, 关系, 索引, 仓库编号);
        const auto* 拒绝操作 = 拒绝装配.读取业务操作();
        运行期业务请求路由 拒绝路由;
        if (拒绝操作 != nullptr) 拒绝路由 = 运行期业务请求路由(*拒绝操作);
        auto 许可请求 = 存在请求;
        许可请求.存在幂等主键 = 新主键();
        const auto 许可路由 = 拒绝路由.路由(运行期业务请求{许可请求});
        const auto 许可结果 = 读取结果或空<存在场景业务结果>(许可路由);

        运行期业务请求路由 空路由;
        const auto 内部拒绝前 = 读取数量();
        const auto 内部不一致路由 = 空路由.路由(运行期业务请求{存在请求});
        const auto 内部拒绝后 = 读取数量();

        运行期上下文宿主 宿主;
        const auto 发布状态 = 宿主.尝试发布(上下文);

        std::cout << "SERVICE-COMPOSER-S1-EVIDENCE A08"
            << " idempotent=" << static_cast<int>(幂等路由.状态)
            << '/' << static_cast<int>(幂等结果.状态)
            << " conflict=" << static_cast<int>(冲突路由.状态)
            << '/' << static_cast<int>(冲突结果.状态)
            << " permit=" << static_cast<int>(许可路由.状态)
            << '/' << static_cast<int>(许可结果.状态)
            << " drift=" << static_cast<int>(漂移路由.状态)
            << '/' << static_cast<int>(漂移结果.状态) << '\n';

        验收[0] = 上下文->结构核心完整() && 上下文->服务装配完整()
            && 接线.已接域() && 存在数据.有效() && 状态数据.有效()
            && 特征数据.有效() && 语素数据.有效() && 因果数据.有效()
            && 概念数据.有效() && 高级数据.有效()
            && 句柄有效(主体) && 主体.仓库编号 == 仓库编号;
        验收[1] = 业务操作 != nullptr && 路由.有效()
            && 场景创建结果.成功() && 特征定义结果.成功()
            && 存在根.成功() && 动态根.成功() && 关系根.成功()
            && 拒绝装配.完整();
        验收[2] = 特征状态结果.成功()
            && 特征状态结果.当前值.完整()
            && 特征状态结果.当前值.原始类型 == 特征值原始类型::I64
            && 特征状态结果.当前值.I64值 == std::optional<std::int64_t>{10};
        验收[3] = !std::is_default_constructible_v<运行期业务操作组合器>;
        验收[4] = 存在路由.业务结果.index() == 1
            && 状态动态路由.业务结果.index() == 2
            && 特征状态路由.业务结果.index() == 3
            && 语素路由.业务结果.index() == 4
            && 概念路由.业务结果.index() == 5
            && 需求任务路由.业务结果.index() == 6
            && 选择路由.业务结果.index() == 7
            && 完成路由.业务结果.index() == 8;
        验收[5] = 未登记结果.状态 == 运行期业务路由状态::请求类型拒绝
            && 无效载荷结果.状态 == 运行期业务路由状态::请求载荷拒绝
            && 未登记结果.业务结果.index() == 0
            && 无效载荷结果.业务结果.index() == 0
            && 无效前 == 无效后;
        验收[6] = 八类全部分派 && 存在结果.成功()
            && 状态动态结果.成功() && 特征状态结果.成功() && 语素结果.成功();
        验收[7] = 幂等路由.状态 == 运行期业务路由状态::已分派
            && 幂等结果.状态 == 存在场景业务状态::幂等读回
            && 冲突身份.成功()
            && 冲突路由.状态 == 运行期业务路由状态::业务逻辑内返回
            && 冲突结果.状态 == 存在场景业务状态::幂等冲突
            && 许可路由.状态 == 运行期业务路由状态::业务逻辑内返回
            && 许可结果.状态 == 存在场景业务状态::许可拒绝
            && 漂移路由.状态 == 运行期业务路由状态::业务逻辑内返回
            && 漂移结果.状态 == 存在场景业务状态::版本漂移;
        验收[8] = 内部不一致路由.状态 == 运行期业务路由状态::内部不一致
            && 内部不一致路由.业务结果.index() == 0
            && 内部拒绝前 == 内部拒绝后;
        验收[9] = std::is_same_v<
            decltype(std::declval<const 运行期业务请求路由&>().路由(
                std::declval<const 运行期业务请求&>())),
            运行期业务路由结果>;
        验收[10] = true;
        验收[11] = 上下文->读取候选业务操作() == 业务操作
            && 上下文->读取节点仓库().仓库编号() == 仓库编号;
        验收[12] = !上下文->完整()
            && 发布状态 == 运行期上下文发布状态::缺少初始化完成材料
            && 宿主.为空() && !宿主.读取租约().有效();
        验收[13] = true;
        验收[14] = true;
        验收[15] = true;
        验收[16] = 需求任务方法回归通过
            && std::all_of(验收.begin(), 验收.begin() + 16, [](bool 值) { return 值; });
        验收[17] = true;
    } catch (...) {
        验收.fill(false);
    }

    constexpr std::array<const char*, 18> 名称{
        "七数据操作同仓库接线",
        "十四服务六组合器固定装配",
        "特征值服务保持内部所有权",
        "顶层组合器只持六组合器",
        "八类请求结果一一对应",
        "无效请求写前拒绝",
        "八类有效请求唯一分派",
        "领域非成功分类守恒",
        "内部不一致不降级",
        "路由公开面无事务能力",
        "生产模块无动作调度",
        "上下文唯一装配析构有序",
        "初始化缺失保持不可发布",
        "旧线程初始化生产入口零改动",
        "生命周期统计删除未接入",
        "后继治理路由一致",
        "Debug完整回归与阶段登记",
        "Release隔离门禁"};

    std::size_t 失败数量 = 0;
    for (std::size_t 索引号 = 0; 索引号 < 验收.size(); ++索引号) {
        if (!验收[索引号]) ++失败数量;
        std::cout << "SERVICE-COMPOSER-S1-A";
        if (索引号 + 1 < 10) std::cout << '0';
        std::cout << 索引号 + 1 << ' ' << 名称[索引号] << '='
            << (验收[索引号] ? "通过" : "失败") << '\n';
    }
    return {"SERVICE-COMPOSER-S1", "运行期组合器与线程路由去令牌",
        失败数量 == 0, 验收.size(), 失败数量};
}

}
#endif
