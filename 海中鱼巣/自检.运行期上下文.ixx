// 文件规则：运行期上下文自检只验证隔离结构核心、宿主与租约骨架；不得制造假服务或生产发布后门。
module;

#include "核心/句柄.h"

#include <array>
#include <cstddef>
#include <memory>
#include <optional>
#include <type_traits>

export module 海中鱼巣.自检.运行期上下文;

import 海中鱼巣.启动.运行期上下文;
import 海中鱼巣.自检.运行器;

export namespace 海中鱼巣 {

自检单元结果 运行运行期上下文自检() {
    std::array<bool, 12> 验收{};
    try {
        auto 上下文 = std::make_shared<运行期上下文>(247, 247);
        const auto& 接线 = 上下文->读取接线();
        验收[0] = 上下文->结构核心完整() && 上下文->服务装配完整()
            && 上下文->读取候选业务操作() != nullptr && !上下文->完整();
        验收[1] = 接线.已接域() && 接线.域编号 == 247 && 接线.运行期纪元 != 0;
        验收[2] = 上下文->读取节点仓库().仓库编号() == 247;

        主信息句柄 主信息;
        节点句柄 节点一;
        节点句柄 节点二;
        关系句柄 关系;
        {
            auto 许可 = 接线.取得共享许可(接线.运行期状态);
            const auto& 令牌 = 许可.读取令牌();
            主信息 = 上下文->读取主信息仓库().创建主信息(令牌);
            节点一 = 上下文->读取节点仓库().创建节点(节点类型::基础信息, 主信息, 令牌);
            const auto 主信息二 = 上下文->读取主信息仓库().创建主信息(令牌);
            节点二 = 上下文->读取节点仓库().创建节点(节点类型::基础信息, 主信息二, 令牌);
            关系 = 上下文->读取关系仓库().创建关系(关系类型::引用, 节点一, 节点二, 0, 令牌);
            验收[3] = 许可.有效() && 句柄有效(主信息) && 句柄有效(节点一)
                && 句柄有效(节点二) && 句柄有效(关系)
                && 上下文->读取索引仓库().绑定主键(24701, 节点一, 令牌);
            验收[4] = 上下文->读取节点仓库().读取节点(节点一, 令牌).has_value()
                && 上下文->读取关系仓库().读取关系(关系, 令牌).has_value()
                && 上下文->读取索引仓库().按主键查节点(24701, 令牌)
                    == std::optional<节点句柄>{节点一};
        }

        运行期上下文宿主 宿主;
        const auto 发布前节点数 = 上下文->读取节点仓库().有效节点数量();
        const auto 发布前关系数 = 上下文->读取关系仓库().有效关系数量();
        const auto 发布前主键数 = 上下文->读取索引仓库().有效主键数量();
        验收[5] = 宿主.为空() && !宿主.读取租约().有效();
        验收[6] = 宿主.尝试发布({}) == 运行期上下文发布状态::无效候选;
        验收[7] = 宿主.尝试发布(上下文)
            == 运行期上下文发布状态::缺少初始化完成材料;
        验收[8] = 宿主.为空() && !宿主.读取租约().有效();
        验收[9] = 发布前节点数 == 上下文->读取节点仓库().有效节点数量()
            && 发布前关系数 == 上下文->读取关系仓库().有效关系数量()
            && 发布前主键数 == 上下文->读取索引仓库().有效主键数量();

        auto 无效上下文 = std::make_shared<运行期上下文>(0, 247);
        验收[10] = !无效上下文->结构核心完整()
            && 宿主.尝试发布(无效上下文) == 运行期上下文发布状态::结构核心不完整;
        验收[11] = !std::is_copy_constructible_v<运行期上下文>
            && !std::is_copy_constructible_v<运行期上下文宿主>
            && std::is_default_constructible_v<运行期上下文租约>;
    } catch (...) {
    }

    std::size_t 失败数量 = 0;
    for (const bool 通过 : 验收) if (!通过) ++失败数量;
    return {"RUNTIME-TXN-S1", "运行期上下文", 失败数量 == 0, 验收.size(), 失败数量};
}

}
