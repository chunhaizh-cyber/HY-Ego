// 文件规则：生产运行期启动只构造完整全新候选、首次发布并持有同身份租约；不得启动消费者或恢复路径。
module;

#include "生产运行期配置.数据.h"

#include <cstdint>
#include <memory>
#include <mutex>
#include <utility>

export module 海中鱼巣.启动.生产运行期;

import 海中鱼巣.启动.运行期上下文;

export namespace 海中鱼巣 {

enum class 生产运行期启动状态 : std::uint8_t {
    未定义 = 0,
    已启动 = 1,
    已有当前上下文 = 2,
    请求拒绝 = 3,
    固定配置错误 = 4,
    系统角色初始化错误 = 5,
    概念活动初始化错误 = 6,
    候选不完整 = 7,
    发布错误 = 8,
    租约不一致 = 9
};

struct 生产运行期启动结果 {
    生产运行期启动状态 状态 = 生产运行期启动状态::未定义;
    系统角色业务状态 系统角色状态 = 系统角色业务状态::入口拒绝;
    概念活动业务状态 概念活动状态 = 概念活动业务状态::入口拒绝;
    运行期上下文发布状态 发布状态 = 运行期上下文发布状态::无效候选;
    运行期上下文租约 租约;

    bool 成功() const {
        return (状态 == 生产运行期启动状态::已启动
                || 状态 == 生产运行期启动状态::已有当前上下文)
            && 租约.有效();
    }
};

class 生产运行期会话 {
public:
    生产运行期会话() = default;
    生产运行期会话(const 生产运行期会话&) = delete;
    生产运行期会话& operator=(const 生产运行期会话&) = delete;

    生产运行期启动结果 启动(const 生产运行期启动请求& 请求) {
        if (!请求.有效()) {
            return {生产运行期启动状态::请求拒绝};
        }

        std::lock_guard<std::mutex> 锁(启动锁_);
        auto 当前租约 = 宿主_.读取租约();
        if (当前租约.有效()) {
            return {
                生产运行期启动状态::已有当前上下文,
                系统角色业务状态::幂等读回,
                概念活动业务状态::幂等读回,
                运行期上下文发布状态::已有当前上下文,
                std::move(当前租约)};
        }

        const auto 配置 = 读取生产运行期固定配置();
        if (!配置.有效()) {
            return {生产运行期启动状态::固定配置错误};
        }

        auto 候选 = std::make_shared<运行期上下文>(配置.域编号, 配置.仓库编号);
        const auto 系统角色结果 = 候选->初始化系统角色(配置.系统角色);
        if (!系统角色结果.成功()) {
            return {
                生产运行期启动状态::系统角色初始化错误,
                系统角色结果.状态};
        }

        const auto 概念活动结果 = 候选->初始化概念活动(配置.概念活动);
        if (!概念活动结果.成功()) {
            return {
                生产运行期启动状态::概念活动初始化错误,
                系统角色结果.状态,
                概念活动结果.状态};
        }
        if (!候选->完整()) {
            return {
                生产运行期启动状态::候选不完整,
                系统角色结果.状态,
                概念活动结果.状态};
        }

        const auto 发布状态 = 宿主_.尝试首次发布全新上下文(候选);
        if (发布状态 != 运行期上下文发布状态::已发布
            && 发布状态 != 运行期上下文发布状态::已有当前上下文) {
            return {
                生产运行期启动状态::发布错误,
                系统角色结果.状态,
                概念活动结果.状态,
                发布状态};
        }

        当前租约 = 宿主_.读取租约();
        if (!当前租约.有效()
            || (发布状态 == 运行期上下文发布状态::已发布
                && 当前租约.读取() != 候选.get())) {
            return {
                生产运行期启动状态::租约不一致,
                系统角色结果.状态,
                概念活动结果.状态,
                发布状态,
                std::move(当前租约)};
        }

        return {
            发布状态 == 运行期上下文发布状态::已发布
                ? 生产运行期启动状态::已启动
                : 生产运行期启动状态::已有当前上下文,
            系统角色结果.状态,
            概念活动结果.状态,
            发布状态,
            std::move(当前租约)};
    }

    运行期上下文租约 读取租约() const {
        return 宿主_.读取租约();
    }

private:
    std::mutex 启动锁_;
    运行期上下文宿主 宿主_;
};

}
