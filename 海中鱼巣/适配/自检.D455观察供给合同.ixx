// 文件规则：D455 观察供给合同自检只构造隔离值式材料；不得访问 SDK、缓存、队列、任务、方法、仓库或领域服务。
module;

#include <array>
#include <cstddef>
#include <cstdint>
#include <iostream>
#include <type_traits>
#include <utility>

export module 海中鱼巣.适配.自检.D455观察供给合同;
import 海中鱼巣.适配.协议.D455采样材料;
import 海中鱼巣.适配.协议.D455观察供给;
import 海中鱼巣.自检.运行器;

namespace 海中鱼巣 {
namespace {

constexpr std::uint64_t 自检当前时间 = 150;

D455受控材料引用 生成引用(D455材料种类 种类, std::uint64_t 编号) {
    return {1, 编号, 1, 种类, 10 + 编号, 1000 + 编号};
}

D455观察范围材料 生成范围(bool 携带目标 = false) {
    D455观察范围材料 范围;
    范围.范围编号 = 1;
    范围.版本 = 1;
    范围.坐标系 = D455坐标系类型::深度相机;
    范围.坐标系版本 = 7;
    范围.来源宽 = 640;
    范围.来源高 = 480;
    范围.左上横坐标 = 10;
    范围.左上纵坐标 = 20;
    范围.宽 = 320;
    范围.高 = 240;
    if (携带目标) {
        范围.目标约束 = D455目标约束引用{900, 1};
    }
    return 范围;
}

D455局部质量材料 生成稳定质量(std::uint64_t 编号 = 70) {
    D455局部质量材料 质量;
    质量.局部对象引用 = 生成引用(D455材料种类::簇掩码, 编号);
    质量.特征类型 = D455材料特征类型::深度有效率;
    质量.质量等级 = D455局部质量等级::稳定可用;
    质量.量化值 = 0.95;
    质量.阈值来源 = 1;
    质量.规则版本 = 1;
    质量.来源材料引用组 = {生成引用(D455材料种类::原始深度, 编号 + 100)};
    质量.用途限制 = D455用途限制::可进入稳定门;
    return 质量;
}

D455局部质量材料 生成不可得质量(std::uint64_t 编号 = 80) {
    auto 质量 = 生成稳定质量(编号);
    质量.质量等级 = D455局部质量等级::不可得;
    质量.量化值.reset();
    质量.用途限制 = D455用途限制::只作诊断;
    质量.不可得原因 = D455不可得原因::深度无效;
    return 质量;
}

D455观察供给产品头 生成产品头(
    D455逻辑供给产品类型 产品类型,
    D455观察运行模式 模式,
    D455材料成熟度 成熟度,
    std::uint64_t 编号) {
    D455观察供给产品头 头;
    头.产品身份 = {编号, 1, 1};
    头.合同内容版本 = D455观察供给协议版本;
    头.来源外设身份 = {"Intel RealSense D455", "SIM-DD01", "1.0", "0B5C"};
    头.等待项 = {编号 + 1000, 1};
    头.运行模式 = 模式;
    头.产品类型 = 产品类型;
    头.成熟度 = 成熟度;
    头.来源材料引用组 = {生成引用(D455材料种类::同步帧, 编号 + 2000)};
    头.观察范围 = 生成范围();
    头.时间窗口 = {100, 110, 120, 100};
    头.配置版本 = 1;
    头.质量规则版本 = 1;
    头.整体供料结果 = D455整体供料结果::有可交付负载;
    头.权威性 = D455材料权威性::外设非权威材料;
    return 头;
}

D455L0原始材料 生成L0材料() {
    D455L0原始材料 材料;
    材料.同步帧引用 = 生成引用(D455材料种类::同步帧, 1);
    材料.彩色引用 = 生成引用(D455材料种类::原始彩色, 2);
    材料.深度引用 = 生成引用(D455材料种类::原始深度, 3);
    材料.左红外引用 = 生成引用(D455材料种类::原始红外, 4);
    材料.右红外引用 = 生成引用(D455材料种类::原始红外, 5);
    材料.点云.单位米 = 0.001;
    材料.点云.参考坐标系 = D455坐标系类型::深度相机;
    材料.点云.坐标系版本 = 1;
    材料.点云.总点数 = 100;
    材料.点云.有效点数 = 90;
    材料.点云.点云引用 = 生成引用(D455材料种类::点云, 6);
    材料.点云.有效点掩码引用 = 生成引用(D455材料种类::有效掩码, 7);
    材料.点云.来源深度引用 = 材料.深度引用;
    材料.点云.派生规则版本 = 1;
    材料.有效深度掩码引用 = 生成引用(D455材料种类::有效掩码, 8);
    材料.RGBD对齐 = D455对齐状态::已对齐;
    材料.标定版本 = 1;
    材料.位姿版本 = 1;
    材料.直接来源引用组 = {材料.同步帧引用, 材料.深度引用};
    return 材料;
}

D455L1单轮材料 生成L1材料() {
    D455L1单轮材料 材料;
    材料.来源L0引用 = 生成引用(D455材料种类::L0成熟材料, 20);
    材料.校正规则版本 = 1;
    材料.对齐规则版本 = 1;
    材料.滤波规则版本 = 1;
    材料.分割规则版本 = 1;
    D455观察簇材料 簇;
    簇.簇编号 = 1;
    簇.簇掩码引用 = 生成引用(D455材料种类::簇掩码, 21);
    簇.平面轮廓引用 = 生成引用(D455材料种类::平面轮廓, 22);
    簇.彩色局部图引用 = 生成引用(D455材料种类::彩色局部图, 23);
    簇.深度局部图引用 = 生成引用(D455材料种类::深度局部图, 24);
    簇.范围 = 生成范围();
    簇.局部质量组 = {生成稳定质量(25)};
    材料.簇组 = {std::move(簇)};
    return 材料;
}

D455L2跨轮材料 生成L2材料() {
    D455L2跨轮材料 材料;
    材料.来源L1引用 = 生成引用(D455材料种类::L1单轮材料, 30);
    材料.参与轮次引用组 = {
        生成引用(D455材料种类::L1单轮材料, 31),
        生成引用(D455材料种类::L1单轮材料, 32)};
    材料.最早参与时间 = 100;
    材料.最晚参与时间 = 110;
    材料.跨轮关联引用 = 生成引用(D455材料种类::跨轮关联材料, 33);
    材料.外设内部轨迹号 = 1;
    材料.生产者世代 = 1;
    材料.连续命中次数 = 2;
    材料.缺失次数 = 0;
    材料.复现离散度 = 0.05;
    材料.稳定性评分 = 0.95;
    材料.局部质量组 = {生成稳定质量(34)};
    return 材料;
}

D455L3稳定门证据 生成L3证据() {
    D455L3稳定门证据 证据;
    证据.来源L2引用 = 生成引用(D455材料种类::L2跨轮材料, 40);
    证据.稳定规则版本 = 1;
    证据.阈值来源 = 1;
    证据.输入版本 = 1;
    for (std::uint8_t 数值 = 1; 数值 <= 9; ++数值) {
        D455L3门项证据 门项;
        门项.门项类型 = static_cast<D455L3门项类型>(数值);
        门项.状态 = D455门项状态::通过;
        门项.阈值来源 = 100 + 数值;
        门项.规则版本 = 1;
        门项.输入版本 = 1;
        门项.证据引用组 = {生成引用(D455材料种类::稳定性材料, 40 + 数值)};
        证据.门项组.push_back(std::move(门项));
    }
    证据.局部质量组 = {生成稳定质量(55)};
    return 证据;
}

D455原始逐簇报告 生成原始报告() {
    D455原始逐簇报告 报告;
    报告.头 = 生成产品头(
        D455逻辑供给产品类型::原始逐簇报告,
        D455观察运行模式::逐簇识别,
        D455材料成熟度::L2跨轮关联,
        100);
    报告.L0来源引用 = 生成引用(D455材料种类::L0成熟材料, 101);
    报告.L1来源引用 = 生成引用(D455材料种类::L1单轮材料, 102);
    报告.L2来源引用 = 生成引用(D455材料种类::L2跨轮材料, 103);
    报告.簇引用组 = {生成引用(D455材料种类::簇掩码, 104)};
    报告.局部质量组 = {生成稳定质量(105)};
    return 报告;
}

D455稳定观察子集报告 生成稳定报告() {
    D455稳定观察子集报告 报告;
    报告.头 = 生成产品头(
        D455逻辑供给产品类型::稳定观察子集报告,
        D455观察运行模式::逐簇识别,
        D455材料成熟度::L3稳定可交付,
        200);
    报告.来源原始产品身份 = {100, 1, 1};
    报告.来源原始产品引用 = 生成引用(D455材料种类::观察供给产品, 201);
    报告.L3稳定门 = 生成L3证据();
    报告.稳定簇引用组 = {生成引用(D455材料种类::簇掩码, 202)};
    报告.局部质量组 = {生成稳定质量(203)};
    return 报告;
}

D455扫描变化报告 生成扫描报告() {
    D455扫描变化报告 报告;
    报告.头 = 生成产品头(
        D455逻辑供给产品类型::扫描变化报告,
        D455观察运行模式::扫描变化,
        D455材料成熟度::L3稳定可交付,
        300);
    报告.可比基准引用 = 生成引用(D455材料种类::基准材料, 301);
    报告.基准版本 = 1;
    报告.当前L3来源引用 = 生成引用(D455材料种类::L3稳定材料, 302);
    报告.局部质量组 = {生成稳定质量(303)};
    报告.比较规则版本 = 1;
    return 报告;
}

D455目标跟踪报告 生成跟踪丢失报告() {
    D455目标跟踪报告 报告;
    报告.头 = 生成产品头(
        D455逻辑供给产品类型::目标跟踪报告,
        D455观察运行模式::目标跟踪,
        D455材料成熟度::L3稳定可交付,
        400);
    报告.目标约束 = {900, 1};
    报告.观察窗口 = 生成范围(true);
    报告.当前L3来源引用 = 生成引用(D455材料种类::L3稳定材料, 401);
    报告.跟踪状态 = D455跟踪状态::丢失;
    报告.最近观测年龄 = 5;
    报告.特征复现离散度 = 0.2;
    报告.丢失原因 = D455不可得原因::质量不足;
    报告.重捕获候选引用组 = {生成引用(D455材料种类::稳定性材料, 402)};
    报告.局部质量组 = {生成不可得质量(403)};
    return 报告;
}

bool 是逻辑内拒绝(const D455合同验证结果& 结果) {
    return 结果.分类 == D455合同结果分类::逻辑内拒绝 && 结果.原因 != D455合同原因::无;
}

bool 是内部逻辑错误(const D455合同验证结果& 结果) {
    return 结果.分类 == D455合同结果分类::内部逻辑错误 && 结果.原因 != D455合同原因::无;
}

}

export 自检单元结果 运行D455观察供给合同自检() {
    std::array<bool, 12> 验收{};

    static_assert(!std::is_same_v<D455材料成熟度, D455观察运行模式>);
    static_assert(!std::is_same_v<D455观察运行模式, D455逻辑供给产品类型>);
    static_assert(!std::is_same_v<D455材料成熟度, D455逻辑供给产品类型>);
    验收[0] = D455观察供给协议版本 == 1;

    const auto 原始报告 = 生成原始报告();
    const auto 稳定报告 = 生成稳定报告();
    const auto 扫描报告 = 生成扫描报告();
    const auto 跟踪报告 = 生成跟踪丢失报告();
    static constexpr std::array 模式组{
        D455观察运行模式::未知,
        D455观察运行模式::逐簇识别,
        D455观察运行模式::扫描变化,
        D455观察运行模式::目标跟踪};
    static constexpr std::array 成熟度组{
        D455材料成熟度::未知,
        D455材料成熟度::L0原始,
        D455材料成熟度::L1单轮处理,
        D455材料成熟度::L2跨轮关联,
        D455材料成熟度::L3稳定可交付};
    bool 组合矩阵通过 = true;
    for (const auto 模式 : 模式组) {
        for (const auto 成熟度 : 成熟度组) {
            auto 待验原始报告 = 原始报告;
            待验原始报告.头.运行模式 = 模式;
            待验原始报告.头.成熟度 = 成熟度;
            if (成熟度 == D455材料成熟度::L0原始) {
                待验原始报告.L1来源引用.reset();
                待验原始报告.L2来源引用.reset();
            }
            else if (成熟度 == D455材料成熟度::L1单轮处理) {
                待验原始报告.L2来源引用.reset();
            }
            const bool 原始组合应有效 = 模式 == D455观察运行模式::逐簇识别
                && (成熟度 == D455材料成熟度::L0原始
                    || 成熟度 == D455材料成熟度::L1单轮处理
                    || 成熟度 == D455材料成熟度::L2跨轮关联);
            组合矩阵通过 = 组合矩阵通过
                && 验证D455原始逐簇报告(待验原始报告, 自检当前时间).有效() == 原始组合应有效;

            auto 待验稳定报告 = 稳定报告;
            待验稳定报告.头.运行模式 = 模式;
            待验稳定报告.头.成熟度 = 成熟度;
            const bool 稳定组合应有效 = 模式 == D455观察运行模式::逐簇识别
                && 成熟度 == D455材料成熟度::L3稳定可交付;
            组合矩阵通过 = 组合矩阵通过
                && 验证D455稳定观察子集报告(待验稳定报告, 自检当前时间).有效() == 稳定组合应有效;

            auto 待验扫描报告 = 扫描报告;
            待验扫描报告.头.运行模式 = 模式;
            待验扫描报告.头.成熟度 = 成熟度;
            const bool 扫描组合应有效 = 模式 == D455观察运行模式::扫描变化
                && 成熟度 == D455材料成熟度::L3稳定可交付;
            组合矩阵通过 = 组合矩阵通过
                && 验证D455扫描变化报告(待验扫描报告, 自检当前时间).有效() == 扫描组合应有效;

            auto 待验跟踪报告 = 跟踪报告;
            待验跟踪报告.头.运行模式 = 模式;
            待验跟踪报告.头.成熟度 = 成熟度;
            const bool 跟踪组合应有效 = 模式 == D455观察运行模式::目标跟踪
                && 成熟度 == D455材料成熟度::L3稳定可交付;
            组合矩阵通过 = 组合矩阵通过
                && 验证D455目标跟踪报告(待验跟踪报告, 自检当前时间).有效() == 跟踪组合应有效;
        }
    }
    验收[1] = 组合矩阵通过;

    验收[2] = 验证D455L0原始材料(生成L0材料()).有效();

    auto 缺L1原始报告 = 原始报告;
    缺L1原始报告.L1来源引用.reset();
    auto 缺L2原始报告 = 原始报告;
    缺L2原始报告.L2来源引用.reset();
    验收[3] = 验证D455L1单轮材料(生成L1材料()).有效()
        && 验证D455L2跨轮材料(生成L2材料()).有效()
        && 是逻辑内拒绝(验证D455原始逐簇报告(缺L1原始报告, 自检当前时间))
        && 是逻辑内拒绝(验证D455原始逐簇报告(缺L2原始报告, 自检当前时间));

    auto 缺阈值L3 = 生成L3证据();
    缺阈值L3.门项组.front().阈值来源 = 0;
    验收[4] = 验证D455L3稳定门证据(生成L3证据()).有效()
        && 是内部逻辑错误(验证D455L3稳定门证据(缺阈值L3));

    static_assert(std::is_same_v<decltype(D455稳定观察子集报告{}.来源原始产品引用), D455受控材料引用>);
    验收[5] = 验证D455稳定观察子集报告(稳定报告, 自检当前时间).有效()
        && 稳定报告.来源原始产品引用.材料种类 == D455材料种类::观察供给产品;

    auto 无基准扫描 = 扫描报告;
    无基准扫描.可比基准引用 = {};
    const auto 无基准结果 = 验证D455扫描变化报告(无基准扫描, 自检当前时间);
    验收[6] = 是逻辑内拒绝(无基准结果)
        && 无基准结果.原因 == D455合同原因::扫描无可比基准;

    auto 无目标跟踪 = 跟踪报告;
    无目标跟踪.目标约束 = {};
    auto 无窗口跟踪 = 跟踪报告;
    无窗口跟踪.观察窗口.宽 = 0;
    验收[7] = 是逻辑内拒绝(验证D455目标跟踪报告(无目标跟踪, 自检当前时间))
        && 是逻辑内拒绝(验证D455目标跟踪报告(无窗口跟踪, 自检当前时间))
        && 验证D455目标跟踪报告(跟踪报告, 自检当前时间).有效()
        && !跟踪报告.新空间坐标.has_value();

    auto 不可得却填值 = 生成不可得质量();
    不可得却填值.量化值 = 0.0;
    auto 缺局部质量稳定报告 = 稳定报告;
    缺局部质量稳定报告.局部质量组.clear();
    验收[8] = 验证D455局部质量材料(生成不可得质量()).有效()
        && 是逻辑内拒绝(验证D455局部质量材料(不可得却填值))
        && 是逻辑内拒绝(验证D455稳定观察子集报告(缺局部质量稳定报告, 自检当前时间));

    auto 过期报告 = 原始报告;
    过期报告.头.时间窗口.最大允许年龄 = 5;
    auto 时间倒置报告 = 原始报告;
    时间倒置报告.头.时间窗口.最早来源时间 = 130;
    auto 范围无效报告 = 原始报告;
    范围无效报告.头.观察范围.宽 = 0;
    auto 来源自循环报告 = 原始报告;
    来源自循环报告.头.来源材料引用组.push_back(来源自循环报告.头.来源材料引用组.front());
    auto 版本错误报告 = 原始报告;
    版本错误报告.头.合同内容版本 = D455观察供给协议版本 + 1;
    验收[9] = 是逻辑内拒绝(验证D455原始逐簇报告(过期报告, 自检当前时间))
        && 是逻辑内拒绝(验证D455原始逐簇报告(时间倒置报告, 自检当前时间))
        && 是逻辑内拒绝(验证D455原始逐簇报告(范围无效报告, 自检当前时间))
        && 是内部逻辑错误(验证D455原始逐簇报告(来源自循环报告, 自检当前时间))
        && 是逻辑内拒绝(验证D455原始逐簇报告(版本错误报告, 自检当前时间));

    auto 负载字段矛盾 = 原始报告;
    负载字段矛盾.头.产品类型 = D455逻辑供给产品类型::稳定观察子集报告;
    验收[10] = 原始报告.头.权威性 == D455材料权威性::外设非权威材料
        && 稳定报告.头.权威性 == D455材料权威性::外设非权威材料
        && 是内部逻辑错误(验证D455观察供给产品({负载字段矛盾}, 自检当前时间));

    验收[11] = D455采样材料协议版本 == 1
        && std::is_copy_constructible_v<D455同步帧材料>
        && std::is_copy_constructible_v<D455观察供给产品>;

    static constexpr std::array<const char*, 12> 名称组{
        "成熟度模式产品三轴独立",
        "四类合法组合与非法组合",
        "L0来源点云掩码坐标闭合",
        "L1与L2不得冒充后续成熟度",
        "L3阈值规则输入局部质量证据",
        "稳定子集只引用原始产品",
        "扫描无基准不形成变化",
        "跟踪目标窗口与丢失空坐标",
        "局部不可得不填默认值",
        "时效范围来源与版本拒绝",
        "非权威材料与负载矛盾分流",
        "既有D455采样合同保持独立"
    };
    std::size_t 失败数量 = 0;
    for (std::size_t 索引 = 0; 索引 < 验收.size(); ++索引) {
        std::cout << "DD01-A" << (索引 < 9 ? "0" : "") << (索引 + 1)
            << ' ' << 名称组[索引] << ": " << (验收[索引] ? "通过" : "失败") << '\n';
        失败数量 += static_cast<std::size_t>(!验收[索引]);
    }
    return {"D455-DD01", "D455 材料成熟度与四类产品数据合同", 失败数量 == 0, 验收.size(), 失败数量};
}

}
