// 文件规则：状态动态组合器只编排两个状态规格和一次动态提交，不接触仓库或事务能力。
module;

#include "../核心/句柄.h"

#include <cstddef>
#include <cstdint>

export module 海中鱼巣.领域.组合.状态动态;

import 海中鱼巣.领域.数据操作.状态动态;
import 海中鱼巣.领域.服务.状态;

export namespace 海中鱼巣 {

struct 创建状态并记录动态请求 {
    std::uint64_t 前状态幂等主键 = 0;
    std::uint64_t 后状态幂等主键 = 0;
    std::uint64_t 动态幂等主键 = 0;
    节点句柄 场景;
    节点句柄 主体;
    std::uint64_t 前时间戳 = 0;
    std::uint64_t 后时间戳 = 0;
    std::int64_t 前状态值 = 0;
    std::int64_t 后状态值 = 0;
    节点句柄 被改变目标;
    节点句柄 来源动作;
};

struct 使用已有前状态记录动态请求 {
    节点句柄 前状态;
    std::uint64_t 后状态幂等主键 = 0;
    std::uint64_t 动态幂等主键 = 0;
    std::uint64_t 后时间戳 = 0;
    std::int64_t 后状态值 = 0;
    节点句柄 被改变目标;
    节点句柄 来源动作;
};

class 状态动态组合器 final {
public:
    状态动态组合器(状态业务服务& 状态服务, 状态动态数据操作& 数据操作)
        : 状态服务_(状态服务), 数据操作_(数据操作) {
    }

    状态动态业务结果 创建状态并记录动态(
        const 创建状态并记录动态请求& 请求) const {
        if (请求.前状态幂等主键 == 0 || 请求.后状态幂等主键 == 0
            || 请求.动态幂等主键 == 0
            || 请求.前状态幂等主键 == 请求.后状态幂等主键
            || 请求.前状态幂等主键 == 请求.动态幂等主键
            || 请求.后状态幂等主键 == 请求.动态幂等主键
            || !句柄有效(请求.场景) || !句柄有效(请求.主体)
            || !句柄有效(请求.被改变目标)
            || 请求.前时间戳 == 0 || 请求.后时间戳 == 0
            || 请求.前时间戳 > 请求.后时间戳) return {};

        const 创建实例状态请求 前请求{
            请求.前状态幂等主键, 请求.场景, 请求.主体,
            请求.前时间戳, 请求.前状态值};
        const 创建实例状态请求 后请求{
            请求.后状态幂等主键, 请求.场景, 请求.主体,
            请求.后时间戳, 请求.后状态值};
        const auto 前规格 = 状态服务_.形成实例状态写入规格(前请求);
        const auto 后规格 = 状态服务_.形成实例状态写入规格(后请求);
        if (!前规格.成功()) return 映射规格失败(前规格.状态);
        if (!后规格.成功()) return 映射规格失败(后规格.状态);
        return 数据操作_.创建状态并记录动态(
            *前规格.规格, *后规格.规格, 请求.动态幂等主键,
            请求.被改变目标, 请求.来源动作);
    }

    状态动态业务结果 使用已有前状态创建后状态并记录动态(
        const 使用已有前状态记录动态请求& 请求) const {
        if (!句柄有效(请求.前状态) || 请求.后状态幂等主键 == 0
            || 请求.动态幂等主键 == 0
            || 请求.后状态幂等主键 == 请求.动态幂等主键
            || 请求.后时间戳 == 0 || !句柄有效(请求.被改变目标)) return {};
        const auto 前材料 = 状态服务_.读取状态材料(请求.前状态);
        if (!前材料.完整实例状态()
            || 前材料.发生时间戳 > 请求.后时间戳) return {};
        const 创建实例状态请求 后请求{
            请求.后状态幂等主键, 前材料.场景, 前材料.主体,
            请求.后时间戳, 请求.后状态值};
        const auto 后规格 = 状态服务_.形成实例状态写入规格(后请求);
        if (!后规格.成功()) return 映射规格失败(后规格.状态);
        return 数据操作_.使用已有前状态创建后状态并记录动态(
            请求.前状态, *后规格.规格, 请求.动态幂等主键,
            请求.被改变目标, 请求.来源动作);
    }

#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
    状态动态故障自检结果 执行已有前状态固定故障自检(
        const 使用已有前状态记录动态请求& 请求,
        std::size_t 故障写点) const {
        if (!句柄有效(请求.前状态) || 请求.后状态幂等主键 == 0
            || 请求.动态幂等主键 == 0
            || 请求.后状态幂等主键 == 请求.动态幂等主键
            || 请求.后时间戳 == 0 || !句柄有效(请求.被改变目标)) return {};
        const auto 前材料 = 状态服务_.读取状态材料(请求.前状态);
        if (!前材料.完整实例状态()
            || 前材料.发生时间戳 > 请求.后时间戳) return {};
        const 创建实例状态请求 后请求{
            请求.后状态幂等主键, 前材料.场景, 前材料.主体,
            请求.后时间戳, 请求.后状态值};
        const auto 后规格 = 状态服务_.形成实例状态写入规格(后请求);
        if (!后规格.成功()) return {};
        return 数据操作_.执行已有前状态固定故障自检(
            请求.前状态, *后规格.规格, 请求.动态幂等主键,
            请求.被改变目标, 请求.来源动作, 故障写点);
    }
#endif

private:
    static 状态动态业务结果 映射规格失败(实例状态规格状态 状态) noexcept {
        switch (状态) {
        case 实例状态规格状态::许可拒绝:
            return {状态动态业务状态::许可拒绝};
        case 实例状态规格状态::版本漂移:
            return {状态动态业务状态::版本漂移};
        case 实例状态规格状态::内部不一致:
            return {状态动态业务状态::内部不一致};
        default:
            return {状态动态业务状态::入口拒绝};
        }
    }

    状态业务服务& 状态服务_;
    状态动态数据操作& 数据操作_;
};

}
