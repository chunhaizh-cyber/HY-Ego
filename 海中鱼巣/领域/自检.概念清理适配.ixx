// 文件规则：概念清理适配自检只承载隔离准备包验收，不得获得私有提交友元或写生产事实。
module;

#include "../核心/主信息仓库.h"
#include "../核心/节点仓库.h"
#include "../核心/关系仓库.h"
#include "../核心/索引仓库.h"
#include "存在服务.h"
#include "动态服务.h"
#include "二次特征服务.h"
#include "因果服务.h"
#include "概念图服务.h"
#include "统计服务.h"

#include <array>
#include <cstddef>
#include <limits>
#include <optional>
#include <type_traits>
#include <vector>

export module 海中鱼巣.领域.自检.概念清理适配;

import 海中鱼巣.核心.协调.结构事务;
import 海中鱼巣.自检.运行器;

export namespace 海中鱼巣 {

namespace 概念清理适配自检细节 {

概念结构写集已补全候选 生成完整值式样本() {
    const auto 节点 = [](std::uint64_t 编号) { return 节点句柄{1, 编号, 1}; };
    const auto 主信息 = [](std::uint64_t 编号) { return 主信息句柄{1, 编号, 1}; };
    const auto 关系 = [](std::uint64_t 编号) { return 关系句柄{1, 编号, 1}; };
    const 节点句柄 目标 = 节点(10);
    const 主信息句柄 目标主信息 = 主信息(10);
    const std::array 根组{节点(1), 节点(2), 节点(3), 节点(4)};
    const std::array 类别组{概念根类别::存在, 概念根类别::动态, 概念根类别::关系, 概念根类别::因果};

    概念删除影响候选 候选;
    候选.完备阶段 = 删除候选完备阶段::领域影响已形成;
    候选.基准活动版本 = 8;
    候选.目标概念 = 目标;
    候选.根类别 = 概念根类别::存在;
    候选.目标节点记录 = {目标.节点编号, 节点类型::存在, 目标主信息, 1, 记录状态::有效, 1};
    候选.目标主信息 = 目标主信息;
    候选.目标生命周期 = {目标, 概念生命周期阶段::退役, 节点(30), 关系(30)};
    候选.当前相关有效关系组.push_back({30, 关系类型::概念生命周期, 目标, 节点(30), 0, 1, 记录状态::有效});
    候选.受影响分量.push_back(目标);
    候选.完整当前输入.活动版本 = 8;
    候选.完整当前输入.根组.assign(根组.begin(), 根组.end());
    for (std::size_t 索引 = 0; 索引 < 根组.size(); ++索引) {
        候选.完整当前输入.签名组.push_back({根组[索引], {类别组[索引], 1, {}}});
        候选.完整当前输入.生命周期组.push_back({根组[索引], 概念生命周期阶段::活跃, 节点(40 + 索引), 关系(40 + 索引)});
    }
    概念约束材料 目标约束;
    目标约束.维度 = 概念约束维度::特征原始值;
    目标约束.定义节点 = 节点(60);
    目标约束.值类型 = 概念约束值类型::I64;
    目标约束.I64值 = 7;
    候选.完整当前输入.签名组.push_back({目标, {概念根类别::存在, 1, {目标约束}}});
    候选.完整当前输入.生命周期组.push_back(候选.目标生命周期);
    候选.完整剩余签名组.assign(
        候选.完整当前输入.签名组.begin(),
        候选.完整当前输入.签名组.begin() + 4);
    for (std::size_t 索引 = 0; 索引 < 根组.size(); ++索引) {
        候选.删除后根可达摘要组.push_back({类别组[索引], 根组[索引], 1});
    }
    候选.待补全结构所有者组 = {
        概念删除待补全结构所有者::索引反查,
        概念删除待补全结构所有者::存在服务,
        概念删除待补全结构所有者::概念图登记,
        概念删除待补全结构所有者::统计缓存};

    constexpr std::uint64_t 写集 = 9;
    节点删除准备包 节点包{目标, 目标主信息, 1, 写集};
    主信息删除准备包 主信息包{目标, 目标主信息, 1, 写集};
    节点关系失效准备包 关系包{目标, 候选.当前相关有效关系组, 写集};
    节点主键删除准备包 索引包{目标, {7001}, 写集};
    概念结构所有者清理授权 授权{目标, 目标主信息, 概念结构所有者类型::存在服务, 写集};
    概念图清理准备包 概念图包{目标, 8, 9, 关系(30), {}, 候选.完整剩余签名组, {}, 写集};
    概念缓存清理准备包 缓存包{目标, {}, 写集};
    return {删除候选完备阶段::结构写集已补全, 候选, 节点包, 主信息包, 关系包,
        索引包, 授权, 概念图包, 缓存包};
}

}

自检单元结果 运行概念清理适配自检() {
    std::array<bool, 12> 验收{};
    try {
        结构事务协调器 协调器(82);
        const auto 接线 = 协调器.生成接线();
        主信息仓库 主信息(182, 接线);
        节点仓库 节点(主信息, 282, 接线);
        关系仓库 关系(节点, 382, 接线);
        索引仓库 索引(节点, 接线);
        存在服务 存在(主信息, 节点, 关系);
        动态服务 动态(主信息, 节点, 关系);
        二次特征服务 二次特征(主信息, 节点, 关系);
        因果服务 因果(主信息, 节点);
        统计服务 统计;

        节点句柄 目标;
        主信息句柄 目标主信息;
        节点句柄 对端;
        关系句柄 目标关系;
        std::array<节点句柄, 4> 所有者节点组{};
        std::array<主信息句柄, 4> 所有者主信息组{};
        {
            auto 许可 = 接线.取得共享许可(接线.运行期状态);
            const auto& 令牌 = 许可.读取令牌();
            目标主信息 = 主信息.创建主信息(令牌);
            目标 = 节点.创建节点(节点类型::存在, 目标主信息, 令牌);
            const auto 对端主信息 = 主信息.创建主信息(令牌);
            对端 = 节点.创建节点(节点类型::特征, 对端主信息, 令牌);
            目标关系 = 关系.创建关系(关系类型::引用, 目标, 对端, 0, 令牌);
            索引.绑定主键(8201, 目标, 令牌);
            索引.绑定主键(8202, 目标, 令牌);
            const std::array 类型组{节点类型::存在, 节点类型::动态, 节点类型::二次特征, 节点类型::因果引用};
            for (std::size_t 索引号 = 0; 索引号 < 类型组.size(); ++索引号) {
                所有者主信息组[索引号] = 主信息.创建主信息(令牌);
                所有者节点组[索引号] = 节点.创建节点(类型组[索引号], 所有者主信息组[索引号], 令牌);
            }
        }

        {
            auto 许可 = 接线.取得共享许可(接线.运行期状态);
            验收[1] = 索引.读取节点主键组(目标, 许可.读取令牌()) == std::vector<std::uint64_t>({8201, 8202})
                && 索引.删除主键(8202, 许可.读取令牌())
                && 索引.读取节点主键组(目标, 许可.读取令牌()) == std::vector<std::uint64_t>({8201});
        }

        const auto 缓存命名空间 = 统计.定义缓存命名空间(
            缓存类型::概念用途观察, 来源结构类型::概念, 8, 1,
            缓存值类型::用途观察, false, 缓存失效条件::规则版本变化);
        const auto 缓存记录 = 统计.记录概念用途观察(缓存命名空间, 目标, 概念用途类型::一般, 1, 0);
        const std::array 前数量{节点.有效节点数量(), 关系.有效关系数量(), 索引.有效主键数量()};

        std::optional<节点删除准备包> 节点包;
        std::optional<主信息删除准备包> 主信息包;
        std::optional<节点关系失效准备包> 关系包;
        std::optional<节点主键删除准备包> 索引包;
        std::optional<概念缓存清理准备包> 缓存包;
        std::array<std::optional<概念结构所有者清理授权>, 4> 授权组;
        {
            auto 许可 = 接线.取得独占许可(接线.运行期状态);
            const auto& 令牌 = 许可.读取令牌();
            const auto 当前关系 = 关系.获取节点相关关系记录组(目标, 令牌);
            const auto 当前主键 = 索引.读取节点主键组(目标, 令牌);
            节点包 = 节点.准备节点删除包(目标, 令牌);
            主信息包 = 主信息.准备主信息删除包(目标, 目标主信息, 令牌);
            关系包 = 关系.准备节点关系失效包(目标, 当前关系, 令牌);
            索引包 = 索引.准备节点主键删除包(目标, 当前主键, 令牌);
            缓存包 = 统计.准备概念缓存清理包(目标, 令牌);
            const std::array 所有者组{概念结构所有者类型::存在服务, 概念结构所有者类型::动态服务,
                概念结构所有者类型::二次特征服务, 概念结构所有者类型::因果服务};
            for (std::size_t 索引号 = 0; 索引号 < 所有者组.size(); ++索引号) {
                const 概念结构所有者清理请求 请求{所有者节点组[索引号], 所有者主信息组[索引号], 所有者组[索引号], true, true};
                授权组[索引号] = 索引号 == 0 ? 存在.形成概念节点清理授权(请求, 令牌)
                    : 索引号 == 1 ? 动态.形成概念节点清理授权(请求, 令牌)
                    : 索引号 == 2 ? 二次特征.形成概念节点清理授权(请求, 令牌)
                    : 因果.形成概念节点清理授权(请求, 令牌);
            }
            const 概念结构所有者清理请求 根请求{目标, 目标主信息, 概念结构所有者类型::存在服务, false, true};
            const auto 伪造令牌 = 结构事务令牌{令牌.域编号, 令牌.运行期纪元, 令牌.许可序号 + 1, 结构许可类型::独占};
            验收[5] = !存在.形成概念节点清理授权(根请求, 令牌).has_value()
                && !节点.准备节点删除包(目标, 伪造令牌).has_value()
                && !关系.准备节点关系失效包(目标, {}, 令牌).has_value();
        }

        const std::array 后数量{节点.有效节点数量(), 关系.有效关系数量(), 索引.有效主键数量()};
        验收[2] = 关系包.has_value() && 关系包->完整() && 关系包->关系组.size() == 1
            && 关系包->关系组.front().关系编号 == 目标关系.关系编号;
        验收[3] = 节点包.has_value() && 节点包->完整()
            && 主信息包.has_value() && 主信息包->完整()
            && 关系包.has_value() && 关系包->完整()
            && 索引包.has_value() && 索引包->完整();
        验收[4] = std::all_of(授权组.begin(), 授权组.end(), [](const auto& 授权) {
            return 授权.has_value() && 授权->完整();
        });
        验收[7] = 缓存记录.has_value() && 缓存包.has_value() && 缓存包->完整()
            && 缓存包->用途观察组.size() == 1 && !缓存包->用途观察组.front().可裁决业务事实;
        验收[9] = 前数量 == 后数量
            && 节点.读取节点(目标).has_value()
            && 关系.读取关系(目标关系).has_value()
            && 索引.按主键查节点(8201) == std::optional<节点句柄>{目标};

        const auto 值式样本 = 概念清理适配自检细节::生成完整值式样本();
        验收[6] = 值式样本.概念图包.完整()
            && 值式样本.概念图包.生命周期关系 == 值式样本.领域影响.目标生命周期.关系;
        验收[8] = 值式样本.完整();
        验收[10] = !std::is_default_constructible_v<概念安全删除提交会话>
            && !std::is_copy_constructible_v<概念安全删除提交会话>
            && std::is_move_constructible_v<概念安全删除提交会话>;

        主信息句柄 审计主信息;
        节点句柄 审计节点;
        {
            auto 许可 = 接线.取得共享许可(接线.运行期状态);
            审计主信息 = 主信息.创建主信息(许可.读取令牌());
            审计节点 = 节点.创建节点(节点类型::基础信息, 审计主信息, 许可.读取令牌());
        }
        {
            auto 许可 = 接线.取得独占许可(接线.运行期状态);
            验收[0] = 节点.删除节点(审计节点, 许可.读取令牌())
                && 主信息.删除主信息(审计主信息, 许可.读取令牌());
        }
        验收[0] = 验收[0]
            && !节点.读取节点(审计节点).has_value()
            && 节点.读取节点审计(审计节点).has_value()
            && !主信息.读取主信息(审计主信息).has_value()
            && 主信息.读取主信息审计(审计主信息).has_value();
        验收[11] = 接线.已接域() && 节点.读取节点(对端).has_value();
    } catch (...) {
    }

    std::size_t 失败数量 = 0;
    for (const bool 通过 : 验收) if (!通过) ++失败数量;
    return {"CONCEPT-S8-S2", "概念清理适配", 失败数量 == 0, 验收.size(), 失败数量};
}

}
