// 文件规则：概念活动业务服务只拥有概念活动私有状态并编排正式规格；不得暴露仓库、会话或结构事务令牌。
module;

#include "概念活动状态.数据.h"

#include <array>
#include <mutex>
#include <optional>
#include <utility>

export module 海中鱼巣.领域.服务.概念活动;

import 海中鱼巣.领域.数据操作.概念活动;
import 海中鱼巣.领域.服务.状态;

export namespace 海中鱼巣 {

class 概念活动业务服务 final {
public:
    概念活动业务服务(
        状态业务服务& 状态服务,
        概念活动数据操作& 数据操作)
        : 状态服务_(状态服务), 数据操作_(数据操作) {
    }

    bool 有效() const noexcept { return 数据操作_.有效(); }

    概念活动初始化结果 初始化(
        const 系统角色清单& 系统角色,
        const 概念活动初始化参数& 参数) {
        std::lock_guard<std::mutex> 锁(活动锁_);
        if (!有效() || !系统角色.完整() || !参数.有效()) return {};
        const auto 签名组 = 形成规范根签名组();
        if (活动材料_.has_value()) {
            if (!活动材料_->匹配参数(参数)) {
                return {概念活动业务状态::幂等冲突};
            }
            const auto 重建 = 数据操作_.重建活动视图(系统角色, 参数, 签名组);
            if (!重建.成功() || !活动材料_->重建视图.等于(重建.视图)) {
                return {重建.成功() ? 概念活动业务状态::内部不一致 : 重建.状态};
            }
            auto 输出 = *活动材料_;
            输出.重建视图 = 重建.视图;
            return {概念活动业务状态::幂等读回, std::move(输出)};
        }

        const auto 活跃规格 = 状态服务_.形成抽象状态写入规格({
            参数.活跃状态稳定主键,
            static_cast<std::int64_t>(运行期概念生命周期阶段::活跃)});
        const auto 冷却规格 = 状态服务_.形成抽象状态写入规格({
            参数.冷却状态稳定主键,
            static_cast<std::int64_t>(运行期概念生命周期阶段::冷却)});
        const auto 退役规格 = 状态服务_.形成抽象状态写入规格({
            参数.退役状态稳定主键,
            static_cast<std::int64_t>(运行期概念生命周期阶段::退役)});
        if (!活跃规格.成功() || !冷却规格.成功() || !退役规格.成功()) {
            return {概念活动业务状态::内部不一致};
        }
        auto 结果 = 数据操作_.初始化全新活动(
            系统角色, 参数, *活跃规格.规格, *冷却规格.规格, *退役规格.规格, 签名组);
        if (!结果.成功() || !结果.改变了结构()
            || 结果.材料.活动版本 != 概念活动初始版本) return 结果;
        活动材料_ = 结果.材料;
        return 结果;
    }

    概念活动初始化结果 复核(
        const 系统角色清单& 系统角色,
        const 概念活动材料& 预期材料) const {
        std::lock_guard<std::mutex> 锁(活动锁_);
        if (!有效() || !系统角色.完整() || !预期材料.完整()
            || !活动材料_.has_value() || !活动材料_->等于(预期材料)) return {};
        const auto 重建 = 数据操作_.重建活动视图(
            系统角色, 预期材料.初始化参数, 形成规范根签名组());
        if (!重建.成功()) return {重建.状态};
        if (!预期材料.重建视图.等于(重建.视图)) {
            return {概念活动业务状态::内部不一致};
        }
        auto 输出 = 预期材料;
        输出.重建视图 = 重建.视图;
        return {概念活动业务状态::幂等读回, std::move(输出)};
    }

    std::optional<概念活动材料> 读取材料() const {
        std::lock_guard<std::mutex> 锁(活动锁_);
        return 活动材料_;
    }

private:
    static std::array<概念签名材料, 4> 形成规范根签名组() {
        return {
            概念签名材料{概念根类别::存在, 1, {}},
            概念签名材料{概念根类别::动态, 1, {}},
            概念签名材料{概念根类别::关系, 1, {}},
            概念签名材料{概念根类别::因果, 1, {}}};
    }

    状态业务服务& 状态服务_;
    概念活动数据操作& 数据操作_;
    mutable std::mutex 活动锁_;
    std::optional<概念活动材料> 活动材料_;
};

}
