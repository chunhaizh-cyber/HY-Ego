export module 海中鱼巣.领域.数据操作.节点直接特征体系;

export import 海中鱼巣.领域.参与者.特征值类型化记录;

namespace 海中鱼巣 {

struct 节点直接特征批次记录 {
    static constexpr std::uint32_t 当前记录格式版本 = 1;

    特征批次身份 批次身份;
    std::uint32_t 记录格式版本 = 当前记录格式版本;
    std::uint64_t 业务规则版本 = 0;
    节点句柄 宿主;
    std::vector<特征值批次引用值式材料> 项目组;
    bool 已发布 = false;

    bool 完整() const noexcept {
        if (!批次身份.有效() || 记录格式版本 != 当前记录格式版本
            || 业务规则版本 == 0 || !句柄有效(宿主)
            || 项目组.empty()) {
            return false;
        }
        for (std::size_t 序号 = 0; 序号 < 项目组.size(); ++序号) {
            const auto& 项目 = 项目组[序号];
            if (项目.批次身份 != 批次身份 || 项目.业务规则版本 != 业务规则版本
                || 项目.项目顺序号 != 序号 || 项目.宿主 != 宿主
                || !句柄有效(项目.定义) || !句柄有效(项目.实例槽)
                || !句柄有效(项目.新特征值) || !句柄有效(项目.来源)
                || !句柄有效(项目.发布后当前关系)) {
                return false;
            }
            const bool 初始 = !项目.写前当前关系.has_value()
                && !项目.写前当前值.has_value()
                && !项目.写前原始值版本.has_value();
            const bool 换代 = 项目.写前当前关系.has_value()
                && 项目.写前当前值.has_value()
                && 项目.写前原始值版本.has_value()
                && 句柄有效(*项目.写前当前关系)
                && 句柄有效(*项目.写前当前值)
                && *项目.写前原始值版本 != 0
                && *项目.写前当前关系 != 项目.发布后当前关系
                && *项目.写前当前值 != 项目.新特征值;
            if (!初始 && !换代) return false;
            for (std::size_t 已有序号 = 0; 已有序号 < 序号; ++已有序号) {
                const auto& 已有 = 项目组[已有序号];
                if (已有.实例槽 == 项目.实例槽
                    || 已有.新特征值 == 项目.新特征值
                    || 已有.发布后当前关系 == 项目.发布后当前关系) {
                    return false;
                }
            }
        }
        return true;
    }
};

class 节点直接特征批次记录仓 final {
public:
    节点直接特征批次记录仓() = default;
    节点直接特征批次记录仓(const 节点直接特征批次记录仓&) = delete;
    节点直接特征批次记录仓& operator=(const 节点直接特征批次记录仓&) = delete;

private:
    friend class 节点直接特征批次记录参与者;
    friend class 节点直接特征体系数据操作;

    mutable std::shared_mutex 锁_;
    std::vector<节点直接特征批次记录> 记录组_;
    std::uint64_t 结构版本_ = 1;
};

class 节点直接特征批次记录参与者 final : public 节点直接身份结构写入事务参与者 {
public:
    explicit 节点直接特征批次记录参与者(节点直接特征批次记录仓& 记录仓) noexcept
        : 记录仓_(记录仓) {
    }

    bool 登记候选(节点直接特征批次记录 记录) {
        if (阶段_ != 阶段::未登记 || !记录.完整()) return false;
        记录.已发布 = false;
        try {
            候选_ = std::move(记录);
        } catch (...) {
            return false;
        }
        阶段_ = 阶段::已登记;
        return true;
    }

private:
    enum class 阶段 : std::uint8_t {
        未登记,
        已登记,
        已准备,
        已确认待发布,
        已发布,
        已撤销
    };

    节点直接身份结构写入结果 准备提交(
        const 节点直接身份结构提交准备只读视图& 视图) override {
        if (阶段_ != 阶段::已登记 || !候选_.has_value()) {
            return {节点直接身份结构写入状态::入口拒绝, 0, 0, 0};
        }
        for (const auto& 项目 : 候选_->项目组) {
            if (!视图.节点是本会话候选(项目.新特征值)
                || 视图.读取候选节点类型(项目.新特征值)
                    != std::optional<节点类型>{节点类型::特征值}) {
                return {节点直接身份结构写入状态::内部不一致,
                    项目.新特征值.节点编号, 0, 0};
            }
            if (!项目.写前当前关系.has_value()
                && (!视图.节点是本会话候选(项目.实例槽)
                    || 视图.读取候选节点类型(项目.实例槽)
                        != std::optional<节点类型>{节点类型::特征})) {
                return {节点直接身份结构写入状态::内部不一致,
                    项目.实例槽.节点编号, 0, 0};
            }
        }

        std::unique_lock<std::shared_mutex> 锁(记录仓_.锁_, std::try_to_lock);
        if (!锁.owns_lock()) {
            return {节点直接身份结构写入状态::许可拒绝, 0, 0, 0};
        }
        const auto 已有 = std::find_if(
            记录仓_.记录组_.cbegin(), 记录仓_.记录组_.cend(),
            [this](const auto& 记录) {
                return 记录.已发布 && 记录.批次身份 == 候选_->批次身份;
            });
        if (已有 != 记录仓_.记录组_.cend()) {
            return {节点直接身份结构写入状态::身份冲突,
                候选_->批次身份.编号, 0, 0};
        }
        try {
            记录仓_.记录组_.push_back(std::move(*候选_));
        } catch (...) {
            return {节点直接身份结构写入状态::内部不一致, 0, 0, 0};
        }
        候选_.reset();
        候选位置_ = 记录仓_.记录组_.size() - 1;
        记录锁_ = std::move(锁);
        阶段_ = 阶段::已准备;
        return {节点直接身份结构写入状态::候选已确认, 0, 0, 0};
    }

    节点直接身份结构写入结果 确认待发布() override {
        if (阶段_ != 阶段::已准备 || !记录锁_.owns_lock()
            || !当前候选完整_已加锁()) {
            return {节点直接身份结构写入状态::内部不一致, 0, 0, 0};
        }
        阶段_ = 阶段::已确认待发布;
        return {节点直接身份结构写入状态::候选已确认, 0, 0, 0};
    }

    void 完成发布() noexcept override {
        if (阶段_ != 阶段::已确认待发布 || !记录锁_.owns_lock()
            || !当前候选完整_已加锁()) {
            std::terminate();
        }
        记录仓_.记录组_[候选位置_].已发布 = true;
        if (记录仓_.结构版本_ == std::numeric_limits<std::uint64_t>::max()) {
            std::terminate();
        }
        ++记录仓_.结构版本_;
        候选位置_ = 无候选位置;
        阶段_ = 阶段::已发布;
        记录锁_.unlock();
    }

    节点直接身份结构写入结果 完成撤销() override {
        if (阶段_ == 阶段::已撤销) {
            return {节点直接身份结构写入状态::候选已撤销, 0, 0, 0};
        }
        if (阶段_ == 阶段::已发布) {
            return {节点直接身份结构写入状态::内部不一致, 0, 0, 0};
        }
        bool 完整 = true;
        if (阶段_ == 阶段::已准备 || 阶段_ == 阶段::已确认待发布) {
            if (!记录锁_.owns_lock() || !当前候选完整_已加锁()) {
                return {节点直接身份结构写入状态::内部不一致, 0, 0, 0};
            }
            记录仓_.记录组_.erase(
                记录仓_.记录组_.begin() + static_cast<std::ptrdiff_t>(候选位置_));
            记录锁_.unlock();
        }
        候选_.reset();
        候选位置_ = 无候选位置;
        阶段_ = 阶段::已撤销;
        return {完整 ? 节点直接身份结构写入状态::候选已撤销
                         : 节点直接身份结构写入状态::内部不一致,
            0, 0, 0};
    }

    bool 当前候选完整_已加锁() const noexcept {
        return 候选位置_ < 记录仓_.记录组_.size()
            && !记录仓_.记录组_[候选位置_].已发布
            && 记录仓_.记录组_[候选位置_].完整();
    }

    static constexpr std::size_t 无候选位置 = static_cast<std::size_t>(-1);
    节点直接特征批次记录仓& 记录仓_;
    阶段 阶段_ = 阶段::未登记;
    std::optional<节点直接特征批次记录> 候选_;
    std::size_t 候选位置_ = 无候选位置;
    std::unique_lock<std::shared_mutex> 记录锁_;
};

}

export namespace 海中鱼巣 {

inline constexpr std::uint64_t 节点直接特征批次身份命名域ABI = 1;

struct 节点直接特征批次冻结记录 final {
    特征批次身份 批次身份;
    std::uint32_t 记录格式版本 = 0;
    std::uint64_t 业务规则版本 = 0;
    节点句柄 宿主;
    std::vector<特征值批次引用值式材料> 项目组;
};

struct 节点直接特征同代次冻结材料 final {
    节点直接统一冻结见证 见证;
    std::uint64_t 特征值结构版本 = 0;
    std::uint64_t 批次结构版本 = 0;
    std::uint64_t 特征值记录数量 = 0;
    std::uint64_t 批次记录数量 = 0;
    std::vector<特征值类型化记录> 特征值记录组;
    std::vector<节点直接特征批次冻结记录> 批次记录组;
};

enum class 节点直接特征冻结状态 : std::uint32_t {
    已形成 = 1,
    入口拒绝 = 2,
    资源失败 = 3,
    内部不一致 = 0x8000
};

struct 节点直接特征同代次冻结结果 final {
    节点直接特征冻结状态 状态 = 节点直接特征冻结状态::内部不一致;
    std::optional<节点直接特征同代次冻结材料> 材料;
};

class 节点直接特征体系数据操作 final {
public:
    节点直接特征体系数据操作(
        节点直接身份结构事务域& 事务域,
        节点直接身份仓库& 节点,
        正式关系仓库& 关系,
        可重建索引仓库& 索引,
        特征值类型化记录仓& 记录仓) noexcept
        : 事务域_(&事务域), 节点_(&节点), 关系_(&关系), 索引_(&索引),
          记录仓_(&记录仓) {
    }

    bool 有效() const noexcept {
        return 事务域_ != nullptr && 节点_ != nullptr && 关系_ != nullptr
            && 索引_ != nullptr && 记录仓_ != nullptr && !事务域_->已隔离();
    }

    节点直接特征同代次冻结结果 复制同代次特征值与批次全量(
        const 节点直接统一冻结许可& 许可) const {
        if (!有效() || !许可.有效() || !事务域_->冻结许可属于本域(许可)) {
            return {节点直接特征冻结状态::入口拒绝, std::nullopt};
        }
        const auto 首次见证 = 许可.读取见证();
        if (首次见证.冻结域身份 == 0 || 首次见证.已发布代次 == 0
            || 首次见证.冻结规则版本 != 1) {
            return {节点直接特征冻结状态::内部不一致, std::nullopt};
        }

        auto 特征值副本 = 特征值类型化记录只读访问器(*记录仓_)
            .复制全部已发布记录();
        if (特征值副本.状态 != 特征值类型化记录全量读取状态::已形成) {
            return {
                特征值副本.状态 == 特征值类型化记录全量读取状态::资源失败
                    ? 节点直接特征冻结状态::资源失败
                    : 节点直接特征冻结状态::内部不一致,
                std::nullopt};
        }

        std::uint64_t 批次结构版本 = 0;
        std::vector<节点直接特征批次冻结记录> 批次副本;
        {
            std::shared_lock<std::shared_mutex> 锁(
                批次记录仓_.锁_, std::try_to_lock);
            if (!锁.owns_lock() || 批次记录仓_.结构版本_ == 0) {
                return {节点直接特征冻结状态::内部不一致, std::nullopt};
            }
            try {
                批次副本.reserve(批次记录仓_.记录组_.size());
                for (const auto& 记录 : 批次记录仓_.记录组_) {
                    if (!记录.已发布 || !记录.完整()) {
                        return {
                            节点直接特征冻结状态::内部不一致, std::nullopt};
                    }
                    const auto 重复 = std::find_if(
                        批次副本.cbegin(), 批次副本.cend(),
                        [&记录](const auto& 已有) {
                            return 已有.批次身份 == 记录.批次身份;
                        });
                    if (重复 != 批次副本.cend()) {
                        return {
                            节点直接特征冻结状态::内部不一致, std::nullopt};
                    }
                    批次副本.push_back({
                        记录.批次身份,
                        记录.记录格式版本,
                        记录.业务规则版本,
                        记录.宿主,
                        记录.项目组});
                }
            } catch (const std::bad_alloc&) {
                return {节点直接特征冻结状态::资源失败, std::nullopt};
            } catch (...) {
                return {节点直接特征冻结状态::内部不一致, std::nullopt};
            }
            批次结构版本 = 批次记录仓_.结构版本_;
        }

        const auto 再次见证 = 许可.读取见证();
        if (!事务域_->冻结许可属于本域(许可)
            || 首次见证.冻结域身份 != 再次见证.冻结域身份
            || 首次见证.已发布代次 != 再次见证.已发布代次
            || 首次见证.冻结规则版本 != 再次见证.冻结规则版本) {
            return {节点直接特征冻结状态::内部不一致, std::nullopt};
        }

        const auto 特征值复核 = 特征值类型化记录只读访问器(*记录仓_)
            .复制全部已发布记录();
        if (特征值复核.状态 != 特征值类型化记录全量读取状态::已形成) {
            return {
                特征值复核.状态 == 特征值类型化记录全量读取状态::资源失败
                    ? 节点直接特征冻结状态::资源失败
                    : 节点直接特征冻结状态::内部不一致,
                std::nullopt};
        }
        if (特征值副本.结构版本 != 特征值复核.结构版本
            || 特征值副本.记录组.size() != 特征值复核.记录组.size()) {
            return {节点直接特征冻结状态::内部不一致, std::nullopt};
        }

        {
            std::shared_lock<std::shared_mutex> 锁(
                批次记录仓_.锁_, std::try_to_lock);
            if (!锁.owns_lock() || 批次记录仓_.结构版本_ != 批次结构版本
                || 批次记录仓_.记录组_.size() != 批次副本.size()) {
                return {节点直接特征冻结状态::内部不一致, std::nullopt};
            }
            for (const auto& 记录 : 批次记录仓_.记录组_) {
                if (!记录.已发布 || !记录.完整()) {
                    return {节点直接特征冻结状态::内部不一致, std::nullopt};
                }
            }
        }

        const auto 特征值存在 = [&特征值副本](
            节点句柄 特征值,
            std::optional<std::uint64_t> 原始值版本) {
            std::size_t 匹配数量 = 0;
            for (const auto& 记录 : 特征值副本.记录组) {
                if (记录.特征值 == 特征值
                    && (!原始值版本.has_value()
                        || 记录.原始值版本 == *原始值版本)) {
                    ++匹配数量;
                }
            }
            return 匹配数量 == 1;
        };
        for (const auto& 批次 : 批次副本) {
            if (!批次.批次身份.有效()
                || 批次.记录格式版本 != 节点直接特征批次记录::当前记录格式版本
                || 批次.业务规则版本 == 0 || !句柄有效(批次.宿主)
                || 批次.项目组.empty()) {
                return {节点直接特征冻结状态::内部不一致, std::nullopt};
            }
            for (std::size_t 序号 = 0; 序号 < 批次.项目组.size(); ++序号) {
                const auto& 项目 = 批次.项目组[序号];
                const bool 初始 = !项目.写前当前关系.has_value()
                    && !项目.写前当前值.has_value()
                    && !项目.写前原始值版本.has_value();
                const bool 换代 = 项目.写前当前关系.has_value()
                    && 项目.写前当前值.has_value()
                    && 项目.写前原始值版本.has_value();
                if (项目.批次身份 != 批次.批次身份
                    || 项目.业务规则版本 != 批次.业务规则版本
                    || 项目.项目顺序号 != 序号 || 项目.宿主 != 批次.宿主
                    || (!初始 && !换代)
                    || !特征值存在(项目.新特征值, std::nullopt)
                    || (换代 && !特征值存在(
                        *项目.写前当前值, 项目.写前原始值版本))) {
                    return {节点直接特征冻结状态::内部不一致, std::nullopt};
                }
            }
        }

        std::sort(特征值副本.记录组.begin(), 特征值副本.记录组.end(),
            [](const auto& 左, const auto& 右) {
                if (左.特征值.仓库编号 != 右.特征值.仓库编号) {
                    return 左.特征值.仓库编号 < 右.特征值.仓库编号;
                }
                if (左.特征值.节点编号 != 右.特征值.节点编号) {
                    return 左.特征值.节点编号 < 右.特征值.节点编号;
                }
                if (左.特征值.版本号 != 右.特征值.版本号) {
                    return 左.特征值.版本号 < 右.特征值.版本号;
                }
                return 左.原始值版本 < 右.原始值版本;
            });
        std::sort(批次副本.begin(), 批次副本.end(),
            [](const auto& 左, const auto& 右) {
                return 左.批次身份.编号 < 右.批次身份.编号;
            });

        节点直接特征同代次冻结材料 材料;
        材料.见证 = 首次见证;
        材料.特征值结构版本 = 特征值副本.结构版本;
        材料.批次结构版本 = 批次结构版本;
        材料.特征值记录数量 =
            static_cast<std::uint64_t>(特征值副本.记录组.size());
        材料.批次记录数量 = static_cast<std::uint64_t>(批次副本.size());
        材料.特征值记录组 = std::move(特征值副本.记录组);
        材料.批次记录组 = std::move(批次副本);
        return {节点直接特征冻结状态::已形成, std::move(材料)};
    }

    特征值归属读取结果 复核特征值归属(
        节点句柄 目标特征值,
        std::optional<节点句柄> 预期抽象特征定义,
        特征值归属读取口径 口径) const {
        if (!有效() || !句柄有效(目标特征值)
            || (预期抽象特征定义.has_value()
                && !句柄有效(*预期抽象特征定义))
            || (口径 != 特征值归属读取口径::当前
                && 口径 != 特征值归属读取口径::历史审计)) {
            return {合同结果状态::入口拒绝, 合同结果原因::无效身份};
        }
        auto 许可 = 事务域_->取得读取许可();
        if (!许可.有效()) {
            return {合同结果状态::许可竞争, 合同结果原因::并发许可失败};
        }

        const auto 值节点 = 节点_->读取节点(目标特征值);
        if (!值节点.has_value()) {
            return {合同结果状态::入口拒绝, 合同结果原因::错版本};
        }
        if (值节点->类型 != 节点类型::特征值) {
            return {合同结果状态::入口拒绝, 合同结果原因::错类型};
        }
        const auto 记录结果 = 特征值类型化记录只读访问器(*记录仓_)
            .读取当前记录(目标特征值);
        if (记录结果.状态 == 特征值类型化记录读取状态::许可竞争) {
            return {合同结果状态::许可竞争, 合同结果原因::并发许可失败};
        }
        if (!记录结果.可读()) {
            return {记录结果.状态 == 特征值类型化记录读取状态::合法未找到
                    ? 合同结果状态::合法未找到 : 合同结果状态::内部错误,
                记录结果.状态 == 特征值类型化记录读取状态::合法未找到
                    ? 合同结果原因::无 : 合同结果原因::权威读回不一致};
        }

        const auto 当前关系组 = 读取关系当前版本组();
        std::vector<正式关系记录> 值证据组;
        for (const auto& 关系 : 当前关系组) {
            if (关系.类型 != 关系类型::特征实例角色 || 关系.顺序号 != 当前值角色
                || 关系.目标节点 != 目标特征值) {
                continue;
            }
            if (口径 == 特征值归属读取口径::当前 && 关系.状态 != 记录状态::有效) {
                continue;
            }
            值证据组.push_back(关系);
        }
        if (值证据组.empty()) {
            return {合同结果状态::合法未找到, 合同结果原因::无};
        }
        if (值证据组.size() != 1) {
            return {合同结果状态::内部错误, 合同结果原因::基数不满足};
        }
        const auto& 值证据 = 值证据组.front();
        const auto 模板组 = 筛选当前有效关系(
            当前关系组, 值证据.源节点, 关系类型::特征实例角色, 定义模板角色);
        if (模板组.size() != 1) {
            return {合同结果状态::内部错误, 合同结果原因::基数不满足};
        }
        const auto 定义节点 = 节点_->读取节点(模板组.front().目标节点);
        const auto 槽节点 = 节点_->读取节点(值证据.源节点);
        if (!定义节点.has_value() || 定义节点->类型 != 节点类型::特征
            || !槽节点.has_value() || 槽节点->类型 != 节点类型::特征) {
            return {合同结果状态::内部错误, 合同结果原因::权威读回不一致};
        }
        if (预期抽象特征定义.has_value()
            && 模板组.front().目标节点 != *预期抽象特征定义) {
            return {合同结果状态::合法未找到, 合同结果原因::值归属不一致};
        }

        特征值归属值式材料 材料{
            目标特征值,
            值节点->版本号,
            记录结果.记录->原始值版本,
            值证据.源节点,
            模板组.front().目标节点,
            模板组.front(),
            值证据,
            记录结果.记录->原始值};
        return {合同结果状态::成功, 合同结果原因::无, std::move(材料)};
    }

    宿主实例特征槽位组读取结果 读取宿主实例特征槽位组(
        节点句柄 宿主) const {
        if (!有效() || !句柄有效(宿主)) {
            return {合同结果状态::入口拒绝, 合同结果原因::无效身份};
        }
        auto 许可 = 事务域_->取得读取许可();
        if (!许可.有效()) {
            return {合同结果状态::许可竞争, 合同结果原因::并发许可失败};
        }
        const auto 宿主节点 = 节点_->读取节点(宿主);
        if (!宿主节点.has_value()) {
            return {合同结果状态::入口拒绝, 合同结果原因::错版本};
        }
        if (!是合法特征宿主类型(宿主节点->类型)) {
            return {合同结果状态::入口拒绝, 合同结果原因::错类型};
        }

        const auto 当前关系组 = 读取关系当前版本组();
        const auto 宿主关系组 = 筛选当前有效关系(
            当前关系组, 宿主, 关系类型::特征实例角色, 宿主槽角色);
        宿主实例特征槽位组值式材料 组材料;
        组材料.宿主 = 宿主;
        组材料.读取结构版本 = 特征值类型化记录只读访问器(*记录仓_)
            .读取结构版本();
        if (组材料.读取结构版本 == 0) {
            return {合同结果状态::许可竞争, 合同结果原因::并发许可失败};
        }
        try {
            组材料.项目组.reserve(宿主关系组.size());
        } catch (...) {
            return {合同结果状态::内部错误, 合同结果原因::权威读回不一致};
        }

        for (const auto& 宿主关系 : 宿主关系组) {
            const auto 反向宿主数量 = std::count_if(
                当前关系组.cbegin(), 当前关系组.cend(),
                [&宿主关系](const auto& 关系) {
                    return 关系.状态 == 记录状态::有效
                        && 关系.类型 == 关系类型::特征实例角色
                        && 关系.顺序号 == 宿主槽角色
                        && 关系.目标节点 == 宿主关系.目标节点;
                });
            const auto 模板组 = 筛选当前有效关系(
                当前关系组, 宿主关系.目标节点,
                关系类型::特征实例角色, 定义模板角色);
            const auto 当前值组 = 筛选当前有效关系(
                当前关系组, 宿主关系.目标节点,
                关系类型::特征实例角色, 当前值角色);
            if (反向宿主数量 != 1 || 模板组.size() != 1 || 当前值组.size() != 1) {
                return {合同结果状态::内部错误, 合同结果原因::基数不满足};
            }
            const auto 槽节点 = 节点_->读取节点(宿主关系.目标节点);
            const auto 定义节点 = 节点_->读取节点(模板组.front().目标节点);
            const auto 值节点 = 节点_->读取节点(当前值组.front().目标节点);
            if (!槽节点.has_value() || 槽节点->类型 != 节点类型::特征
                || !定义节点.has_value() || 定义节点->类型 != 节点类型::特征
                || !值节点.has_value() || 值节点->类型 != 节点类型::特征值) {
                return {合同结果状态::内部错误, 合同结果原因::权威读回不一致};
            }
            const auto 记录结果 = 特征值类型化记录只读访问器(*记录仓_)
                .读取当前记录(当前值组.front().目标节点);
            if (!记录结果.可读()) {
                return {记录结果.状态 == 特征值类型化记录读取状态::许可竞争
                        ? 合同结果状态::许可竞争 : 合同结果状态::内部错误,
                    记录结果.状态 == 特征值类型化记录读取状态::许可竞争
                        ? 合同结果原因::并发许可失败 : 合同结果原因::权威读回不一致};
            }
            try {
                组材料.项目组.push_back({
                    宿主关系.目标节点,
                    模板组.front().目标节点,
                    当前值组.front().目标节点,
                    宿主关系,
                    模板组.front(),
                    当前值组.front(),
                    记录结果.记录->原始值版本,
                    记录结果.记录->原始值});
            } catch (...) {
                return {合同结果状态::内部错误, 合同结果原因::权威读回不一致};
            }
        }
        std::sort(组材料.项目组.begin(), 组材料.项目组.end(),
            [](const auto& 左, const auto& 右) {
                return 左.实例槽.节点编号 < 右.实例槽.节点编号;
            });
        const auto 状态 = 组材料.项目组.empty()
            ? 合同结果状态::合法空组 : 合同结果状态::成功;
        return {状态, 合同结果原因::无, std::move(组材料)};
    }

    特征值退役规格结果 形成特征值退役规格(
        节点句柄 特征值,
        std::uint32_t 预期节点版本,
        std::uint64_t 预期原始值版本) const {
        if (!有效() || !句柄有效(特征值)
            || 预期节点版本 == 0 || 预期原始值版本 == 0) {
            return {合同结果状态::入口拒绝, 合同结果原因::无效身份};
        }
        const auto 归属 = 复核特征值归属(
            特征值, std::nullopt, 特征值归属读取口径::历史审计);
        if (!归属.成功()) return {归属.状态, 归属.原因};
        if (归属.材料->节点版本 != 预期节点版本
            || 归属.材料->原始值版本 != 预期原始值版本) {
            return {合同结果状态::写前漂移, 合同结果原因::错版本};
        }
        return {合同结果状态::成功, 合同结果原因::无,
            特征值退役规格{特征值, 预期节点版本, 预期原始值版本}};
    }

    带值读取结果<特征值退役材料> 读取特征值退役材料(
        节点句柄 特征值) const {
        if (!有效() || !句柄有效(特征值)) {
            return {合同结果状态::入口拒绝, 合同结果原因::无效身份};
        }
        auto 许可 = 事务域_->取得读取许可();
        if (!许可.有效()) {
            return {合同结果状态::许可竞争, 合同结果原因::并发许可失败};
        }
        const auto 节点记录 = 节点_->读取节点(特征值);
        if (!节点记录.has_value()) {
            return {合同结果状态::合法未找到, 合同结果原因::无};
        }
        if (节点记录->类型 != 节点类型::特征值) {
            return {合同结果状态::入口拒绝, 合同结果原因::错类型};
        }
        const auto 类型记录 = 特征值类型化记录只读访问器(*记录仓_)
            .读取当前记录(特征值);
        if (!类型记录.可读()) {
            return {类型记录.状态 == 特征值类型化记录读取状态::许可竞争
                    ? 合同结果状态::许可竞争 : 合同结果状态::内部错误,
                类型记录.状态 == 特征值类型化记录读取状态::许可竞争
                    ? 合同结果原因::并发许可失败 : 合同结果原因::权威读回不一致};
        }

        特征值退役材料 材料;
        材料.特征值 = 特征值;
        材料.节点版本 = 节点记录->版本号;
        材料.原始值版本 = 类型记录.记录->原始值版本;
        const auto 当前关系组 = 读取关系当前版本组();
        for (const auto& 关系 : 当前关系组) {
            if (关系.类型 == 关系类型::特征实例角色
                && 关系.顺序号 == 当前值角色 && 关系.目标节点 == 特征值) {
                材料.当前或失效关系22组.push_back(关系);
            }
            if (关系.类型 == 关系类型::因果来源 && 关系.源节点 == 特征值) {
                材料.来源关系组.push_back(关系);
            }
        }
        {
            std::shared_lock<std::shared_mutex> 锁(批次记录仓_.锁_, std::try_to_lock);
            if (!锁.owns_lock()) {
                return {合同结果状态::许可竞争, 合同结果原因::并发许可失败};
            }
            try {
                for (const auto& 批次 : 批次记录仓_.记录组_) {
                    if (!批次.已发布 || !批次.完整()) continue;
                    for (const auto& 项目 : 批次.项目组) {
                        if (项目.新特征值 == 特征值) 材料.批次引用组.push_back(项目);
                    }
                }
            } catch (...) {
                return {合同结果状态::内部错误, 合同结果原因::权威读回不一致};
            }
        }
        return {合同结果状态::成功, 合同结果原因::无, std::move(材料)};
    }

    带值结构写入结果<实例特征槽位值式材料> 发布新实例槽位(
        const 新实例槽位发布请求& 请求) {
        if (!新实例槽位请求完整(请求)) {
            return {合同结果状态::入口拒绝, 合同结果原因::无效身份};
        }
        const auto 写前 = 复核新实例槽位写前(请求);
        if (写前.状态 != 合同结果状态::成功) {
            return {写前.状态, 写前.原因};
        }

        特征值类型化记录事务参与者 记录参与者(*记录仓_);
        节点句柄 实例槽;
        节点句柄 新值;
        std::optional<无值映射结果> 锁内写前失败;
        节点直接身份结构写入执行器 执行器(事务域_, 节点_, 关系_, 索引_);
        const auto 执行结果 = 执行器.执行(
            [&](节点直接身份结构写入会话& 会话) {
                const auto 锁内复核 = 复核新实例槽位写前_会话(会话, 请求);
                if (锁内复核.状态 != 合同结果状态::成功) {
                    锁内写前失败 = {锁内复核.状态, 锁内复核.原因};
                    return;
                }
                const auto 槽结果 = 会话.创建节点候选(
                    节点类型::特征, 请求.实例槽主键);
                if (!槽结果.成功()) {
                    锁内写前失败 = 映射结构写入结果(槽结果.操作);
                    return;
                }
                实例槽 = *槽结果.值;
                if (!会话.读取节点(实例槽).has_value()) 抛出事务内部不一致();

                const auto 宿主关系 = 会话.创建关系候选(
                    关系类型::特征实例角色, 请求.宿主, 实例槽, 宿主槽角色);
                const auto 定义关系 = 会话.创建关系候选(
                    关系类型::特征实例角色, 实例槽, 请求.抽象定义, 定义模板角色);
                if (!宿主关系.成功() || !定义关系.成功()
                    || !会话.读取关系(*宿主关系.值).has_value()
                    || !会话.读取关系(*定义关系.值).has_value()) {
                    抛出事务内部不一致();
                }
                if (!写入新特征值_会话(
                        会话, 实例槽, 请求.特征值主键, 请求.来源,
                        0, 请求.原始值, 记录参与者, 新值).has_value()) {
                    抛出事务内部不一致();
                }
                if (!写入节点索引_会话(会话, 请求.实例槽主键, 实例槽, 实例槽索引命名域)
                    || !写入节点索引_会话(
                        会话, 请求.特征值主键, 新值, 特征值索引命名域)) {
                    抛出事务内部不一致();
                }
                会话.请求提交();
            },
            记录参与者);
        if (锁内写前失败.has_value()) {
            return {锁内写前失败->状态, 锁内写前失败->原因};
        }
        const auto 映射 = 映射结构写入结果(执行结果);
        if (映射.状态 != 合同结果状态::成功
            && 映射.状态 != 合同结果状态::幂等读回) {
            return {映射.状态, 映射.原因};
        }
        const auto 组 = 读取宿主实例特征槽位组(请求.宿主);
        if (!组.成功()) return {组.状态, 组.原因};
        const auto 项目 = std::find_if(
            组.材料->项目组.cbegin(), 组.材料->项目组.cend(),
            [实例槽](const auto& 当前) { return 当前.实例槽 == 实例槽; });
        if (项目 == 组.材料->项目组.cend()) {
            return {合同结果状态::内部错误, 合同结果原因::权威读回不一致};
        }
        return {映射.状态, 合同结果原因::无, *项目, 组.材料->读取结构版本};
    }

    带值结构写入结果<实例特征槽位值式材料> 换代实例槽位当前值(
        const 实例槽位当前值换代请求& 请求) {
        if (!实例槽位换代请求完整(请求)) {
            return {合同结果状态::入口拒绝, 合同结果原因::无效身份};
        }
        const auto 写前材料 = 读取实例槽位当前材料(请求.实例槽);
        if (!写前材料.成功()) return {写前材料.状态, 写前材料.原因};
        if (形成正式关系句柄(请求.写前当前关系.仓库编号, 写前材料.材料->当前值证据)
                != 请求.写前当前关系
            || 写前材料.材料->当前特征值 != 请求.写前当前值
            || 写前材料.材料->原始值版本 != 请求.写前原始值版本) {
            return {合同结果状态::写前漂移, 合同结果原因::错版本};
        }
        if (!节点_->读取节点(请求.来源).has_value()) {
            return {合同结果状态::入口拒绝, 合同结果原因::错版本};
        }
        const auto 主键状态 = 节点_->读取稳定主键当前身份(请求.新特征值主键);
        if (主键状态.状态 != 稳定主键当前身份状态::未占用) {
            return {合同结果状态::入口拒绝, 合同结果原因::同键异义};
        }

        特征值类型化记录事务参与者 记录参与者(*记录仓_);
        节点句柄 新值;
        std::optional<无值映射结果> 锁内写前失败;
        节点直接身份结构写入执行器 执行器(事务域_, 节点_, 关系_, 索引_);
        const auto 执行结果 = 执行器.执行(
            [&](节点直接身份结构写入会话& 会话) {
                const auto 锁内复核 = 复核换代写前_会话(会话, 请求);
                if (锁内复核.状态 != 合同结果状态::成功) {
                    锁内写前失败 = {锁内复核.状态, 锁内复核.原因};
                    return;
                }
                const auto 失效结果 = 会话.失效关系候选(请求.写前当前关系);
                if (!失效结果.成功()) {
                    锁内写前失败 = 映射结构写入结果(失效结果.操作);
                    return;
                }
                if (!会话.读取关系审计(*失效结果.值).has_value()) {
                    抛出事务内部不一致();
                }
                if (!写入新特征值_会话(
                        会话, 请求.实例槽, 请求.新特征值主键, 请求.来源,
                        0, 请求.新原始值, 记录参与者, 新值).has_value()) {
                    抛出事务内部不一致();
                }
                if (!写入节点索引_会话(
                        会话, 请求.新特征值主键, 新值, 特征值索引命名域)) {
                    抛出事务内部不一致();
                }
                会话.请求提交();
            },
            记录参与者);
        if (锁内写前失败.has_value()) {
            return {锁内写前失败->状态, 锁内写前失败->原因};
        }
        const auto 映射 = 映射结构写入结果(执行结果);
        if (映射.状态 != 合同结果状态::成功
            && 映射.状态 != 合同结果状态::幂等读回) {
            return {映射.状态, 映射.原因};
        }
        const auto 读回 = 读取实例槽位当前材料(请求.实例槽);
        if (!读回.成功() || 读回.材料->当前特征值 != 新值) {
            return {合同结果状态::内部错误, 合同结果原因::权威读回不一致};
        }
        return {映射.状态, 合同结果原因::无, *读回.材料,
            特征值类型化记录只读访问器(*记录仓_).读取结构版本()};
    }

    带值结构写入结果<特征批次提交值式材料> 提交特征批次(
        const 特征批次变更请求& 请求) {
        if (!特征批次请求完整(请求)) {
            return {合同结果状态::入口拒绝, 合同结果原因::无效身份};
        }
        std::optional<节点直接特征批次记录> 已发布批次;
        {
            std::shared_lock<std::shared_mutex> 锁(批次记录仓_.锁_, std::try_to_lock);
            if (!锁.owns_lock()) {
                return {合同结果状态::许可竞争, 合同结果原因::并发许可失败};
            }
            const auto 已有 = std::find_if(
                批次记录仓_.记录组_.cbegin(), 批次记录仓_.记录组_.cend(),
                [&请求](const auto& 记录) {
                    return 记录.已发布 && 记录.批次身份 == 请求.批次身份;
                });
            if (已有 != 批次记录仓_.记录组_.cend()) {
                try {
                    已发布批次 = *已有;
                } catch (...) {
                    return {合同结果状态::内部错误, 合同结果原因::权威读回不一致};
                }
            }
        }
        if (已发布批次.has_value()) {
            return 读取幂等批次结果(请求, *已发布批次);
        }
        const auto 写前 = 复核特征批次写前(请求);
        if (写前.状态 != 合同结果状态::成功) {
            return {写前.状态, 写前.原因};
        }

        特征值类型化记录事务参与者 记录参与者(*记录仓_);
        节点直接特征批次记录参与者 批次参与者(批次记录仓_);
        std::vector<特征值批次引用值式材料> 批次项目组;
        std::optional<无值映射结果> 锁内写前失败;
        std::optional<节点直接特征批次记录> 锁内已发布批次;
        bool 已形成结构候选 = false;
        节点直接身份结构写入执行器 执行器(事务域_, 节点_, 关系_, 索引_);
        std::array<节点直接身份结构写入事务参与者*, 2> 参与者组{
            &记录参与者, &批次参与者};
        const auto 执行结果 = 执行器.执行(
            [&](节点直接身份结构写入会话& 会话) {
                {
                    std::shared_lock<std::shared_mutex> 锁(
                        批次记录仓_.锁_, std::try_to_lock);
                    if (!锁.owns_lock()) {
                        锁内写前失败 = {
                            合同结果状态::许可竞争,
                            合同结果原因::并发许可失败};
                        return;
                    }
                    const auto 已有 = std::find_if(
                        批次记录仓_.记录组_.cbegin(), 批次记录仓_.记录组_.cend(),
                        [&请求](const auto& 记录) {
                            return 记录.已发布 && 记录.批次身份 == 请求.批次身份;
                        });
                    if (已有 != 批次记录仓_.记录组_.cend()) {
                        try {
                            锁内已发布批次 = *已有;
                        } catch (...) {
                            抛出事务内部不一致();
                        }
                        return;
                    }
                }
                const auto 锁内复核 = 复核特征批次写前_会话(会话, 请求);
                if (锁内复核.状态 != 合同结果状态::成功) {
                    锁内写前失败 = {锁内复核.状态, 锁内复核.原因};
                    return;
                }
                try {
                    批次项目组.reserve(请求.项目组.size());
                } catch (...) {
                    抛出事务内部不一致();
                }
                for (const auto& 项目 : 请求.项目组) {
                    节点句柄 实例槽 = 项目.实例槽;
                    if (项目.种类 == 特征批次变更种类::初始) {
                        const auto 槽结果 = 会话.创建节点候选(
                            节点类型::特征, 项目.实例槽主键);
                        if (!槽结果.成功()) {
                            if (已形成结构候选) 抛出事务内部不一致();
                            锁内写前失败 = 映射结构写入结果(槽结果.操作);
                            return;
                        }
                        已形成结构候选 = true;
                        实例槽 = *槽结果.值;
                        if (!会话.读取节点(实例槽).has_value()) {
                            抛出事务内部不一致();
                        }
                        const auto 宿主关系 = 会话.创建关系候选(
                            关系类型::特征实例角色, 请求.宿主, 实例槽, 宿主槽角色);
                        const auto 定义关系 = 会话.创建关系候选(
                            关系类型::特征实例角色, 实例槽, 项目.抽象定义, 定义模板角色);
                        if (!宿主关系.成功() || !定义关系.成功()
                            || !会话.读取关系(*宿主关系.值).has_value()
                            || !会话.读取关系(*定义关系.值).has_value()) {
                            抛出事务内部不一致();
                        }
                        if (!写入节点索引_会话(
                                会话, 项目.实例槽主键, 实例槽, 实例槽索引命名域)) {
                            抛出事务内部不一致();
                        }
                    } else {
                        const auto 失效 = 会话.失效关系候选(*项目.写前当前关系);
                        if (!失效.成功()) {
                            if (已形成结构候选) 抛出事务内部不一致();
                            锁内写前失败 = 映射结构写入结果(失效.操作);
                            return;
                        }
                        已形成结构候选 = true;
                        if (!会话.读取关系审计(*失效.值).has_value()) {
                            抛出事务内部不一致();
                        }
                    }
                    节点句柄 新值;
                    const auto 新当前关系 = 写入新特征值_会话(
                        会话, 实例槽, 项目.新特征值主键, 项目.来源,
                        static_cast<std::int64_t>(项目.项目顺序号),
                        项目.新原始值, 记录参与者, 新值);
                    if (!新当前关系.has_value()) 抛出事务内部不一致();
                    if (!写入节点索引_会话(
                            会话, 项目.新特征值主键, 新值, 特征值索引命名域)) {
                        抛出事务内部不一致();
                    }
                    try {
                        批次项目组.push_back({
                            请求.批次身份,
                            请求.业务规则版本,
                            项目.项目顺序号,
                            请求.宿主,
                            项目.抽象定义,
                            实例槽,
                            新值,
                            项目.来源,
                            项目.写前当前关系,
                            项目.写前当前值,
                            项目.写前原始值版本,
                            *新当前关系});
                    } catch (...) {
                        抛出事务内部不一致();
                    }
                }
                if (!批次参与者.登记候选({
                        请求.批次身份,
                        节点直接特征批次记录::当前记录格式版本,
                        请求.业务规则版本,
                        请求.宿主,
                        批次项目组,
                        false})) {
                    抛出事务内部不一致();
                }
                会话.请求提交();
            },
            std::span<节点直接身份结构写入事务参与者* const>(参与者组));
        if (锁内已发布批次.has_value()) {
            return 读取幂等批次结果(请求, *锁内已发布批次);
        }
        if (锁内写前失败.has_value()) {
            return {锁内写前失败->状态, 锁内写前失败->原因};
        }
        const auto 映射 = 映射结构写入结果(执行结果);
        if (映射.状态 != 合同结果状态::成功
            && 映射.状态 != 合同结果状态::幂等读回) {
            return {映射.状态, 映射.原因};
        }
        const auto 组 = 读取宿主实例特征槽位组(请求.宿主);
        if (!组.成功()) return {组.状态, 组.原因};
        特征批次提交值式材料 材料{
            请求.批次身份, 请求.业务规则版本, 请求.宿主, 组.材料->项目组};
        return {映射.状态, 合同结果原因::无, std::move(材料),
            组.材料->读取结构版本};
    }

private:
    struct 事务内部不一致异常 final {
    };

    struct 无值映射结果 {
        合同结果状态 状态 = 合同结果状态::入口拒绝;
        合同结果原因 原因 = 合同结果原因::无效身份;
    };

    static constexpr std::int64_t 宿主槽角色 = 1;
    static constexpr std::int64_t 定义模板角色 = 2;
    static constexpr std::int64_t 当前值角色 = 3;
    static constexpr std::uint64_t 索引所有者身份 = 0x4E54503241000001ULL;
    static constexpr std::uint32_t 实例槽索引命名域 = 1;
    static constexpr std::uint32_t 特征值索引命名域 = 2;

    [[noreturn]] static void 抛出事务内部不一致() {
        throw 事务内部不一致异常{};
    }

    static bool 是合法特征宿主类型(节点类型 类型) noexcept {
        return 类型 == 节点类型::存在 || 类型 == 节点类型::场景
            || 类型 == 节点类型::需求 || 类型 == 节点类型::任务
            || 类型 == 节点类型::方法;
    }

    static bool 主键属于(
        const 节点稳定主键& 主键,
        节点稳定主键命名域 命名域) noexcept {
        return 稳定主键有效(主键)
            && 主键.命名域 == static_cast<std::uint64_t>(命名域);
    }

    static std::vector<正式关系记录> 筛选当前有效关系(
        const std::vector<正式关系记录>& 关系组,
        节点句柄 源节点,
        关系类型 类型,
        std::int64_t 顺序号) {
        std::vector<正式关系记录> 输出;
        for (const auto& 关系 : 关系组) {
            if (关系.状态 == 记录状态::有效 && 关系.源节点 == 源节点
                && 关系.类型 == 类型 && 关系.顺序号 == 顺序号) {
                输出.push_back(关系);
            }
        }
        return 输出;
    }

    std::vector<正式关系记录> 读取关系当前版本组() const {
        std::vector<正式关系记录> 当前组;
        for (const auto& 记录 : 关系_->读取全部关系审计()) {
            const auto 已有 = std::find_if(
                当前组.begin(), 当前组.end(),
                [&记录](const auto& 当前) { return 当前.关系编号 == 记录.关系编号; });
            if (已有 == 当前组.end()) {
                当前组.push_back(记录);
            } else if (记录.版本号 > 已有->版本号) {
                *已有 = 记录;
            }
        }
        return 当前组;
    }

    合同单项结果<实例特征槽位值式材料> 读取实例槽位当前材料(
        节点句柄 实例槽) const {
        if (!有效() || !句柄有效(实例槽)) {
            return {合同结果状态::入口拒绝, 合同结果原因::无效身份};
        }
        auto 许可 = 事务域_->取得读取许可();
        if (!许可.有效()) {
            return {合同结果状态::许可竞争, 合同结果原因::并发许可失败};
        }
        const auto 关系组 = 读取关系当前版本组();
        std::vector<正式关系记录> 宿主组;
        for (const auto& 关系 : 关系组) {
            if (关系.状态 == 记录状态::有效
                && 关系.类型 == 关系类型::特征实例角色
                && 关系.顺序号 == 宿主槽角色 && 关系.目标节点 == 实例槽) {
                宿主组.push_back(关系);
            }
        }
        const auto 模板组 = 筛选当前有效关系(
            关系组, 实例槽, 关系类型::特征实例角色, 定义模板角色);
        const auto 当前值组 = 筛选当前有效关系(
            关系组, 实例槽, 关系类型::特征实例角色, 当前值角色);
        if (宿主组.size() != 1 || 模板组.size() != 1 || 当前值组.size() != 1) {
            return {合同结果状态::内部错误, 合同结果原因::基数不满足};
        }
        const auto 槽节点 = 节点_->读取节点(实例槽);
        const auto 宿主节点 = 节点_->读取节点(宿主组.front().源节点);
        const auto 定义节点 = 节点_->读取节点(模板组.front().目标节点);
        const auto 值节点 = 节点_->读取节点(当前值组.front().目标节点);
        if (!槽节点.has_value() || 槽节点->类型 != 节点类型::特征
            || 槽节点->稳定主键.命名域 != static_cast<std::uint64_t>(
                节点稳定主键命名域::实例特征槽身份)
            || !宿主节点.has_value() || !是合法特征宿主类型(宿主节点->类型)
            || !定义节点.has_value() || 定义节点->类型 != 节点类型::特征
            || 定义节点->稳定主键.命名域 != static_cast<std::uint64_t>(
                节点稳定主键命名域::抽象特征定义身份)
            || !值节点.has_value() || 值节点->类型 != 节点类型::特征值) {
            return {合同结果状态::内部错误, 合同结果原因::权威读回不一致};
        }
        const auto 记录 = 特征值类型化记录只读访问器(*记录仓_)
            .读取当前记录(当前值组.front().目标节点);
        if (!记录.可读()) {
            return {合同结果状态::内部错误, 合同结果原因::权威读回不一致};
        }
        return {合同结果状态::成功, 合同结果原因::无,
            实例特征槽位值式材料{
                实例槽,
                模板组.front().目标节点,
                当前值组.front().目标节点,
                宿主组.front(),
                模板组.front(),
                当前值组.front(),
                记录.记录->原始值版本,
                记录.记录->原始值}};
    }

    static bool 新实例槽位请求完整(const 新实例槽位发布请求& 请求) noexcept {
        return 句柄有效(请求.宿主) && 句柄有效(请求.抽象定义)
            && 句柄有效(请求.来源)
            && 主键属于(请求.实例槽主键, 节点稳定主键命名域::实例特征槽身份)
            && 主键属于(请求.特征值主键, 节点稳定主键命名域::特征值身份)
            && 请求.原始值.完整();
    }

    static bool 实例槽位换代请求完整(
        const 实例槽位当前值换代请求& 请求) noexcept {
        return 句柄有效(请求.实例槽) && 句柄有效(请求.写前当前关系)
            && 句柄有效(请求.写前当前值) && 请求.写前原始值版本 != 0
            && 主键属于(请求.新特征值主键, 节点稳定主键命名域::特征值身份)
            && 句柄有效(请求.来源) && 请求.新原始值.完整();
    }

    static bool 特征批次请求完整(const 特征批次变更请求& 请求) noexcept {
        if (!请求.批次身份.有效() || 请求.业务规则版本 == 0
            || !句柄有效(请求.宿主) || 请求.项目组.empty()) {
            return false;
        }
        for (std::size_t 序号 = 0; 序号 < 请求.项目组.size(); ++序号) {
            const auto& 项目 = 请求.项目组[序号];
            if (项目.项目顺序号 != 序号
                || 项目.项目顺序号 > static_cast<std::uint64_t>(
                    std::numeric_limits<std::int64_t>::max())
                || !句柄有效(项目.抽象定义)
                || !句柄有效(项目.来源) || !项目.新原始值.完整()
                || !主键属于(
                    项目.新特征值主键, 节点稳定主键命名域::特征值身份)) {
                return false;
            }
            if (项目.种类 == 特征批次变更种类::初始) {
                if (!主键属于(
                        项目.实例槽主键, 节点稳定主键命名域::实例特征槽身份)
                    || 句柄有效(项目.实例槽) || 项目.写前当前关系.has_value()
                    || 项目.写前当前值.has_value()
                    || 项目.写前原始值版本.has_value()) {
                    return false;
                }
            } else if (项目.种类 == 特征批次变更种类::换代) {
                if (!句柄有效(项目.实例槽) || !项目.写前当前关系.has_value()
                    || !项目.写前当前值.has_value()
                    || !项目.写前原始值版本.has_value()
                    || !句柄有效(*项目.写前当前关系)
                    || !句柄有效(*项目.写前当前值)
                    || *项目.写前原始值版本 == 0) {
                    return false;
                }
            } else {
                return false;
            }
        }
        return true;
    }

    合同无值结果 复核新实例槽位写前(
        const 新实例槽位发布请求& 请求) const {
        auto 许可 = 事务域_->取得读取许可();
        if (!许可.有效()) {
            return {合同结果状态::许可竞争, 合同结果原因::并发许可失败};
        }
        const auto 宿主 = 节点_->读取节点(请求.宿主);
        const auto 定义 = 节点_->读取节点(请求.抽象定义);
        if (!宿主.has_value() || !定义.has_value()) {
            return {合同结果状态::入口拒绝, 合同结果原因::错版本};
        }
        if (!是合法特征宿主类型(宿主->类型) || 定义->类型 != 节点类型::特征
            || 定义->稳定主键.命名域 != static_cast<std::uint64_t>(
                节点稳定主键命名域::抽象特征定义身份)) {
            return {合同结果状态::入口拒绝, 合同结果原因::错类型};
        }
        if (!节点_->读取节点(请求.来源).has_value()) {
            return {合同结果状态::入口拒绝, 合同结果原因::错版本};
        }
        if (节点_->读取稳定主键当前身份(请求.实例槽主键).状态
                != 稳定主键当前身份状态::未占用
            || 节点_->读取稳定主键当前身份(请求.特征值主键).状态
                != 稳定主键当前身份状态::未占用) {
            return {合同结果状态::入口拒绝, 合同结果原因::同键异义};
        }
        const auto 关系组 = 读取关系当前版本组();
        const auto 宿主槽位组 = 筛选当前有效关系(
            关系组, 请求.宿主, 关系类型::特征实例角色, 宿主槽角色);
        for (const auto& 宿主槽位 : 宿主槽位组) {
            const auto 模板组 = 筛选当前有效关系(
                关系组, 宿主槽位.目标节点,
                关系类型::特征实例角色, 定义模板角色);
            if (模板组.size() != 1) {
                return {合同结果状态::内部错误, 合同结果原因::基数不满足};
            }
            if (模板组.front().目标节点 == 请求.抽象定义) {
                return {合同结果状态::入口拒绝, 合同结果原因::同键异义};
            }
        }
        return {合同结果状态::成功, 合同结果原因::无};
    }

    合同无值结果 复核新实例槽位写前_会话(
        节点直接身份结构写入会话& 会话,
        const 新实例槽位发布请求& 请求) const {
        const auto 宿主 = 会话.读取节点(请求.宿主);
        const auto 定义 = 会话.读取节点(请求.抽象定义);
        const auto 来源 = 会话.读取节点(请求.来源);
        if (!宿主.has_value() || !定义.has_value() || !来源.has_value()) {
            return {合同结果状态::写前漂移, 合同结果原因::错版本};
        }
        if (!是合法特征宿主类型(宿主->类型) || 定义->类型 != 节点类型::特征
            || 定义->稳定主键.命名域 != static_cast<std::uint64_t>(
                节点稳定主键命名域::抽象特征定义身份)) {
            return {合同结果状态::入口拒绝, 合同结果原因::错类型};
        }
        if (会话.读取稳定主键当前身份(请求.实例槽主键).状态
                != 稳定主键当前身份状态::未占用
            || 会话.读取稳定主键当前身份(请求.特征值主键).状态
                != 稳定主键当前身份状态::未占用) {
            return {合同结果状态::写前漂移, 合同结果原因::同键异义};
        }
        const auto 关系组 = 读取关系当前版本组();
        const auto 宿主槽位组 = 筛选当前有效关系(
            关系组, 请求.宿主, 关系类型::特征实例角色, 宿主槽角色);
        for (const auto& 宿主槽位 : 宿主槽位组) {
            const auto 模板组 = 筛选当前有效关系(
                关系组, 宿主槽位.目标节点,
                关系类型::特征实例角色, 定义模板角色);
            if (模板组.size() != 1) {
                return {合同结果状态::内部错误, 合同结果原因::基数不满足};
            }
            if (模板组.front().目标节点 == 请求.抽象定义) {
                return {合同结果状态::写前漂移, 合同结果原因::同键异义};
            }
        }
        return {合同结果状态::成功, 合同结果原因::无};
    }

    合同无值结果 复核换代写前_会话(
        节点直接身份结构写入会话& 会话,
        const 实例槽位当前值换代请求& 请求) const {
        const auto 槽 = 会话.读取节点(请求.实例槽);
        const auto 旧值 = 会话.读取节点(请求.写前当前值);
        const auto 来源 = 会话.读取节点(请求.来源);
        const auto 当前关系 = 会话.读取关系(请求.写前当前关系);
        if (!槽.has_value() || !旧值.has_value() || !来源.has_value()
            || !当前关系.has_value()) {
            return {合同结果状态::写前漂移, 合同结果原因::错版本};
        }
        if (槽->类型 != 节点类型::特征 || 旧值->类型 != 节点类型::特征值
            || 当前关系->类型 != 关系类型::特征实例角色
            || 当前关系->顺序号 != 当前值角色
            || 当前关系->源节点 != 请求.实例槽
            || 当前关系->目标节点 != 请求.写前当前值
            || 当前关系->状态 != 记录状态::有效) {
            return {合同结果状态::写前漂移, 合同结果原因::值归属不一致};
        }
        const auto 类型记录 = 特征值类型化记录只读访问器(*记录仓_)
            .读取当前记录(请求.写前当前值);
        if (!类型记录.可读()) {
            return {类型记录.状态 == 特征值类型化记录读取状态::许可竞争
                    ? 合同结果状态::许可竞争 : 合同结果状态::内部错误,
                类型记录.状态 == 特征值类型化记录读取状态::许可竞争
                    ? 合同结果原因::并发许可失败 : 合同结果原因::权威读回不一致};
        }
        if (类型记录.记录->原始值版本 != 请求.写前原始值版本) {
            return {合同结果状态::写前漂移, 合同结果原因::错版本};
        }
        if (会话.读取稳定主键当前身份(请求.新特征值主键).状态
            != 稳定主键当前身份状态::未占用) {
            return {合同结果状态::写前漂移, 合同结果原因::同键异义};
        }
        return {合同结果状态::成功, 合同结果原因::无};
    }

    合同无值结果 复核特征批次写前(const 特征批次变更请求& 请求) const {
        auto 许可 = 事务域_->取得读取许可();
        if (!许可.有效()) {
            return {合同结果状态::许可竞争, 合同结果原因::并发许可失败};
        }
        const auto 宿主 = 节点_->读取节点(请求.宿主);
        if (!宿主.has_value()) {
            return {合同结果状态::入口拒绝, 合同结果原因::错版本};
        }
        if (!是合法特征宿主类型(宿主->类型)) {
            return {合同结果状态::入口拒绝, 合同结果原因::错类型};
        }
        const auto 关系组 = 读取关系当前版本组();
        for (std::size_t 序号 = 0; 序号 < 请求.项目组.size(); ++序号) {
            const auto& 项目 = 请求.项目组[序号];
            const auto 定义 = 节点_->读取节点(项目.抽象定义);
            const auto 来源 = 节点_->读取节点(项目.来源);
            if (!定义.has_value() || !来源.has_value()) {
                return {合同结果状态::入口拒绝, 合同结果原因::错版本};
            }
            if (定义->类型 != 节点类型::特征
                || 定义->稳定主键.命名域 != static_cast<std::uint64_t>(
                    节点稳定主键命名域::抽象特征定义身份)) {
                return {合同结果状态::入口拒绝, 合同结果原因::错类型};
            }
            if (节点_->读取稳定主键当前身份(项目.新特征值主键).状态
                != 稳定主键当前身份状态::未占用) {
                return {合同结果状态::入口拒绝, 合同结果原因::同键异义};
            }
            for (std::size_t 已有序号 = 0; 已有序号 < 序号; ++已有序号) {
                const auto& 已有 = 请求.项目组[已有序号];
                if (已有.新特征值主键 == 项目.新特征值主键
                    || (已有.种类 == 特征批次变更种类::换代
                        && 项目.种类 == 特征批次变更种类::换代
                        && 已有.实例槽 == 项目.实例槽)) {
                    return {合同结果状态::入口拒绝, 合同结果原因::同键异义};
                }
            }
            if (项目.种类 == 特征批次变更种类::初始) {
                if (节点_->读取稳定主键当前身份(项目.实例槽主键).状态
                    != 稳定主键当前身份状态::未占用) {
                    return {合同结果状态::入口拒绝, 合同结果原因::同键异义};
                }
                for (std::size_t 已有序号 = 0; 已有序号 < 序号; ++已有序号) {
                    const auto& 已有 = 请求.项目组[已有序号];
                    if (已有.种类 == 特征批次变更种类::初始
                        && (已有.实例槽主键 == 项目.实例槽主键
                            || 已有.抽象定义 == 项目.抽象定义)) {
                        return {合同结果状态::入口拒绝, 合同结果原因::同键异义};
                    }
                }
                const auto 宿主槽位组 = 筛选当前有效关系(
                    关系组, 请求.宿主, 关系类型::特征实例角色, 宿主槽角色);
                for (const auto& 宿主槽位 : 宿主槽位组) {
                    const auto 模板组 = 筛选当前有效关系(
                        关系组, 宿主槽位.目标节点,
                        关系类型::特征实例角色, 定义模板角色);
                    if (模板组.size() != 1) {
                        return {合同结果状态::内部错误, 合同结果原因::基数不满足};
                    }
                    if (模板组.front().目标节点 == 项目.抽象定义) {
                        return {合同结果状态::入口拒绝, 合同结果原因::同键异义};
                    }
                }
                continue;
            }
            std::vector<正式关系记录> 宿主组;
            for (const auto& 关系 : 关系组) {
                if (关系.状态 == 记录状态::有效
                    && 关系.类型 == 关系类型::特征实例角色
                    && 关系.顺序号 == 宿主槽角色
                    && 关系.目标节点 == 项目.实例槽) {
                    宿主组.push_back(关系);
                }
            }
            const auto 模板组 = 筛选当前有效关系(
                关系组, 项目.实例槽, 关系类型::特征实例角色, 定义模板角色);
            const auto 当前值组 = 筛选当前有效关系(
                关系组, 项目.实例槽, 关系类型::特征实例角色, 当前值角色);
            if (宿主组.size() != 1 || 模板组.size() != 1 || 当前值组.size() != 1) {
                return {合同结果状态::内部错误, 合同结果原因::基数不满足};
            }
            if (宿主组.front().源节点 != 请求.宿主
                || 模板组.front().目标节点 != 项目.抽象定义) {
                return {合同结果状态::入口拒绝, 合同结果原因::值归属不一致};
            }
            const auto 当前关系句柄 = 形成正式关系句柄(
                项目.写前当前关系->仓库编号, 当前值组.front());
            if (当前关系句柄 != *项目.写前当前关系
                || 当前值组.front().目标节点 != *项目.写前当前值) {
                return {合同结果状态::写前漂移, 合同结果原因::错版本};
            }
            const auto 记录 = 特征值类型化记录只读访问器(*记录仓_)
                .读取当前记录(*项目.写前当前值);
            if (!记录.可读()) {
                return {记录.状态 == 特征值类型化记录读取状态::许可竞争
                        ? 合同结果状态::许可竞争 : 合同结果状态::内部错误,
                    记录.状态 == 特征值类型化记录读取状态::许可竞争
                        ? 合同结果原因::并发许可失败 : 合同结果原因::权威读回不一致};
            }
            if (记录.记录->原始值版本 != *项目.写前原始值版本) {
                return {合同结果状态::写前漂移, 合同结果原因::错版本};
            }
        }
        return {合同结果状态::成功, 合同结果原因::无};
    }

    合同无值结果 复核特征批次写前_会话(
        节点直接身份结构写入会话& 会话,
        const 特征批次变更请求& 请求) const {
        const auto 宿主 = 会话.读取节点(请求.宿主);
        if (!宿主.has_value()) {
            return {合同结果状态::写前漂移, 合同结果原因::错版本};
        }
        if (!是合法特征宿主类型(宿主->类型)) {
            return {合同结果状态::入口拒绝, 合同结果原因::错类型};
        }
        const auto 关系组 = 读取关系当前版本组();
        for (const auto& 项目 : 请求.项目组) {
            const auto 定义 = 会话.读取节点(项目.抽象定义);
            const auto 来源 = 会话.读取节点(项目.来源);
            if (!定义.has_value() || !来源.has_value()) {
                return {合同结果状态::写前漂移, 合同结果原因::错版本};
            }
            if (定义->类型 != 节点类型::特征
                || 定义->稳定主键.命名域 != static_cast<std::uint64_t>(
                    节点稳定主键命名域::抽象特征定义身份)) {
                return {合同结果状态::入口拒绝, 合同结果原因::错类型};
            }
            if (会话.读取稳定主键当前身份(项目.新特征值主键).状态
                != 稳定主键当前身份状态::未占用) {
                return {合同结果状态::写前漂移, 合同结果原因::同键异义};
            }
            if (项目.种类 == 特征批次变更种类::初始) {
                if (会话.读取稳定主键当前身份(项目.实例槽主键).状态
                    != 稳定主键当前身份状态::未占用) {
                    return {合同结果状态::写前漂移, 合同结果原因::同键异义};
                }
                const auto 宿主槽位组 = 筛选当前有效关系(
                    关系组, 请求.宿主, 关系类型::特征实例角色, 宿主槽角色);
                for (const auto& 宿主槽位 : 宿主槽位组) {
                    const auto 模板组 = 筛选当前有效关系(
                        关系组, 宿主槽位.目标节点,
                        关系类型::特征实例角色, 定义模板角色);
                    if (模板组.size() != 1) {
                        return {合同结果状态::内部错误, 合同结果原因::基数不满足};
                    }
                    if (模板组.front().目标节点 == 项目.抽象定义) {
                        return {合同结果状态::写前漂移, 合同结果原因::同键异义};
                    }
                }
                continue;
            }
            const auto 当前关系 = 会话.读取关系(*项目.写前当前关系);
            const auto 旧值 = 会话.读取节点(*项目.写前当前值);
            std::vector<正式关系记录> 宿主组;
            for (const auto& 关系 : 关系组) {
                if (关系.状态 == 记录状态::有效
                    && 关系.类型 == 关系类型::特征实例角色
                    && 关系.顺序号 == 宿主槽角色
                    && 关系.目标节点 == 项目.实例槽) {
                    宿主组.push_back(关系);
                }
            }
            const auto 模板组 = 筛选当前有效关系(
                关系组, 项目.实例槽, 关系类型::特征实例角色, 定义模板角色);
            if (!当前关系.has_value() || !旧值.has_value()
                || 宿主组.size() != 1 || 模板组.size() != 1
                || 宿主组.front().源节点 != 请求.宿主
                || 模板组.front().目标节点 != 项目.抽象定义
                || 当前关系->类型 != 关系类型::特征实例角色
                || 当前关系->顺序号 != 当前值角色
                || 当前关系->源节点 != 项目.实例槽
                || 当前关系->目标节点 != *项目.写前当前值
                || 当前关系->状态 != 记录状态::有效
                || 旧值->类型 != 节点类型::特征值) {
                return {合同结果状态::写前漂移, 合同结果原因::值归属不一致};
            }
            const auto 类型记录 = 特征值类型化记录只读访问器(*记录仓_)
                .读取当前记录(*项目.写前当前值);
            if (!类型记录.可读()) {
                return {类型记录.状态 == 特征值类型化记录读取状态::许可竞争
                        ? 合同结果状态::许可竞争 : 合同结果状态::内部错误,
                    类型记录.状态 == 特征值类型化记录读取状态::许可竞争
                        ? 合同结果原因::并发许可失败 : 合同结果原因::权威读回不一致};
            }
            if (类型记录.记录->原始值版本 != *项目.写前原始值版本) {
                return {合同结果状态::写前漂移, 合同结果原因::错版本};
            }
        }
        return {合同结果状态::成功, 合同结果原因::无};
    }

    带值结构写入结果<特征批次提交值式材料> 读取幂等批次结果(
        const 特征批次变更请求& 请求,
        const 节点直接特征批次记录& 已发布) const {
        if (!已发布.已发布 || !已发布.完整()) {
            return {合同结果状态::内部错误, 合同结果原因::权威读回不一致};
        }
        if (已发布.批次身份 != 请求.批次身份
            || 已发布.记录格式版本 != 节点直接特征批次记录::当前记录格式版本
            || 已发布.业务规则版本 != 请求.业务规则版本
            || 已发布.宿主 != 请求.宿主
            || 已发布.项目组.size() != 请求.项目组.size()) {
            return {合同结果状态::入口拒绝, 合同结果原因::同键异义};
        }
        auto 许可 = 事务域_->取得读取许可();
        if (!许可.有效()) {
            return {合同结果状态::许可竞争, 合同结果原因::并发许可失败};
        }
        const auto 关系组 = 读取关系当前版本组();
        特征批次提交值式材料 材料;
        材料.批次身份 = 请求.批次身份;
        材料.业务规则版本 = 请求.业务规则版本;
        材料.宿主 = 请求.宿主;
        try {
            材料.项目组.reserve(请求.项目组.size());
        } catch (...) {
            return {合同结果状态::内部错误, 合同结果原因::权威读回不一致};
        }

        for (std::size_t 序号 = 0; 序号 < 请求.项目组.size(); ++序号) {
            const auto& 请求项目 = 请求.项目组[序号];
            const auto& 发布项目 = 已发布.项目组[序号];
            if (发布项目.项目顺序号 != 请求项目.项目顺序号
                || 发布项目.定义 != 请求项目.抽象定义
                || 发布项目.来源 != 请求项目.来源
                || 发布项目.宿主 != 请求.宿主
                || 发布项目.写前当前关系 != 请求项目.写前当前关系
                || 发布项目.写前当前值 != 请求项目.写前当前值
                || 发布项目.写前原始值版本 != 请求项目.写前原始值版本) {
                return {合同结果状态::入口拒绝, 合同结果原因::同键异义};
            }
            const auto 槽节点 = 节点_->读取节点(发布项目.实例槽);
            const auto 值节点 = 节点_->读取节点(发布项目.新特征值);
            if (!槽节点.has_value() || 槽节点->类型 != 节点类型::特征
                || !值节点.has_value() || 值节点->类型 != 节点类型::特征值) {
                return {合同结果状态::内部错误, 合同结果原因::权威读回不一致};
            }
            if (值节点->稳定主键 != 请求项目.新特征值主键) {
                return {合同结果状态::入口拒绝, 合同结果原因::同键异义};
            }
            if (请求项目.种类 == 特征批次变更种类::初始) {
                if (槽节点->稳定主键 != 请求项目.实例槽主键
                    || 请求项目.写前当前关系.has_value()) {
                    return {合同结果状态::入口拒绝, 合同结果原因::同键异义};
                }
            } else if (发布项目.实例槽 != 请求项目.实例槽
                || !请求项目.写前当前关系.has_value()) {
                return {合同结果状态::入口拒绝, 合同结果原因::同键异义};
            }

            const auto 类型记录 = 特征值类型化记录只读访问器(*记录仓_)
                .读取当前记录(发布项目.新特征值);
            if (!类型记录.可读()) {
                return {类型记录.状态 == 特征值类型化记录读取状态::许可竞争
                        ? 合同结果状态::许可竞争 : 合同结果状态::内部错误,
                    类型记录.状态 == 特征值类型化记录读取状态::许可竞争
                        ? 合同结果原因::并发许可失败 : 合同结果原因::权威读回不一致};
            }
            if (!(类型记录.记录->原始值 == 请求项目.新原始值)) {
                return {合同结果状态::入口拒绝, 合同结果原因::同键异义};
            }
            std::vector<正式关系记录> 宿主组;
            for (const auto& 关系 : 关系组) {
                if (关系.状态 == 记录状态::有效
                    && 关系.类型 == 关系类型::特征实例角色
                    && 关系.顺序号 == 宿主槽角色
                    && 关系.源节点 == 请求.宿主
                    && 关系.目标节点 == 发布项目.实例槽) {
                    宿主组.push_back(关系);
                }
            }
            const auto 模板组 = 筛选当前有效关系(
                关系组, 发布项目.实例槽,
                关系类型::特征实例角色, 定义模板角色);
            std::vector<正式关系记录> 发布关系组;
            for (const auto& 关系 : 关系组) {
                if (关系.关系编号 == 发布项目.发布后当前关系.关系编号
                    && 关系.类型 == 关系类型::特征实例角色
                    && 关系.顺序号 == 当前值角色
                    && 关系.源节点 == 发布项目.实例槽
                    && 关系.目标节点 == 发布项目.新特征值) {
                    发布关系组.push_back(关系);
                }
            }
            if (宿主组.size() != 1 || 模板组.size() != 1
                || 模板组.front().目标节点 != 请求项目.抽象定义
                || 发布关系组.size() != 1) {
                return {合同结果状态::内部错误, 合同结果原因::权威读回不一致};
            }
            try {
                材料.项目组.push_back({
                    发布项目.实例槽,
                    请求项目.抽象定义,
                    发布项目.新特征值,
                    宿主组.front(),
                    模板组.front(),
                    发布关系组.front(),
                    类型记录.记录->原始值版本,
                    类型记录.记录->原始值});
            } catch (...) {
                return {合同结果状态::内部错误, 合同结果原因::权威读回不一致};
            }
        }
        const auto 结构版本 = 特征值类型化记录只读访问器(*记录仓_)
            .读取结构版本();
        if (结构版本 == 0) {
            return {合同结果状态::许可竞争, 合同结果原因::并发许可失败};
        }
        return {合同结果状态::幂等读回, 合同结果原因::无,
            std::move(材料), 结构版本};
    }

    std::optional<关系句柄> 写入新特征值_会话(
        节点直接身份结构写入会话& 会话,
        节点句柄 实例槽,
        节点稳定主键 特征值主键,
        节点句柄 来源,
        std::int64_t 来源顺序号,
        const 特征值原始值式材料& 原始值,
        特征值类型化记录事务参与者& 记录参与者,
        节点句柄& 输出特征值) const {
        const auto 值结果 = 会话.创建节点候选(节点类型::特征值, 特征值主键);
        if (!值结果.成功()) 抛出事务内部不一致();
        输出特征值 = *值结果.值;
        if (!会话.读取节点(输出特征值).has_value()) 抛出事务内部不一致();
        const auto 当前关系 = 会话.创建关系候选(
            关系类型::特征实例角色, 实例槽, 输出特征值, 当前值角色);
        const auto 来源关系 = 会话.创建关系候选(
            关系类型::因果来源, 输出特征值, 来源, 来源顺序号);
        if (!当前关系.成功() || !来源关系.成功()
            || !会话.读取关系(*当前关系.值).has_value()
            || !会话.读取关系(*来源关系.值).has_value()
            || !记录参与者.登记初始记录({输出特征值, 1, 原始值})) {
            抛出事务内部不一致();
        }
        return 当前关系.值;
    }

    bool 写入节点索引_会话(
        节点直接身份结构写入会话& 会话,
        const 节点稳定主键& 主键,
        节点句柄 节点,
        std::uint32_t 命名域) const {
        可重建索引记录 记录;
        记录.物理键 = {索引所有者身份, 命名域, 1, 1, 主键.键值};
        记录.目标种类 = 索引目标种类::节点;
        记录.节点 = 节点;
        const auto 结果 = 会话.创建索引候选(记录);
        if (!结果.成功()) return false;
        const auto 读回 = 会话.读取索引物理键(记录.物理键);
        return 读回.has_value()
            && 读回->物理键 == 记录.物理键
            && 读回->目标种类 == 索引目标种类::节点
            && 读回->节点 == 节点
            && !句柄有效(读回->关系);
    }

    static 无值映射结果 映射结构写入结果(
        const 节点直接身份结构写入结果& 结果) noexcept {
        switch (结果.状态) {
        case 节点直接身份结构写入状态::已提交:
            return {合同结果状态::成功, 合同结果原因::无};
        case 节点直接身份结构写入状态::幂等读回:
            return {合同结果状态::幂等读回, 合同结果原因::无};
        case 节点直接身份结构写入状态::许可拒绝:
            return {合同结果状态::许可竞争, 合同结果原因::并发许可失败};
        case 节点直接身份结构写入状态::版本漂移:
            return {合同结果状态::写前漂移, 合同结果原因::错版本};
        case 节点直接身份结构写入状态::身份冲突:
            return {合同结果状态::入口拒绝, 合同结果原因::同键异义};
        case 节点直接身份结构写入状态::入口拒绝:
            return {合同结果状态::入口拒绝, 合同结果原因::无效身份};
        default:
            return {合同结果状态::内部错误, 合同结果原因::事务阶段不一致};
        }
    }

    节点直接身份结构事务域* 事务域_ = nullptr;
    节点直接身份仓库* 节点_ = nullptr;
    正式关系仓库* 关系_ = nullptr;
    可重建索引仓库* 索引_ = nullptr;
    特征值类型化记录仓* 记录仓_ = nullptr;
    mutable 节点直接特征批次记录仓 批次记录仓_;
};

}
