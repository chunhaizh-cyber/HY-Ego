// 文件规则：用途观察算法只形成和比较调用期固定形状纯值；不得读写仓库、线程状态、运行期、持久化或发布结构。
module;

#include "../核心/句柄.h"

#include <cstdint>
#include <limits>
#include <optional>
#include <utility>

export module 海中鱼巣.领域.算法.用途观察;

import 海中鱼巣.领域.材料.用途观察;
import 海中鱼巣.领域.材料.用途事件;
import 海中鱼巣.领域.材料.因果模式;
import 海中鱼巣.领域.算法.用途事件;
import 海中鱼巣.领域.算法.因果模式;
import 海中鱼巣.线程.协议.任务执行请求;

namespace 海中鱼巣 {

namespace 用途观察算法内部 {

用途观察纯值形成结果 形成入口拒绝(用途观察纯值形成原因 原因) {
    return {用途观察纯值形成状态::入口拒绝, 原因, std::nullopt};
}

用途观察纯值形成结果 形成不支持(用途观察纯值形成原因 原因) {
    return {用途观察纯值形成状态::不支持, 原因, std::nullopt};
}

用途观察纯值形成结果 形成内部不一致(用途观察纯值形成原因 原因) {
    return {用途观察纯值形成状态::内部不一致, 原因, std::nullopt};
}

用途观察同账比较结果 形成比较结果(
    用途观察同账比较结论 结论,
    用途观察同账比较原因 原因) noexcept {
    const 用途观察同账比较结果 结果{结论, 原因};
    return 结果.合法() ? 结果 : 用途观察同账比较结果{};
}

std::optional<用途观察纯值形成原因> 映射入口拒绝原因(
    用途事件拒绝原因 原因) noexcept {
    switch (原因) {
    case 用途事件拒绝原因::请求不完整:
        return 用途观察纯值形成原因::请求不完整;
    case 用途事件拒绝原因::来源冻结不完整:
        return 用途观察纯值形成原因::来源冻结不完整;
    case 用途事件拒绝原因::结果尚未正式收口:
        return 用途观察纯值形成原因::结果尚未正式收口;
    case 用途事件拒绝原因::非新版完整回执:
        return 用途观察纯值形成原因::非新版完整回执;
    case 用途事件拒绝原因::来源冻结回合不一致:
        return 用途观察纯值形成原因::来源冻结回合不一致;
    default:
        return std::nullopt;
    }
}

bool 节点句柄为空(const 节点句柄& 句柄) noexcept {
    return 句柄.仓库编号 == 0 && 句柄.节点编号 == 0 && 句柄.版本号 == 0;
}

bool 因果概率分量合法(const 因果概率分量& 分量) noexcept {
    if (!分量.因果身份.当前版本兼容()
        || !分量.因果身份.原因结果角色不同()
        || 分量.机会数 == 0
        || 分量.正结果数 > 分量.机会数
        || 分量.负结果数 > 分量.机会数
        || 分量.正结果数 != 分量.机会数 - 分量.负结果数
        || 分量.Q10000 > 因果概率满量程
        || 分量.正结果数
            > std::numeric_limits<std::uint64_t>::max() / 因果概率满量程) {
        return false;
    }
    return 分量.Q10000
        == 分量.正结果数 * 因果概率满量程 / 分量.机会数;
}

bool 因果概率分量相同(
    const 因果概率分量& 左,
    const 因果概率分量& 右) noexcept {
    return 因果概率分量合法(左) && 因果概率分量合法(右)
        && 因果完整结构键相同(左.因果身份, 右.因果身份)
        && 左.机会数 == 右.机会数
        && 左.正结果数 == 右.正结果数
        && 左.负结果数 == 右.负结果数
        && 左.Q10000 == 右.Q10000;
}

bool 语义身份相同(
    const 用途观察语义身份& 左,
    const 用途观察语义身份& 右) noexcept {
    return 左.完整() && 右.完整()
        && 左.任务 == 右.任务 && 左.任务序号 == 右.任务序号;
}

bool 不可变核心相同(
    const 用途观察不可变核心& 左,
    const 用途观察不可变核心& 右) noexcept {
    return 左.完整() && 右.完整()
        && 左.需求 == 右.需求
        && 左.选择记录 == 右.选择记录
        && 左.方法 == 右.方法
        && 左.动作 == 右.动作
        && 左.场景 == 右.场景
        && 左.主体 == 右.主体
        && 左.目标状态 == 右.目标状态
        && 左.实际状态 == 右.实际状态
        && 左.动态证据 == 右.动态证据
        && 因果概率分量相同(左.历史概率, 右.历史概率);
}

bool 阶段负载相同(
    const 用途观察阶段负载& 左,
    const 用途观察阶段负载& 右) noexcept {
    return 左.合法() && 右.合法()
        && 左.正式结果 == 右.正式结果
        && 左.任务达成 == 右.任务达成
        && 左.需求结算 == 右.需求结算
        && 左.观察阶段 == 右.观察阶段
        && 左.正式结算状态 == 右.正式结算状态;
}

bool 身份材料一致(const 用途事件材料& 事件) noexcept {
    const auto& 冻结 = 事件.冻结来源;
    const auto& 请求 = 冻结.任务执行请求;
    const auto& 回执 = 事件.结果来源.完整回执;
    if (!冻结任务执行请求完整(请求)
        || !回执.来源执行请求.has_value()
        || !冻结任务执行请求相同(请求, *回执.来源执行请求)
        || !句柄有效(事件.任务) || 冻结.冻结任务序号 == 0) {
        return false;
    }
    return 事件.任务 == 请求.调度请求.任务
        && 事件.任务 == 请求.任务材料.身份.节点
        && 事件.任务 == 回执.来源执行请求->调度请求.任务
        && 事件.任务 == 回执.来源执行请求->任务材料.身份.节点
        && 事件.任务 == 回执.句柄组.目标任务
        && 冻结.冻结任务序号 == 请求.调度请求.任务序号
        && 冻结.冻结任务序号
            == 回执.来源执行请求->调度请求.任务序号
        && 冻结.冻结任务序号 == 回执.来源任务序号;
}

bool 内容材料一致(const 用途事件材料& 事件) {
    const auto& 冻结请求 = 事件.冻结来源.任务执行请求;
    const auto& 任务 = 冻结请求.任务材料;
    const auto& 回执 = 事件.结果来源.完整回执;
    const auto& 目标裁决 = 事件.结果来源.目标裁决;
    if (!任务.当前选择.has_value()
        || !句柄有效(事件.需求) || !句柄有效(事件.选择记录)
        || !句柄有效(事件.方法) || !句柄有效(事件.动作)
        || !句柄有效(事件.场景) || !句柄有效(事件.主体)
        || !句柄有效(事件.目标状态) || !句柄有效(事件.实际状态)
        || !句柄有效(事件.动态证据)) {
        return false;
    }
    if (事件.需求 != 任务.来源需求
        || 事件.选择记录 != 任务.当前选择->记录身份.节点
        || 事件.方法 != 冻结请求.方法材料.身份.节点
        || 事件.动作 != 冻结请求.动作材料.身份.节点
        || 事件.场景 != 任务.场景
        || 事件.主体 != 任务.虚拟存在
        || 事件.目标状态 != 任务.目标状态
        || 事件.实际状态 != 回执.句柄组.实际结果状态
        || 事件.动态证据 != 回执.句柄组.动态证据
        || 事件.方法 != 回执.句柄组.目标方法
        || 事件.动作 != 回执.句柄组.目标动作入口
        || 事件.场景 != 回执.句柄组.场景
        || 事件.主体 != 回执.句柄组.主体
        || !目标裁决.成功()
        || 事件.需求 != 目标裁决.需求
        || 事件.目标状态 != 目标裁决.目标状态
        || 事件.实际状态 != 目标裁决.实际状态
        || 事件.目标状态 != 目标裁决.目标状态材料.状态节点
        || 事件.实际状态 != 目标裁决.实际状态材料.状态节点
        || 事件.场景 != 目标裁决.实际状态材料.场景
        || 事件.主体 != 目标裁决.实际状态材料.主体) {
        return false;
    }

    const auto 身份结果 = 形成因果完整结构键(事件.冻结来源.因果候选);
    const auto 重新形成分量 = 形成因果概率分量(事件.冻结来源.因果候选);
    if (!身份结果.成功() || !重新形成分量.has_value()
        || !因果完整结构键相同(
            *身份结果.身份, 事件.效用.历史概率.因果身份)
        || !因果概率分量相同(*重新形成分量, 事件.效用.历史概率)) {
        return false;
    }
    const auto& 候选 = 事件.冻结来源.因果候选;
    return 候选.机会数 == 事件.效用.历史概率.机会数
        && 候选.正结果数 == 事件.效用.历史概率.正结果数
        && 候选.负结果数 == 事件.效用.历史概率.负结果数
        && 候选.Q10000 == 事件.效用.历史概率.Q10000;
}

template <typename 正式结算材料类型>
bool 因果引用一致(
    const 节点句柄& 参数因果引用,
    const 正式结算材料类型& 正式结算) noexcept {
    if (节点句柄为空(参数因果引用)) {
        return !正式结算.因果引用.has_value()
            && !正式结算.因果引用关系.has_value();
    }
    return 句柄有效(参数因果引用)
        && 正式结算.因果引用.has_value()
        && *正式结算.因果引用 == 参数因果引用;
}

bool 正式结算与事件一致(
    const 用途事件材料& 事件,
    节点句柄& 正式结算状态) noexcept {
    const auto& 结算结果 = 事件.结果来源.需求结算;
    if (!结算结果.成功() || !结算结果.材料.正式结算.has_value()
        || !结算结果.材料.最近结算状态.has_value()
        || 结算结果.材料.当前结算 != 分层需求结算结论::已满足) {
        return false;
    }
    const auto& 正式 = *结算结果.材料.正式结算;
    const auto& 状态 = 正式.结算状态;
    if (!正式.完整() || !状态.完整实例状态()
        || !句柄有效(状态.状态节点)
        || 正式.需求 != 事件.需求
        || 正式.来源任务 != 事件.任务
        || 正式.目标状态 != 事件.目标状态
        || 正式.实际状态 != 事件.实际状态
        || 正式.动态证据 != 事件.动态证据
        || 状态.幂等主键 != 事件.结果来源.参数.结算状态幂等主键
        || 状态.发生时间戳 != 事件.结果来源.参数.结算发生时间戳
        || 状态.状态值
            != static_cast<std::int64_t>(分层需求结算结论::已满足)
        || 状态.场景 != 事件.场景 || 状态.主体 != 事件.主体
        || !因果引用一致(事件.结果来源.参数.因果引用, 正式)
        || *结算结果.材料.最近结算状态 != 状态.状态节点) {
        return false;
    }
    正式结算状态 = 状态.状态节点;
    return true;
}

bool 形成阶段负载(
    const 用途事件材料& 事件,
    用途观察阶段负载& 阶段负载) noexcept {
    const auto& 效用 = 事件.效用;
    if (事件.结果来源.正式结果 != 效用.正式结果) return false;
    阶段负载.正式结果 = 效用.正式结果;
    阶段负载.任务达成 = 效用.任务达成;
    阶段负载.需求结算 = 效用.需求结算;
    阶段负载.观察阶段 = 效用.观察阶段;

    if (效用.观察阶段 == 用途观察阶段::最终已结算) {
        节点句柄 状态;
        if (!正式结算与事件一致(事件, 状态)) return false;
        阶段负载.正式结算状态 = 状态;
    } else {
        const auto& 结算材料 = 事件.结果来源.需求结算.材料;
        if (结算材料.正式结算.has_value()
            || 结算材料.最近结算状态.has_value()) {
            return false;
        }
    }
    return 阶段负载.合法();
}

}

}

export namespace 海中鱼巣 {

用途观察纯值形成结果 形成用途观察纯值候选(
    const 用途事件结果& 事件结果,
    std::uint32_t 目标格式版本) {
    using namespace 用途观察算法内部;

    if (事件结果.状态 == 用途事件处理状态::入口拒绝) {
        const auto 原因 = 映射入口拒绝原因(事件结果.拒绝原因);
        if (原因.has_value() && !事件结果.事件.has_value()) {
            return 形成入口拒绝(*原因);
        }
        return 形成内部不一致(用途观察纯值形成原因::正式结果材料矛盾);
    }
    if (事件结果.状态 == 用途事件处理状态::不支持) {
        if (事件结果.拒绝原因 == 用途事件拒绝原因::规则版本不支持
            && !事件结果.事件.has_value()) {
            return 形成不支持(用途观察纯值形成原因::规则版本不支持);
        }
        return 形成内部不一致(用途观察纯值形成原因::正式结果材料矛盾);
    }
    if (事件结果.状态 != 用途事件处理状态::已形成
        || 事件结果.拒绝原因 != 用途事件拒绝原因::无
        || !事件结果.事件.has_value()) {
        return 形成内部不一致(用途观察纯值形成原因::正式结果材料矛盾);
    }

    if (目标格式版本 == 0) {
        return 形成入口拒绝(用途观察纯值形成原因::请求不完整);
    }
    if (目标格式版本 != 用途观察纯值合同格式版本) {
        return 形成不支持(用途观察纯值形成原因::目标格式不支持);
    }

    const auto& 事件 = *事件结果.事件;
    if (!身份材料一致(事件)) {
        return 形成内部不一致(用途观察纯值形成原因::身份材料矛盾);
    }
    if (!内容材料一致(事件)) {
        return 形成内部不一致(用途观察纯值形成原因::内容材料矛盾);
    }

    用途观察阶段负载 阶段负载;
    if (!形成阶段负载(事件, 阶段负载)) {
        return 形成内部不一致(用途观察纯值形成原因::阶段材料矛盾);
    }

    用途观察纯值候选 候选{
        目标格式版本,
        {事件.任务, 事件.冻结来源.冻结任务序号},
        {事件.需求, 事件.选择记录, 事件.方法, 事件.动作,
            事件.场景, 事件.主体, 事件.目标状态, 事件.实际状态,
            事件.动态证据, 事件.效用.历史概率},
        阶段负载};
    const 用途观察语义身份 预期身份{
        事件.任务, 事件.冻结来源.冻结任务序号};
    const 用途观察不可变核心 预期核心{
        事件.需求, 事件.选择记录, 事件.方法, 事件.动作,
        事件.场景, 事件.主体, 事件.目标状态, 事件.实际状态,
        事件.动态证据, 事件.效用.历史概率};
    if (!候选.合法() || 候选.格式版本 != 目标格式版本
        || !语义身份相同(候选.身份, 预期身份)
        || !不可变核心相同(候选.不可变核心, 预期核心)
        || !阶段负载相同(候选.阶段负载, 阶段负载)) {
        return 形成内部不一致(用途观察纯值形成原因::算法不变量破坏);
    }

    用途观察纯值形成结果 结果{
        用途观察纯值形成状态::已形成,
        用途观察纯值形成原因::无,
        std::move(候选)};
    if (!结果.成功()) {
        return 形成内部不一致(用途观察纯值形成原因::算法不变量破坏);
    }
    return 结果;
}

用途观察同账比较结果 比较用途观察同账(
    const 用途观察纯值候选& 新候选,
    const 用途观察纯值候选& 既有候选) {
    using namespace 用途观察算法内部;

    if (新候选.格式版本 == 0) {
        return 形成比较结果(
            用途观察同账比较结论::内部不一致,
            用途观察同账比较原因::新候选非法);
    }
    if (既有候选.格式版本 == 0) {
        return 形成比较结果(
            用途观察同账比较结论::内部不一致,
            用途观察同账比较原因::既有候选非法);
    }
    if (新候选.格式版本 != 用途观察纯值合同格式版本
        || 既有候选.格式版本 != 用途观察纯值合同格式版本) {
        return 形成比较结果(
            用途观察同账比较结论::不支持,
            用途观察同账比较原因::格式版本不支持);
    }
    if (!新候选.合法()) {
        return 形成比较结果(
            用途观察同账比较结论::内部不一致,
            用途观察同账比较原因::新候选非法);
    }
    if (!既有候选.合法()) {
        return 形成比较结果(
            用途观察同账比较结论::内部不一致,
            用途观察同账比较原因::既有候选非法);
    }
    if (!语义身份相同(新候选.身份, 既有候选.身份)) {
        return 形成比较结果(
            用途观察同账比较结论::不同身份,
            用途观察同账比较原因::完整身份不同);
    }

    const bool 核心相同 = 不可变核心相同(
        新候选.不可变核心, 既有候选.不可变核心);
    if (核心相同 && 阶段负载相同(新候选.阶段负载, 既有候选.阶段负载)) {
        return 形成比较结果(
            用途观察同账比较结论::同账幂等,
            用途观察同账比较原因::完整内容相同);
    }
    if (核心相同
        && 既有候选.阶段负载.观察阶段 == 用途观察阶段::待结算
        && 新候选.阶段负载.观察阶段 == 用途观察阶段::最终已结算) {
        return 形成比较结果(
            用途观察同账比较结论::同账允许推进,
            用途观察同账比较原因::待结算推进最终);
    }
    if (!核心相同) {
        return 形成比较结果(
            用途观察同账比较结论::同账冲突,
            用途观察同账比较原因::不可变核心不同);
    }
    return 形成比较结果(
        用途观察同账比较结论::同账冲突,
        用途观察同账比较原因::阶段转换不允许);
}

}
