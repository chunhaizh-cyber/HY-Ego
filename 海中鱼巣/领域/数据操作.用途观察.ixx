// 文件规则：用途观察数据操作唯一解释 O1 物理身份、容量、结构写集与完整读回；不得向业务服务暴露仓库、许可或原始令牌。
module;

#include "../核心/主信息仓库.h"
#include "../核心/节点仓库.h"
#include "../核心/关系仓库.h"
#include "../核心/索引仓库.h"
#include "../核心/容错检查.h"

#include <algorithm>
#include <array>
#include <cstddef>
#include <cstdint>
#include <limits>
#include <optional>
#include <utility>
#include <vector>

export module 海中鱼巣.领域.数据操作.用途观察;

import 海中鱼巣.核心.执行器.结构写入;
import 海中鱼巣.领域.材料.用途观察;
import 海中鱼巣.领域.材料.因果模式;
import 海中鱼巣.领域.材料.用途事件;
import 海中鱼巣.领域.算法.用途观察;

export namespace 海中鱼巣 {

inline constexpr std::uint32_t 用途观察索引命名域 = 0x4F315332U;
inline constexpr std::uint32_t 用途观察索引规则版本 = 1;
inline constexpr std::size_t 用途观察物理身份字节数 = 36;
inline constexpr std::size_t 用途观察最大探测次数 = 1024;
inline constexpr std::uint64_t 单任务用途观察上限 = 1024;
inline constexpr std::uint64_t 全局用途观察上限 = 65536;
inline constexpr std::uint64_t 单条用途观察规范字节上限 = 2048;
inline constexpr std::uint64_t 全部用途观察规范字节上限 = 134217728;

std::optional<std::array<std::uint8_t, 用途观察物理身份字节数>>
形成用途观察物理身份字节(
    const 用途观察语义身份& 身份,
    std::uint32_t 格式版本) noexcept {
    if (!身份.完整() || 格式版本 != 用途观察纯值合同格式版本) return std::nullopt;
    std::array<std::uint8_t, 用途观察物理身份字节数> 输出{};
    const auto 写U32 = [&](std::size_t 偏移, std::uint32_t 值) {
        for (std::size_t 索引 = 0; 索引 < 4; ++索引) {
            输出[偏移 + 索引] = static_cast<std::uint8_t>(值 >> (索引 * 8));
        }
    };
    const auto 写U64 = [&](std::size_t 偏移, std::uint64_t 值) {
        for (std::size_t 索引 = 0; 索引 < 8; ++索引) {
            输出[偏移 + 索引] = static_cast<std::uint8_t>(值 >> (索引 * 8));
        }
    };
    写U32(0, 用途观察索引命名域);
    写U32(4, 格式版本);
    写U64(8, 身份.任务.仓库编号);
    写U64(16, 身份.任务.节点编号);
    写U32(24, 身份.任务.版本号);
    写U64(28, 身份.任务序号);
    return 输出;
}

std::optional<std::uint64_t> 计算用途观察物理哈希(
    const 用途观察语义身份& 身份,
    std::uint32_t 格式版本) noexcept {
    const auto 字节 = 形成用途观察物理身份字节(身份, 格式版本);
    if (!字节.has_value()) return std::nullopt;
    std::uint64_t 哈希 = 14695981039346656037ULL;
    for (const auto 当前 : *字节) {
        哈希 = (哈希 ^ 当前) * 1099511628211ULL;
    }
    return 哈希;
}

std::optional<std::uint64_t> 形成用途观察物理键(
    const 用途观察语义身份& 身份,
    std::uint32_t 格式版本,
    std::size_t 探测序号) noexcept {
    if (探测序号 >= 用途观察最大探测次数) return std::nullopt;
    const auto 原始起点 = 计算用途观察物理哈希(身份, 格式版本);
    if (!原始起点.has_value()) return std::nullopt;
    const std::uint64_t 非零起点 = *原始起点 == 0 ? 1 : *原始起点;
    const std::uint64_t 模数 = std::numeric_limits<std::uint64_t>::max();
    const std::uint64_t 基数 = 非零起点 - 1;
    const auto 增量 = static_cast<std::uint64_t>(探测序号);
    const std::uint64_t 余数 = 增量 != 0 && 基数 >= 模数 - 增量
        ? 基数 - (模数 - 增量)
        : 基数 + 增量;
    return 余数 + 1;
}

enum class 用途观察结构业务状态 : std::uint8_t {
    已新建 = 1,
    已幂等 = 2,
    已推进最终 = 3,
    入口拒绝 = 4,
    不支持 = 5,
    容量拒绝 = 6,
    同账冲突 = 7,
    内部不一致 = 8
};

enum class 用途观察结构业务原因 : std::uint8_t {
    无 = 0,
    数据操作未接域 = 1,
    候选不完整 = 2,
    目标格式不支持 = 3,
    句柄类型不匹配 = 4,
    单任务容量已满 = 5,
    全局容量已满 = 6,
    物理键探测耗尽 = 7,
    规范字节容量已满 = 8,
    不可变核心不同 = 9,
    阶段转换不允许 = 10,
    双证不一致 = 11,
    已发布结构不一致 = 12,
    读取资源失败 = 13,
    结构事务失败 = 14,
    纯值入口拒绝 = 15,
    纯值不支持 = 16,
    纯值内部不一致 = 17
};

struct 用途观察完整值式材料 {
    节点句柄 观察节点;
    主信息句柄 主信息;
    std::uint64_t 物理键 = 0;
    std::uint16_t 探测序号 = 0;
    用途观察纯值候选 候选;
    std::array<std::optional<节点句柄>, 33> 当前角色目标{};
    std::size_t 生命周期关系数量 = 0;
    bool 曾由待结算推进 = false;

    bool 完整() const noexcept {
        return 句柄有效(观察节点) && 句柄有效(主信息) && 物理键 != 0
            && 探测序号 < 用途观察最大探测次数 && 候选.合法()
            && 生命周期关系数量 >= 15 && 生命周期关系数量 <= 17;
    }
};

struct 用途观察结构业务结果 {
    用途观察结构业务状态 状态 = 用途观察结构业务状态::入口拒绝;
    用途观察结构业务原因 原因 = 用途观察结构业务原因::候选不完整;
    std::optional<用途观察完整值式材料> 材料;

    bool 成功() const noexcept {
        return (状态 == 用途观察结构业务状态::已新建
                || 状态 == 用途观察结构业务状态::已幂等
                || 状态 == 用途观察结构业务状态::已推进最终)
            && 原因 == 用途观察结构业务原因::无
            && 材料.has_value() && 材料->完整();
    }

    bool 合法() const noexcept {
        if (成功()) return true;
        if (材料.has_value() || 原因 == 用途观察结构业务原因::无) return false;
        switch (状态) {
        case 用途观察结构业务状态::入口拒绝:
            return 原因 == 用途观察结构业务原因::数据操作未接域
                || 原因 == 用途观察结构业务原因::候选不完整
                || 原因 == 用途观察结构业务原因::句柄类型不匹配
                || 原因 == 用途观察结构业务原因::纯值入口拒绝;
        case 用途观察结构业务状态::不支持:
            return 原因 == 用途观察结构业务原因::目标格式不支持
                || 原因 == 用途观察结构业务原因::纯值不支持;
        case 用途观察结构业务状态::容量拒绝:
            return 原因 == 用途观察结构业务原因::单任务容量已满
                || 原因 == 用途观察结构业务原因::全局容量已满
                || 原因 == 用途观察结构业务原因::物理键探测耗尽
                || 原因 == 用途观察结构业务原因::规范字节容量已满;
        case 用途观察结构业务状态::同账冲突:
            return 原因 == 用途观察结构业务原因::不可变核心不同
                || 原因 == 用途观察结构业务原因::阶段转换不允许;
        case 用途观察结构业务状态::内部不一致:
            return 原因 == 用途观察结构业务原因::双证不一致
                || 原因 == 用途观察结构业务原因::已发布结构不一致
                || 原因 == 用途观察结构业务原因::读取资源失败
                || 原因 == 用途观察结构业务原因::结构事务失败
                || 原因 == 用途观察结构业务原因::纯值内部不一致;
        default:
            return false;
        }
    }
};

enum class 用途观察结构读取状态 : std::uint8_t {
    已读取 = 1,
    未找到 = 2,
    入口拒绝 = 3,
    许可拒绝 = 4,
    内部不一致 = 5
};

struct 用途观察结构读取结果 {
    用途观察结构读取状态 状态 = 用途观察结构读取状态::入口拒绝;
    std::optional<用途观察完整值式材料> 材料;

    bool 成功() const noexcept {
        return 状态 == 用途观察结构读取状态::已读取
            && 材料.has_value() && 材料->完整();
    }
};

class 用途观察数据操作 final {
public:
    用途观察数据操作(
        结构事务接线 接线,
        主信息仓库& 主信息,
        节点仓库& 节点,
        关系仓库& 关系,
        索引仓库& 索引,
        std::uint64_t 关系仓库编号)
        : 接线_(std::move(接线)),
          主信息_(主信息),
          节点_(节点),
          关系_(关系),
          索引_(索引),
          节点仓库编号_(节点_.仓库编号()),
          关系仓库编号_(关系仓库编号),
          执行器_(接线_, &主信息_, &节点_, &关系_, &索引_) {
    }

    bool 有效() const noexcept {
        return 接线_.已接域() && 节点仓库编号_ != 0
            && 关系仓库编号_ != 0 && 执行器_.有效();
    }

    用途观察结构业务结果 发布候选(const 用途观察纯值候选& 候选) const {
        if (!有效()) return 形成业务失败(
            用途观察结构业务状态::入口拒绝,
            用途观察结构业务原因::数据操作未接域);
        if (候选.格式版本 == 0 || !候选.身份.完整()) return 形成业务失败(
            用途观察结构业务状态::入口拒绝,
            用途观察结构业务原因::候选不完整);
        if (候选.格式版本 != 用途观察纯值合同格式版本) return 形成业务失败(
            用途观察结构业务状态::不支持,
            用途观察结构业务原因::目标格式不支持);
        if (!候选.合法()) return 形成业务失败(
            用途观察结构业务状态::入口拒绝,
            用途观察结构业务原因::候选不完整);

        用途观察结构业务结果 业务结果 = 形成业务失败(
            用途观察结构业务状态::内部不一致,
            用途观察结构业务原因::结构事务失败);
        bool 已请求提交 = false;
        const auto 结构结果 = 执行器_.执行([&](结构写入会话& 会话) {
            业务结果 = 在会话中发布(会话, 候选, 已请求提交);
        });
        if (已请求提交) {
            if (结构结果.状态 == 结构写入状态::已提交 && 业务结果.成功()
                && (业务结果.状态 == 用途观察结构业务状态::已新建
                    || 业务结果.状态 == 用途观察结构业务状态::已推进最终)) {
                return 业务结果;
            }
            (void)追根因检查(false, L"用途观察请求提交后未形成唯一结构发布结果。");
            return 形成业务失败(
                用途观察结构业务状态::内部不一致,
                用途观察结构业务原因::结构事务失败);
        }
        if (结构结果.状态 == 结构写入状态::候选已撤销 && 业务结果.合法()) {
            return 业务结果;
        }
        if (结构结果.状态 == 结构写入状态::内部不一致
            && 业务结果.状态 == 用途观察结构业务状态::内部不一致
            && 业务结果.原因 == 用途观察结构业务原因::读取资源失败
            && 业务结果.合法()) {
            return 业务结果;
        }
        (void)追根因检查(false, L"用途观察逻辑内收口未形成完整撤销结果。");
        return 形成业务失败(
            用途观察结构业务状态::内部不一致,
            用途观察结构业务原因::结构事务失败);
    }

    用途观察结构读取结果 读取观察节点(节点句柄 观察节点) const {
        if (!有效() || !句柄有效(观察节点)) return {};
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) return {用途观察结构读取状态::许可拒绝, std::nullopt};
        const auto 解析 = 共享读取单条(观察节点, 许可.读取令牌());
        if (!解析.成功()) return {
            解析.状态 == 解析状态::未找到
                ? 用途观察结构读取状态::未找到
                : 用途观察结构读取状态::内部不一致,
            std::nullopt};
        if (!验证共享双证(解析, 许可.读取令牌())) {
            (void)追根因检查(false, L"用途观察完整读回无法通过单索引与角色一反向关系双证。");
            return {用途观察结构读取状态::内部不一致, std::nullopt};
        }
        return {用途观察结构读取状态::已读取, 解析.材料};
    }

    用途观察结构读取结果 读取完整身份(const 用途观察语义身份& 身份) const {
        if (!有效() || !身份.完整()) return {};
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) return {用途观察结构读取状态::许可拒绝, std::nullopt};
        const auto 双证 = 共享定位身份(身份, 许可.读取令牌());
        if (双证.内部不一致) {
            (void)追根因检查(false, L"用途观察按完整身份读取时双证不一致。");
            return {用途观察结构读取状态::内部不一致, std::nullopt};
        }
        if (!双证.命中.has_value()) {
            return {用途观察结构读取状态::未找到, std::nullopt};
        }
        return {用途观察结构读取状态::已读取, 双证.命中->材料};
    }

private:
    enum class 解析状态 : std::uint8_t { 已形成, 未找到, 内部不一致 };

    struct 结构解析结果 {
        解析状态 状态 = 解析状态::内部不一致;
        用途观察完整值式材料 材料;
        std::array<std::optional<关系记录>, 33> 当前角色{};
        std::optional<关系记录> 已失效角色三十一;

        bool 成功() const noexcept {
            return 状态 == 解析状态::已形成 && 材料.完整();
        }
    };

    struct 身份定位结果 {
        std::optional<结构解析结果> 命中;
        std::optional<std::uint64_t> 第一空闲键;
        bool 内部不一致 = false;
    };

    static 用途观察结构业务结果 形成业务失败(
        用途观察结构业务状态 状态,
        用途观察结构业务原因 原因) noexcept {
        return {状态, 原因, std::nullopt};
    }

    static bool 身份相同(
        const 用途观察语义身份& 左,
        const 用途观察语义身份& 右) noexcept {
        return 左.完整() && 右.完整()
            && 左.任务 == 右.任务 && 左.任务序号 == 右.任务序号;
    }

    static bool 是允许角色(std::int64_t 角色) noexcept {
        return (角色 >= 1 && 角色 <= 15) || (角色 >= 30 && 角色 <= 32);
    }

    static bool I64可转U32(std::int64_t 值) noexcept {
        return 值 >= 0
            && static_cast<std::uint64_t>(值) <= std::numeric_limits<std::uint32_t>::max();
    }

    static bool I64可转非零U32(std::int64_t 值) noexcept {
        return 值 > 0
            && static_cast<std::uint64_t>(值) <= std::numeric_limits<std::uint32_t>::max();
    }

    static std::optional<std::uint16_t> 解析探测序号(
        const 用途观察语义身份& 身份,
        std::uint32_t 格式版本,
        std::uint64_t 物理键) noexcept {
        for (std::size_t 序号 = 0; 序号 < 用途观察最大探测次数; ++序号) {
            if (形成用途观察物理键(身份, 格式版本, 序号)
                == std::optional<std::uint64_t>{物理键}) {
                return static_cast<std::uint16_t>(序号);
            }
        }
        return std::nullopt;
    }

    static std::optional<std::array<std::int64_t, 15>> 形成主信息槽(
        const 用途观察纯值候选& 候选) noexcept {
        if (!候选.合法()) return std::nullopt;
        const auto& 因果 = 候选.不可变核心.历史概率.因果身份;
        const auto& 概率 = 候选.不可变核心.历史概率;
        if (概率.机会数 > 4096 || 概率.正结果数 > 4096
            || 概率.负结果数 > 4096 || 概率.Q10000 > 10000) return std::nullopt;
        return std::array<std::int64_t, 15>{
            static_cast<std::int64_t>(候选.格式版本),
            static_cast<std::int64_t>(候选.身份.任务序号 >> 32),
            static_cast<std::int64_t>(候选.身份.任务序号 & 0xffffffffULL),
            因果.原因动态键.前状态值,
            因果.原因动态键.后状态值,
            static_cast<std::int64_t>(因果.原因动态键.规则版本),
            因果.结果动态键.前状态值,
            因果.结果动态键.后状态值,
            static_cast<std::int64_t>(因果.结果动态键.规则版本),
            static_cast<std::int64_t>(因果.因果规则版本),
            static_cast<std::int64_t>(因果.格式版本),
            static_cast<std::int64_t>(概率.机会数),
            static_cast<std::int64_t>(概率.正结果数),
            static_cast<std::int64_t>(概率.负结果数),
            static_cast<std::int64_t>(概率.Q10000)};
    }

    static std::array<节点句柄, 14> 形成基础角色目标(
        const 用途观察纯值候选& 候选) noexcept {
        const auto& 核心 = 候选.不可变核心;
        const auto& 因果 = 核心.历史概率.因果身份;
        return {候选.身份.任务, 核心.需求, 核心.选择记录, 核心.方法,
            核心.动作, 核心.场景, 核心.主体, 核心.目标状态,
            核心.实际状态, 核心.动态证据,
            因果.原因动态键.被改变目标, 因果.原因动态键.来源动作,
            因果.结果动态键.被改变目标, 因果.结果动态键.来源动作};
    }

    static bool 目标类型匹配(std::size_t 角色, 节点类型 类型) noexcept {
        switch (角色) {
        case 1: return 类型 == 节点类型::任务;
        case 2: return 类型 == 节点类型::需求;
        case 3: return 类型 == 节点类型::任务方法选择记录;
        case 4:
        case 5:
        case 12:
        case 14: return 类型 == 节点类型::方法;
        case 6: return 类型 == 节点类型::场景;
        case 7: return 类型 == 节点类型::存在;
        case 8:
        case 9:
        case 15:
        case 30:
        case 31:
        case 32: return 类型 == 节点类型::状态;
        case 10: return 类型 == 节点类型::动态;
        case 11:
        case 13: return 类型 != 节点类型::未分类
                && 类型 <= 节点类型::用途观察记录;
        default: return false;
        }
    }

    bool 会话候选类型匹配(
        结构写入会话& 会话,
        const 用途观察纯值候选& 候选) const {
        const auto 目标组 = 形成基础角色目标(候选);
        for (std::size_t 索引 = 0; 索引 < 目标组.size(); ++索引) {
            const auto 类型 = 会话.读取节点类型(目标组[索引]);
            const auto 主信息 = 会话.读取节点主信息(目标组[索引]);
            if (!类型.has_value() || !主信息.has_value()
                || !目标类型匹配(索引 + 1, *类型)
                || !会话.主信息可读(*主信息)) return false;
        }
        if (候选.阶段负载.正式结算状态.has_value()) {
            const auto 类型 = 会话.读取节点类型(*候选.阶段负载.正式结算状态);
            const auto 主信息 = 会话.读取节点主信息(*候选.阶段负载.正式结算状态);
            if (!类型.has_value() || !主信息.has_value()
                || !目标类型匹配(15, *类型)
                || !会话.主信息可读(*主信息)) return false;
        }
        return true;
    }

    bool 共享候选类型匹配(
        const 用途观察纯值候选& 候选,
        const 结构事务令牌& 令牌) const {
        const auto 目标组 = 形成基础角色目标(候选);
        for (std::size_t 索引 = 0; 索引 < 目标组.size(); ++索引) {
            const auto 记录 = 节点_.读取节点(目标组[索引], 令牌);
            if (!记录.has_value() || !目标类型匹配(索引 + 1, 记录->类型)
                || !主信息_.读取主信息(记录->主信息, 令牌).has_value()) return false;
        }
        if (候选.阶段负载.正式结算状态.has_value()) {
            const auto 记录 = 节点_.读取节点(*候选.阶段负载.正式结算状态, 令牌);
            if (!记录.has_value() || !目标类型匹配(15, 记录->类型)
                || !主信息_.读取主信息(记录->主信息, 令牌).has_value()) return false;
        }
        return true;
    }

    结构解析结果 解析原始结构(
        节点句柄 观察节点,
        主信息句柄 主信息,
        const 主信息记录& 主信息记录值,
        const std::vector<关系记录>& 关系组,
        const std::vector<std::uint64_t>& 主键组) const {
        结构解析结果 输出;
        if (!句柄有效(观察节点) || !句柄有效(主信息)
            || 主信息记录值.主信息编号 != 主信息.主信息编号
            || 主信息记录值.版本号 != 主信息.版本号
            || 主信息记录值.状态 != 记录状态::有效
            || 主信息记录值.值容器.size() != 15 || 主键组.size() != 1
            || 主键组.front() == 0) return 输出;

        std::array<std::int64_t, 15> 槽{};
        for (std::size_t 索引 = 0; 索引 < 槽.size(); ++索引) {
            if (!主信息记录值.值容器[索引].has_value()) return 输出;
            槽[索引] = *主信息记录值.值容器[索引];
        }
        if (槽[0] != 用途观察纯值合同格式版本
            || !I64可转U32(槽[1]) || !I64可转U32(槽[2])
            || !I64可转非零U32(槽[5]) || !I64可转非零U32(槽[8])
            || !I64可转非零U32(槽[9]) || !I64可转非零U32(槽[10])
            || 槽[11] < 1 || 槽[11] > 4096
            || 槽[12] < 0 || 槽[12] > 4096
            || 槽[13] < 0 || 槽[13] > 4096
            || 槽[14] < 0 || 槽[14] > 10000
            || 槽[12] + 槽[13] != 槽[11]
            || 槽[14] != 槽[12] * 10000 / 槽[11]) return 输出;

        for (const auto& 关系 : 关系组) {
            if (关系.类型 != 关系类型::用途观察证据角色
                || 关系.源节点 != 观察节点 || !是允许角色(关系.顺序号)
                || !句柄有效(关系.目标节点)) return 输出;
            const auto 角色 = static_cast<std::size_t>(关系.顺序号);
            if (关系.状态 == 记录状态::有效) {
                if (输出.当前角色[角色].has_value()) return 输出;
                输出.当前角色[角色] = 关系;
            } else if (关系.状态 == 记录状态::已失效 && 角色 == 31) {
                if (输出.已失效角色三十一.has_value()) return 输出;
                输出.已失效角色三十一 = 关系;
            } else {
                return 输出;
            }
        }
        for (std::size_t 角色 = 1; 角色 <= 14; ++角色) {
            if (!输出.当前角色[角色].has_value()) return 输出;
        }
        const auto 阶段数 = static_cast<std::size_t>(输出.当前角色[30].has_value())
            + static_cast<std::size_t>(输出.当前角色[31].has_value())
            + static_cast<std::size_t>(输出.当前角色[32].has_value());
        if (阶段数 != 1) return 输出;

        用途观察纯值候选 候选;
        候选.格式版本 = static_cast<std::uint32_t>(槽[0]);
        候选.身份.任务 = 输出.当前角色[1]->目标节点;
        候选.身份.任务序号 =
            (static_cast<std::uint64_t>(槽[1]) << 32)
            | static_cast<std::uint64_t>(槽[2]);
        候选.不可变核心.需求 = 输出.当前角色[2]->目标节点;
        候选.不可变核心.选择记录 = 输出.当前角色[3]->目标节点;
        候选.不可变核心.方法 = 输出.当前角色[4]->目标节点;
        候选.不可变核心.动作 = 输出.当前角色[5]->目标节点;
        候选.不可变核心.场景 = 输出.当前角色[6]->目标节点;
        候选.不可变核心.主体 = 输出.当前角色[7]->目标节点;
        候选.不可变核心.目标状态 = 输出.当前角色[8]->目标节点;
        候选.不可变核心.实际状态 = 输出.当前角色[9]->目标节点;
        候选.不可变核心.动态证据 = 输出.当前角色[10]->目标节点;
        auto& 因果 = 候选.不可变核心.历史概率.因果身份;
        因果.原因动态键.被改变目标 = 输出.当前角色[11]->目标节点;
        因果.原因动态键.前状态值 = 槽[3];
        因果.原因动态键.后状态值 = 槽[4];
        因果.原因动态键.有来源动作 = true;
        因果.原因动态键.来源动作 = 输出.当前角色[12]->目标节点;
        因果.原因动态键.规则版本 = static_cast<std::uint32_t>(槽[5]);
        因果.原因动态键.二次特征角色.reset();
        因果.结果动态键.被改变目标 = 输出.当前角色[13]->目标节点;
        因果.结果动态键.前状态值 = 槽[6];
        因果.结果动态键.后状态值 = 槽[7];
        因果.结果动态键.有来源动作 = true;
        因果.结果动态键.来源动作 = 输出.当前角色[14]->目标节点;
        因果.结果动态键.规则版本 = static_cast<std::uint32_t>(槽[8]);
        因果.结果动态键.二次特征角色.reset();
        因果.因果规则版本 = static_cast<std::uint32_t>(槽[9]);
        因果.格式版本 = static_cast<std::uint32_t>(槽[10]);
        auto& 概率 = 候选.不可变核心.历史概率;
        概率.机会数 = static_cast<std::uint64_t>(槽[11]);
        概率.正结果数 = static_cast<std::uint64_t>(槽[12]);
        概率.负结果数 = static_cast<std::uint64_t>(槽[13]);
        概率.Q10000 = static_cast<std::uint64_t>(槽[14]);

        if (输出.当前角色[30].has_value()) {
            if (输出.当前角色[30]->目标节点 != 候选.不可变核心.实际状态
                || 输出.当前角色[15].has_value() || 输出.已失效角色三十一.has_value()) return 输出;
            候选.阶段负载 = {用途正式结果分类::未达成已转待重筹办,
                任务达成分量::未达成, 需求结算分量::未形成,
                用途观察阶段::尝试未达成, std::nullopt};
        } else if (输出.当前角色[31].has_value()) {
            if (输出.当前角色[31]->目标节点 != 候选.不可变核心.实际状态
                || 输出.当前角色[15].has_value() || 输出.已失效角色三十一.has_value()) return 输出;
            候选.阶段负载 = {用途正式结果分类::任务已完成待需求结算,
                任务达成分量::已达成, 需求结算分量::待结算,
                用途观察阶段::待结算, std::nullopt};
        } else {
            if (!输出.当前角色[15].has_value()
                || 输出.当前角色[32]->目标节点 != 输出.当前角色[15]->目标节点) return 输出;
            候选.阶段负载 = {用途正式结果分类::已完成并结算,
                任务达成分量::已达成, 需求结算分量::已满足,
                用途观察阶段::最终已结算, 输出.当前角色[15]->目标节点};
        }
        if (!候选.合法()) return 输出;

        const auto 探测序号 = 解析探测序号(候选.身份, 候选.格式版本, 主键组.front());
        if (!探测序号.has_value()) return 输出;
        const std::size_t 预期关系数 = 候选.阶段负载.观察阶段 == 用途观察阶段::最终已结算
            ? (输出.已失效角色三十一.has_value() ? 17 : 16)
            : 15;
        if (关系组.size() != 预期关系数) return 输出;

        输出.材料.观察节点 = 观察节点;
        输出.材料.主信息 = 主信息;
        输出.材料.物理键 = 主键组.front();
        输出.材料.探测序号 = *探测序号;
        输出.材料.候选 = 候选;
        输出.材料.生命周期关系数量 = 关系组.size();
        输出.材料.曾由待结算推进 = 输出.已失效角色三十一.has_value();
        for (std::size_t 角色 = 1; 角色 < 输出.当前角色.size(); ++角色) {
            if (输出.当前角色[角色].has_value()) {
                输出.材料.当前角色目标[角色] = 输出.当前角色[角色]->目标节点;
            }
        }
        输出.状态 = 解析状态::已形成;
        return 输出;
    }

    结构解析结果 会话读取单条(
        结构写入会话& 会话,
        节点句柄 观察节点) const {
        const auto 类型 = 会话.读取节点类型(观察节点);
        const auto 主信息 = 会话.读取节点主信息(观察节点);
        if (!类型.has_value() || !主信息.has_value()) return {};
        if (*类型 != 节点类型::用途观察记录) return {解析状态::未找到};
        const auto 主信息读取 = 会话.读取完整主信息(*主信息);
        if (主信息读取.状态 != 结构写入会话::完整主信息读取状态::已读取
            || !主信息读取.记录.has_value()) return {};
        auto 输出 = 解析原始结构(
            观察节点, *主信息, *主信息读取.记录,
            会话.读取关系审计记录组(观察节点, 关系类型::用途观察证据角色),
            会话.读取节点主键组(观察节点));
        if (!输出.成功() || !会话候选类型匹配(会话, 输出.材料.候选)
            || !会话.节点可读(观察节点)
            || !会话.主键绑定匹配(输出.材料.物理键, 观察节点)) return {};
        return 输出;
    }

    结构解析结果 共享读取单条(
        节点句柄 观察节点,
        const 结构事务令牌& 令牌) const {
        const auto 节点记录值 = 节点_.读取节点(观察节点, 令牌);
        if (!节点记录值.has_value()) return {解析状态::未找到};
        if (节点记录值->类型 != 节点类型::用途观察记录) return {解析状态::未找到};
        const auto 主信息记录值 = 主信息_.读取主信息(节点记录值->主信息, 令牌);
        if (!主信息记录值.has_value()) return {};
        auto 输出 = 解析原始结构(
            观察节点, 节点记录值->主信息, *主信息记录值,
            关系_.获取关系审计记录组(
                观察节点, 关系类型::用途观察证据角色, 令牌),
            索引_.读取节点主键组(观察节点, 令牌));
        if (!输出.成功() || !共享候选类型匹配(输出.材料.候选, 令牌)
            || 索引_.按主键查节点(输出.材料.物理键, 令牌)
                != std::optional<节点句柄>{观察节点}) return {};
        return 输出;
    }

    身份定位结果 会话定位身份(
        结构写入会话& 会话,
        const 用途观察语义身份& 身份) const {
        身份定位结果 输出;
        std::vector<结构解析结果> 索引命中组;
        for (std::size_t 序号 = 0; 序号 < 用途观察最大探测次数; ++序号) {
            const auto 键 = 形成用途观察物理键(
                身份, 用途观察纯值合同格式版本, 序号);
            if (!键.has_value()) { 输出.内部不一致 = true; return 输出; }
            const auto 当前 = 会话.读取物理主键当前绑定(*键);
            if (当前.状态 == 结构写入会话::物理主键读取状态::空闲) {
                if (!输出.第一空闲键.has_value()) 输出.第一空闲键 = *键;
                continue;
            }
            if (当前.状态 != 结构写入会话::物理主键读取状态::已绑定
                || !当前.节点.has_value()) { 输出.内部不一致 = true; return 输出; }
            const auto 类型 = 会话.读取节点类型(*当前.节点);
            if (!类型.has_value()) { 输出.内部不一致 = true; return 输出; }
            if (*类型 != 节点类型::用途观察记录) continue;
            auto 解析 = 会话读取单条(会话, *当前.节点);
            if (!解析.成功()) { 输出.内部不一致 = true; return 输出; }
            if (身份相同(解析.材料.候选.身份, 身份)) 索引命中组.push_back(std::move(解析));
        }

        std::vector<结构解析结果> 关系命中组;
        const auto 来源关系组 = 会话.读取来源关系记录组(
            身份.任务, 关系类型::用途观察证据角色);
        for (const auto& 关系 : 来源关系组) {
            if (关系.状态 != 记录状态::有效 || 关系.顺序号 != 1
                || 关系.目标节点 != 身份.任务) continue;
            auto 解析 = 会话读取单条(会话, 关系.源节点);
            if (!解析.成功()) { 输出.内部不一致 = true; return 输出; }
            if (身份相同(解析.材料.候选.身份, 身份)) 关系命中组.push_back(std::move(解析));
        }
        if (索引命中组.size() > 1 || 关系命中组.size() > 1
            || 索引命中组.size() != 关系命中组.size()
            || (!索引命中组.empty()
                && 索引命中组.front().材料.观察节点
                    != 关系命中组.front().材料.观察节点)) {
            输出.内部不一致 = true;
            return 输出;
        }
        if (!索引命中组.empty()) 输出.命中 = std::move(索引命中组.front());
        return 输出;
    }

    身份定位结果 共享定位身份(
        const 用途观察语义身份& 身份,
        const 结构事务令牌& 令牌) const {
        身份定位结果 输出;
        std::vector<结构解析结果> 索引命中组;
        for (std::size_t 序号 = 0; 序号 < 用途观察最大探测次数; ++序号) {
            const auto 键 = 形成用途观察物理键(
                身份, 用途观察纯值合同格式版本, 序号);
            if (!键.has_value()) { 输出.内部不一致 = true; return 输出; }
            const auto 当前 = 索引_.按主键查节点(*键, 令牌);
            if (!当前.has_value()) {
                if (!输出.第一空闲键.has_value()) 输出.第一空闲键 = *键;
                continue;
            }
            const auto 记录 = 节点_.读取节点(*当前, 令牌);
            if (!记录.has_value()) { 输出.内部不一致 = true; return 输出; }
            if (记录->类型 != 节点类型::用途观察记录) continue;
            auto 解析 = 共享读取单条(*当前, 令牌);
            if (!解析.成功()) { 输出.内部不一致 = true; return 输出; }
            if (身份相同(解析.材料.候选.身份, 身份)) 索引命中组.push_back(std::move(解析));
        }
        std::vector<结构解析结果> 关系命中组;
        const auto 来源关系组 = 关系_.获取来源关系记录组(
            身份.任务, 关系类型::用途观察证据角色, 令牌);
        for (const auto& 关系 : 来源关系组) {
            if (关系.状态 != 记录状态::有效 || 关系.顺序号 != 1
                || 关系.目标节点 != 身份.任务) continue;
            auto 解析 = 共享读取单条(关系.源节点, 令牌);
            if (!解析.成功()) { 输出.内部不一致 = true; return 输出; }
            if (身份相同(解析.材料.候选.身份, 身份)) 关系命中组.push_back(std::move(解析));
        }
        if (索引命中组.size() > 1 || 关系命中组.size() > 1
            || 索引命中组.size() != 关系命中组.size()
            || (!索引命中组.empty()
                && 索引命中组.front().材料.观察节点
                    != 关系命中组.front().材料.观察节点)) {
            输出.内部不一致 = true;
            return 输出;
        }
        if (!索引命中组.empty()) 输出.命中 = std::move(索引命中组.front());
        return 输出;
    }

    bool 验证共享双证(
        const 结构解析结果& 解析,
        const 结构事务令牌& 令牌) const {
        if (!解析.成功()) return false;
        const auto 定位 = 共享定位身份(解析.材料.候选.身份, 令牌);
        return !定位.内部不一致 && 定位.命中.has_value()
            && 定位.命中->材料.观察节点 == 解析.材料.观察节点;
    }

    bool 会话全局所有者一致(
        结构写入会话& 会话,
        const 用途观察语义身份& 当前身份,
        std::uint64_t& 全局数量,
        std::uint64_t& 每任务数量,
        bool& 资源失败) const {
        const auto 投影 = 会话.读取有效节点与索引投影(节点类型::用途观察记录);
        if (投影.状态 == 结构写入会话::类型索引投影状态::资源失败) {
            资源失败 = true;
            return false;
        }
        if (投影.状态 != 结构写入会话::类型索引投影状态::已形成
            || 投影.节点组.size() != 投影.绑定组.size()) return false;
        全局数量 = static_cast<std::uint64_t>(投影.节点组.size());
        每任务数量 = 0;
        for (const auto& 节点记录值 : 投影.节点组) {
            const 节点句柄 观察{节点仓库编号_, 节点记录值.节点编号, 节点记录值.版本号};
            const auto 绑定数 = static_cast<std::size_t>(std::count_if(
                投影.绑定组.cbegin(), 投影.绑定组.cend(),
                [&](const auto& 绑定) { return 绑定.节点 == 观察; }));
            if (绑定数 != 1) return false;
            const auto 解析 = 会话读取单条(会话, 观察);
            if (!解析.成功()) return false;
            if (解析.材料.候选.身份.任务 == 当前身份.任务) ++每任务数量;
        }
        if (全局数量 > std::numeric_limits<std::uint64_t>::max()
                / 单条用途观察规范字节上限) return false;
        return 全局数量 * 单条用途观察规范字节上限
            <= 全部用途观察规范字节上限;
    }

    用途观察结构业务结果 在会话中发布(
        结构写入会话& 会话,
        const 用途观察纯值候选& 候选,
        bool& 已请求提交) const {
        const auto 撤销返回 = [&](用途观察结构业务结果 结果) {
            if (!会话.请求撤销()) return 形成业务失败(
                用途观察结构业务状态::内部不一致,
                用途观察结构业务原因::结构事务失败);
            return 结果;
        };
        if (!会话候选类型匹配(会话, 候选)) return 撤销返回(形成业务失败(
            用途观察结构业务状态::入口拒绝,
            用途观察结构业务原因::句柄类型不匹配));
        const auto 定位 = 会话定位身份(会话, 候选.身份);
        if (定位.内部不一致) {
            (void)追根因检查(false, L"用途观察写前单索引与角色一反向关系双证不一致。");
            return 撤销返回(形成业务失败(
                用途观察结构业务状态::内部不一致,
                用途观察结构业务原因::双证不一致));
        }

        std::uint64_t 全局数量 = 0;
        std::uint64_t 每任务数量 = 0;
        bool 资源失败 = false;
        if (!会话全局所有者一致(会话, 候选.身份, 全局数量, 每任务数量, 资源失败)) {
            (void)追根因检查(false, L"用途观察节点、索引所有者或容量投影不一致。");
            return 撤销返回(形成业务失败(
                用途观察结构业务状态::内部不一致,
                资源失败 ? 用途观察结构业务原因::读取资源失败
                    : 用途观察结构业务原因::已发布结构不一致));
        }

        if (!定位.命中.has_value()) {
            if (!定位.第一空闲键.has_value()) return 撤销返回(形成业务失败(
                用途观察结构业务状态::容量拒绝,
                用途观察结构业务原因::物理键探测耗尽));
            if (每任务数量 >= 单任务用途观察上限) return 撤销返回(形成业务失败(
                用途观察结构业务状态::容量拒绝,
                用途观察结构业务原因::单任务容量已满));
            if (全局数量 >= 全局用途观察上限) return 撤销返回(形成业务失败(
                用途观察结构业务状态::容量拒绝,
                用途观察结构业务原因::全局容量已满));
            if (全局数量 * 单条用途观察规范字节上限
                > 全部用途观察规范字节上限 - 单条用途观察规范字节上限) {
                return 撤销返回(形成业务失败(
                    用途观察结构业务状态::容量拒绝,
                    用途观察结构业务原因::规范字节容量已满));
            }
            return 新建候选(会话, 候选, *定位.第一空闲键, 已请求提交);
        }

        const auto 比较 = 比较用途观察同账(候选, 定位.命中->材料.候选);
        switch (比较.结论) {
        case 用途观察同账比较结论::同账幂等: {
            用途观察结构业务结果 结果{
                用途观察结构业务状态::已幂等,
                用途观察结构业务原因::无,
                定位.命中->材料};
            return 撤销返回(std::move(结果));
        }
        case 用途观察同账比较结论::同账允许推进:
            return 推进候选(会话, 候选, *定位.命中, 已请求提交);
        case 用途观察同账比较结论::同账冲突:
            return 撤销返回(形成业务失败(
                用途观察结构业务状态::同账冲突,
                比较.原因 == 用途观察同账比较原因::不可变核心不同
                    ? 用途观察结构业务原因::不可变核心不同
                    : 用途观察结构业务原因::阶段转换不允许));
        default:
            (void)追根因检查(false, L"用途观察同身份候选比较形成不允许的内部结果。");
            return 撤销返回(形成业务失败(
                用途观察结构业务状态::内部不一致,
                用途观察结构业务原因::已发布结构不一致));
        }
    }

    用途观察结构业务结果 新建候选(
        结构写入会话& 会话,
        const 用途观察纯值候选& 候选,
        std::uint64_t 物理键,
        bool& 已请求提交) const {
        const auto 槽 = 形成主信息槽(候选);
        if (!槽.has_value() || 物理键 == 0) return 形成业务失败(
            用途观察结构业务状态::内部不一致,
            用途观察结构业务原因::已发布结构不一致);
        const auto 主信息结果 = 会话.创建主信息候选();
        if (!主信息结果.成功() || !主信息结果.值.has_value()) return 形成业务失败(
            用途观察结构业务状态::内部不一致,
            用途观察结构业务原因::结构事务失败);
        const auto 主信息 = *主信息结果.值;
        for (std::size_t 索引 = 0; 索引 < 槽->size(); ++索引) {
            if (!会话.写入候选I64值(主信息, 索引, (*槽)[索引]).成功()) {
                return 形成业务失败(
                    用途观察结构业务状态::内部不一致,
                    用途观察结构业务原因::结构事务失败);
            }
        }
        const auto 节点结果 = 会话.创建节点候选(节点类型::用途观察记录, 主信息);
        if (!节点结果.成功() || !节点结果.值.has_value()) return 形成业务失败(
            用途观察结构业务状态::内部不一致,
            用途观察结构业务原因::结构事务失败);
        const auto 观察 = *节点结果.值;
        if (!会话.绑定主键(物理键, 观察).成功()) return 形成业务失败(
            用途观察结构业务状态::内部不一致,
            用途观察结构业务原因::结构事务失败);
        const auto 目标组 = 形成基础角色目标(候选);
        for (std::size_t 索引 = 0; 索引 < 目标组.size(); ++索引) {
            const auto 关系结果 = 会话.创建关系(
                关系类型::用途观察证据角色, 观察, 目标组[索引],
                static_cast<std::int64_t>(索引 + 1));
            if (!关系结果.成功()) return 形成业务失败(
                用途观察结构业务状态::内部不一致,
                用途观察结构业务原因::结构事务失败);
        }
        if (候选.阶段负载.观察阶段 == 用途观察阶段::最终已结算) {
            const auto 正式状态 = *候选.阶段负载.正式结算状态;
            if (!会话.创建关系(
                    关系类型::用途观察证据角色, 观察, 正式状态, 15).成功()
                || !会话.创建关系(
                    关系类型::用途观察证据角色, 观察, 正式状态, 32).成功()) {
                return 形成业务失败(
                    用途观察结构业务状态::内部不一致,
                    用途观察结构业务原因::结构事务失败);
            }
        } else {
            const auto 阶段角色 = 候选.阶段负载.观察阶段 == 用途观察阶段::尝试未达成
                ? 30 : 31;
            if (!会话.创建关系(
                    关系类型::用途观察证据角色,
                    观察, 候选.不可变核心.实际状态, 阶段角色).成功()) {
                return 形成业务失败(
                    用途观察结构业务状态::内部不一致,
                    用途观察结构业务原因::结构事务失败);
            }
        }
        auto 读回 = 会话读取单条(会话, 观察);
        if (!读回.成功()
            || 比较用途观察同账(候选, 读回.材料.候选).结论
                != 用途观察同账比较结论::同账幂等
            || !会话.请求提交()) {
            (void)追根因检查(false, L"用途观察新建写集未通过提交前完整读回。");
            return 形成业务失败(
                用途观察结构业务状态::内部不一致,
                用途观察结构业务原因::已发布结构不一致);
        }
        已请求提交 = true;
        return {用途观察结构业务状态::已新建,
            用途观察结构业务原因::无, std::move(读回.材料)};
    }

    用途观察结构业务结果 推进候选(
        结构写入会话& 会话,
        const 用途观察纯值候选& 候选,
        const 结构解析结果& 既有,
        bool& 已请求提交) const {
        if (!既有.成功() || !既有.当前角色[31].has_value()
            || 既有.当前角色[15].has_value() || 既有.当前角色[32].has_value()
            || 既有.已失效角色三十一.has_value()
            || !候选.阶段负载.正式结算状态.has_value()) {
            (void)追根因检查(false, L"用途观察待结算推进前结构不满足唯一单向门禁。");
            return 形成业务失败(
                用途观察结构业务状态::内部不一致,
                用途观察结构业务原因::已发布结构不一致);
        }
        const auto 观察 = 既有.材料.观察节点;
        const auto 正式状态 = *候选.阶段负载.正式结算状态;
        if (!会话.创建关系(
                关系类型::用途观察证据角色, 观察, 正式状态, 15).成功()
            || !会话.创建关系(
                关系类型::用途观察证据角色, 观察, 正式状态, 32).成功()) {
            return 形成业务失败(
                用途观察结构业务状态::内部不一致,
                用途观察结构业务原因::结构事务失败);
        }
        const auto& 旧关系 = *既有.当前角色[31];
        const 关系句柄 旧句柄{关系仓库编号_, 旧关系.关系编号, 旧关系.版本号};
        if (!会话.失效已发布关系(旧句柄).成功()) return 形成业务失败(
            用途观察结构业务状态::内部不一致,
            用途观察结构业务原因::结构事务失败);
        auto 读回 = 会话读取单条(会话, 观察);
        if (!读回.成功() || !读回.材料.曾由待结算推进
            || 读回.材料.生命周期关系数量 != 17
            || 比较用途观察同账(候选, 读回.材料.候选).结论
                != 用途观察同账比较结论::同账幂等
            || !会话.请求提交()) {
            (void)追根因检查(false, L"用途观察待结算推进写集未通过提交前完整读回。");
            return 形成业务失败(
                用途观察结构业务状态::内部不一致,
                用途观察结构业务原因::已发布结构不一致);
        }
        已请求提交 = true;
        return {用途观察结构业务状态::已推进最终,
            用途观察结构业务原因::无, std::move(读回.材料)};
    }

    结构事务接线 接线_;
    主信息仓库& 主信息_;
    节点仓库& 节点_;
    关系仓库& 关系_;
    索引仓库& 索引_;
    std::uint64_t 节点仓库编号_ = 0;
    std::uint64_t 关系仓库编号_ = 0;
    结构写入执行器 执行器_;
};

}
