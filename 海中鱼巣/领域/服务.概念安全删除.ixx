// 文件规则：概念安全删除服务只编排已补全写集的单进程提交，不承载恢复或独立删除事实。
module;

#include "../核心/节点仓库.h"
#include "../核心/主信息仓库.h"
#include "../核心/关系仓库.h"
#include "../核心/索引仓库.h"
#include "概念安全删除提交能力.数据.h"
#include "概念图服务.h"
#include "统计服务.h"
#include "存在服务.h"
#include "动态服务.h"
#include "二次特征服务.h"
#include "因果服务.h"

#include <algorithm>
#include <cstdint>
#include <optional>
#include <stdexcept>
#include <utility>
#include <vector>

export module 海中鱼巣.领域.服务.概念安全删除;

import 海中鱼巣.核心.协调.结构事务;

export namespace 海中鱼巣::领域 {

enum class 概念安全删除状态 : std::uint8_t {
    已拒绝 = 0,
    提交环境繁忙 = 1,
    候选已过期 = 2,
    已提交 = 3
};

struct 概念安全删除回执 {
    概念安全删除状态 状态 = 概念安全删除状态::已拒绝;
    节点句柄 原节点;
    节点句柄 节点审计句柄;
    主信息句柄 原主信息;
    主信息句柄 主信息审计句柄;
    std::vector<关系句柄> 关系审计句柄组;
    std::vector<std::uint64_t> 已删除主键组;
    std::vector<概念用途观察材料> 已删除用途观察组;
    std::uint64_t 原活动版本 = 0;
    std::uint64_t 当前活动版本 = 0;
    std::size_t 剩余概念数量 = 0;
    bool 幂等完成 = false;

    bool 已提交() const {
        return 状态 == 概念安全删除状态::已提交
            && 句柄有效(原节点)
            && 句柄有效(节点审计句柄)
            && 句柄有效(原主信息)
            && 句柄有效(主信息审计句柄)
            && 原活动版本 != 0
            && 当前活动版本 == 原活动版本 + 1;
    }

    bool 已完成() const {
        return (状态 == 概念安全删除状态::已提交 || 幂等完成)
            && 句柄有效(原节点)
            && 句柄有效(节点审计句柄)
            && 句柄有效(原主信息)
            && 句柄有效(主信息审计句柄)
            && 原活动版本 != 0
            && 当前活动版本 == 原活动版本 + 1;
    }
};

struct 概念删除后验报告 {
    bool 节点与主信息已删除 = false;
    bool 关系审计完整 = false;
    bool 索引已清理 = false;
    bool 登记与活动图已清理 = false;
    bool 缓存已清理 = false;
    bool 活动版本已发布 = false;

    bool 完整() const {
        return 节点与主信息已删除
            && 关系审计完整
            && 索引已清理
            && 登记与活动图已清理
            && 缓存已清理
            && 活动版本已发布;
    }
};

class 概念安全删除编排器 {
public:
    概念安全删除编排器(
        结构事务接线 接线,
        主信息仓库& 主信息,
        节点仓库& 节点,
        关系仓库& 关系,
        索引仓库& 索引,
        概念图服务& 概念图,
        统计服务& 统计,
        存在服务& 存在,
        动态服务& 动态,
        二次特征服务& 二次特征,
        因果服务& 因果)
        : 接线_(std::move(接线)),
          主信息_(主信息),
          节点_(节点),
          关系_(关系),
          索引_(索引),
          概念图_(概念图),
          统计_(统计),
          存在_(存在),
          动态_(动态),
          二次特征_(二次特征),
          因果_(因果) {
    }

    概念安全删除回执 提交安全删除(const 概念结构写集已补全候选& 输入候选) {
        概念安全删除回执 回执;
        if (!接线_.已接域() || !输入候选.完整()) return 回执;

        if (!节点_.读取节点(输入候选.领域影响.目标概念).has_value()) {
            回执 = 构造预期回执(输入候选);
            if (复核删除审计(回执).完整()) {
                回执.幂等完成 = true;
                return 回执;
            }
            return {};
        }

        auto 许可 = 接线_.取得独占许可(接线_.运行期状态);
        if (!许可.有效()) return 回执;
        const auto& 令牌 = 许可.读取令牌();

        auto 图冻结 = 概念图_.尝试冻结概念图();
        if (!图冻结.has_value()) {
            回执.状态 = 概念安全删除状态::提交环境繁忙;
            return 回执;
        }
        auto 缓存冻结 = 统计_.尝试冻结概念用途缓存();
        if (!缓存冻结.has_value()) {
            回执.状态 = 概念安全删除状态::提交环境繁忙;
            return 回执;
        }

        const auto& 领域影响 = 输入候选.领域影响;
        const auto 目标 = 领域影响.目标概念;
        const auto 当前节点 = 节点_.读取节点(目标, 令牌);
        const auto 当前主信息 = 主信息_.读取主信息(领域影响.目标主信息, 令牌);
        auto 当前关系组 = 关系_.获取节点相关关系记录组(目标, 令牌);
        auto 当前主键组 = 索引_.读取节点主键组(目标, 令牌);
        const auto 排序关系 = [](auto& 组) {
            std::sort(组.begin(), 组.end(), [](const auto& 左, const auto& 右) {
                if (左.关系编号 != 右.关系编号) return 左.关系编号 < 右.关系编号;
                return 左.版本号 < 右.版本号;
            });
        };
        auto 预期关系组 = 领域影响.当前相关有效关系组;
        排序关系(当前关系组);
        排序关系(预期关系组);
        const auto 关系组一致 = [](const auto& 左组, const auto& 右组) {
            return 左组.size() == 右组.size()
                && std::equal(左组.begin(), 左组.end(), 右组.begin(), [](const auto& 左, const auto& 右) {
                    return 左.关系编号 == 右.关系编号
                        && 左.类型 == 右.类型
                        && 左.源节点 == 右.源节点
                        && 左.目标节点 == 右.目标节点
                        && 左.顺序号 == 右.顺序号
                        && 左.版本号 == 右.版本号
                        && 左.状态 == 右.状态;
                });
        };
        auto 预期主键组 = 输入候选.索引包.主键组;
        std::sort(当前主键组.begin(), 当前主键组.end());
        std::sort(预期主键组.begin(), 预期主键组.end());
        if (!当前节点.has_value()
            || !当前主信息.has_value()
            || 当前节点->主信息 != 领域影响.目标主信息
            || 当前节点->类型 != 领域影响.目标节点记录.类型
            || !关系组一致(当前关系组, 预期关系组)
            || 当前主键组 != 预期主键组) {
            回执.状态 = 概念安全删除状态::候选已过期;
            return 回执;
        }

        const auto 节点包 = 节点_.准备节点删除包(目标, 令牌);
        const auto 主信息包 = 主信息_.准备主信息删除包(目标, 领域影响.目标主信息, 令牌);
        const auto 关系包 = 关系_.准备节点关系失效包(目标, 当前关系组, 令牌);
        const auto 索引包 = 索引_.准备节点主键删除包(目标, 当前主键组, 令牌);
        const auto 所有者授权 = 形成所有者授权(领域影响, 令牌);
        auto 概念图包 = 概念图_.准备概念登记与活动快照清理包_已加锁(
            领域影响, 令牌, &图冻结.value());
        const auto 统计包 = 统计_.准备概念缓存清理包_已加锁(
            目标, 令牌, 缓存冻结.value());
        if (!节点包.has_value() || !主信息包.has_value() || !关系包.has_value()
            || !索引包.has_value() || !所有者授权.has_value()
            || !概念图包.has_value() || !概念图包->提交材料完整()
            || !统计包.has_value()) {
            回执.状态 = 概念安全删除状态::候选已过期;
            return 回执;
        }

        概念结构写集已补全候选 当前候选{
            删除候选完备阶段::结构写集已补全,
            领域影响,
            节点包.value(),
            主信息包.value(),
            关系包.value(),
            索引包.value(),
            所有者授权.value(),
            概念图包.value(),
            统计包.value()
        };
        if (!当前候选.完整()) {
            throw std::logic_error("概念安全删除当前写集重建后不完整");
        }

        回执.状态 = 概念安全删除状态::候选已过期;
        回执.幂等完成 = false;
        回执.原节点 = 目标;
        回执.节点审计句柄 = {目标.仓库编号, 目标.节点编号, 目标.版本号 + 1};
        回执.原主信息 = 领域影响.目标主信息;
        回执.主信息审计句柄 = {
            领域影响.目标主信息.仓库编号,
            领域影响.目标主信息.主信息编号,
            领域影响.目标主信息.版本号 + 1};
        回执.关系审计句柄组.reserve(当前关系组.size());
        for (const auto& 关系记录 : 当前关系组) {
            回执.关系审计句柄组.push_back({
                输入候选.领域影响.目标生命周期.关系.仓库编号,
                关系记录.关系编号,
                关系记录.版本号 + 1});
        }
        回执.已删除主键组 = 当前主键组;
        回执.已删除用途观察组 = 当前候选.统计缓存包.用途观察组;
        回执.原活动版本 = 当前候选.概念图包.基准活动版本;
        回执.当前活动版本 = 当前候选.概念图包.新活动版本;
        回执.剩余概念数量 = 当前候选.概念图包.新活动快照.概念节点组.size();

        概念安全删除提交会话 会话(接线_.运行期状态, 目标, 令牌);
        关系_.提交节点关系失效包(当前候选.关系包, 令牌, 会话);
        会话.推进到(概念安全删除提交阶段::索引);
        索引_.提交节点主键删除包(当前候选.索引包, 令牌, 会话);
        会话.推进到(概念安全删除提交阶段::主信息);
        主信息_.提交主信息删除包(当前候选.主信息包, 令牌, 会话);
        会话.推进到(概念安全删除提交阶段::节点);
        节点_.提交节点删除包(当前候选.节点包, 令牌, 会话);
        会话.推进到(概念安全删除提交阶段::概念登记);
        概念图_.提交概念登记清理包_已加锁(
            当前候选.概念图包, 令牌, 会话, 图冻结.value());
        会话.推进到(概念安全删除提交阶段::统计缓存);
        统计_.提交概念缓存清理包_已加锁(
            当前候选.统计缓存包, 令牌, 会话, 缓存冻结.value());
        会话.推进到(概念安全删除提交阶段::活动快照);
        概念图_.提交概念活动快照清理包_已加锁(
            当前候选.概念图包, 令牌, 会话, 图冻结.value());
        会话.推进到(概念安全删除提交阶段::已完成);
        回执.状态 = 概念安全删除状态::已提交;
        return 回执;
    }

    概念删除后验报告 复核删除审计(const 概念安全删除回执& 回执) const {
        概念删除后验报告 报告;
        if (!句柄有效(回执.原节点)
            || !句柄有效(回执.节点审计句柄)
            || !句柄有效(回执.原主信息)
            || !句柄有效(回执.主信息审计句柄)
            || 回执.原活动版本 == 0
            || 回执.当前活动版本 != 回执.原活动版本 + 1) return 报告;

        const auto 节点审计 = 节点_.读取节点审计(回执.节点审计句柄);
        const auto 主信息审计 = 主信息_.读取主信息审计(回执.主信息审计句柄);
        报告.节点与主信息已删除 = !节点_.读取节点(回执.原节点).has_value()
            && 节点审计.has_value() && 节点审计->状态 == 记录状态::已删除
            && !主信息_.读取主信息(回执.原主信息).has_value()
            && 主信息审计.has_value() && 主信息审计->状态 == 记录状态::已删除;

        报告.关系审计完整 = std::all_of(
            回执.关系审计句柄组.begin(), 回执.关系审计句柄组.end(),
            [this](const auto& 句柄) {
                const auto 审计 = 关系_.读取关系审计(句柄);
                return 审计.has_value()
                    && 审计->状态 == 记录状态::已失效
                    && !关系_.读取关系(句柄).has_value();
            });
        报告.索引已清理 = 索引_.读取节点主键组(回执.原节点).empty()
            && std::all_of(
                回执.已删除主键组.begin(), 回执.已删除主键组.end(),
                [this](const auto 主键) { return !索引_.按主键查节点(主键).has_value(); });

        const auto 活动节点组 = 概念图_.读取活动概念节点组();
        const auto 主动召回组 = 概念图_.读取主动召回概念节点组();
        const auto 活动关系组 = 概念图_.读取活动关系组();
        报告.登记与活动图已清理 = !概念图_.读取活动概念签名(回执.原节点).has_value()
            && !概念图_.读取概念生命周期(回执.原节点).has_value()
            && std::find(活动节点组.begin(), 活动节点组.end(), 回执.原节点) == 活动节点组.end()
            && std::find(主动召回组.begin(), 主动召回组.end(), 回执.原节点) == 主动召回组.end()
            && std::none_of(活动关系组.begin(), 活动关系组.end(), [&回执](const auto& 关系) {
                return 关系.源节点 == 回执.原节点 || 关系.目标节点 == 回执.原节点;
            });
        报告.缓存已清理 = std::all_of(
            回执.已删除用途观察组.begin(), 回执.已删除用途观察组.end(),
            [this, &回执](const auto& 材料) {
                const auto 读回 = 统计_.读取概念用途观察组(材料.命名空间, 回执.原节点);
                return 读回.has_value() && 读回->empty();
            });
        报告.活动版本已发布 = 概念图_.读取活动图版本() >= 回执.当前活动版本;
        return 报告;
    }

private:
    static 概念安全删除回执 构造预期回执(const 概念结构写集已补全候选& 候选) {
        概念安全删除回执 回执;
        const auto& 影响 = 候选.领域影响;
        回执.状态 = 概念安全删除状态::候选已过期;
        回执.原节点 = 影响.目标概念;
        回执.节点审计句柄 = {
            影响.目标概念.仓库编号, 影响.目标概念.节点编号, 影响.目标概念.版本号 + 1};
        回执.原主信息 = 影响.目标主信息;
        回执.主信息审计句柄 = {
            影响.目标主信息.仓库编号,
            影响.目标主信息.主信息编号,
            影响.目标主信息.版本号 + 1};
        for (const auto& 关系 : 影响.当前相关有效关系组) {
            回执.关系审计句柄组.push_back({
                影响.目标生命周期.关系.仓库编号, 关系.关系编号, 关系.版本号 + 1});
        }
        回执.已删除主键组 = 候选.索引包.主键组;
        回执.已删除用途观察组 = 候选.统计缓存包.用途观察组;
        回执.原活动版本 = 影响.基准活动版本;
        回执.当前活动版本 = 影响.基准活动版本 + 1;
        回执.剩余概念数量 = 影响.完整剩余签名组.size();
        return 回执;
    }

    std::optional<概念结构所有者清理授权> 形成所有者授权(
        const 概念删除影响候选& 候选,
        const 结构事务令牌& 令牌) const {
        const auto 所有者 = 候选.根类别 == 概念根类别::存在
            ? 概念结构所有者类型::存在服务
            : 候选.根类别 == 概念根类别::动态
                ? 概念结构所有者类型::动态服务
                : 候选.根类别 == 概念根类别::关系
                    ? 概念结构所有者类型::二次特征服务
                    : 候选.根类别 == 概念根类别::因果
                        ? 概念结构所有者类型::因果服务
                        : 概念结构所有者类型::未定义;
        const 概念结构所有者清理请求 请求{
            候选.目标概念, 候选.目标主信息, 所有者, true, true};
        return 所有者 == 概念结构所有者类型::存在服务
            ? 存在_.形成概念节点清理授权(请求, 令牌)
            : 所有者 == 概念结构所有者类型::动态服务
                ? 动态_.形成概念节点清理授权(请求, 令牌)
                : 所有者 == 概念结构所有者类型::二次特征服务
                    ? 二次特征_.形成概念节点清理授权(请求, 令牌)
                    : 所有者 == 概念结构所有者类型::因果服务
                        ? 因果_.形成概念节点清理授权(请求, 令牌)
                        : std::nullopt;
    }

    结构事务接线 接线_;
    主信息仓库& 主信息_;
    节点仓库& 节点_;
    关系仓库& 关系_;
    索引仓库& 索引_;
    概念图服务& 概念图_;
    统计服务& 统计_;
    存在服务& 存在_;
    动态服务& 动态_;
    二次特征服务& 二次特征_;
    因果服务& 因果_;
};

}
