// 文件规则：用途事件组合器只把任务结果正式 DTO 无损适配为用途材料；不得写权威结构或建立第二结果合同。
module;

#include <optional>
#include <utility>

export module 海中鱼巣.领域.组合.用途事件;

import 海中鱼巣.领域.材料.用途事件;
import 海中鱼巣.领域.服务.用途事件;
import 海中鱼巣.领域.组合.任务结果结算;

export namespace 海中鱼巣 {

class 用途事件组合器 final {
public:
    static 用途事件结果 形成用途事件候选(
        const 用途来源冻结材料& 冻结来源,
        const 任务结果治理请求& 请求,
        const 任务结果治理结果& 结果) {
        if (!结果.已收口()) {
            return {用途事件处理状态::入口拒绝,
                用途事件拒绝原因::结果尚未正式收口, std::nullopt};
        }

        const auto 正式结果 = 映射正式结果(结果.状态);
        const auto 收口原因 = 映射收口原因(结果.状态, 结果.拒绝原因);
        if (!正式结果.has_value() || !收口原因.has_value()) {
            return {用途事件处理状态::内部不一致,
                用途事件拒绝原因::正式结果材料矛盾, std::nullopt};
        }

        规范化任务结果来源 来源;
        来源.完整回执 = 请求.回执;
        来源.正式结果 = *正式结果;
        来源.收口原因 = *收口原因;
        来源.协议结果 = 结果.协议结果;
        来源.目标裁决 = 结果.目标裁决;
        来源.任务提交 = 结果.任务提交;
        来源.需求结算 = 结果.需求结算;
        来源.参数 = {
            请求.参数.当前时间戳,
            请求.参数.待重筹办幂等材料编号,
            请求.参数.待重筹办发生时间戳,
            请求.参数.完成状态幂等主键,
            请求.参数.完成发生时间戳,
            请求.参数.结算状态幂等主键,
            请求.参数.结算发生时间戳,
            请求.参数.因果引用};
        if (结果.待结算提示.has_value()) {
            const auto& 提示 = *结果.待结算提示;
            if (提示.性质 != 任务结果提示性质::非权威待结算请求材料) {
                return {用途事件处理状态::内部不一致,
                    用途事件拒绝原因::正式结果材料矛盾, std::nullopt};
            }
            来源.待结算提示 = 规范化待需求结算提示{
                提示.任务, 提示.需求, 提示.实际状态, 提示.动态证据,
                提示.因果引用, 提示.任务完成状态, 提示.需求结算状态,
                提示.结算状态幂等主键, 提示.结算发生时间戳,
                提示.承载机器事实
                    ? 待结算提示承载性质::越权承载机器事实
                    : 待结算提示承载性质::仅非权威请求材料};
        }
        return 用途事件业务服务::形成结构化结果效用(
            {冻结来源, std::move(来源), 用途事件规则版本});
    }

private:
    static std::optional<用途正式结果分类> 映射正式结果(
        任务结果治理状态 状态) noexcept {
        switch (状态) {
        case 任务结果治理状态::未达成已转待重筹办:
            return 用途正式结果分类::未达成已转待重筹办;
        case 任务结果治理状态::任务已完成待需求结算:
            return 用途正式结果分类::任务已完成待需求结算;
        case 任务结果治理状态::已完成并结算:
            return 用途正式结果分类::已完成并结算;
        default:
            return std::nullopt;
        }
    }

    static std::optional<用途结果收口原因> 映射收口原因(
        任务结果治理状态 状态,
        任务结果治理拒绝原因 原因) noexcept {
        if (状态 == 任务结果治理状态::任务已完成待需求结算) {
            return 原因 == 任务结果治理拒绝原因::需求结算待重试
                ? std::optional{用途结果收口原因::需求结算待重试}
                : std::nullopt;
        }
        return 原因 == 任务结果治理拒绝原因::无
            ? std::optional{用途结果收口原因::无}
            : std::nullopt;
    }
};

}
