// 文件规则：因果完整结构键自检只验证纯值身份、比较、召回哈希和用途分量接线；不得进入生产依赖或读写权威结构。
module;

#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
#include "../核心/句柄.h"

#include <algorithm>
#include <array>
#include <cstddef>
#include <cstdint>
#include <iostream>
#include <optional>
#include <type_traits>
#include <utility>
#endif

export module 海中鱼巣.领域.自检.因果完整结构键;

#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
import 海中鱼巣.领域.材料.动态模式;
import 海中鱼巣.领域.算法.动态模式;
import 海中鱼巣.领域.材料.因果模式;
import 海中鱼巣.领域.算法.因果模式;
import 海中鱼巣.领域.材料.用途事件;
import 海中鱼巣.领域.算法.用途事件;
import 海中鱼巣.领域.自检.因果模式;
import 海中鱼巣.自检.运行器;

export namespace 海中鱼巣 {

namespace 因果完整结构键自检内部 {

template <class 类型>
concept 含有机会证据组字段 = requires(类型& 值) { 值.机会证据组; };

template <class 类型>
concept 含有机会数字段 = requires(类型& 值) { 值.机会数; };

template <class 类型>
concept 含有正结果数字段 = requires(类型& 值) { 值.正结果数; };

template <class 类型>
concept 含有负结果数字段 = requires(类型& 值) { 值.负结果数; };

template <class 类型>
concept 含有概率字段 = requires(类型& 值) { 值.Q10000; };

template <class 类型>
concept 含有因果身份字段 = requires(类型& 值) { 值.因果身份; };

template <class 类型>
concept 含有旧原因结构键字段 = requires(类型& 值) { 值.原因结构键; };

template <class 类型>
concept 含有旧结果结构键字段 = requires(类型& 值) { 值.结果结构键; };

template <class 类型>
concept 含有旧因果规则版本字段 = requires(类型& 值) { 值.因果规则版本; };

static_assert(!含有机会证据组字段<因果完整结构键>);
static_assert(!含有机会数字段<因果完整结构键>);
static_assert(!含有正结果数字段<因果完整结构键>);
static_assert(!含有负结果数字段<因果完整结构键>);
static_assert(!含有概率字段<因果完整结构键>);
static_assert(含有因果身份字段<因果概率分量>);
static_assert(含有机会数字段<因果概率分量>);
static_assert(含有正结果数字段<因果概率分量>);
static_assert(含有负结果数字段<因果概率分量>);
static_assert(含有概率字段<因果概率分量>);
static_assert(!含有旧原因结构键字段<因果概率分量>);
static_assert(!含有旧结果结构键字段<因果概率分量>);
static_assert(!含有旧因果规则版本字段<因果概率分量>);
static_assert(std::is_same_v<
    std::remove_cvref_t<decltype(std::declval<因果概率分量&>().因果身份)>,
    因果完整结构键>);

因果概率候选 形成基准候选() {
    using namespace 因果模式自检内部;
    const auto 原因键 = 形成结构键(20);
    const auto 结果键 = 形成结构键(30);
    const auto 聚类结果 = 形成聚类结果({
        {1, 1'001, 2, 原因键},
        {1, 1'002, 1, 结果键},
        {1, 1'003, 3, 结果键},
        {2, 2'001, 2, 原因键},
        {2, 2'002, 1, 结果键},
        {3, 3'001, 2, 原因键},
        {3, 3'002, 3, 结果键}});
    const auto 结果 = 执行因果模式(形成因果请求(聚类结果, 原因键, 结果键));
    return 结果.候选;
}

bool 原始动态键相同(
    const 动态模式结构键& 左,
    const 动态模式结构键& 右) noexcept {
    return 左.被改变目标 == 右.被改变目标
        && 左.前状态值 == 右.前状态值
        && 左.后状态值 == 右.后状态值
        && 左.有来源动作 == 右.有来源动作
        && 左.来源动作 == 右.来源动作
        && 左.规则版本 == 右.规则版本
        && 左.二次特征角色 == 右.二次特征角色;
}

bool 原始候选身份材料相同(
    const 因果概率候选& 左,
    const 因果概率候选& 右) noexcept {
    return 原始动态键相同(左.原因结构键, 右.原因结构键)
        && 原始动态键相同(左.结果结构键, 右.结果结构键)
        && 左.规则版本 == 右.规则版本
        && 左.机会证据组.size() == 右.机会证据组.size()
        && 左.机会数 == 右.机会数
        && 左.正结果数 == 右.正结果数
        && 左.负结果数 == 右.负结果数
        && 左.Q10000 == 右.Q10000;
}

bool 完整字段逐项变化均不同(const 因果完整结构键& 基准) noexcept {
    auto 变化 = 基准;
    ++变化.格式版本;
    if (因果完整结构键相同(基准, 变化)) return false;

    变化 = 基准;
    ++变化.原因动态键.被改变目标.节点编号;
    if (因果完整结构键相同(基准, 变化)) return false;
    变化 = 基准;
    ++变化.原因动态键.前状态值;
    if (因果完整结构键相同(基准, 变化)) return false;
    变化 = 基准;
    ++变化.原因动态键.后状态值;
    if (因果完整结构键相同(基准, 变化)) return false;
    变化 = 基准;
    变化.原因动态键.有来源动作 = false;
    if (因果完整结构键相同(基准, 变化)) return false;
    变化 = 基准;
    ++变化.原因动态键.来源动作.节点编号;
    if (因果完整结构键相同(基准, 变化)) return false;
    变化 = 基准;
    ++变化.原因动态键.规则版本;
    if (因果完整结构键相同(基准, 变化)) return false;
    变化 = 基准;
    变化.原因动态键.二次特征角色 = 1;
    if (因果完整结构键相同(基准, 变化)) return false;

    变化 = 基准;
    ++变化.结果动态键.被改变目标.节点编号;
    if (因果完整结构键相同(基准, 变化)) return false;
    变化 = 基准;
    ++变化.结果动态键.前状态值;
    if (因果完整结构键相同(基准, 变化)) return false;
    变化 = 基准;
    ++变化.结果动态键.后状态值;
    if (因果完整结构键相同(基准, 变化)) return false;
    变化 = 基准;
    变化.结果动态键.有来源动作 = false;
    if (因果完整结构键相同(基准, 变化)) return false;
    变化 = 基准;
    ++变化.结果动态键.来源动作.节点编号;
    if (因果完整结构键相同(基准, 变化)) return false;
    变化 = 基准;
    ++变化.结果动态键.规则版本;
    if (因果完整结构键相同(基准, 变化)) return false;
    变化 = 基准;
    变化.结果动态键.二次特征角色 = 1;
    if (因果完整结构键相同(基准, 变化)) return false;

    变化 = 基准;
    ++变化.因果规则版本;
    return !因果完整结构键相同(基准, 变化);
}

bool 版本不支持结果正确(const 因果概率候选& 候选) {
    const auto 结果 = 形成因果完整结构键(候选);
    return 结果.状态 == 因果完整结构键处理状态::不支持
        && 结果.拒绝原因 == 因果完整结构键拒绝原因::版本不兼容
        && !结果.身份.has_value() && !结果.成功();
}

bool 四类版本漂移均不兼容(
    const 因果完整结构键& 基准,
    const 因果概率候选& 基准候选) {
    auto 格式漂移 = 基准;
    ++格式漂移.格式版本;
    auto 原因漂移 = 基准;
    ++原因漂移.原因动态键.规则版本;
    auto 结果漂移 = 基准;
    ++结果漂移.结果动态键.规则版本;
    auto 因果漂移 = 基准;
    ++因果漂移.因果规则版本;

    auto 原因候选漂移 = 基准候选;
    ++原因候选漂移.原因结构键.规则版本;
    auto 结果候选漂移 = 基准候选;
    ++结果候选漂移.结果结构键.规则版本;
    auto 因果候选漂移 = 基准候选;
    ++因果候选漂移.规则版本;

    const std::array<因果完整结构键, 4> 漂移组{
        格式漂移, 原因漂移, 结果漂移, 因果漂移};
    const bool 身份全部不兼容 = std::all_of(
        漂移组.begin(), 漂移组.end(), [&](const auto& 当前) {
            return !因果完整结构键版本兼容(当前)
                && !因果完整结构键相同(基准, 当前)
                && !计算因果完整结构键稳定哈希(当前).has_value();
        });
    return 身份全部不兼容
        && 版本不支持结果正确(原因候选漂移)
        && 版本不支持结果正确(结果候选漂移)
        && 版本不支持结果正确(因果候选漂移);
}

bool 四种结果合同成立(const 因果完整结构键& 身份) noexcept {
    auto 版本漂移身份 = 身份;
    ++版本漂移身份.因果规则版本;
    auto 同键身份 = 身份;
    同键身份.结果动态键 = 同键身份.原因动态键;
    const 因果完整结构键结果 已形成{
        因果完整结构键处理状态::已形成,
        因果完整结构键拒绝原因::无,
        身份};
    const 因果完整结构键结果 候选拒绝{
        因果完整结构键处理状态::入口拒绝,
        因果完整结构键拒绝原因::候选不完整,
        std::nullopt};
    const 因果完整结构键结果 同键拒绝{
        因果完整结构键处理状态::入口拒绝,
        因果完整结构键拒绝原因::原因结果相同,
        std::nullopt};
    const 因果完整结构键结果 不支持{
        因果完整结构键处理状态::不支持,
        因果完整结构键拒绝原因::版本不兼容,
        std::nullopt};
    const 因果完整结构键结果 内部不一致{
        因果完整结构键处理状态::内部不一致,
        因果完整结构键拒绝原因::算法不变量破坏,
        std::nullopt};
    const 因果完整结构键结果 缺身份成功态{
        因果完整结构键处理状态::已形成,
        因果完整结构键拒绝原因::无,
        std::nullopt};
    const 因果完整结构键结果 错因成功态{
        因果完整结构键处理状态::已形成,
        因果完整结构键拒绝原因::候选不完整,
        身份};
    const 因果完整结构键结果 拒绝夹带身份{
        因果完整结构键处理状态::入口拒绝,
        因果完整结构键拒绝原因::候选不完整,
        身份};
    const 因果完整结构键结果 版本漂移成功态{
        因果完整结构键处理状态::已形成,
        因果完整结构键拒绝原因::无,
        版本漂移身份};
    const 因果完整结构键结果 同键成功态{
        因果完整结构键处理状态::已形成,
        因果完整结构键拒绝原因::无,
        同键身份};
    return 已形成.成功()
        && !候选拒绝.成功() && !同键拒绝.成功()
        && !不支持.成功() && !内部不一致.成功()
        && !缺身份成功态.成功() && !错因成功态.成功()
        && !拒绝夹带身份.成功()
        && !版本漂移成功态.成功() && !同键成功态.成功();
}

}

自检单元结果 运行因果完整结构键自检(bool 用途事件回归通过) {
    using namespace 因果完整结构键自检内部;

    static_assert(std::is_same_v<
        decltype(形成因果完整结构键(std::declval<const 因果概率候选&>())),
        因果完整结构键结果>);
    static_assert(std::is_same_v<
        decltype(计算因果完整结构键稳定哈希(
            std::declval<const 因果完整结构键&>())),
        std::optional<std::uint64_t>>);
    static_assert(std::is_copy_constructible_v<因果完整结构键>);
    static_assert(std::is_copy_constructible_v<因果完整结构键结果>);

    std::array<bool, 14> 验收{};
    try {
        const auto 基准候选 = 形成基准候选();
        const auto 形成结果 = 形成因果完整结构键(基准候选);
        验收[0] = 因果完整结构键格式版本 == 1
            && 动态模式规则版本 != 0 && 因果模式规则版本 != 0
            && 形成结果.成功() && 形成结果.身份.has_value();
        if (!形成结果.身份.has_value()) throw 0;
        const auto 基准身份 = *形成结果.身份;

        验收[1] = 基准身份.局部完整()
            && 基准身份.格式版本 == 因果完整结构键格式版本
            && 动态模式结构键相同(
                基准身份.原因动态键, 基准候选.原因结构键)
            && 动态模式结构键相同(
                基准身份.结果动态键, 基准候选.结果结构键)
            && 基准身份.因果规则版本 == 基准候选.规则版本;

        auto 角色交换 = 基准身份;
        std::swap(角色交换.原因动态键, 角色交换.结果动态键);
        验收[2] = 角色交换.局部完整()
            && 因果完整结构键版本兼容(角色交换)
            && !因果完整结构键相同(基准身份, 角色交换);

        const auto 同内容副本 = 基准身份;
        因果完整结构键 默认无效;
        auto 版本不支持 = 基准身份;
        ++版本不支持.因果规则版本;
        验收[3] = 因果完整结构键相同(基准身份, 同内容副本)
            && 完整字段逐项变化均不同(基准身份)
            && !因果完整结构键相同(默认无效, 默认无效)
            && !因果完整结构键相同(版本不支持, 版本不支持);

        验收[4] = 因果完整结构键版本兼容(基准身份)
            && 四类版本漂移均不兼容(基准身份, 基准候选);

        const 因果完整结构键结果 默认结果;
        const 因果完整结构键 默认身份;
        因果概率候选 不完整候选;
        const auto 不完整副本 = 不完整候选;
        const auto 不完整结果 = 形成因果完整结构键(不完整候选);
        auto 同键候选 = 基准候选;
        同键候选.结果结构键 = 同键候选.原因结构键;
        const auto 同键副本 = 同键候选;
        const auto 同键结果 = 形成因果完整结构键(同键候选);
        验收[5] = 默认结果.状态 == 因果完整结构键处理状态::入口拒绝
            && 默认结果.拒绝原因 == 因果完整结构键拒绝原因::候选不完整
            && !默认结果.身份.has_value() && !默认结果.成功()
            && 默认身份.格式版本 == 因果完整结构键格式版本
            && !默认身份.局部完整() && !默认身份.当前版本兼容()
            && 不完整结果.状态 == 因果完整结构键处理状态::入口拒绝
            && 不完整结果.拒绝原因 == 因果完整结构键拒绝原因::候选不完整
            && !不完整结果.身份.has_value()
            && 同键结果.状态 == 因果完整结构键处理状态::入口拒绝
            && 同键结果.拒绝原因 == 因果完整结构键拒绝原因::原因结果相同
            && !同键结果.身份.has_value()
            && 原始候选身份材料相同(不完整候选, 不完整副本)
            && 原始候选身份材料相同(同键候选, 同键副本)
            && 四种结果合同成立(基准身份);

        const auto 基准哈希一 = 计算因果完整结构键稳定哈希(基准身份);
        const auto 基准哈希二 = 计算因果完整结构键稳定哈希(同内容副本);
        const auto 交换哈希 = 计算因果完整结构键稳定哈希(角色交换);
        auto 原因变化身份 = 基准身份;
        ++原因变化身份.原因动态键.前状态值;
        auto 结果变化身份 = 基准身份;
        ++结果变化身份.结果动态键.后状态值;
        const auto 原因变化哈希 = 计算因果完整结构键稳定哈希(原因变化身份);
        const auto 结果变化哈希 = 计算因果完整结构键稳定哈希(结果变化身份);
        验收[6] = 基准哈希一.has_value() && 基准哈希二.has_value()
            && 交换哈希.has_value() && 基准哈希一 == 基准哈希二
            && 基准哈希一 != 交换哈希
            && 原因变化哈希.has_value() && 结果变化哈希.has_value()
            && 基准哈希一 != 原因变化哈希 && 基准哈希一 != 结果变化哈希
            && !计算因果完整结构键稳定哈希(默认无效).has_value()
            && !计算因果完整结构键稳定哈希(版本不支持).has_value();

        auto 不同身份 = 基准身份;
        ++不同身份.结果动态键.后状态值;
        const auto 不同哈希 = 计算因果完整结构键稳定哈希(不同身份);
        const auto 假定碰撞哈希 = 基准哈希一;
        验收[7] = 不同哈希.has_value()
            && 假定碰撞哈希 == 基准哈希一
            && !因果完整结构键相同(基准身份, 不同身份)
            && 因果完整结构键相同(基准身份, 同内容副本);

        验收[8] = !含有机会证据组字段<因果完整结构键>
            && !含有机会数字段<因果完整结构键>
            && !含有正结果数字段<因果完整结构键>
            && !含有负结果数字段<因果完整结构键>
            && !含有概率字段<因果完整结构键>;

        const auto 用途分量 = 形成因果概率分量(基准候选);
        auto 不支持候选 = 基准候选;
        ++不支持候选.规则版本;
        const auto 不支持分量 = 形成因果概率分量(不支持候选);
        验收[9] = 用途分量.has_value()
            && 含有因果身份字段<因果概率分量>
            && !含有旧原因结构键字段<因果概率分量>
            && !含有旧结果结构键字段<因果概率分量>
            && !含有旧因果规则版本字段<因果概率分量>
            && 因果完整结构键相同(用途分量->因果身份, 基准身份)
            && 用途分量->机会数 == 基准候选.机会数
            && 用途分量->正结果数 == 基准候选.正结果数
            && 用途分量->负结果数 == 基准候选.负结果数
            && 用途分量->Q10000 == 基准候选.Q10000
            && !不支持分量.has_value();

        验收[10] = 用途事件回归通过;
        验收[11] = std::is_copy_constructible_v<因果完整结构键>
            && std::is_move_constructible_v<因果完整结构键>
            && std::is_nothrow_destructible_v<因果完整结构键>
            && !std::is_pointer_v<因果完整结构键>;
        bool 连续二十轮稳定 = true;
        for (std::size_t 轮次 = 0; 轮次 < 20; ++轮次) {
            const auto 当前结果 = 形成因果完整结构键(基准候选);
            const auto 当前分量 = 形成因果概率分量(基准候选);
            if (!当前结果.成功() || !当前分量.has_value()
                || !因果完整结构键相同(*当前结果.身份, 基准身份)
                || !因果完整结构键相同(当前分量->因果身份, 基准身份)
                || 计算因果完整结构键稳定哈希(*当前结果.身份) != 基准哈希一) {
                连续二十轮稳定 = false;
                break;
            }
        }
        验收[12] = 用途事件回归通过 && 连续二十轮稳定
            && std::all_of(
                验收.begin(), 验收.begin() + 12, [](bool 通过) { return 通过; });
        验收[13] = std::all_of(
            验收.begin(), 验收.begin() + 13, [](bool 通过) { return 通过; });
    } catch (...) {
        验收.fill(false);
    }

    static constexpr std::array<const char*, 14> 名称{
        "R01 当前接口与格式运行时子项；正式提交外部核对",
        "R02 纯值身份字段运行时子项；唯一所有权外部核对",
        "R03 原因结果固定有序角色",
        "R04 全字段比较与无效材料拒绝",
        "R05 四类显式版本漂移不支持",
        "R06 默认态合法组合与零结构变化",
        "R07 optional稳定哈希与两角色字段混入",
        "R08 哈希只召回且完整比较裁决",
        "R09 机会计数与Q10000不进入身份",
        "R10 生产用途分量形成入口单一身份与四项计数",
        "R11 三种用途结果既有回归",
        "R12 纯值类型运行时子项；禁止依赖外部扫描",
        "R13 进程内二十轮稳定；两配置与完整回归外部执行",
        "R14 运行时子项汇总；归档提交推送外部结算"};
    std::size_t 失败数量 = 0;
    for (std::size_t 索引 = 0; 索引 < 验收.size(); ++索引) {
        if (!验收[索引]) ++失败数量;
        std::cout << "CAUSAL-IDENTITY-S1-" << 名称[索引] << ": "
            << (验收[索引] ? "通过" : "失败") << '\n';
    }
    return {"CAUSAL-IDENTITY-S1", "因果完整结构键与用途概率分量",
        失败数量 == 0, 验收.size(), 失败数量};
}

}
#endif
