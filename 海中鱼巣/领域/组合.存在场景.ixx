// 文件规则：存在场景组合器只编排已有场景中的实际存在创建和接纳，不直接操作事务或仓库。
module;

#include "../核心/句柄.h"

#include <cstdint>

export module 海中鱼巣.领域.组合.存在场景;

import 海中鱼巣.领域.数据操作.存在场景;

export namespace 海中鱼巣 {

struct 已有场景创建并接纳实际存在请求 {
    节点句柄 场景;
    std::uint64_t 存在幂等主键 = 0;
};

class 存在场景组合器 final {
public:
    explicit 存在场景组合器(存在场景数据操作& 数据操作) : 数据操作_(数据操作) {
    }

    存在场景业务结果 在已有场景中创建并接纳实际存在(
        const 已有场景创建并接纳实际存在请求& 请求) const {
        if (!句柄有效(请求.场景) || 请求.存在幂等主键 == 0) return {};
        const auto 场景材料 = 数据操作_.读取节点身份(请求.场景);
        if (场景材料.状态 != 存在场景读取状态::已找到) {
            return 映射读取失败(场景材料.状态);
        }
        if (场景材料.类型 != 节点类型::场景) return {};

        const auto 存在材料 = 数据操作_.读取主键身份(请求.存在幂等主键);
        if (存在材料.状态 == 存在场景读取状态::未找到) {
            return 数据操作_.在已有场景中创建并接纳实际存在(
                请求.场景, 请求.存在幂等主键);
        }
        if (存在材料.状态 != 存在场景读取状态::已找到) {
            return 映射读取失败(存在材料.状态);
        }
        if (存在材料.类型 != 节点类型::存在
            || 存在材料.虚拟来源.has_value()
            || 存在材料.来源关系.has_value()) {
            return {存在场景业务状态::幂等冲突};
        }

        const auto 当前归属 = 数据操作_.读取场景归属(请求.场景, 存在材料.节点);
        if (当前归属.已归属()) {
            return {存在场景业务状态::幂等读回,
                存在材料.节点, 请求.场景, *当前归属.归属关系};
        }
        if (当前归属.状态 != 存在场景读取状态::未找到) {
            return 映射读取失败(当前归属.状态);
        }
        return 数据操作_.创建场景归属(请求.场景, 存在材料.节点);
    }

private:
    static 存在场景业务结果 映射读取失败(存在场景读取状态 状态) noexcept {
        switch (状态) {
        case 存在场景读取状态::许可拒绝:
            return {存在场景业务状态::许可拒绝};
        case 存在场景读取状态::版本漂移:
            return {存在场景业务状态::版本漂移};
        case 存在场景读取状态::内部不一致:
            return {存在场景业务状态::内部不一致};
        default:
            return {存在场景业务状态::入口拒绝};
        }
    }

    存在场景数据操作& 数据操作_;
};

}
