class 需求结算写入规格 final {
public:
    需求结算写入规格() = delete;

private:
    friend class 需求任务方法数据操作;

    需求结算写入规格(
        节点句柄 需求,
        节点句柄 来源任务,
        节点句柄 实际状态,
        节点句柄 动态证据,
        节点句柄 因果引用,
        分层需求结算结论 结论,
        实例状态写入规格 结算状态规格)
        : 需求_(需求), 来源任务_(来源任务), 实际状态_(实际状态),
          动态证据_(动态证据), 因果引用_(因果引用), 结论_(结论),
          结算状态规格_(std::move(结算状态规格)) {}

    bool 完整() const noexcept {
        const bool 因果句柄完整 = 句柄有效(因果引用_)
            || (因果引用_.仓库编号 == 0 && 因果引用_.节点编号 == 0
                && 因果引用_.版本号 == 0);
        return 句柄有效(需求_) && 句柄有效(来源任务_) && 句柄有效(实际状态_)
            && 句柄有效(动态证据_)
            && 因果句柄完整 && 结论_ == 分层需求结算结论::已满足
            && 结算状态规格_.完整()
            && 结算状态规格_.读取状态值() == static_cast<std::int64_t>(结论_);
    }

    节点句柄 需求_;
    节点句柄 来源任务_;
    节点句柄 实际状态_;
    节点句柄 动态证据_;
    节点句柄 因果引用_;
    分层需求结算结论 结论_ = 分层需求结算结论::未结算;
    实例状态写入规格 结算状态规格_;
};

