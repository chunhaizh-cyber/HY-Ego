    }

    std::vector<方法登记项材料> 读取方法登记项组(节点句柄 登记根) const {
        std::vector<方法登记项材料> 输出;
        if (!有效() || !句柄有效(登记根)) return 输出;
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) return 输出;
        for (const auto& 记录 : 关系_.获取关系记录组(登记根, 关系类型::归属, 许可.读取令牌())) {
            const auto 材料 = 读取方法登记项_已许可(记录.目标节点, 许可.读取令牌());
            if (!材料.完整()) return {};
            输出.push_back(材料);
        }
        std::sort(输出.begin(), 输出.end(), [](const auto& 左, const auto& 右) {
            return 节点稳定小于(左.身份.节点, 右.身份.节点);
        });
        return 输出;
    }

    std::vector<方法规格材料> 读取方法规格组(
        节点句柄 方法首,
        分层方法角色 角色) const {
        std::vector<方法规格材料> 输出;
        if (!有效() || !句柄有效(方法首) || !是规格角色(角色)) return 输出;
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) return 输出;
        for (const auto& 记录 : 关系_.获取关系记录组(方法首, 关系类型::模板, 许可.读取令牌())) {
            if (记录.顺序号 != static_cast<std::int64_t>(角色)) continue;
            const auto 材料 = 读取方法规格_已许可(方法首, 记录.目标节点, 许可.读取令牌());
            const bool 完整 = 角色 == 分层方法角色::方法条件 ? 材料.完整条件()
                : 角色 == 分层方法角色::方法结果 ? 材料.完整结果()
                : 材料.完整动作入口();
            if (!完整) return {};
            输出.push_back(材料);
        }
        std::sort(输出.begin(), 输出.end(), [](const auto& 左, const auto& 右) {
            return 节点稳定小于(左.身份.节点, 右.身份.节点);
        });
        return 输出;
    }

    需求提交结果 创建完整目标状态需求(const 完整需求写入规格& 规格) const {
        return 创建完整目标状态需求_实现(规格
#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
            , nullptr
#endif
        );
    }

    需求提交结果 创建概念命名需求(const 概念命名需求写入规格& 规格) const {
        if (!规格.完整()) return {};
        const auto 写前 = 读取主键需求(规格.需求主键_);
        if (写前.状态 == 需求任务方法读取状态::已找到) {
            return 概念命名需求匹配(写前, 规格)
                ? 需求提交结果{需求任务方法业务状态::幂等读回, 写前}
                : 需求提交结果{需求任务方法业务状态::幂等冲突};
        }
        if (写前.状态 != 需求任务方法读取状态::未找到) return 从需求读取失败(写前.状态);

        const auto 根 = 读取需求(规格.服务根需求_);
        const auto 目标状态 = 状态数据操作_.读取状态材料(规格.目标状态_);
        if (!根.完整目标状态需求() || 根.主体 != 规格.主体_
            || 根.目标宿主 != 规格.目标宿主_ || 根.场景 != 规格.场景_
            || !目标状态.完整抽象状态()) return {};

        节点句柄 新需求;
        const auto 结构结果 = 执行器_.执行([&](结构写入会话& 会话) {
            if (!会话需求端点匹配(会话, 规格.主体_, 规格.目标宿主_, 规格.场景_,
                    规格.目标特征_, 规格.当前特征状态材料_, 规格.目标状态_)
                || !会话需求材料匹配(会话, 规格.服务根需求_, 根)) return;
            主信息句柄 新主信息;
            if (!写入身份_会话(会话, 节点类型::需求, 规格.需求主键_, 新主信息, 新需求)) return;
            std::vector<关系句柄> 写入关系;
            if (!写入需求关系组_会话(会话, 新需求, 规格.主体_, 规格.目标宿主_,
                    规格.场景_, 规格.目标特征_, 规格.当前特征状态材料_,
                    规格.目标状态_, 写入关系)) return;
            if (!追加关系_会话(会话, 关系类型::需求目标概念, 新需求,
                    规格.目标概念_, 0, 写入关系)) return;
            const auto 挂载 = 会话.挂载或重挂节点(新需求, 规格.服务根需求_);
            if (!挂载.关系已确定() || !挂载.父关系.has_value()
                || !会话.关系可读(*挂载.父关系)) return;
            if (会话.主信息可读(新主信息) && 会话.节点可读(新需求)
                && 会话.主键绑定匹配(规格.需求主键_, 新需求)) {
                (void)会话.请求提交();
            }
        });
        const auto 当前 = 读取主键需求(规格.需求主键_);
        if (概念命名需求匹配(当前, 规格)) {
            return {结构结果.状态 == 结构写入状态::已提交
                    ? 需求任务方法业务状态::已提交 : 需求任务方法业务状态::幂等读回,
                当前};
        }
        if (当前.状态 == 需求任务方法读取状态::已找到) {
            return {需求任务方法业务状态::幂等冲突};
        }
        return 从结构失败形成需求结果(结构结果);
    }

    需求提交结果 更新需求父子(节点句柄 子需求, 节点句柄 新父需求) const {
        if (!有效() || !句柄有效(子需求) || !句柄有效(新父需求)
            || 子需求 == 新父需求) return {};
        const auto 子 = 读取需求(子需求);
        const auto 父 = 读取需求(新父需求);
        if (!子.完整目标状态需求() || !父.完整目标状态需求()) return {};
        if (子.父需求 == std::optional<节点句柄>{新父需求}
            && 子.父子关系.has_value() && 子.父子关系->当前有效()) {
            return {需求任务方法业务状态::幂等读回, 子};
        }

        节点挂载结果 挂载;
        const auto 结构结果 = 执行器_.执行([&](结构写入会话& 会话) {
            if (!会话需求材料匹配(会话, 子需求, 子)
                || !会话需求材料匹配(会话, 新父需求, 父)) return;
            挂载 = 会话.挂载或重挂节点(子需求, 新父需求);
            if (!挂载.关系已确定() || !挂载.父关系.has_value()
                || !会话.关系可读(*挂载.父关系)) return;
            (void)会话.请求提交();
        });
        const auto 当前 = 读取需求(子需求);
        if (当前.完整目标状态需求() && 当前.父需求 == std::optional<节点句柄>{新父需求}
            && 当前.父子关系.has_value()) {
            return {结构结果.状态 == 结构写入状态::已提交
                    ? 需求任务方法业务状态::已提交 : 需求任务方法业务状态::幂等读回,
                当前};
        }
        return 从结构失败形成需求结果(结构结果);
    }

    任务提交结果 创建任务承接(const 任务承接写入规格& 规格) const {
        if (!规格.完整()) return {};
        const auto 写前 = 读取主键任务(规格.任务主键_);
        if (写前.状态 == 需求任务方法读取状态::已找到) {
            return 任务承接匹配(写前, 规格)
                ? 任务提交结果{需求任务方法业务状态::幂等读回, 写前}
                : 任务提交结果{需求任务方法业务状态::幂等冲突};
        }
        if (写前.状态 != 需求任务方法读取状态::未找到) return 从任务读取失败(写前.状态);
        const auto 需求 = 读取需求(规格.来源需求_);
        if (!需求.完整目标状态需求()) return {};

        节点句柄 新任务;
        const auto 结构结果 = 执行器_.执行([&](结构写入会话& 会话) {
            if (!会话需求材料匹配(会话, 规格.来源需求_, 需求)) return;
            主信息句柄 新主信息;
            if (!写入身份_会话(会话, 节点类型::任务, 规格.任务主键_, 新主信息, 新任务)) return;
            const auto 虚拟存在 = 存在数据操作_.写入虚拟存在_会话(
                会话, 规格.虚拟存在规格_, 新任务);
            if (!虚拟存在.完整()) return;
            const auto 初始状态 = 状态数据操作_.写入候选主体实例状态_会话(
                会话, 规格.初始状态规格_, 虚拟存在.存在);
            if (!初始状态.成功()
                || 初始状态.材料.状态值 != static_cast<std::int64_t>(分层任务生命周期阶段::已创建)) return;
            std::vector<关系句柄> 写入关系;
            if (!追加关系_会话(会话, 关系类型::归属, 规格.来源需求_, 新任务, 0, 写入关系)
                || !追加关系_会话(会话, 关系类型::引用, 新任务, 规格.来源需求_, 0, 写入关系)
                || !追加关系_会话(会话, 关系类型::引用, 新任务, 虚拟存在.存在, 0, 写入关系)
                || !追加关系_会话(会话, 关系类型::引用, 新任务, 需求.场景, 0, 写入关系)
                || !追加关系_会话(会话, 关系类型::模板, 新任务, 需求.目标状态, 0, 写入关系)
                || !追加关系_会话(会话, 关系类型::任务生命周期, 新任务,
                    初始状态.材料.状态节点, 1, 写入关系)) return;
            if (会话.主信息可读(新主信息) && 会话.节点可读(新任务)
                && 会话.主键绑定匹配(规格.任务主键_, 新任务)) {
                (void)会话.请求提交();
            }
        });
        const auto 当前 = 读取主键任务(规格.任务主键_);
        if (任务承接匹配(当前, 规格)) {
            return {结构结果.状态 == 结构写入状态::已提交
                    ? 需求任务方法业务状态::已提交 : 需求任务方法业务状态::幂等读回,
                当前};
        }
        if (当前.状态 == 需求任务方法读取状态::已找到) {
            return {需求任务方法业务状态::幂等冲突};
        }
        return 从结构失败形成任务结果(结构结果);
    }

    任务提交结果 迁移任务生命周期(const 任务生命周期写入规格& 规格) const {
        return 迁移任务生命周期_实现(规格
#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
            , nullptr
#endif
        );
    }

    任务提交结果 提交任务方法选择(const 任务方法选择写入规格& 规格) const {
        if (!规格.完整()) return {};
        const auto 写前记录 = 读取主键选择记录(规格.记录主键_);
        if (写前记录.has_value()) {
            const auto 当前任务 = 读取任务(规格.任务_);
            return 选择匹配(*写前记录, 规格) && 当前任务.当前选择.has_value()
                && 当前任务.当前选择->记录身份.节点 == 写前记录->记录身份.节点
                ? 任务提交结果{需求任务方法业务状态::幂等读回, 当前任务}
                : 任务提交结果{需求任务方法业务状态::幂等冲突};
        }
        const auto 任务 = 读取任务(规格.任务_);
        const auto 方法 = 读取方法登记项(规格.方法_);
        if (!任务.完整承接() || 任务.当前生命周期.阶段 != 分层任务生命周期阶段::筹办中
            || 任务.当前选择.has_value() || !方法.完整()
            || 方法.生命周期 != 分层方法生命周期::活跃
            || 任务.当前生命周期.关系.关系 != 规格.生命周期关系_
            || 任务.当前生命周期.版本 != 规格.生命周期版本_
            || 方法.生命周期关系.关系 != 规格.方法生命周期关系_
            || 方法.生命周期关系.关系.版本号 != 规格.方法生命周期版本_) return {};

        节点句柄 新记录;
        const auto 结构结果 = 执行器_.执行([&](结构写入会话& 会话) {
            if (!会话任务材料匹配(会话, 规格.任务_, 任务)
                || !会话方法登记项匹配(会话, 规格.方法_, 方法)) return;
            主信息句柄 新主信息;
            if (!写入身份_会话(会话, 节点类型::任务方法选择记录,
                    规格.记录主键_, 新主信息, 新记录)) return;
            const std::array<std::int64_t, 16> 值组{
                static_cast<std::int64_t>(规格.幂等材料编号_),
                static_cast<std::int64_t>(规格.方法_.仓库编号),
                static_cast<std::int64_t>(规格.方法_.节点编号),
                static_cast<std::int64_t>(规格.方法_.版本号),
                static_cast<std::int64_t>(规格.生命周期关系_.仓库编号),
                static_cast<std::int64_t>(规格.生命周期关系_.关系编号),
                static_cast<std::int64_t>(规格.生命周期关系_.版本号),
                static_cast<std::int64_t>(规格.生命周期版本_),
                static_cast<std::int64_t>(规格.方法生命周期关系_.仓库编号),
                static_cast<std::int64_t>(规格.方法生命周期关系_.关系编号),
                static_cast<std::int64_t>(规格.方法生命周期关系_.版本号),
                static_cast<std::int64_t>(规格.方法生命周期版本_),
                static_cast<std::int64_t>(规格.排序规则版本_),
                static_cast<std::int64_t>(规格.召回请求规则版本_),
                static_cast<std::int64_t>(规格.来源候选数量_),
                1};
            for (std::size_t 索引号 = 0; 索引号 < 值组.size(); ++索引号) {
                if (!会话.写入候选I64值(新主信息, 索引号, 值组[索引号]).成功()
                    || !会话.候选I64值匹配(新主信息, 索引号, 值组[索引号])) return;
            }
            std::vector<关系句柄> 写入关系;
            if (!追加关系_会话(会话, 关系类型::引用, 规格.任务_, 规格.方法_, 30, 写入关系)
                || !追加关系_会话(会话, 关系类型::任务方法选择,
                    规格.任务_, 新记录, 30, 写入关系)) return;
            if (会话.主信息可读(新主信息) && 会话.节点可读(新记录)
                && 会话.主键绑定匹配(规格.记录主键_, 新记录)) {
                (void)会话.请求提交();
            }
        });
        const auto 当前 = 读取任务(规格.任务_);
        if (当前.当前选择.has_value() && 选择匹配(*当前.当前选择, 规格)) {
            return {结构结果.状态 == 结构写入状态::已提交
                    ? 需求任务方法业务状态::已提交 : 需求任务方法业务状态::幂等读回,
                当前};
        }
        if (读取主键选择记录(规格.记录主键_).has_value()) {
            return {需求任务方法业务状态::幂等冲突};
        }
        return 从结构失败形成任务结果(结构结果);
    }

    任务提交结果 提交任务实际结果并完成(const 任务完成写入规格& 规格) const {
        if (!规格.完整()) return {};
        const auto 写前 = 读取任务(规格.任务_);
        if (!写前.完整承接()) return {};
        if (写前.当前生命周期.阶段 == 分层任务生命周期阶段::已完成
            && 写前.实际结果状态 == std::optional<节点句柄>{规格.实际状态_}) {
            return {需求任务方法业务状态::幂等读回, 写前};
        }
        if (写前.当前生命周期.阶段 != 分层任务生命周期阶段::执行中
            || 写前.实际结果状态.has_value()
            || 写前.当前生命周期.关系.关系 != 规格.预期当前关系_
            || 写前.当前生命周期.版本 != 规格.预期当前版本_) return {};

        const auto 结构结果 = 执行器_.执行([&](结构写入会话& 会话) {
            if (!会话任务材料匹配(会话, 规格.任务_, 写前)
                || 会话.读取节点类型(规格.实际状态_) != std::optional<节点类型>{节点类型::状态}) return;
            const auto 完成状态 = 状态数据操作_.写入实例状态_会话(会话, 规格.完成状态规格_);
            if (!完成状态.成功()
                || 完成状态.材料.状态值 != static_cast<std::int64_t>(分层任务生命周期阶段::已完成)) return;
            std::vector<关系句柄> 写入关系;
            if (!追加关系_会话(会话, 关系类型::引用, 规格.任务_, 规格.实际状态_, 20, 写入关系)
                || !追加关系_会话(会话, 关系类型::任务生命周期, 规格.任务_,
                    完成状态.材料.状态节点,
                    static_cast<std::int64_t>(规格.预期当前版本_ + 1), 写入关系)) return;
            const auto 失效 = 会话.失效已发布关系(规格.预期当前关系_);
            if (!失效.成功()) return;
            const auto 失效审计 = 会话.读取关系审计(*失效.值);
            if (!失效审计.has_value() || 失效审计->状态 != 记录状态::已失效) return;
            (void)会话.请求提交();
        });
        const auto 当前 = 读取任务(规格.任务_);
        if (当前.完整承接() && 当前.当前生命周期.阶段 == 分层任务生命周期阶段::已完成
            && 当前.实际结果状态 == std::optional<节点句柄>{规格.实际状态_}) {
            return {结构结果.状态 == 结构写入状态::已提交
                    ? 需求任务方法业务状态::已提交 : 需求任务方法业务状态::幂等读回,
                当前};
        }
        return 从结构失败形成任务结果(结构结果);
    }

    需求提交结果 提交需求结算(const 需求结算写入规格& 规格) const {
        if (!规格.完整()) return {};
        const auto 写前 = 读取需求(规格.需求_);
        if (写前.状态 != 需求任务方法读取状态::已找到) {
            return 从需求读取失败(写前.状态);
        }
        if (!写前.完整目标状态需求()) {
            return {需求任务方法业务状态::内部不一致};
        }
        const auto 任务 = 读取任务(规格.来源任务_);
        if (任务.状态 != 需求任务方法读取状态::已找到) {
            return 从需求读取失败(任务.状态);
        }
        if (!任务.完整承接()) return {需求任务方法业务状态::内部不一致};
        if (任务.来源需求 != 规格.需求_
            || 任务.当前生命周期.阶段 != 分层任务生命周期阶段::已完成
            || 任务.实际结果状态 != std::optional<节点句柄>{规格.实际状态_}
            || 规格.结算状态规格_.读取场景() != 任务.场景
            || 规格.结算状态规格_.读取主体() != 任务.虚拟存在) return {};
        const auto 动态身份 = 状态数据操作_.读取节点身份(规格.动态证据_);
        if (!动态身份.当前可读()) {
            return {映射状态动态读取失败(动态身份.状态)};
        }
        if (动态身份.类型 != 节点类型::动态) return {};
        if (句柄有效(规格.因果引用_)) {
            const auto 因果身份 = 状态数据操作_.读取节点身份(规格.因果引用_);
            if (!因果身份.当前可读()) {
                return {映射状态动态读取失败(因果身份.状态)};
            }
            if (因果身份.类型 != 节点类型::因果引用) return {};
        }
        if (写前.正式结算.has_value()) {
            return 正式结算匹配(*写前.正式结算, 规格, 写前, 任务)
                ? 需求提交结果{需求任务方法业务状态::幂等读回, 写前}
                : 需求提交结果{需求任务方法业务状态::幂等冲突};
        }

        需求结算会话收口 会话收口 = 需求结算会话收口::未进入;
        const auto 结构结果 = 执行器_.执行([&](结构写入会话& 会话) {
            if (!会话需求材料匹配(会话, 规格.需求_, 写前)
                || !会话任务材料匹配(会话, 规格.来源任务_, 任务)
                || 会话.读取节点类型(规格.实际状态_) != std::optional<节点类型>{节点类型::状态}
                || 会话.读取节点类型(规格.动态证据_) != std::optional<节点类型>{节点类型::动态}
                || (句柄有效(规格.因果引用_)
                    && 会话.读取节点类型(规格.因果引用_)
                        != std::optional<节点类型>{节点类型::因果引用})) {
                会话收口 = 需求结算会话收口::版本漂移;
                return;
            }
            std::optional<关系记录> 已有归属;
            const auto 归属状态 = 查找状态型归属_会话(会话, 规格.需求_, 已有归属);
            if (归属状态 == 需求任务方法读取状态::已找到) {
                会话收口 = 需求结算会话收口::并发占用;
                return;
            }
            if (归属状态 != 需求任务方法读取状态::未找到) {
                会话收口 = 需求结算会话收口::内部不一致;
                return;
            }
            const auto 结算状态 = 状态数据操作_.写入实例状态_会话(会话, 规格.结算状态规格_);
            if (!结算状态.成功()) {
                switch (结算状态.状态) {
                case 状态写入参与状态::入口拒绝:
                    会话收口 = 需求结算会话收口::入口拒绝;
                    break;
                case 状态写入参与状态::版本漂移:
                    会话收口 = 需求结算会话收口::版本漂移;
                    break;
                default:
                    会话收口 = 需求结算会话收口::内部不一致;
                    break;
                }
                return;
            }
            if (结算状态.材料.状态值 != static_cast<std::int64_t>(规格.结论_)) {
                会话收口 = 需求结算会话收口::内部不一致;
                return;
            }
            std::vector<关系句柄> 写入关系;
            if (!追加关系_会话(会话, 关系类型::归属, 规格.需求_,
                    结算状态.材料.状态节点,
                    static_cast<std::int64_t>(结算状态.材料.发生时间戳), 写入关系)
                || !追加关系_会话(会话, 关系类型::引用, 结算状态.材料.状态节点,
                    规格.来源任务_, 结算来源任务顺序号, 写入关系)
                || !追加关系_会话(会话, 关系类型::模板, 结算状态.材料.状态节点,
                    写前.目标状态, 结算目标状态顺序号, 写入关系)
                || !追加关系_会话(会话, 关系类型::引用, 结算状态.材料.状态节点,
                    规格.实际状态_, 结算实际状态顺序号, 写入关系)
                || !追加关系_会话(会话, 关系类型::因果来源,
                    结算状态.材料.状态节点, 规格.动态证据_,
                    结算动态证据顺序号, 写入关系)) {
                会话收口 = 需求结算会话收口::内部不一致;
                return;
            }
            if (句柄有效(规格.因果引用_)
                && !追加关系_会话(会话, 关系类型::引用,
                    结算状态.材料.状态节点, 规格.因果引用_,
                    结算因果引用顺序号, 写入关系)) {
                会话收口 = 需求结算会话收口::内部不一致;
                return;
            }
            需求正式结算材料 会话材料;
            const auto 会话读取 = 读取正式结算材料_会话(
                会话, 规格.需求_, 写前, 任务, 结算状态.材料, 会话材料);
            if (会话读取 != 需求任务方法读取状态::已找到
                || !正式结算匹配(会话材料, 规格, 写前, 任务)
                || !会话.请求提交()) {
                会话收口 = 会话读取 == 需求任务方法读取状态::版本漂移
                    ? 需求结算会话收口::版本漂移
                    : 需求结算会话收口::内部不一致;
                return;
            }
            会话收口 = 需求结算会话收口::已请求提交;
        });

        if (会话收口 == 需求结算会话收口::内部不一致) {
            return {需求任务方法业务状态::内部不一致};
        }
        if (会话收口 == 需求结算会话收口::入口拒绝) return {};
        if (会话收口 == 需求结算会话收口::未进入) {
            return 从结构失败形成需求结果(结构结果);
        }

        const auto 当前 = 读取需求(规格.需求_);
        if (当前.状态 != 需求任务方法读取状态::已找到) {
            return 从需求读取失败(当前.状态);
        }
        if (!当前.正式结算.has_value()) {
            return {会话收口 == 需求结算会话收口::版本漂移
                ? 需求任务方法业务状态::版本漂移
                : 需求任务方法业务状态::内部不一致};
        }
        const auto 当前任务 = 读取任务(规格.来源任务_);
        if (当前任务.状态 != 需求任务方法读取状态::已找到) {
            return 从需求读取失败(当前任务.状态);
        }
        if (!当前任务.完整承接()) {
            return {需求任务方法业务状态::内部不一致};
        }
        if (会话收口 == 需求结算会话收口::版本漂移
            || 会话收口 == 需求结算会话收口::并发占用) {
            return 正式结算匹配(*当前.正式结算, 规格, 当前, 当前任务)
                ? 需求提交结果{需求任务方法业务状态::幂等读回, 当前}
                : 需求提交结果{需求任务方法业务状态::幂等冲突};
        }
        if (会话收口 != 需求结算会话收口::已请求提交
            || 结构结果.状态 != 结构写入状态::已提交
            || !正式结算匹配(*当前.正式结算, 规格, 当前, 当前任务)) {
            return {需求任务方法业务状态::内部不一致};
        }
        return {需求任务方法业务状态::已提交, 当前};
    }

    方法提交结果 创建方法登记根(const 方法登记根写入规格& 规格) const {
        if (!规格.完整()) return {};
        const auto 写前 = 读取主键方法登记根(规格.根主键_);
        if (写前.状态 == 需求任务方法读取状态::已找到) {
            return 方法根匹配(写前, 规格)
                ? 方法提交结果{需求任务方法业务状态::幂等读回, 写前}
                : 方法提交结果{需求任务方法业务状态::幂等冲突};
        }
        if (写前.状态 != 需求任务方法读取状态::未找到) {
            return {映射读取失败(写前.状态)};
        }

        节点句柄 新根;
        const auto 结构结果 = 执行器_.执行([&](结构写入会话& 会话) {
            主信息句柄 新主信息;
            if (!写入身份_会话(会话, 节点类型::方法, 规格.根主键_, 新主信息, 新根)) return;
            const auto 角色 = 状态数据操作_.写入抽象状态_会话(会话, 规格.角色状态_);
            const auto 活跃 = 状态数据操作_.写入抽象状态_会话(会话, 规格.活跃状态_);
            const auto 失效 = 状态数据操作_.写入抽象状态_会话(会话, 规格.失效状态_);
            if (!角色.成功() || !活跃.成功() || !失效.成功()
                || 角色.材料.状态值 != static_cast<std::int64_t>(分层方法角色::方法登记根)
                || 活跃.材料.状态值 != static_cast<std::int64_t>(分层方法生命周期::活跃)
                || 失效.材料.状态值 != static_cast<std::int64_t>(分层方法生命周期::已失效)) return;
            std::vector<关系句柄> 写入关系;
            if (!追加关系_会话(会话, 关系类型::模板, 新根, 角色.材料.状态节点, 0, 写入关系)
                || !追加关系_会话(会话, 关系类型::模板, 新根, 活跃.材料.状态节点, 40, 写入关系)
                || !追加关系_会话(会话, 关系类型::模板, 新根, 失效.材料.状态节点, 41, 写入关系)) return;
            if (会话.主信息可读(新主信息) && 会话.节点可读(新根)
                && 会话.主键绑定匹配(规格.根主键_, 新根)) (void)会话.请求提交();
        });
        const auto 当前 = 读取主键方法登记根(规格.根主键_);
        if (方法根匹配(当前, 规格)) {
            return {结构结果.状态 == 结构写入状态::已提交
                    ? 需求任务方法业务状态::已提交 : 需求任务方法业务状态::幂等读回,
                当前};
        }
        if (当前.状态 == 需求任务方法读取状态::已找到) {
            return {需求任务方法业务状态::幂等冲突};
        }
        return {映射结构失败(结构结果)};
    }

    方法提交结果 创建方法首(const 方法首写入规格& 规格) const {
        if (!规格.完整()) return {};
        const auto 写前身份 = 读取主键身份(规格.方法主键_);
        if (写前身份.状态 == 需求任务方法读取状态::已找到) {
            const auto 当前 = 读取方法登记项(写前身份.节点);
            return 方法首匹配(当前, 规格)
                ? 方法提交结果{需求任务方法业务状态::幂等读回, {}, 当前}
                : 方法提交结果{需求任务方法业务状态::幂等冲突};
        }
        if (写前身份.状态 != 需求任务方法读取状态::未找到) {
            return {映射读取失败(写前身份.状态)};
        }
        const auto 根 = 读取方法登记根(规格.登记根_);
        if (!根.完整()) return {};

        节点句柄 新方法;
        const auto 结构结果 = 执行器_.执行([&](结构写入会话& 会话) {
            if (!会话方法根匹配(会话, 根)) return;
            主信息句柄 新主信息;
            if (!写入身份_会话(会话, 节点类型::方法, 规格.方法主键_, 新主信息, 新方法)) return;
            const auto 角色 = 状态数据操作_.写入抽象状态_会话(会话, 规格.角色状态_);
            const auto 虚拟存在 = 存在数据操作_.写入虚拟存在_会话(
                会话, 规格.虚拟存在规格_, 新方法);
            if (!角色.成功() || !虚拟存在.完整()
                || 角色.材料.状态值 != static_cast<std::int64_t>(分层方法角色::方法首)) return;
            std::vector<关系句柄> 写入关系;
            if (!追加关系_会话(会话, 关系类型::模板, 新方法, 角色.材料.状态节点, 0, 写入关系)
                || !追加关系_会话(会话, 关系类型::引用, 新方法, 虚拟存在.存在, 0, 写入关系)
                || !追加关系_会话(会话, 关系类型::模板, 新方法, 根.活跃状态, 2, 写入关系)
                || !追加关系_会话(会话, 关系类型::归属, 规格.登记根_, 新方法, 0, 写入关系)) return;
            if (会话.主信息可读(新主信息) && 会话.节点可读(新方法)
                && 会话.主键绑定匹配(规格.方法主键_, 新方法)) (void)会话.请求提交();
        });
        const auto 当前 = 读取方法登记项(新方法);
        if (方法首匹配(当前, 规格)) {
            return {结构结果.状态 == 结构写入状态::已提交
                    ? 需求任务方法业务状态::已提交 : 需求任务方法业务状态::幂等读回,
                {}, 当前};
        }
        const auto 当前身份 = 读取主键身份(规格.方法主键_);
        if (当前身份.状态 == 需求任务方法读取状态::已找到) {
            const auto 并发当前 = 读取方法登记项(当前身份.节点);
            return 方法首匹配(并发当前, 规格)
                ? 方法提交结果{需求任务方法业务状态::幂等读回, {}, 并发当前}
                : 方法提交结果{需求任务方法业务状态::幂等冲突};
        }
        return {映射结构失败(结构结果)};
    }

    方法提交结果 创建方法条件(const 方法条件写入规格& 规格) const {
        return 创建方法规格_实现(规格);
    }

    方法提交结果 创建方法结果(const 方法结果写入规格& 规格) const {
        return 创建方法规格_实现(规格);
    }

    方法提交结果 创建方法动作入口(const 方法动作入口写入规格& 规格) const {
        return 创建方法规格_实现(规格);
    }

    方法提交结果 迁移方法生命周期(const 方法生命周期写入规格& 规格) const {
        if (!规格.完整()) return {};
        const auto 写前 = 读取方法登记项(规格.方法首_);
        if (!写前.完整() || 写前.生命周期关系.关系 != 规格.预期当前关系_) return {};
        if (写前.生命周期 == 规格.目标生命周期_) {
            return {需求任务方法业务状态::幂等读回, {}, 写前};
        }
        const auto 根 = 读取方法登记根(写前.登记根);
        if (!根.完整()) return {};
        const auto 目标状态 = 规格.目标生命周期_ == 分层方法生命周期::活跃
            ? 根.活跃状态 : 根.失效状态;

        const auto 结构结果 = 执行器_.执行([&](结构写入会话& 会话) {
            if (!会话方法登记项匹配(会话, 规格.方法首_, 写前)
                || !会话方法根匹配(会话, 根)) return;
            const auto 重挂 = 会话.重挂已发布关系(
                规格.预期当前关系_, 规格.方法首_, 目标状态);
            if (!重挂.成功() || !会话.关系可读(*重挂.值)) return;
            (void)会话.请求提交();
        });
        const auto 当前 = 读取方法登记项(规格.方法首_);
        if (当前.完整() && 当前.生命周期 == 规格.目标生命周期_
            && 当前.生命周期关系.关系.关系编号 == 规格.预期当前关系_.关系编号
            && 当前.生命周期关系.关系.版本号 == 规格.预期当前关系_.版本号 + 1) {
            return {结构结果.状态 == 结构写入状态::已提交
                    ? 需求任务方法业务状态::已提交 : 需求任务方法业务状态::幂等读回,
                {}, 当前};
        }
        return {映射结构失败(结构结果)};
    }

    std::optional<方法动作桥请求材料> 读取任务动作桥请求(节点句柄 任务) const {
        const auto 任务材料 = 读取任务(任务);
        if (!任务材料.完整承接() || !任务材料.当前选择.has_value()
            || 任务材料.当前生命周期.阶段 != 分层任务生命周期阶段::执行中) return std::nullopt;
        const auto 方法 = 读取方法登记项(任务材料.当前选择->方法);
        if (!方法.完整() || 方法.生命周期 != 分层方法生命周期::活跃) return std::nullopt;
        const auto 动作组 = 读取方法规格组(方法.身份.节点, 分层方法角色::动作入口);
        if (动作组.size() != 1 || !动作组.front().完整动作入口()) return std::nullopt;
        const auto& 动作 = 动作组.front();
        return 方法动作桥请求材料{
            任务, 方法.身份.节点, 动作.身份.节点, 动作.稳定动作键,
            *动作.输入场景, *动作.输出场景};
    }

#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
    需求任务方法故障自检结果 执行完整需求固定故障自检(
        const 完整需求写入规格& 规格,
        std::size_t 故障写点) const {
        固定故障控制 控制{故障写点};
        const auto 结果 = 创建完整目标状态需求_实现(规格, &控制);
        return {结果.状态, 控制.已执行写点, 控制.故障已命中};
    }

    需求任务方法故障自检结果 执行任务生命周期固定故障自检(
        const 任务生命周期写入规格& 规格,
        std::size_t 故障写点) const {
        固定故障控制 控制{故障写点};
        const auto 结果 = 迁移任务生命周期_实现(规格, &控制);
        return {结果.状态, 控制.已执行写点, 控制.故障已命中};
    }

    需求任务方法故障自检结果 执行方法动作入口固定故障自检(
        const 方法动作入口写入规格& 规格,
        std::size_t 故障写点) const {
        固定故障控制 控制{故障写点};
        const auto 结果 = 创建方法规格_实现(规格, &控制);
        return {结果.状态, 控制.已执行写点, 控制.故障已命中};
    }
#endif

private:
    static constexpr std::int64_t 需求主体顺序号 = 1;
    static constexpr std::int64_t 需求目标宿主顺序号 = 2;
    static constexpr std::int64_t 需求场景顺序号 = 3;
    static constexpr std::int64_t 需求目标特征顺序号 = 4;
    static constexpr std::int64_t 需求当前特征状态顺序号 = 5;
    static constexpr std::int64_t 任务实际结果顺序号 = 20;
    static constexpr std::int64_t 任务方法选择顺序号 = 30;
    static constexpr std::uint64_t 状态值槽位 = 0;
    static constexpr std::uint64_t 状态时间戳槽位 = 1;
    static constexpr std::uint64_t 状态幂等编号低位槽位 = 2;
    static constexpr std::uint64_t 状态幂等编号高位槽位 = 3;
    static constexpr std::int64_t 结算来源任务顺序号 = 1;
    static constexpr std::int64_t 结算目标状态顺序号 = 2;
    static constexpr std::int64_t 结算实际状态顺序号 = 3;
    static constexpr std::int64_t 结算动态证据顺序号 = 4;
    static constexpr std::int64_t 结算因果引用顺序号 = 5;

    enum class 需求结算会话收口 : std::uint8_t {
        未进入 = 0,
        并发占用 = 1,
        入口拒绝 = 2,
        版本漂移 = 3,
        内部不一致 = 4,
        已请求提交 = 5
    };

    enum class 生命周期历史核对状态 : std::uint8_t {
        目标不存在 = 0,
        唯一同义 = 1,
        同键异义 = 2,
        内部不一致 = 3
    };

    struct 生命周期历史核对结果 {
        生命周期历史核对状态 状态 = 生命周期历史核对状态::内部不一致;
        任务权威材料 当前;
    };

#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
    struct 固定故障控制 {
        std::size_t 目标写点 = 0;
        std::size_t 已执行写点 = 0;
        bool 故障已命中 = false;
    };

    static bool 命中固定故障(固定故障控制* 控制) noexcept {
        if (控制 == nullptr) return false;
        ++控制->已执行写点;
        if (控制->目标写点 != 0 && 控制->已执行写点 == 控制->目标写点) {
            控制->故障已命中 = true;
            return true;
        }
        return false;
    }
#endif

    static bool 节点稳定小于(const 节点句柄& 左, const 节点句柄& 右) noexcept {
        if (左.仓库编号 != 右.仓库编号) return 左.仓库编号 < 右.仓库编号;
        if (左.节点编号 != 右.节点编号) return 左.节点编号 < 右.节点编号;
        return 左.版本号 < 右.版本号;
    }

    static bool 是规格角色(分层方法角色 角色) noexcept {
        return 角色 == 分层方法角色::方法条件
            || 角色 == 分层方法角色::方法结果
            || 角色 == 分层方法角色::动作入口;
    }

    static bool 是终态(分层任务生命周期阶段 阶段) noexcept {
        return 阶段 == 分层任务生命周期阶段::已完成
            || 阶段 == 分层任务生命周期阶段::失败
            || 阶段 == 分层任务生命周期阶段::取消;
    }

    static bool 合法任务迁移(
        分层任务生命周期阶段 当前,
        分层任务生命周期阶段 目标) noexcept {
        if (是终态(当前)) return false;
        return (当前 == 分层任务生命周期阶段::已创建 && 目标 == 分层任务生命周期阶段::已承接)
            || (当前 == 分层任务生命周期阶段::已承接 && 目标 == 分层任务生命周期阶段::筹办中)
            || (当前 == 分层任务生命周期阶段::筹办中 && 目标 == 分层任务生命周期阶段::排队中)
            || (当前 == 分层任务生命周期阶段::排队中 && 目标 == 分层任务生命周期阶段::执行中)
            || (当前 == 分层任务生命周期阶段::执行中 && 目标 == 分层任务生命周期阶段::等待中)
            || (当前 == 分层任务生命周期阶段::等待中 && 目标 == 分层任务生命周期阶段::执行中)
            || ((当前 == 分层任务生命周期阶段::排队中
                    || 当前 == 分层任务生命周期阶段::执行中
                    || 当前 == 分层任务生命周期阶段::等待中)
                && 目标 == 分层任务生命周期阶段::待重筹办)
            || (当前 == 分层任务生命周期阶段::待重筹办
                && 目标 == 分层任务生命周期阶段::筹办中);
    }

    高级节点身份 读取主键身份(std::uint64_t 主键) const {
        if (!有效() || 主键 == 0) return {};
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) return {需求任务方法读取状态::许可拒绝};
        const auto 节点 = 索引_.按主键查节点(主键, 许可.读取令牌());
        if (!节点.has_value()) return {需求任务方法读取状态::未找到};
        return 读取身份_已许可(*节点, 主键, 许可.读取令牌());
    }

    高级节点身份 读取身份_已许可(
        节点句柄 节点,
        std::optional<std::uint64_t> 预期主键,
        const 结构事务令牌& 令牌) const {
        高级节点身份 输出;
        输出.节点 = 节点;
        if (!句柄有效(节点)) return 输出;
        const auto 记录 = 节点_.读取节点(节点, 令牌);
        if (!记录.has_value()) {
            输出.状态 = 需求任务方法读取状态::版本漂移;
            return 输出;
        }
        if (!主信息_.读取主信息(记录->主信息, 令牌).has_value()) {
            输出.状态 = 需求任务方法读取状态::内部不一致;
            return 输出;
        }
        const auto 主键组 = 索引_.读取节点主键组(节点, 令牌);
        if (主键组.size() != 1 || 主键组.front() == 0
            || (预期主键.has_value() && 主键组.front() != *预期主键)) {
            输出.状态 = 需求任务方法读取状态::内部不一致;
            return 输出;
        }
        输出.状态 = 需求任务方法读取状态::已找到;
        输出.幂等主键 = 主键组.front();
        输出.类型 = 记录->类型;
        输出.主信息 = 记录->主信息;
        return 输出;
    }

    std::optional<高级关系证据> 形成关系证据_已许可(
        const 关系记录& 记录,
        const 结构事务令牌& 令牌,
        bool 允许失效 = false) const {
        if (记录.关系编号 == 0 || 记录.版本号 == 0
            || (!允许失效 && 记录.状态 != 记录状态::有效)) return std::nullopt;
        const 关系句柄 句柄{关系仓库编号_, 记录.关系编号, 记录.版本号};
        const auto 当前 = 允许失效
            ? 关系_.读取关系审计(句柄, 令牌)
            : 关系_.读取关系(句柄, 令牌);
        if (!当前.has_value() || 当前->关系编号 != 记录.关系编号
            || 当前->版本号 != 记录.版本号 || 当前->类型 != 记录.类型
            || 当前->源节点 != 记录.源节点 || 当前->目标节点 != 记录.目标节点
            || 当前->顺序号 != 记录.顺序号 || 当前->状态 != 记录.状态) return std::nullopt;
        return 高级关系证据{
            句柄, 记录.类型, 记录.源节点, 记录.目标节点,
            记录.顺序号, 记录.状态};
    }

    static bool 设置唯一关系(
        std::optional<高级关系证据>& 目标,
        const 高级关系证据& 值) noexcept {
        if (目标.has_value()) return false;
        目标 = 值;
        return true;
    }

    static std::uint64_t 合并状态幂等编号(
        std::int64_t 低位,
        std::int64_t 高位) noexcept {
        return static_cast<std::uint64_t>(低位)
            | (static_cast<std::uint64_t>(高位) << 32U);
    }

    static 关系值式证据 转换状态关系证据(const 高级关系证据& 证据) noexcept {
        return {证据.关系, 证据.类型, 证据.源节点, 证据.目标节点, 证据.顺序号};
    }

    需求任务方法读取状态 读取结算实例状态_已许可(
        节点句柄 状态,
        const 结构事务令牌& 令牌,
        状态值式材料& 输出) const {
        const auto 身份 = 读取身份_已许可(状态, std::nullopt, 令牌);
        if (!身份.当前可读()) return 身份.状态;
        if (身份.类型 != 节点类型::状态) return 需求任务方法读取状态::类型不匹配;

        const auto 值 = 主信息_.读取I64值(身份.主信息, 状态值槽位, 令牌);
        const auto 时间 = 主信息_.读取I64值(身份.主信息, 状态时间戳槽位, 令牌);
        const auto 低位 = 主信息_.读取I64值(
            身份.主信息, 状态幂等编号低位槽位, 令牌);
        const auto 高位 = 主信息_.读取I64值(
            身份.主信息, 状态幂等编号高位槽位, 令牌);
        if (!值.has_value() || !时间.has_value() || *时间 <= 0
            || !低位.has_value() || !高位.has_value() || *低位 < 0 || *高位 < 0
            || static_cast<std::uint64_t>(*低位) > 0xffff'ffffULL
            || static_cast<std::uint64_t>(*高位) > 0xffff'ffffULL
            || 合并状态幂等编号(*低位, *高位) != 身份.幂等主键
            || *值 != static_cast<std::int64_t>(分层需求结算结论::已满足)) {
            return 需求任务方法读取状态::内部不一致;
        }

        std::optional<高级关系证据> 主体关系;
        std::optional<高级关系证据> 场景关系;
        for (const auto& 记录 : 关系_.获取关系记录组(状态, 关系类型::引用, 令牌)) {
            const auto 证据 = 形成关系证据_已许可(记录, 令牌);
            if (!证据.has_value()) return 需求任务方法读取状态::内部不一致;
            const auto 目标 = 读取身份_已许可(记录.目标节点, std::nullopt, 令牌);
            if (!目标.当前可读()) return 目标.状态;
            if (目标.类型 == 节点类型::存在) {
                if (!设置唯一关系(主体关系, *证据)) {
                    return 需求任务方法读取状态::内部不一致;
                }
            } else if (目标.类型 == 节点类型::场景) {
                if (!设置唯一关系(场景关系, *证据)) {
                    return 需求任务方法读取状态::内部不一致;
                }
            }
        }
        if (!主体关系.has_value() || !场景关系.has_value()) {
            return 需求任务方法读取状态::内部不一致;
        }

        std::optional<高级关系证据> 临时关系;
        for (const auto& 记录 : 关系_.获取关系记录组(
                场景关系->目标节点, 关系类型::运行期临时, 令牌)) {
            if (记录.目标节点 != 状态) continue;
            const auto 证据 = 形成关系证据_已许可(记录, 令牌);
            if (!证据.has_value() || 临时关系.has_value()) {
                return 需求任务方法读取状态::内部不一致;
            }
            临时关系 = *证据;
        }
        if (!临时关系.has_value()) return 需求任务方法读取状态::内部不一致;

        输出.状态 = 状态动态读取状态::已找到;
        输出.种类 = 状态动态材料种类::实例状态;
        输出.幂等主键 = 身份.幂等主键;
        输出.状态节点 = 状态;
        输出.主信息 = 身份.主信息;
        输出.状态值 = *值;
        输出.发生时间戳 = static_cast<std::uint64_t>(*时间);
        输出.主体 = 主体关系->目标节点;
        输出.场景 = 场景关系->目标节点;
        输出.主体关系 = 转换状态关系证据(*主体关系);
        输出.场景关系 = 转换状态关系证据(*场景关系);
        输出.场景临时关系 = 转换状态关系证据(*临时关系);
        return 输出.完整实例状态()
            ? 需求任务方法读取状态::已找到
            : 需求任务方法读取状态::内部不一致;
    }

    需求任务方法读取状态 读取正式结算材料_已许可(
        节点句柄 需求,
        const 需求权威材料& 需求材料,
        const 关系记录& 归属记录,
        const 结构事务令牌& 令牌,
        需求正式结算材料& 输出) const {
        const auto 归属证据 = 形成关系证据_已许可(归属记录, 令牌);
        if (!归属证据.has_value() || 归属记录.类型 != 关系类型::归属
            || 归属记录.源节点 != 需求) return 需求任务方法读取状态::内部不一致;

        状态值式材料 结算状态;
        const auto 状态读取 = 读取结算实例状态_已许可(
            归属记录.目标节点, 令牌, 结算状态);
        if (状态读取 != 需求任务方法读取状态::已找到) return 状态读取;
        if (归属记录.顺序号 != static_cast<std::int64_t>(结算状态.发生时间戳)) {
            return 需求任务方法读取状态::内部不一致;
        }

        std::optional<高级关系证据> 来源任务关系;
        std::optional<高级关系证据> 实际状态关系;
        std::optional<高级关系证据> 因果引用关系;
        for (const auto& 记录 : 关系_.获取关系记录组(
                结算状态.状态节点, 关系类型::引用, 令牌)) {
            const auto 证据 = 形成关系证据_已许可(记录, 令牌);
            if (!证据.has_value()) return 需求任务方法读取状态::内部不一致;
            if (证据->关系 == 结算状态.主体关系.关系
                || 证据->关系 == 结算状态.场景关系.关系) continue;
            const auto 目标 = 读取身份_已许可(记录.目标节点, std::nullopt, 令牌);
            if (!目标.当前可读()) return 目标.状态;
            if (记录.顺序号 == 结算来源任务顺序号 && 目标.类型 == 节点类型::任务) {
                if (!设置唯一关系(来源任务关系, *证据)) {
                    return 需求任务方法读取状态::内部不一致;
                }
            } else if (记录.顺序号 == 结算实际状态顺序号
                && 目标.类型 == 节点类型::状态) {
                if (!设置唯一关系(实际状态关系, *证据)) {
                    return 需求任务方法读取状态::内部不一致;
                }
            } else if (记录.顺序号 == 结算因果引用顺序号
                && 目标.类型 == 节点类型::因果引用) {
                if (!设置唯一关系(因果引用关系, *证据)) {
                    return 需求任务方法读取状态::内部不一致;
                }
            } else {
                return 需求任务方法读取状态::内部不一致;
            }
        }

        std::optional<高级关系证据> 目标状态关系;
        for (const auto& 记录 : 关系_.获取关系记录组(
                结算状态.状态节点, 关系类型::模板, 令牌)) {
            const auto 证据 = 形成关系证据_已许可(记录, 令牌);
            const auto 目标 = 读取身份_已许可(记录.目标节点, std::nullopt, 令牌);
            if (!证据.has_value() || !目标.当前可读()) {
                return 目标.当前可读() ? 需求任务方法读取状态::内部不一致 : 目标.状态;
            }
            if (记录.顺序号 != 结算目标状态顺序号 || 目标.类型 != 节点类型::状态
                || !设置唯一关系(目标状态关系, *证据)) {
                return 需求任务方法读取状态::内部不一致;
            }
        }

        std::optional<高级关系证据> 动态证据关系;
        for (const auto& 记录 : 关系_.获取关系记录组(
                结算状态.状态节点, 关系类型::因果来源, 令牌)) {
            const auto 证据 = 形成关系证据_已许可(记录, 令牌);
            const auto 目标 = 读取身份_已许可(记录.目标节点, std::nullopt, 令牌);
            if (!证据.has_value() || !目标.当前可读()) {
                return 目标.当前可读() ? 需求任务方法读取状态::内部不一致 : 目标.状态;
            }
            if (记录.顺序号 != 结算动态证据顺序号 || 目标.类型 != 节点类型::动态
                || !设置唯一关系(动态证据关系, *证据)) {
                return 需求任务方法读取状态::内部不一致;
            }
        }

        if (!来源任务关系.has_value() || !目标状态关系.has_value()
            || !实际状态关系.has_value() || !动态证据关系.has_value()) {
            return 需求任务方法读取状态::内部不一致;
        }

        输出.结算状态 = 结算状态;
        输出.需求 = 需求;
        输出.需求归属关系 = *归属证据;
        输出.来源任务 = 来源任务关系->目标节点;
        输出.来源任务关系 = *来源任务关系;
        输出.目标状态 = 目标状态关系->目标节点;
        输出.目标状态关系 = *目标状态关系;
        输出.实际状态 = 实际状态关系->目标节点;
        输出.实际状态关系 = *实际状态关系;
        输出.动态证据 = 动态证据关系->目标节点;
        输出.动态证据关系 = *动态证据关系;
        if (因果引用关系.has_value()) {
            输出.因果引用 = 因果引用关系->目标节点;
            输出.因果引用关系 = *因果引用关系;
        }

        const auto 来源任务 = 读取任务_已许可(输出.来源任务, 令牌);
        if (来源任务.状态 != 需求任务方法读取状态::已找到) return 来源任务.状态;
        if (!来源任务.完整承接() || 来源任务.来源需求 != 需求
            || 来源任务.当前生命周期.阶段 != 分层任务生命周期阶段::已完成
            || 来源任务.实际结果状态 != std::optional<节点句柄>{输出.实际状态}
            || 来源任务.场景 != 结算状态.场景
            || 来源任务.虚拟存在 != 结算状态.主体
            || 输出.目标状态 != 需求材料.目标状态 || !输出.完整()) {
            return 需求任务方法读取状态::内部不一致;
        }
        return 需求任务方法读取状态::已找到;
    }

    需求权威材料 读取需求_已许可(
        节点句柄 需求,
        const 结构事务令牌& 令牌) const {
        需求权威材料 输出;
        输出.身份 = 读取身份_已许可(需求, std::nullopt, 令牌);
        if (!输出.身份.当前可读()) {
            输出.状态 = 输出.身份.状态;
            return 输出;
        }
        if (输出.身份.类型 != 节点类型::需求) {
            输出.状态 = 需求任务方法读取状态::类型不匹配;
            return 输出;
        }

        std::optional<高级关系证据> 主体关系;
        std::optional<高级关系证据> 宿主关系;
        std::optional<高级关系证据> 场景关系;
        std::optional<高级关系证据> 特征关系;
        std::optional<高级关系证据> 当前值关系;
        for (const auto& 记录 : 关系_.获取关系记录组(需求, 关系类型::引用, 令牌)) {
            const auto 证据 = 形成关系证据_已许可(记录, 令牌);
            if (!证据.has_value()) return 需求内部不一致(输出);
            const auto 目标 = 读取身份_已许可(记录.目标节点, std::nullopt, 令牌);
            if (!目标.当前可读()) return 需求内部不一致(输出);
            if (记录.顺序号 == 需求主体顺序号 && 目标.类型 == 节点类型::存在) {
                if (!设置唯一关系(主体关系, *证据)) return 需求内部不一致(输出);
            } else if (记录.顺序号 == 需求目标宿主顺序号 && 目标.类型 == 节点类型::存在) {
                if (!设置唯一关系(宿主关系, *证据)) return 需求内部不一致(输出);
            } else if (记录.顺序号 == 需求场景顺序号 && 目标.类型 == 节点类型::场景) {
                if (!设置唯一关系(场景关系, *证据)) return 需求内部不一致(输出);
            } else if (记录.顺序号 == 需求目标特征顺序号 && 目标.类型 == 节点类型::特征) {
                if (!设置唯一关系(特征关系, *证据)) return 需求内部不一致(输出);
            } else if (记录.顺序号 == 需求当前特征状态顺序号 && 目标.类型 == 节点类型::特征值) {
                if (!设置唯一关系(当前值关系, *证据)) return 需求内部不一致(输出);
            }
        }
        if (!宿主关系.has_value()) {
            for (const auto& 记录 : 关系_.获取来源关系记录组(需求, 关系类型::引用, 令牌)) {
                if (记录.顺序号 != 需求目标宿主顺序号) continue;
                const auto 来源 = 读取身份_已许可(记录.源节点, std::nullopt, 令牌);
                const auto 证据 = 形成关系证据_已许可(记录, 令牌);
                if (!来源.当前可读() || 来源.类型 != 节点类型::存在
                    || !证据.has_value() || !设置唯一关系(宿主关系, *证据)) {
                    return 需求内部不一致(输出);
                }
            }
        }

        std::optional<高级关系证据> 目标状态关系;
        for (const auto& 记录 : 关系_.获取关系记录组(需求, 关系类型::模板, 令牌)) {
            if (记录.顺序号 != 0) continue;
            const auto 目标 = 读取身份_已许可(记录.目标节点, std::nullopt, 令牌);
            const auto 证据 = 形成关系证据_已许可(记录, 令牌);
            if (!目标.当前可读() || 目标.类型 != 节点类型::状态
                || !证据.has_value() || !设置唯一关系(目标状态关系, *证据)) {
                return 需求内部不一致(输出);
            }
        }
        if (!主体关系.has_value() || !宿主关系.has_value() || !场景关系.has_value()
            || !特征关系.has_value() || !当前值关系.has_value() || !目标状态关系.has_value()) {
            return 需求内部不一致(输出);
        }
        输出.主体关系 = *主体关系;
        输出.主体 = 主体关系->目标节点;
        输出.目标宿主关系 = *宿主关系;
        输出.目标宿主 = 宿主关系->源节点 == 需求 ? 宿主关系->目标节点 : 宿主关系->源节点;
        输出.场景关系 = *场景关系;
        输出.场景 = 场景关系->目标节点;
        输出.目标特征关系 = *特征关系;
        输出.目标特征 = 特征关系->目标节点;
        输出.当前特征状态关系 = *当前值关系;
        输出.当前特征状态材料 = 当前值关系->目标节点;
        输出.目标状态关系 = *目标状态关系;
        输出.目标状态 = 目标状态关系->目标节点;

        const auto 概念组 = 关系_.获取关系记录组(需求, 关系类型::需求目标概念, 令牌);
        if (概念组.size() > 1) return 需求内部不一致(输出);
        if (概念组.size() == 1) {
            const auto 证据 = 形成关系证据_已许可(概念组.front(), 令牌);
            if (!证据.has_value()) return 需求内部不一致(输出);
            输出.目标概念 = 概念组.front().目标节点;
            输出.目标概念关系 = *证据;
        }

        const auto 父组 = 关系_.获取来源关系记录组(需求, 关系类型::普通父子, 令牌);
        if (父组.size() > 1) return 需求内部不一致(输出);
        if (父组.size() == 1) {
            const auto 父身份 = 读取身份_已许可(父组.front().源节点, std::nullopt, 令牌);
            const auto 证据 = 形成关系证据_已许可(父组.front(), 令牌);
            if (!父身份.当前可读() || 父身份.类型 != 节点类型::需求 || !证据.has_value()) {
                return 需求内部不一致(输出);
            }
            输出.父需求 = 父组.front().源节点;
            输出.父子关系 = *证据;
        }

        std::optional<关系记录> 唯一正式结算;
        for (const auto& 记录 : 关系_.获取关系记录组(需求, 关系类型::归属, 令牌)) {
            const auto 目标 = 读取身份_已许可(记录.目标节点, std::nullopt, 令牌);
            if (!目标.当前可读()) return 需求内部不一致(输出);
            if (目标.类型 != 节点类型::状态) continue;
            if (唯一正式结算.has_value()) return 需求内部不一致(输出);
            唯一正式结算 = 记录;
        }
        if (唯一正式结算.has_value()) {
            需求正式结算材料 正式结算;
            const auto 读取状态 = 读取正式结算材料_已许可(
                需求, 输出, *唯一正式结算, 令牌, 正式结算);
            if (读取状态 != 需求任务方法读取状态::已找到) {
                if (读取状态 == 需求任务方法读取状态::许可拒绝
                    || 读取状态 == 需求任务方法读取状态::版本漂移) {
                    输出.状态 = 读取状态;
                    return 输出;
                }
                return 需求内部不一致(输出);
            }
            输出.正式结算 = 正式结算;
            输出.最近结算状态 = 正式结算.结算状态.状态节点;
            输出.当前结算 = 分层需求结算结论::已满足;
        }
        输出.状态 = 需求任务方法读取状态::已找到;
        return 输出;
    }

    static 需求权威材料 需求内部不一致(需求权威材料 输出) noexcept {
        输出.状态 = 需求任务方法读取状态::内部不一致;
        return 输出;
    }

    任务权威材料 读取任务_已许可(
        节点句柄 任务,
        const 结构事务令牌& 令牌) const {
        任务权威材料 输出;
        输出.身份 = 读取身份_已许可(任务, std::nullopt, 令牌);
        if (!输出.身份.当前可读()) {
            输出.状态 = 输出.身份.状态;
            return 输出;
        }
        if (输出.身份.类型 != 节点类型::任务) {
            输出.状态 = 需求任务方法读取状态::类型不匹配;
            return 输出;
        }

        std::optional<高级关系证据> 来源需求;
        std::optional<高级关系证据> 虚拟存在;
        std::optional<高级关系证据> 场景;
        std::optional<高级关系证据> 目标状态;
        std::optional<高级关系证据> 实际结果;
        std::optional<高级关系证据> 方法投影;
        for (const auto& 记录 : 关系_.获取关系记录组(任务, 关系类型::引用, 令牌)) {
            const auto 目标 = 读取身份_已许可(记录.目标节点, std::nullopt, 令牌);
            const auto 证据 = 形成关系证据_已许可(记录, 令牌);
            if (!目标.当前可读() || !证据.has_value()) return 任务内部不一致(输出);
            if (目标.类型 == 节点类型::需求 && 记录.顺序号 == 0) {
                if (!设置唯一关系(来源需求, *证据)) return 任务内部不一致(输出);
            } else if (目标.类型 == 节点类型::存在 && 记录.顺序号 == 0) {
                if (!设置唯一关系(虚拟存在, *证据)) return 任务内部不一致(输出);
            } else if (目标.类型 == 节点类型::场景 && 记录.顺序号 == 0) {
                if (!设置唯一关系(场景, *证据)) return 任务内部不一致(输出);
            } else if (目标.类型 == 节点类型::状态 && 记录.顺序号 == 任务实际结果顺序号) {
                if (!设置唯一关系(实际结果, *证据)) return 任务内部不一致(输出);
            } else if (目标.类型 == 节点类型::方法 && 记录.顺序号 == 任务方法选择顺序号) {
                if (!设置唯一关系(方法投影, *证据)) return 任务内部不一致(输出);
            }
        }
        for (const auto& 记录 : 关系_.获取关系记录组(任务, 关系类型::模板, 令牌)) {
            if (记录.顺序号 != 0) continue;
            const auto 目标 = 读取身份_已许可(记录.目标节点, std::nullopt, 令牌);
            const auto 证据 = 形成关系证据_已许可(记录, 令牌);
            if (!目标.当前可读() || 目标.类型 != 节点类型::状态
                || !证据.has_value() || !设置唯一关系(目标状态, *证据)) {
                return 任务内部不一致(输出);
            }
        }
        const auto 生命周期组 = 关系_.获取关系记录组(任务, 关系类型::任务生命周期, 令牌);
        if (生命周期组.size() != 1 || !来源需求.has_value() || !虚拟存在.has_value()
            || !场景.has_value() || !目标状态.has_value()) return 任务内部不一致(输出);
        const auto 生命周期 = 读取任务生命周期项_已许可(生命周期组.front(), 令牌);
        if (!生命周期.has_value() || !生命周期->当前()) return 任务内部不一致(输出);

        std::optional<高级关系证据> 授权;
        for (const auto& 记录 : 关系_.获取来源关系记录组(任务, 关系类型::归属, 令牌)) {
            if (记录.源节点 != 来源需求->目标节点) continue;
            const auto 证据 = 形成关系证据_已许可(记录, 令牌);
            if (!证据.has_value() || !设置唯一关系(授权, *证据)) return 任务内部不一致(输出);
        }
        if (!授权.has_value()) return 任务内部不一致(输出);

        输出.来源需求 = 来源需求->目标节点;
        输出.虚拟存在 = 虚拟存在->目标节点;
        输出.场景 = 场景->目标节点;
        输出.目标状态 = 目标状态->目标节点;
        输出.任务来源需求关系 = *来源需求;
        输出.虚拟存在关系 = *虚拟存在;
        输出.场景关系 = *场景;
        输出.目标状态关系 = *目标状态;
        输出.需求拥有任务关系 = *授权;
        输出.当前生命周期 = *生命周期;
        if (实际结果.has_value()) {
            输出.实际结果状态 = 实际结果->目标节点;
            输出.实际结果关系 = *实际结果;
        }

        const auto 发布组 = 关系_.获取关系记录组(任务, 关系类型::任务方法选择, 令牌);
        if (发布组.size() > 1 || (发布组.size() == 1 && !方法投影.has_value())) {
            return 任务内部不一致(输出);
        }
        if (发布组.size() == 1) {
            const auto 发布 = 形成关系证据_已许可(发布组.front(), 令牌);
            if (!发布.has_value()) return 任务内部不一致(输出);
            const auto 选择 = 读取选择记录_已许可(
                发布组.front().目标节点, *方法投影, *发布, 令牌);
            if (!选择.has_value()) return 任务内部不一致(输出);
            输出.当前选择 = *选择;
        }
        输出.状态 = 需求任务方法读取状态::已找到;
        return 输出;
    }

    static 任务权威材料 任务内部不一致(任务权威材料 输出) noexcept {
        输出.状态 = 需求任务方法读取状态::内部不一致;
        return 输出;
    }

    std::optional<任务生命周期材料> 读取任务生命周期项_已许可(
        const 关系记录& 记录,
        const 结构事务令牌& 令牌,
        bool 审计 = false) const {
        const auto 证据 = 形成关系证据_已许可(记录, 令牌, 审计);
        const auto 状态身份 = 读取身份_已许可(记录.目标节点, std::nullopt, 令牌);
        if (!证据.has_value() || !状态身份.当前可读() || 状态身份.类型 != 节点类型::状态
            || 记录.顺序号 <= 0
            || 记录.顺序号 > static_cast<std::int64_t>(std::numeric_limits<std::uint32_t>::max())) {
            return std::nullopt;
        }
        const auto 状态值 = 主信息_.读取I64值(状态身份.主信息, 状态值槽位, 令牌);
        const auto 时间戳 = 主信息_.读取I64值(状态身份.主信息, 状态时间戳槽位, 令牌);
        if (!状态值.has_value() || !时间戳.has_value() || *时间戳 <= 0
            || *状态值 < static_cast<std::int64_t>(分层任务生命周期阶段::已创建)
            || *状态值 > static_cast<std::int64_t>(分层任务生命周期阶段::取消)) {
            return std::nullopt;
        }
        return 任务生命周期材料{
            *证据, 记录.目标节点, static_cast<分层任务生命周期阶段>(*状态值),
            static_cast<std::uint32_t>(记录.顺序号), static_cast<std::uint64_t>(*时间戳),
            记录.状态};
    }

    std::vector<任务生命周期材料> 读取任务生命周期历史_已许可(
        节点句柄 任务,
        const 结构事务令牌& 令牌) const {
        std::vector<任务生命周期材料> 输出;
        for (const auto& 记录 : 关系_.获取关系审计记录组(任务, 关系类型::任务生命周期, 令牌)) {
            const auto 项 = 读取任务生命周期项_已许可(记录, 令牌, true);
            if (!项.has_value()) return {};
            输出.push_back(*项);
        }
        std::sort(输出.begin(), 输出.end(), [](const auto& 左, const auto& 右) {
            return 左.版本 < 右.版本;
        });
        if (输出.empty()) return 输出;
        for (std::size_t 索引号 = 0; 索引号 < 输出.size(); ++索引号) {
            if (输出[索引号].版本 != 索引号 + 1) return {};
        }
        return 输出;
    }

    std::optional<任务方法选择材料> 读取选择记录_已许可(
        节点句柄 记录节点,
        const 高级关系证据& 方法投影,
        const 高级关系证据& 发布,
        const 结构事务令牌& 令牌) const {
        const auto 身份 = 读取身份_已许可(记录节点, std::nullopt, 令牌);
        if (!身份.当前可读() || 身份.类型 != 节点类型::任务方法选择记录
            || !方法投影.当前有效() || !发布.当前有效()) return std::nullopt;
        std::array<std::int64_t, 16> 值组{};
        for (std::size_t 索引号 = 0; 索引号 < 值组.size(); ++索引号) {
            const auto 值 = 主信息_.读取I64值(身份.主信息, 索引号, 令牌);
            if (!值.has_value()) return std::nullopt;
            值组[索引号] = *值;
        }
        if (值组[0] <= 0 || 值组[1] <= 0 || 值组[2] <= 0 || 值组[3] <= 0
            || 值组[4] <= 0 || 值组[5] <= 0 || 值组[6] <= 0 || 值组[7] <= 0
            || 值组[8] <= 0 || 值组[9] <= 0 || 值组[10] <= 0 || 值组[11] <= 0
            || 值组[12] <= 0 || 值组[13] <= 0 || 值组[14] <= 0 || 值组[15] != 1) {
            return std::nullopt;
        }
        const 节点句柄 方法{
            static_cast<std::uint64_t>(值组[1]), static_cast<std::uint64_t>(值组[2]),
            static_cast<std::uint32_t>(值组[3])};
        const 关系句柄 生命周期{
            static_cast<std::uint64_t>(值组[4]), static_cast<std::uint64_t>(值组[5]),
            static_cast<std::uint32_t>(值组[6])};
        const 关系句柄 方法生命周期{
            static_cast<std::uint64_t>(值组[8]), static_cast<std::uint64_t>(值组[9]),
            static_cast<std::uint32_t>(值组[10])};
        if (方法 != 方法投影.目标节点 || 发布.目标节点 != 记录节点
            || 方法投影.源节点 != 发布.源节点) return std::nullopt;
        任务方法选择材料 输出{
            身份, 发布.源节点, 方法, static_cast<std::uint64_t>(值组[0]),
            方法投影, 发布, 生命周期, static_cast<std::uint32_t>(值组[7]),
            方法生命周期, static_cast<std::uint32_t>(值组[11]),
            static_cast<std::uint32_t>(值组[12]), static_cast<std::uint32_t>(值组[13]),
            static_cast<std::uint64_t>(值组[14])};
        return 输出.完整() ? std::optional<任务方法选择材料>{输出} : std::nullopt;
    }

    std::optional<任务方法选择材料> 读取主键选择记录(std::uint64_t 主键) const {
        if (!有效() || 主键 == 0) return std::nullopt;
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) return std::nullopt;
        const auto 节点 = 索引_.按主键查节点(主键, 许可.读取令牌());
        if (!节点.has_value()) return std::nullopt;
        const auto 身份 = 读取身份_已许可(*节点, 主键, 许可.读取令牌());
        if (!身份.当前可读() || 身份.类型 != 节点类型::任务方法选择记录) return std::nullopt;
        for (const auto& 发布 : 关系_.获取来源关系记录组(*节点, 关系类型::任务方法选择, 许可.读取令牌())) {
            const auto 发布证据 = 形成关系证据_已许可(发布, 许可.读取令牌());
            if (!发布证据.has_value()) continue;
            for (const auto& 投影 : 关系_.获取关系记录组(发布.源节点, 关系类型::引用, 许可.读取令牌())) {
                if (投影.顺序号 != 任务方法选择顺序号) continue;
                const auto 投影证据 = 形成关系证据_已许可(投影, 许可.读取令牌());
                if (!投影证据.has_value()) continue;
                const auto 选择 = 读取选择记录_已许可(*节点, *投影证据, *发布证据, 许可.读取令牌());
                if (选择.has_value()) return 选择;
            }
        }
        return std::nullopt;
    }

    方法登记根材料 读取方法登记根_已许可(
        节点句柄 根,
        const 结构事务令牌& 令牌) const {
        方法登记根材料 输出;
        输出.身份 = 读取身份_已许可(根, std::nullopt, 令牌);
        if (!输出.身份.当前可读()) {
            输出.状态 = 输出.身份.状态;
            return 输出;
        }
        if (输出.身份.类型 != 节点类型::方法) {
            输出.状态 = 需求任务方法读取状态::类型不匹配;
            return 输出;
        }
        std::optional<高级关系证据> 角色;
        std::optional<高级关系证据> 活跃;
        std::optional<高级关系证据> 失效;
        for (const auto& 记录 : 关系_.获取关系记录组(根, 关系类型::模板, 令牌)) {
            const auto 证据 = 形成关系证据_已许可(记录, 令牌);
            const auto 值 = 读取抽象状态值_已许可(记录.目标节点, 令牌);
            if (!证据.has_value() || !值.has_value()) return 方法根内部不一致(输出);
            if (记录.顺序号 == 0 && *值 == static_cast<std::int64_t>(分层方法角色::方法登记根)) {
                if (!设置唯一关系(角色, *证据)) return 方法根内部不一致(输出);
            } else if (记录.顺序号 == 40 && *值 == static_cast<std::int64_t>(分层方法生命周期::活跃)) {
                if (!设置唯一关系(活跃, *证据)) return 方法根内部不一致(输出);
            } else if (记录.顺序号 == 41 && *值 == static_cast<std::int64_t>(分层方法生命周期::已失效)) {
                if (!设置唯一关系(失效, *证据)) return 方法根内部不一致(输出);
            }
        }
        if (!角色.has_value() || !活跃.has_value() || !失效.has_value()) return 方法根内部不一致(输出);
        输出.角色状态 = 角色->目标节点;
        输出.活跃状态 = 活跃->目标节点;
        输出.失效状态 = 失效->目标节点;
        输出.角色关系 = *角色;
        输出.活跃状态关系 = *活跃;
        输出.失效状态关系 = *失效;
        输出.状态 = 需求任务方法读取状态::已找到;
        return 输出;
    }

    static 方法登记根材料 方法根内部不一致(方法登记根材料 输出) noexcept {
        输出.状态 = 需求任务方法读取状态::内部不一致;
        return 输出;
    }

    方法登记项材料 读取方法登记项_已许可(
        节点句柄 方法首,
        const 结构事务令牌& 令牌) const {
        方法登记项材料 输出;
        输出.身份 = 读取身份_已许可(方法首, std::nullopt, 令牌);
        if (!输出.身份.当前可读()) {
            输出.状态 = 输出.身份.状态;
            return 输出;
        }
        if (输出.身份.类型 != 节点类型::方法) {
            输出.状态 = 需求任务方法读取状态::类型不匹配;
            return 输出;
        }
        std::optional<高级关系证据> 登记;
        for (const auto& 记录 : 关系_.获取来源关系记录组(方法首, 关系类型::归属, 令牌)) {
            const auto 根 = 读取方法登记根_已许可(记录.源节点, 令牌);
            const auto 证据 = 形成关系证据_已许可(记录, 令牌);
            if (!根.完整() || !证据.has_value() || !设置唯一关系(登记, *证据)) {
                return 方法项内部不一致(输出);
            }
        }
        std::optional<高级关系证据> 角色;
        std::optional<高级关系证据> 生命周期;
        for (const auto& 记录 : 关系_.获取关系记录组(方法首, 关系类型::模板, 令牌)) {
            const auto 证据 = 形成关系证据_已许可(记录, 令牌);
            const auto 目标 = 读取身份_已许可(记录.目标节点, std::nullopt, 令牌);
            if (!证据.has_value() || !目标.当前可读()) return 方法项内部不一致(输出);
            if (目标.类型 == 节点类型::方法) continue;
            if (目标.类型 != 节点类型::状态) return 方法项内部不一致(输出);
            const auto 值 = 读取抽象状态值_已许可(记录.目标节点, 令牌);
            if (!值.has_value()) return 方法项内部不一致(输出);
            if (记录.顺序号 == 0 && *值 == static_cast<std::int64_t>(分层方法角色::方法首)) {
                if (!设置唯一关系(角色, *证据)) return 方法项内部不一致(输出);
            } else if (记录.顺序号 == 2
                && (*值 == static_cast<std::int64_t>(分层方法生命周期::活跃)
                    || *值 == static_cast<std::int64_t>(分层方法生命周期::已失效))) {
                if (!设置唯一关系(生命周期, *证据)) return 方法项内部不一致(输出);
            }
        }
        std::optional<高级关系证据> 虚拟存在;
        for (const auto& 记录 : 关系_.获取关系记录组(方法首, 关系类型::引用, 令牌)) {
            if (记录.顺序号 != 0) continue;
            const auto 目标 = 读取身份_已许可(记录.目标节点, std::nullopt, 令牌);
            const auto 证据 = 形成关系证据_已许可(记录, 令牌);
            if (目标.当前可读() && 目标.类型 == 节点类型::存在) {
                if (!证据.has_value() || !设置唯一关系(虚拟存在, *证据)) {
                    return 方法项内部不一致(输出);
                }
            }
        }
        if (!登记.has_value() || !角色.has_value() || !生命周期.has_value()
            || !虚拟存在.has_value()) return 方法项内部不一致(输出);
        const auto 生命周期值 = 读取抽象状态值_已许可(生命周期->目标节点, 令牌);
        if (!生命周期值.has_value()) return 方法项内部不一致(输出);
        输出.登记根 = 登记->源节点;
        输出.角色状态 = 角色->目标节点;
        输出.虚拟存在 = 虚拟存在->目标节点;
        输出.登记关系 = *登记;
        输出.角色关系 = *角色;
        输出.虚拟存在关系 = *虚拟存在;
        输出.生命周期关系 = *生命周期;
        输出.生命周期 = static_cast<分层方法生命周期>(*生命周期值);
        输出.状态 = 需求任务方法读取状态::已找到;
        return 输出;
    }

    static 方法登记项材料 方法项内部不一致(方法登记项材料 输出) noexcept {
        输出.状态 = 需求任务方法读取状态::内部不一致;
        return 输出;
    }

    方法规格材料 读取方法规格_已许可(
        节点句柄 方法首,
        节点句柄 规格节点,
        const 结构事务令牌& 令牌) const {
        方法规格材料 输出;
        输出.身份 = 读取身份_已许可(规格节点, std::nullopt, 令牌);
        输出.方法首 = 方法首;
        if (!输出.身份.当前可读() || 输出.身份.类型 != 节点类型::方法) {
            输出.状态 = 输出.身份.当前可读()
                ? 需求任务方法读取状态::类型不匹配 : 输出.身份.状态;
            return 输出;
        }
        std::optional<高级关系证据> 归属;
        for (const auto& 记录 : 关系_.获取来源关系记录组(规格节点, 关系类型::模板, 令牌)) {
            if (记录.源节点 != 方法首) continue;
            const auto 证据 = 形成关系证据_已许可(记录, 令牌);
            if (!证据.has_value() || !设置唯一关系(归属, *证据)) return 方法规格内部不一致(输出);
            输出.角色 = static_cast<分层方法角色>(记录.顺序号);
        }
        std::optional<高级关系证据> 角色;
        std::optional<高级关系证据> 入口;
        for (const auto& 记录 : 关系_.获取关系记录组(规格节点, 关系类型::模板, 令牌)) {
            const auto 证据 = 形成关系证据_已许可(记录, 令牌);
            const auto 值 = 读取抽象状态值_已许可(记录.目标节点, 令牌);
            if (!证据.has_value() || !值.has_value()) return 方法规格内部不一致(输出);
            if (记录.顺序号 == 0 && *值 == static_cast<std::int64_t>(输出.角色)) {
                if (!设置唯一关系(角色, *证据)) return 方法规格内部不一致(输出);
            } else if (输出.角色 == 分层方法角色::动作入口 && 记录.顺序号 == 1
                && *值 >= 1 && *值 <= 6) {
                if (!设置唯一关系(入口, *证据)) return 方法规格内部不一致(输出);
            } else if (输出.角色 == 分层方法角色::方法条件 && 记录.顺序号 == 31) {
                if (!设置唯一关系(输出.目标状态关系, *证据)) return 方法规格内部不一致(输出);
                输出.目标状态 = 记录.目标节点;
                输出.目标状态值 = *值;
            } else if (输出.角色 == 分层方法角色::方法结果 && 记录.顺序号 == 33) {
                if (!设置唯一关系(输出.目标状态关系, *证据)) return 方法规格内部不一致(输出);
                输出.目标状态 = 记录.目标节点;
                输出.目标状态值 = *值;
            }
        }
        if (!归属.has_value() || !角色.has_value()) return 方法规格内部不一致(输出);
        输出.方法角色关系 = *归属;
        输出.角色状态关系 = *角色;
        输出.角色状态 = 角色->目标节点;
        if (入口.has_value()) {
            输出.入口状态关系 = *入口;
            输出.入口状态 = 入口->目标节点;
        }

        bool 旧动作场景关系存在 = false;
        for (const auto& 记录 : 关系_.获取关系记录组(规格节点, 关系类型::引用, 令牌)) {
            const auto 目标 = 读取身份_已许可(记录.目标节点, std::nullopt, 令牌);
            const auto 证据 = 形成关系证据_已许可(记录, 令牌);
            if (!目标.当前可读() || !证据.has_value()) return 方法规格内部不一致(输出);
            if (记录.顺序号 == 0 && 目标.类型 == 节点类型::场景) {
                if (输出.场景.has_value()) return 方法规格内部不一致(输出);
                输出.场景 = 记录.目标节点;
                输出.场景关系 = *证据;
            } else if ((记录.顺序号 == 30 || 记录.顺序号 == 32)
                && 目标.类型 == 节点类型::特征) {
                if (输出.目标特征.has_value()) return 方法规格内部不一致(输出);
                输出.目标特征 = 记录.目标节点;
                输出.目标特征关系 = *证据;
            } else if (记录.顺序号 == 1 && 输出.角色 == 分层方法角色::动作入口) {
                if (目标.类型 != 节点类型::场景 || 输出.输入场景.has_value()) {
                    return 方法规格内部不一致(输出);
                }
                旧动作场景关系存在 = true;
                输出.输入场景 = 记录.目标节点;
                输出.输入场景关系 = *证据;
            } else if (记录.顺序号 == 2 && 输出.角色 == 分层方法角色::动作入口) {
                if (目标.类型 != 节点类型::场景 || 输出.输出场景.has_value()) {
                    return 方法规格内部不一致(输出);
                }
                旧动作场景关系存在 = true;
                输出.输出场景 = 记录.目标节点;
                输出.输出场景关系 = *证据;
            }
        }
        const auto 新动作场景组 =
            关系_.获取关系记录组(规格节点, 关系类型::方法动作场景, 令牌);
        if (输出.角色 != 分层方法角色::动作入口) {
            if (!新动作场景组.empty()) return 方法规格内部不一致(输出);
        } else if (!新动作场景组.empty()) {
            if (旧动作场景关系存在) return 方法规格内部不一致(输出);
            for (const auto& 记录 : 新动作场景组) {
                const auto 目标 = 读取身份_已许可(记录.目标节点, std::nullopt, 令牌);
                const auto 证据 = 形成关系证据_已许可(记录, 令牌);
                if (!目标.当前可读() || 目标.类型 != 节点类型::场景
                    || !证据.has_value()) {
                    return 方法规格内部不一致(输出);
                }
                if (记录.顺序号 == 1) {
                    if (输出.输入场景.has_value()) return 方法规格内部不一致(输出);
                    输出.输入场景 = 记录.目标节点;
                    输出.输入场景关系 = *证据;
                } else if (记录.顺序号 == 2) {
                    if (输出.输出场景.has_value()) return 方法规格内部不一致(输出);
                    输出.输出场景 = 记录.目标节点;
                    输出.输出场景关系 = *证据;
                } else {
                    return 方法规格内部不一致(输出);
                }
            }
        }
        if (输出.角色 == 分层方法角色::动作入口
            && (!输出.输入场景.has_value() || !输出.输出场景.has_value())) {
            return 方法规格内部不一致(输出);
        }
        if (输出.角色 == 分层方法角色::方法条件
            || 输出.角色 == 分层方法角色::方法结果) {
            const auto 来源版本 = 主信息_.读取I64值(输出.身份.主信息, 0, 令牌);
            if (!来源版本.has_value() || *来源版本 <= 0) return 方法规格内部不一致(输出);
            输出.来源版本 = static_cast<std::uint64_t>(*来源版本);
        } else if (输出.角色 == 分层方法角色::动作入口) {
            const auto 稳定动作键 = 主信息_.读取I64值(输出.身份.主信息, 0, 令牌);
            if (!稳定动作键.has_value() || *稳定动作键 <= 0) return 方法规格内部不一致(输出);
            输出.稳定动作键 = static_cast<std::uint64_t>(*稳定动作键);
        }
        输出.状态 = 需求任务方法读取状态::已找到;
        return 输出;
    }

    static 方法规格材料 方法规格内部不一致(方法规格材料 输出) noexcept {
        输出.状态 = 需求任务方法读取状态::内部不一致;
        return 输出;
    }

    std::optional<std::int64_t> 读取抽象状态值_已许可(
        节点句柄 状态,
        const 结构事务令牌& 令牌) const {
        const auto 身份 = 读取身份_已许可(状态, std::nullopt, 令牌);
        if (!身份.当前可读() || 身份.类型 != 节点类型::状态
            || !关系_.获取关系记录组(状态, 关系类型::运行期临时, 令牌).empty()
            || !关系_.获取来源关系记录组(状态, 关系类型::运行期临时, 令牌).empty()) {
            return std::nullopt;
        }
        return 主信息_.读取I64值(身份.主信息, 状态值槽位, 令牌);
    }

    bool 写入身份_会话(
        结构写入会话& 会话,
        节点类型 类型,
        std::uint64_t 主键,
        主信息句柄& 新主信息,
        节点句柄& 新节点
#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
        , 固定故障控制* 故障 = nullptr
#endif
    ) const {
        const auto 主结果 = 会话.创建主信息候选();
        if (!主结果.成功()) return false;
        新主信息 = *主结果.值;
#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
        if (命中固定故障(故障)) return false;
#endif
        const auto 节点结果 = 会话.创建节点候选(类型, 新主信息);
        if (!节点结果.成功()) return false;
        新节点 = *节点结果.值;
#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
        if (命中固定故障(故障)) return false;
#endif
        if (!会话.绑定主键(形成索引绑定请求(
            主键, 新节点, 索引所有者::需求任务方法)).成功()) return false;
#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
        if (命中固定故障(故障)) return false;
#endif
        return true;
    }

    bool 追加关系_会话(
        结构写入会话& 会话,
        关系类型 类型,
        节点句柄 源节点,
        节点句柄 目标节点,
        std::int64_t 顺序号,
        std::vector<关系句柄>& 写入关系
#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
        , 固定故障控制* 故障 = nullptr
#endif
    ) const {
        const auto 结果 = 会话.创建关系(类型, 源节点, 目标节点, 顺序号);
        if (!结果.成功()) return false;
        if (std::find(写入关系.begin(), 写入关系.end(), *结果.值) == 写入关系.end()) {
            写入关系.push_back(*结果.值);
        }
#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
        if (命中固定故障(故障)) return false;
#endif
        return 会话.关系可读(*结果.值);
    }

    bool 写入需求关系组_会话(
        结构写入会话& 会话,
        节点句柄 需求,
        节点句柄 主体,
        节点句柄 目标宿主,
        节点句柄 场景,
        节点句柄 目标特征,
        节点句柄 当前特征状态材料,
        节点句柄 目标状态,
        std::vector<关系句柄>& 写入关系
#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
        , 固定故障控制* 故障 = nullptr
#endif
    ) const {
        if (!追加关系_会话(会话, 关系类型::引用, 需求, 主体, 需求主体顺序号, 写入关系
#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
                , 故障
#endif
            )) return false;
        const bool 宿主已写 = 主体 == 目标宿主
            ? 追加关系_会话(会话, 关系类型::引用, 目标宿主, 需求,
                需求目标宿主顺序号, 写入关系
#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
                , 故障
#endif
            )
            : 追加关系_会话(会话, 关系类型::引用, 需求, 目标宿主,
                需求目标宿主顺序号, 写入关系
#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
                , 故障
#endif
            );
        return 宿主已写
            && 追加关系_会话(会话, 关系类型::引用, 需求, 场景, 需求场景顺序号, 写入关系
#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
                , 故障
#endif
            )
            && 追加关系_会话(会话, 关系类型::引用, 需求, 目标特征, 需求目标特征顺序号, 写入关系
#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
                , 故障
#endif
            )
            && 追加关系_会话(会话, 关系类型::引用, 需求, 当前特征状态材料,
                需求当前特征状态顺序号, 写入关系
#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
                , 故障
#endif
            )
            && 追加关系_会话(会话, 关系类型::模板, 需求, 目标状态, 0, 写入关系
#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
                , 故障
#endif
            );
    }

    需求提交结果 创建完整目标状态需求_实现(
        const 完整需求写入规格& 规格
#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
        , 固定故障控制* 故障
#endif
    ) const {
        if (!规格.完整()) return {};
        const auto 写前 = 读取主键需求(规格.需求主键_);
        if (写前.状态 == 需求任务方法读取状态::已找到) {
            return 完整需求匹配(写前, 规格)
                ? 需求提交结果{需求任务方法业务状态::幂等读回, 写前}
                : 需求提交结果{需求任务方法业务状态::幂等冲突};
        }
        if (写前.状态 != 需求任务方法读取状态::未找到) return 从需求读取失败(写前.状态);

        节点句柄 新需求;
        const auto 结构结果 = 执行器_.执行([&](结构写入会话& 会话) {
            if (!会话需求端点匹配(会话, 规格.主体_, 规格.目标宿主_, 规格.场景_,
                    规格.目标特征_, 规格.当前特征状态材料_, {})) return;
            const auto 状态 = 状态数据操作_.写入抽象状态_会话(会话, 规格.目标状态规格_);
            if (!状态.成功()) return;
#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
            if (命中固定故障(故障)) return;
#endif
            主信息句柄 新主信息;
            if (!写入身份_会话(会话, 节点类型::需求, 规格.需求主键_, 新主信息, 新需求
#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
                    , 故障
#endif
                )) return;
            std::vector<关系句柄> 写入关系;
            if (!写入需求关系组_会话(会话, 新需求, 规格.主体_, 规格.目标宿主_,
                    规格.场景_, 规格.目标特征_, 规格.当前特征状态材料_,
                    状态.材料.状态节点, 写入关系
#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
                    , 故障
#endif
                )) return;
            if (会话.主信息可读(新主信息) && 会话.节点可读(新需求)
                && 会话.主键绑定匹配(规格.需求主键_, 新需求)) (void)会话.请求提交();
        });
        const auto 当前 = 读取主键需求(规格.需求主键_);
        if (完整需求匹配(当前, 规格)) {
            return {结构结果.状态 == 结构写入状态::已提交
                    ? 需求任务方法业务状态::已提交 : 需求任务方法业务状态::幂等读回,
                当前};
        }
        if (当前.状态 == 需求任务方法读取状态::已找到) {
            return {需求任务方法业务状态::幂等冲突};
        }
        return 从结构失败形成需求结果(结构结果);
    }

    生命周期历史核对结果 核对任务生命周期完整历史(
        const 任务生命周期写入规格& 规格) const {
        if (!规格.完整()
            || 规格.状态规格_.读取幂等主键() != 规格.幂等材料编号_
            || 规格.状态规格_.读取状态值()
                != static_cast<std::int64_t>(规格.目标阶段_)) {
            return {};
        }

        const auto 历史 = 读取任务生命周期历史(规格.任务_);
        if (历史.empty()) return {};
        std::size_t 当前关系数量 = 0;
        std::size_t 同键历史数量 = 0;
        bool 同键历史完全同义 = true;
        for (std::size_t 索引号 = 0; 索引号 < 历史.size(); ++索引号) {
            const auto& 历史项 = 历史[索引号];
            if (!历史项.完整() || 历史项.版本 != 索引号 + 1
                || 历史项.关系.类型 != 关系类型::任务生命周期
                || 历史项.关系.源节点 != 规格.任务_
                || 历史项.关系.目标节点 != 历史项.状态
                || 历史项.关系.顺序号 != static_cast<std::int64_t>(历史项.版本)
                || 历史项.关系.状态 != 历史项.记录阶段) {
                return {};
            }
            if (历史项.当前()) ++当前关系数量;

            const auto 状态材料 = 状态数据操作_.读取状态材料(历史项.状态);
            if (!状态材料.完整实例状态()
                || 状态材料.状态节点 != 历史项.状态
                || 状态材料.发生时间戳 != 历史项.发生时间戳
                || 状态材料.状态值 != static_cast<std::int64_t>(历史项.阶段)
                || 状态材料.场景 != 规格.状态规格_.读取场景()
                || 状态材料.主体 != 规格.状态规格_.读取主体()) {
                return {};
            }
            if (状态材料.幂等主键 != 规格.幂等材料编号_) continue;
            ++同键历史数量;
            同键历史完全同义 = 同键历史完全同义
                && 历史项.阶段 == 规格.目标阶段_
                && 历史项.发生时间戳 == 规格.状态规格_.读取发生时间戳();
        }
        if (当前关系数量 != 1 || 同键历史数量 > 1) return {};

        const auto 当前 = 读取任务(规格.任务_);
        if (!当前.完整承接()
            || 当前.场景 != 规格.状态规格_.读取场景()
            || 当前.虚拟存在 != 规格.状态规格_.读取主体()) {
            return {};
        }
        if (同键历史数量 == 0) {
            return {生命周期历史核对状态::目标不存在, 当前};
        }
        return {
            同键历史完全同义
                ? 生命周期历史核对状态::唯一同义
                : 生命周期历史核对状态::同键异义,
            当前};
    }

    任务提交结果 迁移任务生命周期_实现(
        const 任务生命周期写入规格& 规格
#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
        , 固定故障控制* 故障
#endif
    ) const {
        if (!规格.完整()) return {};
        const auto 写前 = 读取任务(规格.任务_);
        if (!写前.完整承接()) return {};
        if (写前.当前生命周期.关系.关系 != 规格.预期当前关系_
            || 写前.当前生命周期.版本 != 规格.预期当前版本_) {
            const auto 历史核对 = 核对任务生命周期完整历史(规格);
            if (历史核对.状态 == 生命周期历史核对状态::唯一同义) {
                return {需求任务方法业务状态::幂等读回, 历史核对.当前};
            }
            if (历史核对.状态 == 生命周期历史核对状态::同键异义) {
                return {需求任务方法业务状态::幂等冲突};
            }
            if (历史核对.状态 == 生命周期历史核对状态::内部不一致) {
                return {需求任务方法业务状态::内部不一致};
            }
            return {};
        }
        if (写前.当前生命周期.阶段 == 规格.目标阶段_) {
            const auto 历史核对 = 核对任务生命周期完整历史(规格);
            if (历史核对.状态 == 生命周期历史核对状态::唯一同义) {
                return {需求任务方法业务状态::幂等读回, 历史核对.当前};
            }
            if (历史核对.状态 == 生命周期历史核对状态::同键异义
                || 历史核对.状态 == 生命周期历史核对状态::目标不存在) {
                return {需求任务方法业务状态::幂等冲突};
            }
            return {需求任务方法业务状态::内部不一致};
        }
        if (!合法任务迁移(写前.当前生命周期.阶段, 规格.目标阶段_)) return {};

        const auto 结构结果 = 执行器_.执行([&](结构写入会话& 会话) {
            if (!会话任务材料匹配(会话, 规格.任务_, 写前)) return;
            const auto 新状态 = 状态数据操作_.写入实例状态_会话(会话, 规格.状态规格_);
            if (!新状态.成功()
                || 新状态.材料.状态值 != static_cast<std::int64_t>(规格.目标阶段_)) return;
#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
            if (命中固定故障(故障)) return;
#endif
            std::vector<关系句柄> 写入关系;
            if (!追加关系_会话(会话, 关系类型::任务生命周期, 规格.任务_,
                    新状态.材料.状态节点,
                    static_cast<std::int64_t>(规格.预期当前版本_ + 1), 写入关系
#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
                    , 故障
#endif
                )) return;
            if (规格.目标阶段_ == 分层任务生命周期阶段::筹办中
                && 写前.当前生命周期.阶段 == 分层任务生命周期阶段::待重筹办
                && 写前.当前选择.has_value()) {
                const auto 失效投影 = 会话.失效已发布关系(
                    写前.当前选择->方法投影关系.关系);
                if (!失效投影.成功()) return;
                const auto 投影审计 = 会话.读取关系审计(*失效投影.值);
                if (!投影审计.has_value() || 投影审计->状态 != 记录状态::已失效) return;
#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
                if (命中固定故障(故障)) return;
#endif
                const auto 失效发布 = 会话.失效已发布关系(
                    写前.当前选择->发布关系.关系);
                if (!失效发布.成功()) return;
                const auto 发布审计 = 会话.读取关系审计(*失效发布.值);
                if (!发布审计.has_value() || 发布审计->状态 != 记录状态::已失效) return;
#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
                if (命中固定故障(故障)) return;
#endif
            }
            const auto 失效旧生命周期 = 会话.失效已发布关系(规格.预期当前关系_);
            if (!失效旧生命周期.成功()) return;
            const auto 生命周期审计 = 会话.读取关系审计(*失效旧生命周期.值);
            if (!生命周期审计.has_value()
                || 生命周期审计->状态 != 记录状态::已失效) return;
#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
            if (命中固定故障(故障)) return;
#endif
            (void)会话.请求提交();
        });
        const auto 历史核对 = 核对任务生命周期完整历史(规格);
        if (历史核对.状态 == 生命周期历史核对状态::唯一同义) {
            return {结构结果.状态 == 结构写入状态::已提交
                    ? 需求任务方法业务状态::已提交 : 需求任务方法业务状态::幂等读回,
                历史核对.当前};
        }
        if (历史核对.状态 == 生命周期历史核对状态::同键异义) {
            return {结构结果.状态 == 结构写入状态::已提交
                    ? 需求任务方法业务状态::内部不一致
                    : 需求任务方法业务状态::幂等冲突};
        }
        if (历史核对.状态 == 生命周期历史核对状态::内部不一致
            || 结构结果.状态 == 结构写入状态::已提交) {
            return {需求任务方法业务状态::内部不一致};
        }
        return 从结构失败形成任务结果(结构结果);
    }

    方法提交结果 创建方法规格_实现(const 方法条件写入规格& 规格) const {
        if (!规格.完整()) return {};
        return 创建方法规格共用(
            规格.条件主键_, 规格.方法首_, 分层方法角色::方法条件,
            规格.场景_, 规格.目标特征_, 规格.期望抽象状态_, 规格.来源版本_,
            规格.角色状态_, std::nullopt, {}, {});
    }

    方法提交结果 创建方法规格_实现(const 方法结果写入规格& 规格) const {
        if (!规格.完整()) return {};
        return 创建方法规格共用(
            规格.结果主键_, 规格.方法首_, 分层方法角色::方法结果,
            规格.场景_, 规格.目标特征_, 规格.目标抽象状态_, 规格.来源版本_,
            规格.角色状态_, std::nullopt, {}, {});
    }

    方法提交结果 创建方法规格_实现(
        const 方法动作入口写入规格& 规格
#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
        , 固定故障控制* 故障 = nullptr
#endif
        ) const {
        if (!规格.完整()) return {};
        return 创建方法规格共用(
            规格.动作主键_, 规格.方法首_, 分层方法角色::动作入口,
            {}, {}, {}, 规格.动作主键_, 规格.角色状态_,
            规格.入口状态_, 规格.输入场景_, 规格.输出场景_
#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
            , 故障
#endif
        );
    }

    方法提交结果 创建方法规格共用(
        std::uint64_t 主键,
        节点句柄 方法首,
        分层方法角色 角色,
        节点句柄 场景,
        节点句柄 目标特征,
        节点句柄 目标状态,
        std::uint64_t 来源版本或动作键,
        const 抽象状态写入规格& 角色状态规格,
        std::optional<抽象状态写入规格> 入口状态规格,
        节点句柄 输入场景,
        节点句柄 输出场景
#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
        , 固定故障控制* 故障 = nullptr
#endif
        ) const {
        const auto 写前身份 = 读取主键身份(主键);
        if (写前身份.状态 == 需求任务方法读取状态::已找到) {
            const auto 当前 = 读取单个方法规格(方法首, 写前身份.节点);
            return 方法规格语义匹配(当前, 角色, 场景, 目标特征, 目标状态,
                    来源版本或动作键, 输入场景, 输出场景,
                    角色状态规格, 入口状态规格)
                ? 方法提交结果{需求任务方法业务状态::幂等读回, {}, {}, 当前}
                : 方法提交结果{需求任务方法业务状态::幂等冲突};
        }
        if (写前身份.状态 != 需求任务方法读取状态::未找到) {
            return {映射读取失败(写前身份.状态)};
        }
        const auto 方法 = 读取方法登记项(方法首);
        if (!方法.完整() || 方法.生命周期 != 分层方法生命周期::活跃) return {};

        节点句柄 新规格;
        const auto 结构结果 = 执行器_.执行([&](结构写入会话& 会话) {
            if (!会话方法登记项匹配(会话, 方法首, 方法)) return;
            if (角色 == 分层方法角色::动作入口) {
                if (会话.读取节点类型(输入场景) != std::optional<节点类型>{节点类型::场景}
                    || 会话.读取节点类型(输出场景) != std::optional<节点类型>{节点类型::场景}) return;
            } else if (会话.读取节点类型(场景) != std::optional<节点类型>{节点类型::场景}
                || 会话.读取节点类型(目标特征) != std::optional<节点类型>{节点类型::特征}
                || 会话.读取节点类型(目标状态) != std::optional<节点类型>{节点类型::状态}) return;
            主信息句柄 新主信息;
            if (!写入身份_会话(会话, 节点类型::方法, 主键, 新主信息, 新规格)) return;
            if (!会话.写入候选I64值(
                    新主信息, 0, static_cast<std::int64_t>(来源版本或动作键)).成功()
                || !会话.候选I64值匹配(
                    新主信息, 0, static_cast<std::int64_t>(来源版本或动作键))) return;
            const auto 角色状态 = 状态数据操作_.写入抽象状态_会话(会话, 角色状态规格);
            if (!角色状态.成功()
                || 角色状态.材料.状态值 != static_cast<std::int64_t>(角色)) return;
            std::vector<关系句柄> 写入关系;
            if (!追加关系_会话(会话, 关系类型::模板, 方法首, 新规格,
                    static_cast<std::int64_t>(角色), 写入关系)
                || !追加关系_会话(会话, 关系类型::模板, 新规格,
                    角色状态.材料.状态节点, 0, 写入关系)) return;
            if (角色 == 分层方法角色::动作入口) {
                if (!入口状态规格.has_value()) return;
                const auto 入口状态 = 状态数据操作_.写入抽象状态_会话(会话, *入口状态规格);
                if (!入口状态.成功() || 入口状态.材料.状态值 < 1 || 入口状态.材料.状态值 > 6
                    || !追加关系_会话(会话, 关系类型::模板, 新规格,
                        入口状态.材料.状态节点, 1, 写入关系)
                    || !追加关系_会话(会话, 关系类型::方法动作场景,
                        新规格, 输入场景, 1, 写入关系)) return;
#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
                if (命中固定故障(故障)) return;
#endif
                if (!追加关系_会话(会话, 关系类型::方法动作场景,
                        新规格, 输出场景, 2, 写入关系)) return;
#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
                if (命中固定故障(故障)) return;
#endif
            } else {
                const auto 目标状态值 = 读取会话抽象状态值(会话, 目标状态);
                if (!目标状态值.has_value()
                    || !追加关系_会话(会话, 关系类型::引用, 新规格, 场景, 0, 写入关系)
                    || !追加关系_会话(会话, 关系类型::引用, 新规格, 目标特征,
                        角色 == 分层方法角色::方法条件 ? 30 : 32, 写入关系)
                    || !追加关系_会话(会话, 关系类型::模板, 新规格, 目标状态,
                        角色 == 分层方法角色::方法条件 ? 31 : 33, 写入关系)) return;
            }
            if (会话.主信息可读(新主信息) && 会话.节点可读(新规格)
                && 会话.主键绑定匹配(主键, 新规格)) (void)会话.请求提交();
        });
        const auto 当前 = 读取单个方法规格(方法首, 新规格);
        if (方法规格语义匹配(当前, 角色, 场景, 目标特征, 目标状态,
                来源版本或动作键, 输入场景, 输出场景,
                角色状态规格, 入口状态规格)) {
            return {结构结果.状态 == 结构写入状态::已提交
                    ? 需求任务方法业务状态::已提交 : 需求任务方法业务状态::幂等读回,
                {}, {}, 当前};
        }
        const auto 并发身份 = 读取主键身份(主键);
        if (并发身份.状态 == 需求任务方法读取状态::已找到) {
            const auto 并发当前 = 读取单个方法规格(方法首, 并发身份.节点);
            return 方法规格语义匹配(并发当前, 角色, 场景, 目标特征, 目标状态,
                    来源版本或动作键, 输入场景, 输出场景,
                    角色状态规格, 入口状态规格)
                ? 方法提交结果{需求任务方法业务状态::幂等读回, {}, {}, 并发当前}
                : 方法提交结果{需求任务方法业务状态::幂等冲突};
        }
        return {映射结构失败(结构结果)};
    }

    方法规格材料 读取单个方法规格(节点句柄 方法首, 节点句柄 规格) const {
        if (!有效() || !句柄有效(方法首) || !句柄有效(规格)) return {};
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) return {需求任务方法读取状态::许可拒绝};
        return 读取方法规格_已许可(方法首, 规格, 许可.读取令牌());
    }

    std::optional<std::int64_t> 读取会话抽象状态值(
        结构写入会话& 会话,
        节点句柄 状态) const {
        if (会话.读取节点类型(状态) != std::optional<节点类型>{节点类型::状态}
            || !会话.读取关系记录组(状态, 关系类型::运行期临时).empty()
            || !会话.读取来源关系记录组(状态, 关系类型::运行期临时).empty()) return std::nullopt;
        const auto 主信息 = 会话.读取节点主信息(状态);
        return 主信息.has_value() ? 会话.读取I64值(*主信息, 状态值槽位) : std::nullopt;
    }

    std::optional<高级关系证据> 形成关系证据_会话(
        结构写入会话& 会话,
        const 关系记录& 记录) const {
        if (记录.关系编号 == 0 || 记录.版本号 == 0 || 记录.状态 != 记录状态::有效) {
            return std::nullopt;
        }
        const 关系句柄 句柄{关系仓库编号_, 记录.关系编号, 记录.版本号};
        const auto 当前 = 会话.读取关系审计(句柄);
        if (!当前.has_value() || 当前->关系编号 != 记录.关系编号
            || 当前->版本号 != 记录.版本号 || 当前->类型 != 记录.类型
            || 当前->源节点 != 记录.源节点 || 当前->目标节点 != 记录.目标节点
            || 当前->顺序号 != 记录.顺序号 || 当前->状态 != 记录.状态
            || !会话.关系可读(句柄)) return std::nullopt;
        return 高级关系证据{
            句柄, 记录.类型, 记录.源节点, 记录.目标节点,
            记录.顺序号, 记录.状态};
    }

    需求任务方法读取状态 查找状态型归属_会话(
        结构写入会话& 会话,
        节点句柄 需求,
        std::optional<关系记录>& 唯一记录) const {
        for (const auto& 记录 : 会话.读取关系记录组(需求, 关系类型::归属)) {
            const auto 证据 = 形成关系证据_会话(会话, 记录);
            const auto 类型 = 会话.读取节点类型(记录.目标节点);
            if (!证据.has_value() || !类型.has_value()) {
                return 需求任务方法读取状态::内部不一致;
            }
            if (*类型 != 节点类型::状态) continue;
            if (唯一记录.has_value()) return 需求任务方法读取状态::内部不一致;
            唯一记录 = 记录;
        }
        return 唯一记录.has_value()
            ? 需求任务方法读取状态::已找到
            : 需求任务方法读取状态::未找到;
    }

    需求任务方法读取状态 读取正式结算材料_会话(
        结构写入会话& 会话,
        节点句柄 需求,
        const 需求权威材料& 需求材料,
        const 任务权威材料& 任务材料,
        const 状态值式材料& 结算状态,
        需求正式结算材料& 输出) const {
        if (!结算状态.完整实例状态()
            || 结算状态.状态值 != static_cast<std::int64_t>(分层需求结算结论::已满足)) {
            return 需求任务方法读取状态::内部不一致;
        }
        std::optional<关系记录> 归属记录;
        const auto 归属读取 = 查找状态型归属_会话(会话, 需求, 归属记录);
        if (归属读取 != 需求任务方法读取状态::已找到
            || !归属记录.has_value() || 归属记录->目标节点 != 结算状态.状态节点
            || 归属记录->顺序号 != static_cast<std::int64_t>(结算状态.发生时间戳)) {
            return 归属读取 == 需求任务方法读取状态::内部不一致
                ? 归属读取 : 需求任务方法读取状态::内部不一致;
        }
        const auto 归属证据 = 形成关系证据_会话(会话, *归属记录);
        if (!归属证据.has_value()) return 需求任务方法读取状态::内部不一致;

        std::optional<高级关系证据> 来源任务关系;
        std::optional<高级关系证据> 实际状态关系;
        std::optional<高级关系证据> 因果引用关系;
        for (const auto& 记录 : 会话.读取关系记录组(
                结算状态.状态节点, 关系类型::引用)) {
            const auto 证据 = 形成关系证据_会话(会话, 记录);
            if (!证据.has_value()) return 需求任务方法读取状态::内部不一致;
            if (证据->关系 == 结算状态.主体关系.关系
                || 证据->关系 == 结算状态.场景关系.关系) continue;
            const auto 类型 = 会话.读取节点类型(记录.目标节点);
            if (!类型.has_value()) return 需求任务方法读取状态::版本漂移;
            if (记录.顺序号 == 结算来源任务顺序号 && *类型 == 节点类型::任务) {
                if (!设置唯一关系(来源任务关系, *证据)) {
                    return 需求任务方法读取状态::内部不一致;
                }
            } else if (记录.顺序号 == 结算实际状态顺序号 && *类型 == 节点类型::状态) {
                if (!设置唯一关系(实际状态关系, *证据)) {
                    return 需求任务方法读取状态::内部不一致;
                }
            } else if (记录.顺序号 == 结算因果引用顺序号
                && *类型 == 节点类型::因果引用) {
                if (!设置唯一关系(因果引用关系, *证据)) {
                    return 需求任务方法读取状态::内部不一致;
                }
            } else {
                return 需求任务方法读取状态::内部不一致;
            }
        }

        std::optional<高级关系证据> 目标状态关系;
        for (const auto& 记录 : 会话.读取关系记录组(
                结算状态.状态节点, 关系类型::模板)) {
            const auto 证据 = 形成关系证据_会话(会话, 记录);
            const auto 类型 = 会话.读取节点类型(记录.目标节点);
            if (!证据.has_value() || !类型.has_value()
                || 记录.顺序号 != 结算目标状态顺序号 || *类型 != 节点类型::状态
                || !设置唯一关系(目标状态关系, *证据)) {
                return 需求任务方法读取状态::内部不一致;
            }
        }

        std::optional<高级关系证据> 动态证据关系;
        for (const auto& 记录 : 会话.读取关系记录组(
                结算状态.状态节点, 关系类型::因果来源)) {
            const auto 证据 = 形成关系证据_会话(会话, 记录);
            const auto 类型 = 会话.读取节点类型(记录.目标节点);
            if (!证据.has_value() || !类型.has_value()
                || 记录.顺序号 != 结算动态证据顺序号 || *类型 != 节点类型::动态
                || !设置唯一关系(动态证据关系, *证据)) {
                return 需求任务方法读取状态::内部不一致;
            }
        }

        if (!来源任务关系.has_value() || !目标状态关系.has_value()
            || !实际状态关系.has_value() || !动态证据关系.has_value()) {
            return 需求任务方法读取状态::内部不一致;
        }
        输出.结算状态 = 结算状态;
        输出.需求 = 需求;
        输出.需求归属关系 = *归属证据;
        输出.来源任务 = 来源任务关系->目标节点;
        输出.来源任务关系 = *来源任务关系;
        输出.目标状态 = 目标状态关系->目标节点;
        输出.目标状态关系 = *目标状态关系;
        输出.实际状态 = 实际状态关系->目标节点;
        输出.实际状态关系 = *实际状态关系;
        输出.动态证据 = 动态证据关系->目标节点;
        输出.动态证据关系 = *动态证据关系;
        if (因果引用关系.has_value()) {
            输出.因果引用 = 因果引用关系->目标节点;
            输出.因果引用关系 = *因果引用关系;
        }
        return 会话需求材料匹配(会话, 需求, 需求材料)
            && 会话任务材料匹配(会话, 输出.来源任务, 任务材料)
            && 任务材料.来源需求 == 需求
            && 任务材料.当前生命周期.阶段 == 分层任务生命周期阶段::已完成
            && 任务材料.实际结果状态 == std::optional<节点句柄>{输出.实际状态}
            && 任务材料.场景 == 结算状态.场景
            && 任务材料.虚拟存在 == 结算状态.主体
            && 输出.目标状态 == 需求材料.目标状态 && 输出.完整()
            ? 需求任务方法读取状态::已找到
            : 需求任务方法读取状态::内部不一致;
    }

    bool 会话需求端点匹配(
        结构写入会话& 会话,
        节点句柄 主体,
        节点句柄 目标宿主,
        节点句柄 场景,
        节点句柄 目标特征,
        节点句柄 当前特征状态材料,
        节点句柄 目标状态) const {
        return 会话.读取节点类型(主体) == std::optional<节点类型>{节点类型::存在}
            && 会话.读取节点类型(目标宿主) == std::optional<节点类型>{节点类型::存在}
            && 会话.读取节点类型(场景) == std::optional<节点类型>{节点类型::场景}
            && 会话.读取节点类型(目标特征) == std::optional<节点类型>{节点类型::特征}
            && 会话.读取节点类型(当前特征状态材料) == std::optional<节点类型>{节点类型::特征值}
            && (!句柄有效(目标状态)
                || 读取会话抽象状态值(会话, 目标状态).has_value());
    }

    bool 会话需求材料匹配(
        结构写入会话& 会话,
        节点句柄 需求,
        const 需求权威材料& 材料) const {
        if (!材料.完整目标状态需求()
            || 会话.读取节点类型(需求) != std::optional<节点类型>{节点类型::需求}) return false;
        const auto 引用组 = 会话.读取关系记录组(需求, 关系类型::引用);
        const auto 模板组 = 会话.读取关系记录组(需求, 关系类型::模板);
        const auto 来源引用组 = 会话.读取来源关系记录组(需求, 关系类型::引用);
        const auto 匹配 = [](const auto& 组, 节点句柄 源, 节点句柄 目标, std::int64_t 顺序号) {
            return std::count_if(组.begin(), 组.end(), [&](const auto& 记录) {
                return 记录.源节点 == 源 && 记录.目标节点 == 目标 && 记录.顺序号 == 顺序号;
            }) == 1;
        };
        const bool 宿主匹配 = 材料.主体 == 材料.目标宿主
            ? std::count_if(来源引用组.begin(), 来源引用组.end(), [&](const auto& 记录) {
                    return 记录.源节点 == 材料.目标宿主
                        && 记录.顺序号 == 需求目标宿主顺序号;
                }) == 1
            : 匹配(引用组, 需求, 材料.目标宿主, 需求目标宿主顺序号);
        return 匹配(引用组, 需求, 材料.主体, 需求主体顺序号)
            && 宿主匹配 && 匹配(引用组, 需求, 材料.场景, 需求场景顺序号)
            && 匹配(引用组, 需求, 材料.目标特征, 需求目标特征顺序号)
            && 匹配(引用组, 需求, 材料.当前特征状态材料, 需求当前特征状态顺序号)
            && 匹配(模板组, 需求, 材料.目标状态, 0);
    }

    bool 会话任务材料匹配(
        结构写入会话& 会话,
        节点句柄 任务,
        const 任务权威材料& 材料) const {
        if (!材料.完整承接()
            || 会话.读取节点类型(任务) != std::optional<节点类型>{节点类型::任务}) return false;
        const auto 生命周期 = 会话.读取关系审计(材料.当前生命周期.关系.关系);
        return 生命周期.has_value() && 生命周期->状态 == 记录状态::有效
            && 生命周期->源节点 == 任务
            && 生命周期->目标节点 == 材料.当前生命周期.状态
            && 生命周期->顺序号 == static_cast<std::int64_t>(材料.当前生命周期.版本);
    }

    bool 会话方法根匹配(
        结构写入会话& 会话,
        const 方法登记根材料& 根) const {
        return 根.完整()
            && 会话.读取节点类型(根.身份.节点) == std::optional<节点类型>{节点类型::方法}
            && 读取会话抽象状态值(会话, 根.角色状态)
                == std::optional<std::int64_t>{static_cast<std::int64_t>(分层方法角色::方法登记根)}
            && 读取会话抽象状态值(会话, 根.活跃状态)
                == std::optional<std::int64_t>{static_cast<std::int64_t>(分层方法生命周期::活跃)}
            && 读取会话抽象状态值(会话, 根.失效状态)
                == std::optional<std::int64_t>{static_cast<std::int64_t>(分层方法生命周期::已失效)};
    }

    bool 会话方法登记项匹配(
        结构写入会话& 会话,
        节点句柄 方法首,
        const 方法登记项材料& 材料) const {
        if (!材料.完整()
            || 会话.读取节点类型(方法首) != std::optional<节点类型>{节点类型::方法}) return false;
        const auto 生命周期 = 会话.读取关系审计(材料.生命周期关系.关系);
        return 生命周期.has_value() && 生命周期->状态 == 记录状态::有效
            && 生命周期->源节点 == 方法首 && 生命周期->顺序号 == 2;
    }

    bool 完整需求匹配(
        const 需求权威材料& 当前,
        const 完整需求写入规格& 规格) const {
        if (!当前.完整目标状态需求()) return false;
        const auto 目标状态 = 状态数据操作_.读取状态材料(当前.目标状态);
        return 目标状态.完整抽象状态()
            && 目标状态.幂等主键 == 规格.目标状态规格_.读取幂等主键()
            && 目标状态.状态值 == 规格.目标状态规格_.读取状态值()
            && 当前.身份.幂等主键 == 规格.需求主键_
            && 当前.主体 == 规格.主体_ && 当前.目标宿主 == 规格.目标宿主_
            && 当前.场景 == 规格.场景_ && 当前.目标特征 == 规格.目标特征_
            && 当前.当前特征状态材料 == 规格.当前特征状态材料_;
    }

    static bool 正式结算匹配(
        const 需求正式结算材料& 当前,
        const 需求结算写入规格& 规格,
        const 需求权威材料& 需求,
        const 任务权威材料& 任务) noexcept {
        const bool 因果匹配 = 句柄有效(规格.因果引用_)
            ? 当前.因果引用 == std::optional<节点句柄>{规格.因果引用_}
            : !当前.因果引用.has_value();
        return 当前.完整() && 需求.完整目标状态需求() && 任务.完整承接()
            && 当前.需求 == 规格.需求_ && 当前.来源任务 == 规格.来源任务_
            && 当前.目标状态 == 需求.目标状态 && 当前.实际状态 == 规格.实际状态_
            && 当前.动态证据 == 规格.动态证据_ && 因果匹配
            && 当前.结算状态.幂等主键 == 规格.结算状态规格_.读取幂等主键()
            && 当前.结算状态.场景 == 规格.结算状态规格_.读取场景()
            && 当前.结算状态.主体 == 规格.结算状态规格_.读取主体()
            && 当前.结算状态.发生时间戳 == 规格.结算状态规格_.读取发生时间戳()
            && 当前.结算状态.状态值 == 规格.结算状态规格_.读取状态值()
            && 当前.结算状态.状态值 == static_cast<std::int64_t>(规格.结论_)
            && 任务.来源需求 == 规格.需求_
            && 任务.当前生命周期.阶段 == 分层任务生命周期阶段::已完成
            && 任务.实际结果状态 == std::optional<节点句柄>{规格.实际状态_}
            && 任务.场景 == 当前.结算状态.场景
            && 任务.虚拟存在 == 当前.结算状态.主体;
    }

    static bool 概念命名需求匹配(
        const 需求权威材料& 当前,
        const 概念命名需求写入规格& 规格) noexcept {
        return 当前.完整概念命名需求() && 当前.身份.幂等主键 == 规格.需求主键_
            && 当前.主体 == 规格.主体_ && 当前.目标宿主 == 规格.目标宿主_
            && 当前.场景 == 规格.场景_ && 当前.目标特征 == 规格.目标特征_
            && 当前.当前特征状态材料 == 规格.当前特征状态材料_
            && 当前.目标状态 == 规格.目标状态_
            && 当前.目标概念 == std::optional<节点句柄>{规格.目标概念_}
            && 当前.父需求 == std::optional<节点句柄>{规格.服务根需求_};
    }

    bool 任务承接匹配(
        const 任务权威材料& 当前,
        const 任务承接写入规格& 规格) const {
        if (!当前.完整承接() || 当前.身份.幂等主键 != 规格.任务主键_) return false;
        const auto 生命周期历史 = 读取任务生命周期历史(当前.身份.节点);
        const auto 初始生命周期位置 = std::find_if(
            生命周期历史.begin(), 生命周期历史.end(), [](const auto& 项) {
                return 项.版本 == 1;
            });
        if (初始生命周期位置 == 生命周期历史.end()
            || std::count_if(
                生命周期历史.begin(), 生命周期历史.end(), [](const auto& 项) {
                    return 项.版本 == 1;
                }) != 1) return false;
        const auto& 初始生命周期 = *初始生命周期位置;
        if (!初始生命周期.完整()
            || 初始生命周期.阶段 != 分层任务生命周期阶段::已创建
            || 初始生命周期.关系.类型 != 关系类型::任务生命周期
            || 初始生命周期.关系.源节点 != 当前.身份.节点
            || 初始生命周期.关系.目标节点 != 初始生命周期.状态
            || 初始生命周期.关系.顺序号 != 1) return false;
        const auto 虚拟存在 = 存在数据操作_.读取主键身份(
            规格.虚拟存在规格_.读取幂等主键());
        const auto 初始状态 = 状态数据操作_.读取状态材料(初始生命周期.状态);
        return 当前.来源需求 == 规格.来源需求_
            && 虚拟存在.当前可读() && 虚拟存在.类型 == 节点类型::存在
            && 虚拟存在.节点 == 当前.虚拟存在
            && 虚拟存在.虚拟来源 == std::optional<节点句柄>{当前.身份.节点}
            && 初始状态.完整实例状态()
            && 初始状态.幂等主键 == 规格.初始状态规格_.读取幂等主键()
            && 初始状态.场景 == 规格.初始状态规格_.读取场景()
            && 初始状态.主体 == 当前.虚拟存在
            && 初始状态.发生时间戳 == 规格.初始状态规格_.读取发生时间戳()
            && 初始状态.状态值 == 规格.初始状态规格_.读取状态值();
    }

    static bool 选择匹配(
        const 任务方法选择材料& 当前,
        const 任务方法选择写入规格& 规格) noexcept {
        return 当前.完整() && 当前.记录身份.幂等主键 == 规格.记录主键_
            && 当前.任务 == 规格.任务_ && 当前.方法 == 规格.方法_
            && 当前.幂等材料编号 == 规格.幂等材料编号_
            && 当前.来源生命周期关系 == 规格.生命周期关系_
            && 当前.来源生命周期版本 == 规格.生命周期版本_
            && 当前.来源方法生命周期关系 == 规格.方法生命周期关系_
            && 当前.来源方法生命周期版本 == 规格.方法生命周期版本_
            && 当前.排序规则版本 == 规格.排序规则版本_
            && 当前.召回请求规则版本 == 规格.召回请求规则版本_
            && 当前.来源候选数量 == 规格.来源候选数量_;
    }

    bool 方法根匹配(
        const 方法登记根材料& 当前,
        const 方法登记根写入规格& 规格) const {
        if (!当前.完整() || 当前.身份.幂等主键 != 规格.根主键_) return false;
        const auto 角色 = 状态数据操作_.读取状态材料(当前.角色状态);
        const auto 活跃 = 状态数据操作_.读取状态材料(当前.活跃状态);
        const auto 失效 = 状态数据操作_.读取状态材料(当前.失效状态);
        return 角色.完整抽象状态() && 活跃.完整抽象状态() && 失效.完整抽象状态()
            && 角色.幂等主键 == 规格.角色状态_.读取幂等主键()
            && 活跃.幂等主键 == 规格.活跃状态_.读取幂等主键()
            && 失效.幂等主键 == 规格.失效状态_.读取幂等主键()
            && 角色.状态值 == 规格.角色状态_.读取状态值()
            && 活跃.状态值 == 规格.活跃状态_.读取状态值()
            && 失效.状态值 == 规格.失效状态_.读取状态值();
    }

    bool 方法首匹配(
        const 方法登记项材料& 当前,
        const 方法首写入规格& 规格) const {
        if (!当前.完整() || 当前.身份.幂等主键 != 规格.方法主键_) return false;
        const auto 虚拟存在 = 存在数据操作_.读取主键身份(
            规格.虚拟存在规格_.读取幂等主键());
        const auto 角色状态 = 状态数据操作_.读取状态材料(当前.角色状态);
        return 当前.登记根 == 规格.登记根_
            && 当前.生命周期 == 分层方法生命周期::活跃
            && 虚拟存在.当前可读() && 虚拟存在.类型 == 节点类型::存在
            && 虚拟存在.节点 == 当前.虚拟存在
            && 虚拟存在.虚拟来源 == std::optional<节点句柄>{当前.身份.节点}
            && 角色状态.完整抽象状态()
            && 角色状态.幂等主键 == 规格.角色状态_.读取幂等主键()
            && 角色状态.状态值 == 规格.角色状态_.读取状态值();
    }

    bool 方法规格语义匹配(
        const 方法规格材料& 当前,
        分层方法角色 角色,
        节点句柄 场景,
        节点句柄 目标特征,
        节点句柄 目标状态,
        std::uint64_t 来源版本或动作键,
        节点句柄 输入场景,
        节点句柄 输出场景,
        const 抽象状态写入规格& 角色状态规格,
        const std::optional<抽象状态写入规格>& 入口状态规格) const {
        const auto 角色状态 = 状态数据操作_.读取状态材料(当前.角色状态);
        if (!角色状态.完整抽象状态()
            || 角色状态.幂等主键 != 角色状态规格.读取幂等主键()
            || 角色状态.状态值 != 角色状态规格.读取状态值()
            || 角色状态.状态值 != static_cast<std::int64_t>(角色)) return false;
        if (角色 == 分层方法角色::方法条件) {
            return 当前.完整条件() && 当前.场景 == std::optional<节点句柄>{场景}
                && 当前.目标特征 == std::optional<节点句柄>{目标特征}
                && 当前.目标状态 == std::optional<节点句柄>{目标状态}
                && 当前.来源版本 == 来源版本或动作键;
        }
        if (角色 == 分层方法角色::方法结果) {
            return 当前.完整结果() && 当前.场景 == std::optional<节点句柄>{场景}
                && 当前.目标特征 == std::optional<节点句柄>{目标特征}
                && 当前.目标状态 == std::optional<节点句柄>{目标状态}
                && 当前.来源版本 == 来源版本或动作键;
        }
        if (角色 != 分层方法角色::动作入口 || !当前.完整动作入口()
            || !入口状态规格.has_value() || !当前.入口状态.has_value()) return false;
        const auto 入口状态 = 状态数据操作_.读取状态材料(*当前.入口状态);
        return 入口状态.完整抽象状态()
            && 入口状态.幂等主键 == 入口状态规格->读取幂等主键()
            && 入口状态.状态值 == 入口状态规格->读取状态值()
            && 当前.稳定动作键 == 来源版本或动作键
            && 当前.输入场景 == std::optional<节点句柄>{输入场景}
            && 当前.输出场景 == std::optional<节点句柄>{输出场景};
    }

    static 需求任务方法业务状态 映射读取失败(需求任务方法读取状态 状态) noexcept {
        switch (状态) {
        case 需求任务方法读取状态::许可拒绝: return 需求任务方法业务状态::许可拒绝;
        case 需求任务方法读取状态::版本漂移: return 需求任务方法业务状态::版本漂移;
        case 需求任务方法读取状态::内部不一致: return 需求任务方法业务状态::内部不一致;
        default: return 需求任务方法业务状态::入口拒绝;
        }
    }

    static 需求任务方法读取状态 映射状态动态读取失败为读取状态(
        状态动态读取状态 状态) noexcept {
        switch (状态) {
        case 状态动态读取状态::未找到:
            return 需求任务方法读取状态::未找到;
        case 状态动态读取状态::入口拒绝:
            return 需求任务方法读取状态::入口拒绝;
        case 状态动态读取状态::类型不匹配:
            return 需求任务方法读取状态::类型不匹配;
        case 状态动态读取状态::许可拒绝:
            return 需求任务方法读取状态::许可拒绝;
        case 状态动态读取状态::版本漂移:
            return 需求任务方法读取状态::版本漂移;
        case 状态动态读取状态::内部不一致:
        case 状态动态读取状态::已找到:
        default:
            return 需求任务方法读取状态::内部不一致;
        }
    }

    static 需求任务方法业务状态 映射状态动态读取失败(
        状态动态读取状态 状态) noexcept {
        switch (状态) {
        case 状态动态读取状态::许可拒绝:
            return 需求任务方法业务状态::许可拒绝;
        case 状态动态读取状态::版本漂移:
            return 需求任务方法业务状态::版本漂移;
        case 状态动态读取状态::内部不一致:
        case 状态动态读取状态::已找到:
            return 需求任务方法业务状态::内部不一致;
        default:
            return 需求任务方法业务状态::入口拒绝;
        }
    }

    static 需求任务方法业务状态 映射结构失败(const 结构写入结果& 结果) noexcept {
        switch (结果.状态) {
        case 结构写入状态::许可拒绝: return 需求任务方法业务状态::许可拒绝;
        case 结构写入状态::版本漂移: return 需求任务方法业务状态::版本漂移;
        case 结构写入状态::入口拒绝: return 需求任务方法业务状态::入口拒绝;
        default: return 需求任务方法业务状态::内部不一致;
        }
    }

    static 需求提交结果 从需求读取失败(需求任务方法读取状态 状态) noexcept {
        return {映射读取失败(状态)};
    }

    static 任务提交结果 从任务读取失败(需求任务方法读取状态 状态) noexcept {
        return {映射读取失败(状态)};
    }

    static 需求提交结果 从结构失败形成需求结果(const 结构写入结果& 结果) noexcept {
        return {映射结构失败(结果)};
    }

    static 任务提交结果 从结构失败形成任务结果(const 结构写入结果& 结果) noexcept {
        return {映射结构失败(结果)};
    }

    结构事务接线 接线_;
    主信息仓库& 主信息_;
    节点仓库& 节点_;
    关系仓库& 关系_;
    索引仓库& 索引_;
    std::uint64_t 关系仓库编号_ = 0;
    存在场景数据操作& 存在数据操作_;
    状态动态数据操作& 状态数据操作_;
    结构写入执行器 执行器_;
};

}
