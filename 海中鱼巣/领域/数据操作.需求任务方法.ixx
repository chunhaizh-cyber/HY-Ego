class 需求任务方法数据操作 final {
public:
    需求任务方法数据操作(
        结构事务接线 接线,
        主信息仓库& 主信息,
        节点仓库& 节点,
        关系仓库& 关系,
        索引仓库& 索引,
        std::uint64_t 关系仓库编号,
        存在场景数据操作& 存在数据操作,
        状态动态数据操作& 状态数据操作)
        : 接线_(std::move(接线)), 主信息_(主信息), 节点_(节点), 关系_(关系),
          索引_(索引), 关系仓库编号_(关系仓库编号), 存在数据操作_(存在数据操作),
          状态数据操作_(状态数据操作),
          执行器_(接线_, &主信息_, &节点_, &关系_, &索引_) {}

    bool 有效() const noexcept {
        return 接线_.已接域() && 关系仓库编号_ != 0 && 执行器_.有效()
            && 存在数据操作_.有效() && 状态数据操作_.有效();
    }

    std::optional<完整需求写入规格> 形成完整需求写入规格(
        std::uint64_t 需求主键,
        节点句柄 主体,
        节点句柄 目标宿主,
        节点句柄 场景,
        节点句柄 目标特征,
        节点句柄 当前特征状态材料,
        抽象状态写入规格 目标状态规格) const {
        完整需求写入规格 规格(
            需求主键, 主体, 目标宿主, 场景, 目标特征,
            当前特征状态材料, std::move(目标状态规格));
        return 规格.完整()
            ? std::optional<完整需求写入规格>{std::move(规格)}
            : std::nullopt;
    }

    std::optional<概念命名需求写入规格> 形成概念命名需求写入规格(
        std::uint64_t 需求主键,
        节点句柄 主体,
        节点句柄 目标宿主,
        节点句柄 场景,
        节点句柄 目标特征,
        节点句柄 当前特征状态材料,
        节点句柄 目标状态,
        节点句柄 目标概念,
        节点句柄 服务根需求) const {
        概念命名需求写入规格 规格(
            需求主键, 主体, 目标宿主, 场景, 目标特征,
            当前特征状态材料, 目标状态, 目标概念, 服务根需求);
        return 规格.完整()
            ? std::optional<概念命名需求写入规格>{std::move(规格)}
            : std::nullopt;
    }

