    需求权威材料 读取需求(节点句柄 需求) const {
        if (!有效() || !句柄有效(需求)) return {};
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) return {需求任务方法读取状态::许可拒绝};
        return 读取需求_已许可(需求, 许可.读取令牌());
    }

    需求权威材料 读取主键需求(std::uint64_t 主键) const {
        if (!有效() || 主键 == 0) return {};
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) return {需求任务方法读取状态::许可拒绝};
        const auto 需求 = 索引_.按主键查节点(主键, 许可.读取令牌());
        if (!需求.has_value()) return {需求任务方法读取状态::未找到};
        auto 输出 = 读取需求_已许可(*需求, 许可.读取令牌());
        if (输出.状态 == 需求任务方法读取状态::已找到
            && 输出.身份.幂等主键 != 主键) {
            输出.状态 = 需求任务方法读取状态::内部不一致;
        }
        return 输出;
    }

    任务权威材料 读取任务(节点句柄 任务) const {
        if (!有效() || !句柄有效(任务)) return {};
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) return {需求任务方法读取状态::许可拒绝};
        return 读取任务_已许可(任务, 许可.读取令牌());
    }

    任务权威材料 读取主键任务(std::uint64_t 主键) const {
        if (!有效() || 主键 == 0) return {};
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) return {需求任务方法读取状态::许可拒绝};
        const auto 任务 = 索引_.按主键查节点(主键, 许可.读取令牌());
        if (!任务.has_value()) return {需求任务方法读取状态::未找到};
        auto 输出 = 读取任务_已许可(*任务, 许可.读取令牌());
        if (输出.状态 == 需求任务方法读取状态::已找到
            && 输出.身份.幂等主键 != 主键) {
            输出.状态 = 需求任务方法读取状态::内部不一致;
        }
        return 输出;
    }

