    需求任务方法读取状态 复核需求结算证据(
        节点句柄 动态证据,
        节点句柄 因果引用) const {
        const bool 因果引用全零 = 因果引用.仓库编号 == 0
            && 因果引用.节点编号 == 0 && 因果引用.版本号 == 0;
        if (!有效() || !句柄有效(动态证据)
            || (!因果引用全零 && !句柄有效(因果引用))) {
            return 需求任务方法读取状态::入口拒绝;
        }
        const auto 动态身份 = 状态数据操作_.读取节点身份(动态证据);
        if (!动态身份.当前可读()) {
            return 映射状态动态读取失败为读取状态(动态身份.状态);
        }
        if (动态身份.类型 != 节点类型::动态) {
            return 需求任务方法读取状态::类型不匹配;
        }
        if (因果引用全零) return 需求任务方法读取状态::已找到;
        const auto 因果身份 = 状态数据操作_.读取节点身份(因果引用);
        if (!因果身份.当前可读()) {
            return 映射状态动态读取失败为读取状态(因果身份.状态);
        }
        return 因果身份.类型 == 节点类型::因果引用
            ? 需求任务方法读取状态::已找到
            : 需求任务方法读取状态::类型不匹配;
    }

