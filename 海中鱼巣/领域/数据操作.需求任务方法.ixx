// 文件规则：需求任务方法数据操作封闭四仓库和唯一结构执行器，只执行类型化读写与精确收口。
module;

#include "../核心/结构事务接线.数据.h"
#include "../核心/主信息仓库.h"
#include "../核心/节点仓库.h"
#include "../核心/关系仓库.h"
#include "../核心/索引仓库.h"

#include <algorithm>
#include <array>
#include <cstddef>
#include <cstdint>
#include <limits>
#include <optional>
#include <utility>
#include <vector>

export module 海中鱼巣.领域.数据操作.需求任务方法;

import 海中鱼巣.核心.执行器.结构写入;
import 海中鱼巣.领域.数据操作.存在场景;
import 海中鱼巣.领域.数据操作.状态动态;

export namespace 海中鱼巣 {

enum class 需求任务方法业务状态 : std::uint8_t {
    已提交 = 1,
    幂等读回 = 2,
    入口拒绝 = 3,
    幂等冲突 = 4,
    许可拒绝 = 5,
    版本漂移 = 6,
    内部不一致 = 7
};

enum class 需求任务方法读取状态 : std::uint8_t {
    已找到 = 1,
    未找到 = 2,
    入口拒绝 = 3,
    类型不匹配 = 4,
    许可拒绝 = 5,
    版本漂移 = 6,
    内部不一致 = 7
};

enum class 分层需求结算结论 : std::int64_t {
    未结算 = 0,
    已满足 = 1,
    未满足 = 2
};

enum class 分层任务生命周期阶段 : std::int64_t {
    未定义 = 0,
    已创建 = 1,
    已承接 = 2,
    筹办中 = 3,
    排队中 = 4,
    执行中 = 5,
    等待中 = 6,
    待重筹办 = 7,
    已完成 = 8,
    失败 = 9,
    取消 = 10
};

enum class 分层方法角色 : std::int64_t {
    未定义 = 0,
    方法首 = 1,
    方法条件 = 2,
    方法结果 = 3,
    条件结果对 = 4,
    动作入口 = 5,
    方法登记根 = 6
};

enum class 分层方法生命周期 : std::int64_t {
    未定义 = 0,
    活跃 = 1,
    已失效 = 2
};

struct 高级关系证据 {
    关系句柄 关系;
    关系类型 类型 = 关系类型::普通父子;
    节点句柄 源节点;
    节点句柄 目标节点;
    std::int64_t 顺序号 = 0;
    记录状态 状态 = 记录状态::无效;

    bool 完整() const noexcept {
        return 句柄有效(关系) && 句柄有效(源节点) && 句柄有效(目标节点);
    }

    bool 当前有效() const noexcept {
        return 完整() && 状态 == 记录状态::有效;
    }
};

struct 高级节点身份 {
    需求任务方法读取状态 状态 = 需求任务方法读取状态::入口拒绝;
    std::uint64_t 幂等主键 = 0;
    节点句柄 节点;
    节点类型 类型 = 节点类型::未分类;
    主信息句柄 主信息;

    bool 当前可读() const noexcept {
        return 状态 == 需求任务方法读取状态::已找到
            && 句柄有效(节点) && 句柄有效(主信息);
    }
};

struct 需求正式结算材料 {
    状态值式材料 结算状态;
    节点句柄 需求;
    高级关系证据 需求归属关系;
    节点句柄 来源任务;
    高级关系证据 来源任务关系;
    节点句柄 目标状态;
    高级关系证据 目标状态关系;
    节点句柄 实际状态;
    高级关系证据 实际状态关系;
    节点句柄 动态证据;
    高级关系证据 动态证据关系;
    std::optional<节点句柄> 因果引用;
    std::optional<高级关系证据> 因果引用关系;

    bool 完整() const noexcept {
        const bool 因果完整 = 因果引用.has_value() == 因果引用关系.has_value()
            && (!因果引用.has_value()
                || (句柄有效(*因果引用) && 因果引用关系->当前有效()
                    && 因果引用关系->类型 == 关系类型::引用
                    && 因果引用关系->源节点 == 结算状态.状态节点
                    && 因果引用关系->目标节点 == *因果引用
                    && 因果引用关系->顺序号 == 5));
        return 结算状态.完整实例状态()
            && 结算状态.状态值 == static_cast<std::int64_t>(分层需求结算结论::已满足)
            && 句柄有效(需求) && 需求归属关系.当前有效()
            && 需求归属关系.类型 == 关系类型::归属
            && 需求归属关系.源节点 == 需求
            && 需求归属关系.目标节点 == 结算状态.状态节点
            && 需求归属关系.顺序号 == static_cast<std::int64_t>(结算状态.发生时间戳)
            && 句柄有效(来源任务) && 来源任务关系.当前有效()
            && 来源任务关系.类型 == 关系类型::引用
            && 来源任务关系.源节点 == 结算状态.状态节点
            && 来源任务关系.目标节点 == 来源任务 && 来源任务关系.顺序号 == 1
            && 句柄有效(目标状态) && 目标状态关系.当前有效()
            && 目标状态关系.类型 == 关系类型::模板
            && 目标状态关系.源节点 == 结算状态.状态节点
            && 目标状态关系.目标节点 == 目标状态 && 目标状态关系.顺序号 == 2
            && 句柄有效(实际状态) && 实际状态关系.当前有效()
            && 实际状态关系.类型 == 关系类型::引用
            && 实际状态关系.源节点 == 结算状态.状态节点
            && 实际状态关系.目标节点 == 实际状态 && 实际状态关系.顺序号 == 3
            && 句柄有效(动态证据) && 动态证据关系.当前有效()
            && 动态证据关系.类型 == 关系类型::因果来源
            && 动态证据关系.源节点 == 结算状态.状态节点
            && 动态证据关系.目标节点 == 动态证据 && 动态证据关系.顺序号 == 4
            && 因果完整;
    }
};

struct 需求权威材料 {
    需求任务方法读取状态 状态 = 需求任务方法读取状态::入口拒绝;
    高级节点身份 身份;
    节点句柄 主体;
    节点句柄 目标宿主;
    节点句柄 场景;
    节点句柄 目标特征;
    节点句柄 当前特征状态材料;
    节点句柄 目标状态;
    高级关系证据 主体关系;
    高级关系证据 目标宿主关系;
    高级关系证据 场景关系;
    高级关系证据 目标特征关系;
    高级关系证据 当前特征状态关系;
    高级关系证据 目标状态关系;
    std::optional<节点句柄> 目标概念;
    std::optional<高级关系证据> 目标概念关系;
    std::optional<节点句柄> 父需求;
    std::optional<高级关系证据> 父子关系;
    分层需求结算结论 当前结算 = 分层需求结算结论::未结算;
    std::optional<节点句柄> 最近结算状态;
    std::optional<需求正式结算材料> 正式结算;

    bool 完整目标状态需求() const noexcept {
        return 状态 == 需求任务方法读取状态::已找到 && 身份.当前可读()
            && 身份.类型 == 节点类型::需求 && 句柄有效(主体)
            && 句柄有效(目标宿主) && 句柄有效(场景)
            && 句柄有效(目标特征) && 句柄有效(当前特征状态材料)
            && 句柄有效(目标状态) && 主体关系.当前有效()
            && 目标宿主关系.当前有效() && 场景关系.当前有效()
            && 目标特征关系.当前有效() && 当前特征状态关系.当前有效()
            && 目标状态关系.当前有效();
    }

    bool 完整概念命名需求() const noexcept {
        return 完整目标状态需求() && 目标概念.has_value()
            && 目标概念关系.has_value() && 目标概念关系->当前有效()
            && 父需求.has_value() && 父子关系.has_value()
            && 父子关系->当前有效();
    }
};

struct 任务生命周期材料 {
    高级关系证据 关系;
    节点句柄 状态;
    分层任务生命周期阶段 阶段 = 分层任务生命周期阶段::未定义;
    std::uint32_t 版本 = 0;
    std::uint64_t 发生时间戳 = 0;
    记录状态 记录阶段 = 记录状态::无效;

    bool 完整() const noexcept {
        return 关系.完整() && 句柄有效(状态)
            && 阶段 >= 分层任务生命周期阶段::已创建
            && 阶段 <= 分层任务生命周期阶段::取消
            && 版本 != 0 && 关系.顺序号 == static_cast<std::int64_t>(版本);
    }

    bool 当前() const noexcept {
        return 完整() && 记录阶段 == 记录状态::有效 && 关系.当前有效();
    }
};

struct 任务方法选择材料 {
    高级节点身份 记录身份;
    节点句柄 任务;
    节点句柄 方法;
    std::uint64_t 幂等材料编号 = 0;
    高级关系证据 方法投影关系;
    高级关系证据 发布关系;
    关系句柄 来源生命周期关系;
    std::uint32_t 来源生命周期版本 = 0;
    关系句柄 来源方法生命周期关系;
    std::uint32_t 来源方法生命周期版本 = 0;
    std::uint32_t 排序规则版本 = 0;
    std::uint32_t 召回请求规则版本 = 0;
    std::uint64_t 来源候选数量 = 0;

    bool 完整() const noexcept {
        return 记录身份.当前可读() && 记录身份.类型 == 节点类型::任务方法选择记录
            && 句柄有效(任务) && 句柄有效(方法) && 幂等材料编号 != 0
            && 方法投影关系.当前有效() && 发布关系.当前有效()
            && 句柄有效(来源生命周期关系) && 来源生命周期版本 != 0
            && 句柄有效(来源方法生命周期关系) && 来源方法生命周期版本 != 0
            && 排序规则版本 != 0 && 召回请求规则版本 != 0
            && 来源候选数量 != 0;
    }
};

struct 任务权威材料 {
    需求任务方法读取状态 状态 = 需求任务方法读取状态::入口拒绝;
    高级节点身份 身份;
    节点句柄 来源需求;
    节点句柄 虚拟存在;
    节点句柄 场景;
    节点句柄 目标状态;
    高级关系证据 需求拥有任务关系;
    高级关系证据 任务来源需求关系;
    高级关系证据 虚拟存在关系;
    高级关系证据 场景关系;
    高级关系证据 目标状态关系;
    任务生命周期材料 当前生命周期;
    std::optional<节点句柄> 实际结果状态;
    std::optional<高级关系证据> 实际结果关系;
    std::optional<任务方法选择材料> 当前选择;

    bool 完整承接() const noexcept {
        return 状态 == 需求任务方法读取状态::已找到 && 身份.当前可读()
            && 身份.类型 == 节点类型::任务 && 句柄有效(来源需求)
            && 句柄有效(虚拟存在) && 句柄有效(场景) && 句柄有效(目标状态)
            && 需求拥有任务关系.当前有效() && 任务来源需求关系.当前有效()
            && 虚拟存在关系.当前有效() && 场景关系.当前有效()
            && 目标状态关系.当前有效() && 当前生命周期.当前();
    }
};

struct 方法登记根材料 {
    需求任务方法读取状态 状态 = 需求任务方法读取状态::入口拒绝;
    高级节点身份 身份;
    节点句柄 角色状态;
    节点句柄 活跃状态;
    节点句柄 失效状态;
    高级关系证据 角色关系;
    高级关系证据 活跃状态关系;
    高级关系证据 失效状态关系;

    bool 完整() const noexcept {
        return 状态 == 需求任务方法读取状态::已找到 && 身份.当前可读()
            && 身份.类型 == 节点类型::方法 && 句柄有效(角色状态)
            && 句柄有效(活跃状态) && 句柄有效(失效状态)
            && 角色状态 != 活跃状态 && 角色状态 != 失效状态
            && 活跃状态 != 失效状态 && 角色关系.当前有效()
            && 活跃状态关系.当前有效() && 失效状态关系.当前有效();
    }
};

struct 方法登记项材料 {
    需求任务方法读取状态 状态 = 需求任务方法读取状态::入口拒绝;
    高级节点身份 身份;
    节点句柄 登记根;
    节点句柄 角色状态;
    节点句柄 虚拟存在;
    高级关系证据 登记关系;
    高级关系证据 角色关系;
    高级关系证据 虚拟存在关系;
    高级关系证据 生命周期关系;
    分层方法生命周期 生命周期 = 分层方法生命周期::未定义;

    bool 完整() const noexcept {
        return 状态 == 需求任务方法读取状态::已找到 && 身份.当前可读()
            && 身份.类型 == 节点类型::方法 && 句柄有效(登记根)
            && 句柄有效(角色状态) && 句柄有效(虚拟存在)
            && 登记关系.当前有效() && 角色关系.当前有效()
            && 虚拟存在关系.当前有效() && 生命周期关系.当前有效()
            && (生命周期 == 分层方法生命周期::活跃
                || 生命周期 == 分层方法生命周期::已失效);
    }
};

struct 方法规格材料 {
    需求任务方法读取状态 状态 = 需求任务方法读取状态::入口拒绝;
    高级节点身份 身份;
    节点句柄 方法首;
    分层方法角色 角色 = 分层方法角色::未定义;
    节点句柄 角色状态;
    高级关系证据 方法角色关系;
    高级关系证据 角色状态关系;
    std::optional<节点句柄> 场景;
    std::optional<高级关系证据> 场景关系;
    std::optional<节点句柄> 目标特征;
    std::optional<高级关系证据> 目标特征关系;
    std::optional<节点句柄> 目标状态;
    std::optional<高级关系证据> 目标状态关系;
    std::uint64_t 来源版本 = 0;
    std::int64_t 目标状态值 = 0;
    std::optional<节点句柄> 入口状态;
    std::optional<高级关系证据> 入口状态关系;
    std::optional<节点句柄> 输入场景;
    std::optional<节点句柄> 输出场景;
    std::optional<高级关系证据> 输入场景关系;
    std::optional<高级关系证据> 输出场景关系;
    std::uint64_t 稳定动作键 = 0;

    bool 完整条件() const noexcept {
        return 状态 == 需求任务方法读取状态::已找到 && 身份.当前可读()
            && 角色 == 分层方法角色::方法条件 && 句柄有效(方法首)
            && 句柄有效(角色状态) && 方法角色关系.当前有效()
            && 角色状态关系.当前有效() && 场景.has_value() && 场景关系.has_value()
            && 场景关系->当前有效() && 目标特征.has_value()
            && 目标特征关系.has_value() && 目标特征关系->当前有效()
            && 目标状态.has_value() && 目标状态关系.has_value()
            && 目标状态关系->当前有效() && 来源版本 != 0;
    }

    bool 完整结果() const noexcept {
        return 状态 == 需求任务方法读取状态::已找到 && 身份.当前可读()
            && 角色 == 分层方法角色::方法结果 && 句柄有效(方法首)
            && 句柄有效(角色状态) && 方法角色关系.当前有效()
            && 角色状态关系.当前有效() && 场景.has_value() && 场景关系.has_value()
            && 场景关系->当前有效() && 目标特征.has_value()
            && 目标特征关系.has_value() && 目标特征关系->当前有效()
            && 目标状态.has_value() && 目标状态关系.has_value()
            && 目标状态关系->当前有效() && 来源版本 != 0;
    }

    bool 完整动作入口() const noexcept {
        return 状态 == 需求任务方法读取状态::已找到 && 身份.当前可读()
            && 角色 == 分层方法角色::动作入口 && 句柄有效(方法首)
            && 句柄有效(角色状态) && 方法角色关系.当前有效()
            && 角色状态关系.当前有效() && 入口状态.has_value()
            && 入口状态关系.has_value() && 入口状态关系->当前有效()
            && 输入场景.has_value() && 输出场景.has_value()
            && 输入场景关系.has_value() && 输出场景关系.has_value()
            && 输入场景关系->当前有效() && 输出场景关系->当前有效()
            && 稳定动作键 != 0;
    }
};

struct 方法动作桥请求材料 {
    节点句柄 任务;
    节点句柄 方法首;
    节点句柄 动作入口;
    std::uint64_t 稳定动作键 = 0;
    节点句柄 输入场景;
    节点句柄 输出场景;

    bool 完整() const noexcept {
        return 句柄有效(任务) && 句柄有效(方法首) && 句柄有效(动作入口)
            && 稳定动作键 != 0 && 句柄有效(输入场景) && 句柄有效(输出场景);
    }
};

struct 需求提交结果 {
    需求任务方法业务状态 状态 = 需求任务方法业务状态::入口拒绝;
    需求权威材料 材料;

    bool 成功() const noexcept {
        return 状态 == 需求任务方法业务状态::已提交
            || 状态 == 需求任务方法业务状态::幂等读回;
    }
};

struct 任务提交结果 {
    需求任务方法业务状态 状态 = 需求任务方法业务状态::入口拒绝;
    任务权威材料 材料;

    bool 成功() const noexcept {
        return 状态 == 需求任务方法业务状态::已提交
            || 状态 == 需求任务方法业务状态::幂等读回;
    }
};

struct 方法提交结果 {
    需求任务方法业务状态 状态 = 需求任务方法业务状态::入口拒绝;
    方法登记根材料 根;
    方法登记项材料 登记项;
    方法规格材料 规格;

    bool 成功() const noexcept {
        return 状态 == 需求任务方法业务状态::已提交
            || 状态 == 需求任务方法业务状态::幂等读回;
    }
};

class 完整需求写入规格 final {
public:
    完整需求写入规格() = delete;

private:
    friend class 需求任务方法数据操作;

    完整需求写入规格(
        std::uint64_t 需求主键,
        节点句柄 主体,
        节点句柄 目标宿主,
        节点句柄 场景,
        节点句柄 目标特征,
        节点句柄 当前特征状态材料,
        抽象状态写入规格 目标状态规格)
        : 需求主键_(需求主键), 主体_(主体), 目标宿主_(目标宿主), 场景_(场景),
          目标特征_(目标特征), 当前特征状态材料_(当前特征状态材料),
          目标状态规格_(std::move(目标状态规格)) {}

    bool 完整() const noexcept {
        return 需求主键_ != 0 && 句柄有效(主体_) && 句柄有效(目标宿主_)
            && 句柄有效(场景_) && 句柄有效(目标特征_)
            && 句柄有效(当前特征状态材料_) && 目标状态规格_.完整();
    }

    std::uint64_t 需求主键_ = 0;
    节点句柄 主体_;
    节点句柄 目标宿主_;
    节点句柄 场景_;
    节点句柄 目标特征_;
    节点句柄 当前特征状态材料_;
