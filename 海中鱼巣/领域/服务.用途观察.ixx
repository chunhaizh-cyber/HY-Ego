// 文件规则：用途观察业务服务只负责用途事件准入、纯值形成与业务结果映射；不得取得仓库、许可、令牌或结构写入会话。
module;

#include "../核心/句柄.h"

#include <cstdint>
#include <optional>

export module 海中鱼巣.领域.服务.用途观察;

import 海中鱼巣.领域.材料.用途事件;
import 海中鱼巣.领域.材料.用途观察;
import 海中鱼巣.领域.算法.用途观察;
import 海中鱼巣.领域.数据操作.用途观察;

export namespace 海中鱼巣 {

struct 用途观察发布请求 {
    用途事件结果 事件结果;
    std::uint32_t 目标格式版本 = 0;
};

class 用途观察业务服务 final {
public:
    explicit 用途观察业务服务(用途观察数据操作& 数据操作)
        : 数据操作_(数据操作) {
    }

    用途观察结构业务结果 发布用途观察(
        const 用途事件结果& 事件结果,
        std::uint32_t 目标格式版本) const {
        const auto 形成结果 = 形成用途观察纯值候选(事件结果, 目标格式版本);
        if (形成结果.成功()) return 数据操作_.发布候选(*形成结果.候选);
        switch (形成结果.状态) {
        case 用途观察纯值形成状态::入口拒绝:
            return {用途观察结构业务状态::入口拒绝,
                用途观察结构业务原因::纯值入口拒绝, std::nullopt};
        case 用途观察纯值形成状态::不支持:
            return {用途观察结构业务状态::不支持,
                用途观察结构业务原因::纯值不支持, std::nullopt};
        case 用途观察纯值形成状态::内部不一致:
            return {用途观察结构业务状态::内部不一致,
                用途观察结构业务原因::纯值内部不一致, std::nullopt};
        default:
            return {用途观察结构业务状态::内部不一致,
                用途观察结构业务原因::纯值内部不一致, std::nullopt};
        }
    }

    用途观察结构业务结果 发布用途观察(const 用途观察发布请求& 请求) const {
        return 发布用途观察(请求.事件结果, 请求.目标格式版本);
    }

    用途观察结构读取结果 读取用途观察(节点句柄 观察节点) const {
        return 数据操作_.读取观察节点(观察节点);
    }

    用途观察结构读取结果 读取用途观察(
        const 用途观察语义身份& 身份) const {
        return 数据操作_.读取完整身份(身份);
    }

private:
    用途观察数据操作& 数据操作_;
};

}
