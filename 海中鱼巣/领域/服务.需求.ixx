// 文件规则：需求业务服务只裁决目标状态需求、父子和独立结算，不接触仓库或事务能力。
module;

#include "../核心/句柄.h"

#include <cstddef>
#include <cstdint>
#include <optional>
#include <utility>

export module 海中鱼巣.领域.服务.需求;

import 海中鱼巣.领域.数据操作.需求任务方法;
import 海中鱼巣.领域.数据操作.状态动态;
import 海中鱼巣.领域.服务.状态;

export namespace 海中鱼巣 {

struct 创建完整目标状态需求请求 {
    std::uint64_t 需求幂等主键 = 0;
    std::uint64_t 目标状态幂等主键 = 0;
    节点句柄 主体;
    节点句柄 目标宿主;
    节点句柄 场景;
    节点句柄 目标特征;
    节点句柄 当前特征状态材料;
    std::int64_t 目标状态值 = 0;
};

struct 创建概念命名需求请求 {
    std::uint64_t 需求幂等主键 = 0;
    节点句柄 主体;
    节点句柄 目标宿主;
    节点句柄 场景;
    节点句柄 目标特征;
    节点句柄 当前特征状态材料;
    节点句柄 目标状态;
    节点句柄 目标概念;
    节点句柄 服务根需求;
};

struct 更新需求父子请求 {
    节点句柄 子需求;
    节点句柄 新父需求;
};

struct 提交需求结算请求 {
    节点句柄 需求;
    节点句柄 来源任务;
    节点句柄 实际状态;
    节点句柄 动态证据;
    节点句柄 因果引用;
    std::uint64_t 结算状态幂等主键 = 0;
    std::uint64_t 发生时间戳 = 0;
};

class 需求业务服务 final {
public:
    需求业务服务(
        需求任务方法数据操作& 数据操作,
        状态业务服务& 状态服务)
        : 数据操作_(数据操作), 状态服务_(状态服务) {
    }

    需求提交结果 创建完整目标状态需求(
        const 创建完整目标状态需求请求& 请求) const {
        if (请求.需求幂等主键 == 0 || 请求.目标状态幂等主键 == 0
            || !句柄有效(请求.主体) || !句柄有效(请求.目标宿主)
            || !句柄有效(请求.场景) || !句柄有效(请求.目标特征)
            || !句柄有效(请求.当前特征状态材料)) return {};
        const 创建抽象状态请求 状态请求{
            请求.目标状态幂等主键, 请求.目标状态值};
        抽象状态规格结果 状态规格 =
            状态服务_.形成抽象状态写入规格(状态请求);
        if (!状态规格.成功()) return {映射规格失败(状态规格.状态)};
        const auto 写入规格 = 数据操作_.形成完整需求写入规格(
            请求.需求幂等主键, 请求.主体, 请求.目标宿主, 请求.场景,
            请求.目标特征, 请求.当前特征状态材料,
            std::move(*状态规格.规格));
        return 写入规格.has_value()
            ? 数据操作_.创建完整目标状态需求(*写入规格)
            : 需求提交结果{需求任务方法业务状态::内部不一致};
    }

    需求提交结果 创建概念命名需求(
        const 创建概念命名需求请求& 请求) const {
        if (请求.需求幂等主键 == 0 || !句柄有效(请求.主体)
            || !句柄有效(请求.目标宿主) || !句柄有效(请求.场景)
            || !句柄有效(请求.目标特征) || !句柄有效(请求.当前特征状态材料)
            || !句柄有效(请求.目标状态) || !句柄有效(请求.目标概念)
            || !句柄有效(请求.服务根需求)) return {};
        const auto 目标状态 = 状态服务_.读取状态材料(请求.目标状态);
        if (!目标状态.完整抽象状态()) return {};
        const auto 写入规格 = 数据操作_.形成概念命名需求写入规格(
            请求.需求幂等主键, 请求.主体, 请求.目标宿主, 请求.场景,
            请求.目标特征, 请求.当前特征状态材料, 请求.目标状态,
            请求.目标概念, 请求.服务根需求);
        return 写入规格.has_value()
            ? 数据操作_.创建概念命名需求(*写入规格)
            : 需求提交结果{需求任务方法业务状态::内部不一致};
    }

    需求提交结果 更新父需求(const 更新需求父子请求& 请求) const {
        if (!句柄有效(请求.子需求) || !句柄有效(请求.新父需求)
            || 请求.子需求 == 请求.新父需求) return {};
        return 数据操作_.更新需求父子(请求.子需求, 请求.新父需求);
    }

    需求提交结果 提交独立结算(const 提交需求结算请求& 请求) const {
        if (!句柄有效(请求.需求) || !句柄有效(请求.来源任务)
            || !句柄有效(请求.实际状态) || !句柄有效(请求.动态证据)
            || 请求.结算状态幂等主键 == 0
            || 请求.发生时间戳 == 0) return {};
        const auto 需求 = 数据操作_.读取需求(请求.需求);
        const auto 任务 = 数据操作_.读取任务(请求.来源任务);
        const auto 目标状态 = 需求.完整目标状态需求()
            ? 状态服务_.读取状态材料(需求.目标状态) : 状态值式材料{};
        const auto 实际状态 = 状态服务_.读取状态材料(请求.实际状态);
        if (!需求.完整目标状态需求() || !任务.完整承接()
            || 任务.来源需求 != 请求.需求
            || 任务.当前生命周期.阶段 != 分层任务生命周期阶段::已完成
            || 任务.实际结果状态 != std::optional<节点句柄>{请求.实际状态}
            || !目标状态.完整抽象状态() || !实际状态.完整实例状态()
            || 实际状态.场景 != 任务.场景 || 实际状态.主体 != 任务.虚拟存在) return {};
        const auto 结论 = 目标状态.状态值 == 实际状态.状态值
            ? 分层需求结算结论::已满足 : 分层需求结算结论::未满足;
        const 创建实例状态请求 结算状态请求{
            请求.结算状态幂等主键, 任务.场景, 任务.虚拟存在,
            请求.发生时间戳, static_cast<std::int64_t>(结论)};
        实例状态规格结果 结算规格 =
            状态服务_.形成实例状态写入规格(结算状态请求);
        if (!结算规格.成功()) return {映射规格失败(结算规格.状态)};
        const auto 写入规格 = 数据操作_.形成需求结算写入规格(
            请求.需求, 请求.来源任务, 请求.实际状态,
            请求.动态证据, 请求.因果引用, 结论,
            std::move(*结算规格.规格));
        return 写入规格.has_value()
            ? 数据操作_.提交需求结算(*写入规格)
            : 需求提交结果{需求任务方法业务状态::内部不一致};
    }

    需求权威材料 读取需求(节点句柄 需求) const {
        return 句柄有效(需求) ? 数据操作_.读取需求(需求) : 需求权威材料{};
    }

    需求权威材料 读取主键需求(std::uint64_t 主键) const {
        return 主键 != 0 ? 数据操作_.读取主键需求(主键) : 需求权威材料{};
    }

#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
    需求任务方法故障自检结果 执行完整需求固定故障自检(
        const 创建完整目标状态需求请求& 请求,
        std::size_t 故障写点) const {
        if (请求.需求幂等主键 == 0 || 请求.目标状态幂等主键 == 0
            || !句柄有效(请求.主体) || !句柄有效(请求.目标宿主)
            || !句柄有效(请求.场景) || !句柄有效(请求.目标特征)
            || !句柄有效(请求.当前特征状态材料)) return {};
        const 创建抽象状态请求 状态请求{
            请求.目标状态幂等主键, 请求.目标状态值};
        抽象状态规格结果 状态规格 =
            状态服务_.形成抽象状态写入规格(状态请求);
        if (!状态规格.成功()) {
            return {映射规格失败(状态规格.状态), 0, false};
        }
        const auto 写入规格 = 数据操作_.形成完整需求写入规格(
            请求.需求幂等主键, 请求.主体, 请求.目标宿主, 请求.场景,
            请求.目标特征, 请求.当前特征状态材料,
            std::move(*状态规格.规格));
        if (!写入规格.has_value()) {
            return {需求任务方法业务状态::内部不一致, 0, false};
        }
        return 数据操作_.执行完整需求固定故障自检(
            *写入规格,
            故障写点);
    }
#endif

private:
    static 需求任务方法业务状态 映射规格失败(状态写入规格状态 状态) noexcept {
        switch (状态) {
        case 状态写入规格状态::许可拒绝:
            return 需求任务方法业务状态::许可拒绝;
        case 状态写入规格状态::版本漂移:
            return 需求任务方法业务状态::版本漂移;
        case 状态写入规格状态::内部不一致:
            return 需求任务方法业务状态::内部不一致;
        default:
            return 需求任务方法业务状态::入口拒绝;
        }
    }

    需求任务方法数据操作& 数据操作_;
    状态业务服务& 状态服务_;
};

}
