// 文件规则：状态业务服务只裁决抽象状态、完整实例状态和写入规格，不接触仓库或事务能力。
module;

#include "../核心/句柄.h"

#include <cstdint>
#include <limits>
#include <optional>

export module 海中鱼巣.领域.服务.状态;

import 海中鱼巣.领域.数据操作.状态动态;

export namespace 海中鱼巣 {

struct 创建抽象状态请求 {
    std::uint64_t 幂等主键 = 0;
    std::int64_t 状态值 = 0;
};

struct 创建实例状态请求 {
    std::uint64_t 幂等主键 = 0;
    节点句柄 场景;
    节点句柄 主体;
    std::uint64_t 发生时间戳 = 0;
    std::int64_t 状态值 = 0;
};

struct 创建候选主体实例状态请求 {
    std::uint64_t 幂等主键 = 0;
    节点句柄 场景;
    std::uint64_t 发生时间戳 = 0;
    std::int64_t 状态值 = 0;
};

enum class 状态写入规格状态 : std::uint8_t {
    已形成 = 1,
    入口拒绝 = 2,
    许可拒绝 = 3,
    版本漂移 = 4,
    内部不一致 = 5
};

using 实例状态规格状态 = 状态写入规格状态;

struct 抽象状态规格结果 {
    状态写入规格状态 状态 = 状态写入规格状态::入口拒绝;
    std::optional<抽象状态写入规格> 规格;

    bool 成功() const noexcept {
        return 状态 == 状态写入规格状态::已形成
            && 规格.has_value() && 规格->完整();
    }
};

struct 候选主体实例状态规格结果 {
    状态写入规格状态 状态 = 状态写入规格状态::入口拒绝;
    std::optional<候选主体实例状态写入规格> 规格;

    bool 成功() const noexcept {
        return 状态 == 状态写入规格状态::已形成
            && 规格.has_value() && 规格->完整();
    }
};

struct 实例状态规格结果 {
    实例状态规格状态 状态 = 实例状态规格状态::入口拒绝;
    std::optional<实例状态写入规格> 规格;

    bool 成功() const noexcept {
        return 状态 == 实例状态规格状态::已形成
            && 规格.has_value() && 规格->完整();
    }
};

class 状态业务服务 final {
public:
    explicit 状态业务服务(状态动态数据操作& 数据操作) : 数据操作_(数据操作) {
    }

    抽象状态规格结果 形成抽象状态写入规格(const 创建抽象状态请求& 请求) const {
        if (请求.幂等主键 == 0) return {};
        抽象状态规格结果 输出;
        输出.状态 = 状态写入规格状态::已形成;
        输出.规格 = 抽象状态写入规格(请求.幂等主键, 请求.状态值);
        return 输出;
    }

    状态动态业务结果 创建抽象状态(const 创建抽象状态请求& 请求) const {
        const auto 规格结果 = 形成抽象状态写入规格(请求);
        if (!规格结果.成功()) return 映射状态规格失败(规格结果.状态);
        return 数据操作_.创建抽象状态(*规格结果.规格);
    }

    实例状态规格结果 形成实例状态写入规格(const 创建实例状态请求& 请求) const {
        if (请求.幂等主键 == 0 || !句柄有效(请求.场景) || !句柄有效(请求.主体)
            || 请求.发生时间戳 == 0
            || 请求.发生时间戳 > static_cast<std::uint64_t>(std::numeric_limits<std::int64_t>::max())) {
            return {};
        }
        const auto 场景身份 = 数据操作_.读取节点身份(请求.场景);
        const auto 主体身份 = 数据操作_.读取节点身份(请求.主体);
        if (!场景身份.当前可读() || !主体身份.当前可读()) {
            return {合并读取失败(场景身份.状态, 主体身份.状态)};
        }
        if (场景身份.类型 != 节点类型::场景 || 主体身份.类型 != 节点类型::存在) return {};
        实例状态规格结果 输出;
        输出.状态 = 实例状态规格状态::已形成;
        输出.规格 = 实例状态写入规格(
            请求.幂等主键, 请求.场景, 请求.主体, 请求.发生时间戳, 请求.状态值);
        return 输出;
    }

    候选主体实例状态规格结果 形成候选主体实例状态写入规格(
        const 创建候选主体实例状态请求& 请求) const {
        if (请求.幂等主键 == 0 || !句柄有效(请求.场景)
            || 请求.发生时间戳 == 0
            || 请求.发生时间戳 > static_cast<std::uint64_t>(std::numeric_limits<std::int64_t>::max())) {
            return {};
        }
        const auto 场景身份 = 数据操作_.读取节点身份(请求.场景);
        if (!场景身份.当前可读()) return {映射单个读取失败(场景身份.状态)};
        if (场景身份.类型 != 节点类型::场景) return {};
        候选主体实例状态规格结果 输出;
        输出.状态 = 状态写入规格状态::已形成;
        输出.规格 = 候选主体实例状态写入规格(
            请求.幂等主键, 请求.场景, 请求.发生时间戳, 请求.状态值);
        return 输出;
    }

    状态动态业务结果 创建完整实例状态(const 创建实例状态请求& 请求) const {
        const auto 规格结果 = 形成实例状态写入规格(请求);
        if (!规格结果.成功()) return 映射规格失败(规格结果.状态);
        return 数据操作_.创建实例状态(*规格结果.规格);
    }

    状态值式材料 读取状态材料(节点句柄 状态节点) const {
        if (!句柄有效(状态节点)) return {};
        return 数据操作_.读取状态材料(状态节点);
    }

    状态值式材料 读取主键状态材料(std::uint64_t 主键) const {
        if (主键 == 0) return {};
        return 数据操作_.读取主键状态材料(主键);
    }

private:
    static 状态写入规格状态 映射单个读取失败(状态动态读取状态 状态) noexcept {
        switch (状态) {
        case 状态动态读取状态::许可拒绝:
            return 状态写入规格状态::许可拒绝;
        case 状态动态读取状态::版本漂移:
            return 状态写入规格状态::版本漂移;
        case 状态动态读取状态::内部不一致:
            return 状态写入规格状态::内部不一致;
        default:
            return 状态写入规格状态::入口拒绝;
        }
    }

    static 实例状态规格状态 合并读取失败(
        状态动态读取状态 左,
        状态动态读取状态 右) noexcept {
        if (左 == 状态动态读取状态::内部不一致
            || 右 == 状态动态读取状态::内部不一致) return 实例状态规格状态::内部不一致;
        if (左 == 状态动态读取状态::许可拒绝
            || 右 == 状态动态读取状态::许可拒绝) return 实例状态规格状态::许可拒绝;
        if (左 == 状态动态读取状态::版本漂移
            || 右 == 状态动态读取状态::版本漂移) return 实例状态规格状态::版本漂移;
        return 实例状态规格状态::入口拒绝;
    }

    static 状态动态业务结果 映射规格失败(实例状态规格状态 状态) noexcept {
        switch (状态) {
        case 实例状态规格状态::许可拒绝:
            return {状态动态业务状态::许可拒绝};
        case 实例状态规格状态::版本漂移:
            return {状态动态业务状态::版本漂移};
        case 实例状态规格状态::内部不一致:
            return {状态动态业务状态::内部不一致};
        default:
            return {状态动态业务状态::入口拒绝};
        }
    }

    static 状态动态业务结果 映射状态规格失败(状态写入规格状态 状态) noexcept {
        return 映射规格失败(状态);
    }

    状态动态数据操作& 数据操作_;
};

}
