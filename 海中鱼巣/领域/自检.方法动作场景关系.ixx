// 文件规则：方法动作场景关系自检只验证关系 17、正式服务 ABI 和失败收口，不进入生产依赖。
module;

#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
#include "../核心/主信息仓库.h"
#include "../核心/节点仓库.h"
#include "../核心/关系仓库.h"
#include "../核心/索引仓库.h"

#include <algorithm>
#include <array>
#include <cstddef>
#include <cstdint>
#include <iostream>
#include <optional>
#include <thread>
#include <type_traits>
#include <utility>
#include <vector>
#endif

export module 海中鱼巣.领域.自检.方法动作场景关系;

#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
import 海中鱼巣.核心.协调.结构事务;
import 海中鱼巣.领域.数据操作.存在场景;
import 海中鱼巣.领域.数据操作.状态动态;
import 海中鱼巣.领域.数据操作.需求任务方法;
import 海中鱼巣.领域.服务.存在;
import 海中鱼巣.领域.服务.场景;
import 海中鱼巣.领域.服务.状态;
import 海中鱼巣.领域.服务.方法;
import 海中鱼巣.自检.运行器;

export namespace 海中鱼巣 {

namespace 方法动作场景关系自检内部 {

struct 结构数量 {
    std::uint64_t 节点 = 0;
    std::uint64_t 关系 = 0;
    std::uint64_t 主键 = 0;

    bool operator==(const 结构数量&) const = default;
};

bool 关系证据匹配(
    const 高级关系证据& 证据,
    关系类型 类型,
    节点句柄 源节点,
    节点句柄 目标节点,
    std::int64_t 顺序号) {
    return 证据.当前有效() && 证据.类型 == 类型
        && 证据.源节点 == 源节点 && 证据.目标节点 == 目标节点
        && 证据.顺序号 == 顺序号;
}

bool 关系记录相同(
    const std::optional<关系记录>& 左,
    const std::optional<关系记录>& 右) {
    return 左.has_value() && 右.has_value()
        && 左->关系编号 == 右->关系编号 && 左->类型 == 右->类型
        && 左->源节点 == 右->源节点 && 左->目标节点 == 右->目标节点
        && 左->顺序号 == 右->顺序号 && 左->版本号 == 右->版本号
        && 左->状态 == 右->状态;
}

}

自检单元结果 运行方法动作场景关系自检(
    bool 需求任务方法回归通过,
    bool 运行期组合回归通过,
    bool 服务兼容边界回归通过) {
    using namespace 方法动作场景关系自检内部;

    static_assert(static_cast<std::uint32_t>(关系类型::方法动作场景) == 17);
    static_assert(!std::is_default_constructible_v<方法动作入口写入规格>);
    static_assert(std::is_same_v<
        decltype(std::declval<const 方法业务服务&>().创建动作入口(
            创建方法动作入口请求{})),
        方法提交结果>);
    static_assert(std::is_same_v<
        decltype(std::declval<const 方法业务服务&>().读取规格组(
            节点句柄{}, 分层方法角色::动作入口)),
        std::vector<方法规格材料>>);

    std::array<bool, 16> 验收{};
    try {
        constexpr std::uint64_t 关系仓库编号 = 7853;
        结构事务协调器 协调器(785);
        const auto 接线 = 协调器.生成接线();
        主信息仓库 主信息(7851, 接线);
        节点仓库 节点(主信息, 7852, 接线);
        关系仓库 关系(节点, 关系仓库编号, 接线);
        索引仓库 索引(节点, 接线);
        存在场景数据操作 存在数据操作(
            接线, 主信息, 节点, 关系, 索引, 关系仓库编号);
        状态动态数据操作 状态数据操作(
            接线, 主信息, 节点, 关系, 索引, 关系仓库编号);
        需求任务方法数据操作 方法数据操作(
            接线, 主信息, 节点, 关系, 索引, 关系仓库编号,
            存在数据操作, 状态数据操作);
        存在业务服务 存在服务(存在数据操作);
        场景业务服务 场景服务(存在数据操作);
        状态业务服务 状态服务(状态数据操作);
        方法业务服务 方法服务(方法数据操作, 存在服务, 状态服务);

        std::uint64_t 主键序号 = 0x0785'0000'0000'1000ULL;
        const auto 新主键 = [&]() noexcept { return ++主键序号; };
        const auto 读取数量 = [&]() noexcept {
            return 结构数量{
                节点.有效节点数量(), 关系.有效关系数量(), 索引.有效主键数量()};
        };

        const auto 场景甲结果 = 场景服务.创建场景({新主键()});
        const auto 场景乙结果 = 场景服务.创建场景({新主键()});
        const auto 场景丙结果 = 场景服务.创建场景({新主键()});
        const auto 场景甲 = 场景甲结果.场景;
        const auto 场景乙 = 场景乙结果.场景;
        const auto 场景丙 = 场景丙结果.场景;
        const auto 非场景状态结果 = 状态服务.创建抽象状态({新主键(), 785});
        const auto 非场景状态 = 非场景状态结果.状态材料.状态节点;

        const auto 登记根 = 方法服务.创建登记根({
            新主键(), 新主键(), 新主键(), 新主键()});
        const auto 建立方法 = [&]() {
            return 方法服务.创建方法首({
                新主键(), 新主键(), 新主键(), 登记根.根.身份.节点});
        };

        const auto 低层方法甲结果 = 建立方法();
        const auto 低层方法乙结果 = 建立方法();
        const auto 审计方法结果 = 建立方法();
        const auto 新动作方法结果 = 建立方法();
        const auto 部分方法结果 = 建立方法();
        const auto 混存方法结果 = 建立方法();
        const auto 旧动作方法结果 = 建立方法();
        const auto 故障方法结果 = 建立方法();
        const auto 并发方法结果 = 建立方法();
        const auto 低层方法甲 = 低层方法甲结果.登记项.身份.节点;
        const auto 低层方法乙 = 低层方法乙结果.登记项.身份.节点;
        const auto 审计方法 = 审计方法结果.登记项.身份.节点;

        const bool 夹具完整 = 接线.已接域() && 存在数据操作.有效()
            && 状态数据操作.有效() && 方法数据操作.有效()
            && 场景甲结果.成功() && 场景乙结果.成功() && 场景丙结果.成功()
            && 非场景状态结果.成功() && 登记根.成功()
            && 低层方法甲结果.成功() && 低层方法乙结果.成功()
            && 审计方法结果.成功() && 新动作方法结果.成功()
            && 部分方法结果.成功() && 混存方法结果.成功()
            && 旧动作方法结果.成功() && 故障方法结果.成功()
            && 并发方法结果.成功();

        关系句柄 低层槽一;
        关系句柄 低层槽二;
        关系句柄 其它动作槽一;
        bool 槽位拒绝 = false;
        bool 端点拒绝 = false;
        bool 重复角色拒绝 = false;
        bool 普通引用回归 = false;
        bool 重挂与审计回归 = false;
        {
            auto 许可 = 接线.取得独占许可(接线.运行期状态);
            const auto& 令牌 = 许可.读取令牌();

            const auto 未知前 = 关系.有效关系数量(令牌);
            const auto 未知关系 = 关系.创建关系(
                static_cast<关系类型>(18), 低层方法甲, 场景甲, 1, 令牌);
            验收[0] = 夹具完整
                && static_cast<std::uint32_t>(关系类型::方法动作场景) == 17
                && !句柄有效(未知关系)
                && 关系.有效关系数量(令牌) == 未知前;

            const auto 槽位前 = 关系.有效关系数量(令牌);
            const auto 零槽 = 关系.创建关系(
                关系类型::方法动作场景, 低层方法甲, 场景甲, 0, 令牌);
            const auto 未知槽 = 关系.创建关系(
                关系类型::方法动作场景, 低层方法甲, 场景甲, 3, 令牌);
            槽位拒绝 = !句柄有效(零槽) && !句柄有效(未知槽)
                && 关系.有效关系数量(令牌) == 槽位前;
            验收[1] = 槽位拒绝;

            const auto 端点前 = 关系.有效关系数量(令牌);
            const auto 错源 = 关系.创建关系(
                关系类型::方法动作场景, 场景甲, 场景乙, 1, 令牌);
            const auto 错目标 = 关系.创建关系(
                关系类型::方法动作场景, 低层方法甲, 非场景状态, 1, 令牌);
            端点拒绝 = !句柄有效(错源) && !句柄有效(错目标)
                && 关系.有效关系数量(令牌) == 端点前;
            验收[2] = 端点拒绝;

            低层槽一 = 关系.创建关系(
                关系类型::方法动作场景, 低层方法甲, 场景甲, 1, 令牌);
            低层槽二 = 关系.创建关系(
                关系类型::方法动作场景, 低层方法甲, 场景甲, 2, 令牌);
            const auto 槽一记录 = 关系.读取关系(低层槽一, 令牌);
            const auto 槽二记录 = 关系.读取关系(低层槽二, 令牌);
            验收[3] = 句柄有效(低层槽一) && 句柄有效(低层槽二)
                && 槽一记录.has_value() && 槽二记录.has_value()
                && 槽一记录->类型 == 关系类型::方法动作场景
                && 槽二记录->类型 == 关系类型::方法动作场景
                && 槽一记录->源节点 == 低层方法甲
                && 槽二记录->源节点 == 低层方法甲
                && 槽一记录->目标节点 == 场景甲
                && 槽二记录->目标节点 == 场景甲
                && 槽一记录->顺序号 == 1 && 槽二记录->顺序号 == 2;

            const auto 重复前 = 关系.有效关系数量(令牌);
            const auto 同目标重复 = 关系.创建关系(
                关系类型::方法动作场景, 低层方法甲, 场景甲, 1, 令牌);
            const auto 异目标重复 = 关系.创建关系(
                关系类型::方法动作场景, 低层方法甲, 场景乙, 1, 令牌);
            重复角色拒绝 = !句柄有效(同目标重复) && !句柄有效(异目标重复)
                && 关系.有效关系数量(令牌) == 重复前;
            验收[4] = 重复角色拒绝;

            其它动作槽一 = 关系.创建关系(
                关系类型::方法动作场景, 低层方法乙, 场景甲, 1, 令牌);
            验收[5] = 句柄有效(其它动作槽一)
                && 关系.读取关系(其它动作槽一, 令牌).has_value();

            const auto 普通甲 = 关系.创建关系(
                关系类型::引用, 低层方法乙, 场景乙, 100, 令牌);
            const auto 普通重复 = 关系.创建关系(
                关系类型::引用, 低层方法乙, 场景乙, 101, 令牌);
            const auto 普通乙 = 关系.创建关系(
                关系类型::引用, 低层方法乙, 场景丙, 101, 令牌);
            普通引用回归 = 句柄有效(普通甲) && !句柄有效(普通重复)
                && 句柄有效(普通乙)
                && static_cast<std::uint32_t>(关系类型::任务生命周期证据) == 15
                && static_cast<std::uint32_t>(关系类型::任务方法选择) == 16;
            验收[6] = 普通引用回归;

            const auto 重挂前记录 = 关系.读取关系(低层槽一, 令牌);
            const bool 普通重挂拒绝 = !关系.重挂关系(
                低层槽一, 低层方法甲, 场景乙, 令牌);
            const auto 结构化重挂 = 关系.结构化重挂已发布关系(
                低层槽一, 低层方法甲, 场景乙, 令牌);
            const auto 重挂后记录 = 关系.读取关系(低层槽一, 令牌);

            const auto 待失效 = 关系.创建关系(
                关系类型::方法动作场景, 审计方法, 场景乙, 1, 令牌);
            const auto 待删除 = 关系.创建关系(
                关系类型::方法动作场景, 审计方法, 场景丙, 2, 令牌);
            const auto 失效 = 关系.失效关系(待失效, 令牌);
            const auto 删除 = 关系.严格删除关系(待删除, 令牌);
            const auto 失效审计 = 关系.读取关系审计(失效.当前关系, 令牌);
            const auto 删除审计 = 关系.读取关系审计(待删除, 令牌);
            重挂与审计回归 = 普通重挂拒绝
                && 结构化重挂.操作.状态 == 结构写入状态::入口拒绝
                && 关系记录相同(重挂前记录, 重挂后记录)
                && 失效.完整() && 失效审计.has_value()
                && 失效审计->状态 == 记录状态::已失效
                && 删除.状态 == 结构写入状态::已提交
                && !删除审计.has_value();
        }

        const 创建方法动作入口请求 新动作请求{
            新主键(), 新主键(), 新主键(),
            新动作方法结果.登记项.身份.节点, 场景甲, 场景甲, 1};
        const auto 新动作首次 = 方法服务.创建动作入口(新动作请求);
        const auto 新动作节点 = 新动作首次.规格.身份.节点;
        const auto 新动作读回组 = 方法服务.读取规格组(
            新动作方法结果.登记项.身份.节点, 分层方法角色::动作入口);
        const auto 新动作关系组 = 关系.获取关系记录组(
            新动作节点, 关系类型::方法动作场景);
        const auto 新动作旧引用组 = 关系.获取关系记录组(
            新动作节点, 关系类型::引用);
        验收[7] = 新动作首次.状态 == 需求任务方法业务状态::已提交
            && 新动作首次.规格.完整动作入口()
            && 新动作首次.规格.输入场景 == std::optional<节点句柄>{场景甲}
            && 新动作首次.规格.输出场景 == std::optional<节点句柄>{场景甲}
            && 新动作首次.规格.输入场景关系.has_value()
            && 新动作首次.规格.输出场景关系.has_value()
            && 关系证据匹配(*新动作首次.规格.输入场景关系,
                关系类型::方法动作场景, 新动作节点, 场景甲, 1)
            && 关系证据匹配(*新动作首次.规格.输出场景关系,
                关系类型::方法动作场景, 新动作节点, 场景甲, 2)
            && 新动作读回组.size() == 1 && 新动作读回组.front().完整动作入口()
            && 新动作关系组.size() == 2 && 新动作旧引用组.empty();

        const 创建方法动作入口请求 部分请求{
            新主键(), 新主键(), 新主键(),
            部分方法结果.登记项.身份.节点, 场景甲, 场景乙, 2};
        const auto 部分动作 = 方法服务.创建动作入口(部分请求);
        bool 部分删除成功 = false;
        if (部分动作.规格.输出场景关系.has_value()) {
            auto 许可 = 接线.取得独占许可(接线.运行期状态);
            部分删除成功 = 关系.严格删除关系(
                部分动作.规格.输出场景关系->关系, 许可.读取令牌()).状态
                == 结构写入状态::已提交;
        }
        const auto 部分读回 = 方法服务.读取规格组(
            部分方法结果.登记项.身份.节点, 分层方法角色::动作入口);

        const 创建方法动作入口请求 混存请求{
            新主键(), 新主键(), 新主键(),
            混存方法结果.登记项.身份.节点, 场景甲, 场景乙, 3};
        const auto 混存动作 = 方法服务.创建动作入口(混存请求);
        bool 混存已形成 = false;
        bool 重复未知拒绝 = false;
        {
            auto 许可 = 接线.取得独占许可(接线.运行期状态);
            const auto& 令牌 = 许可.读取令牌();
            const auto 混存前 = 关系.有效关系数量(令牌);
            const auto 旧输入 = 关系.创建关系(
                关系类型::引用, 混存动作.规格.身份.节点, 场景甲, 1, 令牌);
            const auto 重复槽 = 关系.创建关系(
                关系类型::方法动作场景,
                混存动作.规格.身份.节点, 场景丙, 1, 令牌);
            const auto 未知槽 = 关系.创建关系(
                关系类型::方法动作场景,
                混存动作.规格.身份.节点, 场景丙, 3, 令牌);
            混存已形成 = 句柄有效(旧输入);
            重复未知拒绝 = !句柄有效(重复槽) && !句柄有效(未知槽)
                && 关系.有效关系数量(令牌) == 混存前 + 1;
        }
        const auto 混存读回 = 方法服务.读取规格组(
            混存方法结果.登记项.身份.节点, 分层方法角色::动作入口);
        验收[8] = 部分动作.成功() && 部分删除成功 && 部分读回.empty()
            && 混存动作.成功() && 混存已形成 && 重复未知拒绝
            && 混存读回.empty() && 槽位拒绝 && 重复角色拒绝;

        const 创建方法动作入口请求 旧动作请求{
            新主键(), 新主键(), 新主键(),
            旧动作方法结果.登记项.身份.节点, 场景甲, 场景乙, 4};
        const auto 旧动作首次 = 方法服务.创建动作入口(旧动作请求);
        bool 旧结构替换成功 = false;
        if (旧动作首次.规格.输入场景关系.has_value()
            && 旧动作首次.规格.输出场景关系.has_value()) {
            auto 许可 = 接线.取得独占许可(接线.运行期状态);
            const auto& 令牌 = 许可.读取令牌();
            const auto 删除输入 = 关系.严格删除关系(
                旧动作首次.规格.输入场景关系->关系, 令牌);
            const auto 删除输出 = 关系.严格删除关系(
                旧动作首次.规格.输出场景关系->关系, 令牌);
            const auto 旧输入 = 关系.创建关系(
                关系类型::引用, 旧动作首次.规格.身份.节点, 场景甲, 1, 令牌);
            const auto 旧输出 = 关系.创建关系(
                关系类型::引用, 旧动作首次.规格.身份.节点, 场景乙, 2, 令牌);
            旧结构替换成功 = 删除输入.状态 == 结构写入状态::已提交
                && 删除输出.状态 == 结构写入状态::已提交
                && 句柄有效(旧输入) && 句柄有效(旧输出);
        }
        const auto 旧结构读前数量 = 读取数量();
        const auto 旧动作读回组 = 方法服务.读取规格组(
            旧动作方法结果.登记项.身份.节点, 分层方法角色::动作入口);
        const auto 旧动作重复 = 方法服务.创建动作入口(旧动作请求);
        const auto 旧结构读后数量 = 读取数量();
        const auto 旧动作关系组 = 关系.获取关系记录组(
            旧动作首次.规格.身份.节点, 关系类型::方法动作场景);
        const auto 旧动作引用组 = 关系.获取关系记录组(
            旧动作首次.规格.身份.节点, 关系类型::引用);
        验收[9] = 旧结构替换成功 && 旧动作读回组.size() == 1
            && 旧动作读回组.front().完整动作入口()
            && 旧动作读回组.front().输入场景关系->类型 == 关系类型::引用
            && 旧动作读回组.front().输出场景关系->类型 == 关系类型::引用
            && 旧动作重复.状态 == 需求任务方法业务状态::幂等读回
            && 旧动作关系组.empty() && 旧动作引用组.size() == 2
            && 旧结构读后数量 == 旧结构读前数量;

        const auto 精确重复前 = 读取数量();
        const auto 新动作重复 = 方法服务.创建动作入口(新动作请求);
        auto 异义请求 = 新动作请求;
        异义请求.输出场景 = 场景乙;
        const auto 新动作冲突 = 方法服务.创建动作入口(异义请求);
        验收[10] = 新动作重复.状态 == 需求任务方法业务状态::幂等读回
            && 新动作冲突.状态 == 需求任务方法业务状态::幂等冲突
            && 读取数量() == 精确重复前;

        验收[11] = 重挂与审计回归;

        const 创建方法动作入口请求 故障探针请求{
            新主键(), 新主键(), 新主键(),
            故障方法结果.登记项.身份.节点, 场景甲, 场景乙, 5};
        const auto 故障探针 = 方法服务.执行动作入口固定故障自检(故障探针请求, 0);
        const 创建方法动作入口请求 故障请求{
            新主键(), 新主键(), 新主键(),
            故障方法结果.登记项.身份.节点, 场景乙, 场景丙, 6};
        const auto 故障前数量 = 读取数量();
        const auto 故障前动作数量 = 方法服务.读取规格组(
            故障方法结果.登记项.身份.节点,
            分层方法角色::动作入口).size();
        bool 两写点全部回前态 = 故障探针.状态 == 需求任务方法业务状态::已提交
            && 故障探针.已执行写点 == 2 && !故障探针.故障已命中;
        for (std::size_t 写点 = 1; 写点 <= 2; ++写点) {
            const auto 故障结果 = 方法服务.执行动作入口固定故障自检(故障请求, 写点);
            const auto 角色状态 = 状态服务.读取主键状态材料(故障请求.角色状态幂等主键);
            const auto 入口状态 = 状态服务.读取主键状态材料(故障请求.入口状态幂等主键);
            const auto 当前动作组 = 方法服务.读取规格组(
                故障方法结果.登记项.身份.节点, 分层方法角色::动作入口);
            两写点全部回前态 = 两写点全部回前态
                && 故障结果.故障已命中 && 故障结果.已执行写点 == 写点
                && !角色状态.当前可读() && !入口状态.当前可读()
                && 当前动作组.size() == 故障前动作数量
                && 读取数量() == 故障前数量;
        }
        const auto 故障后正常提交 = 方法服务.创建动作入口(故障请求);
        验收[12] = 两写点全部回前态 && 故障后正常提交.成功();

        const 创建方法动作入口请求 并发请求{
            新主键(), 新主键(), 新主键(),
            并发方法结果.登记项.身份.节点, 场景甲, 场景甲, 1};
        constexpr std::size_t 并发数量 = 50;
        std::array<需求任务方法业务状态, 并发数量> 并发状态{};
        std::vector<std::thread> 并发线程组;
        并发线程组.reserve(并发数量);
        for (std::size_t 索引号 = 0; 索引号 < 并发数量; ++索引号) {
            并发线程组.emplace_back([&, 索引号] {
                并发状态[索引号] = 方法服务.创建动作入口(并发请求).状态;
            });
        }
        for (auto& 线程 : 并发线程组) 线程.join();
        const auto 并发提交数量 = std::count(
            并发状态.begin(), 并发状态.end(), 需求任务方法业务状态::已提交);
        const auto 并发幂等数量 = std::count(
            并发状态.begin(), 并发状态.end(), 需求任务方法业务状态::幂等读回);
        const auto 并发动作组 = 方法服务.读取规格组(
            并发方法结果.登记项.身份.节点, 分层方法角色::动作入口);
        验收[13] = 并发提交数量 == 1
            && 并发幂等数量 == static_cast<std::ptrdiff_t>(并发数量 - 1)
            && 并发动作组.size() == 1 && 并发动作组.front().完整动作入口();

        const bool 正式服务公开面回归 = std::is_same_v<
                decltype(std::declval<const 存在业务服务&>().创建实际存在(
                    创建实际存在请求{})),
                存在场景业务结果>
            && std::is_same_v<
                decltype(std::declval<const 场景业务服务&>().创建场景(
                    创建场景请求{})),
                存在场景业务结果>
            && std::is_same_v<
                decltype(std::declval<const 状态业务服务&>().创建抽象状态(
                    创建抽象状态请求{})),
                状态动态业务结果>
            && std::is_same_v<
                decltype(std::declval<const 方法业务服务&>().创建动作入口(
                    创建方法动作入口请求{})),
                方法提交结果>;
        验收[14] = 正式服务公开面回归 && 需求任务方法回归通过
            && 运行期组合回归通过 && 服务兼容边界回归通过
            && 普通引用回归 && 重挂与审计回归;
        验收[15] = std::all_of(
            验收.begin(), 验收.begin() + 15, [](bool 通过) { return 通过; });
    } catch (...) {
    }

    static constexpr std::array<const char*, 16> 名称组{
        "A01 关系17与未知18数值边界",
        "A02 角色槽1和2准入",
        "A03 方法源与场景目标端点",
        "A04 同场景双角色完整读回",
        "A05 同角色第二关系拒绝",
        "A06 不同动作复用场景角色",
        "A07 普通引用与关系15和16回归",
        "A08 新动作只写关系17",
        "A09 部分混存重复未知结构拒绝",
        "A10 旧引用严格只读兼容",
        "A11 精确幂等与异义冲突",
        "A12 重挂拒绝与失效删除审计",
        "A13 两个新增写点故障回前态",
        "A14 五十组并发单提交",
        "A15 单一所有权与正式公开面回归",
        "A16 独立自检与阶段前置"};
    std::size_t 失败数量 = 0;
    for (std::size_t 索引号 = 0; 索引号 < 验收.size(); ++索引号) {
        if (!验收[索引号]) ++失败数量;
        std::cout << "METHOD-ACTION-REL-S1 " << 名称组[索引号]
            << ": " << (验收[索引号] ? "通过" : "失败") << '\n';
    }
    return {"METHOD-ACTION-REL-S1", "方法动作场景关系",
        失败数量 == 0, 验收.size(), 失败数量};
}

}
#endif
