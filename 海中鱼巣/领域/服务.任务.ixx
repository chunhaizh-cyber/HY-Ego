// 文件规则：任务业务服务只裁决承接、生命周期、选择和完成语义，不接触仓库或事务能力。
module;

#include "../核心/句柄.h"

#include <cstddef>
#include <cstdint>
#include <optional>
#include <utility>
#include <vector>

export module 海中鱼巣.领域.服务.任务;

import 海中鱼巣.领域.数据操作.需求任务方法;
import 海中鱼巣.领域.数据操作.存在场景;
import 海中鱼巣.领域.数据操作.状态动态;
import 海中鱼巣.领域.服务.需求;
import 海中鱼巣.领域.服务.存在;
import 海中鱼巣.领域.服务.状态;

export namespace 海中鱼巣 {

struct 创建任务承接请求 {
    std::uint64_t 任务幂等主键 = 0;
    std::uint64_t 虚拟存在幂等主键 = 0;
    std::uint64_t 初始状态幂等主键 = 0;
    节点句柄 来源需求;
    std::uint64_t 发生时间戳 = 0;
};

struct 迁移任务生命周期请求 {
    节点句柄 任务;
    分层任务生命周期阶段 目标阶段 = 分层任务生命周期阶段::未定义;
    std::uint64_t 幂等材料编号 = 0;
    std::uint64_t 发生时间戳 = 0;
};

struct 提交任务方法选择请求 {
    std::uint64_t 记录幂等主键 = 0;
    节点句柄 任务;
    节点句柄 方法;
    std::uint64_t 幂等材料编号 = 0;
    关系句柄 来源生命周期关系;
    std::uint32_t 来源生命周期版本 = 0;
    关系句柄 来源方法生命周期关系;
    std::uint32_t 来源方法生命周期版本 = 0;
    std::uint32_t 排序规则版本 = 0;
    std::uint32_t 召回请求规则版本 = 0;
    std::uint64_t 来源候选数量 = 0;
};

struct 完成任务请求 {
    节点句柄 任务;
    节点句柄 实际状态;
    std::uint64_t 完成状态幂等主键 = 0;
    std::uint64_t 发生时间戳 = 0;
};

class 任务业务服务 final {
public:
    任务业务服务(
        需求任务方法数据操作& 数据操作,
        需求业务服务& 需求服务,
        存在业务服务& 存在服务,
        状态业务服务& 状态服务)
        : 数据操作_(数据操作), 需求服务_(需求服务), 存在服务_(存在服务),
          状态服务_(状态服务) {
    }

    任务提交结果 创建承接任务(const 创建任务承接请求& 请求) const {
        if (请求.任务幂等主键 == 0 || 请求.虚拟存在幂等主键 == 0
            || 请求.初始状态幂等主键 == 0 || !句柄有效(请求.来源需求)
            || 请求.发生时间戳 == 0) return {};
        const auto 需求 = 需求服务_.读取需求(请求.来源需求);
        if (!需求.完整目标状态需求()) return {};
        const 候选来源虚拟存在规格请求 虚拟存在请求{
            请求.虚拟存在幂等主键, 节点类型::任务};
        虚拟存在规格结果 虚拟规格 =
            存在服务_.形成本会话候选来源虚拟存在写入规格(虚拟存在请求);
        const 创建候选主体实例状态请求 初始状态请求{
            请求.初始状态幂等主键, 需求.场景, 请求.发生时间戳,
            static_cast<std::int64_t>(分层任务生命周期阶段::已创建)};
        候选主体实例状态规格结果 状态规格 =
            状态服务_.形成候选主体实例状态写入规格(初始状态请求);
        if (!虚拟规格.成功() || !状态规格.成功()) {
            return {合并规格失败(虚拟规格.状态, 状态规格.状态)};
        }
        const auto 写入规格 = 数据操作_.形成任务承接写入规格(
            请求.任务幂等主键, 请求.来源需求,
            std::move(*虚拟规格.规格), std::move(*状态规格.规格));
        return 写入规格.has_value()
            ? 数据操作_.创建任务承接(*写入规格)
            : 任务提交结果{需求任务方法业务状态::内部不一致};
    }

    任务提交结果 迁移生命周期(const 迁移任务生命周期请求& 请求) const {
        if (!句柄有效(请求.任务) || 请求.幂等材料编号 == 0
            || 请求.发生时间戳 == 0
            || 请求.目标阶段 < 分层任务生命周期阶段::已承接
            || 请求.目标阶段 > 分层任务生命周期阶段::取消) return {};
        const auto 当前 = 数据操作_.读取任务(请求.任务);
        if (!当前.完整承接()) return {};
        if (当前.当前生命周期.阶段 == 请求.目标阶段) {
            const auto 当前状态 = 状态服务_.读取状态材料(当前.当前生命周期.状态);
            return 当前状态.完整实例状态()
                && 当前状态.幂等主键 == 请求.幂等材料编号
                && 当前状态.发生时间戳 == 请求.发生时间戳
                ? 任务提交结果{需求任务方法业务状态::幂等读回, 当前}
                : 任务提交结果{需求任务方法业务状态::幂等冲突};
        }
        const 创建实例状态请求 生命周期状态请求{
            请求.幂等材料编号, 当前.场景, 当前.虚拟存在,
            请求.发生时间戳, static_cast<std::int64_t>(请求.目标阶段)};
        实例状态规格结果 状态规格 =
            状态服务_.形成实例状态写入规格(生命周期状态请求);
        if (!状态规格.成功()) return {映射状态规格失败(状态规格.状态)};
        const auto 写入规格 = 数据操作_.形成任务生命周期写入规格(
            请求.任务, 当前.当前生命周期.关系.关系,
            当前.当前生命周期.版本, 请求.目标阶段, 请求.幂等材料编号,
            std::move(*状态规格.规格));
        return 写入规格.has_value()
            ? 数据操作_.迁移任务生命周期(*写入规格)
            : 任务提交结果{需求任务方法业务状态::内部不一致};
    }

    任务提交结果 提交方法选择(const 提交任务方法选择请求& 请求) const {
        if (请求.记录幂等主键 == 0 || !句柄有效(请求.任务)
            || !句柄有效(请求.方法) || 请求.幂等材料编号 == 0
            || !句柄有效(请求.来源生命周期关系)
            || 请求.来源生命周期版本 == 0
            || !句柄有效(请求.来源方法生命周期关系)
            || 请求.来源方法生命周期版本 == 0
            || 请求.排序规则版本 == 0 || 请求.召回请求规则版本 == 0
            || 请求.来源候选数量 == 0) return {};
        const auto 写入规格 = 数据操作_.形成任务方法选择写入规格(
            请求.记录幂等主键, 请求.任务, 请求.方法, 请求.幂等材料编号,
            请求.来源生命周期关系, 请求.来源生命周期版本,
            请求.来源方法生命周期关系, 请求.来源方法生命周期版本,
            请求.排序规则版本, 请求.召回请求规则版本, 请求.来源候选数量);
        return 写入规格.has_value()
            ? 数据操作_.提交任务方法选择(*写入规格)
            : 任务提交结果{需求任务方法业务状态::内部不一致};
    }

    任务提交结果 提交实际结果并完成(const 完成任务请求& 请求) const {
        if (!句柄有效(请求.任务) || !句柄有效(请求.实际状态)
            || 请求.完成状态幂等主键 == 0 || 请求.发生时间戳 == 0) return {};
        const auto 当前 = 数据操作_.读取任务(请求.任务);
        const auto 实际状态 = 状态服务_.读取状态材料(请求.实际状态);
        if (!当前.完整承接() || !实际状态.完整实例状态()
            || 实际状态.场景 != 当前.场景 || 实际状态.主体 != 当前.虚拟存在) return {};
        if (当前.当前生命周期.阶段 == 分层任务生命周期阶段::已完成) {
            const auto 完成状态 = 状态服务_.读取状态材料(当前.当前生命周期.状态);
            return 当前.实际结果状态 == std::optional<节点句柄>{请求.实际状态}
                && 完成状态.完整实例状态()
                && 完成状态.幂等主键 == 请求.完成状态幂等主键
                && 完成状态.发生时间戳 == 请求.发生时间戳
                ? 任务提交结果{需求任务方法业务状态::幂等读回, 当前}
                : 任务提交结果{需求任务方法业务状态::幂等冲突};
        }
        const 创建实例状态请求 完成状态请求{
            请求.完成状态幂等主键, 当前.场景, 当前.虚拟存在,
            请求.发生时间戳,
            static_cast<std::int64_t>(分层任务生命周期阶段::已完成)};
        实例状态规格结果 完成规格 =
            状态服务_.形成实例状态写入规格(完成状态请求);
        if (!完成规格.成功()) return {映射状态规格失败(完成规格.状态)};
        const auto 写入规格 = 数据操作_.形成任务完成写入规格(
            请求.任务, 请求.实际状态, 当前.当前生命周期.关系.关系,
            当前.当前生命周期.版本, std::move(*完成规格.规格));
        return 写入规格.has_value()
            ? 数据操作_.提交任务实际结果并完成(*写入规格)
            : 任务提交结果{需求任务方法业务状态::内部不一致};
    }

    任务权威材料 读取任务(节点句柄 任务) const {
        return 句柄有效(任务) ? 数据操作_.读取任务(任务) : 任务权威材料{};
    }

    任务权威材料 读取主键任务(std::uint64_t 主键) const {
        return 主键 != 0 ? 数据操作_.读取主键任务(主键) : 任务权威材料{};
    }

    std::vector<任务生命周期材料> 读取生命周期历史(节点句柄 任务) const {
        return 句柄有效(任务)
            ? 数据操作_.读取任务生命周期历史(任务)
            : std::vector<任务生命周期材料>{};
    }

    std::optional<方法动作桥请求材料> 读取动作桥请求(节点句柄 任务) const {
        return 句柄有效(任务)
            ? 数据操作_.读取任务动作桥请求(任务)
            : std::optional<方法动作桥请求材料>{};
    }

#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
    需求任务方法故障自检结果 执行生命周期固定故障自检(
        const 迁移任务生命周期请求& 请求,
        std::size_t 故障写点) const {
        if (!句柄有效(请求.任务) || 请求.幂等材料编号 == 0
            || 请求.发生时间戳 == 0
            || 请求.目标阶段 < 分层任务生命周期阶段::已承接
            || 请求.目标阶段 > 分层任务生命周期阶段::取消) return {};
        const auto 当前 = 数据操作_.读取任务(请求.任务);
        if (!当前.完整承接() || 当前.当前生命周期.阶段 == 请求.目标阶段) return {};
        const 创建实例状态请求 生命周期状态请求{
            请求.幂等材料编号, 当前.场景, 当前.虚拟存在,
            请求.发生时间戳, static_cast<std::int64_t>(请求.目标阶段)};
        实例状态规格结果 状态规格 =
            状态服务_.形成实例状态写入规格(生命周期状态请求);
        if (!状态规格.成功()) {
            return {映射状态规格失败(状态规格.状态), 0, false};
        }
        const auto 写入规格 = 数据操作_.形成任务生命周期写入规格(
            请求.任务, 当前.当前生命周期.关系.关系,
            当前.当前生命周期.版本, 请求.目标阶段,
            请求.幂等材料编号, std::move(*状态规格.规格));
        if (!写入规格.has_value()) {
            return {需求任务方法业务状态::内部不一致, 0, false};
        }
        return 数据操作_.执行任务生命周期固定故障自检(
            *写入规格,
            故障写点);
    }
#endif

private:
    static 需求任务方法业务状态 合并规格失败(
        虚拟存在规格状态 存在状态,
        状态写入规格状态 状态状态) noexcept {
        if (存在状态 == 虚拟存在规格状态::内部不一致
            || 状态状态 == 状态写入规格状态::内部不一致) {
            return 需求任务方法业务状态::内部不一致;
        }
        if (存在状态 == 虚拟存在规格状态::许可拒绝
            || 状态状态 == 状态写入规格状态::许可拒绝) {
            return 需求任务方法业务状态::许可拒绝;
        }
        if (存在状态 == 虚拟存在规格状态::版本漂移
            || 状态状态 == 状态写入规格状态::版本漂移) {
            return 需求任务方法业务状态::版本漂移;
        }
        return 需求任务方法业务状态::入口拒绝;
    }

    static 需求任务方法业务状态 映射状态规格失败(状态写入规格状态 状态) noexcept {
        switch (状态) {
        case 状态写入规格状态::许可拒绝:
            return 需求任务方法业务状态::许可拒绝;
        case 状态写入规格状态::版本漂移:
            return 需求任务方法业务状态::版本漂移;
        case 状态写入规格状态::内部不一致:
            return 需求任务方法业务状态::内部不一致;
        default:
            return 需求任务方法业务状态::入口拒绝;
        }
    }

    需求任务方法数据操作& 数据操作_;
    需求业务服务& 需求服务_;
    存在业务服务& 存在服务_;
    状态业务服务& 状态服务_;
};

}
