// 文件规则：特征业务服务只裁决定义、槽位和批次值式规格，不接触仓库或事务能力。
module;

#include "../核心/句柄.h"
#include "特征值服务.h"

#include <cstddef>
#include <cstdint>
#include <optional>
#include <utility>
#include <vector>

export module 海中鱼巣.领域.服务.特征;

import 海中鱼巣.领域.数据操作.特征体系;

export namespace 海中鱼巣 {

struct 创建特征定义请求 {
    std::uint64_t 幂等主键 = 0;
};

struct 创建实例特征槽位请求 {
    std::uint64_t 幂等主键 = 0;
    节点句柄 宿主;
    节点句柄 特征定义;
};

struct 初始特征原始值请求 {
    特征值原始类型 原始类型 = 特征值原始类型::未建立;
    std::optional<std::int64_t> I64值;
    std::vector<std::int64_t> VecI64值;
    std::vector<std::uint64_t> VecU64值;
};

struct 发布初始特征状态请求 {
    std::uint64_t 特征值幂等主键 = 0;
    节点句柄 实例槽位;
    初始特征原始值请求 原始值;
};

struct 特征批次来源请求 {
    节点句柄 来源;
    std::uint64_t 版本 = 0;
};

struct 特征批次初始项请求 {
    std::uint32_t 顺序号 = 0;
    std::uint64_t 槽位幂等主键 = 0;
    std::uint64_t 特征值幂等主键 = 0;
    节点句柄 特征定义;
    初始特征原始值请求 原始值;
    特征批次来源请求 来源;
};

struct 特征批次换代项请求 {
    std::uint32_t 顺序号 = 0;
    节点句柄 实例槽位;
    特征关系证据 预期当前关系;
    节点句柄 预期当前值;
    std::uint64_t 预期原始值版本 = 0;
    std::uint64_t 新值幂等主键 = 0;
    初始特征原始值请求 新原始值;
    特征批次来源请求 来源;
};

struct 形成特征批次变更请求 {
    std::uint64_t 批次幂等身份 = 0;
    std::uint64_t 规则版本 = 0;
    std::uint64_t 完整载荷摘要 = 0;
    节点句柄 候选宿主;
    std::vector<特征批次初始项请求> 初始项组;
    std::vector<特征批次换代项请求> 换代项组;
};

enum class 特征规格状态 : std::uint8_t {
    已形成 = 1,
    入口拒绝 = 2,
    许可拒绝 = 3,
    版本漂移 = 4,
    内部不一致 = 5
};

struct 特征槽位规格结果 {
    特征规格状态 状态 = 特征规格状态::入口拒绝;
    std::optional<特征槽位写入规格> 规格;

    bool 成功() const noexcept {
        return 状态 == 特征规格状态::已形成 && 规格.has_value() && 规格->完整();
    }
};

struct 初始特征值规格结果 {
    特征规格状态 状态 = 特征规格状态::入口拒绝;
    std::optional<初始特征值写入规格> 规格;

    bool 成功() const noexcept {
        return 状态 == 特征规格状态::已形成 && 规格.has_value() && 规格->完整();
    }
};

struct 特征批次规格结果 {
    特征规格状态 状态 = 特征规格状态::入口拒绝;
    std::optional<特征批次变更规格> 规格;

    bool 成功() const noexcept {
        return 状态 == 特征规格状态::已形成 && 规格.has_value() && 规格->完整();
    }
};

class 特征业务服务 final {
public:
    explicit 特征业务服务(特征体系数据操作& 数据操作) : 数据操作_(数据操作) {}

    特征体系业务结果 创建特征定义(const 创建特征定义请求& 请求) const {
        if (请求.幂等主键 == 0) return {};
        return 数据操作_.创建特征定义(请求.幂等主键);
    }

    特征槽位规格结果 形成实例特征槽位规格(
        const 创建实例特征槽位请求& 请求) const {
        if (请求.幂等主键 == 0 || !句柄有效(请求.宿主)
            || !句柄有效(请求.特征定义) || 请求.宿主 == 请求.特征定义) return {};
        const auto 宿主 = 数据操作_.读取节点身份(请求.宿主);
        const auto 定义 = 数据操作_.读取特征定义(请求.特征定义);
        if (!宿主.当前可读() || !定义.完整()) {
            return {合并读取失败(宿主.状态, 定义.状态)};
        }
        if (!允许特征宿主(宿主.类型)) return {};
        const auto 规格 = 数据操作_.形成特征槽位写入规格(
            请求.幂等主键, 请求.宿主, 请求.特征定义);
        if (!规格.has_value()) return {特征规格状态::内部不一致};
        特征槽位规格结果 输出;
        输出.状态 = 特征规格状态::已形成;
        输出.规格 = *规格;
        return 输出;
    }

    初始特征值规格结果 形成初始特征值规格(
        std::uint64_t 特征值幂等主键,
        const 初始特征原始值请求& 请求) const {
        if (特征值幂等主键 == 0 || !原始值字段自洽(请求)) return {};
        const auto 规格 = 数据操作_.形成初始特征值写入规格(
            特征值幂等主键, 请求.原始类型, 请求.I64值,
            请求.VecI64值, 请求.VecU64值);
        if (!规格.has_value()) return {特征规格状态::内部不一致};
        初始特征值规格结果 输出;
        输出.状态 = 特征规格状态::已形成;
        输出.规格 = *规格;
        return 输出;
    }

    特征体系业务结果 创建实例特征槽位(
        const 创建实例特征槽位请求& 请求) const {
        const auto 规格 = 形成实例特征槽位规格(请求);
        if (!规格.成功()) return 映射规格失败(规格.状态);
        return 数据操作_.创建实例特征槽位(*规格.规格);
    }

    特征体系业务结果 发布初始特征状态(
        const 发布初始特征状态请求& 请求) const {
        if (!句柄有效(请求.实例槽位)) return {};
        const auto 规格 = 形成初始特征值规格(请求.特征值幂等主键, 请求.原始值);
        if (!规格.成功()) return 映射规格失败(规格.状态);
        return 数据操作_.发布初始特征状态(请求.实例槽位, *规格.规格);
    }

    特征批次规格结果 形成特征批次变更规格(
        const 形成特征批次变更请求& 请求) const {
        const auto 项目数量 = 请求.初始项组.size() + 请求.换代项组.size();
        if (请求.批次幂等身份 == 0 || 请求.规则版本 == 0
            || 请求.完整载荷摘要 == 0 || !句柄有效(请求.候选宿主)
            || 项目数量 == 0) return {};

        const auto 宿主 = 数据操作_.读取节点身份(请求.候选宿主);
        if (宿主.当前可读()) {
            if (!允许特征宿主(宿主.类型)) return {};
        } else if (宿主.状态 != 特征体系读取状态::未找到) {
            return {映射读取失败(宿主.状态)};
        }

        std::vector<bool> 已见顺序(项目数量, false);
        std::vector<std::uint64_t> 已见幂等主键;
        std::vector<节点句柄> 已见特征定义;
        std::vector<节点句柄> 已见实例槽位;
        std::vector<特征批次初始项规格> 初始规格组;
        std::vector<特征批次换代项规格> 换代规格组;
        已见幂等主键.reserve(请求.初始项组.size() * 2 + 请求.换代项组.size());
        已见特征定义.reserve(项目数量);
        已见实例槽位.reserve(请求.换代项组.size());
        初始规格组.reserve(请求.初始项组.size());
        换代规格组.reserve(请求.换代项组.size());

        for (const auto& 项目 : 请求.初始项组) {
            if (!登记顺序(项目.顺序号, 已见顺序)
                || 项目.槽位幂等主键 == 0 || 项目.特征值幂等主键 == 0
                || 项目.槽位幂等主键 == 项目.特征值幂等主键
                || !登记幂等主键(项目.槽位幂等主键, 已见幂等主键)
                || !登记幂等主键(项目.特征值幂等主键, 已见幂等主键)
                || !句柄有效(项目.特征定义) || !原始值字段自洽(项目.原始值)
                || !来源自洽(项目.来源)) return {};
            const auto 定义 = 数据操作_.读取特征定义(项目.特征定义);
            if (!定义.完整()) return {映射读取失败(定义.状态)};
            const auto 来源 = 数据操作_.读取节点身份(项目.来源.来源);
            if (!来源可接受(项目.来源, 请求.候选宿主, 来源)) {
                return {映射读取失败(来源.状态)};
            }
            if (!登记节点(项目.特征定义, 已见特征定义)) return {};

            const auto 槽位规格 = 数据操作_.形成特征槽位写入规格(
                项目.槽位幂等主键, 请求.候选宿主, 项目.特征定义);
            const auto 值规格 = 数据操作_.形成初始特征值写入规格(
                项目.特征值幂等主键, 项目.原始值.原始类型, 项目.原始值.I64值,
                项目.原始值.VecI64值, 项目.原始值.VecU64值);
            if (!槽位规格.has_value() || !值规格.has_value()) {
                return {特征规格状态::内部不一致};
            }
            const auto 初始规格 = 数据操作_.形成特征批次初始项规格(
                项目.顺序号, *槽位规格, *值规格,
                {项目.来源.来源, 项目.来源.版本});
            if (!初始规格.has_value()) return {特征规格状态::内部不一致};
            初始规格组.push_back(*初始规格);
        }

        for (const auto& 项目 : 请求.换代项组) {
            if (!登记顺序(项目.顺序号, 已见顺序)
                || !句柄有效(项目.实例槽位) || !项目.预期当前关系.完整()
                || 项目.预期当前关系.类型 != 关系类型::归属
                || 项目.预期当前关系.源节点 != 项目.实例槽位
                || !句柄有效(项目.预期当前值)
                || 项目.预期当前关系.目标节点 != 项目.预期当前值
                || 项目.预期原始值版本 == 0 || 项目.新值幂等主键 == 0
                || !登记幂等主键(项目.新值幂等主键, 已见幂等主键)
                || !原始值字段自洽(项目.新原始值) || !来源自洽(项目.来源)
                || !登记节点(项目.实例槽位, 已见实例槽位)) return {};
            const auto 槽位 = 数据操作_.读取实例特征槽位(项目.实例槽位);
            if (!槽位.完整()) return {映射读取失败(槽位.状态)};
            if (槽位.宿主 != 请求.候选宿主
                || !登记节点(槽位.特征定义, 已见特征定义)) return {};
            const auto 来源 = 数据操作_.读取节点身份(项目.来源.来源);
            if (!来源可接受(项目.来源, 请求.候选宿主, 来源)) {
                return {映射读取失败(来源.状态)};
            }
            const auto 新值规格 = 数据操作_.形成初始特征值写入规格(
                项目.新值幂等主键, 项目.新原始值.原始类型, 项目.新原始值.I64值,
                项目.新原始值.VecI64值, 项目.新原始值.VecU64值);
            if (!新值规格.has_value()) return {特征规格状态::内部不一致};
            const auto 换代规格 = 数据操作_.形成特征批次换代项规格(
                项目.顺序号, 项目.实例槽位, 项目.预期当前关系,
                项目.预期当前值, 项目.预期原始值版本, *新值规格,
                {项目.来源.来源, 项目.来源.版本});
            if (!换代规格.has_value()) return {特征规格状态::内部不一致};
            换代规格组.push_back(*换代规格);
        }

        const auto 规格 = 数据操作_.形成特征批次变更规格(
            请求.批次幂等身份, 请求.规则版本, 请求.完整载荷摘要,
            请求.候选宿主, std::move(初始规格组), std::move(换代规格组));
        if (!规格.has_value()) return {特征规格状态::内部不一致};
        特征批次规格结果 输出;
        输出.状态 = 特征规格状态::已形成;
        输出.规格 = *规格;
        return 输出;
    }

    特征批次结果 提交特征批次变更(const 形成特征批次变更请求& 请求) const {
        const auto 规格 = 形成特征批次变更规格(请求);
        if (!规格.成功()) return {映射规格状态(规格.状态)};
        return 数据操作_.提交特征批次(*规格.规格);
    }

    特征定义值式材料 读取特征定义(节点句柄 特征定义) const {
        if (!句柄有效(特征定义)) return {};
        return 数据操作_.读取特征定义(特征定义);
    }

    特征定义值式材料 读取主键特征定义(std::uint64_t 主键) const {
        if (主键 == 0) return {};
        return 数据操作_.读取主键特征定义(主键);
    }

    特征槽位值式材料 读取实例特征槽位(节点句柄 实例槽位) const {
        if (!句柄有效(实例槽位)) return {};
        return 数据操作_.读取实例特征槽位(实例槽位);
    }

    特征槽位值式材料 读取宿主定义槽位(
        节点句柄 宿主,
        节点句柄 特征定义) const {
        if (!句柄有效(宿主) || !句柄有效(特征定义)) return {};
        return 数据操作_.读取宿主定义槽位(宿主, 特征定义);
    }

    特征原始值式材料 读取实例槽位当前值(节点句柄 实例槽位) const {
        if (!句柄有效(实例槽位)) return {};
        return 数据操作_.读取实例槽位当前值(实例槽位);
    }

    宿主特征状态值式材料 读取宿主特征状态(
        节点句柄 宿主,
        节点句柄 特征定义) const {
        if (!句柄有效(宿主) || !句柄有效(特征定义)) return {};
        return 数据操作_.读取宿主特征状态(宿主, 特征定义);
    }

private:
    static bool 允许特征宿主(节点类型 类型) noexcept {
        return 类型 == 节点类型::存在 || 类型 == 节点类型::场景
            || 类型 == 节点类型::需求 || 类型 == 节点类型::任务
            || 类型 == 节点类型::方法;
    }

    static bool 原始值字段自洽(const 初始特征原始值请求& 请求) noexcept {
        switch (请求.原始类型) {
        case 特征值原始类型::I64:
            return 请求.I64值.has_value() && 请求.VecI64值.empty() && 请求.VecU64值.empty();
        case 特征值原始类型::VecI64:
            return !请求.I64值.has_value() && !请求.VecI64值.empty()
                && 请求.VecI64值.size() <= 特征值服务::最大序列元素数量
                && 请求.VecU64值.empty();
        case 特征值原始类型::VecU64:
            return !请求.I64值.has_value() && 请求.VecI64值.empty()
                && !请求.VecU64值.empty()
                && 请求.VecU64值.size() <= 特征值服务::最大序列元素数量;
        default:
            return false;
        }
    }

    static bool 来源自洽(const 特征批次来源请求& 来源) noexcept {
        return 句柄有效(来源.来源) && 来源.版本 != 0;
    }

    static bool 来源可接受(
        const 特征批次来源请求& 来源请求,
        节点句柄 候选宿主,
        const 特征节点身份& 来源身份) noexcept {
        return 来源身份.当前可读()
            || (来源请求.来源 == 候选宿主
                && 来源身份.状态 == 特征体系读取状态::未找到);
    }

    static bool 登记顺序(std::uint32_t 顺序号, std::vector<bool>& 已见顺序) noexcept {
        if (顺序号 >= 已见顺序.size() || 已见顺序[顺序号]) return false;
        已见顺序[顺序号] = true;
        return true;
    }

    static bool 登记幂等主键(
        std::uint64_t 幂等主键,
        std::vector<std::uint64_t>& 已见幂等主键) {
        for (const auto 已见 : 已见幂等主键) {
            if (已见 == 幂等主键) return false;
        }
        已见幂等主键.push_back(幂等主键);
        return true;
    }

    static bool 登记节点(节点句柄 节点, std::vector<节点句柄>& 已见节点) {
        for (const auto& 已见 : 已见节点) {
            if (已见 == 节点) return false;
        }
        已见节点.push_back(节点);
        return true;
    }

    static 特征规格状态 映射读取失败(特征体系读取状态 状态) noexcept {
        switch (状态) {
        case 特征体系读取状态::许可拒绝:
            return 特征规格状态::许可拒绝;
        case 特征体系读取状态::版本漂移:
            return 特征规格状态::版本漂移;
        case 特征体系读取状态::内部不一致:
            return 特征规格状态::内部不一致;
        default:
            return 特征规格状态::入口拒绝;
        }
    }

    static 特征规格状态 合并读取失败(
        特征体系读取状态 左,
        特征体系读取状态 右) noexcept {
        if (左 == 特征体系读取状态::内部不一致
            || 右 == 特征体系读取状态::内部不一致) return 特征规格状态::内部不一致;
        if (左 == 特征体系读取状态::许可拒绝
            || 右 == 特征体系读取状态::许可拒绝) return 特征规格状态::许可拒绝;
        if (左 == 特征体系读取状态::版本漂移
            || 右 == 特征体系读取状态::版本漂移) return 特征规格状态::版本漂移;
        return 特征规格状态::入口拒绝;
    }

    static 特征体系业务结果 映射规格失败(特征规格状态 状态) noexcept {
        switch (状态) {
        case 特征规格状态::许可拒绝:
            return {特征体系业务状态::许可拒绝};
        case 特征规格状态::版本漂移:
            return {特征体系业务状态::版本漂移};
        case 特征规格状态::内部不一致:
            return {特征体系业务状态::内部不一致};
        default:
            return {特征体系业务状态::入口拒绝};
        }
    }

    static 特征体系业务状态 映射规格状态(特征规格状态 状态) noexcept {
        return 映射规格失败(状态).状态;
    }

    特征体系数据操作& 数据操作_;
};

}
