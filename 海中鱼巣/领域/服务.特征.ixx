// 文件规则：特征业务服务只裁决定义、槽位和初始原始值规格，不接触仓库或事务能力。
module;

#include "../核心/句柄.h"
#include "特征值服务.h"

#include <cstdint>
#include <optional>
#include <utility>
#include <vector>

export module 海中鱼巣.领域.服务.特征;

import 海中鱼巣.领域.数据操作.特征体系;

export namespace 海中鱼巣 {

struct 创建特征定义请求 {
    std::uint64_t 幂等主键 = 0;
};

struct 创建实例特征槽位请求 {
    std::uint64_t 幂等主键 = 0;
    节点句柄 宿主;
    节点句柄 特征定义;
};

struct 初始特征原始值请求 {
    特征值原始类型 原始类型 = 特征值原始类型::未建立;
    std::optional<std::int64_t> I64值;
    std::vector<std::int64_t> VecI64值;
    std::vector<std::uint64_t> VecU64值;
};

struct 发布初始特征状态请求 {
    std::uint64_t 特征值幂等主键 = 0;
    节点句柄 实例槽位;
    初始特征原始值请求 原始值;
};

enum class 特征规格状态 : std::uint8_t {
    已形成 = 1,
    入口拒绝 = 2,
    许可拒绝 = 3,
    版本漂移 = 4,
    内部不一致 = 5
};

struct 特征槽位规格结果 {
    特征规格状态 状态 = 特征规格状态::入口拒绝;
    std::optional<特征槽位写入规格> 规格;

    bool 成功() const noexcept {
        return 状态 == 特征规格状态::已形成 && 规格.has_value() && 规格->完整();
    }
};

struct 初始特征值规格结果 {
    特征规格状态 状态 = 特征规格状态::入口拒绝;
    std::optional<初始特征值写入规格> 规格;

    bool 成功() const noexcept {
        return 状态 == 特征规格状态::已形成 && 规格.has_value() && 规格->完整();
    }
};

class 特征业务服务 final {
public:
    explicit 特征业务服务(特征体系数据操作& 数据操作) : 数据操作_(数据操作) {}

    特征体系业务结果 创建特征定义(const 创建特征定义请求& 请求) const {
        if (请求.幂等主键 == 0) return {};
        return 数据操作_.创建特征定义(请求.幂等主键);
    }

    特征槽位规格结果 形成实例特征槽位规格(
        const 创建实例特征槽位请求& 请求) const {
        if (请求.幂等主键 == 0 || !句柄有效(请求.宿主)
            || !句柄有效(请求.特征定义) || 请求.宿主 == 请求.特征定义) return {};
        const auto 宿主 = 数据操作_.读取节点身份(请求.宿主);
        const auto 定义 = 数据操作_.读取特征定义(请求.特征定义);
        if (!宿主.当前可读() || !定义.完整()) {
            return {合并读取失败(宿主.状态, 定义.状态)};
        }
        if (!允许特征宿主(宿主.类型)) return {};
        特征槽位规格结果 输出;
        输出.状态 = 特征规格状态::已形成;
        输出.规格 = 特征槽位写入规格(请求.幂等主键, 请求.宿主, 请求.特征定义);
        return 输出;
    }

    初始特征值规格结果 形成初始特征值规格(
        std::uint64_t 特征值幂等主键,
        const 初始特征原始值请求& 请求) const {
        if (特征值幂等主键 == 0 || !原始值字段自洽(请求)) return {};
        初始特征值规格结果 输出;
        输出.状态 = 特征规格状态::已形成;
        输出.规格 = 初始特征值写入规格(
            特征值幂等主键, 请求.原始类型, 请求.I64值,
            请求.VecI64值, 请求.VecU64值);
        return 输出;
    }

    特征体系业务结果 创建实例特征槽位(
        const 创建实例特征槽位请求& 请求) const {
        const auto 规格 = 形成实例特征槽位规格(请求);
        if (!规格.成功()) return 映射规格失败(规格.状态);
        return 数据操作_.创建实例特征槽位(*规格.规格);
    }

    特征体系业务结果 发布初始特征状态(
        const 发布初始特征状态请求& 请求) const {
        if (!句柄有效(请求.实例槽位)) return {};
        const auto 规格 = 形成初始特征值规格(请求.特征值幂等主键, 请求.原始值);
        if (!规格.成功()) return 映射规格失败(规格.状态);
        return 数据操作_.发布初始特征状态(请求.实例槽位, *规格.规格);
    }

    特征定义值式材料 读取特征定义(节点句柄 特征定义) const {
        if (!句柄有效(特征定义)) return {};
        return 数据操作_.读取特征定义(特征定义);
    }

    特征定义值式材料 读取主键特征定义(std::uint64_t 主键) const {
        if (主键 == 0) return {};
        return 数据操作_.读取主键特征定义(主键);
    }

    特征槽位值式材料 读取实例特征槽位(节点句柄 实例槽位) const {
        if (!句柄有效(实例槽位)) return {};
        return 数据操作_.读取实例特征槽位(实例槽位);
    }

    特征槽位值式材料 读取宿主定义槽位(
        节点句柄 宿主,
        节点句柄 特征定义) const {
        if (!句柄有效(宿主) || !句柄有效(特征定义)) return {};
        return 数据操作_.读取宿主定义槽位(宿主, 特征定义);
    }

    特征原始值式材料 读取实例槽位当前值(节点句柄 实例槽位) const {
        if (!句柄有效(实例槽位)) return {};
        return 数据操作_.读取实例槽位当前值(实例槽位);
    }

    宿主特征状态值式材料 读取宿主特征状态(
        节点句柄 宿主,
        节点句柄 特征定义) const {
        if (!句柄有效(宿主) || !句柄有效(特征定义)) return {};
        return 数据操作_.读取宿主特征状态(宿主, 特征定义);
    }

private:
    static bool 允许特征宿主(节点类型 类型) noexcept {
        return 类型 == 节点类型::存在 || 类型 == 节点类型::场景
            || 类型 == 节点类型::需求 || 类型 == 节点类型::任务
            || 类型 == 节点类型::方法;
    }

    static bool 原始值字段自洽(const 初始特征原始值请求& 请求) noexcept {
        switch (请求.原始类型) {
        case 特征值原始类型::I64:
            return 请求.I64值.has_value() && 请求.VecI64值.empty() && 请求.VecU64值.empty();
        case 特征值原始类型::VecI64:
            return !请求.I64值.has_value() && !请求.VecI64值.empty()
                && 请求.VecI64值.size() <= 特征值服务::最大序列元素数量
                && 请求.VecU64值.empty();
        case 特征值原始类型::VecU64:
            return !请求.I64值.has_value() && 请求.VecI64值.empty()
                && !请求.VecU64值.empty()
                && 请求.VecU64值.size() <= 特征值服务::最大序列元素数量;
        default:
            return false;
        }
    }

    static 特征规格状态 合并读取失败(
        特征体系读取状态 左,
        特征体系读取状态 右) noexcept {
        if (左 == 特征体系读取状态::内部不一致
            || 右 == 特征体系读取状态::内部不一致) return 特征规格状态::内部不一致;
        if (左 == 特征体系读取状态::许可拒绝
            || 右 == 特征体系读取状态::许可拒绝) return 特征规格状态::许可拒绝;
        if (左 == 特征体系读取状态::版本漂移
            || 右 == 特征体系读取状态::版本漂移) return 特征规格状态::版本漂移;
        return 特征规格状态::入口拒绝;
    }

    static 特征体系业务结果 映射规格失败(特征规格状态 状态) noexcept {
        switch (状态) {
        case 特征规格状态::许可拒绝:
            return {特征体系业务状态::许可拒绝};
        case 特征规格状态::版本漂移:
            return {特征体系业务状态::版本漂移};
        case 特征规格状态::内部不一致:
            return {特征体系业务状态::内部不一致};
        default:
            return {特征体系业务状态::入口拒绝};
        }
    }

    特征体系数据操作& 数据操作_;
};

}
