// 文件规则：场景业务服务只裁决场景身份和接纳语义，不接触仓库或事务能力。
module;

#include "../核心/句柄.h"

#include <cstdint>

export module 海中鱼巣.领域.服务.场景;

import 海中鱼巣.领域.数据操作.存在场景;

export namespace 海中鱼巣 {

struct 创建场景请求 {
    std::uint64_t 幂等主键 = 0;
};

struct 场景接纳存在请求 {
    节点句柄 场景;
    节点句柄 存在;
};

class 场景业务服务 final {
public:
    explicit 场景业务服务(存在场景数据操作& 数据操作) : 数据操作_(数据操作) {
    }

    存在场景业务结果 创建场景(const 创建场景请求& 请求) const {
        if (请求.幂等主键 == 0) return {};
        const auto 当前身份 = 数据操作_.读取主键身份(请求.幂等主键);
        if (当前身份.状态 == 存在场景读取状态::未找到) {
            return 数据操作_.创建场景(请求.幂等主键);
        }
        if (当前身份.状态 != 存在场景读取状态::已找到) {
            return 映射读取失败(当前身份.状态);
        }
        if (当前身份.类型 != 节点类型::场景) {
            return {存在场景业务状态::幂等冲突};
        }
        return {存在场景业务状态::幂等读回, {}, 当前身份.节点};
    }

    存在场景业务结果 接纳已有存在(const 场景接纳存在请求& 请求) const {
        if (!句柄有效(请求.场景) || !句柄有效(请求.存在)) return {};
        const auto 场景材料 = 数据操作_.读取节点身份(请求.场景);
        const auto 存在材料 = 数据操作_.读取节点身份(请求.存在);
        if (场景材料.状态 != 存在场景读取状态::已找到
            || 存在材料.状态 != 存在场景读取状态::已找到) {
            return 映射两个读取失败(场景材料.状态, 存在材料.状态);
        }
        if (场景材料.类型 != 节点类型::场景 || 存在材料.类型 != 节点类型::存在) {
            return {};
        }

        const auto 当前归属 = 数据操作_.读取场景归属(请求.场景, 请求.存在);
        if (当前归属.已归属()) {
            return {存在场景业务状态::幂等读回,
                请求.存在, 请求.场景, *当前归属.归属关系};
        }
        if (当前归属.状态 != 存在场景读取状态::未找到) {
            return 映射读取失败(当前归属.状态);
        }
        return 数据操作_.创建场景归属(请求.场景, 请求.存在);
    }

private:
    static 存在场景业务结果 映射读取失败(存在场景读取状态 状态) noexcept {
        switch (状态) {
        case 存在场景读取状态::许可拒绝:
            return {存在场景业务状态::许可拒绝};
        case 存在场景读取状态::版本漂移:
            return {存在场景业务状态::版本漂移};
        case 存在场景读取状态::内部不一致:
            return {存在场景业务状态::内部不一致};
        default:
            return {存在场景业务状态::入口拒绝};
        }
    }

    static 存在场景业务结果 映射两个读取失败(
        存在场景读取状态 左,
        存在场景读取状态 右) noexcept {
        if (左 == 存在场景读取状态::内部不一致 || 右 == 存在场景读取状态::内部不一致) {
            return {存在场景业务状态::内部不一致};
        }
        if (左 == 存在场景读取状态::许可拒绝 || 右 == 存在场景读取状态::许可拒绝) {
            return {存在场景业务状态::许可拒绝};
        }
        if (左 == 存在场景读取状态::版本漂移 || 右 == 存在场景读取状态::版本漂移) {
            return {存在场景业务状态::版本漂移};
        }
        return {存在场景业务状态::入口拒绝};
    }

    存在场景数据操作& 数据操作_;
};

}
