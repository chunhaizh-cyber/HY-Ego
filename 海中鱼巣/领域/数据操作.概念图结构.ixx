// 文件规则：概念图结构数据操作层封闭四仓库和结构执行器，只承载创建型概念关系。
module;

#include "../核心/结构事务接线.数据.h"
#include "../核心/主信息仓库.h"
#include "../核心/节点仓库.h"
#include "../核心/关系仓库.h"
#include "../核心/索引仓库.h"
#include "../核心/容错检查.h"

#include <algorithm>
#include <array>
#include <cstddef>
#include <cstdint>
#include <functional>
#include <optional>
#include <utility>
#include <vector>

export module 海中鱼巣.领域.数据操作.概念图结构;

import 海中鱼巣.核心.执行器.结构写入;

export namespace 海中鱼巣 {

class 概念图结构业务服务;
class 概念图结构数据操作;

enum class 概念根类别 : std::uint8_t {
    未定义 = 0,
    存在 = 1,
    动态 = 2,
    关系 = 3,
    因果 = 4
};

enum class 概念图结构业务状态 : std::uint8_t {
    已提交 = 1,
    幂等读回 = 2,
    入口拒绝 = 3,
    幂等冲突 = 4,
    许可拒绝 = 5,
    版本漂移 = 6,
    内部不一致 = 7
};

enum class 概念图结构读取状态 : std::uint8_t {
    已找到 = 1,
    未找到 = 2,
    入口拒绝 = 3,
    许可拒绝 = 4,
    版本漂移 = 5,
    类型不匹配 = 6,
    内部不一致 = 7
};

struct 概念根候选 {
    概念根类别 类别 = 概念根类别::未定义;
    std::uint64_t 稳定主键 = 0;
    节点句柄 节点;

    bool 完整() const noexcept {
        return 类别 != 概念根类别::未定义 && 稳定主键 != 0 && 句柄有效(节点);
    }
};

struct 概念根候选组 {
    概念根候选 存在根;
    概念根候选 动态根;
    概念根候选 关系根;
    概念根候选 因果根;

    bool 完整() const noexcept {
        return 存在根.完整() && 存在根.类别 == 概念根类别::存在
            && 动态根.完整() && 动态根.类别 == 概念根类别::动态
            && 关系根.完整() && 关系根.类别 == 概念根类别::关系
            && 因果根.完整() && 因果根.类别 == 概念根类别::因果;
    }

    const 概念根候选* 查找(概念根类别 类别) const noexcept {
        switch (类别) {
        case 概念根类别::存在: return &存在根;
        case 概念根类别::动态: return &动态根;
        case 概念根类别::关系: return &关系根;
        case 概念根类别::因果: return &因果根;
        default: return nullptr;
        }
    }
};

struct 概念根角色 {
    概念根类别 类别 = 概念根类别::未定义;
    std::uint64_t 稳定主键 = 0;
    节点句柄 节点;
    主信息句柄 主信息;

    bool 完整() const noexcept {
        return 类别 != 概念根类别::未定义 && 稳定主键 != 0
            && 句柄有效(节点) && 句柄有效(主信息);
    }
};

struct 概念根角色组 {
    概念根角色 存在根;
    概念根角色 动态根;
    概念根角色 关系根;
    概念根角色 因果根;

    bool 完整() const noexcept {
        return 存在根.完整() && 存在根.类别 == 概念根类别::存在
            && 动态根.完整() && 动态根.类别 == 概念根类别::动态
            && 关系根.完整() && 关系根.类别 == 概念根类别::关系
            && 因果根.完整() && 因果根.类别 == 概念根类别::因果
            && 存在根.节点 != 动态根.节点 && 存在根.节点 != 关系根.节点
            && 存在根.节点 != 因果根.节点 && 动态根.节点 != 关系根.节点
            && 动态根.节点 != 因果根.节点 && 关系根.节点 != 因果根.节点
            && 存在根.稳定主键 != 动态根.稳定主键
            && 存在根.稳定主键 != 关系根.稳定主键
            && 存在根.稳定主键 != 因果根.稳定主键
            && 动态根.稳定主键 != 关系根.稳定主键
            && 动态根.稳定主键 != 因果根.稳定主键
            && 关系根.稳定主键 != 因果根.稳定主键;
    }

    const 概念根角色* 查找(概念根类别 类别) const noexcept {
        switch (类别) {
        case 概念根类别::存在: return &存在根;
        case 概念根类别::动态: return &动态根;
        case 概念根类别::关系: return &关系根;
        case 概念根类别::因果: return &因果根;
        default: return nullptr;
        }
    }
};

struct 概念根角色组值式材料 {
    概念图结构读取状态 状态 = 概念图结构读取状态::入口拒绝;
    概念根角色组 根角色;

    bool 完整() const noexcept {
        return 状态 == 概念图结构读取状态::已找到 && 根角色.完整();
    }
};

struct 概念关系证据 {
    关系句柄 关系;
    关系类型 类型 = 关系类型::普通父子;
    节点句柄 源节点;
    节点句柄 目标节点;
    std::int64_t 顺序号 = 0;
    记录状态 状态 = 记录状态::无效;

    bool 完整() const noexcept {
        return 句柄有效(关系) && 句柄有效(源节点) && 句柄有效(目标节点)
            && 状态 == 记录状态::有效;
    }
};

struct 概念关系组值式材料 {
    概念图结构读取状态 状态 = 概念图结构读取状态::入口拒绝;
    std::vector<概念关系证据> 关系组;

    bool 当前可读() const noexcept {
        if (状态 != 概念图结构读取状态::已找到 || 关系组.empty()) return false;
        for (const auto& 关系 : 关系组) {
            if (!关系.完整()) return false;
        }
        return true;
    }

    bool 包含(关系类型 类型, 节点句柄 源节点, 节点句柄 目标节点) const noexcept {
        return std::count_if(关系组.begin(), 关系组.end(), [&](const auto& 关系) {
            return 关系.类型 == 类型 && 关系.源节点 == 源节点 && 关系.目标节点 == 目标节点;
        }) == 1;
    }
};

struct 概念图结构业务结果 {
    概念图结构业务状态 状态 = 概念图结构业务状态::入口拒绝;
    std::vector<概念关系证据> 关系组;

    bool 成功() const noexcept {
        return 状态 == 概念图结构业务状态::已提交
            || 状态 == 概念图结构业务状态::幂等读回;
    }

    bool 改变了结构() const noexcept {
        return 状态 == 概念图结构业务状态::已提交;
    }
};

class 概念关系写入规格 final {
public:
    概念关系写入规格() = delete;

    关系类型 读取类型() const noexcept { return 类型_; }
    概念根类别 读取根类别() const noexcept { return 根类别_; }
    节点句柄 读取源节点() const noexcept { return 源节点_; }
    节点句柄 读取目标节点() const noexcept { return 目标节点_; }
    std::int64_t 读取顺序号() const noexcept { return 顺序号_; }

    bool 完整() const noexcept {
        return 根类别_ != 概念根类别::未定义
            && 句柄有效(源节点_) && 句柄有效(目标节点_);
    }

private:
    friend class 概念图结构业务服务;
    friend class 概念图结构数据操作;

    概念关系写入规格(
        关系类型 类型,
        概念根类别 根类别,
        节点句柄 源节点,
        节点句柄 目标节点,
        std::int64_t 顺序号)
        : 类型_(类型), 根类别_(根类别), 源节点_(源节点),
          目标节点_(目标节点), 顺序号_(顺序号) {}

    关系类型 类型_ = 关系类型::普通父子;
    概念根类别 根类别_ = 概念根类别::未定义;
    节点句柄 源节点_;
    节点句柄 目标节点_;
    std::int64_t 顺序号_ = 0;
};

#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
inline constexpr char 概念图结构固定故障标记[] = "concept-structure-write-fault";

struct 概念关系固定故障项 {
    关系类型 类型 = 关系类型::普通父子;
    概念根类别 根类别 = 概念根类别::未定义;
    节点句柄 源节点;
    节点句柄 目标节点;
    std::int64_t 顺序号 = 0;
};

struct 概念关系固定故障自检结果 {
    概念图结构业务结果 业务结果;
    std::size_t 已写入数量 = 0;
    bool 故障已命中 = false;
};
#endif

class 概念图结构数据操作 final {
public:
    概念图结构数据操作(
        结构事务接线 接线,
        主信息仓库& 主信息,
        节点仓库& 节点,
        关系仓库& 关系,
        索引仓库& 索引,
        std::uint64_t 关系仓库编号)
        : 接线_(std::move(接线)), 主信息_(主信息), 节点_(节点), 关系_(关系),
          索引_(索引), 关系仓库编号_(关系仓库编号),
          执行器_(接线_, &主信息_, &节点_, &关系_, &索引_) {}

    bool 有效() const noexcept {
        return 接线_.已接域() && 关系仓库编号_ != 0 && 执行器_.有效();
    }

    概念根角色组值式材料 复核根角色组(const 概念根候选组& 候选组) const {
        if (!有效() || !候选组.完整()) return {};
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) return {概念图结构读取状态::许可拒绝};
        return 复核根角色组_已许可(候选组, 许可.读取令牌());
    }

    概念关系组值式材料 读取关系组(节点句柄 源节点, 关系类型 类型) const {
        if (!有效() || !句柄有效(源节点) || !是创建型关系(类型)) return {};
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) return {概念图结构读取状态::许可拒绝};
        return 读取关系组_已许可(源节点, 类型, 许可.读取令牌());
    }

    概念关系组值式材料 读取来源关系组(节点句柄 目标节点, 关系类型 类型) const {
        if (!有效() || !句柄有效(目标节点) || !是创建型关系(类型)) return {};
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) return {概念图结构读取状态::许可拒绝};
        return 读取来源关系组_已许可(目标节点, 类型, 许可.读取令牌());
    }

    概念图结构业务结果 创建关系组(
        const 概念根角色组& 根角色组,
        const std::vector<概念关系写入规格>& 写入组) const {
        return 创建关系组_实现(根角色组, 写入组, std::nullopt, nullptr, nullptr);
    }

#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
    概念关系固定故障自检结果 执行固定写点故障自检(
        const 概念根角色组& 根角色组,
        const std::vector<概念关系固定故障项>& 请求组,
        std::size_t 故障写点) const {
        std::vector<概念关系写入规格> 写入组;
        写入组.reserve(请求组.size());
        for (const auto& 请求 : 请求组) {
            写入组.push_back(概念关系写入规格(
                请求.类型, 请求.根类别, 请求.源节点, 请求.目标节点, 请求.顺序号));
        }
        std::size_t 已写入数量 = 0;
        bool 故障已命中 = false;
        auto 业务结果 = 创建关系组_实现(
            根角色组, 写入组, 故障写点, &已写入数量, &故障已命中);
        return {std::move(业务结果), 已写入数量, 故障已命中};
    }
#endif

private:
    enum class 归根复核状态 : std::uint8_t {
        已归根 = 1,
        未归根 = 2,
        跨类别 = 3,
        内部不一致 = 4
    };

    struct 会话节点身份 {
        节点句柄 节点;
        节点类型 类型 = 节点类型::未分类;
        主信息句柄 主信息;
        std::uint64_t 稳定主键 = 0;

        bool 完整() const noexcept {
            return 句柄有效(节点) && 类型 != 节点类型::未分类
                && 句柄有效(主信息) && 稳定主键 != 0;
        }
    };

    static bool 是根类别(概念根类别 类别) noexcept {
        return 类别 == 概念根类别::存在 || 类别 == 概念根类别::动态
            || 类别 == 概念根类别::关系 || 类别 == 概念根类别::因果;
    }

    static bool 是创建型关系(关系类型 类型) noexcept {
        return 类型 == 关系类型::实例支持概念 || 类型 == 关系类型::概念上下位
            || 类型 == 关系类型::概念定义材料;
    }

    static 节点类型 根类别节点类型(概念根类别 类别) noexcept {
        switch (类别) {
        case 概念根类别::存在: return 节点类型::存在;
        case 概念根类别::动态: return 节点类型::动态;
        case 概念根类别::关系: return 节点类型::二次特征;
        case 概念根类别::因果: return 节点类型::因果引用;
        default: return 节点类型::未分类;
        }
    }

    static 概念根候选组 转换候选组(const 概念根角色组& 根角色组) noexcept {
        return {
            {根角色组.存在根.类别, 根角色组.存在根.稳定主键, 根角色组.存在根.节点},
            {根角色组.动态根.类别, 根角色组.动态根.稳定主键, 根角色组.动态根.节点},
            {根角色组.关系根.类别, 根角色组.关系根.稳定主键, 根角色组.关系根.节点},
            {根角色组.因果根.类别, 根角色组.因果根.稳定主键, 根角色组.因果根.节点}};
    }

    概念根角色组值式材料 复核根角色组_已许可(
        const 概念根候选组& 候选组,
        const 结构事务令牌& 令牌) const {
        概念根角色组值式材料 输出;
        概念图结构读取状态 状态 = 概念图结构读取状态::已找到;
        输出.根角色.存在根 = 复核单根_已许可(候选组.存在根, 状态, 令牌);
        if (状态 == 概念图结构读取状态::已找到) {
            输出.根角色.动态根 = 复核单根_已许可(候选组.动态根, 状态, 令牌);
        }
        if (状态 == 概念图结构读取状态::已找到) {
            输出.根角色.关系根 = 复核单根_已许可(候选组.关系根, 状态, 令牌);
        }
        if (状态 == 概念图结构读取状态::已找到) {
            输出.根角色.因果根 = 复核单根_已许可(候选组.因果根, 状态, 令牌);
        }
        if (状态 != 概念图结构读取状态::已找到) {
            输出.状态 = 状态;
            return 输出;
        }
        if (!输出.根角色.完整()) {
            输出.状态 = 概念图结构读取状态::类型不匹配;
            return 输出;
        }
        输出.状态 = 概念图结构读取状态::已找到;
        return 输出;
    }

    概念根角色 复核单根_已许可(
        const 概念根候选& 候选,
        概念图结构读取状态& 状态,
        const 结构事务令牌& 令牌) const {
        概念根角色 输出;
        if (!候选.完整() || 根类别节点类型(候选.类别) == 节点类型::未分类) {
            状态 = 概念图结构读取状态::入口拒绝;
            return 输出;
        }
        const auto 节点记录 = 节点_.读取节点(候选.节点, 令牌);
        if (!节点记录.has_value()) {
            状态 = 概念图结构读取状态::版本漂移;
            return 输出;
        }
        if (节点记录->类型 != 根类别节点类型(候选.类别)) {
            状态 = 概念图结构读取状态::类型不匹配;
            return 输出;
        }
        if (!主信息_.读取主信息(节点记录->主信息, 令牌).has_value()) {
            状态 = 概念图结构读取状态::内部不一致;
            return 输出;
        }
        const auto 主键组 = 索引_.读取节点主键组(候选.节点, 令牌);
        if (主键组 != std::vector<std::uint64_t>{候选.稳定主键}
            || 索引_.按主键查节点(候选.稳定主键, 令牌)
                != std::optional<节点句柄>{候选.节点}) {
            状态 = 概念图结构读取状态::类型不匹配;
            return 输出;
        }
        if (!关系_.获取来源关系记录组(
                候选.节点, 关系类型::概念上下位, 令牌).empty()) {
            状态 = 概念图结构读取状态::类型不匹配;
            return 输出;
        }
        if (候选.类别 == 概念根类别::动态
            && !关系_.获取来源关系记录组(
                候选.节点, 关系类型::运行期临时, 令牌).empty()) {
            状态 = 概念图结构读取状态::类型不匹配;
            return 输出;
        }
        输出 = {候选.类别, 候选.稳定主键, 候选.节点, 节点记录->主信息};
        return 输出;
    }

    std::optional<概念关系证据> 形成关系证据_已许可(
        const 关系记录& 记录,
        const 结构事务令牌& 令牌) const {
        if (记录.状态 != 记录状态::有效 || !句柄有效(记录.源节点)
            || !句柄有效(记录.目标节点)) return std::nullopt;
        const 关系句柄 句柄{关系仓库编号_, 记录.关系编号, 记录.版本号};
        const auto 当前 = 关系_.读取关系(句柄, 令牌);
        if (!当前.has_value() || 当前->状态 != 记录状态::有效
            || 当前->类型 != 记录.类型 || 当前->源节点 != 记录.源节点
            || 当前->目标节点 != 记录.目标节点 || 当前->顺序号 != 记录.顺序号) {
            return std::nullopt;
        }
        return 概念关系证据{
            句柄, 记录.类型, 记录.源节点, 记录.目标节点,
            记录.顺序号, 记录.状态};
    }

    概念关系组值式材料 读取关系组_已许可(
        节点句柄 源节点,
        关系类型 类型,
        const 结构事务令牌& 令牌) const {
        概念关系组值式材料 输出;
        for (const auto& 记录 : 关系_.获取关系记录组(源节点, 类型, 令牌)) {
            const auto 证据 = 形成关系证据_已许可(记录, 令牌);
            if (!证据.has_value() || 证据->类型 != 类型 || 证据->源节点 != 源节点
                || std::count_if(输出.关系组.begin(), 输出.关系组.end(), [&](const auto& 已有) {
                    return 已有.目标节点 == 证据->目标节点;
                }) != 0) {
                return 关系读取内部不一致();
            }
            输出.关系组.push_back(*证据);
        }
        输出.状态 = 输出.关系组.empty()
            ? 概念图结构读取状态::未找到
            : 概念图结构读取状态::已找到;
        return 输出;
    }

    概念关系组值式材料 读取来源关系组_已许可(
        节点句柄 目标节点,
        关系类型 类型,
        const 结构事务令牌& 令牌) const {
        概念关系组值式材料 输出;
        for (const auto& 记录 : 关系_.获取来源关系记录组(目标节点, 类型, 令牌)) {
            const auto 证据 = 形成关系证据_已许可(记录, 令牌);
            if (!证据.has_value() || 证据->类型 != 类型 || 证据->目标节点 != 目标节点
                || std::count_if(输出.关系组.begin(), 输出.关系组.end(), [&](const auto& 已有) {
                    return 已有.源节点 == 证据->源节点;
                }) != 0) {
                return 关系读取内部不一致();
            }
            输出.关系组.push_back(*证据);
        }
        输出.状态 = 输出.关系组.empty()
            ? 概念图结构读取状态::未找到
            : 概念图结构读取状态::已找到;
        return 输出;
    }

    概念关系组值式材料 关系读取内部不一致() const {
        (void)追根因检查(false, L"概念关系无法按完整句柄、版本、状态和端点唯一读回。");
        return {概念图结构读取状态::内部不一致};
    }

    std::optional<概念关系证据> 形成关系证据_会话(
        结构写入会话& 会话,
        const 关系记录& 记录) const {
        if (记录.状态 != 记录状态::有效 || !句柄有效(记录.源节点)
            || !句柄有效(记录.目标节点)) return std::nullopt;
        const 关系句柄 句柄{关系仓库编号_, 记录.关系编号, 记录.版本号};
        if (!会话.关系可读(句柄)) return std::nullopt;
        return 概念关系证据{
            句柄, 记录.类型, 记录.源节点, 记录.目标节点,
            记录.顺序号, 记录.状态};
    }

    bool 读取关系组_会话(
        结构写入会话& 会话,
        节点句柄 源节点,
        关系类型 类型,
        std::vector<概念关系证据>& 输出) const {
        输出.clear();
        for (const auto& 记录 : 会话.读取关系记录组(源节点, 类型)) {
            const auto 证据 = 形成关系证据_会话(会话, 记录);
            if (!证据.has_value() || 证据->类型 != 类型 || 证据->源节点 != 源节点
                || std::count_if(输出.begin(), 输出.end(), [&](const auto& 已有) {
                    return 已有.目标节点 == 证据->目标节点;
                }) != 0) return false;
            输出.push_back(*证据);
        }
        return true;
    }

    bool 读取来源关系组_会话(
        结构写入会话& 会话,
        节点句柄 目标节点,
        关系类型 类型,
        std::vector<概念关系证据>& 输出) const {
        输出.clear();
        for (const auto& 记录 : 会话.读取来源关系记录组(目标节点, 类型)) {
            const auto 证据 = 形成关系证据_会话(会话, 记录);
            if (!证据.has_value() || 证据->类型 != 类型 || 证据->目标节点 != 目标节点
                || std::count_if(输出.begin(), 输出.end(), [&](const auto& 已有) {
                    return 已有.源节点 == 证据->源节点;
                }) != 0) return false;
            输出.push_back(*证据);
        }
        return true;
    }

    std::optional<会话节点身份> 读取节点身份_会话(
        结构写入会话& 会话,
        节点句柄 节点) const {
        const auto 类型 = 会话.读取节点类型(节点);
        const auto 主信息 = 会话.读取节点主信息(节点);
        const auto 主键组 = 会话.读取节点主键组(节点);
        if (!类型.has_value() || !主信息.has_value() || !句柄有效(*主信息)
            || 主键组.size() != 1 || 主键组.front() == 0
            || !会话.主键绑定匹配(主键组.front(), 节点)) return std::nullopt;
        return 会话节点身份{节点, *类型, *主信息, 主键组.front()};
    }

    bool 节点是任一根(节点句柄 节点, const 概念根角色组& 根角色组) const noexcept {
        return 节点 == 根角色组.存在根.节点 || 节点 == 根角色组.动态根.节点
            || 节点 == 根角色组.关系根.节点 || 节点 == 根角色组.因果根.节点;
    }

    bool 是运行期临时节点_会话(结构写入会话& 会话, 节点句柄 节点, bool& 内部不一致) const {
        std::vector<概念关系证据> 来源组;
        if (!读取来源关系组_会话(会话, 节点, 关系类型::运行期临时, 来源组)) {
            内部不一致 = true;
            return false;
        }
        return !来源组.empty();
    }

    bool 节点匹配根类别_会话(
        结构写入会话& 会话,
        节点句柄 节点,
        概念根类别 类别,
        bool 要求长期,
        bool& 内部不一致) const {
        const auto 身份 = 读取节点身份_会话(会话, 节点);
        if (!身份.has_value()) return false;
        if (身份->类型 != 根类别节点类型(类别)) return false;
        if (要求长期 && (身份->类型 == 节点类型::动态 || 身份->类型 == 节点类型::状态)
            && 是运行期临时节点_会话(会话, 节点, 内部不一致)) return false;
        return !内部不一致;
    }

    bool 验证根角色组_会话(
        结构写入会话& 会话,
        const 概念根角色组& 根角色组) const {
        if (!根角色组.完整()) return false;
        const std::array<const 概念根角色*, 4> 根组{
            &根角色组.存在根, &根角色组.动态根,
            &根角色组.关系根, &根角色组.因果根};
        for (const auto* 根 : 根组) {
            const auto 身份 = 读取节点身份_会话(会话, 根->节点);
            if (!身份.has_value() || 身份->类型 != 根类别节点类型(根->类别)
                || 身份->主信息 != 根->主信息 || 身份->稳定主键 != 根->稳定主键) return false;
            std::vector<概念关系证据> 上位组;
            if (!读取来源关系组_会话(
                    会话, 根->节点, 关系类型::概念上下位, 上位组) || !上位组.empty()) return false;
            if (根->类别 == 概念根类别::动态) {
                bool 内部不一致 = false;
                if (是运行期临时节点_会话(会话, 根->节点, 内部不一致)
                    || 内部不一致) return false;
            }
        }
        return true;
    }

    归根复核状态 复核概念归根_会话(
        结构写入会话& 会话,
        节点句柄 起点,
        概念根类别 类别,
        const 概念根角色组& 根角色组) const {
        const auto* 期望根 = 根角色组.查找(类别);
        if (期望根 == nullptr) return 归根复核状态::跨类别;
        bool 到达期望根 = false;
        bool 发现其它根 = false;
        bool 发现无根终点 = false;
        bool 内部不一致 = false;
        std::vector<节点句柄> 当前路径;
        std::function<void(节点句柄)> 追溯 = [&](节点句柄 当前) {
            if (内部不一致) return;
            if (当前 == 期望根->节点) {
                到达期望根 = true;
                return;
            }
            if (节点是任一根(当前, 根角色组)) {
                发现其它根 = true;
                return;
            }
            if (std::find(当前路径.begin(), 当前路径.end(), 当前) != 当前路径.end()) {
                内部不一致 = true;
                return;
            }
            bool 类型内部不一致 = false;
            if (!节点匹配根类别_会话(会话, 当前, 类别, true, 类型内部不一致)) {
                内部不一致 = 类型内部不一致;
                if (!内部不一致) 发现其它根 = true;
                return;
            }
            std::vector<概念关系证据> 上位组;
            if (!读取来源关系组_会话(
                    会话, 当前, 关系类型::概念上下位, 上位组)) {
                内部不一致 = true;
                return;
            }
            if (上位组.empty()) {
                发现无根终点 = true;
                return;
            }
            当前路径.push_back(当前);
            for (const auto& 关系 : 上位组) 追溯(关系.源节点);
            当前路径.pop_back();
        };
        追溯(起点);
        if (内部不一致) return 归根复核状态::内部不一致;
        if (发现其它根) return 归根复核状态::跨类别;
        if (!到达期望根 || 发现无根终点) return 归根复核状态::未归根;
        return 归根复核状态::已归根;
    }

    bool 是首次挂载候选_会话(
        结构写入会话& 会话,
        节点句柄 节点,
        概念根类别 类别,
        const 概念根角色组& 根角色组,
        bool& 内部不一致) const {
        if (节点是任一根(节点, 根角色组)
            || !节点匹配根类别_会话(会话, 节点, 类别, true, 内部不一致)) return false;
        std::vector<概念关系证据> 上位输出;
        std::vector<概念关系证据> 上位来源;
        std::vector<概念关系证据> 支持来源;
        std::vector<概念关系证据> 定义输出;
        if (!读取关系组_会话(会话, 节点, 关系类型::概念上下位, 上位输出)
            || !读取来源关系组_会话(会话, 节点, 关系类型::概念上下位, 上位来源)
            || !读取来源关系组_会话(会话, 节点, 关系类型::实例支持概念, 支持来源)
            || !读取关系组_会话(会话, 节点, 关系类型::概念定义材料, 定义输出)) {
            内部不一致 = true;
            return false;
        }
        return 上位输出.empty() && 上位来源.empty()
            && 支持来源.empty() && 定义输出.empty();
    }

    bool 从下位可达上位_会话(
        结构写入会话& 会话,
        节点句柄 下位,
        节点句柄 上位,
        bool& 内部不一致) const {
        bool 已找到 = false;
        std::vector<节点句柄> 当前路径;
        std::function<void(节点句柄)> 向下 = [&](节点句柄 当前) {
            if (内部不一致 || 已找到) return;
            if (当前 == 上位) {
                已找到 = true;
                return;
            }
            if (std::find(当前路径.begin(), 当前路径.end(), 当前) != 当前路径.end()) {
                内部不一致 = true;
                return;
            }
            std::vector<概念关系证据> 下位组;
            if (!读取关系组_会话(
                    会话, 当前, 关系类型::概念上下位, 下位组)) {
                内部不一致 = true;
                return;
            }
            当前路径.push_back(当前);
            for (const auto& 关系 : 下位组) 向下(关系.目标节点);
            当前路径.pop_back();
        };
        向下(下位);
        return 已找到;
    }

    bool 允许定义材料_会话(
        结构写入会话& 会话,
        节点句柄 材料,
        bool& 内部不一致) const {
        const auto 身份 = 读取节点身份_会话(会话, 材料);
        if (!身份.has_value()) return false;
        switch (身份->类型) {
        case 节点类型::基础信息:
        case 节点类型::存在:
        case 节点类型::场景:
        case 节点类型::特征:
        case 节点类型::二次特征:
        case 节点类型::因果引用:
            return true;
        case 节点类型::状态:
        case 节点类型::动态:
            return !是运行期临时节点_会话(会话, 材料, 内部不一致)
                && !内部不一致;
        default:
            return false;
        }
    }

    bool 验证关系请求_会话(
        结构写入会话& 会话,
        const 概念根角色组& 根角色组,
        const 概念关系写入规格& 规格,
        bool& 内部不一致) const {
        if (!规格.完整() || !是根类别(规格.读取根类别())
            || !是创建型关系(规格.读取类型())) return false;
        const auto 源身份 = 读取节点身份_会话(会话, 规格.读取源节点());
        const auto 目标身份 = 读取节点身份_会话(会话, 规格.读取目标节点());
        if (!源身份.has_value() || !目标身份.has_value()) return false;

        if (规格.读取类型() == 关系类型::实例支持概念) {
            if (规格.读取源节点() == 规格.读取目标节点()
                || 节点是任一根(规格.读取源节点(), 根角色组)) return false;
            bool 源内部不一致 = false;
            if (!节点匹配根类别_会话(
                    会话, 规格.读取源节点(), 规格.读取根类别(), true, 源内部不一致)) {
                内部不一致 = 源内部不一致;
                return false;
            }
            const auto 目标归根 = 复核概念归根_会话(
                会话, 规格.读取目标节点(), 规格.读取根类别(), 根角色组);
            内部不一致 = 目标归根 == 归根复核状态::内部不一致;
            return 目标归根 == 归根复核状态::已归根;
        }

        if (规格.读取类型() == 关系类型::概念上下位) {
            if (规格.读取源节点() == 规格.读取目标节点()
                || 节点是任一根(规格.读取目标节点(), 根角色组)) return false;
            const auto 源归根 = 复核概念归根_会话(
                会话, 规格.读取源节点(), 规格.读取根类别(), 根角色组);
            if (源归根 != 归根复核状态::已归根) {
                内部不一致 = 源归根 == 归根复核状态::内部不一致;
                return false;
            }
            const auto 目标归根 = 复核概念归根_会话(
                会话, 规格.读取目标节点(), 规格.读取根类别(), 根角色组);
            if (目标归根 == 归根复核状态::内部不一致) {
                内部不一致 = true;
                return false;
            }
            if (目标归根 != 归根复核状态::已归根
                && !是首次挂载候选_会话(
                    会话, 规格.读取目标节点(), 规格.读取根类别(),
                    根角色组, 内部不一致)) return false;
            if (从下位可达上位_会话(
                    会话, 规格.读取目标节点(), 规格.读取源节点(), 内部不一致)) return false;
            return !内部不一致;
        }

        const auto 源归根 = 复核概念归根_会话(
            会话, 规格.读取源节点(), 规格.读取根类别(), 根角色组);
        if (源归根 != 归根复核状态::已归根) {
            内部不一致 = 源归根 == 归根复核状态::内部不一致;
            return false;
        }
        return 允许定义材料_会话(会话, 规格.读取目标节点(), 内部不一致);
    }

    std::optional<概念关系证据> 读取精确关系_会话(
        结构写入会话& 会话,
        const 概念关系写入规格& 规格,
        bool& 幂等冲突,
        bool& 内部不一致) const {
        std::vector<概念关系证据> 关系组;
        if (!读取关系组_会话(
                会话, 规格.读取源节点(), 规格.读取类型(), 关系组)) {
            内部不一致 = true;
            return std::nullopt;
        }
        std::optional<概念关系证据> 输出;
        for (const auto& 关系 : 关系组) {
            if (关系.目标节点 != 规格.读取目标节点()) continue;
            if (输出.has_value()) {
                内部不一致 = true;
                return std::nullopt;
            }
            if (关系.顺序号 != 规格.读取顺序号()) {
                幂等冲突 = true;
                return std::nullopt;
            }
            输出 = 关系;
        }
        return 输出;
    }

    bool 写入请求组无重复(const std::vector<概念关系写入规格>& 写入组) const noexcept {
        if (写入组.empty()) return false;
        for (std::size_t 左 = 0; 左 < 写入组.size(); ++左) {
            if (!写入组[左].完整() || !是创建型关系(写入组[左].读取类型())
                || !是根类别(写入组[左].读取根类别())) return false;
            for (std::size_t 右 = 左 + 1; 右 < 写入组.size(); ++右) {
                if (写入组[左].读取类型() == 写入组[右].读取类型()
                    && 写入组[左].读取源节点() == 写入组[右].读取源节点()
                    && 写入组[左].读取目标节点() == 写入组[右].读取目标节点()) return false;
            }
        }
        return true;
    }

    std::optional<std::vector<概念关系证据>> 读取请求组当前(
        const 概念根角色组& 根角色组,
        const std::vector<概念关系写入规格>& 写入组) const {
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) return std::nullopt;
        const auto 根复核 = 复核根角色组_已许可(转换候选组(根角色组), 许可.读取令牌());
        if (!根复核.完整()) return std::nullopt;
        std::vector<概念关系证据> 输出;
        for (const auto& 规格 : 写入组) {
            const auto 关系组 = 读取关系组_已许可(
                规格.读取源节点(), 规格.读取类型(), 许可.读取令牌());
            if (关系组.状态 == 概念图结构读取状态::内部不一致) return std::nullopt;
            const auto 命中 = std::find_if(关系组.关系组.begin(), 关系组.关系组.end(), [&](const auto& 关系) {
                return 关系.目标节点 == 规格.读取目标节点()
                    && 关系.顺序号 == 规格.读取顺序号();
            });
            if (命中 == 关系组.关系组.end()) return std::nullopt;
            输出.push_back(*命中);
        }
        return 输出;
    }

    概念图结构业务结果 创建关系组_实现(
        const 概念根角色组& 根角色组,
        const std::vector<概念关系写入规格>& 写入组,
        std::optional<std::size_t> 故障写点,
        std::size_t* 已写入数量输出,
        bool* 故障已命中输出) const {
        if (!有效() || !根角色组.完整() || !写入请求组无重复(写入组)
            || (故障写点.has_value()
                && (*故障写点 == 0 || *故障写点 > 写入组.size()))) return {};

        std::vector<概念关系证据> 会话关系组;
        std::size_t 已写入数量 = 0;
        bool 语义已闭合 = false;
        bool 已请求提交 = false;
        bool 幂等冲突 = false;
        bool 内部不一致 = false;
        bool 故障已命中 = false;
        const auto 执行结果 = 执行器_.执行([&](结构写入会话& 会话) {
            if (!验证根角色组_会话(会话, 根角色组)) return;
            for (const auto& 规格 : 写入组) {
                if (!验证关系请求_会话(会话, 根角色组, 规格, 内部不一致)
                    || 内部不一致) return;
                auto 当前关系 = 读取精确关系_会话(
                    会话, 规格, 幂等冲突, 内部不一致);
                if (幂等冲突 || 内部不一致) return;
                if (当前关系.has_value()) {
                    会话关系组.push_back(*当前关系);
                    continue;
                }
                const auto 创建结果 = 会话.创建关系(
                    规格.读取类型(), 规格.读取源节点(),
                    规格.读取目标节点(), 规格.读取顺序号());
                if (!创建结果.成功() || !创建结果.值.has_value()) return;
                bool 写后冲突 = false;
                当前关系 = 读取精确关系_会话(
                    会话, 规格, 写后冲突, 内部不一致);
                if (写后冲突 || 内部不一致 || !当前关系.has_value()
                    || 当前关系->关系 != *创建结果.值) {
                    内部不一致 = true;
                    return;
                }
                会话关系组.push_back(*当前关系);
                ++已写入数量;
                if (故障写点.has_value() && 已写入数量 == *故障写点) {
                    故障已命中 = true;
                    return;
                }
            }
            语义已闭合 = 会话关系组.size() == 写入组.size();
            if (!语义已闭合 || 已写入数量 == 0) return;
            if (!会话.请求提交()) {
                内部不一致 = true;
                return;
            }
            已请求提交 = true;
        });

        if (已写入数量输出 != nullptr) *已写入数量输出 = 已写入数量;
        if (故障已命中输出 != nullptr) *故障已命中输出 = 故障已命中;
        if (故障已命中) return {};
        if (幂等冲突) return {概念图结构业务状态::幂等冲突};
        if (内部不一致) {
            (void)追根因检查(false, L"概念关系写入后无法按同一令牌完整读回。");
            return {概念图结构业务状态::内部不一致};
        }
        if (执行结果.状态 == 结构写入状态::已提交
            && 语义已闭合 && 已请求提交) {
            const auto 当前 = 读取请求组当前(根角色组, 写入组);
            if (!当前.has_value() || 当前->size() != 写入组.size()) {
                (void)追根因检查(false, L"概念关系提交后无法从权威仓库完整读回。");
                return {概念图结构业务状态::内部不一致};
            }
            return {概念图结构业务状态::已提交, *当前};
        }
        if (语义已闭合 && 已写入数量 == 0
            && 执行结果.状态 == 结构写入状态::入口拒绝) {
            return {概念图结构业务状态::幂等读回, 会话关系组};
        }
        if (执行结果.状态 == 结构写入状态::许可拒绝) {
            const auto 当前 = 读取请求组当前(根角色组, 写入组);
            return 当前.has_value()
                ? 概念图结构业务结果{概念图结构业务状态::幂等读回, *当前}
                : 概念图结构业务结果{概念图结构业务状态::许可拒绝};
        }
        if (执行结果.状态 == 结构写入状态::版本漂移) {
            return {概念图结构业务状态::版本漂移};
        }
        if (执行结果.状态 == 结构写入状态::内部不一致) {
            return {概念图结构业务状态::内部不一致};
        }
        return {概念图结构业务状态::入口拒绝};
    }

    结构事务接线 接线_;
    主信息仓库& 主信息_;
    节点仓库& 节点_;
    关系仓库& 关系_;
    索引仓库& 索引_;
    std::uint64_t 关系仓库编号_ = 0;
    结构写入执行器 执行器_;
};

}
