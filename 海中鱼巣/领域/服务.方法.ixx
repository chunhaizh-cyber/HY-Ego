// 文件规则：方法业务服务只裁决登记、规格、生命周期和动作桥材料，不接触仓库或事务能力。
module;

#include "../核心/句柄.h"

#include <cstddef>
#include <cstdint>
#include <utility>
#include <vector>

export module 海中鱼巣.领域.服务.方法;

import 海中鱼巣.领域.数据操作.需求任务方法;
import 海中鱼巣.领域.数据操作.存在场景;
import 海中鱼巣.领域.数据操作.状态动态;
import 海中鱼巣.领域.服务.存在;
import 海中鱼巣.领域.服务.状态;

export namespace 海中鱼巣 {

struct 创建方法登记根请求 {
    std::uint64_t 根幂等主键 = 0;
    std::uint64_t 角色状态幂等主键 = 0;
    std::uint64_t 活跃状态幂等主键 = 0;
    std::uint64_t 失效状态幂等主键 = 0;
};

struct 创建方法首请求 {
    std::uint64_t 方法幂等主键 = 0;
    std::uint64_t 虚拟存在幂等主键 = 0;
    std::uint64_t 角色状态幂等主键 = 0;
    节点句柄 登记根;
};

struct 创建方法条件请求 {
    std::uint64_t 条件幂等主键 = 0;
    std::uint64_t 角色状态幂等主键 = 0;
    节点句柄 方法首;
    节点句柄 场景;
    节点句柄 目标特征;
    节点句柄 期望抽象状态;
    std::uint64_t 来源版本 = 0;
};

struct 创建方法结果请求 {
    std::uint64_t 结果幂等主键 = 0;
    std::uint64_t 角色状态幂等主键 = 0;
    节点句柄 方法首;
    节点句柄 场景;
    节点句柄 目标特征;
    节点句柄 目标抽象状态;
    std::uint64_t 来源版本 = 0;
};

struct 创建方法动作入口请求 {
    std::uint64_t 动作幂等主键 = 0;
    std::uint64_t 角色状态幂等主键 = 0;
    std::uint64_t 入口状态幂等主键 = 0;
    节点句柄 方法首;
    节点句柄 输入场景;
    节点句柄 输出场景;
    std::int64_t 入口状态值 = 0;
};

struct 迁移方法生命周期请求 {
    节点句柄 方法首;
    分层方法生命周期 目标生命周期 = 分层方法生命周期::未定义;
};

class 方法业务服务 final {
public:
    方法业务服务(
        需求任务方法数据操作& 数据操作,
        存在业务服务& 存在服务,
        状态业务服务& 状态服务)
        : 数据操作_(数据操作), 存在服务_(存在服务), 状态服务_(状态服务) {
    }

    方法提交结果 创建登记根(const 创建方法登记根请求& 请求) const {
        if (请求.根幂等主键 == 0 || 请求.角色状态幂等主键 == 0
            || 请求.活跃状态幂等主键 == 0 || 请求.失效状态幂等主键 == 0
            || 请求.角色状态幂等主键 == 请求.活跃状态幂等主键
            || 请求.角色状态幂等主键 == 请求.失效状态幂等主键
            || 请求.活跃状态幂等主键 == 请求.失效状态幂等主键) return {};
        const 创建抽象状态请求 角色请求{
            请求.角色状态幂等主键,
            static_cast<std::int64_t>(分层方法角色::方法登记根)};
        const 创建抽象状态请求 活跃请求{
            请求.活跃状态幂等主键,
            static_cast<std::int64_t>(分层方法生命周期::活跃)};
        const 创建抽象状态请求 失效请求{
            请求.失效状态幂等主键,
            static_cast<std::int64_t>(分层方法生命周期::已失效)};
        抽象状态规格结果 角色 = 状态服务_.形成抽象状态写入规格(角色请求);
        抽象状态规格结果 活跃 = 状态服务_.形成抽象状态写入规格(活跃请求);
        抽象状态规格结果 失效 = 状态服务_.形成抽象状态写入规格(失效请求);
        if (!角色.成功() || !活跃.成功() || !失效.成功()) {
            return {合并状态规格失败(角色.状态, 活跃.状态, 失效.状态)};
        }
        const auto 写入规格 = 数据操作_.形成方法登记根写入规格(
            请求.根幂等主键, std::move(*角色.规格),
            std::move(*活跃.规格), std::move(*失效.规格));
        return 写入规格.has_value()
            ? 数据操作_.创建方法登记根(*写入规格)
            : 方法提交结果{需求任务方法业务状态::内部不一致};
    }

    方法提交结果 创建方法首(const 创建方法首请求& 请求) const {
        if (请求.方法幂等主键 == 0 || 请求.虚拟存在幂等主键 == 0
            || 请求.角色状态幂等主键 == 0 || !句柄有效(请求.登记根)) return {};
        const auto 根 = 数据操作_.读取方法登记根(请求.登记根);
        if (!根.完整()) return {};
        const 候选来源虚拟存在规格请求 虚拟存在请求{
            请求.虚拟存在幂等主键, 节点类型::方法};
        虚拟存在规格结果 虚拟规格 =
            存在服务_.形成本会话候选来源虚拟存在写入规格(虚拟存在请求);
        const 创建抽象状态请求 角色请求{
            请求.角色状态幂等主键,
            static_cast<std::int64_t>(分层方法角色::方法首)};
        抽象状态规格结果 角色规格 =
            状态服务_.形成抽象状态写入规格(角色请求);
        if (!虚拟规格.成功() || !角色规格.成功()) {
            return {合并存在状态规格失败(虚拟规格.状态, 角色规格.状态)};
        }
        const auto 写入规格 = 数据操作_.形成方法首写入规格(
            请求.方法幂等主键, 请求.登记根, std::move(*虚拟规格.规格),
            std::move(*角色规格.规格));
        return 写入规格.has_value()
            ? 数据操作_.创建方法首(*写入规格)
            : 方法提交结果{需求任务方法业务状态::内部不一致};
    }

    方法提交结果 创建条件(const 创建方法条件请求& 请求) const {
        if (请求.条件幂等主键 == 0 || 请求.角色状态幂等主键 == 0
            || !句柄有效(请求.方法首) || !句柄有效(请求.场景)
            || !句柄有效(请求.目标特征) || !句柄有效(请求.期望抽象状态)
            || 请求.来源版本 == 0) return {};
        const auto 状态 = 状态服务_.读取状态材料(请求.期望抽象状态);
        if (!状态.完整抽象状态()) return {};
        const 创建抽象状态请求 角色请求{
            请求.角色状态幂等主键,
            static_cast<std::int64_t>(分层方法角色::方法条件)};
        抽象状态规格结果 角色 = 状态服务_.形成抽象状态写入规格(角色请求);
        if (!角色.成功()) return {映射状态规格失败(角色.状态)};
        const auto 写入规格 = 数据操作_.形成方法条件写入规格(
            请求.条件幂等主键, 请求.方法首, 请求.场景, 请求.目标特征,
            请求.期望抽象状态, 请求.来源版本, std::move(*角色.规格));
        return 写入规格.has_value()
            ? 数据操作_.创建方法条件(*写入规格)
            : 方法提交结果{需求任务方法业务状态::内部不一致};
    }

    方法提交结果 创建结果(const 创建方法结果请求& 请求) const {
        if (请求.结果幂等主键 == 0 || 请求.角色状态幂等主键 == 0
            || !句柄有效(请求.方法首) || !句柄有效(请求.场景)
            || !句柄有效(请求.目标特征) || !句柄有效(请求.目标抽象状态)
            || 请求.来源版本 == 0) return {};
        const auto 状态 = 状态服务_.读取状态材料(请求.目标抽象状态);
        if (!状态.完整抽象状态()) return {};
        const 创建抽象状态请求 角色请求{
            请求.角色状态幂等主键,
            static_cast<std::int64_t>(分层方法角色::方法结果)};
        抽象状态规格结果 角色 = 状态服务_.形成抽象状态写入规格(角色请求);
        if (!角色.成功()) return {映射状态规格失败(角色.状态)};
        const auto 写入规格 = 数据操作_.形成方法结果写入规格(
            请求.结果幂等主键, 请求.方法首, 请求.场景, 请求.目标特征,
            请求.目标抽象状态, 请求.来源版本, std::move(*角色.规格));
        return 写入规格.has_value()
            ? 数据操作_.创建方法结果(*写入规格)
            : 方法提交结果{需求任务方法业务状态::内部不一致};
    }

    方法提交结果 创建动作入口(const 创建方法动作入口请求& 请求) const {
        if (请求.动作幂等主键 == 0 || 请求.角色状态幂等主键 == 0
            || 请求.入口状态幂等主键 == 0 || !句柄有效(请求.方法首)
            || !句柄有效(请求.输入场景) || !句柄有效(请求.输出场景)
            || 请求.入口状态值 < 1 || 请求.入口状态值 > 6) return {};
        const 创建抽象状态请求 角色请求{
            请求.角色状态幂等主键,
            static_cast<std::int64_t>(分层方法角色::动作入口)};
        const 创建抽象状态请求 入口请求{
            请求.入口状态幂等主键, 请求.入口状态值};
        抽象状态规格结果 角色 = 状态服务_.形成抽象状态写入规格(角色请求);
        抽象状态规格结果 入口 = 状态服务_.形成抽象状态写入规格(入口请求);
        if (!角色.成功() || !入口.成功()) {
            return {合并状态规格失败(角色.状态, 入口.状态, 状态写入规格状态::已形成)};
        }
        const auto 写入规格 = 数据操作_.形成方法动作入口写入规格(
            请求.动作幂等主键, 请求.方法首, 请求.输入场景, 请求.输出场景,
            std::move(*角色.规格), std::move(*入口.规格));
        return 写入规格.has_value()
            ? 数据操作_.创建方法动作入口(*写入规格)
            : 方法提交结果{需求任务方法业务状态::内部不一致};
    }

    方法提交结果 迁移生命周期(const 迁移方法生命周期请求& 请求) const {
        if (!句柄有效(请求.方法首)
            || (请求.目标生命周期 != 分层方法生命周期::活跃
                && 请求.目标生命周期 != 分层方法生命周期::已失效)) return {};
        const auto 当前 = 数据操作_.读取方法登记项(请求.方法首);
        if (!当前.完整()) return {};
        const auto 写入规格 = 数据操作_.形成方法生命周期写入规格(
            请求.方法首, 当前.生命周期关系.关系, 请求.目标生命周期);
        return 写入规格.has_value()
            ? 数据操作_.迁移方法生命周期(*写入规格)
            : 方法提交结果{需求任务方法业务状态::内部不一致};
    }

    方法登记根材料 读取登记根(节点句柄 根) const {
        return 句柄有效(根) ? 数据操作_.读取方法登记根(根) : 方法登记根材料{};
    }

    方法登记根材料 读取主键登记根(std::uint64_t 主键) const {
        return 主键 != 0 ? 数据操作_.读取主键方法登记根(主键) : 方法登记根材料{};
    }

    方法登记项材料 读取登记项(节点句柄 方法首) const {
        return 句柄有效(方法首) ? 数据操作_.读取方法登记项(方法首) : 方法登记项材料{};
    }

    std::vector<方法登记项材料> 读取登记项组(节点句柄 登记根) const {
        return 句柄有效(登记根)
            ? 数据操作_.读取方法登记项组(登记根)
            : std::vector<方法登记项材料>{};
    }

    std::vector<方法规格材料> 读取规格组(
        节点句柄 方法首,
        分层方法角色 角色) const {
        return 句柄有效(方法首)
            ? 数据操作_.读取方法规格组(方法首, 角色)
            : std::vector<方法规格材料>{};
    }

#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
    需求任务方法故障自检结果 执行动作入口固定故障自检(
        const 创建方法动作入口请求& 请求,
        std::size_t 故障写点) const {
        if (请求.动作幂等主键 == 0 || 请求.角色状态幂等主键 == 0
            || 请求.入口状态幂等主键 == 0 || !句柄有效(请求.方法首)
            || !句柄有效(请求.输入场景) || !句柄有效(请求.输出场景)
            || 请求.入口状态值 < 1 || 请求.入口状态值 > 6) return {};
        const 创建抽象状态请求 角色请求{
            请求.角色状态幂等主键,
            static_cast<std::int64_t>(分层方法角色::动作入口)};
        const 创建抽象状态请求 入口请求{
            请求.入口状态幂等主键, 请求.入口状态值};
        抽象状态规格结果 角色 = 状态服务_.形成抽象状态写入规格(角色请求);
        抽象状态规格结果 入口 = 状态服务_.形成抽象状态写入规格(入口请求);
        if (!角色.成功() || !入口.成功()) {
            return {合并状态规格失败(
                角色.状态, 入口.状态, 状态写入规格状态::已形成), 0, false};
        }
        const auto 写入规格 = 数据操作_.形成方法动作入口写入规格(
            请求.动作幂等主键, 请求.方法首, 请求.输入场景, 请求.输出场景,
            std::move(*角色.规格), std::move(*入口.规格));
        if (!写入规格.has_value()) {
            return {需求任务方法业务状态::内部不一致, 0, false};
        }
        return 数据操作_.执行方法动作入口固定故障自检(*写入规格, 故障写点);
    }
#endif

private:
    static 需求任务方法业务状态 映射状态规格失败(状态写入规格状态 状态) noexcept {
        switch (状态) {
        case 状态写入规格状态::许可拒绝:
            return 需求任务方法业务状态::许可拒绝;
        case 状态写入规格状态::版本漂移:
            return 需求任务方法业务状态::版本漂移;
        case 状态写入规格状态::内部不一致:
            return 需求任务方法业务状态::内部不一致;
        default:
            return 需求任务方法业务状态::入口拒绝;
        }
    }

    static 需求任务方法业务状态 合并状态规格失败(
        状态写入规格状态 甲,
        状态写入规格状态 乙,
        状态写入规格状态 丙) noexcept {
        if (甲 == 状态写入规格状态::内部不一致
            || 乙 == 状态写入规格状态::内部不一致
            || 丙 == 状态写入规格状态::内部不一致) {
            return 需求任务方法业务状态::内部不一致;
        }
        if (甲 == 状态写入规格状态::许可拒绝
            || 乙 == 状态写入规格状态::许可拒绝
            || 丙 == 状态写入规格状态::许可拒绝) {
            return 需求任务方法业务状态::许可拒绝;
        }
        if (甲 == 状态写入规格状态::版本漂移
            || 乙 == 状态写入规格状态::版本漂移
            || 丙 == 状态写入规格状态::版本漂移) {
            return 需求任务方法业务状态::版本漂移;
        }
        return 需求任务方法业务状态::入口拒绝;
    }

    static 需求任务方法业务状态 合并存在状态规格失败(
        虚拟存在规格状态 存在状态,
        状态写入规格状态 状态状态) noexcept {
        if (存在状态 == 虚拟存在规格状态::内部不一致
            || 状态状态 == 状态写入规格状态::内部不一致) {
            return 需求任务方法业务状态::内部不一致;
        }
        if (存在状态 == 虚拟存在规格状态::许可拒绝
            || 状态状态 == 状态写入规格状态::许可拒绝) {
            return 需求任务方法业务状态::许可拒绝;
        }
        if (存在状态 == 虚拟存在规格状态::版本漂移
            || 状态状态 == 状态写入规格状态::版本漂移) {
            return 需求任务方法业务状态::版本漂移;
        }
        return 需求任务方法业务状态::入口拒绝;
    }

    需求任务方法数据操作& 数据操作_;
    存在业务服务& 存在服务_;
    状态业务服务& 状态服务_;
};

}
