// 文件规则：语素概念入口组合器只组合文本准入和两类关系规格，不接触仓库或事务能力。
module;

export module 海中鱼巣.领域.组合.语素概念入口;

import 海中鱼巣.领域.数据操作.语素基础;
import 海中鱼巣.领域.服务.语素;

export namespace 海中鱼巣 {

class 语素概念入口组合器 final {
public:
    语素概念入口组合器(语素业务服务& 语素服务, 语素基础数据操作& 数据操作)
        : 语素服务_(语素服务), 数据操作_(数据操作) {}

    语义基础业务结果 创建语素概念入口(
        const 创建语素概念入口请求& 请求) const {
        const auto 规格 = 语素服务_.形成语素概念入口规格(请求);
        return 规格.成功()
            ? 数据操作_.创建语素入口(*规格.规格)
            : 语素业务服务::映射规格失败(规格.状态);
    }

private:
    语素业务服务& 语素服务_;
    语素基础数据操作& 数据操作_;
};

}
