// 文件规则：节点直接退役协调器只承载强类型退役入口和阶段边界，不持有仓库、令牌、锁或投影事实。
module;

#include "节点直接P3合同.数据.h"

#include <cstdint>
#include <optional>

export module 海中鱼巣.领域.退役.节点直接对象;

import 海中鱼巣.领域.服务.节点直接特征;
import 海中鱼巣.领域.服务.节点直接状态;
import 海中鱼巣.领域.服务.节点直接动态;
import 海中鱼巣.领域.服务.节点直接存在;
import 海中鱼巣.领域.服务.节点直接场景;
import 海中鱼巣.领域.组合.节点直接自我读取;
import 海中鱼巣.领域.数据操作.节点直接系统角色;
import 海中鱼巣.领域.数据操作.节点直接概念结构;
import 海中鱼巣.领域.数据操作.节点直接需求任务方法;
import 海中鱼巣.领域.适配.特征值退役;
import 海中鱼巣.领域.适配.状态动态退役;
import 海中鱼巣.领域.适配.自我存在场景退役;
import 海中鱼巣.领域.适配.语义概念退役;
import 海中鱼巣.领域.适配.需求任务方法用途退役;
import 海中鱼巣.领域.审计.节点直接退役;

export namespace 海中鱼巣::领域 {

struct 节点直接对象退役结果 {
    节点直接P3结果头 头{};
    std::optional<权威退役回执> 回执;
};

class 节点直接对象退役服务 final {
public:
    节点直接对象退役服务() = delete;

    // C3-D1：八个对象族保持独立强类型重载，禁止通用载荷和通用退役包。
    static 节点直接对象退役结果 退役节点直接对象(const 特征值退役规格& 规格) {
        return 提交特征值退役(规格);
    }
    static 节点直接对象退役结果 退役节点直接对象(const 状态退役规格& 规格) {
        return 提交状态退役(规格);
    }
    static 节点直接对象退役结果 退役节点直接对象(const 动态退役规格& 规格) {
        return 提交动态退役(规格);
    }
    static 节点直接对象退役结果 退役节点直接对象(const 自我结构退役规格& 规格) {
        return 提交自我结构退役(规格);
    }
    static 节点直接对象退役结果 退役节点直接对象(const 系统角色退役规格& 规格) {
        return 提交系统角色退役(规格);
    }
    static 节点直接对象退役结果 退役节点直接对象(const 存在场景增量退役规格& 规格) {
        return 提交存在场景增量退役(规格);
    }
    static 节点直接对象退役结果 退役节点直接对象(const 语义概念退役规格& 规格) {
        return 提交语义概念退役(规格);
    }
    static 节点直接对象退役结果 退役节点直接对象(
        const 需求任务方法用途退役规格& 规格) {
        return 提交需求任务方法用途退役(规格);
    }

private:
    // 候选接线固定为：冻结 -> 独占许可/锁内复核 -> 关系失效 -> 记录退役
    // -> 索引移除 -> 节点删除 -> 权威读回 -> 确认 -> 最后发布。
    // 具体提供者实体由各合同拥有者汇合后定义；本叶不复制其接口或算法。
    static 节点直接对象退役结果 提交特征值退役(const 特征值退役规格&);
    static 节点直接对象退役结果 提交状态退役(const 状态退役规格&);
    static 节点直接对象退役结果 提交动态退役(const 动态退役规格&);
    static 节点直接对象退役结果 提交自我结构退役(const 自我结构退役规格&);
    static 节点直接对象退役结果 提交系统角色退役(const 系统角色退役规格&);
    static 节点直接对象退役结果 提交存在场景增量退役(const 存在场景增量退役规格&);
    static 节点直接对象退役结果 提交语义概念退役(const 语义概念退役规格&);
    static 节点直接对象退役结果 提交需求任务方法用途退役(const 需求任务方法用途退役规格&);
};

}
