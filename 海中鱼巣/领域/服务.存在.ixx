// 文件规则：存在业务服务只裁决实际存在和虚拟存在业务语义，不接触仓库或事务能力。
module;

#include "../核心/句柄.h"

#include <cstdint>
#include <optional>

export module 海中鱼巣.领域.服务.存在;

import 海中鱼巣.领域.数据操作.存在场景;

export namespace 海中鱼巣 {

struct 创建实际存在请求 {
    std::uint64_t 幂等主键 = 0;
};

struct 创建虚拟存在请求 {
    std::uint64_t 幂等主键 = 0;
    节点句柄 来源;
};

struct 候选来源虚拟存在规格请求 {
    std::uint64_t 幂等主键 = 0;
    节点类型 预期来源类型 = 节点类型::未分类;
};

enum class 虚拟存在规格状态 : std::uint8_t {
    已形成 = 1,
    入口拒绝 = 2,
    许可拒绝 = 3,
    版本漂移 = 4,
    内部不一致 = 5
};

struct 虚拟存在规格结果 {
    虚拟存在规格状态 状态 = 虚拟存在规格状态::入口拒绝;
    std::optional<虚拟存在写入规格> 规格;

    bool 成功() const noexcept {
        return 状态 == 虚拟存在规格状态::已形成
            && 规格.has_value() && 规格->完整();
    }
};

class 存在业务服务 final {
public:
    explicit 存在业务服务(存在场景数据操作& 数据操作) : 数据操作_(数据操作) {
    }

    存在场景业务结果 创建实际存在(const 创建实际存在请求& 请求) const {
        if (请求.幂等主键 == 0) return {};
        const auto 当前身份 = 数据操作_.读取主键身份(请求.幂等主键);
        if (当前身份.状态 == 存在场景读取状态::未找到) {
            return 数据操作_.创建实际存在(请求.幂等主键);
        }
        if (当前身份.状态 != 存在场景读取状态::已找到) {
            return 映射读取失败(当前身份.状态);
        }
        if (当前身份.类型 != 节点类型::存在
            || 当前身份.虚拟来源.has_value()
            || 当前身份.来源关系.has_value()) {
            return {存在场景业务状态::幂等冲突};
        }
        return {存在场景业务状态::幂等读回, 当前身份.节点};
    }

    虚拟存在规格结果 形成已发布来源虚拟存在写入规格(
        const 创建虚拟存在请求& 请求) const {
        if (请求.幂等主键 == 0 || !句柄有效(请求.来源)) return {};
        const auto 来源材料 = 数据操作_.读取节点身份(请求.来源);
        if (来源材料.状态 != 存在场景读取状态::已找到) {
            return {映射规格读取失败(来源材料.状态)};
        }
        if (!是虚拟来源类型(来源材料.类型)) return {};
        虚拟存在规格结果 输出;
        输出.状态 = 虚拟存在规格状态::已形成;
        输出.规格 = 虚拟存在写入规格(
            请求.幂等主键, 来源材料.类型, 虚拟存在来源阶段::已发布);
        return 输出;
    }

    虚拟存在规格结果 形成本会话候选来源虚拟存在写入规格(
        const 候选来源虚拟存在规格请求& 请求) const {
        if (请求.幂等主键 == 0 || !是虚拟来源类型(请求.预期来源类型)) return {};
        虚拟存在规格结果 输出;
        输出.状态 = 虚拟存在规格状态::已形成;
        输出.规格 = 虚拟存在写入规格(
            请求.幂等主键, 请求.预期来源类型, 虚拟存在来源阶段::本会话候选);
        return 输出;
    }

    存在场景业务结果 创建虚拟存在(const 创建虚拟存在请求& 请求) const {
        const auto 规格结果 = 形成已发布来源虚拟存在写入规格(请求);
        if (!规格结果.成功()) return 映射规格失败(规格结果.状态);

        const auto 当前身份 = 数据操作_.读取主键身份(请求.幂等主键);
        if (当前身份.状态 == 存在场景读取状态::未找到) {
            return 数据操作_.创建虚拟存在(*规格结果.规格, 请求.来源);
        }
        if (当前身份.状态 != 存在场景读取状态::已找到) {
            return 映射读取失败(当前身份.状态);
        }
        if (当前身份.类型 != 节点类型::存在
            || 当前身份.虚拟来源 != std::optional<节点句柄>{请求.来源}
            || !当前身份.来源关系.has_value()) {
            return {存在场景业务状态::幂等冲突};
        }
        return {存在场景业务状态::幂等读回,
            当前身份.节点, {}, *当前身份.来源关系};
    }

private:
    static bool 是虚拟来源类型(节点类型 类型) noexcept {
        return 类型 == 节点类型::需求 || 类型 == 节点类型::任务 || 类型 == 节点类型::方法;
    }

    static 存在场景业务结果 映射读取失败(存在场景读取状态 状态) noexcept {
        switch (状态) {
        case 存在场景读取状态::许可拒绝:
            return {存在场景业务状态::许可拒绝};
        case 存在场景读取状态::版本漂移:
            return {存在场景业务状态::版本漂移};
        case 存在场景读取状态::内部不一致:
            return {存在场景业务状态::内部不一致};
        default:
            return {存在场景业务状态::入口拒绝};
        }
    }

    static 虚拟存在规格状态 映射规格读取失败(存在场景读取状态 状态) noexcept {
        switch (状态) {
        case 存在场景读取状态::许可拒绝:
            return 虚拟存在规格状态::许可拒绝;
        case 存在场景读取状态::版本漂移:
            return 虚拟存在规格状态::版本漂移;
        case 存在场景读取状态::内部不一致:
            return 虚拟存在规格状态::内部不一致;
        default:
            return 虚拟存在规格状态::入口拒绝;
        }
    }

    static 存在场景业务结果 映射规格失败(虚拟存在规格状态 状态) noexcept {
        switch (状态) {
        case 虚拟存在规格状态::许可拒绝:
            return {存在场景业务状态::许可拒绝};
        case 虚拟存在规格状态::版本漂移:
            return {存在场景业务状态::版本漂移};
        case 虚拟存在规格状态::内部不一致:
            return {存在场景业务状态::内部不一致};
        default:
            return {存在场景业务状态::入口拒绝};
        }
    }

    存在场景数据操作& 数据操作_;
};

}
