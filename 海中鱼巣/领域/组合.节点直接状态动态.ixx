// 文件规则：组合只组织状态迁移与动态候选的同会话顺序，不复制服务、仓库、关系或记录实现。
module;

#include "状态动态类型化记录.数据.h"

export module 海中鱼巣.领域.组合.节点直接状态动态;

export namespace 海中鱼巣 {

struct 状态动态同会话候选 final {
    完整实例状态请求 前状态请求;
    完整实例状态请求 后状态请求;
    完整动态请求 动态请求;

    bool 字段自洽() const noexcept {
        return 前状态请求.主体 == 后状态请求.主体
            && 前状态请求.场景 == 后状态请求.场景
            && 前状态请求.特征 == 后状态请求.特征
            && 前状态请求.特征值 == 后状态请求.特征值
            && 动态请求.主体 == 后状态请求.主体
            && 动态请求.场景 == 后状态请求.场景;
    }
};

class 节点直接状态动态组合 final {
public:
    static bool 形成状态迁移候选(
        const 完整实例状态请求& 前状态请求,
        const 完整实例状态请求& 后状态请求) noexcept {
        return 前状态请求.主体 == 后状态请求.主体
            && 前状态请求.场景 == 后状态请求.场景
            && 前状态请求.特征 == 后状态请求.特征
            && 前状态请求.特征值 == 后状态请求.特征值
            && 后状态请求.发生时间 >= 前状态请求.发生时间;
    }

    static bool 形成动作致变候选(
        const 完整动态请求& 请求) noexcept {
        return 请求.种类 == 动态种类::动作致变
            && 请求.来源动作.has_value()
            && 请求.同源状态迁移动能.has_value()
            && 句柄有效(*请求.来源动作)
            && 句柄有效(*请求.同源状态迁移动能);
    }

    static bool 形成聚合候选(
        const 完整动态请求& 请求) noexcept {
        return 请求.种类 == 动态种类::聚合动态
            && 请求.聚合规则版本 != 0
            && !请求.来源低层动态组.empty();
    }
};

}
