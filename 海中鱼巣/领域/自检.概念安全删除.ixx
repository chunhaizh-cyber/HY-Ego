// 文件规则：概念安全删除自检只承载隔离提交验收，不得成为私有入口友元或生产依赖。
module;

#include "../核心/主信息仓库.h"
#include "../核心/节点仓库.h"
#include "../核心/关系仓库.h"
#include "../核心/索引仓库.h"
#include "存在服务.h"
#include "动态服务.h"
#include "二次特征服务.h"
#include "因果服务.h"
#include "状态服务.h"
#include "语素服务.h"
#include "概念图服务.h"
#include "统计服务.h"

#include <algorithm>
#include <array>
#include <atomic>
#include <cstddef>
#include <cstdint>
#include <limits>
#include <iostream>
#include <optional>
#include <thread>
#include <vector>

export module 海中鱼巣.领域.自检.概念安全删除;

import 海中鱼巣.领域.初始化.概念图;
import 海中鱼巣.核心.协调.结构事务;
import 海中鱼巣.领域.服务.概念安全删除;
import 海中鱼巣.自检.运行器;

export namespace 海中鱼巣 {

自检单元结果 运行概念安全删除自检() {
    std::array<bool, 12> 验收{};
    try {
        结构事务协调器 协调器(83);
        const auto 接线 = 协调器.生成接线();
        主信息仓库 主信息(183, 接线);
        节点仓库 节点(主信息, 283, 接线);
        关系仓库 关系(节点, 383, 接线);
        索引仓库 索引(节点, 接线);
        存在服务 存在(主信息, 节点, 关系);
        动态服务 动态(主信息, 节点, 关系);
        二次特征服务 二次特征(主信息, 节点, 关系);
        因果服务 因果(主信息, 节点);
        状态服务 状态(主信息, 节点, 关系);
        语素服务 语素(主信息, 节点, 关系, 索引);
        概念图服务 概念图(节点, 关系);
        统计服务 统计;
        概念图初始化服务 初始化(概念图, 存在, 动态, 二次特征, 因果, 状态, 语素);
        const auto 初始化结果 = 初始化.初始化四个根();
        const auto 基础活动版本 = 概念图.初始化活动图基础版本();

        const auto 来源实例 = 存在.创建实际存在();
        const auto 根支持 = 概念图.确保存在实例根支持(来源实例);
        概念约束材料 约束;
        约束.维度 = 概念约束维度::特征原始值;
        约束.定义节点 = 来源实例;
        约束.值类型 = 概念约束值类型::I64;
        约束.I64值 = 83;
        概念候选输入材料 输入;
        输入.签名 = {概念根类别::存在, 1, {约束}};
        输入.来源实例 = 来源实例;
        输入.定义材料组 = {来源实例};
        const auto 发布候选 = 概念图.计算固定点候选图(
            概念图.读取活动图版本(), {输入}, 32, 8);
        const auto 发布结果 = 概念图.发布候选图版本并返回结果(
            发布候选, 存在, 动态, 二次特征, 因果);
        const auto 发布版本 = 发布结果.可读活动版本();
        auto 支持概念组 = 概念图.读取实例支持概念(来源实例);
        支持概念组.erase(std::remove(
            支持概念组.begin(), 支持概念组.end(), 初始化结果.存在根.根节点), 支持概念组.end());
        const 节点句柄 目标 = 支持概念组.size() == 1 ? 支持概念组.front() : 节点句柄{};
        const auto 支持关系组 = 关系.获取关系记录组(来源实例, 关系类型::实例支持概念);
        const auto 支持位置 = std::find_if(支持关系组.begin(), 支持关系组.end(), [&目标](const auto& 记录) {
            return 记录.目标节点 == 目标;
        });
        const 关系句柄 支持关系 = 支持位置 == 支持关系组.end()
            ? 关系句柄{}
            : 关系句柄{383, 支持位置->关系编号, 支持位置->版本号};
        const auto 支持失效 = 概念图.失效活动普通概念实例支持({
            来源实例, 目标, 支持关系, 概念图.读取活动图版本()});

        const auto 命名空间 = 统计.定义缓存命名空间(
            缓存类型::概念用途观察, 来源结构类型::概念,
            概念图.读取活动图版本(), 83, 缓存值类型::用途观察,
            false, 缓存失效条件::规则版本变化);
        const auto 目标缓存 = 统计.记录概念用途观察(
            命名空间, 目标, 概念用途类型::一般, 10, 0);
        const auto 其它缓存 = 统计.记录概念用途观察(
            命名空间, 初始化结果.存在根.根节点, 概念用途类型::一般, 11, 0);
        const 概念生命周期复核规则 规则{83, 100, 90, 80};
        const auto 冷却候选 = 概念图.读取生命周期复核候选(目标, 命名空间, 规则, 统计);
        const auto 冷却 = 冷却候选.has_value()
            ? 概念图.转换概念生命周期(
                目标, 概念生命周期阶段::冷却, 冷却候选.value(), 规则, 统计)
            : std::nullopt;
        const auto 退役候选 = 概念图.读取生命周期复核候选(目标, 命名空间, 规则, 统计);
        const auto 退役 = 退役候选.has_value()
            ? 概念图.转换概念生命周期(
                目标, 概念生命周期阶段::退役, 退役候选.value(), 规则, 统计)
            : std::nullopt;
        const auto 影响读取 = 概念图.读取概念删除影响候选({
            目标, 概念图.读取活动图版本(), 128, std::numeric_limits<std::size_t>::max()});

        std::optional<概念结构写集已补全候选> 待提交;
        if (影响读取.候选.has_value()) {
            auto 许可 = 接线.取得独占许可(接线.运行期状态);
            const auto& 令牌 = 许可.读取令牌();
            const auto& 影响 = 影响读取.候选.value();
            const auto 当前节点 = 节点.读取节点(目标, 令牌);
            const auto 当前关系 = 关系.获取节点相关关系记录组(目标, 令牌);
            const auto 当前主键 = 索引.读取节点主键组(目标, 令牌);
            if (当前节点.has_value()) {
                const auto 节点包 = 节点.准备节点删除包(目标, 令牌);
                const auto 主信息包 = 主信息.准备主信息删除包(目标, 当前节点->主信息, 令牌);
                const auto 关系包 = 关系.准备节点关系失效包(目标, 当前关系, 令牌);
                const auto 索引包 = 索引.准备节点主键删除包(目标, 当前主键, 令牌);
                const 概念结构所有者清理请求 请求{
                    目标, 当前节点->主信息, 概念结构所有者类型::存在服务, true, true};
                const auto 授权 = 存在.形成概念节点清理授权(请求, 令牌);
                const auto 缓存包 = 统计.准备概念缓存清理包(目标, 令牌);
                if (节点包.has_value() && 主信息包.has_value() && 关系包.has_value()
                    && 索引包.has_value() && 授权.has_value() && 缓存包.has_value()) {
                    待提交 = 概念图.补全概念删除结构写集(
                        影响, 节点包.value(), 主信息包.value(), 关系包.value(),
                        索引包.value(), 授权.value(), 缓存包.value(), 令牌);
                }
            }
        }

        验收[0] = 初始化结果.成功() && 基础活动版本.has_value()
            && 句柄有效(来源实例) && 根支持.has_value()
            && 发布候选.已收敛() && 发布版本.has_value() && 句柄有效(目标)
            && 支持失效.状态 == 实例支持失效状态::已失效
            && 冷却.has_value() && 退役.has_value() && 待提交.has_value();
        验收[1] = 待提交.has_value() && 待提交->完整();
        验收[2] = 目标缓存.has_value() && 其它缓存.has_value();
        验收[3] = 待提交.has_value() && 待提交->概念图包.提交材料完整();


        领域::概念安全删除回执 删除回执;
        std::atomic_size_t 关系交错{0};
        std::atomic_size_t 索引交错{0};
        std::atomic_size_t 发布交错{0};
        std::atomic_size_t 删除交错{0};
        std::atomic_bool 删除异常{false};
        const auto 甲主信息 = 主信息.创建主信息();
        const auto 乙主信息 = 主信息.创建主信息();
        const auto 甲 = 节点.创建节点(节点类型::基础信息, 甲主信息);
        const auto 乙 = 节点.创建节点(节点类型::基础信息, 乙主信息);
        std::thread 关系线程([&]() {
            for (std::size_t 次数 = 0; 次数 < 50; ++次数) {
                const auto 结果 = 关系.挂载或重挂节点(乙, 甲);
                if (结果.关系已确定()) ++关系交错;
            }
        });
        std::thread 索引线程([&]() {
            for (std::size_t 次数 = 0; 次数 < 50; ++次数) {
                const auto 主键 = 83000 + 次数;
                if (索引.绑定主键(主键, 甲) && 索引.删除主键(主键)) ++索引交错;
            }
        });
        std::thread 发布线程([&]() {
            for (std::size_t 次数 = 0; 次数 < 50; ++次数) {
                const auto 结果 = 概念图.发布候选图版本并返回结果(
                    发布候选, 存在, 动态, 二次特征, 因果);
                if (结果.可读活动版本().has_value()
                    || 结果.状态 == 候选图发布状态::基准版本过期) ++发布交错;
            }
        });
        std::thread 删除线程([&]() {
            if (!待提交.has_value()) return;
            try {
                for (std::size_t 次数 = 0; 次数 < 50; ++次数) {
                    const auto 结果 = 领域::概念安全删除编排器(
                        接线, 主信息, 节点, 关系, 索引, 概念图, 统计,
                        存在, 动态, 二次特征, 因果).提交安全删除(待提交.value());
                    if (!删除回执.已提交() && 结果.已提交()) 删除回执 = 结果;
                    if (结果.状态 == 领域::概念安全删除状态::已提交
                        || 结果.状态 == 领域::概念安全删除状态::候选已过期
                        || 结果.状态 == 领域::概念安全删除状态::提交环境繁忙) ++删除交错;
                }
            } catch (const std::exception& 异常) {
                删除异常.store(true);
                std::cout << "CONCEPT-S8-S3-EXCEPTION " << 异常.what() << std::endl;
            } catch (...) {
                删除异常.store(true);
                std::cout << "CONCEPT-S8-S3-EXCEPTION 未知" << std::endl;
            }
        });
        关系线程.join();
        索引线程.join();
        发布线程.join();
        删除线程.join();
        if (!删除回执.已提交() && 待提交.has_value()) {
            const auto 最终提交 = 领域::概念安全删除编排器(
                接线, 主信息, 节点, 关系, 索引, 概念图, 统计,
                存在, 动态, 二次特征, 因果).提交安全删除(待提交.value());
            if (最终提交.已提交()) 删除回执 = 最终提交;
        }

        const auto 其它缓存读回 = 统计.读取概念用途观察(
            命名空间, 初始化结果.存在根.根节点, 概念用途类型::一般);
        const auto 目标缓存读回 = 统计.读取概念用途观察组(命名空间, 目标);
        const auto 活动节点组 = 概念图.读取活动概念节点组();
        const auto 活动关系组 = 概念图.读取活动关系组();
        const auto 四树 = 概念图.读取全部抽象树视图();
        bool 树含目标 = false;
        if (四树.has_value()) {
            for (const auto& 树 : 四树.value()) {
                树含目标 = 树含目标 || std::any_of(
                    树.投影项组.begin(), 树.投影项组.end(), [&目标](const auto& 项) {
                        return 项.概念 == 目标;
                    });
            }
        }

        验收[4] = 删除回执.已提交() && 删除回执.剩余概念数量 == 4;
        验收[5] = !节点.读取节点(目标).has_value()
            && 节点.读取节点审计(删除回执.节点审计句柄).has_value()
            && !主信息.读取主信息(删除回执.原主信息).has_value()
            && 主信息.读取主信息审计(删除回执.主信息审计句柄).has_value();
        验收[6] = std::all_of(
            删除回执.关系审计句柄组.begin(), 删除回执.关系审计句柄组.end(),
            [&关系](const auto& 句柄) {
                const auto 记录 = 关系.读取关系审计(句柄);
                return 记录.has_value() && 记录->状态 == 记录状态::已失效;
            });
        验收[7] = 索引.读取节点主键组(目标).empty();
        验收[8] = 目标缓存读回.has_value() && 目标缓存读回->empty()
            && 其它缓存读回.has_value()
            && 其它缓存读回->概念 == 其它缓存->概念
            && 其它缓存读回->用途 == 其它缓存->用途
            && 其它缓存读回->观察次数候选 == 其它缓存->观察次数候选
            && 其它缓存读回->最近观察时间戳 == 其它缓存->最近观察时间戳;
        验收[9] = 概念图.读取活动图版本() == 删除回执.当前活动版本
            && std::find(活动节点组.begin(), 活动节点组.end(), 目标) == 活动节点组.end()
            && std::none_of(活动关系组.begin(), 活动关系组.end(), [&目标](const auto& 材料) {
                return 材料.源节点 == 目标 || 材料.目标节点 == 目标;
            })
            && 四树.has_value() && !树含目标;
        验收[10] = !删除异常.load() && 关系交错 == 50 && 索引交错 == 50
            && 发布交错 == 50 && 删除交错 == 50;
        验收[11] = 接线.已接域()
            && 概念图.读取活动概念根组().size() == 4
            && 节点.读取节点(甲).has_value()
            && 节点.读取节点(乙).has_value();
    } catch (...) {
    }

    std::size_t 失败数量 = 0;
    for (std::size_t 索引 = 0; 索引 < 验收.size(); ++索引) {
        if (!验收[索引]) ++失败数量;
        std::cout << "CONCEPT-S8-S3-A";
        if (索引 + 1 < 10) std::cout << '0';
        std::cout << 索引 + 1 << ": " << (验收[索引] ? "通过" : "失败") << std::endl;
    }
    return {"CONCEPT-S8-S3", "概念安全删除", 失败数量 == 0, 验收.size(), 失败数量};
}

}
