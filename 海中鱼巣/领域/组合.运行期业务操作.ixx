// 文件规则：运行期业务操作组合器只封装既有组合器的强类型入口，不持事务能力。
module;

#include "../核心/句柄.h"

#include <cstdint>

export module 海中鱼巣.领域.组合.运行期业务操作;

import 海中鱼巣.领域.数据操作.存在场景;
import 海中鱼巣.领域.数据操作.状态动态;
import 海中鱼巣.领域.数据操作.特征体系;
import 海中鱼巣.领域.数据操作.语素基础;
import 海中鱼巣.领域.数据操作.需求任务方法;
import 海中鱼巣.领域.数据操作.轻量因果;
import 海中鱼巣.领域.组合.存在场景;
import 海中鱼巣.领域.组合.状态动态;
import 海中鱼巣.领域.组合.特征状态;
import 海中鱼巣.领域.组合.语素概念入口;
import 海中鱼巣.领域.服务.语素;
import 海中鱼巣.领域.服务.需求;
import 海中鱼巣.领域.服务.任务;
import 海中鱼巣.领域.服务.方法;
import 海中鱼巣.领域.服务.轻量因果;
import 海中鱼巣.领域.组合.概念结构发布;
import 海中鱼巣.领域.组合.需求任务方法;
import 海中鱼巣.领域.组合.任务执行;
import 海中鱼巣.领域.组合.任务结果结算;
import 海中鱼巣.线程.协议.任务执行请求;
import 海中鱼巣.线程.任务结果回执协议;

export namespace 海中鱼巣 {

struct 运行期任务排队请求 {
    任务执行冻结请求 冻结请求;
};

struct 运行期任务执行请求 {
    任务执行冻结请求 冻结请求;
    std::uint64_t 当前时间戳 = 0;
};

struct 运行期任务收口请求 {
    任务执行冻结请求 冻结请求;
    分层任务生命周期阶段 当前阶段 = 分层任务生命周期阶段::未定义;
};

class 运行期业务操作组合器 final {
public:
    运行期业务操作组合器(
        存在场景组合器& 存在场景,
        状态动态组合器& 状态动态,
        特征状态组合器& 特征状态,
        语素概念入口组合器& 语素概念入口,
        概念结构发布组合器& 概念结构发布,
        需求任务方法组合器& 需求任务方法,
        任务执行组合器& 任务执行,
        任务结果结算组合器& 任务结果结算,
        需求业务服务& 需求服务,
        任务业务服务& 任务服务,
        方法业务服务& 方法服务,
        轻量因果业务服务& 轻量因果服务)
        : 存在场景_(存在场景),
          状态动态_(状态动态),
          特征状态_(特征状态),
          语素概念入口_(语素概念入口),
          概念结构发布_(概念结构发布),
          需求任务方法_(需求任务方法),
          任务执行_(任务执行),
          任务结果结算_(任务结果结算),
          需求服务_(需求服务),
          任务服务_(任务服务),
          方法服务_(方法服务),
          轻量因果服务_(轻量因果服务) {
    }

    bool 完整() const noexcept {
        return true;
    }

    static bool 请求完整(
        const 已有场景创建并接纳实际存在请求& 请求) noexcept {
        return 句柄有效(请求.场景) && 请求.存在幂等主键 != 0;
    }

    static bool 请求完整(const 创建状态并记录动态请求& 请求) noexcept {
        return 请求.前状态幂等主键 != 0 && 请求.后状态幂等主键 != 0
            && 请求.动态幂等主键 != 0
            && 句柄有效(请求.场景) && 句柄有效(请求.主体)
            && 句柄有效(请求.被改变目标)
            && 请求.前时间戳 != 0 && 请求.后时间戳 != 0
            && 请求.前时间戳 <= 请求.后时间戳;
    }

    static bool 请求完整(const 创建槽位并发布初始状态请求& 请求) noexcept {
        return 请求.槽位幂等主键 != 0 && 请求.特征值幂等主键 != 0
            && 句柄有效(请求.宿主) && 句柄有效(请求.特征定义);
    }

    static bool 请求完整(const 创建语素概念入口请求& 请求) noexcept {
        return 请求.幂等主键 != 0 && !请求.文本.empty()
            && 句柄有效(请求.对应信息) && 句柄有效(请求.概念追溯);
    }

    static bool 请求完整(const 发布概念结构请求& 请求) noexcept {
        if (!请求.根角色.完整() || 请求.关系组.empty()) return false;
        for (const auto& 关系 : 请求.关系组) {
            if (!关系.完整()) return false;
        }
        return true;
    }

    static bool 请求完整(const 创建需求并承接任务请求& 请求) noexcept {
        return 请求.需求.需求幂等主键 != 0
            && 请求.需求.目标状态幂等主键 != 0
            && 句柄有效(请求.需求.主体)
            && 句柄有效(请求.需求.目标宿主)
            && 句柄有效(请求.需求.场景)
            && 句柄有效(请求.需求.目标特征)
            && 句柄有效(请求.需求.当前特征状态材料)
            && 请求.任务幂等主键 != 0
            && 请求.任务虚拟存在幂等主键 != 0
            && 请求.任务初始状态幂等主键 != 0
            && 请求.任务创建时间戳 != 0;
    }

    static bool 请求完整(const 召回并提交唯一选择请求& 请求) noexcept {
        return 句柄有效(请求.召回.任务)
            && 句柄有效(请求.召回.登记根)
            && 请求.召回.排序规则版本 != 0
            && 请求.召回.召回请求规则版本 != 0
            && 请求.选择记录幂等主键 != 0
            && 请求.选择幂等材料编号 != 0;
    }

    static bool 请求完整(const 完成任务并独立结算请求& 请求) noexcept {
        return 句柄有效(请求.完成.任务)
            && 句柄有效(请求.完成.实际状态)
            && 请求.完成.完成状态幂等主键 != 0
            && 请求.完成.发生时间戳 != 0
            && 请求.结算状态幂等主键 != 0
            && 请求.结算时间戳 != 0
            && 句柄有效(请求.动态证据);
    }

    static bool 请求完整(const 任务执行调度请求& 请求) noexcept {
        return 复核任务执行调度请求(请求).成功();
    }

    static bool 请求完整(const 运行期任务排队请求& 请求) noexcept {
        return 冻结任务执行请求完整(请求.冻结请求);
    }

    static bool 请求完整(const 运行期任务执行请求& 请求) noexcept {
        return 冻结任务执行请求完整(请求.冻结请求)
            && 请求.当前时间戳 != 0;
    }

    static bool 请求完整(const 运行期任务收口请求& 请求) noexcept {
        return 冻结任务执行请求完整(请求.冻结请求)
            && (请求.当前阶段 == 分层任务生命周期阶段::排队中
                || 请求.当前阶段 == 分层任务生命周期阶段::执行中
                || 请求.当前阶段 == 分层任务生命周期阶段::等待中);
    }

    static bool 请求完整(const 任务结果治理请求& 请求) noexcept {
        return 请求.参数.当前时间戳 != 0
            && 复核任务结果回执材料(
                请求.回执,
                任务结果回执准入上下文{请求.参数.当前时间戳}).状态
                == 任务结果回执准入状态::可准入;
    }

    static bool 请求完整(const 创建完整目标状态需求请求& 请求) noexcept {
        return 请求.需求幂等主键 != 0 && 请求.目标状态幂等主键 != 0
            && 句柄有效(请求.主体) && 句柄有效(请求.目标宿主)
            && 句柄有效(请求.场景) && 句柄有效(请求.目标特征)
            && 句柄有效(请求.当前特征状态材料);
    }

    static bool 请求完整(const 创建任务承接请求& 请求) noexcept {
        return 请求.任务幂等主键 != 0 && 请求.虚拟存在幂等主键 != 0
            && 请求.初始状态幂等主键 != 0 && 句柄有效(请求.来源需求)
            && 请求.发生时间戳 != 0;
    }

    static bool 请求完整(const 迁移任务生命周期请求& 请求) noexcept {
        return 句柄有效(请求.任务) && 请求.幂等材料编号 != 0
            && 请求.发生时间戳 != 0
            && 请求.目标阶段 >= 分层任务生命周期阶段::已承接
            && 请求.目标阶段 <= 分层任务生命周期阶段::取消;
    }

    static bool 请求完整(const 创建方法首请求& 请求) noexcept {
        return 请求.方法幂等主键 != 0 && 请求.虚拟存在幂等主键 != 0
            && 请求.角色状态幂等主键 != 0 && 句柄有效(请求.登记根);
    }

    static bool 请求完整(const 创建方法结果请求& 请求) noexcept {
        return 请求.结果幂等主键 != 0 && 请求.角色状态幂等主键 != 0
            && 句柄有效(请求.方法首) && 句柄有效(请求.场景)
            && 句柄有效(请求.目标特征) && 句柄有效(请求.目标抽象状态)
            && 请求.来源版本 != 0;
    }

    static bool 请求完整(const 创建方法动作入口请求& 请求) noexcept {
        return 请求.动作幂等主键 != 0 && 请求.角色状态幂等主键 != 0
            && 请求.入口状态幂等主键 != 0 && 句柄有效(请求.方法首)
            && 句柄有效(请求.输入场景) && 句柄有效(请求.输出场景)
            && 请求.入口状态值 >= 1 && 请求.入口状态值 <= 6;
    }

    static bool 请求完整(const 创建轻量因果请求& 请求) noexcept {
        return 请求.幂等主键 != 0 && 句柄有效(请求.来源动态);
    }

    存在场景业务结果 在已有场景中创建并接纳实际存在(
        const 已有场景创建并接纳实际存在请求& 请求) const {
        return 请求完整(请求)
            ? 存在场景_.在已有场景中创建并接纳实际存在(请求)
            : 存在场景业务结果{};
    }

    状态动态业务结果 创建状态并记录动态(
        const 创建状态并记录动态请求& 请求) const {
        return 请求完整(请求)
            ? 状态动态_.创建状态并记录动态(请求)
            : 状态动态业务结果{};
    }

    特征体系业务结果 创建槽位并发布初始状态(
        const 创建槽位并发布初始状态请求& 请求) const {
        return 请求完整(请求)
            ? 特征状态_.创建槽位并发布初始状态(请求)
            : 特征体系业务结果{};
    }

    语义基础业务结果 创建语素概念入口(
        const 创建语素概念入口请求& 请求) const {
        return 请求完整(请求)
            ? 语素概念入口_.创建语素概念入口(请求)
            : 语义基础业务结果{};
    }

    概念结构发布结果 发布概念结构(
        const 发布概念结构请求& 请求) const {
        return 请求完整(请求)
            ? 概念结构发布_.发布(请求)
            : 概念结构发布结果{};
    }

    创建需求并承接任务结果 创建需求并承接任务(
        const 创建需求并承接任务请求& 请求) const {
        return 请求完整(请求)
            ? 需求任务方法_.创建需求并承接任务(请求)
            : 创建需求并承接任务结果{};
    }

    召回并提交唯一选择结果 召回并提交唯一选择(
        const 召回并提交唯一选择请求& 请求) const {
        return 请求完整(请求)
            ? 需求任务方法_.召回并提交唯一选择(请求)
            : 召回并提交唯一选择结果{};
    }

    完成任务并独立结算结果 完成任务并独立结算(
        const 完成任务并独立结算请求& 请求) const {
        return 请求完整(请求)
            ? 需求任务方法_.完成任务并独立结算(请求)
            : 完成任务并独立结算结果{};
    }

    任务执行组合结果 冻结任务执行请求(
        const 任务执行调度请求& 请求) const {
        return 请求完整(请求)
            ? 任务执行_.冻结任务执行请求(请求)
            : 任务执行组合结果{};
    }

    任务执行组合结果 确认任务进入排队中(
        const 运行期任务排队请求& 请求) const {
        return 请求完整(请求)
            ? 任务执行_.确认任务进入排队中(请求.冻结请求)
            : 任务执行组合结果{};
    }

    任务执行组合结果 执行任务目标状态值变化(
        const 运行期任务执行请求& 请求) const {
        return 请求完整(请求)
            ? 任务执行_.执行任务目标状态值变化(
                请求.冻结请求, 请求.当前时间戳)
            : 任务执行组合结果{};
    }

    任务执行组合结果 收口任务执行请求(
        const 运行期任务收口请求& 请求) const {
        return 请求完整(请求)
            ? 任务执行_.收口过期或允许拒绝请求(
                请求.冻结请求, 请求.当前阶段)
            : 任务执行组合结果{};
    }

    任务结果治理结果 处理任务执行结果(
        const 任务结果治理请求& 请求) const {
        return 请求完整(请求)
            ? 任务结果结算_.处理任务执行结果(请求)
            : 任务结果治理结果{};
    }

    需求提交结果 创建完整目标状态需求(
        const 创建完整目标状态需求请求& 请求) const {
        return 请求完整(请求)
            ? 需求服务_.创建完整目标状态需求(请求)
            : 需求提交结果{};
    }

    任务提交结果 创建已有需求承接任务(
        const 创建任务承接请求& 请求) const {
        return 请求完整(请求)
            ? 任务服务_.创建承接任务(请求)
            : 任务提交结果{};
    }

    任务提交结果 迁移任务生命周期(
        const 迁移任务生命周期请求& 请求) const {
        return 请求完整(请求)
            ? 任务服务_.迁移生命周期(请求)
            : 任务提交结果{};
    }

    方法提交结果 创建方法首(const 创建方法首请求& 请求) const {
        return 请求完整(请求)
            ? 方法服务_.创建方法首(请求)
            : 方法提交结果{};
    }

    方法提交结果 创建方法结果(const 创建方法结果请求& 请求) const {
        return 请求完整(请求)
            ? 方法服务_.创建结果(请求)
            : 方法提交结果{};
    }

    方法提交结果 创建方法动作入口(
        const 创建方法动作入口请求& 请求) const {
        return 请求完整(请求)
            ? 方法服务_.创建动作入口(请求)
            : 方法提交结果{};
    }

    轻量因果业务结果 创建轻量因果(const 创建轻量因果请求& 请求) const {
        return 请求完整(请求)
            ? 轻量因果服务_.创建轻量因果(请求)
            : 轻量因果业务结果{};
    }

    需求权威材料 读取需求(节点句柄 需求) const {
        return 需求服务_.读取需求(需求);
    }

    任务权威材料 读取任务(节点句柄 任务) const {
        return 任务服务_.读取任务(任务);
    }

    方法登记项材料 读取方法登记项(节点句柄 方法) const {
        return 方法服务_.读取登记项(方法);
    }

    轻量因果值式材料 读取轻量因果(节点句柄 因果) const {
        return 轻量因果服务_.读取轻量因果(因果);
    }

private:
    存在场景组合器& 存在场景_;
    状态动态组合器& 状态动态_;
    特征状态组合器& 特征状态_;
    语素概念入口组合器& 语素概念入口_;
    概念结构发布组合器& 概念结构发布_;
    需求任务方法组合器& 需求任务方法_;
    任务执行组合器& 任务执行_;
    任务结果结算组合器& 任务结果结算_;
    需求业务服务& 需求服务_;
    任务业务服务& 任务服务_;
    方法业务服务& 方法服务_;
    轻量因果业务服务& 轻量因果服务_;
};

}
