// 文件规则：运行期业务操作组合器只封装六个既有组合器的八类强类型入口，不持事务能力。
module;

#include "../核心/句柄.h"

#include <cstdint>

export module 海中鱼巣.领域.组合.运行期业务操作;

import 海中鱼巣.领域.数据操作.存在场景;
import 海中鱼巣.领域.数据操作.状态动态;
import 海中鱼巣.领域.数据操作.特征体系;
import 海中鱼巣.领域.数据操作.语素基础;
import 海中鱼巣.领域.组合.存在场景;
import 海中鱼巣.领域.组合.状态动态;
import 海中鱼巣.领域.组合.特征状态;
import 海中鱼巣.领域.组合.语素概念入口;
import 海中鱼巣.领域.服务.语素;
import 海中鱼巣.领域.组合.概念结构发布;
import 海中鱼巣.领域.组合.需求任务方法;

export namespace 海中鱼巣 {

class 运行期业务操作组合器 final {
public:
    运行期业务操作组合器(
        存在场景组合器& 存在场景,
        状态动态组合器& 状态动态,
        特征状态组合器& 特征状态,
        语素概念入口组合器& 语素概念入口,
        概念结构发布组合器& 概念结构发布,
        需求任务方法组合器& 需求任务方法)
        : 存在场景_(存在场景),
          状态动态_(状态动态),
          特征状态_(特征状态),
          语素概念入口_(语素概念入口),
          概念结构发布_(概念结构发布),
          需求任务方法_(需求任务方法) {
    }

    bool 完整() const noexcept {
        return true;
    }

    static bool 请求完整(
        const 已有场景创建并接纳实际存在请求& 请求) noexcept {
        return 句柄有效(请求.场景) && 请求.存在幂等主键 != 0;
    }

    static bool 请求完整(const 创建状态并记录动态请求& 请求) noexcept {
        return 请求.前状态幂等主键 != 0 && 请求.后状态幂等主键 != 0
            && 请求.动态幂等主键 != 0
            && 句柄有效(请求.场景) && 句柄有效(请求.主体)
            && 句柄有效(请求.被改变目标)
            && 请求.前时间戳 != 0 && 请求.后时间戳 != 0
            && 请求.前时间戳 <= 请求.后时间戳;
    }

    static bool 请求完整(const 创建槽位并发布初始状态请求& 请求) noexcept {
        return 请求.槽位幂等主键 != 0 && 请求.特征值幂等主键 != 0
            && 句柄有效(请求.宿主) && 句柄有效(请求.特征定义);
    }

    static bool 请求完整(const 创建语素概念入口请求& 请求) noexcept {
        return 请求.幂等主键 != 0 && !请求.文本.empty()
            && 句柄有效(请求.对应信息) && 句柄有效(请求.概念追溯);
    }

    static bool 请求完整(const 发布概念结构请求& 请求) noexcept {
        if (!请求.根角色.完整() || 请求.关系组.empty()) return false;
        for (const auto& 关系 : 请求.关系组) {
            if (!关系.完整()) return false;
        }
        return true;
    }

    static bool 请求完整(const 创建需求并承接任务请求& 请求) noexcept {
        return 请求.需求.需求幂等主键 != 0
            && 请求.需求.目标状态幂等主键 != 0
            && 句柄有效(请求.需求.主体)
            && 句柄有效(请求.需求.目标宿主)
            && 句柄有效(请求.需求.场景)
            && 句柄有效(请求.需求.目标特征)
            && 句柄有效(请求.需求.当前特征状态材料)
            && 请求.任务幂等主键 != 0
            && 请求.任务虚拟存在幂等主键 != 0
            && 请求.任务初始状态幂等主键 != 0
            && 请求.任务创建时间戳 != 0;
    }

    static bool 请求完整(const 召回并提交唯一选择请求& 请求) noexcept {
        return 句柄有效(请求.召回.任务)
            && 句柄有效(请求.召回.登记根)
            && 请求.召回.排序规则版本 != 0
            && 请求.召回.召回请求规则版本 != 0
            && 请求.选择记录幂等主键 != 0
            && 请求.选择幂等材料编号 != 0;
    }

    static bool 请求完整(const 完成任务并独立结算请求& 请求) noexcept {
        return 句柄有效(请求.完成.任务)
            && 句柄有效(请求.完成.实际状态)
            && 请求.完成.完成状态幂等主键 != 0
            && 请求.完成.发生时间戳 != 0
            && 请求.结算状态幂等主键 != 0
            && 请求.结算时间戳 != 0
            && 句柄有效(请求.动态证据);
    }

    存在场景业务结果 在已有场景中创建并接纳实际存在(
        const 已有场景创建并接纳实际存在请求& 请求) const {
        return 请求完整(请求)
            ? 存在场景_.在已有场景中创建并接纳实际存在(请求)
            : 存在场景业务结果{};
    }

    状态动态业务结果 创建状态并记录动态(
        const 创建状态并记录动态请求& 请求) const {
        return 请求完整(请求)
            ? 状态动态_.创建状态并记录动态(请求)
            : 状态动态业务结果{};
    }

    特征体系业务结果 创建槽位并发布初始状态(
        const 创建槽位并发布初始状态请求& 请求) const {
        return 请求完整(请求)
            ? 特征状态_.创建槽位并发布初始状态(请求)
            : 特征体系业务结果{};
    }

    语义基础业务结果 创建语素概念入口(
        const 创建语素概念入口请求& 请求) const {
        return 请求完整(请求)
            ? 语素概念入口_.创建语素概念入口(请求)
            : 语义基础业务结果{};
    }

    概念结构发布结果 发布概念结构(
        const 发布概念结构请求& 请求) const {
        return 请求完整(请求)
            ? 概念结构发布_.发布(请求)
            : 概念结构发布结果{};
    }

    创建需求并承接任务结果 创建需求并承接任务(
        const 创建需求并承接任务请求& 请求) const {
        return 请求完整(请求)
            ? 需求任务方法_.创建需求并承接任务(请求)
            : 创建需求并承接任务结果{};
    }

    召回并提交唯一选择结果 召回并提交唯一选择(
        const 召回并提交唯一选择请求& 请求) const {
        return 请求完整(请求)
            ? 需求任务方法_.召回并提交唯一选择(请求)
            : 召回并提交唯一选择结果{};
    }

    完成任务并独立结算结果 完成任务并独立结算(
        const 完成任务并独立结算请求& 请求) const {
        return 请求完整(请求)
            ? 需求任务方法_.完成任务并独立结算(请求)
            : 完成任务并独立结算结果{};
    }

private:
    存在场景组合器& 存在场景_;
    状态动态组合器& 状态动态_;
    特征状态组合器& 特征状态_;
    语素概念入口组合器& 语素概念入口_;
    概念结构发布组合器& 概念结构发布_;
    需求任务方法组合器& 需求任务方法_;
};

}
