// 文件规则：语素基础数据操作层封闭四仓库和结构执行器，公开面只返回值式语义材料。
module;

#include "../核心/结构事务接线.数据.h"
#include "../核心/主信息仓库.h"
#include "../核心/节点仓库.h"
#include "../核心/关系仓库.h"
#include "../核心/索引仓库.h"
#include "../核心/容错检查.h"

#include <algorithm>
#include <cstdint>
#include <optional>
#include <utility>
#include <vector>

export module 海中鱼巣.领域.数据操作.语素基础;

import 海中鱼巣.核心.执行器.结构写入;

export namespace 海中鱼巣 {

enum class 语义基础业务状态 : std::uint8_t {
    已提交 = 1,
    幂等读回 = 2,
    入口拒绝 = 3,
    幂等冲突 = 4,
    许可拒绝 = 5,
    版本漂移 = 6,
    内部不一致 = 7
};

enum class 语义基础读取状态 : std::uint8_t {
    已找到 = 1,
    未找到 = 2,
    入口拒绝 = 3,
    许可拒绝 = 4,
    版本漂移 = 5,
    类型不匹配 = 6,
    内部不一致 = 7
};

enum class 语义节点角色 : std::uint8_t {
    未定义 = 0,
    语素 = 1,
    基础信息 = 2,
    存在 = 3,
    场景 = 4,
    特征 = 5,
    特征值 = 6,
    需求 = 7,
    任务 = 8,
    方法 = 9,
    抽象动态 = 10,
    实例动态 = 11,
    因果引用 = 12,
    抽象状态 = 13,
    实例状态 = 14,
    二次特征 = 15,
    任务方法选择记录 = 16
};

enum class 语素关系角色 : std::uint8_t {
    未定义 = 0,
    对应信息 = 1,
    概念追溯 = 2
};

struct 语义关系证据 {
    关系句柄 关系;
    关系类型 类型 = 关系类型::普通父子;
    节点句柄 源节点;
    节点句柄 目标节点;
    std::int64_t 顺序号 = 0;

    bool 完整() const noexcept {
        return 句柄有效(关系) && 句柄有效(源节点) && 句柄有效(目标节点);
    }
};

struct 语义节点身份 {
    语义基础读取状态 状态 = 语义基础读取状态::入口拒绝;
    节点句柄 节点;
    节点类型 类型 = 节点类型::未分类;
    语义节点角色 角色 = 语义节点角色::未定义;
    主信息句柄 主信息;

    bool 当前可读() const noexcept {
        return 状态 == 语义基础读取状态::已找到 && 句柄有效(节点)
            && 句柄有效(主信息) && 角色 != 语义节点角色::未定义;
    }
};

struct 基础信息值式材料 {
    语义基础读取状态 状态 = 语义基础读取状态::入口拒绝;
    std::uint64_t 幂等主键 = 0;
    节点句柄 基础信息;
    主信息句柄 主信息;

    bool 完整() const noexcept {
        return 状态 == 语义基础读取状态::已找到 && 幂等主键 != 0
            && 句柄有效(基础信息) && 句柄有效(主信息);
    }
};

struct 语素入口值式材料 {
    语义基础读取状态 状态 = 语义基础读取状态::入口拒绝;
    std::uint64_t 幂等主键 = 0;
    节点句柄 语素入口;
    主信息句柄 主信息;
    std::vector<节点句柄> 对应信息组;
    std::vector<语义关系证据> 对应关系组;
    std::vector<节点句柄> 概念追溯组;
    std::vector<语义关系证据> 追溯关系组;

    bool 完整() const noexcept {
        if (状态 != 语义基础读取状态::已找到 || 幂等主键 == 0
            || !句柄有效(语素入口) || !句柄有效(主信息)
            || 对应信息组.empty() || 对应信息组.size() != 对应关系组.size()
            || 概念追溯组.size() != 追溯关系组.size()) return false;
        for (std::size_t 索引 = 0; 索引 < 对应关系组.size(); ++索引) {
            if (!句柄有效(对应信息组[索引]) || !对应关系组[索引].完整()
                || 对应关系组[索引].类型 != 关系类型::语素对应信息
                || 对应关系组[索引].源节点 != 语素入口
                || 对应关系组[索引].目标节点 != 对应信息组[索引]) return false;
        }
        for (std::size_t 索引 = 0; 索引 < 追溯关系组.size(); ++索引) {
            if (!句柄有效(概念追溯组[索引]) || !追溯关系组[索引].完整()
                || 追溯关系组[索引].类型 != 关系类型::语素概念追溯
                || 追溯关系组[索引].源节点 != 语素入口
                || 追溯关系组[索引].目标节点 != 概念追溯组[索引]) return false;
        }
        return true;
    }

    bool 包含关系(语素关系角色 角色, 节点句柄 目标) const noexcept {
        const auto& 目标组 = 角色 == 语素关系角色::对应信息 ? 对应信息组 : 概念追溯组;
        return std::count(目标组.begin(), 目标组.end(), 目标) == 1;
    }
};

struct 概念名称入口组读取结果 {
    语义基础读取状态 状态 = 语义基础读取状态::入口拒绝;
    节点句柄 概念;
    std::vector<语素入口值式材料> 名称入口组;

    bool 成功() const noexcept {
        return 状态 == 语义基础读取状态::已找到 && 句柄有效(概念);
    }
};

struct 语义基础业务结果 {
    语义基础业务状态 状态 = 语义基础业务状态::入口拒绝;
    基础信息值式材料 基础信息;
    语素入口值式材料 语素;

    bool 成功() const noexcept {
        return 状态 == 语义基础业务状态::已提交
            || 状态 == 语义基础业务状态::幂等读回;
    }

    bool 改变了结构() const noexcept {
        return 状态 == 语义基础业务状态::已提交;
    }
};

class 语素入口写入规格 final {
public:
    语素入口写入规格() = delete;

    std::uint64_t 读取幂等主键() const noexcept { return 幂等主键_; }
    节点句柄 读取对应信息() const noexcept { return 对应信息_; }
    语义节点角色 读取对应角色() const noexcept { return 对应角色_; }
    const std::optional<节点句柄>& 读取概念追溯() const noexcept { return 概念追溯_; }
    语义节点角色 读取追溯角色() const noexcept { return 追溯角色_; }

    bool 完整() const noexcept {
        return 幂等主键_ != 0 && 句柄有效(对应信息_)
            && 对应角色_ != 语义节点角色::未定义
            && (概念追溯_.has_value()
                ? 句柄有效(*概念追溯_) && 追溯角色_ != 语义节点角色::未定义
                : 追溯角色_ == 语义节点角色::未定义);
    }

private:
    friend class 语素基础数据操作;

    语素入口写入规格(
        std::uint64_t 幂等主键,
        节点句柄 对应信息,
        语义节点角色 对应角色,
        std::optional<节点句柄> 概念追溯,
        语义节点角色 追溯角色)
        : 幂等主键_(幂等主键), 对应信息_(对应信息), 对应角色_(对应角色),
          概念追溯_(概念追溯), 追溯角色_(追溯角色) {}

    std::uint64_t 幂等主键_ = 0;
    节点句柄 对应信息_;
    语义节点角色 对应角色_ = 语义节点角色::未定义;
    std::optional<节点句柄> 概念追溯_;
    语义节点角色 追溯角色_ = 语义节点角色::未定义;
};

class 语素基础数据操作 final {
public:
    语素基础数据操作(
        结构事务接线 接线,
        主信息仓库& 主信息,
        节点仓库& 节点,
        关系仓库& 关系,
        索引仓库& 索引,
        std::uint64_t 关系仓库编号)
        : 接线_(std::move(接线)), 主信息_(主信息), 节点_(节点), 关系_(关系),
          索引_(索引), 关系仓库编号_(关系仓库编号),
          执行器_(接线_, &主信息_, &节点_, &关系_, &索引_) {}

    bool 有效() const noexcept {
        return 接线_.已接域() && 关系仓库编号_ != 0 && 执行器_.有效();
    }

    std::optional<语素入口写入规格> 形成语素入口写入规格(
        std::uint64_t 幂等主键,
        节点句柄 对应信息,
        语义节点角色 对应角色,
        std::optional<节点句柄> 概念追溯,
        语义节点角色 追溯角色) const {
        语素入口写入规格 规格(
            幂等主键, 对应信息, 对应角色, 概念追溯, 追溯角色);
        return 规格.完整()
            ? std::optional<语素入口写入规格>{std::move(规格)}
            : std::nullopt;
    }

    语义节点身份 读取节点身份(节点句柄 目标) const {
        if (!有效() || !句柄有效(目标)) return {};
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) return {语义基础读取状态::许可拒绝};
        return 读取节点身份_已许可(目标, 许可.读取令牌());
    }

    基础信息值式材料 读取基础信息(节点句柄 目标) const {
        if (!有效() || !句柄有效(目标)) return {};
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) return {语义基础读取状态::许可拒绝};
        return 读取基础信息_已许可(目标, std::nullopt, 许可.读取令牌());
    }

    基础信息值式材料 读取主键基础信息(std::uint64_t 主键) const {
        if (!有效() || 主键 == 0) return {};
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) return {语义基础读取状态::许可拒绝};
        const auto 目标 = 索引_.按主键查节点(主键, 许可.读取令牌());
        if (!目标.has_value()) return {语义基础读取状态::未找到};
        return 读取基础信息_已许可(*目标, 主键, 许可.读取令牌());
    }

    语素入口值式材料 读取语素入口(节点句柄 目标) const {
        if (!有效() || !句柄有效(目标)) return {};
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) return {语义基础读取状态::许可拒绝};
        return 读取语素入口_已许可(目标, std::nullopt, 许可.读取令牌());
    }

    语素入口值式材料 读取主键语素入口(std::uint64_t 主键) const {
        if (!有效() || 主键 == 0) return {};
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) return {语义基础读取状态::许可拒绝};
        const auto 目标 = 索引_.按主键查节点(主键, 许可.读取令牌());
        if (!目标.has_value()) return {语义基础读取状态::未找到};
        return 读取语素入口_已许可(*目标, 主键, 许可.读取令牌());
    }

    概念名称入口组读取结果 读取概念名称入口组(节点句柄 概念) const {
        概念名称入口组读取结果 输出;
        输出.概念 = 概念;
        if (!有效() || !句柄有效(概念)) return 输出;
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) {
            输出.状态 = 语义基础读取状态::许可拒绝;
            return 输出;
        }
        const auto 概念身份 = 读取节点身份_已许可(概念, 许可.读取令牌());
        if (!概念身份.当前可读()) {
            输出.状态 = 概念身份.状态;
            return 输出;
        }
        if (!允许概念追溯角色(概念身份.角色)) {
            输出.状态 = 语义基础读取状态::类型不匹配;
            return 输出;
        }
        for (const auto& 记录 : 关系_.获取来源关系记录组(
                 概念, 关系类型::语素概念追溯, 许可.读取令牌())) {
            const auto 证据 = 读取关系证据_已许可(记录, 许可.读取令牌());
            if (!证据.has_value() || 证据->类型 != 关系类型::语素概念追溯
                || 证据->源节点 != 记录.源节点 || 证据->目标节点 != 概念
                || std::find_if(
                    输出.名称入口组.begin(), 输出.名称入口组.end(),
                    [&](const 语素入口值式材料& 已有) {
                        return 已有.语素入口 == 记录.源节点;
                    }) != 输出.名称入口组.end()) {
                return 名称入口组内部不一致(概念, L"概念名称反向关系无法唯一按完整句柄读回。");
            }
            const auto 语素 = 读取语素入口_已许可(
                记录.源节点, std::nullopt, 许可.读取令牌());
            if (!语素.完整() || !语素.包含关系(语素关系角色::概念追溯, 概念)
                || std::count_if(
                    语素.追溯关系组.begin(), 语素.追溯关系组.end(),
                    [&](const 语义关系证据& 当前) {
                        return 当前.关系 == 证据->关系 && 当前.源节点 == 证据->源节点
                            && 当前.目标节点 == 证据->目标节点
                            && 当前.类型 == 证据->类型 && 当前.顺序号 == 证据->顺序号;
                    }) != 1) {
                return 名称入口组内部不一致(概念, L"概念名称语素材料与反向关系互证矛盾。");
            }
            输出.名称入口组.push_back(语素);
        }
        std::sort(
            输出.名称入口组.begin(), 输出.名称入口组.end(),
            [](const 语素入口值式材料& 左, const 语素入口值式材料& 右) {
                if (左.语素入口.仓库编号 != 右.语素入口.仓库编号) {
                    return 左.语素入口.仓库编号 < 右.语素入口.仓库编号;
                }
                if (左.语素入口.节点编号 != 右.语素入口.节点编号) {
                    return 左.语素入口.节点编号 < 右.语素入口.节点编号;
                }
                return 左.语素入口.版本号 < 右.语素入口.版本号;
            });
        输出.状态 = 语义基础读取状态::已找到;
        return 输出;
    }

    语义基础业务结果 创建基础信息(std::uint64_t 主键) const {
        if (!有效() || 主键 == 0) return {};
        const auto 写前 = 读取主键基础信息(主键);
        if (写前.完整()) return 形成基础信息结果(语义基础业务状态::幂等读回, 写前);
        if (写前.状态 != 语义基础读取状态::未找到) return 从读取冲突形成结果(写前.状态);

        主信息句柄 新主信息;
        节点句柄 新节点;
        const auto 结构结果 = 执行器_.执行([&](结构写入会话& 会话) {
            if (!写入带主键节点_会话(
                    会话, 节点类型::基础信息, 主键, 新主信息, 新节点)) return;
            (void)会话.请求提交();
        });
        const auto 当前 = 读取主键基础信息(主键);
        if (当前.完整()) {
            return 形成基础信息结果(
                结构结果.状态 == 结构写入状态::已提交
                    ? 语义基础业务状态::已提交
                    : 语义基础业务状态::幂等读回,
                当前);
        }
        return 映射结构失败(结构结果, 当前.状态, L"基础信息身份写入后无法完整读回。");
    }

    语义基础业务结果 创建语素入口(const 语素入口写入规格& 规格) const {
        if (!有效() || !规格.完整()) return {};
        const auto 对应身份 = 读取节点身份(规格.读取对应信息());
        if (!对应身份.当前可读() || 对应身份.角色 != 规格.读取对应角色()) {
            return 从读取失败形成结果(对应身份.状态);
        }
        std::optional<语义节点身份> 追溯身份;
        if (规格.读取概念追溯().has_value()) {
            追溯身份 = 读取节点身份(*规格.读取概念追溯());
            if (!追溯身份->当前可读() || 追溯身份->角色 != 规格.读取追溯角色()) {
                return 从读取失败形成结果(追溯身份->状态);
            }
        }

        const auto 写前 = 读取主键语素入口(规格.读取幂等主键());
        if (写前.完整()) {
            return 匹配语素入口(写前, 规格)
                ? 形成语素结果(语义基础业务状态::幂等读回, 写前)
                : 语义基础业务结果{语义基础业务状态::幂等冲突};
        }
        if (写前.状态 != 语义基础读取状态::未找到) return 从读取冲突形成结果(写前.状态);

        主信息句柄 新主信息;
        节点句柄 新语素;
        bool 写前漂移 = false;
        const auto 结构结果 = 执行器_.执行([&](结构写入会话& 会话) {
            if (!验证身份_会话(会话, 对应身份)) {
                写前漂移 = true;
                return;
            }
            if (追溯身份.has_value() && !验证身份_会话(会话, *追溯身份)) {
                写前漂移 = true;
                return;
            }
            if (!写入带主键节点_会话(
                    会话, 节点类型::语素, 规格.读取幂等主键(), 新主信息, 新语素)) return;
            const auto 对应关系 = 会话.创建关系(
                关系类型::语素对应信息, 新语素, 规格.读取对应信息());
            if (!对应关系.成功() || !会话.关系可读(*对应关系.值)) return;
            if (规格.读取概念追溯().has_value()) {
                const auto 追溯关系 = 会话.创建关系(
                    关系类型::语素概念追溯, 新语素, *规格.读取概念追溯());
                if (!追溯关系.成功() || !会话.关系可读(*追溯关系.值)) return;
            }
            (void)会话.请求提交();
        });

        const auto 当前 = 读取主键语素入口(规格.读取幂等主键());
        if (当前.完整() && 匹配语素入口(当前, 规格)) {
            return 形成语素结果(
                结构结果.状态 == 结构写入状态::已提交
                    ? 语义基础业务状态::已提交
                    : 语义基础业务状态::幂等读回,
                当前);
        }
        if (当前.完整()) return {语义基础业务状态::幂等冲突};
        if (写前漂移) return {语义基础业务状态::版本漂移};
        return 映射结构失败(结构结果, 当前.状态, L"语素入口写入后无法完整读回。");
    }

    语义基础业务结果 追加语素关系(
        节点句柄 语素入口,
        节点句柄 目标,
        语素关系角色 关系角色,
        语义节点角色 目标角色) const {
        if (!有效() || !句柄有效(语素入口) || !句柄有效(目标)
            || (关系角色 != 语素关系角色::对应信息
                && 关系角色 != 语素关系角色::概念追溯)
            || 目标角色 == 语义节点角色::未定义) return {};
        const auto 语素 = 读取语素入口(语素入口);
        const auto 目标身份 = 读取节点身份(目标);
        if (!语素.完整() || !目标身份.当前可读() || 目标身份.角色 != 目标角色) {
            return 合并读取失败(语素.状态, 目标身份.状态);
        }
        if (语素.包含关系(关系角色, 目标)) {
            return 形成语素结果(语义基础业务状态::幂等读回, 语素);
        }
        const auto 类型 = 关系角色 == 语素关系角色::对应信息
            ? 关系类型::语素对应信息 : 关系类型::语素概念追溯;
        bool 新建关系 = false;
        bool 写前漂移 = false;
        const auto 结构结果 = 执行器_.执行([&](结构写入会话& 会话) {
            if (!验证语素_会话(会话, 语素) || !验证身份_会话(会话, 目标身份)) {
                写前漂移 = true;
                return;
            }
            const auto 结果 = 会话.创建关系(类型, 语素入口, 目标);
            if (!结果.成功() || !结果.值.has_value() || !会话.关系可读(*结果.值)) return;
            新建关系 = 结果.操作.改变了结构();
            (void)会话.请求提交();
        });
        const auto 当前 = 读取语素入口(语素入口);
        if (当前.完整() && 当前.包含关系(关系角色, 目标)) {
            return 形成语素结果(
                结构结果.状态 == 结构写入状态::已提交 && 新建关系
                    ? 语义基础业务状态::已提交
                    : 语义基础业务状态::幂等读回,
                当前);
        }
        if (写前漂移) return {语义基础业务状态::版本漂移};
        return 映射结构失败(结构结果, 当前.状态, L"语素关系追加后无法完整读回。");
    }

private:
    static 节点类型 角色节点类型(语义节点角色 角色) noexcept {
        switch (角色) {
        case 语义节点角色::语素: return 节点类型::语素;
        case 语义节点角色::基础信息: return 节点类型::基础信息;
        case 语义节点角色::存在: return 节点类型::存在;
        case 语义节点角色::场景: return 节点类型::场景;
        case 语义节点角色::特征: return 节点类型::特征;
        case 语义节点角色::特征值: return 节点类型::特征值;
        case 语义节点角色::需求: return 节点类型::需求;
        case 语义节点角色::任务: return 节点类型::任务;
        case 语义节点角色::方法: return 节点类型::方法;
        case 语义节点角色::抽象动态:
        case 语义节点角色::实例动态: return 节点类型::动态;
        case 语义节点角色::因果引用: return 节点类型::因果引用;
        case 语义节点角色::抽象状态:
        case 语义节点角色::实例状态: return 节点类型::状态;
        case 语义节点角色::二次特征: return 节点类型::二次特征;
        case 语义节点角色::任务方法选择记录: return 节点类型::任务方法选择记录;
        default: return 节点类型::未分类;
        }
    }

    语义节点角色 识别节点角色_已许可(
        节点句柄 目标,
        节点类型 类型,
        const 结构事务令牌& 令牌) const {
        switch (类型) {
        case 节点类型::语素: return 语义节点角色::语素;
        case 节点类型::基础信息: return 语义节点角色::基础信息;
        case 节点类型::存在: return 语义节点角色::存在;
        case 节点类型::场景: return 语义节点角色::场景;
        case 节点类型::特征: return 语义节点角色::特征;
        case 节点类型::特征值: return 语义节点角色::特征值;
        case 节点类型::需求: return 语义节点角色::需求;
        case 节点类型::任务: return 语义节点角色::任务;
        case 节点类型::方法: return 语义节点角色::方法;
        case 节点类型::动态:
            return 关系_.存在目标关系(关系类型::运行期临时, 目标, 令牌)
                ? 语义节点角色::实例动态 : 语义节点角色::抽象动态;
        case 节点类型::因果引用: return 语义节点角色::因果引用;
        case 节点类型::状态:
            return 关系_.存在目标关系(关系类型::运行期临时, 目标, 令牌)
                ? 语义节点角色::实例状态 : 语义节点角色::抽象状态;
        case 节点类型::二次特征: return 语义节点角色::二次特征;
        case 节点类型::任务方法选择记录: return 语义节点角色::任务方法选择记录;
        default: return 语义节点角色::未定义;
        }
    }

    语义节点身份 读取节点身份_已许可(
        节点句柄 目标,
        const 结构事务令牌& 令牌) const {
        语义节点身份 输出;
        输出.节点 = 目标;
        if (!句柄有效(目标)) return 输出;
        const auto 记录 = 节点_.读取节点(目标, 令牌);
        if (!记录.has_value()) {
            输出.状态 = 语义基础读取状态::版本漂移;
            return 输出;
        }
        if (!主信息_.读取主信息(记录->主信息, 令牌).has_value()) {
            return 身份内部不一致(目标, L"语义节点缺少当前可读主信息锚点。");
        }
        const auto 角色 = 识别节点角色_已许可(目标, 记录->类型, 令牌);
        if (角色 == 语义节点角色::未定义) {
            输出.状态 = 语义基础读取状态::类型不匹配;
            return 输出;
        }
        输出.状态 = 语义基础读取状态::已找到;
        输出.类型 = 记录->类型;
        输出.角色 = 角色;
        输出.主信息 = 记录->主信息;
        return 输出;
    }

    语义节点身份 身份内部不一致(节点句柄 目标, const wchar_t* 说明) const {
        (void)追根因检查(false, 说明);
        语义节点身份 输出;
        输出.状态 = 语义基础读取状态::内部不一致;
        输出.节点 = 目标;
        return 输出;
    }

    std::optional<std::uint64_t> 读取唯一主键_已许可(
        节点句柄 目标,
        std::optional<std::uint64_t> 期望主键,
        const 结构事务令牌& 令牌) const {
        const auto 主键组 = 索引_.读取节点主键组(目标, 令牌);
        if (主键组.size() != 1 || 主键组.front() == 0) return std::nullopt;
        if (期望主键.has_value() && 主键组.front() != *期望主键) return std::nullopt;
        if (索引_.按主键查节点(主键组.front(), 令牌) != std::optional<节点句柄>{目标}) {
            return std::nullopt;
        }
        return 主键组.front();
    }

    std::optional<语义关系证据> 读取关系证据_已许可(
        const 关系记录& 记录,
        const 结构事务令牌& 令牌) const {
        if (记录.状态 != 记录状态::有效 || !句柄有效(记录.源节点)
            || !句柄有效(记录.目标节点)) return std::nullopt;
        const 关系句柄 句柄{关系仓库编号_, 记录.关系编号, 记录.版本号};
        const auto 当前 = 关系_.读取关系(句柄, 令牌);
        if (!当前.has_value() || 当前->状态 != 记录状态::有效
            || 当前->类型 != 记录.类型 || 当前->源节点 != 记录.源节点
            || 当前->目标节点 != 记录.目标节点 || 当前->顺序号 != 记录.顺序号) {
            return std::nullopt;
        }
        return 语义关系证据{句柄, 记录.类型, 记录.源节点, 记录.目标节点, 记录.顺序号};
    }

    基础信息值式材料 读取基础信息_已许可(
        节点句柄 目标,
        std::optional<std::uint64_t> 期望主键,
        const 结构事务令牌& 令牌) const {
        基础信息值式材料 输出;
        输出.基础信息 = 目标;
        const auto 身份 = 读取节点身份_已许可(目标, 令牌);
        if (!身份.当前可读()) {
            输出.状态 = 身份.状态;
            return 输出;
        }
        if (身份.类型 != 节点类型::基础信息) {
            输出.状态 = 语义基础读取状态::类型不匹配;
            return 输出;
        }
        const auto 主键 = 读取唯一主键_已许可(目标, 期望主键, 令牌);
        if (!主键.has_value()) return 基础信息内部不一致(目标, L"基础信息身份没有唯一非零主键。");
        输出.状态 = 语义基础读取状态::已找到;
        输出.幂等主键 = *主键;
        输出.主信息 = 身份.主信息;
        return 输出;
    }

    基础信息值式材料 基础信息内部不一致(节点句柄 目标, const wchar_t* 说明) const {
        (void)追根因检查(false, 说明);
        基础信息值式材料 输出;
        输出.状态 = 语义基础读取状态::内部不一致;
        输出.基础信息 = 目标;
        return 输出;
    }

    语素入口值式材料 读取语素入口_已许可(
        节点句柄 目标,
        std::optional<std::uint64_t> 期望主键,
        const 结构事务令牌& 令牌) const {
        语素入口值式材料 输出;
        输出.语素入口 = 目标;
        const auto 身份 = 读取节点身份_已许可(目标, 令牌);
        if (!身份.当前可读()) {
            输出.状态 = 身份.状态;
            return 输出;
        }
        if (身份.类型 != 节点类型::语素) {
            输出.状态 = 语义基础读取状态::类型不匹配;
            return 输出;
        }
        const auto 主键 = 读取唯一主键_已许可(目标, 期望主键, 令牌);
        if (!主键.has_value()) return 语素内部不一致(目标, L"语素入口没有唯一非零主键。");
        输出.幂等主键 = *主键;
        输出.主信息 = 身份.主信息;
        if (!读取语素关系组_已许可(
                目标, 关系类型::语素对应信息,
                输出.对应信息组, 输出.对应关系组, 令牌)
            || !读取语素关系组_已许可(
                目标, 关系类型::语素概念追溯,
                输出.概念追溯组, 输出.追溯关系组, 令牌)) {
            return 语素内部不一致(目标, L"语素入口关系无法按完整句柄读回。");
        }
        if (输出.对应信息组.empty()) {
            return 语素内部不一致(目标, L"语素入口缺少对应信息关系。");
        }
        输出.状态 = 语义基础读取状态::已找到;
        return 输出;
    }

    bool 读取语素关系组_已许可(
        节点句柄 语素入口,
        关系类型 类型,
        std::vector<节点句柄>& 目标组,
        std::vector<语义关系证据>& 证据组,
        const 结构事务令牌& 令牌) const {
        for (const auto& 记录 : 关系_.获取关系记录组(语素入口, 类型, 令牌)) {
            const auto 证据 = 读取关系证据_已许可(记录, 令牌);
            const auto 目标身份 = 读取节点身份_已许可(记录.目标节点, 令牌);
            const bool 角色允许 = 类型 == 关系类型::语素对应信息
                ? 允许对应信息角色(目标身份.角色)
                : 允许概念追溯角色(目标身份.角色);
            if (!证据.has_value() || !目标身份.当前可读() || !角色允许
                || 证据->类型 != 类型 || 证据->源节点 != 语素入口
                || std::find(目标组.begin(), 目标组.end(), 记录.目标节点) != 目标组.end()) {
                return false;
            }
            目标组.push_back(记录.目标节点);
            证据组.push_back(*证据);
        }
        return true;
    }

    语素入口值式材料 语素内部不一致(节点句柄 目标, const wchar_t* 说明) const {
        (void)追根因检查(false, 说明);
        语素入口值式材料 输出;
        输出.状态 = 语义基础读取状态::内部不一致;
        输出.语素入口 = 目标;
        return 输出;
    }

    概念名称入口组读取结果 名称入口组内部不一致(
        节点句柄 概念,
        const wchar_t* 说明) const {
        (void)追根因检查(false, 说明);
        概念名称入口组读取结果 输出;
        输出.状态 = 语义基础读取状态::内部不一致;
        输出.概念 = 概念;
        return 输出;
    }

    static bool 写入带主键节点_会话(
        结构写入会话& 会话,
        节点类型 类型,
        std::uint64_t 主键,
        主信息句柄& 新主信息,
        节点句柄& 新节点) {
        const auto 主结果 = 会话.创建主信息候选();
        if (!主结果.成功() || !主结果.值.has_value()) return false;
        新主信息 = *主结果.值;
        const auto 节点结果 = 会话.创建节点候选(类型, 新主信息);
        if (!节点结果.成功() || !节点结果.值.has_value()) return false;
        新节点 = *节点结果.值;
        if (!会话.绑定主键(主键, 新节点).成功()) return false;
        return 会话.主信息可读(新主信息) && 会话.节点可读(新节点)
            && 会话.主键绑定匹配(主键, 新节点);
    }

    static bool 允许对应信息角色(语义节点角色 角色) noexcept {
        return 角色 == 语义节点角色::基础信息 || 角色 == 语义节点角色::存在
            || 角色 == 语义节点角色::场景 || 角色 == 语义节点角色::特征
            || 角色 == 语义节点角色::抽象状态 || 角色 == 语义节点角色::抽象动态
            || 角色 == 语义节点角色::二次特征 || 角色 == 语义节点角色::因果引用
            || 角色 == 语义节点角色::需求 || 角色 == 语义节点角色::任务
            || 角色 == 语义节点角色::方法;
    }

    static bool 允许概念追溯角色(语义节点角色 角色) noexcept {
        return 角色 == 语义节点角色::基础信息 || 角色 == 语义节点角色::存在
            || 角色 == 语义节点角色::特征 || 角色 == 语义节点角色::抽象状态
            || 角色 == 语义节点角色::抽象动态 || 角色 == 语义节点角色::二次特征
            || 角色 == 语义节点角色::因果引用;
    }

    static bool 验证身份_会话(
        结构写入会话& 会话,
        const 语义节点身份& 身份) {
        return 身份.当前可读()
            && 会话.读取节点类型(身份.节点) == std::optional<节点类型>{角色节点类型(身份.角色)}
            && 会话.读取节点主信息(身份.节点) == std::optional<主信息句柄>{身份.主信息};
    }

    static bool 验证语素_会话(
        结构写入会话& 会话,
        const 语素入口值式材料& 语素) {
        return 语素.完整()
            && 会话.读取节点类型(语素.语素入口) == std::optional<节点类型>{节点类型::语素}
            && 会话.读取节点主信息(语素.语素入口) == std::optional<主信息句柄>{语素.主信息};
    }

    static bool 匹配语素入口(
        const 语素入口值式材料& 材料,
        const 语素入口写入规格& 规格) noexcept {
        return 材料.完整() && 材料.幂等主键 == 规格.读取幂等主键()
            && 材料.包含关系(语素关系角色::对应信息, 规格.读取对应信息())
            && (!规格.读取概念追溯().has_value()
                || 材料.包含关系(语素关系角色::概念追溯, *规格.读取概念追溯()));
    }

    static 语义基础业务结果 形成基础信息结果(
        语义基础业务状态 状态,
        const 基础信息值式材料& 材料) {
        语义基础业务结果 输出;
        输出.状态 = 状态;
        输出.基础信息 = 材料;
        return 输出;
    }

    static 语义基础业务结果 形成语素结果(
        语义基础业务状态 状态,
        const 语素入口值式材料& 材料) {
        语义基础业务结果 输出;
        输出.状态 = 状态;
        输出.语素 = 材料;
        return 输出;
    }

    static 语义基础业务结果 合并读取失败(
        语义基础读取状态 左,
        语义基础读取状态 右) noexcept {
        if (左 == 语义基础读取状态::内部不一致
            || 右 == 语义基础读取状态::内部不一致) return {语义基础业务状态::内部不一致};
        if (左 == 语义基础读取状态::许可拒绝
            || 右 == 语义基础读取状态::许可拒绝) return {语义基础业务状态::许可拒绝};
        if (左 == 语义基础读取状态::版本漂移
            || 右 == 语义基础读取状态::版本漂移) return {语义基础业务状态::版本漂移};
        return {语义基础业务状态::入口拒绝};
    }

    static 语义基础业务结果 从读取失败形成结果(语义基础读取状态 状态) noexcept {
        switch (状态) {
        case 语义基础读取状态::许可拒绝:
            return {语义基础业务状态::许可拒绝};
        case 语义基础读取状态::版本漂移:
            return {语义基础业务状态::版本漂移};
        case 语义基础读取状态::内部不一致:
            return {语义基础业务状态::内部不一致};
        default:
            return {语义基础业务状态::入口拒绝};
        }
    }

    static 语义基础业务结果 从读取冲突形成结果(语义基础读取状态 状态) noexcept {
        if (状态 == 语义基础读取状态::类型不匹配) {
            return {语义基础业务状态::幂等冲突};
        }
        return 从读取失败形成结果(状态);
    }

    static 语义基础业务结果 映射结构失败(
        const 结构写入结果& 结果,
        语义基础读取状态 读回状态,
        const wchar_t* 说明) {
        if (读回状态 == 语义基础读取状态::类型不匹配) {
            return {语义基础业务状态::幂等冲突};
        }
        switch (结果.状态) {
        case 结构写入状态::许可拒绝:
            return {语义基础业务状态::许可拒绝};
        case 结构写入状态::版本漂移:
            return {语义基础业务状态::版本漂移};
        default:
            (void)追根因检查(false, 说明);
            return {语义基础业务状态::内部不一致};
        }
    }

    结构事务接线 接线_;
    主信息仓库& 主信息_;
    节点仓库& 节点_;
    关系仓库& 关系_;
    索引仓库& 索引_;
    std::uint64_t 关系仓库编号_ = 0;
    结构写入执行器 执行器_;
};

}
