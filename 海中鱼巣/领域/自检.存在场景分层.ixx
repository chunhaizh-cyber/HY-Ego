// 文件规则：存在场景分层自检只验证隔离业务路径、并发幂等和失败收口，不进入生产依赖。
module;

#include "../核心/主信息仓库.h"
#include "../核心/节点仓库.h"
#include "../核心/关系仓库.h"
#include "../核心/索引仓库.h"

#include <algorithm>
#include <array>
#include <cstddef>
#include <cstdint>
#include <iostream>
#include <optional>
#include <thread>
#include <type_traits>
#include <utility>
#include <vector>

export module 海中鱼巣.领域.自检.存在场景分层;

import 海中鱼巣.核心.协调.结构事务;
import 海中鱼巣.核心.执行器.结构写入;
import 海中鱼巣.领域.数据操作.存在场景;
import 海中鱼巣.领域.服务.存在;
import 海中鱼巣.领域.服务.场景;
import 海中鱼巣.领域.组合.存在场景;
import 海中鱼巣.自检.运行器;

export namespace 海中鱼巣 {

namespace 存在场景分层自检内部 {

struct 结构数量 {
    std::uint64_t 节点 = 0;
    std::uint64_t 关系 = 0;
    std::uint64_t 索引 = 0;

    bool operator==(const 结构数量&) const = default;
};

bool 是实际存在材料(const 节点身份材料& 材料) {
    return 材料.当前可读() && 材料.类型 == 节点类型::存在
        && !材料.虚拟来源.has_value() && !材料.来源关系.has_value();
}

}

自检单元结果 运行存在场景分层自检() {
    using namespace 存在场景分层自检内部;

    static_assert(std::is_standard_layout_v<创建实际存在请求>);
    static_assert(std::is_standard_layout_v<创建虚拟存在请求>);
    static_assert(std::is_standard_layout_v<创建场景请求>);
    static_assert(std::is_standard_layout_v<场景接纳存在请求>);
    static_assert(std::is_standard_layout_v<已有场景创建并接纳实际存在请求>);
    static_assert(std::is_same_v<
        decltype(std::declval<const 存在业务服务&>().创建实际存在(创建实际存在请求{})),
        存在场景业务结果>);
    static_assert(std::is_same_v<
        decltype(std::declval<const 场景业务服务&>().创建场景(创建场景请求{})),
        存在场景业务结果>);

    std::array<bool, 16> 验收{};
    try {
        constexpr std::uint64_t 关系仓库编号 = 7203;
        结构事务协调器 协调器(720);
        const auto 接线 = 协调器.生成接线();
        主信息仓库 主信息(7201, 接线);
        节点仓库 节点(主信息, 7202, 接线);
        关系仓库 关系(节点, 关系仓库编号, 接线);
        索引仓库 索引(节点, 接线);
        结构写入执行器 夹具执行器(接线, &主信息, &节点, &关系, &索引);
        存在场景数据操作 数据操作(接线, 主信息, 节点, 关系, 索引, 关系仓库编号);
        存在业务服务 存在服务(数据操作);
        场景业务服务 场景服务(数据操作);
        存在场景组合器 组合器(数据操作);

        const auto 读取数量 = [&] {
            return 结构数量{节点.有效节点数量(), 关系.有效关系数量(), 索引.有效主键数量()};
        };
        const auto 创建夹具节点 = [&](节点类型 类型, std::uint64_t 主键 = 0) {
            主信息句柄 新主信息;
            节点句柄 新节点;
            const auto 结果 = 夹具执行器.执行([&](结构写入会话& 会话) {
                const auto 主结果 = 会话.创建主信息候选();
                if (!主结果.成功()) return;
                新主信息 = *主结果.值;
                const auto 节点结果 = 会话.创建节点候选(类型, 新主信息);
                if (!节点结果.成功()) return;
                新节点 = *节点结果.值;
                if (主键 != 0 && !会话.绑定主键(主键, 新节点).成功()) return;
                bool 可提交 = 会话.主信息可读(新主信息) && 会话.节点可读(新节点);
                if (主键 != 0) 可提交 = 会话.主键绑定匹配(主键, 新节点) && 可提交;
                if (可提交) (void)会话.请求提交();
            });
            return 结果.状态 == 结构写入状态::已提交 ? 新节点 : 节点句柄{};
        };

        constexpr std::uint64_t 错误类型主键 = 0x0720'0000'0000'0001ULL;
        const auto 需求来源 = 创建夹具节点(节点类型::需求);
        const auto 任务来源 = 创建夹具节点(节点类型::任务);
        const auto 方法来源 = 创建夹具节点(节点类型::方法);
        const auto 非法来源 = 创建夹具节点(节点类型::特征);
        const auto 错误类型身份 = 创建夹具节点(节点类型::需求, 错误类型主键);

        验收[0] = 接线.已接域() && 夹具执行器.有效() && 数据操作.有效();
        验收[1] = std::is_standard_layout_v<创建实际存在请求>
            && std::is_standard_layout_v<创建虚拟存在请求>
            && std::is_standard_layout_v<创建场景请求>
            && std::is_standard_layout_v<场景接纳存在请求>
            && std::is_standard_layout_v<已有场景创建并接纳实际存在请求>
            && std::is_standard_layout_v<存在场景业务结果>;
        验收[2] = 句柄有效(需求来源) && 句柄有效(任务来源)
            && 句柄有效(方法来源) && 句柄有效(非法来源)
            && 句柄有效(错误类型身份);

        const auto 拒绝前 = 读取数量();
        const auto 零实际 = 存在服务.创建实际存在({0});
        const auto 零场景 = 场景服务.创建场景({0});
        const auto 无效虚拟 = 存在服务.创建虚拟存在({0x0720'0000'0000'0010ULL, 非法来源});
        auto 过期来源 = 需求来源;
        ++过期来源.版本号;
        const auto 过期虚拟 = 存在服务.创建虚拟存在({0x0720'0000'0000'0011ULL, 过期来源});
        const auto 无效接纳 = 场景服务.接纳已有存在({{}, {}});
        const auto 数据层非法虚拟 = 数据操作.创建虚拟存在(
            0x0720'0000'0000'0013ULL, 非法来源);
        const auto 数据层错误归属 = 数据操作.创建场景归属(需求来源, 非法来源);
        const auto 数据层错误组合 = 数据操作.在已有场景中创建并接纳实际存在(
            需求来源, 0x0720'0000'0000'0014ULL);
        存在场景业务结果 重入许可拒绝;
        {
            auto 独占许可 = 接线.取得独占许可(接线.运行期状态);
            if (独占许可.有效()) {
                重入许可拒绝 = 存在服务.创建实际存在({0x0720'0000'0000'0012ULL});
            }
        }
        验收[3] = 零实际.状态 == 存在场景业务状态::入口拒绝
            && 零场景.状态 == 存在场景业务状态::入口拒绝
            && 无效虚拟.状态 == 存在场景业务状态::入口拒绝
            && 过期虚拟.状态 == 存在场景业务状态::版本漂移
            && 无效接纳.状态 == 存在场景业务状态::入口拒绝
            && 数据层非法虚拟.状态 == 存在场景业务状态::入口拒绝
            && 数据层错误归属.状态 == 存在场景业务状态::入口拒绝
            && 数据层错误组合.状态 == 存在场景业务状态::入口拒绝
            && 重入许可拒绝.状态 == 存在场景业务状态::许可拒绝
            && 读取数量() == 拒绝前;

        const auto 冲突前 = 读取数量();
        const auto 错误类型冲突 = 存在服务.创建实际存在({错误类型主键});
        验收[4] = 错误类型冲突.状态 == 存在场景业务状态::幂等冲突
            && 读取数量() == 冲突前;

        constexpr std::uint64_t 实际存在主键 = 0x0720'0000'0000'0100ULL;
        const auto 实际前 = 读取数量();
        const auto 实际创建 = 存在服务.创建实际存在({实际存在主键});
        const auto 实际创建后 = 读取数量();
        const auto 实际重复 = 存在服务.创建实际存在({实际存在主键});
        const auto 实际材料 = 数据操作.读取主键身份(实际存在主键);
        const auto 实际节点记录 = 节点.读取节点(实际创建.存在);
        验收[5] = 实际创建.状态 == 存在场景业务状态::已提交
            && 实际重复.状态 == 存在场景业务状态::幂等读回
            && 实际重复.存在 == 实际创建.存在
            && 实际创建后.节点 == 实际前.节点 + 1
            && 实际创建后.关系 == 实际前.关系
            && 实际创建后.索引 == 实际前.索引 + 1
            && 读取数量() == 实际创建后
            && 是实际存在材料(实际材料)
            && 实际节点记录.has_value()
            && 实际节点记录->类型 == 节点类型::存在
            && 主信息.读取主信息(实际节点记录->主信息).has_value();

        constexpr std::uint64_t 虚拟存在主键 = 0x0720'0000'0000'0200ULL;
        const auto 虚拟前 = 读取数量();
        const auto 虚拟创建 = 存在服务.创建虚拟存在({虚拟存在主键, 需求来源});
        const auto 虚拟创建后 = 读取数量();
        const auto 虚拟重复 = 存在服务.创建虚拟存在({虚拟存在主键, 需求来源});
        const auto 虚拟来源冲突 = 存在服务.创建虚拟存在({虚拟存在主键, 任务来源});
        const auto 虚拟材料 = 数据操作.读取主键身份(虚拟存在主键);
        const auto 虚拟关系记录 = 句柄有效(虚拟创建.关系)
            ? 关系.读取关系(虚拟创建.关系)
            : std::optional<关系记录>{};
        验收[6] = 虚拟创建.状态 == 存在场景业务状态::已提交
            && 虚拟重复.状态 == 存在场景业务状态::幂等读回
            && 虚拟来源冲突.状态 == 存在场景业务状态::幂等冲突
            && 虚拟创建后.节点 == 虚拟前.节点 + 1
            && 虚拟创建后.关系 == 虚拟前.关系 + 1
            && 虚拟创建后.索引 == 虚拟前.索引 + 1
            && 读取数量() == 虚拟创建后
            && 虚拟材料.虚拟来源 == std::optional<节点句柄>{需求来源}
            && 虚拟材料.来源关系 == std::optional<关系句柄>{虚拟创建.关系}
            && 虚拟关系记录.has_value()
            && 虚拟关系记录->类型 == 关系类型::引用
            && 虚拟关系记录->源节点 == 虚拟创建.存在
            && 虚拟关系记录->目标节点 == 需求来源;

        constexpr std::uint64_t 场景主键 = 0x0720'0000'0000'0300ULL;
        const auto 场景前 = 读取数量();
        const auto 场景创建 = 场景服务.创建场景({场景主键});
        const auto 场景创建后 = 读取数量();
        const auto 场景重复 = 场景服务.创建场景({场景主键});
        const auto 错误键场景 = 场景服务.创建场景({错误类型主键});
        const auto 场景材料 = 数据操作.读取主键身份(场景主键);
        验收[7] = 场景创建.状态 == 存在场景业务状态::已提交
            && 场景重复.状态 == 存在场景业务状态::幂等读回
            && 场景重复.场景 == 场景创建.场景
            && 错误键场景.状态 == 存在场景业务状态::幂等冲突
            && 场景创建后.节点 == 场景前.节点 + 1
            && 场景创建后.关系 == 场景前.关系
            && 场景创建后.索引 == 场景前.索引 + 1
            && 读取数量() == 场景创建后
            && 场景材料.当前可读() && 场景材料.类型 == 节点类型::场景;

        const auto 接纳前 = 读取数量();
        const auto 接纳创建 = 场景服务.接纳已有存在({场景创建.场景, 实际创建.存在});
        const auto 接纳创建后 = 读取数量();
        const auto 接纳重复 = 场景服务.接纳已有存在({场景创建.场景, 实际创建.存在});
        auto 过期存在 = 实际创建.存在;
        ++过期存在.版本号;
        const auto 过期接纳 = 场景服务.接纳已有存在({场景创建.场景, 过期存在});
        const auto 错误类型接纳 = 场景服务.接纳已有存在({需求来源, 实际创建.存在});
        const auto 接纳材料 = 数据操作.读取场景归属(场景创建.场景, 实际创建.存在);
        验收[8] = 接纳创建.状态 == 存在场景业务状态::已提交
            && 接纳重复.状态 == 存在场景业务状态::幂等读回
            && 接纳重复.关系 == 接纳创建.关系
            && 过期接纳.状态 == 存在场景业务状态::版本漂移
            && 错误类型接纳.状态 == 存在场景业务状态::入口拒绝
            && 接纳创建后.节点 == 接纳前.节点
            && 接纳创建后.关系 == 接纳前.关系 + 1
            && 接纳创建后.索引 == 接纳前.索引
            && 读取数量() == 接纳创建后
            && 接纳材料.已归属()
            && 接纳材料.归属关系 == std::optional<关系句柄>{接纳创建.关系};

        constexpr std::uint64_t 组合场景主键 = 0x0720'0000'0000'0400ULL;
        constexpr std::uint64_t 组合新存在主键 = 0x0720'0000'0000'0401ULL;
        constexpr std::uint64_t 组合已有存在主键 = 0x0720'0000'0000'0402ULL;
        const auto 组合场景 = 场景服务.创建场景({组合场景主键});
        const auto 组合全新前 = 读取数量();
        const auto 组合全新 = 组合器.在已有场景中创建并接纳实际存在(
            {组合场景.场景, 组合新存在主键});
        const auto 组合全新后 = 读取数量();
        const auto 组合已有身份 = 存在服务.创建实际存在({组合已有存在主键});
        const auto 组合补归属前 = 读取数量();
        const auto 组合补归属 = 组合器.在已有场景中创建并接纳实际存在(
            {组合场景.场景, 组合已有存在主键});
        const auto 组合补归属后 = 读取数量();
        const auto 组合均已有 = 组合器.在已有场景中创建并接纳实际存在(
            {组合场景.场景, 组合已有存在主键});
        验收[9] = 组合场景.成功() && 组合全新.状态 == 存在场景业务状态::已提交
            && 组合全新.场景 == 组合场景.场景 && 句柄有效(组合全新.存在)
            && 组合全新后.节点 == 组合全新前.节点 + 1
            && 组合全新后.关系 == 组合全新前.关系 + 1
            && 组合全新后.索引 == 组合全新前.索引 + 1
            && 组合已有身份.成功()
            && 组合补归属.状态 == 存在场景业务状态::已提交
            && 组合补归属.存在 == 组合已有身份.存在
            && 组合补归属后.节点 == 组合补归属前.节点
            && 组合补归属后.关系 == 组合补归属前.关系 + 1
            && 组合补归属后.索引 == 组合补归属前.索引
            && 组合均已有.状态 == 存在场景业务状态::幂等读回
            && 读取数量() == 组合补归属后;

        constexpr std::uint64_t 并发主键 = 0x0720'0000'0000'0500ULL;
        const auto 并发主键前 = 读取数量();
        std::vector<存在场景业务结果> 主键竞争结果(8);
        std::vector<std::thread> 主键线程组;
        for (std::size_t 索引值 = 0; 索引值 < 主键竞争结果.size(); ++索引值) {
            主键线程组.emplace_back([&, 索引值] {
                主键竞争结果[索引值] = 存在服务.创建实际存在({并发主键});
            });
        }
        for (auto& 线程 : 主键线程组) 线程.join();
        const auto 并发主键后 = 读取数量();
        const auto 主键提交数 = std::count_if(主键竞争结果.begin(), 主键竞争结果.end(), [](const auto& 结果) {
            return 结果.状态 == 存在场景业务状态::已提交;
        });
        const auto 主键幂等数 = std::count_if(主键竞争结果.begin(), 主键竞争结果.end(), [](const auto& 结果) {
            return 结果.状态 == 存在场景业务状态::幂等读回;
        });
        const auto 并发主键材料 = 数据操作.读取主键身份(并发主键);
        const bool 主键句柄一致 = 并发主键材料.当前可读()
            && std::all_of(主键竞争结果.begin(), 主键竞争结果.end(), [&](const auto& 结果) {
                return 结果.成功() && 结果.存在 == 并发主键材料.节点;
            });
        验收[10] = 主键提交数 == 1 && 主键幂等数 == 7 && 主键句柄一致
            && 并发主键后.节点 == 并发主键前.节点 + 1
            && 并发主键后.关系 == 并发主键前.关系
            && 并发主键后.索引 == 并发主键前.索引 + 1;

        constexpr std::uint64_t 并发场景主键 = 0x0720'0000'0000'0600ULL;
        constexpr std::uint64_t 并发存在主键 = 0x0720'0000'0000'0601ULL;
        const auto 并发场景 = 场景服务.创建场景({并发场景主键});
        const auto 并发存在 = 存在服务.创建实际存在({并发存在主键});
        const auto 并发归属前 = 读取数量();
        std::vector<存在场景业务结果> 归属竞争结果(8);
        std::vector<std::thread> 归属线程组;
        for (std::size_t 索引值 = 0; 索引值 < 归属竞争结果.size(); ++索引值) {
            归属线程组.emplace_back([&, 索引值] {
                归属竞争结果[索引值] = 场景服务.接纳已有存在({并发场景.场景, 并发存在.存在});
            });
        }
        for (auto& 线程 : 归属线程组) 线程.join();
        const auto 并发归属后 = 读取数量();
        const auto 归属提交数 = std::count_if(归属竞争结果.begin(), 归属竞争结果.end(), [](const auto& 结果) {
            return 结果.状态 == 存在场景业务状态::已提交;
        });
        const auto 归属幂等数 = std::count_if(归属竞争结果.begin(), 归属竞争结果.end(), [](const auto& 结果) {
            return 结果.状态 == 存在场景业务状态::幂等读回;
        });
        const auto 并发归属材料 = 数据操作.读取场景归属(并发场景.场景, 并发存在.存在);
        const bool 归属句柄一致 = 并发归属材料.已归属()
            && std::all_of(归属竞争结果.begin(), 归属竞争结果.end(), [&](const auto& 结果) {
                return 结果.成功() && 结果.关系 == *并发归属材料.归属关系;
            });
        验收[11] = 归属提交数 == 1 && 归属幂等数 == 7 && 归属句柄一致
            && 并发归属后.节点 == 并发归属前.节点
            && 并发归属后.关系 == 并发归属前.关系 + 1
            && 并发归属后.索引 == 并发归属前.索引;

        const auto 内部不一致前 = 读取数量();
        存在场景数据操作 错误关系编号数据操作(
            接线, 主信息, 节点, 关系, 索引, 关系仓库编号 + 1);
        场景业务服务 错误关系编号场景服务(错误关系编号数据操作);
        const auto 内部不一致结果 = 错误关系编号场景服务.接纳已有存在(
            {并发场景.场景, 并发存在.存在});
        验收[12] = 内部不一致结果.状态 == 存在场景业务状态::内部不一致
            && 读取数量() == 内部不一致前;

        验收[13] = 夹具执行器.有效()
            && 节点.读取节点(实际创建.存在).has_value()
            && 关系.读取关系(接纳创建.关系).has_value()
            && 索引.按主键查节点(实际存在主键)
                == std::optional<节点句柄>{实际创建.存在};
        验收[14] = 数据操作.读取节点身份(场景创建.场景).当前可读()
            && 数据操作.读取节点身份(虚拟创建.存在).当前可读()
            && 数据操作.读取场景归属(组合场景.场景, 组合全新.存在).已归属();
        验收[15] = 组合全新.场景 == 组合场景.场景
            && 场景服务.创建场景({组合场景主键}).状态 == 存在场景业务状态::幂等读回
            && 读取数量() == 内部不一致前;
    } catch (...) {
    }

    constexpr std::array<const char*, 16> 名称组{
        "五个真模块与隔离装配",
        "公开业务值式请求与结果",
        "数据操作单一生产执行器入口",
        "无效输入版本漂移许可拒绝写前收口",
        "主键错误类型幂等冲突",
        "实际存在创建读回与重复不增量",
        "虚拟存在唯一来源与冲突拒绝",
        "场景创建读回与错误类型键拒绝",
        "已有存在唯一归属与幂等读回",
        "已有场景组合三种身份归属分支",
        "并发主键单提交与候选无残留",
        "并发归属单提交与关系无重复",
        "内部不一致不降级为入口拒绝",
        "仓库会话及既有总成回归材料",
        "禁止依赖保持值式只读边界",
        "暂停计划与生产调用边界不扩张"};
    std::size_t 失败数量 = 0;
    for (std::size_t 索引值 = 0; 索引值 < 验收.size(); ++索引值) {
        if (!验收[索引值]) ++失败数量;
        std::cout << "EXIST-SCENE-S1-A" << (索引值 + 1 < 10 ? "0" : "") << 索引值 + 1
            << ' ' << 名称组[索引值] << ": " << (验收[索引值] ? "通过" : "失败") << '\n';
    }
    return {"EXIST-SCENE-S1", "存在场景首组分层垂直样例",
        失败数量 == 0, 验收.size(), 失败数量};
}

}
