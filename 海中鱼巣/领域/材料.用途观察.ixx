// 文件规则：用途观察材料只承载调用期固定形状纯值候选与强类型结果；不得承载仓库、事务、线程状态、持久化或发布能力。
module;

#include "../核心/句柄.h"

#include <cstdint>
#include <limits>
#include <optional>

export module 海中鱼巣.领域.材料.用途观察;

import 海中鱼巣.领域.材料.因果模式;
import 海中鱼巣.领域.材料.用途事件;

export namespace 海中鱼巣 {

inline constexpr std::uint32_t 用途观察纯值合同格式版本 = 1;

struct 用途观察语义身份 {
    节点句柄 任务;
    std::uint64_t 任务序号 = 0;

    bool 完整() const noexcept {
        return 句柄有效(任务) && 任务序号 != 0;
    }
};

struct 用途观察不可变核心 {
    节点句柄 需求;
    节点句柄 选择记录;
    节点句柄 方法;
    节点句柄 动作;
    节点句柄 场景;
    节点句柄 主体;
    节点句柄 目标状态;
    节点句柄 实际状态;
    节点句柄 动态证据;
    因果概率分量 历史概率;

    bool 完整() const noexcept {
        if (!句柄有效(需求) || !句柄有效(选择记录)
            || !句柄有效(方法) || !句柄有效(动作)
            || !句柄有效(场景) || !句柄有效(主体)
            || !句柄有效(目标状态) || !句柄有效(实际状态)
            || !句柄有效(动态证据)
            || !历史概率.因果身份.当前版本兼容()
            || !历史概率.因果身份.原因结果角色不同()
            || 历史概率.机会数 == 0
            || 历史概率.正结果数 > 历史概率.机会数
            || 历史概率.负结果数 > 历史概率.机会数
            || 历史概率.正结果数 != 历史概率.机会数 - 历史概率.负结果数
            || 历史概率.Q10000 > 因果概率满量程
            || 历史概率.正结果数
                > std::numeric_limits<std::uint64_t>::max() / 因果概率满量程) {
            return false;
        }
        return 历史概率.Q10000
            == 历史概率.正结果数 * 因果概率满量程 / 历史概率.机会数;
    }
};

struct 用途观察阶段负载 {
    用途正式结果分类 正式结果 = 用途正式结果分类::未定义;
    任务达成分量 任务达成 = 任务达成分量::未达成;
    需求结算分量 需求结算 = 需求结算分量::未形成;
    用途观察阶段 观察阶段 = 用途观察阶段::尝试未达成;
    std::optional<节点句柄> 正式结算状态;

    bool 合法() const noexcept {
        switch (观察阶段) {
        case 用途观察阶段::尝试未达成:
            return 正式结果 == 用途正式结果分类::未达成已转待重筹办
                && 任务达成 == 任务达成分量::未达成
                && 需求结算 == 需求结算分量::未形成
                && !正式结算状态.has_value();
        case 用途观察阶段::待结算:
            return 正式结果 == 用途正式结果分类::任务已完成待需求结算
                && 任务达成 == 任务达成分量::已达成
                && 需求结算 == 需求结算分量::待结算
                && !正式结算状态.has_value();
        case 用途观察阶段::最终已结算:
            return 正式结果 == 用途正式结果分类::已完成并结算
                && 任务达成 == 任务达成分量::已达成
                && 需求结算 == 需求结算分量::已满足
                && 正式结算状态.has_value() && 句柄有效(*正式结算状态);
        default:
            return false;
        }
    }
};

struct 用途观察纯值候选 {
    std::uint32_t 格式版本 = 用途观察纯值合同格式版本;
    用途观察语义身份 身份;
    用途观察不可变核心 不可变核心;
    用途观察阶段负载 阶段负载;

    bool 合法() const noexcept {
        return 格式版本 == 用途观察纯值合同格式版本
            && 身份.完整() && 不可变核心.完整() && 阶段负载.合法();
    }
};

enum class 用途观察纯值形成状态 : std::uint8_t {
    已形成 = 1,
    入口拒绝 = 2,
    不支持 = 3,
    内部不一致 = 4
};

enum class 用途观察纯值形成原因 : std::uint8_t {
    无 = 0,
    请求不完整 = 1,
    来源冻结不完整 = 2,
    结果尚未正式收口 = 3,
    非新版完整回执 = 4,
    来源冻结回合不一致 = 5,
    规则版本不支持 = 6,
    目标格式不支持 = 7,
    正式结果材料矛盾 = 8,
    身份材料矛盾 = 9,
    内容材料矛盾 = 10,
    阶段材料矛盾 = 11,
    算法不变量破坏 = 12
};

struct 用途观察纯值形成结果 {
    用途观察纯值形成状态 状态 = 用途观察纯值形成状态::入口拒绝;
    用途观察纯值形成原因 原因 = 用途观察纯值形成原因::请求不完整;
    std::optional<用途观察纯值候选> 候选;

    bool 合法() const noexcept {
        if (状态 == 用途观察纯值形成状态::已形成) {
            return 原因 == 用途观察纯值形成原因::无
                && 候选.has_value() && 候选->合法();
        }
        if (候选.has_value()) return false;
        switch (状态) {
        case 用途观察纯值形成状态::入口拒绝:
            return 原因 == 用途观察纯值形成原因::请求不完整
                || 原因 == 用途观察纯值形成原因::来源冻结不完整
                || 原因 == 用途观察纯值形成原因::结果尚未正式收口
                || 原因 == 用途观察纯值形成原因::非新版完整回执
                || 原因 == 用途观察纯值形成原因::来源冻结回合不一致;
        case 用途观察纯值形成状态::不支持:
            return 原因 == 用途观察纯值形成原因::规则版本不支持
                || 原因 == 用途观察纯值形成原因::目标格式不支持;
        case 用途观察纯值形成状态::内部不一致:
            return 原因 == 用途观察纯值形成原因::正式结果材料矛盾
                || 原因 == 用途观察纯值形成原因::身份材料矛盾
                || 原因 == 用途观察纯值形成原因::内容材料矛盾
                || 原因 == 用途观察纯值形成原因::阶段材料矛盾
                || 原因 == 用途观察纯值形成原因::算法不变量破坏;
        default:
            return false;
        }
    }

    bool 成功() const noexcept {
        return 状态 == 用途观察纯值形成状态::已形成 && 合法();
    }
};

enum class 用途观察同账比较结论 : std::uint8_t {
    不同身份 = 1,
    同账幂等 = 2,
    同账允许推进 = 3,
    同账冲突 = 4,
    不支持 = 5,
    内部不一致 = 6
};

enum class 用途观察同账比较原因 : std::uint8_t {
    无 = 0,
    格式版本不支持 = 1,
    新候选非法 = 2,
    既有候选非法 = 3,
    完整身份不同 = 4,
    完整内容相同 = 5,
    待结算推进最终 = 6,
    不可变核心不同 = 7,
    阶段转换不允许 = 8,
    算法不变量破坏 = 9
};

struct 用途观察同账比较结果 {
    用途观察同账比较结论 结论 = 用途观察同账比较结论::内部不一致;
    用途观察同账比较原因 原因 = 用途观察同账比较原因::算法不变量破坏;

    bool 合法() const noexcept {
        switch (结论) {
        case 用途观察同账比较结论::不同身份:
            return 原因 == 用途观察同账比较原因::完整身份不同;
        case 用途观察同账比较结论::同账幂等:
            return 原因 == 用途观察同账比较原因::完整内容相同;
        case 用途观察同账比较结论::同账允许推进:
            return 原因 == 用途观察同账比较原因::待结算推进最终;
        case 用途观察同账比较结论::同账冲突:
            return 原因 == 用途观察同账比较原因::不可变核心不同
                || 原因 == 用途观察同账比较原因::阶段转换不允许;
        case 用途观察同账比较结论::不支持:
            return 原因 == 用途观察同账比较原因::格式版本不支持;
        case 用途观察同账比较结论::内部不一致:
            return 原因 == 用途观察同账比较原因::新候选非法
                || 原因 == 用途观察同账比较原因::既有候选非法
                || 原因 == 用途观察同账比较原因::算法不变量破坏;
        default:
            return false;
        }
    }
};

}
