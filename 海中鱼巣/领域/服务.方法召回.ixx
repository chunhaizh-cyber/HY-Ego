// 文件规则：方法召回业务服务只重建非权威候选、复判和建议，不提交任务选择。
module;

#include "../核心/句柄.h"
#include "特征值服务.h"

#include <algorithm>
#include <cstdint>
#include <optional>
#include <vector>

export module 海中鱼巣.领域.服务.方法召回;

import 海中鱼巣.领域.数据操作.需求任务方法;
import 海中鱼巣.领域.数据操作.特征体系;
import 海中鱼巣.领域.数据操作.状态动态;
import 海中鱼巣.领域.服务.需求;
import 海中鱼巣.领域.服务.任务;
import 海中鱼巣.领域.服务.方法;
import 海中鱼巣.领域.服务.特征;
import 海中鱼巣.领域.服务.状态;

export namespace 海中鱼巣 {

struct 方法召回请求 {
    节点句柄 任务;
    节点句柄 登记根;
    std::uint32_t 排序规则版本 = 0;
    std::uint32_t 召回请求规则版本 = 0;
};

enum class 方法召回状态 : std::uint8_t {
    唯一建议 = 1,
    无候选 = 2,
    非唯一建议 = 3,
    入口拒绝 = 4,
    内部不一致 = 5
};

struct 方法召回候选 {
    节点句柄 方法;
    关系句柄 方法生命周期关系;
    std::uint32_t 方法生命周期版本 = 0;
    std::uint64_t 排序分值 = 0;
    std::uint64_t 匹配条件数量 = 0;
    std::uint64_t 匹配结果数量 = 0;
    节点句柄 动作入口;

    bool 完整() const noexcept {
        return 句柄有效(方法) && 句柄有效(方法生命周期关系)
            && 方法生命周期版本 != 0 && 排序分值 != 0
            && 匹配结果数量 != 0 && 句柄有效(动作入口);
    }
};

struct 方法召回结果 {
    方法召回状态 状态 = 方法召回状态::入口拒绝;
    节点句柄 任务;
    关系句柄 任务生命周期关系;
    std::uint32_t 任务生命周期版本 = 0;
    std::uint32_t 排序规则版本 = 0;
    std::uint32_t 召回请求规则版本 = 0;
    std::vector<方法召回候选> 候选组;
    std::optional<方法召回候选> 建议;

    bool 有唯一建议() const noexcept {
        return 状态 == 方法召回状态::唯一建议 && 建议.has_value()
            && 建议->完整() && 句柄有效(任务生命周期关系)
            && 任务生命周期版本 != 0 && 排序规则版本 != 0
            && 召回请求规则版本 != 0 && !候选组.empty();
    }
};

class 方法召回业务服务 final {
public:
    方法召回业务服务(
        需求业务服务& 需求服务,
        任务业务服务& 任务服务,
        方法业务服务& 方法服务,
        特征业务服务& 特征服务,
        状态业务服务& 状态服务)
        : 需求服务_(需求服务), 任务服务_(任务服务), 方法服务_(方法服务),
          特征服务_(特征服务), 状态服务_(状态服务) {
    }

    方法召回结果 召回(const 方法召回请求& 请求) const {
        if (!句柄有效(请求.任务) || !句柄有效(请求.登记根)
            || 请求.排序规则版本 == 0 || 请求.召回请求规则版本 == 0) return {};
        const auto 任务 = 任务服务_.读取任务(请求.任务);
        if (!任务.完整承接()
            || 任务.当前生命周期.阶段 != 分层任务生命周期阶段::筹办中
            || 任务.当前选择.has_value()) return {};
        const auto 需求 = 需求服务_.读取需求(任务.来源需求);
        const auto 根 = 方法服务_.读取登记根(请求.登记根);
        if (!需求.完整目标状态需求() || !根.完整()) return {};
        const auto 当前特征 = 特征服务_.读取宿主特征状态(需求.主体, 需求.目标特征);
        const auto 目标状态 = 状态服务_.读取状态材料(需求.目标状态);
        if (!当前特征.有当前值() || !目标状态.完整抽象状态()
            || 当前特征.当前值.特征值节点 != 需求.当前特征状态材料) {
            return {方法召回状态::内部不一致};
        }

        方法召回结果 输出;
        输出.任务 = 请求.任务;
        输出.任务生命周期关系 = 任务.当前生命周期.关系.关系;
        输出.任务生命周期版本 = 任务.当前生命周期.版本;
        输出.排序规则版本 = 请求.排序规则版本;
        输出.召回请求规则版本 = 请求.召回请求规则版本;
        for (const auto& 方法 : 方法服务_.读取登记项组(请求.登记根)) {
            if (!方法.完整() || 方法.生命周期 != 分层方法生命周期::活跃) continue;
            const auto 条件组 = 方法服务_.读取规格组(
                方法.身份.节点, 分层方法角色::方法条件);
            const auto 结果组 = 方法服务_.读取规格组(
                方法.身份.节点, 分层方法角色::方法结果);
            const auto 动作组 = 方法服务_.读取规格组(
                方法.身份.节点, 分层方法角色::动作入口);
            if (动作组.size() != 1 || !动作组.front().完整动作入口()) continue;
            const bool 条件全部匹配 = std::all_of(
                条件组.begin(), 条件组.end(), [&](const auto& 条件) {
                    return 条件.完整条件()
                        && 条件.场景 == std::optional<节点句柄>{需求.场景}
                        && 条件.目标特征 == std::optional<节点句柄>{需求.目标特征}
                        && 条件.来源版本 == 当前特征.当前值.原始值版本
                        && 当前特征.当前值.原始类型 == 特征值原始类型::I64
                        && 当前特征.当前值.I64值 == std::optional<std::int64_t>{条件.目标状态值};
                });
            if (!条件全部匹配) continue;
            const auto 匹配结果数量 = static_cast<std::uint64_t>(std::count_if(
                结果组.begin(), 结果组.end(), [&](const auto& 结果) {
                    return 结果.完整结果()
                        && 结果.场景 == std::optional<节点句柄>{需求.场景}
                        && 结果.目标特征 == std::optional<节点句柄>{需求.目标特征}
                        && 结果.目标状态值 == 目标状态.状态值;
                }));
            if (匹配结果数量 == 0) continue;
            输出.候选组.push_back({
                方法.身份.节点,
                方法.生命周期关系.关系,
                方法.生命周期关系.关系.版本号,
                1000 + static_cast<std::uint64_t>(条件组.size()) * 10 + 匹配结果数量,
                static_cast<std::uint64_t>(条件组.size()),
                匹配结果数量,
                动作组.front().身份.节点});
        }
        std::sort(输出.候选组.begin(), 输出.候选组.end(), [](const auto& 左, const auto& 右) {
            if (左.排序分值 != 右.排序分值) return 左.排序分值 > 右.排序分值;
            if (左.方法.仓库编号 != 右.方法.仓库编号) return 左.方法.仓库编号 < 右.方法.仓库编号;
            if (左.方法.节点编号 != 右.方法.节点编号) return 左.方法.节点编号 < 右.方法.节点编号;
            return 左.方法.版本号 < 右.方法.版本号;
        });
        if (输出.候选组.empty()) {
            输出.状态 = 方法召回状态::无候选;
            return 输出;
        }
        if (输出.候选组.size() > 1
            && 输出.候选组[0].排序分值 == 输出.候选组[1].排序分值) {
            输出.状态 = 方法召回状态::非唯一建议;
            return 输出;
        }
        输出.建议 = 输出.候选组.front();
        输出.状态 = 方法召回状态::唯一建议;
        return 输出;
    }

    std::optional<提交任务方法选择请求> 适配唯一建议(
        const 方法召回结果& 召回结果,
        std::uint64_t 记录幂等主键,
        std::uint64_t 幂等材料编号) const {
        if (!召回结果.有唯一建议() || 记录幂等主键 == 0 || 幂等材料编号 == 0) {
            return std::nullopt;
        }
        const auto 任务 = 任务服务_.读取任务(召回结果.任务);
        const auto 方法 = 方法服务_.读取登记项(召回结果.建议->方法);
        if (!任务.完整承接() || 任务.当前生命周期.阶段 != 分层任务生命周期阶段::筹办中
            || 任务.当前选择.has_value() || !方法.完整()
            || 方法.生命周期 != 分层方法生命周期::活跃
            || 任务.当前生命周期.关系.关系 != 召回结果.任务生命周期关系
            || 任务.当前生命周期.版本 != 召回结果.任务生命周期版本
            || 方法.生命周期关系.关系 != 召回结果.建议->方法生命周期关系
            || 方法.生命周期关系.关系.版本号 != 召回结果.建议->方法生命周期版本) {
            return std::nullopt;
        }
        return 提交任务方法选择请求{
            记录幂等主键, 召回结果.任务, 召回结果.建议->方法, 幂等材料编号,
            召回结果.任务生命周期关系, 召回结果.任务生命周期版本,
            召回结果.建议->方法生命周期关系,
            召回结果.建议->方法生命周期版本,
            召回结果.排序规则版本, 召回结果.召回请求规则版本,
            static_cast<std::uint64_t>(召回结果.候选组.size())};
    }

private:
    需求业务服务& 需求服务_;
    任务业务服务& 任务服务_;
    方法业务服务& 方法服务_;
    特征业务服务& 特征服务_;
    状态业务服务& 状态服务_;
};

}
