// 文件规则：状态服务只承担状态事实准入、值式读写合同和退役材料形成；不直接接触仓库或事务令牌。
module;

#include "状态动态类型化记录.数据.h"

export module 海中鱼巣.领域.服务.节点直接状态;

export namespace 海中鱼巣 {

class 节点直接状态服务 final {
public:
    完整状态写入结果 创建完整状态事实(
        const 完整实例状态请求& 请求);

    完整状态读取结果 读取完整状态事实(节点句柄 状态) const;
    主体状态事实组读取结果 读取主体状态事实组(节点句柄 主体) const;

    状态退役规格结果 形成状态退役规格(
        节点句柄 状态, std::uint64_t 预期版本) const;

    带值读取结果<状态退役材料> 读取状态退役材料(
        节点句柄 状态) const;

private:
    static bool 状态请求可准入(const 完整实例状态请求& 请求) noexcept {
        return 请求.发生时间 != 0 && 句柄有效(请求.主体)
            && 句柄有效(请求.场景) && 句柄有效(请求.特征)
            && 句柄有效(请求.特征值) && 句柄有效(请求.来源存在)
            && (!请求.接收时间 || *请求.接收时间 >= 请求.发生时间)
            && static_cast<std::uint32_t>(请求.记录模式) >= 1
            && static_cast<std::uint32_t>(请求.记录模式) <= 3;
    }

    static bool 退役规格可准入(
        节点句柄 状态, std::uint64_t 预期版本) noexcept {
        return 句柄有效(状态) && 预期版本 != 0;
    }
};

}
