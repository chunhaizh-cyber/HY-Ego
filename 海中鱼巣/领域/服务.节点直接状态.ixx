// 文件规则：本模块只承担完整状态事实的业务准入与值式读取，不暴露仓库、记录参与者、许可或会话。
module;

#include "../核心/句柄.h"
#include "节点直接领域合同.数据.h"

export module 海中鱼巣.领域.服务.节点直接状态;

export import 海中鱼巣.领域.数据操作.节点直接状态动态;
export import 海中鱼巣.领域.服务.节点直接特征;

export namespace 海中鱼巣 {

class 节点直接状态服务 final {
public:
    节点直接状态服务(
        节点直接状态动态数据操作& 数据操作,
        节点直接特征服务& 特征服务) noexcept
        : 数据操作_(&数据操作), 特征服务_(&特征服务) {
    }

    bool 有效() const noexcept {
        return 数据操作_ != nullptr && 特征服务_ != nullptr
            && 数据操作_->有效() && 特征服务_->有效();
    }

    完整状态写入结果 创建完整状态事实(
        const 完整实例状态请求& 请求) {
        if (!有效() || !请求字段有效(请求)) {
            return {合同结果状态::入口拒绝, 合同结果原因::无效身份};
        }
        const auto 归属 = 特征服务_->复核特征值归属(
            请求.特征值, 请求.特征, 特征值归属读取口径::当前);
        if (!归属.成功()) return {归属.状态, 归属.原因};
        const auto 结果 = 数据操作_->创建完整状态事实(请求);
        if (!结果.成功()) return 结果;
        if (!材料符合请求(*结果.材料, 请求)) {
            return {合同结果状态::内部错误,
                合同结果原因::权威读回不一致};
        }
        return 结果;
    }

    完整状态读取结果 读取完整状态事实(节点句柄 状态) const {
        if (!有效() || !句柄有效(状态)) {
            return {合同结果状态::入口拒绝, 合同结果原因::无效身份};
        }
        auto 结果 = 数据操作_->读取完整状态事实(状态);
        if (!结果.成功()) return 结果;
        const auto 归属 = 特征服务_->复核特征值归属(
            结果.材料->值证据.目标节点,
            结果.材料->特征证据.目标节点,
            特征值归属读取口径::当前);
        if (!归属.成功()) {
            return {归属.状态 == 合同结果状态::许可竞争
                    ? 合同结果状态::许可竞争 : 合同结果状态::内部错误,
                归属.状态 == 合同结果状态::许可竞争
                    ? 合同结果原因::并发许可失败
                    : 合同结果原因::值归属不一致};
        }
        return 结果;
    }

    主体状态事实组读取结果 读取主体状态事实组(
        节点句柄 主体) const {
        if (!有效() || !句柄有效(主体)) {
            return {合同结果状态::入口拒绝, 合同结果原因::无效身份};
        }
        auto 结果 = 数据操作_->读取主体状态事实组(主体);
        if (!结果.成功()) return 结果;
        for (const auto& 项目 : 结果.材料->项目组) {
            const auto 归属 = 特征服务_->复核特征值归属(
                项目.值证据.目标节点,
                项目.特征证据.目标节点,
                特征值归属读取口径::当前);
            if (!归属.成功()) {
                return {
                    归属.状态 == 合同结果状态::许可竞争
                        ? 合同结果状态::许可竞争
                        : 合同结果状态::内部错误,
                    归属.状态 == 合同结果状态::许可竞争
                        ? 合同结果原因::并发许可失败
                        : 合同结果原因::值归属不一致};
            }
        }
        return 结果;
    }

    状态退役规格结果 形成状态退役规格(
        节点句柄 状态,
        std::uint32_t 预期节点版本) const {
        if (!有效()) {
            return {合同结果状态::入口拒绝, 合同结果原因::无效身份};
        }
        return 数据操作_->形成状态退役规格(状态, 预期节点版本);
    }

    带值读取结果<状态退役材料> 读取状态退役材料(
        节点句柄 状态) const {
        if (!有效()) {
            return {合同结果状态::入口拒绝, 合同结果原因::无效身份};
        }
        return 数据操作_->读取状态退役材料(状态);
    }

private:
    static bool 请求字段有效(const 完整实例状态请求& 请求) noexcept {
        return 稳定主键有效(请求.状态稳定主键)
            && 请求.状态稳定主键.命名域 == static_cast<std::uint64_t>(
                节点稳定主键命名域::状态身份)
            && 句柄有效(请求.主体) && 句柄有效(请求.场景)
            && 句柄有效(请求.特征) && 句柄有效(请求.特征值)
            && 句柄有效(请求.来源存在) && 请求.发生时间 != 0
            && (!请求.接收时间.has_value()
                || *请求.接收时间 >= 请求.发生时间)
            && 状态记录模式有效(请求.记录模式);
    }

    static bool 材料符合请求(
        const 状态事实值式材料& 材料,
        const 完整实例状态请求& 请求) noexcept {
        return 材料.稳定主键 == 请求.状态稳定主键
            && 材料.发生时间 == 请求.发生时间
            && 材料.接收时间 == 请求.接收时间
            && 材料.记录模式 == 请求.记录模式
            && 材料.主体证据.目标节点 == 请求.主体
            && 材料.场景证据.目标节点 == 请求.场景
            && 材料.特征证据.目标节点 == 请求.特征
            && 材料.值证据.目标节点 == 请求.特征值
            && 材料.来源存在证据.目标节点 == 请求.来源存在;
    }

    节点直接状态动态数据操作* 数据操作_ = nullptr;
    节点直接特征服务* 特征服务_ = nullptr;
};

}
