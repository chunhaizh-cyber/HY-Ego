    特征体系业务结果 创建特征定义(std::uint64_t 主键) const {
        if (!有效() || 主键 == 0) return {};
        const auto 写前 = 读取主键特征定义(主键);
        if (写前.完整()) return 形成定义结果(特征体系业务状态::幂等读回, 写前);
        if (写前.状态 == 特征体系读取状态::类型不匹配
            || 写前.状态 == 特征体系读取状态::内部不一致) {
            return {写前.状态 == 特征体系读取状态::内部不一致
                ? 特征体系业务状态::内部不一致 : 特征体系业务状态::幂等冲突};
        }
        if (写前.状态 != 特征体系读取状态::未找到) return 从读取失败形成结果(写前.状态);

        const auto 结构结果 = 执行器_.执行([&](结构写入会话& 会话) {
            主信息句柄 新主信息;
            节点句柄 新定义;
            if (!写入带主键节点_会话(会话, 节点类型::特征, 主键, 新主信息, 新定义)) return;
            (void)会话.请求提交();
        });
        const auto 当前 = 读取主键特征定义(主键);
        if (当前.完整()) {
            return 形成定义结果(
                结构结果.状态 == 结构写入状态::已提交
                    ? 特征体系业务状态::已提交 : 特征体系业务状态::幂等读回,
                当前);
        }
        if (当前.状态 == 特征体系读取状态::类型不匹配) {
            return {特征体系业务状态::幂等冲突};
        }
        return 映射结构失败(结构结果);
    }

    特征体系业务结果 创建实例特征槽位(const 特征槽位写入规格& 规格) const {
        if (!有效() || !规格.完整()) return {};
        const auto 宿主身份 = 读取节点身份(规格.读取宿主());
        const auto 定义 = 读取特征定义(规格.读取特征定义());
        if (!宿主身份.当前可读() || !定义.完整()) {
            return 合并身份定义失败(宿主身份, 定义);
        }
        if (!允许特征宿主(宿主身份.类型)) return {};

        const auto 已有槽位 = 读取宿主定义槽位(规格.读取宿主(), 规格.读取特征定义());
        if (已有槽位.完整()) {
            return 已有槽位.幂等主键 == 规格.读取幂等主键()
                ? 形成槽位结果(特征体系业务状态::幂等读回, 已有槽位)
                : 特征体系业务结果{特征体系业务状态::幂等冲突};
        }
        if (已有槽位.状态 != 特征体系读取状态::未找到) {
            return 从读取失败形成结果(已有槽位.状态);
        }
        const auto 主键槽位 = 读取主键实例特征槽位(规格.读取幂等主键());
        if (主键槽位.完整()) {
            return 匹配槽位(主键槽位, 规格)
                ? 形成槽位结果(特征体系业务状态::幂等读回, 主键槽位)
                : 特征体系业务结果{特征体系业务状态::幂等冲突};
        }
        if (主键槽位.状态 != 特征体系读取状态::未找到) {
            return 主键槽位.状态 == 特征体系读取状态::类型不匹配
                ? 特征体系业务结果{特征体系业务状态::幂等冲突}
                : 从读取失败形成结果(主键槽位.状态);
        }

        bool 版本已经漂移 = false;
        const auto 结构结果 = 执行器_.执行([&](结构写入会话& 会话) {
            if (!验证宿主定义_会话(会话, 宿主身份, 定义)
                || 存在宿主定义槽位_会话(会话, 规格.读取宿主(), 规格.读取特征定义())) {
                版本已经漂移 = true;
                return;
            }
            特征槽位值式材料 新槽位;
            if (!写入槽位_会话(会话, 规格, 新槽位)) return;
            (void)会话.请求提交();
        });
        const auto 当前 = 读取主键实例特征槽位(规格.读取幂等主键());
        if (匹配槽位(当前, 规格)) {
            return 形成槽位结果(
                结构结果.状态 == 结构写入状态::已提交
                    ? 特征体系业务状态::已提交 : 特征体系业务状态::幂等读回,
                当前);
        }
        if (当前.状态 == 特征体系读取状态::已找到
            || 当前.状态 == 特征体系读取状态::类型不匹配) {
            return {特征体系业务状态::幂等冲突};
        }
        if (版本已经漂移) return {特征体系业务状态::版本漂移};
        return 映射结构失败(结构结果);
    }

    特征体系业务结果 发布初始特征状态(
        节点句柄 实例槽位,
        const 初始特征值写入规格& 规格) const {
        if (!有效() || !句柄有效(实例槽位) || !规格.完整()) return {};
        const auto 槽位 = 读取实例特征槽位(实例槽位);
        if (!槽位.完整()) return 从读取失败形成结果(槽位.状态);
        const auto 已有当前值 = 读取实例槽位当前值(实例槽位);
        if (已有当前值.完整()) {
            return 匹配原始值(已有当前值, 规格)
                ? 形成值结果(特征体系业务状态::幂等读回, 槽位, 已有当前值)
                : 特征体系业务结果{特征体系业务状态::幂等冲突};
        }
        if (已有当前值.状态 != 特征体系读取状态::未找到) {
            return 从读取失败形成结果(已有当前值.状态);
        }
        const auto 主键值 = 读取主键当前值候选(规格.读取幂等主键());
        if (主键值.状态 != 特征体系读取状态::未找到) {
            if (主键值.完整() && 匹配原始值(主键值, 规格)
                && 主键值.实例槽位 == 实例槽位) {
                return 形成值结果(特征体系业务状态::幂等读回, 槽位, 主键值);
            }
            if (主键值.状态 == 特征体系读取状态::许可拒绝
                || 主键值.状态 == 特征体系读取状态::版本漂移
                || 主键值.状态 == 特征体系读取状态::内部不一致) {
                return 从读取失败形成结果(主键值.状态);
            }
            return {特征体系业务状态::幂等冲突};
        }

        bool 版本已经漂移 = false;
        特征值原始材料事务参与者 参与者(特征值_);
        const auto 结构结果 = 执行器_.执行([&](结构写入会话& 会话) {
            if (!验证槽位_会话(会话, 槽位)
                || !会话.读取关系记录组(实例槽位, 关系类型::归属).empty()) {
                版本已经漂移 = true;
                return;
            }
            特征原始值式材料 新值;
            if (!写入初始值_会话(会话, 参与者, 实例槽位, 规格, 新值)) return;
            (void)会话.请求提交();
        }, 参与者);
        const auto 当前 = 读取实例槽位当前值(实例槽位);
        if (匹配原始值(当前, 规格)) {
            return 形成值结果(
                结构结果.状态 == 结构写入状态::已提交
                    ? 特征体系业务状态::已提交 : 特征体系业务状态::幂等读回,
                槽位, 当前);
        }
        if (当前.状态 == 特征体系读取状态::已找到) {
            return {特征体系业务状态::幂等冲突};
        }
        if (版本已经漂移) return {特征体系业务状态::版本漂移};
        return 映射结构失败(结构结果);
    }

    特征体系业务结果 创建槽位并发布初始状态(
        const 特征槽位写入规格& 槽位规格,
        const 初始特征值写入规格& 值规格) const {
        if (!有效() || !槽位规格.完整() || !值规格.完整()
            || 槽位规格.读取幂等主键() == 值规格.读取幂等主键()) return {};
        const auto 宿主身份 = 读取节点身份(槽位规格.读取宿主());
        const auto 定义 = 读取特征定义(槽位规格.读取特征定义());
        if (!宿主身份.当前可读() || !定义.完整()) {
            return 合并身份定义失败(宿主身份, 定义);
        }
        if (!允许特征宿主(宿主身份.类型)) return {};

        const auto 已有槽位 = 读取宿主定义槽位(
            槽位规格.读取宿主(), 槽位规格.读取特征定义());
        if (已有槽位.完整()) {
            const auto 当前值 = 读取实例槽位当前值(已有槽位.实例槽位);
            if (匹配槽位(已有槽位, 槽位规格) && 匹配原始值(当前值, 值规格)) {
                return 形成值结果(特征体系业务状态::幂等读回, 已有槽位, 当前值);
            }
            return {特征体系业务状态::幂等冲突};
        }
        if (已有槽位.状态 != 特征体系读取状态::未找到) {
            return 从读取失败形成结果(已有槽位.状态);
        }
        const auto 主键槽位 = 读取主键实例特征槽位(槽位规格.读取幂等主键());
        const auto 主键值 = 读取主键当前值候选(值规格.读取幂等主键());
        if (主键槽位.状态 != 特征体系读取状态::未找到
            || 主键值.状态 != 特征体系读取状态::未找到) {
            const auto 并发槽位 = 读取宿主定义槽位(
                槽位规格.读取宿主(), 槽位规格.读取特征定义());
            const auto 并发值 = 并发槽位.完整()
                ? 读取实例槽位当前值(并发槽位.实例槽位)
                : 特征原始值式材料{};
            if (匹配槽位(并发槽位, 槽位规格) && 匹配原始值(并发值, 值规格)) {
                return 形成值结果(特征体系业务状态::幂等读回, 并发槽位, 并发值);
            }
            if (主键槽位.状态 == 特征体系读取状态::许可拒绝
                || 主键值.状态 == 特征体系读取状态::许可拒绝) {
                return {特征体系业务状态::许可拒绝};
            }
            if (主键槽位.状态 == 特征体系读取状态::版本漂移
                || 主键值.状态 == 特征体系读取状态::版本漂移) {
                return {特征体系业务状态::版本漂移};
            }
            if (主键槽位.状态 == 特征体系读取状态::内部不一致
                || 主键值.状态 == 特征体系读取状态::内部不一致) {
                return {特征体系业务状态::内部不一致};
            }
            return {特征体系业务状态::幂等冲突};
        }

        bool 版本已经漂移 = false;
        特征值原始材料事务参与者 参与者(特征值_);
        const auto 结构结果 = 执行器_.执行([&](结构写入会话& 会话) {
            if (!验证宿主定义_会话(会话, 宿主身份, 定义)
                || 存在宿主定义槽位_会话(
                    会话, 槽位规格.读取宿主(), 槽位规格.读取特征定义())) {
                版本已经漂移 = true;
                return;
            }
            特征槽位值式材料 新槽位;
            if (!写入槽位_会话(会话, 槽位规格, 新槽位)) return;
            特征原始值式材料 新值;
            if (!写入初始值_会话(
                    会话, 参与者, 新槽位.实例槽位, 值规格, 新值)) return;
            (void)会话.请求提交();
        }, 参与者);

        const auto 当前槽位 = 读取宿主定义槽位(
            槽位规格.读取宿主(), 槽位规格.读取特征定义());
        const auto 当前值 = 当前槽位.完整()
            ? 读取实例槽位当前值(当前槽位.实例槽位)
            : 特征原始值式材料{};
        if (匹配槽位(当前槽位, 槽位规格) && 匹配原始值(当前值, 值规格)) {
            return 形成值结果(
                结构结果.状态 == 结构写入状态::已提交
                    ? 特征体系业务状态::已提交 : 特征体系业务状态::幂等读回,
                当前槽位, 当前值);
        }
        if (当前槽位.状态 == 特征体系读取状态::已找到) {
            return {特征体系业务状态::幂等冲突};
        }
        if (版本已经漂移) return {特征体系业务状态::版本漂移};
        return 映射结构失败(结构结果);
    }

    特征体系业务结果 创建组合二次特征(
        std::uint64_t 主键,
        const std::vector<节点句柄>& 有序组成项组) const {
        if (!有效() || 主键 == 0 || !组成项请求可用(有序组成项组)) return {};
        for (const auto 组成项 : 有序组成项组) {
            const auto 身份 = 读取节点身份(组成项);
            if (!身份.当前可读()) return 从读取失败形成结果(身份.状态);
            if (!允许二次特征组成项(身份.类型)) return {};
        }

        const auto 写前 = 读取主键二次特征(主键);
        if (写前.完整()) {
            return 写前.有序组成项组 == 有序组成项组
                ? 形成二次特征结果(特征体系业务状态::幂等读回, 写前)
                : 特征体系业务结果{特征体系业务状态::幂等冲突};
        }
        if (写前.状态 != 特征体系读取状态::未找到) {
            return 写前.状态 == 特征体系读取状态::类型不匹配
                ? 特征体系业务结果{特征体系业务状态::幂等冲突}
                : 从读取失败形成结果(写前.状态);
        }

        bool 版本已经漂移 = false;
        const auto 结构结果 = 执行器_.执行([&](结构写入会话& 会话) {
            for (const auto 组成项 : 有序组成项组) {
                const auto 类型 = 会话.读取节点类型(组成项);
                if (!类型.has_value() || !允许二次特征组成项(*类型)) {
                    版本已经漂移 = true;
                    return;
                }
            }
            主信息句柄 新主信息;
            节点句柄 新二次特征;
            if (!写入带主键节点_会话(
                    会话, 节点类型::二次特征, 主键, 新主信息, 新二次特征)) return;
            for (std::size_t 索引 = 0; 索引 < 有序组成项组.size(); ++索引) {
                const auto 关系结果 = 会话.创建关系(
                    关系类型::引用, 新二次特征, 有序组成项组[索引],
                    static_cast<std::int64_t>(索引));
                if (!关系结果.成功() || !会话.关系可读(*关系结果.值)) return;
            }
            (void)会话.请求提交();
        });
        const auto 当前 = 读取主键二次特征(主键);
        if (当前.完整() && 当前.有序组成项组 == 有序组成项组) {
            return 形成二次特征结果(
                结构结果.状态 == 结构写入状态::已提交
                    ? 特征体系业务状态::已提交 : 特征体系业务状态::幂等读回,
                当前);
        }
        if (当前.状态 == 特征体系读取状态::已找到
            || 当前.状态 == 特征体系读取状态::类型不匹配) {
            return {特征体系业务状态::幂等冲突};
        }
        if (版本已经漂移) return {特征体系业务状态::版本漂移};
        return 映射结构失败(结构结果);
    }

private:
    friend class 特征批次同层授权桥;
    friend class 特征批次结构参与包;

    std::unique_ptr<特征批次结构参与包> 形成特征批次同层参与包_(
        const 特征批次变更规格& 规格) const;

    特征批次结果 从批次记录形成结果_(
        const 特征批次变更规格& 规格,
        const 特征批次发布记录& 记录,
        特征批次提交状态 状态) const;

    static bool 批次记录语义匹配_(
        const 特征批次变更规格& 规格,
        const 特征批次发布记录& 记录) noexcept;

    bool 形成特征批次候选_会话(
        结构写入会话& 会话,
        const 特征批次变更规格& 规格,
        特征值原始材料事务参与者& 原始材料参与者,
        特征批次发布记录事务参与者& 批次记录参与者,
        特征批次结果& 候选结果,
        特征批次提交状态& 提前收口状态) const;

    static bool 允许特征宿主(节点类型 类型) noexcept {
        return 类型 == 节点类型::存在 || 类型 == 节点类型::场景
            || 类型 == 节点类型::需求 || 类型 == 节点类型::任务
            || 类型 == 节点类型::方法;
    }

    static bool 允许二次特征组成项(节点类型 类型) noexcept {
        return 类型 == 节点类型::基础信息 || 类型 == 节点类型::存在
            || 类型 == 节点类型::场景 || 类型 == 节点类型::特征
            || 类型 == 节点类型::二次特征 || 类型 == 节点类型::因果引用;
    }

    static bool 组成项请求可用(const std::vector<节点句柄>& 组成项组) {
        if (组成项组.empty()) return false;
        for (std::size_t 左 = 0; 左 < 组成项组.size(); ++左) {
            if (!句柄有效(组成项组[左])) return false;
            for (std::size_t 右 = 左 + 1; 右 < 组成项组.size(); ++右) {
                if (组成项组[左] == 组成项组[右]) return false;
            }
        }
        return true;
    }

    特征节点身份 读取节点身份_已许可(
        节点句柄 目标,
        const 结构事务令牌& 令牌) const {
        特征节点身份 输出;
        输出.节点 = 目标;
        if (!句柄有效(目标)) return 输出;
        const auto 记录 = 节点_.读取节点(目标, 令牌);
        if (!记录.has_value()) {
            输出.状态 = 特征体系读取状态::版本漂移;
            return 输出;
        }
        if (!主信息_.读取主信息(记录->主信息, 令牌).has_value()) {
            return 身份内部不一致(目标, L"特征体系节点缺少当前可读主信息锚点。");
        }
        输出.状态 = 特征体系读取状态::已找到;
        输出.类型 = 记录->类型;
        输出.主信息 = 记录->主信息;
        return 输出;
    }

    特征节点身份 身份内部不一致(节点句柄 目标, const wchar_t* 说明) const {
        (void)追根因检查(false, 说明);
        特征节点身份 输出;
        输出.状态 = 特征体系读取状态::内部不一致;
        输出.节点 = 目标;
        return 输出;
    }

    std::optional<特征关系证据> 读取关系证据_已许可(
        const 关系记录& 记录,
        const 结构事务令牌& 令牌) const {
        if (记录.状态 != 记录状态::有效 || !句柄有效(记录.源节点)
            || !句柄有效(记录.目标节点)) return std::nullopt;
        const 关系句柄 句柄{关系仓库编号_, 记录.关系编号, 记录.版本号};
        const auto 当前 = 关系_.读取关系(句柄, 令牌);
        if (!当前.has_value() || 当前->状态 != 记录状态::有效
            || 当前->类型 != 记录.类型 || 当前->源节点 != 记录.源节点
            || 当前->目标节点 != 记录.目标节点 || 当前->顺序号 != 记录.顺序号) {
            return std::nullopt;
        }
        return 特征关系证据{句柄, 记录.类型, 记录.源节点, 记录.目标节点, 记录.顺序号};
    }

    std::optional<std::uint64_t> 读取唯一主键_已许可(
        节点句柄 目标,
        std::optional<std::uint64_t> 期望主键,
        const 结构事务令牌& 令牌) const {
        const auto 主键组 = 索引_.读取节点主键组(目标, 令牌);
        if (主键组.size() != 1 || 主键组.front() == 0) return std::nullopt;
        if (期望主键.has_value() && 主键组.front() != *期望主键) return std::nullopt;
        if (索引_.按主键查节点(主键组.front(), 令牌) != std::optional<节点句柄>{目标}) {
            return std::nullopt;
        }
        return 主键组.front();
    }

    特征定义值式材料 读取特征定义_已许可(
        节点句柄 目标,
        std::optional<std::uint64_t> 期望主键,
        const 结构事务令牌& 令牌) const {
        特征定义值式材料 输出;
        输出.特征定义 = 目标;
        const auto 身份 = 读取节点身份_已许可(目标, 令牌);
        if (!身份.当前可读()) {
            输出.状态 = 身份.状态;
            return 输出;
        }
        if (身份.类型 != 节点类型::特征) {
            输出.状态 = 特征体系读取状态::类型不匹配;
            return 输出;
        }
        if (!关系_.获取关系记录组(目标, 关系类型::模板, 令牌).empty()) {
            输出.状态 = 特征体系读取状态::类型不匹配;
            return 输出;
        }
        const auto 主键 = 读取唯一主键_已许可(目标, 期望主键, 令牌);
        if (!主键.has_value()) return 定义内部不一致(目标, L"特征定义缺少唯一非零主键或索引复核失败。");
        输出.状态 = 特征体系读取状态::已找到;
        输出.幂等主键 = *主键;
        输出.主信息 = 身份.主信息;
        return 输出;
    }

    特征槽位值式材料 读取实例槽位_已许可(
        节点句柄 目标,
        std::optional<std::uint64_t> 期望主键,
        const 结构事务令牌& 令牌) const {
        特征槽位值式材料 输出;
        输出.实例槽位 = 目标;
        const auto 身份 = 读取节点身份_已许可(目标, 令牌);
        if (!身份.当前可读()) {
            输出.状态 = 身份.状态;
            return 输出;
        }
        if (身份.类型 != 节点类型::特征) {
            输出.状态 = 特征体系读取状态::类型不匹配;
            return 输出;
        }
        const auto 主键 = 读取唯一主键_已许可(目标, 期望主键, 令牌);
        if (!主键.has_value()) return 槽位内部不一致(目标, L"实例特征槽位缺少唯一非零主键。");

        const auto 模板组 = 关系_.获取关系记录组(目标, 关系类型::模板, 令牌);
        if (模板组.size() != 1) {
            输出.状态 = 模板组.empty()
                ? 特征体系读取状态::类型不匹配 : 特征体系读取状态::内部不一致;
            return 输出;
        }
        const auto 模板证据 = 读取关系证据_已许可(模板组.front(), 令牌);
        if (!模板证据.has_value()) return 槽位内部不一致(目标, L"实例特征槽位模板关系无法完整读回。");
        const auto 定义 = 读取特征定义_已许可(模板证据->目标节点, std::nullopt, 令牌);
        if (!定义.完整()) return 槽位内部不一致(目标, L"实例特征槽位模板目标不是完整特征定义。");

        const auto 来源组 = 关系_.获取来源关系记录组(目标, 关系类型::归属, 令牌);
        if (来源组.size() != 1) return 槽位内部不一致(目标, L"实例特征槽位没有唯一宿主归属来源。");
        const auto 宿主证据 = 读取关系证据_已许可(来源组.front(), 令牌);
        if (!宿主证据.has_value()) return 槽位内部不一致(目标, L"实例特征槽位宿主关系无法完整读回。");
        const auto 宿主 = 读取节点身份_已许可(宿主证据->源节点, 令牌);
        if (!宿主.当前可读() || !允许特征宿主(宿主.类型)) {
            return 槽位内部不一致(目标, L"实例特征槽位宿主类型不在固定白名单。");
        }

        输出.状态 = 特征体系读取状态::已找到;
        输出.幂等主键 = *主键;
        输出.宿主 = 宿主.节点;
        输出.特征定义 = 定义.特征定义;
        输出.主信息 = 身份.主信息;
        输出.宿主关系 = *宿主证据;
        输出.模板关系 = *模板证据;
        return 输出;
    }

    特征槽位值式材料 读取宿主定义槽位_已许可(
        节点句柄 宿主,
        节点句柄 特征定义,
        const 结构事务令牌& 令牌) const {
        特征槽位值式材料 输出;
        输出.宿主 = 宿主;
        输出.特征定义 = 特征定义;
        const auto 宿主身份 = 读取节点身份_已许可(宿主, 令牌);
        if (!宿主身份.当前可读()) {
            输出.状态 = 宿主身份.状态;
            return 输出;
        }
        if (!允许特征宿主(宿主身份.类型)) return 输出;
        const auto 定义 = 读取特征定义_已许可(特征定义, std::nullopt, 令牌);
        if (!定义.完整()) {
            输出.状态 = 定义.状态;
            return 输出;
        }

        std::optional<特征槽位值式材料> 命中;
        for (const auto& 记录 : 关系_.获取关系记录组(宿主, 关系类型::归属, 令牌)) {
            const auto 证据 = 读取关系证据_已许可(记录, 令牌);
            if (!证据.has_value()) return 槽位内部不一致({}, L"宿主归属候选关系无法完整读回。");
            const auto 目标身份 = 读取节点身份_已许可(记录.目标节点, 令牌);
            if (!目标身份.当前可读()) return 槽位内部不一致({}, L"宿主归属候选端点无法完整读回。");
            if (目标身份.类型 != 节点类型::特征) continue;
            const auto 候选 = 读取实例槽位_已许可(记录.目标节点, std::nullopt, 令牌);
            if (候选.状态 == 特征体系读取状态::类型不匹配) continue;
            if (!候选.完整()) return 候选;
            if (候选.宿主 != 宿主 || 候选.特征定义 != 特征定义) continue;
            if (命中.has_value()) return 槽位内部不一致(候选.实例槽位, L"同一宿主和特征定义出现多个实例槽位。");
            命中 = 候选;
        }
        if (!命中.has_value()) {
            输出.状态 = 特征体系读取状态::未找到;
            return 输出;
        }
        return *命中;
    }

    特征原始值式材料 读取当前值_已许可(
        const 特征槽位值式材料& 槽位,
        const 结构事务令牌& 令牌) const {
        特征原始值式材料 输出;
        输出.实例槽位 = 槽位.实例槽位;
        if (!槽位.完整()) {
            输出.状态 = 槽位.状态;
            return 输出;
        }
        const auto 当前关系组 = 关系_.获取关系记录组(
            槽位.实例槽位, 关系类型::归属, 令牌);
        if (当前关系组.empty()) {
            输出.状态 = 特征体系读取状态::未找到;
            return 输出;
        }
        if (当前关系组.size() != 1) return 值内部不一致(槽位.实例槽位, L"实例槽位出现多个当前特征值关系。");
        const auto 关系证据 = 读取关系证据_已许可(当前关系组.front(), 令牌);
        if (!关系证据.has_value()) return 值内部不一致(槽位.实例槽位, L"当前特征值关系无法完整读回。");
        const auto 身份 = 读取节点身份_已许可(关系证据->目标节点, 令牌);
        if (!身份.当前可读() || 身份.类型 != 节点类型::特征值) {
            return 值内部不一致(槽位.实例槽位, L"当前特征值关系目标不是可读特征值节点。");
        }
        const auto 主键 = 读取唯一主键_已许可(身份.节点, std::nullopt, 令牌);
        if (!主键.has_value()) return 值内部不一致(槽位.实例槽位, L"当前特征值没有唯一非零主键。");

        const auto 侧表 = 侧表访问器_.读取(身份.节点);
        if (侧表.状态 == 特征值侧表读取状态::许可竞争) {
            输出.状态 = 特征体系读取状态::许可拒绝;
            return 输出;
        }
        if (!侧表.可读()) return 值内部不一致(槽位.实例槽位, L"当前特征值侧表材料缺失或互相矛盾。");

        输出.状态 = 特征体系读取状态::已找到;
        输出.幂等主键 = *主键;
        输出.特征值节点 = 身份.节点;
        输出.主信息 = 身份.主信息;
        输出.当前值关系 = *关系证据;
        输出.原始类型 = 侧表.原始类型;
        输出.原始值版本 = 侧表.原始值版本;
        if (侧表.原始类型 == 特征值原始类型::I64) {
            输出.I64值 = 主信息_.读取I64值(身份.主信息, 0, 令牌);
            if (!输出.I64值.has_value()) return 值内部不一致(槽位.实例槽位, L"I64 特征值缺少主信息值。");
        } else {
            if (主信息_.读取I64值(身份.主信息, 0, 令牌).has_value()) {
                return 值内部不一致(槽位.实例槽位, L"Vec 特征值错误携带 I64 主信息值。");
            }
            输出.VecI64值 = 侧表.VecI64值;
            输出.VecU64值 = 侧表.VecU64值;
        }
        return 输出;
    }

    特征原始值式材料 读取批次历史值_已许可(
        const 特征槽位值式材料& 槽位,
        const 特征批次发布项目& 项目,
        const 结构事务令牌& 令牌) const {
        特征原始值式材料 输出;
        输出.实例槽位 = 槽位.实例槽位;
        if (!槽位.完整() || 项目.实例槽位 != 槽位.实例槽位
            || !句柄有效(项目.新特征值)
            || !句柄有效(项目.发布后新当前关系)) {
            输出.状态 = 特征体系读取状态::内部不一致;
            return 输出;
        }
        const auto 身份 = 读取节点身份_已许可(项目.新特征值, 令牌);
        if (!身份.当前可读() || 身份.类型 != 节点类型::特征值) {
            return 值内部不一致(槽位.实例槽位, L"批次历史特征值节点不可读或类型错误。");
        }
        const auto 主键 = 读取唯一主键_已许可(身份.节点, std::nullopt, 令牌);
        if (!主键.has_value()) {
            return 值内部不一致(槽位.实例槽位, L"批次历史特征值缺少唯一主键。");
        }
        const auto 审计关系组 = 关系_.获取关系审计记录组(
            槽位.实例槽位, 关系类型::归属, 令牌);
        const auto 关系位置 = std::find_if(
            审计关系组.begin(), 审计关系组.end(), [&](const 关系记录& 记录) {
                return 记录.关系编号 == 项目.发布后新当前关系.关系编号
                    && 记录.源节点 == 槽位.实例槽位
                    && 记录.目标节点 == 身份.节点
                    && 记录.版本号 >= 项目.发布后新当前关系.版本号;
            });
        if (关系位置 == 审计关系组.end()) {
            return 值内部不一致(槽位.实例槽位, L"批次历史当前值关系缺少审计互证。");
        }
        const auto 侧表 = 侧表访问器_.读取(身份.节点);
        if (侧表.状态 == 特征值侧表读取状态::许可竞争) {
            输出.状态 = 特征体系读取状态::许可拒绝;
            return 输出;
        }
        if (!侧表.可读()) {
            return 值内部不一致(槽位.实例槽位, L"批次历史特征值侧表材料缺失。");
        }
        输出.状态 = 特征体系读取状态::已找到;
        输出.幂等主键 = *主键;
        输出.特征值节点 = 身份.节点;
        输出.主信息 = 身份.主信息;
        输出.当前值关系 = {
            项目.发布后新当前关系, 关系类型::归属,
            槽位.实例槽位, 身份.节点, 0};
        输出.原始类型 = 侧表.原始类型;
        输出.原始值版本 = 侧表.原始值版本;
        if (侧表.原始类型 == 特征值原始类型::I64) {
            输出.I64值 = 主信息_.读取I64值(身份.主信息, 0, 令牌);
            if (!输出.I64值.has_value()) {
                return 值内部不一致(槽位.实例槽位, L"批次历史 I64 特征值缺少主信息值。");
            }
        } else {
            if (主信息_.读取I64值(身份.主信息, 0, 令牌).has_value()) {
                return 值内部不一致(槽位.实例槽位, L"批次历史 Vec 特征值错误携带 I64 值。");
            }
            输出.VecI64值 = 侧表.VecI64值;
            输出.VecU64值 = 侧表.VecU64值;
        }
        return 输出;
    }

    特征原始值式材料 读取主键当前值候选(std::uint64_t 主键) const {
        if (!有效() || 主键 == 0) return {};
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) return {特征体系读取状态::许可拒绝};
        const auto 目标 = 索引_.按主键查节点(主键, 许可.读取令牌());
        if (!目标.has_value()) return {特征体系读取状态::未找到};
        const auto 身份 = 读取节点身份_已许可(*目标, 许可.读取令牌());
        if (!身份.当前可读()) return {身份.状态};
        if (身份.类型 != 节点类型::特征值) return {特征体系读取状态::类型不匹配};
        const auto 来源组 = 关系_.获取来源关系记录组(*目标, 关系类型::归属, 许可.读取令牌());
        if (来源组.size() != 1) return 值内部不一致({}, L"主键特征值没有唯一实例槽位来源。");
        const auto 槽位 = 读取实例槽位_已许可(来源组.front().源节点, std::nullopt, 许可.读取令牌());
        if (!槽位.完整()) return 从槽位失败形成值(槽位);
        auto 输出 = 读取当前值_已许可(槽位, 许可.读取令牌());
        if (输出.完整() && 输出.幂等主键 != 主键) {
            return 值内部不一致(槽位.实例槽位, L"主键特征值反向读回到不同主键。");
        }
        return 输出;
    }

    二次特征值式材料 读取二次特征_已许可(
        节点句柄 目标,
        std::optional<std::uint64_t> 期望主键,
        const 结构事务令牌& 令牌) const {
        二次特征值式材料 输出;
        输出.二次特征 = 目标;
        const auto 身份 = 读取节点身份_已许可(目标, 令牌);
        if (!身份.当前可读()) {
            输出.状态 = 身份.状态;
            return 输出;
        }
        if (身份.类型 != 节点类型::二次特征) {
            输出.状态 = 特征体系读取状态::类型不匹配;
            return 输出;
        }
        const auto 主键 = 读取唯一主键_已许可(目标, 期望主键, 令牌);
        if (!主键.has_value()) return 二次特征内部不一致(目标, L"二次特征缺少唯一非零主键。");
        const auto 关系组 = 关系_.获取关系记录组(目标, 关系类型::引用, 令牌);
        if (关系组.empty()) return 二次特征内部不一致(目标, L"二次特征组成项为空。");
        std::vector<std::optional<节点句柄>> 项组(关系组.size());
        std::vector<std::optional<特征关系证据>> 证据组(关系组.size());
        for (const auto& 记录 : 关系组) {
            if (记录.顺序号 < 0 || static_cast<std::size_t>(记录.顺序号) >= 关系组.size()) {
                return 二次特征内部不一致(目标, L"二次特征组成关系顺序号不连续。");
            }
            const auto 位置 = static_cast<std::size_t>(记录.顺序号);
            if (项组[位置].has_value()) return 二次特征内部不一致(目标, L"二次特征组成关系顺序号重复。");
            const auto 证据 = 读取关系证据_已许可(记录, 令牌);
            const auto 项身份 = 读取节点身份_已许可(记录.目标节点, 令牌);
            if (!证据.has_value() || !项身份.当前可读()
                || !允许二次特征组成项(项身份.类型) || 记录.目标节点 == 目标) {
                return 二次特征内部不一致(目标, L"二次特征组成项类型、端点或关系证据无效。");
            }
            for (const auto& 已有 : 项组) {
                if (已有.has_value() && *已有 == 记录.目标节点) {
                    return 二次特征内部不一致(目标, L"二次特征包含重复组成项。");
                }
            }
            项组[位置] = 记录.目标节点;
            证据组[位置] = *证据;
        }
        输出.有序组成项组.reserve(项组.size());
        输出.组成关系组.reserve(证据组.size());
        for (std::size_t 索引 = 0; 索引 < 项组.size(); ++索引) {
            if (!项组[索引].has_value() || !证据组[索引].has_value()) {
                return 二次特征内部不一致(目标, L"二次特征组成关系存在顺序空洞。");
            }
            输出.有序组成项组.push_back(*项组[索引]);
            输出.组成关系组.push_back(*证据组[索引]);
        }
        输出.状态 = 特征体系读取状态::已找到;
        输出.幂等主键 = *主键;
        输出.主信息 = 身份.主信息;
        return 输出;
    }

    特征定义值式材料 定义内部不一致(节点句柄 目标, const wchar_t* 说明) const {
        (void)追根因检查(false, 说明);
        特征定义值式材料 输出;
        输出.状态 = 特征体系读取状态::内部不一致;
        输出.特征定义 = 目标;
        return 输出;
    }

    特征槽位值式材料 槽位内部不一致(节点句柄 目标, const wchar_t* 说明) const {
        (void)追根因检查(false, 说明);
        特征槽位值式材料 输出;
        输出.状态 = 特征体系读取状态::内部不一致;
        输出.实例槽位 = 目标;
        return 输出;
    }

    特征原始值式材料 值内部不一致(节点句柄 槽位, const wchar_t* 说明) const {
        (void)追根因检查(false, 说明);
        特征原始值式材料 输出;
        输出.状态 = 特征体系读取状态::内部不一致;
        输出.实例槽位 = 槽位;
        return 输出;
    }

    二次特征值式材料 二次特征内部不一致(节点句柄 目标, const wchar_t* 说明) const {
        (void)追根因检查(false, 说明);
        二次特征值式材料 输出;
        输出.状态 = 特征体系读取状态::内部不一致;
        输出.二次特征 = 目标;
        return 输出;
    }

    static 特征原始值式材料 从槽位失败形成值(const 特征槽位值式材料& 槽位) {
        特征原始值式材料 输出;
        输出.状态 = 槽位.状态;
        输出.实例槽位 = 槽位.实例槽位;
        return 输出;
    }

    static bool 记录匹配证据(const 关系记录& 记录, const 特征关系证据& 证据) noexcept {
        return 证据.完整() && 记录.关系编号 == 证据.关系.关系编号
            && 记录.版本号 == 证据.关系.版本号 && 记录.类型 == 证据.类型
            && 记录.源节点 == 证据.源节点 && 记录.目标节点 == 证据.目标节点
            && 记录.顺序号 == 证据.顺序号 && 记录.状态 == 记录状态::有效;
    }

    static bool 关系组包含证据(
        const std::vector<关系记录>& 关系组,
        const 特征关系证据& 证据) noexcept {
        return std::count_if(关系组.begin(), 关系组.end(), [&](const auto& 记录) {
            return 记录匹配证据(记录, 证据);
        }) == 1;
    }

    static bool 写入带主键节点_会话(
        结构写入会话& 会话,
        节点类型 类型,
        std::uint64_t 主键,
        主信息句柄& 新主信息,
        节点句柄& 新节点) {
        const auto 主结果 = 会话.创建主信息候选();
        if (!主结果.成功()) return false;
        新主信息 = *主结果.值;
        const auto 节点结果 = 会话.创建节点候选(类型, 新主信息);
        if (!节点结果.成功()) return false;
        新节点 = *节点结果.值;
        if (!会话.绑定主键(形成索引绑定请求(
            主键, 新节点, 索引所有者::特征体系)).成功()) return false;
        return 会话.主信息可读(新主信息) && 会话.节点可读(新节点)
            && 会话.主键绑定匹配(主键, 新节点);
    }

    static bool 验证宿主定义_会话(
        结构写入会话& 会话,
        const 特征节点身份& 宿主,
        const 特征定义值式材料& 定义) {
        return 宿主.当前可读() && 定义.完整()
            && 会话.读取节点类型(宿主.节点) == std::optional<节点类型>{宿主.类型}
            && 会话.读取节点主信息(宿主.节点) == std::optional<主信息句柄>{宿主.主信息}
            && 会话.读取节点类型(定义.特征定义) == std::optional<节点类型>{节点类型::特征}
            && 会话.读取节点主信息(定义.特征定义) == std::optional<主信息句柄>{定义.主信息}
            && 会话.主键绑定匹配(定义.幂等主键, 定义.特征定义)
            && 会话.读取关系记录组(定义.特征定义, 关系类型::模板).empty();
    }

    static bool 存在宿主定义槽位_会话(
        结构写入会话& 会话,
        节点句柄 宿主,
        节点句柄 特征定义) {
        for (const auto& 宿主关系 : 会话.读取关系记录组(宿主, 关系类型::归属)) {
            if (会话.读取节点类型(宿主关系.目标节点)
                != std::optional<节点类型>{节点类型::特征}) continue;
            const auto 模板组 = 会话.读取关系记录组(宿主关系.目标节点, 关系类型::模板);
            for (const auto& 模板 : 模板组) {
                if (模板.目标节点 == 特征定义) return true;
            }
        }
        return false;
    }

    static bool 验证槽位_会话(结构写入会话& 会话, const 特征槽位值式材料& 槽位) {
        if (!槽位.完整()
            || 会话.读取节点类型(槽位.宿主) == std::nullopt
            || 会话.读取节点类型(槽位.实例槽位) != std::optional<节点类型>{节点类型::特征}
            || 会话.读取节点主信息(槽位.实例槽位) != std::optional<主信息句柄>{槽位.主信息}
            || 会话.读取节点类型(槽位.特征定义) != std::optional<节点类型>{节点类型::特征}
            || !会话.主键绑定匹配(槽位.幂等主键, 槽位.实例槽位)) return false;
        const auto 宿主关系组 = 会话.读取关系记录组(槽位.宿主, 关系类型::归属);
        const auto 模板关系组 = 会话.读取关系记录组(槽位.实例槽位, 关系类型::模板);
        return 关系组包含证据(宿主关系组, 槽位.宿主关系)
            && 模板关系组.size() == 1 && 关系组包含证据(模板关系组, 槽位.模板关系);
    }

    static bool 写入槽位_会话(
        结构写入会话& 会话,
        const 特征槽位写入规格& 规格,
        特征槽位值式材料& 输出) {
        主信息句柄 新主信息;
        节点句柄 新槽位;
        if (!写入带主键节点_会话(
                会话, 节点类型::特征, 规格.读取幂等主键(), 新主信息, 新槽位)) return false;
        const auto 宿主关系 = 会话.创建关系(
            关系类型::归属, 规格.读取宿主(), 新槽位);
        if (!宿主关系.成功()) return false;
        const auto 模板关系 = 会话.创建关系(
            关系类型::模板, 新槽位, 规格.读取特征定义());
        if (!模板关系.成功()) return false;
        if (!会话.关系可读(*宿主关系.值) || !会话.关系可读(*模板关系.值)) return false;
        输出.状态 = 特征体系读取状态::已找到;
        输出.幂等主键 = 规格.读取幂等主键();
        输出.宿主 = 规格.读取宿主();
        输出.特征定义 = 规格.读取特征定义();
        输出.实例槽位 = 新槽位;
        输出.主信息 = 新主信息;
        输出.宿主关系 = {*宿主关系.值, 关系类型::归属, 输出.宿主, 新槽位, 0};
        输出.模板关系 = {*模板关系.值, 关系类型::模板, 新槽位, 输出.特征定义, 0};
        return true;
    }

    static bool 写入初始值_会话(
        结构写入会话& 会话,
        特征值原始材料事务参与者& 参与者,
        节点句柄 实例槽位,
        const 初始特征值写入规格& 规格,
        特征原始值式材料& 输出) {
        主信息句柄 新主信息;
        节点句柄 新值;
        if (!写入带主键节点_会话(
                会话, 节点类型::特征值, 规格.读取幂等主键(), 新主信息, 新值)) return false;
        const auto 当前关系 = 会话.创建关系(关系类型::归属, 实例槽位, 新值);
        if (!当前关系.成功()) return false;
        if (规格.读取原始类型() == 特征值原始类型::I64
            && !会话.写入候选I64值(新主信息, 0, *规格.读取I64值()).成功()) return false;
        特征值初始原始材料 材料{
            新值, 新主信息, 规格.读取原始类型(), 1,
            规格.读取I64值(), 规格.读取VecI64值(), 规格.读取VecU64值()};
        if (!参与者.登记初始材料(std::move(材料))) return false;
        bool 完整 = 会话.关系可读(*当前关系.值);
        if (规格.读取原始类型() == 特征值原始类型::I64) {
            完整 = 会话.候选I64值匹配(新主信息, 0, *规格.读取I64值()) && 完整;
        }
        if (!完整) return false;
        输出.状态 = 特征体系读取状态::已找到;
        输出.幂等主键 = 规格.读取幂等主键();
        输出.实例槽位 = 实例槽位;
        输出.特征值节点 = 新值;
        输出.主信息 = 新主信息;
        输出.当前值关系 = {*当前关系.值, 关系类型::归属, 实例槽位, 新值, 0};
        输出.原始类型 = 规格.读取原始类型();
        输出.原始值版本 = 1;
        输出.I64值 = 规格.读取I64值();
        输出.VecI64值 = 规格.读取VecI64值();
        输出.VecU64值 = 规格.读取VecU64值();
        return true;
    }

    static bool 匹配槽位(
        const 特征槽位值式材料& 材料,
        const 特征槽位写入规格& 规格) noexcept {
        return 材料.完整() && 材料.幂等主键 == 规格.读取幂等主键()
            && 材料.宿主 == 规格.读取宿主()
            && 材料.特征定义 == 规格.读取特征定义();
    }

    static bool 匹配原始值(
        const 特征原始值式材料& 材料,
        const 初始特征值写入规格& 规格) noexcept {
        return 材料.完整() && 材料.幂等主键 == 规格.读取幂等主键()
            && 材料.原始类型 == 规格.读取原始类型() && 材料.原始值版本 == 1
            && 材料.I64值 == 规格.读取I64值()
            && 材料.VecI64值 == 规格.读取VecI64值()
            && 材料.VecU64值 == 规格.读取VecU64值();
    }

    static 特征体系业务结果 形成定义结果(
        特征体系业务状态 状态,
        const 特征定义值式材料& 定义) {
        特征体系业务结果 输出;
        输出.状态 = 状态;
        输出.定义 = 定义;
        return 输出;
    }

    static 特征体系业务结果 形成槽位结果(
        特征体系业务状态 状态,
        const 特征槽位值式材料& 槽位) {
        特征体系业务结果 输出;
        输出.状态 = 状态;
        输出.槽位 = 槽位;
        return 输出;
    }

    static 特征体系业务结果 形成值结果(
        特征体系业务状态 状态,
        const 特征槽位值式材料& 槽位,
        const 特征原始值式材料& 当前值) {
        特征体系业务结果 输出;
        输出.状态 = 状态;
        输出.槽位 = 槽位;
        输出.当前值 = 当前值;
        return 输出;
    }

    static 特征体系业务结果 形成二次特征结果(
        特征体系业务状态 状态,
        const 二次特征值式材料& 二次特征) {
        特征体系业务结果 输出;
        输出.状态 = 状态;
        输出.二次特征 = 二次特征;
        return 输出;
    }

    static 特征体系业务结果 合并身份定义失败(
        const 特征节点身份& 身份,
        const 特征定义值式材料& 定义) noexcept {
        if (身份.状态 == 特征体系读取状态::内部不一致
            || 定义.状态 == 特征体系读取状态::内部不一致) return {特征体系业务状态::内部不一致};
        if (身份.状态 == 特征体系读取状态::许可拒绝
            || 定义.状态 == 特征体系读取状态::许可拒绝) return {特征体系业务状态::许可拒绝};
        if (身份.状态 == 特征体系读取状态::版本漂移
            || 定义.状态 == 特征体系读取状态::版本漂移) return {特征体系业务状态::版本漂移};
        return {特征体系业务状态::入口拒绝};
    }

    static 特征体系业务结果 从读取失败形成结果(特征体系读取状态 状态) noexcept {
        switch (状态) {
        case 特征体系读取状态::许可拒绝:
            return {特征体系业务状态::许可拒绝};
        case 特征体系读取状态::版本漂移:
            return {特征体系业务状态::版本漂移};
        case 特征体系读取状态::内部不一致:
            return {特征体系业务状态::内部不一致};
        default:
            return {特征体系业务状态::入口拒绝};
        }
    }

    static 特征体系业务结果 映射结构失败(const 结构写入结果& 结果) {
        switch (结果.状态) {
        case 结构写入状态::许可拒绝:
            return {特征体系业务状态::许可拒绝};
        case 结构写入状态::版本漂移:
            return {特征体系业务状态::版本漂移};
        case 结构写入状态::入口拒绝:
            (void)追根因检查(false, L"特征体系业务准入后结构会话未形成提交决定。");
            return {特征体系业务状态::内部不一致};
        case 结构写入状态::内部不一致:
            (void)追根因检查(false, L"特征体系结构写入或参与者收口内部不一致。");
            return {特征体系业务状态::内部不一致};
        default:
            (void)追根因检查(false, L"特征体系结构会话返回不允许的收口状态。");
            return {特征体系业务状态::内部不一致};
        }
    }

    结构事务接线 接线_;
    主信息仓库& 主信息_;
    节点仓库& 节点_;
    关系仓库& 关系_;
    索引仓库& 索引_;
    特征值服务& 特征值_;
    std::uint64_t 关系仓库编号_ = 0;
    结构写入执行器 执行器_;
    特征值原始材料侧表访问器 侧表访问器_;
    mutable 特征批次发布记录账 批次记录账_;
    mutable 特征批次发布记录账访问器 批次记录访问器_;
};

class 特征批次结构参与包 final {
public:
    特征批次结构参与包(const 特征批次结构参与包&) = delete;
    特征批次结构参与包& operator=(const 特征批次结构参与包&) = delete;
    特征批次结构参与包(特征批次结构参与包&&) = delete;
    特征批次结构参与包& operator=(特征批次结构参与包&&) = delete;

private:
    friend class 特征批次同层授权桥;
    friend class 特征体系数据操作;

    特征批次结构参与包(
        const 特征体系数据操作& 数据操作,
        特征批次变更规格 规格)
        : 数据操作_(数据操作), 规格_(std::move(规格)),
          原始材料参与者_(数据操作_.特征值_),
          批次记录参与者_(数据操作_.批次记录账_) {
        候选结果_.批次 = 规格_.读取批次身份();
        候选结果_.业务规则版本 = 规格_.读取业务规则版本();
        候选结果_.宿主 = 规格_.读取宿主();
    }

    bool 形成候选_(结构写入会话& 会话) {
        if (候选结果_.状态 != 特征批次提交状态::入口拒绝) return false;
        特征批次提交状态 提前收口 = 特征批次提交状态::入口拒绝;
        const bool 已形成 = 数据操作_.形成特征批次候选_会话(
            会话, 规格_, 原始材料参与者_, 批次记录参与者_, 候选结果_, 提前收口);
        if (!已形成 && 提前收口 != 特征批次提交状态::入口拒绝
            && 提前收口 != 特征批次提交状态::幂等读回) {
            候选结果_.状态 = 提前收口;
        }
        return 已形成;
    }

    特征批次结果 读取候选结果_() const {
        if (候选结果_.状态 != 特征批次提交状态::入口拒绝) return 候选结果_;
        return 数据操作_.读取特征批次结果(规格_);
    }

    const 特征体系数据操作& 数据操作_;
    特征批次变更规格 规格_;
    特征值原始材料事务参与者 原始材料参与者_;
    特征批次发布记录事务参与者 批次记录参与者_;
    特征批次结果 候选结果_;
};

inline bool 特征体系数据操作::批次记录语义匹配_(
    const 特征批次变更规格& 规格,
    const 特征批次发布记录& 记录) noexcept {
    if (!规格.完整() || !记录.完整() || 记录.批次 != 规格.读取批次身份()
        || 记录.记录格式版本 != 特征批次发布记录::当前记录格式版本
        || 记录.业务规则版本 != 规格.读取业务规则版本()
        || 记录.宿主 != 规格.读取宿主()
        || 记录.项目组.size() != 规格.读取项目组().size()) return false;
    for (std::size_t 索引 = 0; 索引 < 记录.项目组.size(); ++索引) {
        const auto& 已发布 = 记录.项目组[索引];
        const auto& 请求 = 规格.读取项目组()[索引];
        if (const auto* 初始 = std::get_if<特征批次初始项规格>(&请求)) {
            if (已发布.种类 != 特征批次项目种类::初始
                || 已发布.顺序号 != 初始->读取顺序号()
                || 已发布.特征定义 != 初始->读取特征定义()
                || 已发布.来源 != 初始->读取来源()) return false;
        } else {
            const auto& 换代 = std::get<特征批次换代项规格>(请求);
            if (已发布.种类 != 特征批次项目种类::换代
                || 已发布.顺序号 != 换代.读取顺序号()
                || 已发布.实例槽位 != 换代.读取实例槽位()
                || 已发布.特征定义 != 换代.读取特征定义()
                || 已发布.来源 != 换代.读取来源()
                || 已发布.写前当前关系 != 换代.读取预期当前关系()
                || 已发布.写前当前值 != 换代.读取预期当前值()
                || 已发布.写前原始值版本 != 换代.读取预期原始值版本()) return false;
        }
    }
    return true;
}

inline 特征批次结果 特征体系数据操作::从批次记录形成结果_(
    const 特征批次变更规格& 规格,
    const 特征批次发布记录& 记录,
    特征批次提交状态 状态) const {
    特征批次结果 输出;
    输出.状态 = 状态;
    输出.批次 = 规格.读取批次身份();
    输出.业务规则版本 = 规格.读取业务规则版本();
    输出.宿主 = 规格.读取宿主();
    if (!批次记录语义匹配_(规格, 记录)) {
        输出.状态 = 特征批次提交状态::幂等冲突;
        return 输出;
    }
    auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
    if (!许可.有效()) {
        输出.状态 = 特征批次提交状态::许可拒绝;
        return 输出;
    }
    输出.项目组.reserve(记录.项目组.size());
    for (std::size_t 索引 = 0; 索引 < 记录.项目组.size(); ++索引) {
        const auto& 已发布 = 记录.项目组[索引];
        const auto& 请求 = 规格.读取项目组()[索引];
        const auto 槽位 = 读取实例槽位_已许可(
            已发布.实例槽位, std::nullopt, 许可.读取令牌());
        const auto 新值 = 读取批次历史值_已许可(
            槽位, 已发布, 许可.读取令牌());
        const auto 来源 = 读取节点身份_已许可(
            已发布.来源, 许可.读取令牌());
        if (!槽位.完整() || !新值.完整() || !来源.当前可读()) {
            输出.状态 = 槽位.状态 == 特征体系读取状态::许可拒绝
                    || 新值.状态 == 特征体系读取状态::许可拒绝
                    || 来源.状态 == 特征体系读取状态::许可拒绝
                ? 特征批次提交状态::许可拒绝
                : 特征批次提交状态::内部不一致;
            输出.项目组.clear();
            return 输出;
        }
        if (槽位.宿主 != 记录.宿主 || 槽位.特征定义 != 已发布.特征定义
            || 新值.特征值节点 != 已发布.新特征值
            || 新值.当前值关系.关系 != 已发布.发布后新当前关系) {
            输出.状态 = 特征批次提交状态::内部不一致;
            输出.项目组.clear();
            return 输出;
        }
        const auto& 新值规格 = std::visit(
            [](const auto& 项目) -> const 初始特征值写入规格& {
                return 项目.读取新值规格();
            }, 请求);
        const bool 请求键和值匹配 = 新值.幂等主键 == 新值规格.读取幂等主键()
            && 匹配原始值(新值, 新值规格)
            && (std::holds_alternative<特征批次换代项规格>(请求)
                || 槽位.幂等主键
                    == std::get<特征批次初始项规格>(请求).读取槽位幂等主键());
        if (!请求键和值匹配) {
            输出.状态 = 特征批次提交状态::幂等冲突;
            输出.项目组.clear();
            return 输出;
        }
        输出.项目组.push_back({
            已发布.顺序号, 已发布.种类, 已发布.特征定义,
            槽位, 新值, 已发布.来源, 已发布.写前当前关系,
            已发布.写前当前值, 已发布.写前原始值版本});
    }
    return 输出;
}

inline 特征批次结果 特征体系数据操作::读取特征批次结果(
    const 特征批次变更规格& 规格) const {
    特征批次结果 输出;
    if (!规格.完整()) return 输出;
    输出.批次 = 规格.读取批次身份();
    输出.业务规则版本 = 规格.读取业务规则版本();
    输出.宿主 = 规格.读取宿主();
    const auto 读取 = 批次记录访问器_.读取(规格.读取批次身份());
    switch (读取.状态) {
    case 特征批次发布记录读取状态::未找到:
        return 输出;
    case 特征批次发布记录读取状态::许可竞争:
        输出.状态 = 特征批次提交状态::许可拒绝;
        return 输出;
    case 特征批次发布记录读取状态::未知格式:
        输出.状态 = 特征批次提交状态::未知格式;
        return 输出;
    case 特征批次发布记录读取状态::内部不一致:
        输出.状态 = 特征批次提交状态::内部不一致;
        return 输出;
    case 特征批次发布记录读取状态::可读:
        return 从批次记录形成结果_(
            规格, 读取.记录, 特征批次提交状态::幂等读回);
    }
    输出.状态 = 特征批次提交状态::内部不一致;
    return 输出;
}

inline std::unique_ptr<特征批次结构参与包>
特征体系数据操作::形成特征批次同层参与包_(
    const 特征批次变更规格& 规格) const {
    if (!有效() || !规格.完整()) return {};
    auto 参与包 = std::unique_ptr<特征批次结构参与包>(
        new 特征批次结构参与包(*this, 规格));
    const auto 预读 = 读取特征批次结果(规格);
    if (预读.状态 != 特征批次提交状态::入口拒绝) {
        参与包->候选结果_ = 预读;
    }
    return 参与包;
}

inline bool 特征体系数据操作::形成特征批次候选_会话(
    结构写入会话& 会话,
    const 特征批次变更规格& 规格,
    特征值原始材料事务参与者& 原始材料参与者,
    特征批次发布记录事务参与者& 批次记录参与者,
    特征批次结果& 候选结果,
    特征批次提交状态& 提前收口状态) const {
    const auto 锁内记录 = 批次记录访问器_.读取(规格.读取批次身份());
    if (锁内记录.状态 != 特征批次发布记录读取状态::未找到) {
        if (锁内记录.状态 == 特征批次发布记录读取状态::可读) {
            提前收口状态 = 批次记录语义匹配_(规格, 锁内记录.记录)
                ? 特征批次提交状态::幂等读回
                : 特征批次提交状态::幂等冲突;
        } else if (锁内记录.状态 == 特征批次发布记录读取状态::许可竞争) {
            提前收口状态 = 特征批次提交状态::许可拒绝;
        } else if (锁内记录.状态 == 特征批次发布记录读取状态::未知格式) {
            提前收口状态 = 特征批次提交状态::未知格式;
        } else {
            提前收口状态 = 特征批次提交状态::内部不一致;
        }
        return false;
    }

    const auto 宿主类型 = 会话.读取节点类型(规格.读取宿主());
    if (!宿主类型.has_value() || !允许特征宿主(*宿主类型)) {
        提前收口状态 = 特征批次提交状态::版本漂移;
        return false;
    }
    for (const auto& 项目 : 规格.读取项目组()) {
        const auto 定义 = std::visit([](const auto& 值) { return 值.读取特征定义(); }, 项目);
        const auto 来源 = std::visit([](const auto& 值) { return 值.读取来源(); }, 项目);
        const auto 新值主键 = std::visit(
            [](const auto& 值) { return 值.读取新值规格().读取幂等主键(); }, 项目);
        if (会话.读取节点类型(定义) != std::optional<节点类型>{节点类型::特征}
            || !会话.读取节点类型(来源).has_value()) {
            提前收口状态 = 特征批次提交状态::版本漂移;
            return false;
        }
        const auto 新值绑定 = 会话.读取物理主键当前绑定(新值主键);
        if (新值绑定.状态 != 结构写入会话::物理主键读取状态::空闲) {
            提前收口状态 = 新值绑定.状态 == 结构写入会话::物理主键读取状态::已绑定
                ? 特征批次提交状态::幂等冲突
                : 特征批次提交状态::内部不一致;
            return false;
        }
        if (const auto* 初始 = std::get_if<特征批次初始项规格>(&项目)) {
            const auto 槽位绑定 = 会话.读取物理主键当前绑定(初始->读取槽位幂等主键());
            if (槽位绑定.状态 != 结构写入会话::物理主键读取状态::空闲
                || 存在宿主定义槽位_会话(
                    会话, 规格.读取宿主(), 初始->读取特征定义())) {
                提前收口状态 = 特征批次提交状态::幂等冲突;
                return false;
            }
            continue;
        }
        const auto& 换代 = std::get<特征批次换代项规格>(项目);
        if (会话.读取节点类型(换代.读取实例槽位())
                != std::optional<节点类型>{节点类型::特征}
            || 会话.读取节点类型(换代.读取预期当前值())
                != std::optional<节点类型>{节点类型::特征值}) {
            提前收口状态 = 特征批次提交状态::版本漂移;
            return false;
        }
        const auto 当前组 = 会话.读取关系记录组(
            换代.读取实例槽位(), 关系类型::归属);
        if (当前组.size() != 1) {
            提前收口状态 = 特征批次提交状态::版本漂移;
            return false;
        }
        const 关系句柄 当前关系{
            关系仓库编号_, 当前组.front().关系编号, 当前组.front().版本号};
        const auto 原始材料 = 侧表访问器_.读取(换代.读取预期当前值());
        if (当前关系 != 换代.读取预期当前关系()
            || 当前组.front().目标节点 != 换代.读取预期当前值()
            || !原始材料.可读()
            || 原始材料.原始值版本 != 换代.读取预期原始值版本()) {
            提前收口状态 = 原始材料.状态 == 特征值侧表读取状态::许可竞争
                ? 特征批次提交状态::许可拒绝
                : 特征批次提交状态::版本漂移;
            return false;
        }
    }

    特征批次发布记录 记录;
    记录.批次 = 规格.读取批次身份();
    记录.记录格式版本 = 特征批次发布记录::当前记录格式版本;
    记录.业务规则版本 = 规格.读取业务规则版本();
    记录.宿主 = 规格.读取宿主();
    记录.项目组.reserve(规格.读取项目组().size());
    候选结果.项目组.clear();
    候选结果.项目组.reserve(规格.读取项目组().size());

    for (const auto& 项目 : 规格.读取项目组()) {
        特征槽位值式材料 槽位;
        特征原始值式材料 新值;
        特征批次发布项目 发布项目;
        if (const auto* 初始 = std::get_if<特征批次初始项规格>(&项目)) {
            const 特征槽位写入规格 槽位规格(
                初始->读取槽位幂等主键(), 规格.读取宿主(), 初始->读取特征定义());
            if (!写入槽位_会话(会话, 槽位规格, 槽位)
                || !写入初始值_会话(
                    会话, 原始材料参与者, 槽位.实例槽位,
                    初始->读取新值规格(), 新值)) return false;
            发布项目 = {
                初始->读取顺序号(), 特征批次项目种类::初始,
                初始->读取特征定义(), 槽位.实例槽位, 新值.特征值节点,
                初始->读取来源(), {}, {}, 0, 新值.当前值关系.关系};
        } else {
            const auto& 换代 = std::get<特征批次换代项规格>(项目);
            const auto 旧关系失效 = 会话.失效已发布关系(换代.读取预期当前关系());
            if (!旧关系失效.成功()
                || !写入初始值_会话(
                    会话, 原始材料参与者, 换代.读取实例槽位(),
                    换代.读取新值规格(), 新值)) return false;
            槽位.状态 = 特征体系读取状态::已找到;
            槽位.宿主 = 规格.读取宿主();
            槽位.特征定义 = 换代.读取特征定义();
            槽位.实例槽位 = 换代.读取实例槽位();
            发布项目 = {
                换代.读取顺序号(), 特征批次项目种类::换代,
                换代.读取特征定义(), 换代.读取实例槽位(), 新值.特征值节点,
                换代.读取来源(), 换代.读取预期当前关系(),
                换代.读取预期当前值(), 换代.读取预期原始值版本(),
                新值.当前值关系.关系};
        }
        const auto 来源关系 = 会话.创建关系(
            关系类型::因果来源, 新值.特征值节点, 发布项目.来源,
            static_cast<std::int64_t>(发布项目.顺序号));
        if (!来源关系.成功() || !会话.关系可读(*来源关系.值)) return false;
        记录.项目组.push_back(发布项目);
    }
    if (!记录.完整() || !批次记录参与者.登记候选(std::move(记录))) return false;
    候选结果.状态 = 特征批次提交状态::入口拒绝;
    return 会话.请求提交();
}

inline 特征批次结果 特征体系数据操作::提交特征批次(
    const 特征批次变更规格& 规格) const {
    auto 参与包 = 形成特征批次同层参与包_(规格);
    if (!参与包) return {};
    auto 预读 = 参与包->读取候选结果_();
    if (预读.状态 != 特征批次提交状态::入口拒绝) return 预读;
    std::array<结构写入事务参与者*, 2> 参与者组{
        &参与包->原始材料参与者_, &参与包->批次记录参与者_};
    const auto 结构结果 = 执行器_.执行(
        [&](结构写入会话& 会话) { (void)参与包->形成候选_(会话); },
        std::span<结构写入事务参与者* const>(参与者组));
    auto 输出 = 参与包->读取候选结果_();
    if (输出.成功()) {
        if (结构结果.状态 == 结构写入状态::已提交
            || 结构结果.状态 == 结构写入状态::候选已确认) {
            输出.状态 = 特征批次提交状态::已提交;
        }
        return 输出;
    }
    if (输出.状态 != 特征批次提交状态::入口拒绝) return 输出;
    switch (结构结果.状态) {
    case 结构写入状态::许可拒绝:
        输出.状态 = 特征批次提交状态::许可拒绝;
        break;
    case 结构写入状态::版本漂移:
        输出.状态 = 特征批次提交状态::版本漂移;
        break;
    default:
        输出.状态 = 特征批次提交状态::内部不一致;
        break;
    }
    return 输出;
}

#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
inline 特征批次故障自检结果 特征体系数据操作::提交特征批次故障自检(
    const 特征批次变更规格& 规格,
    const 结构写入故障自检配置& 配置) const {
    特征批次故障自检结果 自检;
    auto 参与包 = 形成特征批次同层参与包_(规格);
    if (!参与包) return 自检;
    自检.业务结果 = 参与包->读取候选结果_();
    if (自检.业务结果.状态 != 特征批次提交状态::入口拒绝) return 自检;
    std::array<结构写入事务参与者*, 2> 参与者组{
        &参与包->原始材料参与者_, &参与包->批次记录参与者_};
    自检.结构结果 = 执行器_.执行原子收口故障自检(
        [&](结构写入会话& 会话) { (void)参与包->形成候选_(会话); },
        std::span<结构写入事务参与者* const>(参与者组),
        配置);
    自检.业务结果 = 参与包->读取候选结果_();
    if (自检.业务结果.状态 == 特征批次提交状态::入口拒绝) {
        switch (自检.结构结果.状态) {
        case 结构写入状态::许可拒绝:
            自检.业务结果.状态 = 特征批次提交状态::许可拒绝;
            break;
        case 结构写入状态::版本漂移:
            自检.业务结果.状态 = 特征批次提交状态::版本漂移;
            break;
        default:
            自检.业务结果.状态 = 特征批次提交状态::内部不一致;
            break;
        }
    }
    自检.批次仍未发布 = 读取特征批次结果(规格).状态
        == 特征批次提交状态::入口拒绝;
    return 自检;
}

inline 特征批次竞争自检结果 特征体系数据操作::提交特征批次竞争自检(
    const 特征批次变更规格& 规格,
    const std::function<特征批次结果()>& 抢先发布) const {
    特征批次竞争自检结果 自检;
    auto 参与包 = 形成特征批次同层参与包_(规格);
    if (!参与包 || !抢先发布) return 自检;
    自检.事务外预读 = 参与包->读取候选结果_();
    if (自检.事务外预读.状态 != 特征批次提交状态::入口拒绝) {
        自检.当前请求结果 = 自检.事务外预读;
        return 自检;
    }
    try {
        自检.抢先结果 = 抢先发布();
    } catch (...) {
        自检.当前请求结果.状态 = 特征批次提交状态::内部不一致;
        return 自检;
    }
    std::array<结构写入事务参与者*, 2> 参与者组{
        &参与包->原始材料参与者_, &参与包->批次记录参与者_};
    自检.当前结构结果 = 执行器_.执行(
        [&](结构写入会话& 会话) { (void)参与包->形成候选_(会话); },
        std::span<结构写入事务参与者* const>(参与者组));
    自检.当前请求结果 = 参与包->读取候选结果_();
    if (自检.当前请求结果.状态 == 特征批次提交状态::入口拒绝) {
        switch (自检.当前结构结果.状态) {
        case 结构写入状态::许可拒绝:
            自检.当前请求结果.状态 = 特征批次提交状态::许可拒绝;
            break;
        case 结构写入状态::版本漂移:
            自检.当前请求结果.状态 = 特征批次提交状态::版本漂移;
            break;
        default:
            自检.当前请求结果.状态 = 特征批次提交状态::内部不一致;
            break;
        }
    }
    return 自检;
}
#endif

}
