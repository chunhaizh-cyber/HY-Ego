    特征批次结果 读取特征批次结果(const 特征批次变更规格& 规格) const;

    特征批次结果 提交特征批次(const 特征批次变更规格& 规格) const;

#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
    特征批次故障自检结果 提交特征批次故障自检(
        const 特征批次变更规格& 规格,
        const 结构写入故障自检配置& 配置) const;

    特征批次竞争自检结果 提交特征批次竞争自检(
        const 特征批次变更规格& 规格,
        const std::function<特征批次结果()>& 抢先发布) const;

    bool 自检注入批次发布记录(特征批次发布记录 记录) const {
        return 批次记录账_.自检注入已发布记录(std::move(记录));
