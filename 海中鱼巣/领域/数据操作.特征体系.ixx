    特征批次结果 读取批次账许可竞争自检(
        const 特征批次变更规格& 规格) const {
        特征批次结果 输出;
        输出.批次 = 规格.读取批次身份();
        输出.业务规则版本 = 规格.读取业务规则版本();
        输出.宿主 = 规格.读取宿主();
        const bool 已调用 = 批次记录账_.自检独占期间([&] {
            输出 = 读取特征批次结果(规格);
        });
