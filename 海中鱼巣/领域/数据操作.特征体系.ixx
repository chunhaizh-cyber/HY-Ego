        节点句柄 特征定义,
        节点句柄 来源,
        初始特征值写入规格 新值规格) const {
        特征批次初始项规格 规格(
            顺序号, 槽位幂等主键, 特征定义, 来源, std::move(新值规格));
        return 规格.完整()
            ? std::optional<特征批次初始项规格>{std::move(规格)}
            : std::nullopt;
