export import 海中鱼巣.领域.参与者.特征批次发布记录;
import 海中鱼巣.领域.参与者.特征值原始材料;

export namespace 海中鱼巣 {

enum class 特征体系业务状态 : std::uint8_t {
    已提交 = 1,
    幂等读回 = 2,
    入口拒绝 = 3,
    幂等冲突 = 4,
    许可拒绝 = 5,
    版本漂移 = 6,
    内部不一致 = 7
};

enum class 特征体系读取状态 : std::uint8_t {
    已找到 = 1,
    未找到 = 2,
    入口拒绝 = 3,
    许可拒绝 = 4,
    版本漂移 = 5,
    类型不匹配 = 6,
    内部不一致 = 7
};

struct 特征关系证据 {
    关系句柄 关系;
    关系类型 类型 = 关系类型::普通父子;
    节点句柄 源节点;
    节点句柄 目标节点;
    std::int64_t 顺序号 = 0;

    bool 完整() const noexcept {
        return 句柄有效(关系) && 句柄有效(源节点) && 句柄有效(目标节点);
    }
};

struct 特征节点身份 {
    特征体系读取状态 状态 = 特征体系读取状态::入口拒绝;
    节点句柄 节点;
    节点类型 类型 = 节点类型::未分类;
    主信息句柄 主信息;

    bool 当前可读() const noexcept {
        return 状态 == 特征体系读取状态::已找到
            && 句柄有效(节点) && 句柄有效(主信息);
    }
};

struct 特征定义值式材料 {
    特征体系读取状态 状态 = 特征体系读取状态::入口拒绝;
    std::uint64_t 幂等主键 = 0;
    节点句柄 特征定义;
    主信息句柄 主信息;

    bool 完整() const noexcept {
        return 状态 == 特征体系读取状态::已找到 && 幂等主键 != 0
            && 句柄有效(特征定义) && 句柄有效(主信息);
    }
};

struct 特征槽位值式材料 {
    特征体系读取状态 状态 = 特征体系读取状态::入口拒绝;
    std::uint64_t 幂等主键 = 0;
    节点句柄 宿主;
    节点句柄 特征定义;
    节点句柄 实例槽位;
    主信息句柄 主信息;
    特征关系证据 宿主关系;
    特征关系证据 模板关系;

    bool 完整() const noexcept {
        return 状态 == 特征体系读取状态::已找到 && 幂等主键 != 0
            && 句柄有效(宿主) && 句柄有效(特征定义)
            && 句柄有效(实例槽位) && 句柄有效(主信息)
            && 宿主关系.完整() && 模板关系.完整();
    }
};

struct 特征原始值式材料 {
    特征体系读取状态 状态 = 特征体系读取状态::入口拒绝;
    std::uint64_t 幂等主键 = 0;
    节点句柄 实例槽位;
    节点句柄 特征值节点;
    主信息句柄 主信息;
    特征关系证据 当前值关系;
    特征值原始类型 原始类型 = 特征值原始类型::未建立;
    std::uint64_t 原始值版本 = 0;
    std::optional<std::int64_t> I64值;
    std::vector<std::int64_t> VecI64值;
    std::vector<std::uint64_t> VecU64值;

    bool 完整() const noexcept {
        if (状态 != 特征体系读取状态::已找到 || 幂等主键 == 0
            || !句柄有效(实例槽位) || !句柄有效(特征值节点)
            || !句柄有效(主信息) || !当前值关系.完整() || 原始值版本 == 0) {
            return false;
        }
        switch (原始类型) {
        case 特征值原始类型::I64:
            return I64值.has_value() && VecI64值.empty() && VecU64值.empty();
        case 特征值原始类型::VecI64:
            return !I64值.has_value() && !VecI64值.empty() && VecU64值.empty();
        case 特征值原始类型::VecU64:
            return !I64值.has_value() && VecI64值.empty() && !VecU64值.empty();
        default:
            return false;
        }
    }
};

struct 宿主特征状态值式材料 {
    特征体系读取状态 状态 = 特征体系读取状态::入口拒绝;
    节点句柄 宿主;
    节点句柄 特征定义;
    特征槽位值式材料 槽位;
    特征原始值式材料 当前值;

    bool 有槽位() const noexcept {
        return 槽位.完整();
    }

    bool 有当前值() const noexcept {
        return 状态 == 特征体系读取状态::已找到
            && 槽位.完整() && 当前值.完整();
    }
};

struct 二次特征值式材料 {
    特征体系读取状态 状态 = 特征体系读取状态::入口拒绝;
    std::uint64_t 幂等主键 = 0;
    节点句柄 二次特征;
    主信息句柄 主信息;
    std::vector<节点句柄> 有序组成项组;
    std::vector<特征关系证据> 组成关系组;

    bool 完整() const noexcept {
        if (状态 != 特征体系读取状态::已找到 || 幂等主键 == 0
            || !句柄有效(二次特征) || !句柄有效(主信息)
            || 有序组成项组.empty() || 有序组成项组.size() != 组成关系组.size()) {
            return false;
        }
        for (std::size_t 索引 = 0; 索引 < 组成关系组.size(); ++索引) {
            if (!句柄有效(有序组成项组[索引]) || !组成关系组[索引].完整()
                || 组成关系组[索引].顺序号 != static_cast<std::int64_t>(索引)
                || 组成关系组[索引].目标节点 != 有序组成项组[索引]) return false;
        }
        return true;
    }
};

struct 特征体系业务结果 {
    特征体系业务状态 状态 = 特征体系业务状态::入口拒绝;
    特征定义值式材料 定义;
    特征槽位值式材料 槽位;
    特征原始值式材料 当前值;
    二次特征值式材料 二次特征;

    bool 成功() const noexcept {
        return 状态 == 特征体系业务状态::已提交
            || 状态 == 特征体系业务状态::幂等读回;
    }

    bool 改变了结构() const noexcept {
        return 状态 == 特征体系业务状态::已提交;
    }
};

enum class 特征批次提交状态 : std::uint8_t {
    已提交 = 1,
    幂等读回 = 2,
    入口拒绝 = 3,
    幂等冲突 = 4,
    许可拒绝 = 5,
    版本漂移 = 6,
    未知格式 = 7,
    内部不一致 = 8
};

struct 特征批次项目结果 {
    std::uint32_t 顺序号 = 0;
    特征批次项目种类 种类 = 特征批次项目种类::初始;
    节点句柄 特征定义;
    特征槽位值式材料 槽位;
    特征原始值式材料 新值;
    节点句柄 来源;
    关系句柄 写前当前关系;
    节点句柄 写前当前值;
    std::uint64_t 写前原始值版本 = 0;

    bool 完整() const noexcept {
        const bool 写前证据完整 = 种类 == 特征批次项目种类::初始
            ? !句柄有效(写前当前关系) && !句柄有效(写前当前值)
                && 写前原始值版本 == 0
            : 句柄有效(写前当前关系) && 句柄有效(写前当前值)
                && 写前原始值版本 != 0;
        return 句柄有效(特征定义) && 槽位.完整() && 新值.完整()
            && 句柄有效(来源) && 写前证据完整;
    }
};

struct 特征批次结果 {
    特征批次提交状态 状态 = 特征批次提交状态::入口拒绝;
    特征批次身份 批次;
    std::uint32_t 业务规则版本 = 0;
    节点句柄 宿主;
    std::vector<特征批次项目结果> 项目组;

    bool 成功() const noexcept {
        return 状态 == 特征批次提交状态::已提交
            || 状态 == 特征批次提交状态::幂等读回;
    }

    bool 改变了结构() const noexcept {
        return 状态 == 特征批次提交状态::已提交;
    }
};

#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
struct 特征批次故障自检结果 {
    特征批次结果 业务结果;
    结构写入结果 结构结果;
    bool 批次仍未发布 = false;
};

struct 特征批次竞争自检结果 {
    特征批次结果 事务外预读;
    特征批次结果 抢先结果;
    特征批次结果 当前请求结果;
    结构写入结果 当前结构结果;
};
#endif

class 特征槽位写入规格 final {
public:
    特征槽位写入规格() = delete;

    std::uint64_t 读取幂等主键() const noexcept { return 幂等主键_; }
    节点句柄 读取宿主() const noexcept { return 宿主_; }
    节点句柄 读取特征定义() const noexcept { return 特征定义_; }

    bool 完整() const noexcept {
        return 幂等主键_ != 0 && 句柄有效(宿主_) && 句柄有效(特征定义_)
            && 宿主_ != 特征定义_;
    }

private:
    friend class 特征体系数据操作;

    特征槽位写入规格(std::uint64_t 幂等主键, 节点句柄 宿主, 节点句柄 特征定义)
        : 幂等主键_(幂等主键), 宿主_(宿主), 特征定义_(特征定义) {}

    std::uint64_t 幂等主键_ = 0;
    节点句柄 宿主_;
    节点句柄 特征定义_;
};

class 初始特征值写入规格 final {
public:
    初始特征值写入规格() = delete;

    std::uint64_t 读取幂等主键() const noexcept { return 幂等主键_; }
    特征值原始类型 读取原始类型() const noexcept { return 原始类型_; }
    const std::optional<std::int64_t>& 读取I64值() const noexcept { return I64值_; }
    const std::vector<std::int64_t>& 读取VecI64值() const noexcept { return VecI64值_; }
    const std::vector<std::uint64_t>& 读取VecU64值() const noexcept { return VecU64值_; }

    bool 完整() const noexcept {
        if (幂等主键_ == 0) return false;
        switch (原始类型_) {
        case 特征值原始类型::I64:
            return I64值_.has_value() && VecI64值_.empty() && VecU64值_.empty();
        case 特征值原始类型::VecI64:
            return !I64值_.has_value() && !VecI64值_.empty()
                && VecI64值_.size() <= 特征值服务::最大序列元素数量 && VecU64值_.empty();
        case 特征值原始类型::VecU64:
            return !I64值_.has_value() && VecI64值_.empty() && !VecU64值_.empty()
                && VecU64值_.size() <= 特征值服务::最大序列元素数量;
        default:
            return false;
        }
    }

private:
    friend class 特征体系数据操作;

    初始特征值写入规格(
        std::uint64_t 幂等主键,
        特征值原始类型 原始类型,
        std::optional<std::int64_t> I64值,
        std::vector<std::int64_t> VecI64值,
        std::vector<std::uint64_t> VecU64值)
        : 幂等主键_(幂等主键), 原始类型_(原始类型), I64值_(I64值),
          VecI64值_(std::move(VecI64值)), VecU64值_(std::move(VecU64值)) {}

    std::uint64_t 幂等主键_ = 0;
    特征值原始类型 原始类型_ = 特征值原始类型::未建立;
    std::optional<std::int64_t> I64值_;
    std::vector<std::int64_t> VecI64值_;
    std::vector<std::uint64_t> VecU64值_;
};

class 特征批次初始项规格 final {
public:
    特征批次初始项规格() = delete;

    std::uint32_t 读取顺序号() const noexcept { return 顺序号_; }
    std::uint64_t 读取槽位幂等主键() const noexcept { return 槽位幂等主键_; }
    节点句柄 读取特征定义() const noexcept { return 特征定义_; }
    节点句柄 读取来源() const noexcept { return 来源_; }
    const 初始特征值写入规格& 读取新值规格() const noexcept { return 新值规格_; }

    bool 完整() const noexcept {
        return 槽位幂等主键_ != 0 && 句柄有效(特征定义_)
            && 句柄有效(来源_) && 特征定义_ != 来源_ && 新值规格_.完整()
            && 槽位幂等主键_ != 新值规格_.读取幂等主键();
    }

private:
    friend class 特征体系数据操作;

    特征批次初始项规格(
        std::uint32_t 顺序号,
        std::uint64_t 槽位幂等主键,
        节点句柄 特征定义,
        节点句柄 来源,
        初始特征值写入规格 新值规格)
        : 顺序号_(顺序号), 槽位幂等主键_(槽位幂等主键),
          特征定义_(特征定义), 来源_(来源), 新值规格_(std::move(新值规格)) {}

    std::uint32_t 顺序号_ = 0;
    std::uint64_t 槽位幂等主键_ = 0;
    节点句柄 特征定义_;
    节点句柄 来源_;
    初始特征值写入规格 新值规格_;
};

class 特征批次换代项规格 final {
public:
    特征批次换代项规格() = delete;

    std::uint32_t 读取顺序号() const noexcept { return 顺序号_; }
    节点句柄 读取实例槽位() const noexcept { return 实例槽位_; }
    节点句柄 读取特征定义() const noexcept { return 特征定义_; }
    关系句柄 读取预期当前关系() const noexcept { return 预期当前关系_; }
    节点句柄 读取预期当前值() const noexcept { return 预期当前值_; }
    std::uint64_t 读取预期原始值版本() const noexcept { return 预期原始值版本_; }
    节点句柄 读取来源() const noexcept { return 来源_; }
    const 初始特征值写入规格& 读取新值规格() const noexcept { return 新值规格_; }

    bool 完整() const noexcept {
        return 句柄有效(实例槽位_) && 句柄有效(特征定义_)
            && 句柄有效(预期当前关系_) && 句柄有效(预期当前值_)
            && 预期原始值版本_ != 0 && 句柄有效(来源_)
            && 新值规格_.完整() && 预期当前值_ != 来源_;
    }

private:
    friend class 特征体系数据操作;

    特征批次换代项规格(
        std::uint32_t 顺序号,
        节点句柄 实例槽位,
        节点句柄 特征定义,
        关系句柄 预期当前关系,
        节点句柄 预期当前值,
        std::uint64_t 预期原始值版本,
        节点句柄 来源,
        初始特征值写入规格 新值规格)
        : 顺序号_(顺序号), 实例槽位_(实例槽位), 特征定义_(特征定义),
          预期当前关系_(预期当前关系), 预期当前值_(预期当前值),
          预期原始值版本_(预期原始值版本), 来源_(来源),
          新值规格_(std::move(新值规格)) {}

    std::uint32_t 顺序号_ = 0;
    节点句柄 实例槽位_;
    节点句柄 特征定义_;
    关系句柄 预期当前关系_;
    节点句柄 预期当前值_;
    std::uint64_t 预期原始值版本_ = 0;
    节点句柄 来源_;
    初始特征值写入规格 新值规格_;
};

using 特征批次项目规格 = std::variant<特征批次初始项规格, 特征批次换代项规格>;

class 特征批次变更规格 final {
public:
    特征批次变更规格() = delete;

    特征批次身份 读取批次身份() const noexcept { return 批次_; }
    std::uint32_t 读取业务规则版本() const noexcept { return 业务规则版本_; }
    节点句柄 读取宿主() const noexcept { return 宿主_; }
    const std::vector<特征批次项目规格>& 读取项目组() const noexcept { return 项目组_; }

    bool 完整() const noexcept {
        if (!批次_.有效() || 业务规则版本_ != 1 || !句柄有效(宿主_)
            || 项目组_.empty()) return false;
        for (std::size_t 索引 = 0; 索引 < 项目组_.size(); ++索引) {
            const bool 完整项 = std::visit([](const auto& 项目) { return 项目.完整(); }, 项目组_[索引]);
            const auto 顺序号 = std::visit([](const auto& 项目) { return 项目.读取顺序号(); }, 项目组_[索引]);
            if (!完整项 || 顺序号 != 索引) return false;
        }
        return true;
    }

private:
    friend class 特征体系数据操作;

    特征批次变更规格(
        特征批次身份 批次,
        std::uint32_t 业务规则版本,
        节点句柄 宿主,
        std::vector<特征批次项目规格> 项目组)
        : 批次_(批次), 业务规则版本_(业务规则版本), 宿主_(宿主),
          项目组_(std::move(项目组)) {}

    特征批次身份 批次_;
    std::uint32_t 业务规则版本_ = 0;
    节点句柄 宿主_;
    std::vector<特征批次项目规格> 项目组_;
};

class 特征批次结构参与包;

class 特征体系数据操作 final {
public:
    特征体系数据操作(
        结构事务接线 接线,
        主信息仓库& 主信息,
        节点仓库& 节点,
        关系仓库& 关系,
        索引仓库& 索引,
        特征值服务& 特征值,
        std::uint64_t 关系仓库编号)
        : 接线_(std::move(接线)), 主信息_(主信息), 节点_(节点), 关系_(关系),
          索引_(索引), 特征值_(特征值), 关系仓库编号_(关系仓库编号),
          执行器_(接线_, &主信息_, &节点_, &关系_, &索引_), 侧表访问器_(特征值_),
          批次记录访问器_(批次记录账_) {}

    bool 有效() const noexcept {
        return 接线_.已接域() && 关系仓库编号_ != 0 && 执行器_.有效();
    }

    std::optional<特征槽位写入规格> 形成特征槽位写入规格(
        std::uint64_t 幂等主键,
        节点句柄 宿主,
        节点句柄 特征定义) const {
        特征槽位写入规格 规格(幂等主键, 宿主, 特征定义);
        return 规格.完整()
            ? std::optional<特征槽位写入规格>{std::move(规格)}
            : std::nullopt;
    }

    std::optional<初始特征值写入规格> 形成初始特征值写入规格(
        std::uint64_t 幂等主键,
        特征值原始类型 原始类型,
        std::optional<std::int64_t> I64值,
        std::vector<std::int64_t> VecI64值,
        std::vector<std::uint64_t> VecU64值) const {
        初始特征值写入规格 规格(
            幂等主键, 原始类型, I64值, std::move(VecI64值), std::move(VecU64值));
        return 规格.完整()
            ? std::optional<初始特征值写入规格>{std::move(规格)}
            : std::nullopt;
    }

    std::optional<特征批次初始项规格> 形成特征批次初始项规格(
        std::uint32_t 顺序号,
