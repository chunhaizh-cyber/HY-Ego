// 文件规则：特征体系数据操作层独占执行器和原始材料参与者，公开面只返回值式业务材料。
module;

#include "../核心/结构事务接线.数据.h"
#include "../核心/主信息仓库.h"
#include "../核心/节点仓库.h"
#include "../核心/关系仓库.h"
#include "../核心/索引仓库.h"
#include "../核心/容错检查.h"
#include "特征值服务.h"

#include <algorithm>
#include <cstddef>
#include <cstdint>
#include <functional>
#include <iterator>
#include <memory>
#include <optional>
#include <utility>
#include <vector>

export module 海中鱼巣.领域.数据操作.特征体系;

import 海中鱼巣.核心.执行器.结构写入;
import 海中鱼巣.领域.参与者.特征值原始材料;

export namespace 海中鱼巣 {

enum class 特征体系业务状态 : std::uint8_t {
    已提交 = 1,
    幂等读回 = 2,
    入口拒绝 = 3,
    幂等冲突 = 4,
    许可拒绝 = 5,
    版本漂移 = 6,
    内部不一致 = 7
};

enum class 特征体系读取状态 : std::uint8_t {
    已找到 = 1,
    未找到 = 2,
    入口拒绝 = 3,
    许可拒绝 = 4,
    版本漂移 = 5,
    类型不匹配 = 6,
    内部不一致 = 7
};

struct 特征关系证据 {
    关系句柄 关系;
    关系类型 类型 = 关系类型::普通父子;
    节点句柄 源节点;
    节点句柄 目标节点;
    std::int64_t 顺序号 = 0;

    bool 完整() const noexcept {
        return 句柄有效(关系) && 句柄有效(源节点) && 句柄有效(目标节点);
    }
};

struct 特征节点身份 {
    特征体系读取状态 状态 = 特征体系读取状态::入口拒绝;
    节点句柄 节点;
    节点类型 类型 = 节点类型::未分类;
    主信息句柄 主信息;

    bool 当前可读() const noexcept {
        return 状态 == 特征体系读取状态::已找到
            && 句柄有效(节点) && 句柄有效(主信息);
    }
};

struct 特征定义值式材料 {
    特征体系读取状态 状态 = 特征体系读取状态::入口拒绝;
    std::uint64_t 幂等主键 = 0;
    节点句柄 特征定义;
    主信息句柄 主信息;

    bool 完整() const noexcept {
        return 状态 == 特征体系读取状态::已找到 && 幂等主键 != 0
            && 句柄有效(特征定义) && 句柄有效(主信息);
    }
};

struct 特征槽位值式材料 {
    特征体系读取状态 状态 = 特征体系读取状态::入口拒绝;
    std::uint64_t 幂等主键 = 0;
    节点句柄 宿主;
    节点句柄 特征定义;
    节点句柄 实例槽位;
    主信息句柄 主信息;
    特征关系证据 宿主关系;
    特征关系证据 模板关系;

    bool 完整() const noexcept {
        return 状态 == 特征体系读取状态::已找到 && 幂等主键 != 0
            && 句柄有效(宿主) && 句柄有效(特征定义)
            && 句柄有效(实例槽位) && 句柄有效(主信息)
            && 宿主关系.完整() && 模板关系.完整();
    }
};

struct 特征原始值式材料 {
    特征体系读取状态 状态 = 特征体系读取状态::入口拒绝;
    std::uint64_t 幂等主键 = 0;
    节点句柄 实例槽位;
    节点句柄 特征值节点;
    主信息句柄 主信息;
    特征关系证据 当前值关系;
    特征值原始类型 原始类型 = 特征值原始类型::未建立;
    std::uint64_t 原始值版本 = 0;
    std::optional<std::int64_t> I64值;
    std::vector<std::int64_t> VecI64值;
    std::vector<std::uint64_t> VecU64值;

    bool 完整() const noexcept {
        if (状态 != 特征体系读取状态::已找到 || 幂等主键 == 0
            || !句柄有效(实例槽位) || !句柄有效(特征值节点)
            || !句柄有效(主信息) || !当前值关系.完整() || 原始值版本 == 0) {
            return false;
        }
        switch (原始类型) {
        case 特征值原始类型::I64:
            return I64值.has_value() && VecI64值.empty() && VecU64值.empty();
        case 特征值原始类型::VecI64:
            return !I64值.has_value() && !VecI64值.empty() && VecU64值.empty();
        case 特征值原始类型::VecU64:
            return !I64值.has_value() && VecI64值.empty() && !VecU64值.empty();
        default:
            return false;
        }
    }
};

struct 宿主特征状态值式材料 {
    特征体系读取状态 状态 = 特征体系读取状态::入口拒绝;
    节点句柄 宿主;
    节点句柄 特征定义;
    特征槽位值式材料 槽位;
    特征原始值式材料 当前值;

    bool 有槽位() const noexcept {
        return 槽位.完整();
    }

    bool 有当前值() const noexcept {
        return 状态 == 特征体系读取状态::已找到
            && 槽位.完整() && 当前值.完整();
    }
};

struct 二次特征值式材料 {
    特征体系读取状态 状态 = 特征体系读取状态::入口拒绝;
    std::uint64_t 幂等主键 = 0;
    节点句柄 二次特征;
    主信息句柄 主信息;
    std::vector<节点句柄> 有序组成项组;
    std::vector<特征关系证据> 组成关系组;

    bool 完整() const noexcept {
        if (状态 != 特征体系读取状态::已找到 || 幂等主键 == 0
            || !句柄有效(二次特征) || !句柄有效(主信息)
            || 有序组成项组.empty() || 有序组成项组.size() != 组成关系组.size()) {
            return false;
        }
        for (std::size_t 索引 = 0; 索引 < 组成关系组.size(); ++索引) {
            if (!句柄有效(有序组成项组[索引]) || !组成关系组[索引].完整()
                || 组成关系组[索引].顺序号 != static_cast<std::int64_t>(索引)
                || 组成关系组[索引].目标节点 != 有序组成项组[索引]) return false;
        }
        return true;
    }
};

struct 特征体系业务结果 {
    特征体系业务状态 状态 = 特征体系业务状态::入口拒绝;
    特征定义值式材料 定义;
    特征槽位值式材料 槽位;
    特征原始值式材料 当前值;
    二次特征值式材料 二次特征;

    bool 成功() const noexcept {
        return 状态 == 特征体系业务状态::已提交
            || 状态 == 特征体系业务状态::幂等读回;
    }

    bool 改变了结构() const noexcept {
        return 状态 == 特征体系业务状态::已提交;
    }
};

class 特征槽位写入规格 final {
public:
    特征槽位写入规格() = delete;

    std::uint64_t 读取幂等主键() const noexcept { return 幂等主键_; }
    节点句柄 读取宿主() const noexcept { return 宿主_; }
    节点句柄 读取特征定义() const noexcept { return 特征定义_; }

    bool 完整() const noexcept {
        return 幂等主键_ != 0 && 句柄有效(宿主_) && 句柄有效(特征定义_)
            && 宿主_ != 特征定义_;
    }

private:
    friend class 特征体系数据操作;

    特征槽位写入规格(std::uint64_t 幂等主键, 节点句柄 宿主, 节点句柄 特征定义)
        : 幂等主键_(幂等主键), 宿主_(宿主), 特征定义_(特征定义) {}

    std::uint64_t 幂等主键_ = 0;
    节点句柄 宿主_;
    节点句柄 特征定义_;
};

class 初始特征值写入规格 final {
public:
    初始特征值写入规格() = delete;

    std::uint64_t 读取幂等主键() const noexcept { return 幂等主键_; }
    特征值原始类型 读取原始类型() const noexcept { return 原始类型_; }
    const std::optional<std::int64_t>& 读取I64值() const noexcept { return I64值_; }
    const std::vector<std::int64_t>& 读取VecI64值() const noexcept { return VecI64值_; }
    const std::vector<std::uint64_t>& 读取VecU64值() const noexcept { return VecU64值_; }

    bool 完整() const noexcept {
        if (幂等主键_ == 0) return false;
        switch (原始类型_) {
        case 特征值原始类型::I64:
            return I64值_.has_value() && VecI64值_.empty() && VecU64值_.empty();
        case 特征值原始类型::VecI64:
            return !I64值_.has_value() && !VecI64值_.empty()
                && VecI64值_.size() <= 特征值服务::最大序列元素数量 && VecU64值_.empty();
        case 特征值原始类型::VecU64:
            return !I64值_.has_value() && VecI64值_.empty() && !VecU64值_.empty()
                && VecU64值_.size() <= 特征值服务::最大序列元素数量;
        default:
            return false;
        }
    }

private:
    friend class 特征体系数据操作;

    初始特征值写入规格(
        std::uint64_t 幂等主键,
        特征值原始类型 原始类型,
        std::optional<std::int64_t> I64值,
        std::vector<std::int64_t> VecI64值,
        std::vector<std::uint64_t> VecU64值)
        : 幂等主键_(幂等主键), 原始类型_(原始类型), I64值_(I64值),
          VecI64值_(std::move(VecI64值)), VecU64值_(std::move(VecU64值)) {}

    std::uint64_t 幂等主键_ = 0;
    特征值原始类型 原始类型_ = 特征值原始类型::未建立;
    std::optional<std::int64_t> I64值_;
    std::vector<std::int64_t> VecI64值_;
    std::vector<std::uint64_t> VecU64值_;
};

enum class 特征批次项种类 : std::uint8_t {
    初始 = 1,
    当前值换代 = 2
};

struct 特征批次来源版本 {
    节点句柄 来源;
    std::uint64_t 版本 = 0;

    bool 完整() const noexcept {
        return 句柄有效(来源) && 版本 != 0;
    }
};

class 特征批次初始项规格 final {
public:
    特征批次初始项规格() = delete;

    std::uint32_t 读取顺序号() const noexcept { return 顺序号_; }
    const 特征槽位写入规格& 读取槽位规格() const noexcept { return 槽位规格_; }
    const 初始特征值写入规格& 读取值规格() const noexcept { return 值规格_; }
    const 特征批次来源版本& 读取来源版本() const noexcept { return 来源版本_; }

    bool 完整() const noexcept {
        return 槽位规格_.完整() && 值规格_.完整() && 来源版本_.完整()
            && 槽位规格_.读取幂等主键() != 值规格_.读取幂等主键();
    }

private:
    friend class 特征体系数据操作;

    特征批次初始项规格(
        std::uint32_t 顺序号,
        特征槽位写入规格 槽位规格,
        初始特征值写入规格 值规格,
        特征批次来源版本 来源版本)
        : 顺序号_(顺序号), 槽位规格_(std::move(槽位规格)),
          值规格_(std::move(值规格)), 来源版本_(来源版本) {}

    std::uint32_t 顺序号_ = 0;
    特征槽位写入规格 槽位规格_;
    初始特征值写入规格 值规格_;
    特征批次来源版本 来源版本_;
};

class 特征批次换代项规格 final {
public:
    特征批次换代项规格() = delete;

    std::uint32_t 读取顺序号() const noexcept { return 顺序号_; }
    节点句柄 读取实例槽位() const noexcept { return 实例槽位_; }
    const 特征关系证据& 读取预期当前关系() const noexcept { return 预期当前关系_; }
    节点句柄 读取预期当前值() const noexcept { return 预期当前值_; }
    std::uint64_t 读取预期原始值版本() const noexcept { return 预期原始值版本_; }
    const 初始特征值写入规格& 读取新值规格() const noexcept { return 新值规格_; }
    const 特征批次来源版本& 读取来源版本() const noexcept { return 来源版本_; }

    bool 完整() const noexcept {
        return 句柄有效(实例槽位_) && 预期当前关系_.完整()
            && 预期当前关系_.类型 == 关系类型::归属
            && 预期当前关系_.源节点 == 实例槽位_
            && 预期当前关系_.目标节点 == 预期当前值_
            && 句柄有效(预期当前值_) && 预期原始值版本_ != 0
            && 新值规格_.完整() && 来源版本_.完整();
    }

private:
    friend class 特征体系数据操作;

    特征批次换代项规格(
        std::uint32_t 顺序号,
        节点句柄 实例槽位,
        特征关系证据 预期当前关系,
        节点句柄 预期当前值,
        std::uint64_t 预期原始值版本,
        初始特征值写入规格 新值规格,
        特征批次来源版本 来源版本)
        : 顺序号_(顺序号), 实例槽位_(实例槽位),
          预期当前关系_(std::move(预期当前关系)), 预期当前值_(预期当前值),
          预期原始值版本_(预期原始值版本), 新值规格_(std::move(新值规格)),
          来源版本_(来源版本) {}

    std::uint32_t 顺序号_ = 0;
    节点句柄 实例槽位_;
    特征关系证据 预期当前关系_;
    节点句柄 预期当前值_;
    std::uint64_t 预期原始值版本_ = 0;
    初始特征值写入规格 新值规格_;
    特征批次来源版本 来源版本_;
};

class 特征批次变更规格 final {
public:
    特征批次变更规格() = delete;

    std::uint64_t 读取批次幂等身份() const noexcept { return 批次幂等身份_; }
    std::uint64_t 读取规则版本() const noexcept { return 规则版本_; }
    std::uint64_t 读取完整载荷摘要() const noexcept { return 完整载荷摘要_; }
    节点句柄 读取候选宿主() const noexcept { return 候选宿主_; }
    const std::vector<特征批次初始项规格>& 读取初始项组() const noexcept { return 初始项组_; }
    const std::vector<特征批次换代项规格>& 读取换代项组() const noexcept { return 换代项组_; }
    std::size_t 读取项目数量() const noexcept { return 初始项组_.size() + 换代项组_.size(); }

    bool 完整() const noexcept {
        return 批次幂等身份_ != 0 && 规则版本_ != 0 && 完整载荷摘要_ != 0
            && 句柄有效(候选宿主_) && 读取项目数量() != 0;
    }

private:
    friend class 特征体系数据操作;

    特征批次变更规格(
        std::uint64_t 批次幂等身份,
        std::uint64_t 规则版本,
        std::uint64_t 完整载荷摘要,
        节点句柄 候选宿主,
        std::vector<特征批次初始项规格> 初始项组,
        std::vector<特征批次换代项规格> 换代项组)
        : 批次幂等身份_(批次幂等身份), 规则版本_(规则版本),
          完整载荷摘要_(完整载荷摘要), 候选宿主_(候选宿主),
          初始项组_(std::move(初始项组)), 换代项组_(std::move(换代项组)) {}

    std::uint64_t 批次幂等身份_ = 0;
    std::uint64_t 规则版本_ = 0;
    std::uint64_t 完整载荷摘要_ = 0;
    节点句柄 候选宿主_;
    std::vector<特征批次初始项规格> 初始项组_;
    std::vector<特征批次换代项规格> 换代项组_;
};

struct 特征批次项结果 {
    特征批次项种类 种类 = 特征批次项种类::初始;
    std::uint32_t 顺序号 = 0;
    特征槽位值式材料 槽位;
    特征原始值式材料 当前值;

    bool 完整() const noexcept { return 槽位.完整() && 当前值.完整(); }
};

struct 特征批次结果 {
    特征体系业务状态 状态 = 特征体系业务状态::入口拒绝;
    std::uint64_t 批次幂等身份 = 0;
    std::uint64_t 规则版本 = 0;
    std::uint64_t 完整载荷摘要 = 0;
    节点句柄 候选宿主;
    std::vector<特征批次项结果> 有序项目组;

    bool 成功() const noexcept {
        return 状态 == 特征体系业务状态::已提交
            || 状态 == 特征体系业务状态::幂等读回;
    }

    bool 完整() const noexcept {
        if (!成功() || 批次幂等身份 == 0 || 规则版本 == 0
            || 完整载荷摘要 == 0 || !句柄有效(候选宿主) || 有序项目组.empty()) return false;
        for (std::size_t 索引 = 0; 索引 < 有序项目组.size(); ++索引) {
            if (!有序项目组[索引].完整()
                || 有序项目组[索引].顺序号 != static_cast<std::uint32_t>(索引)
                || 有序项目组[索引].槽位.宿主 != 候选宿主) return false;
        }
        return true;
    }
};

class 特征体系数据操作;

class 特征批次结构参与包 final {
public:
    特征批次结构参与包() = delete;
    特征批次结构参与包(const 特征批次结构参与包&) = delete;
    特征批次结构参与包& operator=(const 特征批次结构参与包&) = delete;
    特征批次结构参与包(特征批次结构参与包&&) noexcept = default;
    特征批次结构参与包& operator=(特征批次结构参与包&&) noexcept = default;
    ~特征批次结构参与包() = default;

    bool 完整() const noexcept {
        return 所有者_ != nullptr && 规格_.完整() && static_cast<bool>(参与者_);
    }

private:
    friend class 特征体系数据操作;

    特征批次结构参与包(
        const 特征体系数据操作* 所有者,
        特征值服务& 特征值,
        特征批次变更规格 规格)
        : 所有者_(所有者), 规格_(std::move(规格)),
          参与者_(std::make_unique<特征值原始材料事务参与者>(特征值)) {}

    bool 加入结构写入会话(结构写入会话& 会话);
    特征值原始材料事务参与者& 读取内部参与者() { return *参与者_; }
    const 特征批次结果& 读取候选结果() const noexcept { return 候选结果_; }
#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
    void 经过候选写点() {
        ++已经过候选写点数量_;
        if (候选写入故障序号_ != 0 && 已经过候选写点数量_ == 候选写入故障序号_) throw 0;
    }
#endif

    const 特征体系数据操作* 所有者_ = nullptr;
    特征批次变更规格 规格_;
    std::unique_ptr<特征值原始材料事务参与者> 参与者_;
    std::vector<特征槽位值式材料> 换代写前槽位组_;
    特征批次结果 候选结果_;
#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
    std::size_t 候选写入故障序号_ = 0;
    std::size_t 已经过候选写点数量_ = 0;
#endif
};

class 特征体系数据操作 final {
public:
    特征体系数据操作(
        结构事务接线 接线,
        主信息仓库& 主信息,
        节点仓库& 节点,
        关系仓库& 关系,
        索引仓库& 索引,
        特征值服务& 特征值,
        std::uint64_t 关系仓库编号)
        : 接线_(std::move(接线)), 主信息_(主信息), 节点_(节点), 关系_(关系),
          索引_(索引), 特征值_(特征值), 关系仓库编号_(关系仓库编号),
          执行器_(接线_, &主信息_, &节点_, &关系_, &索引_), 侧表访问器_(特征值_) {}

    bool 有效() const noexcept {
        return 接线_.已接域() && 关系仓库编号_ != 0 && 执行器_.有效();
    }

    std::optional<特征槽位写入规格> 形成特征槽位写入规格(
        std::uint64_t 幂等主键,
        节点句柄 宿主,
        节点句柄 特征定义) const {
        特征槽位写入规格 规格(幂等主键, 宿主, 特征定义);
        return 规格.完整()
            ? std::optional<特征槽位写入规格>{std::move(规格)}
            : std::nullopt;
    }

    std::optional<初始特征值写入规格> 形成初始特征值写入规格(
        std::uint64_t 幂等主键,
        特征值原始类型 原始类型,
        std::optional<std::int64_t> I64值,
        std::vector<std::int64_t> VecI64值,
        std::vector<std::uint64_t> VecU64值) const {
        初始特征值写入规格 规格(
            幂等主键, 原始类型, I64值, std::move(VecI64值), std::move(VecU64值));
        return 规格.完整()
            ? std::optional<初始特征值写入规格>{std::move(规格)}
            : std::nullopt;
    }

    std::optional<特征批次初始项规格> 形成特征批次初始项规格(
        std::uint32_t 顺序号,
        const 特征槽位写入规格& 槽位规格,
        const 初始特征值写入规格& 值规格,
        特征批次来源版本 来源版本) const {
        特征批次初始项规格 规格(顺序号, 槽位规格, 值规格, 来源版本);
        return 规格.完整()
            ? std::optional<特征批次初始项规格>{std::move(规格)}
            : std::nullopt;
    }

    std::optional<特征批次换代项规格> 形成特征批次换代项规格(
        std::uint32_t 顺序号,
        节点句柄 实例槽位,
        特征关系证据 预期当前关系,
        节点句柄 预期当前值,
        std::uint64_t 预期原始值版本,
        const 初始特征值写入规格& 新值规格,
        特征批次来源版本 来源版本) const {
        特征批次换代项规格 规格(
            顺序号, 实例槽位, std::move(预期当前关系), 预期当前值,
            预期原始值版本, 新值规格, 来源版本);
        return 规格.完整()
            ? std::optional<特征批次换代项规格>{std::move(规格)}
            : std::nullopt;
    }

    std::optional<特征批次变更规格> 形成特征批次变更规格(
        std::uint64_t 批次幂等身份,
        std::uint64_t 规则版本,
        std::uint64_t 完整载荷摘要,
        节点句柄 候选宿主,
        std::vector<特征批次初始项规格> 初始项组,
        std::vector<特征批次换代项规格> 换代项组) const {
        特征批次变更规格 规格(
            批次幂等身份, 规则版本, 完整载荷摘要, 候选宿主,
            std::move(初始项组), std::move(换代项组));
        return 批次规格逐项完整(规格)
            ? std::optional<特征批次变更规格>{std::move(规格)}
            : std::nullopt;
    }

    特征批次结果 读取特征批次结果(const 特征批次变更规格& 规格) const {
        特征批次结果 输出;
        if (!有效() || !批次规格逐项完整(规格)) return 输出;
        输出.批次幂等身份 = 规格.读取批次幂等身份();
        输出.规则版本 = 规格.读取规则版本();
        输出.完整载荷摘要 = 规格.读取完整载荷摘要();
        输出.候选宿主 = 规格.读取候选宿主();
        输出.有序项目组.resize(规格.读取项目数量());
        for (const auto& 项 : 规格.读取初始项组()) {
            auto& 项结果 = 输出.有序项目组[项.读取顺序号()];
            项结果.种类 = 特征批次项种类::初始;
            项结果.顺序号 = 项.读取顺序号();
            项结果.槽位 = 读取宿主定义槽位(
                规格.读取候选宿主(), 项.读取槽位规格().读取特征定义());
            if (!匹配槽位(项结果.槽位, 项.读取槽位规格())) return {};
            项结果.当前值 = 读取批次已发布值(
                项结果.槽位, 项.读取值规格().读取幂等主键());
            if (!匹配原始值(项结果.当前值, 项.读取值规格(), 1)
                || !批次元数据匹配(
                    项结果.当前值, 规格, 特征批次项种类::初始,
                    项.读取顺序号(), 项.读取来源版本())) return {};
        }
        for (const auto& 项 : 规格.读取换代项组()) {
            auto& 项结果 = 输出.有序项目组[项.读取顺序号()];
            项结果.种类 = 特征批次项种类::当前值换代;
            项结果.顺序号 = 项.读取顺序号();
            项结果.槽位 = 读取实例特征槽位(项.读取实例槽位());
            if (!项结果.槽位.完整() || 项结果.槽位.宿主 != 规格.读取候选宿主()) return {};
            项结果.当前值 = 读取批次已发布值(
                项结果.槽位, 项.读取新值规格().读取幂等主键());
            if (!匹配原始值(
                    项结果.当前值, 项.读取新值规格(), 1)
                || !批次元数据匹配(
                    项结果.当前值, 规格, 特征批次项种类::当前值换代,
                    项.读取顺序号(), 项.读取来源版本(), &项)) return {};
        }
        输出.状态 = 特征体系业务状态::幂等读回;
        return 输出.完整() ? 输出 : 特征批次结果{};
    }

    特征批次结果 提交特征批次(const 特征批次变更规格& 规格) const {
        const auto 预检 = 预检特征批次(规格);
        if (预检 == 特征批次预检状态::已发布同义) return 读取特征批次结果(规格);
        if (预检 != 特征批次预检状态::可写) return 形成批次失败结果(规格, 预检);
        auto 参与包 = 形成特征批次结构参与包(规格);
        if (!参与包.has_value()) return 形成批次失败结果(规格, 特征批次预检状态::内部不一致);
        const auto 结构结果 = 执行器_.执行([&](结构写入会话& 会话) {
            if (!参与包->加入结构写入会话(会话)) return;
            (void)会话.请求提交();
        }, 参与包->读取内部参与者());
        auto 当前 = 读取特征批次结果(规格);
        if (当前.完整()) {
            当前.状态 = 结构结果.状态 == 结构写入状态::已提交
                ? 特征体系业务状态::已提交 : 特征体系业务状态::幂等读回;
            return 当前;
        }
        当前 = 形成批次失败结果(规格, 特征批次预检状态::内部不一致);
        当前.状态 = 映射结构失败(结构结果).状态;
        return 当前;
    }

#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
    std::size_t 读取特征批次候选写点数量(const 特征批次变更规格& 规格) const noexcept {
        std::size_t 数量 = 0;
        for (const auto& 项 : 规格.读取初始项组()) {
            数量 += 21;
            if (项.读取值规格().读取原始类型() == 特征值原始类型::I64) ++数量;
        }
        for (const auto& 项 : 规格.读取换代项组()) {
            数量 += 29;
            if (项.读取新值规格().读取原始类型() == 特征值原始类型::I64) ++数量;
        }
        return 数量;
    }

    结构写入结果 执行特征批次原子收口故障自检(
        const 特征批次变更规格& 规格,
        std::size_t 候选写入故障序号,
        const 结构写入故障自检配置& 配置,
        const std::function<void()>& 观察回调 = {}) const {
        if (预检特征批次(规格) != 特征批次预检状态::可写) {
            return {结构写入状态::入口拒绝, 0, 0, 0};
        }
        auto 参与包 = 形成特征批次结构参与包(规格);
        if (!参与包.has_value()) return {结构写入状态::内部不一致, 0, 0, 0};
        if (候选写入故障序号 > 读取特征批次候选写点数量(规格)) {
            return {结构写入状态::入口拒绝, 0, 0, 0};
        }
        参与包->候选写入故障序号_ = 候选写入故障序号;
        const auto 写入回调 = [&](结构写入会话& 会话) {
            if (!参与包->加入结构写入会话(会话)) return;
            (void)会话.请求提交();
        };
        if (候选写入故障序号 != 0) {
            return 执行器_.执行(写入回调, 参与包->读取内部参与者());
        }
        return 执行器_.执行原子收口故障自检(
            写入回调,
            参与包->读取内部参与者(),
            配置,
            观察回调);
    }
#endif

    特征节点身份 读取节点身份(节点句柄 目标) const {
        if (!有效() || !句柄有效(目标)) return {};
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) return {特征体系读取状态::许可拒绝};
        return 读取节点身份_已许可(目标, 许可.读取令牌());
    }

    特征定义值式材料 读取特征定义(节点句柄 特征定义) const {
        if (!有效() || !句柄有效(特征定义)) return {};
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) return {特征体系读取状态::许可拒绝};
        return 读取特征定义_已许可(特征定义, std::nullopt, 许可.读取令牌());
    }

    特征定义值式材料 读取主键特征定义(std::uint64_t 主键) const {
        if (!有效() || 主键 == 0) return {};
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) return {特征体系读取状态::许可拒绝};
        const auto 目标 = 索引_.按主键查节点(主键, 许可.读取令牌());
        if (!目标.has_value()) return {特征体系读取状态::未找到};
        return 读取特征定义_已许可(*目标, 主键, 许可.读取令牌());
    }

    特征槽位值式材料 读取实例特征槽位(节点句柄 实例槽位) const {
        if (!有效() || !句柄有效(实例槽位)) return {};
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) return {特征体系读取状态::许可拒绝};
        return 读取实例槽位_已许可(实例槽位, std::nullopt, 许可.读取令牌());
    }

    特征槽位值式材料 读取主键实例特征槽位(std::uint64_t 主键) const {
        if (!有效() || 主键 == 0) return {};
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) return {特征体系读取状态::许可拒绝};
        const auto 目标 = 索引_.按主键查节点(主键, 许可.读取令牌());
        if (!目标.has_value()) return {特征体系读取状态::未找到};
        return 读取实例槽位_已许可(*目标, 主键, 许可.读取令牌());
    }

    特征槽位值式材料 读取宿主定义槽位(节点句柄 宿主, 节点句柄 特征定义) const {
        if (!有效() || !句柄有效(宿主) || !句柄有效(特征定义)) return {};
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) return {特征体系读取状态::许可拒绝};
        return 读取宿主定义槽位_已许可(宿主, 特征定义, 许可.读取令牌());
    }

    特征原始值式材料 读取实例槽位当前值(节点句柄 实例槽位) const {
        if (!有效() || !句柄有效(实例槽位)) return {};
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) return {特征体系读取状态::许可拒绝};
        const auto 槽位 = 读取实例槽位_已许可(实例槽位, std::nullopt, 许可.读取令牌());
        if (!槽位.完整()) return 从槽位失败形成值(槽位);
        return 读取当前值_已许可(槽位, 许可.读取令牌());
    }

    宿主特征状态值式材料 读取宿主特征状态(
        节点句柄 宿主,
        节点句柄 特征定义) const {
        宿主特征状态值式材料 输出;
        输出.宿主 = 宿主;
        输出.特征定义 = 特征定义;
        if (!有效() || !句柄有效(宿主) || !句柄有效(特征定义)) return 输出;
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) {
            输出.状态 = 特征体系读取状态::许可拒绝;
            return 输出;
        }
        输出.槽位 = 读取宿主定义槽位_已许可(宿主, 特征定义, 许可.读取令牌());
        if (输出.槽位.状态 == 特征体系读取状态::未找到) {
            输出.状态 = 特征体系读取状态::未找到;
            return 输出;
        }
        if (!输出.槽位.完整()) {
            输出.状态 = 输出.槽位.状态;
            return 输出;
        }
        输出.当前值 = 读取当前值_已许可(输出.槽位, 许可.读取令牌());
        输出.状态 = 输出.当前值.状态;
        return 输出;
    }

    二次特征值式材料 读取二次特征(节点句柄 二次特征) const {
        if (!有效() || !句柄有效(二次特征)) return {};
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) return {特征体系读取状态::许可拒绝};
        return 读取二次特征_已许可(二次特征, std::nullopt, 许可.读取令牌());
    }

    二次特征值式材料 读取主键二次特征(std::uint64_t 主键) const {
        if (!有效() || 主键 == 0) return {};
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) return {特征体系读取状态::许可拒绝};
        const auto 目标 = 索引_.按主键查节点(主键, 许可.读取令牌());
        if (!目标.has_value()) return {特征体系读取状态::未找到};
        return 读取二次特征_已许可(*目标, 主键, 许可.读取令牌());
    }

    特征体系业务结果 创建特征定义(std::uint64_t 主键) const {
        if (!有效() || 主键 == 0) return {};
        const auto 写前 = 读取主键特征定义(主键);
        if (写前.完整()) return 形成定义结果(特征体系业务状态::幂等读回, 写前);
        if (写前.状态 == 特征体系读取状态::类型不匹配
            || 写前.状态 == 特征体系读取状态::内部不一致) {
            return {写前.状态 == 特征体系读取状态::内部不一致
                ? 特征体系业务状态::内部不一致 : 特征体系业务状态::幂等冲突};
        }
        if (写前.状态 != 特征体系读取状态::未找到) return 从读取失败形成结果(写前.状态);

        const auto 结构结果 = 执行器_.执行([&](结构写入会话& 会话) {
            主信息句柄 新主信息;
            节点句柄 新定义;
            if (!写入带主键节点_会话(会话, 节点类型::特征, 主键, 新主信息, 新定义)) return;
            (void)会话.请求提交();
        });
        const auto 当前 = 读取主键特征定义(主键);
        if (当前.完整()) {
            return 形成定义结果(
                结构结果.状态 == 结构写入状态::已提交
                    ? 特征体系业务状态::已提交 : 特征体系业务状态::幂等读回,
                当前);
        }
        if (当前.状态 == 特征体系读取状态::类型不匹配) {
            return {特征体系业务状态::幂等冲突};
        }
        return 映射结构失败(结构结果);
    }

    特征体系业务结果 创建实例特征槽位(const 特征槽位写入规格& 规格) const {
        if (!有效() || !规格.完整()) return {};
        const auto 宿主身份 = 读取节点身份(规格.读取宿主());
        const auto 定义 = 读取特征定义(规格.读取特征定义());
        if (!宿主身份.当前可读() || !定义.完整()) {
            return 合并身份定义失败(宿主身份, 定义);
        }
        if (!允许特征宿主(宿主身份.类型)) return {};

        const auto 已有槽位 = 读取宿主定义槽位(规格.读取宿主(), 规格.读取特征定义());
        if (已有槽位.完整()) {
            return 已有槽位.幂等主键 == 规格.读取幂等主键()
                ? 形成槽位结果(特征体系业务状态::幂等读回, 已有槽位)
                : 特征体系业务结果{特征体系业务状态::幂等冲突};
        }
        if (已有槽位.状态 != 特征体系读取状态::未找到) {
            return 从读取失败形成结果(已有槽位.状态);
        }
        const auto 主键槽位 = 读取主键实例特征槽位(规格.读取幂等主键());
        if (主键槽位.完整()) {
            return 匹配槽位(主键槽位, 规格)
                ? 形成槽位结果(特征体系业务状态::幂等读回, 主键槽位)
                : 特征体系业务结果{特征体系业务状态::幂等冲突};
        }
        if (主键槽位.状态 != 特征体系读取状态::未找到) {
            return 主键槽位.状态 == 特征体系读取状态::类型不匹配
                ? 特征体系业务结果{特征体系业务状态::幂等冲突}
                : 从读取失败形成结果(主键槽位.状态);
        }

        bool 版本已经漂移 = false;
        const auto 结构结果 = 执行器_.执行([&](结构写入会话& 会话) {
            if (!验证宿主定义_会话(会话, 宿主身份, 定义)
                || 存在宿主定义槽位_会话(会话, 规格.读取宿主(), 规格.读取特征定义())) {
                版本已经漂移 = true;
                return;
            }
            特征槽位值式材料 新槽位;
            if (!写入槽位_会话(会话, 规格, 新槽位)) return;
            (void)会话.请求提交();
        });
        const auto 当前 = 读取主键实例特征槽位(规格.读取幂等主键());
        if (匹配槽位(当前, 规格)) {
            return 形成槽位结果(
                结构结果.状态 == 结构写入状态::已提交
                    ? 特征体系业务状态::已提交 : 特征体系业务状态::幂等读回,
                当前);
        }
        if (当前.状态 == 特征体系读取状态::已找到
            || 当前.状态 == 特征体系读取状态::类型不匹配) {
            return {特征体系业务状态::幂等冲突};
        }
        if (版本已经漂移) return {特征体系业务状态::版本漂移};
        return 映射结构失败(结构结果);
    }

    特征体系业务结果 发布初始特征状态(
        节点句柄 实例槽位,
        const 初始特征值写入规格& 规格) const {
        if (!有效() || !句柄有效(实例槽位) || !规格.完整()) return {};
        const auto 槽位 = 读取实例特征槽位(实例槽位);
        if (!槽位.完整()) return 从读取失败形成结果(槽位.状态);
        const auto 已有当前值 = 读取实例槽位当前值(实例槽位);
        if (已有当前值.完整()) {
            return 匹配原始值(已有当前值, 规格)
                ? 形成值结果(特征体系业务状态::幂等读回, 槽位, 已有当前值)
                : 特征体系业务结果{特征体系业务状态::幂等冲突};
        }
        if (已有当前值.状态 != 特征体系读取状态::未找到) {
            return 从读取失败形成结果(已有当前值.状态);
        }
        const auto 主键值 = 读取主键当前值候选(规格.读取幂等主键());
        if (主键值.状态 != 特征体系读取状态::未找到) {
            if (主键值.完整() && 匹配原始值(主键值, 规格)
                && 主键值.实例槽位 == 实例槽位) {
                return 形成值结果(特征体系业务状态::幂等读回, 槽位, 主键值);
            }
            if (主键值.状态 == 特征体系读取状态::许可拒绝
                || 主键值.状态 == 特征体系读取状态::版本漂移
                || 主键值.状态 == 特征体系读取状态::内部不一致) {
                return 从读取失败形成结果(主键值.状态);
            }
            return {特征体系业务状态::幂等冲突};
        }

        bool 版本已经漂移 = false;
        特征值原始材料事务参与者 参与者(特征值_);
        const auto 结构结果 = 执行器_.执行([&](结构写入会话& 会话) {
            if (!验证槽位_会话(会话, 槽位)
                || !会话.读取关系记录组(实例槽位, 关系类型::归属).empty()) {
                版本已经漂移 = true;
                return;
            }
            特征原始值式材料 新值;
            if (!写入初始值_会话(会话, 参与者, 实例槽位, 规格, 新值)) return;
            (void)会话.请求提交();
        }, 参与者);
        const auto 当前 = 读取实例槽位当前值(实例槽位);
        if (匹配原始值(当前, 规格)) {
            return 形成值结果(
                结构结果.状态 == 结构写入状态::已提交
                    ? 特征体系业务状态::已提交 : 特征体系业务状态::幂等读回,
                槽位, 当前);
        }
        if (当前.状态 == 特征体系读取状态::已找到) {
            return {特征体系业务状态::幂等冲突};
        }
        if (版本已经漂移) return {特征体系业务状态::版本漂移};
        return 映射结构失败(结构结果);
    }

    特征体系业务结果 创建槽位并发布初始状态(
        const 特征槽位写入规格& 槽位规格,
        const 初始特征值写入规格& 值规格) const {
        if (!有效() || !槽位规格.完整() || !值规格.完整()
            || 槽位规格.读取幂等主键() == 值规格.读取幂等主键()) return {};
        const auto 宿主身份 = 读取节点身份(槽位规格.读取宿主());
        const auto 定义 = 读取特征定义(槽位规格.读取特征定义());
        if (!宿主身份.当前可读() || !定义.完整()) {
            return 合并身份定义失败(宿主身份, 定义);
        }
        if (!允许特征宿主(宿主身份.类型)) return {};

        const auto 已有槽位 = 读取宿主定义槽位(
            槽位规格.读取宿主(), 槽位规格.读取特征定义());
        if (已有槽位.完整()) {
            const auto 当前值 = 读取实例槽位当前值(已有槽位.实例槽位);
            if (匹配槽位(已有槽位, 槽位规格) && 匹配原始值(当前值, 值规格)) {
                return 形成值结果(特征体系业务状态::幂等读回, 已有槽位, 当前值);
            }
            return {特征体系业务状态::幂等冲突};
        }
        if (已有槽位.状态 != 特征体系读取状态::未找到) {
            return 从读取失败形成结果(已有槽位.状态);
        }
        const auto 主键槽位 = 读取主键实例特征槽位(槽位规格.读取幂等主键());
        const auto 主键值 = 读取主键当前值候选(值规格.读取幂等主键());
        if (主键槽位.状态 != 特征体系读取状态::未找到
            || 主键值.状态 != 特征体系读取状态::未找到) {
            const auto 并发槽位 = 读取宿主定义槽位(
                槽位规格.读取宿主(), 槽位规格.读取特征定义());
            const auto 并发值 = 并发槽位.完整()
                ? 读取实例槽位当前值(并发槽位.实例槽位)
                : 特征原始值式材料{};
            if (匹配槽位(并发槽位, 槽位规格) && 匹配原始值(并发值, 值规格)) {
                return 形成值结果(特征体系业务状态::幂等读回, 并发槽位, 并发值);
            }
            if (主键槽位.状态 == 特征体系读取状态::许可拒绝
                || 主键值.状态 == 特征体系读取状态::许可拒绝) {
                return {特征体系业务状态::许可拒绝};
            }
            if (主键槽位.状态 == 特征体系读取状态::版本漂移
                || 主键值.状态 == 特征体系读取状态::版本漂移) {
                return {特征体系业务状态::版本漂移};
            }
            if (主键槽位.状态 == 特征体系读取状态::内部不一致
                || 主键值.状态 == 特征体系读取状态::内部不一致) {
                return {特征体系业务状态::内部不一致};
            }
            return {特征体系业务状态::幂等冲突};
        }

        bool 版本已经漂移 = false;
        特征值原始材料事务参与者 参与者(特征值_);
        const auto 结构结果 = 执行器_.执行([&](结构写入会话& 会话) {
            if (!验证宿主定义_会话(会话, 宿主身份, 定义)
                || 存在宿主定义槽位_会话(
                    会话, 槽位规格.读取宿主(), 槽位规格.读取特征定义())) {
                版本已经漂移 = true;
                return;
            }
            特征槽位值式材料 新槽位;
            if (!写入槽位_会话(会话, 槽位规格, 新槽位)) return;
            特征原始值式材料 新值;
            if (!写入初始值_会话(
                    会话, 参与者, 新槽位.实例槽位, 值规格, 新值)) return;
            (void)会话.请求提交();
        }, 参与者);

        const auto 当前槽位 = 读取宿主定义槽位(
            槽位规格.读取宿主(), 槽位规格.读取特征定义());
        const auto 当前值 = 当前槽位.完整()
            ? 读取实例槽位当前值(当前槽位.实例槽位)
            : 特征原始值式材料{};
        if (匹配槽位(当前槽位, 槽位规格) && 匹配原始值(当前值, 值规格)) {
            return 形成值结果(
                结构结果.状态 == 结构写入状态::已提交
                    ? 特征体系业务状态::已提交 : 特征体系业务状态::幂等读回,
                当前槽位, 当前值);
        }
        if (当前槽位.状态 == 特征体系读取状态::已找到) {
            return {特征体系业务状态::幂等冲突};
        }
        if (版本已经漂移) return {特征体系业务状态::版本漂移};
        return 映射结构失败(结构结果);
    }

    特征体系业务结果 创建组合二次特征(
        std::uint64_t 主键,
        const std::vector<节点句柄>& 有序组成项组) const {
        if (!有效() || 主键 == 0 || !组成项请求可用(有序组成项组)) return {};
        for (const auto 组成项 : 有序组成项组) {
            const auto 身份 = 读取节点身份(组成项);
            if (!身份.当前可读()) return 从读取失败形成结果(身份.状态);
            if (!允许二次特征组成项(身份.类型)) return {};
        }

        const auto 写前 = 读取主键二次特征(主键);
        if (写前.完整()) {
            return 写前.有序组成项组 == 有序组成项组
                ? 形成二次特征结果(特征体系业务状态::幂等读回, 写前)
                : 特征体系业务结果{特征体系业务状态::幂等冲突};
        }
        if (写前.状态 != 特征体系读取状态::未找到) {
            return 写前.状态 == 特征体系读取状态::类型不匹配
                ? 特征体系业务结果{特征体系业务状态::幂等冲突}
                : 从读取失败形成结果(写前.状态);
        }

        bool 版本已经漂移 = false;
        const auto 结构结果 = 执行器_.执行([&](结构写入会话& 会话) {
            for (const auto 组成项 : 有序组成项组) {
                const auto 类型 = 会话.读取节点类型(组成项);
                if (!类型.has_value() || !允许二次特征组成项(*类型)) {
                    版本已经漂移 = true;
                    return;
                }
            }
            主信息句柄 新主信息;
            节点句柄 新二次特征;
            if (!写入带主键节点_会话(
                    会话, 节点类型::二次特征, 主键, 新主信息, 新二次特征)) return;
            for (std::size_t 索引 = 0; 索引 < 有序组成项组.size(); ++索引) {
                const auto 关系结果 = 会话.创建关系(
                    关系类型::引用, 新二次特征, 有序组成项组[索引],
                    static_cast<std::int64_t>(索引));
                if (!关系结果.成功() || !会话.关系可读(*关系结果.值)) return;
            }
            (void)会话.请求提交();
        });
        const auto 当前 = 读取主键二次特征(主键);
        if (当前.完整() && 当前.有序组成项组 == 有序组成项组) {
            return 形成二次特征结果(
                结构结果.状态 == 结构写入状态::已提交
                    ? 特征体系业务状态::已提交 : 特征体系业务状态::幂等读回,
                当前);
        }
        if (当前.状态 == 特征体系读取状态::已找到
            || 当前.状态 == 特征体系读取状态::类型不匹配) {
            return {特征体系业务状态::幂等冲突};
        }
        if (版本已经漂移) return {特征体系业务状态::版本漂移};
        return 映射结构失败(结构结果);
    }

private:
    friend class 特征批次结构参与包;

    enum class 特征批次预检状态 : std::uint8_t {
        可写 = 1,
        已发布同义 = 2,
        入口拒绝 = 3,
        幂等冲突 = 4,
        许可拒绝 = 5,
        版本漂移 = 6,
        内部不一致 = 7
    };

    static constexpr std::uint64_t 批次身份低位元数据槽 = 100;
    static constexpr std::uint64_t 批次身份高位元数据槽 = 101;
    static constexpr std::uint64_t 批次规则版本低位元数据槽 = 102;
    static constexpr std::uint64_t 批次规则版本高位元数据槽 = 103;
    static constexpr std::uint64_t 批次摘要低位元数据槽 = 104;
    static constexpr std::uint64_t 批次摘要高位元数据槽 = 105;
    static constexpr std::uint64_t 批次项种类元数据槽 = 106;
    static constexpr std::uint64_t 批次顺序元数据槽 = 107;
    static constexpr std::uint64_t 批次来源版本低位元数据槽 = 108;
    static constexpr std::uint64_t 批次来源版本高位元数据槽 = 109;
    static constexpr std::uint64_t 批次预期关系仓库低位元数据槽 = 110;
    static constexpr std::uint64_t 批次预期关系仓库高位元数据槽 = 111;
    static constexpr std::uint64_t 批次预期关系编号低位元数据槽 = 112;
    static constexpr std::uint64_t 批次预期关系编号高位元数据槽 = 113;
    static constexpr std::uint64_t 批次预期关系版本元数据槽 = 114;
    static constexpr std::uint64_t 批次预期值仓库低位元数据槽 = 115;
    static constexpr std::uint64_t 批次预期值仓库高位元数据槽 = 116;
    static constexpr std::uint64_t 批次预期值编号低位元数据槽 = 117;
    static constexpr std::uint64_t 批次预期值编号高位元数据槽 = 118;
    static constexpr std::uint64_t 批次预期值版本元数据槽 = 119;
    static constexpr std::uint64_t 批次预期原始版本低位元数据槽 = 120;
    static constexpr std::uint64_t 批次预期原始版本高位元数据槽 = 121;

    static std::int64_t U64低位(std::uint64_t 值) noexcept {
        return static_cast<std::int64_t>(值 & 0xFFFFFFFFULL);
    }

    static std::int64_t U64高位(std::uint64_t 值) noexcept {
        return static_cast<std::int64_t>((值 >> 32U) & 0xFFFFFFFFULL);
    }

    bool 批次元数据匹配(
        const 特征原始值式材料& 值,
        const 特征批次变更规格& 规格,
        特征批次项种类 种类,
        std::uint32_t 顺序号,
        const 特征批次来源版本& 来源,
        const 特征批次换代项规格* 换代项 = nullptr) const {
        if (!值.完整() || !来源.完整()) return false;
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) return false;
        const auto& 令牌 = 许可.读取令牌();
        const auto 等于I64元数据 = [&](std::uint64_t 槽位, std::int64_t 预期) {
            return 主信息_.读取I64值(值.主信息, 槽位, 令牌)
                == std::optional<std::int64_t>{预期};
        };
        const auto 等于U64元数据 = [&](std::uint64_t 低位槽, std::uint64_t 高位槽, std::uint64_t 预期) {
            return 等于I64元数据(低位槽, U64低位(预期))
                && 等于I64元数据(高位槽, U64高位(预期));
        };
        if (!等于U64元数据(批次身份低位元数据槽, 批次身份高位元数据槽, 规格.读取批次幂等身份())
            || !等于U64元数据(批次规则版本低位元数据槽, 批次规则版本高位元数据槽, 规格.读取规则版本())
            || !等于U64元数据(批次摘要低位元数据槽, 批次摘要高位元数据槽, 规格.读取完整载荷摘要())
            || !等于I64元数据(批次项种类元数据槽, static_cast<std::int64_t>(种类))
            || !等于I64元数据(批次顺序元数据槽, static_cast<std::int64_t>(顺序号))
            || !等于U64元数据(
                批次来源版本低位元数据槽, 批次来源版本高位元数据槽, 来源.版本)) return false;
        if (种类 == 特征批次项种类::当前值换代) {
            if (换代项 == nullptr
                || !等于U64元数据(
                    批次预期关系仓库低位元数据槽, 批次预期关系仓库高位元数据槽,
                    换代项->读取预期当前关系().关系.仓库编号)
                || !等于U64元数据(
                    批次预期关系编号低位元数据槽, 批次预期关系编号高位元数据槽,
                    换代项->读取预期当前关系().关系.关系编号)
                || !等于I64元数据(
                    批次预期关系版本元数据槽,
                    static_cast<std::int64_t>(换代项->读取预期当前关系().关系.版本号))
                || !等于U64元数据(
                    批次预期值仓库低位元数据槽, 批次预期值仓库高位元数据槽,
                    换代项->读取预期当前值().仓库编号)
                || !等于U64元数据(
                    批次预期值编号低位元数据槽, 批次预期值编号高位元数据槽,
                    换代项->读取预期当前值().节点编号)
                || !等于I64元数据(
                    批次预期值版本元数据槽,
                    static_cast<std::int64_t>(换代项->读取预期当前值().版本号))
                || !等于U64元数据(
                    批次预期原始版本低位元数据槽, 批次预期原始版本高位元数据槽,
                    换代项->读取预期原始值版本())) return false;
        }
        const auto 来源关系组 = 关系_.获取关系记录组(值.特征值节点, 关系类型::引用, 令牌);
        return std::count_if(来源关系组.begin(), 来源关系组.end(), [&](const auto& 关系) {
            return 关系.目标节点 == 来源.来源
                && 关系.顺序号 == 0
                && 关系.状态 == 记录状态::有效;
        }) == 1;
    }

    bool 存在历史批次身份(const 特征批次变更规格& 规格) const {
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) return true;
        const auto& 令牌 = 许可.读取令牌();
        const auto 值记录组 = 节点_.读取指定类型有效节点记录组(节点类型::特征值, 令牌);
        if (值记录组.状态 != 节点记录组读取状态::已形成) return true;
        for (const auto& 值记录 : 值记录组.记录组) {
            const auto 低位 = 主信息_.读取I64值(
                值记录.主信息, 批次身份低位元数据槽, 令牌);
            const auto 高位 = 主信息_.读取I64值(
                值记录.主信息, 批次身份高位元数据槽, 令牌);
            if (低位 == std::optional<std::int64_t>{U64低位(规格.读取批次幂等身份())}
                && 高位 == std::optional<std::int64_t>{U64高位(规格.读取批次幂等身份())}) return true;
        }
        return false;
    }

    static bool 写入批次元数据与来源_会话(
        结构写入会话& 会话,
        const 特征批次变更规格& 规格,
        特征批次项种类 种类,
        std::uint32_t 顺序号,
        const 特征批次来源版本& 来源,
        const 特征原始值式材料& 新值,
        const 特征批次换代项规格* 换代项 = nullptr,
        const std::function<void()>& 写点回调 = {}) {
        if (!来源.完整() || !新值.完整()) return false;
        const auto 写入I64元数据 = [&](std::uint64_t 槽位, std::int64_t 值) {
            if (!会话.写入候选I64值(新值.主信息, 槽位, 值).成功()
                || !会话.候选I64值匹配(新值.主信息, 槽位, 值)) return false;
            if (写点回调) 写点回调();
            return true;
        };
        const auto 写入U64元数据 = [&](std::uint64_t 低位槽, std::uint64_t 高位槽, std::uint64_t 值) {
            return 写入I64元数据(低位槽, U64低位(值))
                && 写入I64元数据(高位槽, U64高位(值));
        };
        if (!写入U64元数据(批次身份低位元数据槽, 批次身份高位元数据槽, 规格.读取批次幂等身份())
            || !写入U64元数据(批次规则版本低位元数据槽, 批次规则版本高位元数据槽, 规格.读取规则版本())
            || !写入U64元数据(批次摘要低位元数据槽, 批次摘要高位元数据槽, 规格.读取完整载荷摘要())
            || !写入I64元数据(批次项种类元数据槽, static_cast<std::int64_t>(种类))
            || !写入I64元数据(批次顺序元数据槽, static_cast<std::int64_t>(顺序号))
            || !写入U64元数据(
                批次来源版本低位元数据槽, 批次来源版本高位元数据槽, 来源.版本)) return false;
        if (种类 == 特征批次项种类::当前值换代) {
            if (换代项 == nullptr
                || !写入U64元数据(
                    批次预期关系仓库低位元数据槽, 批次预期关系仓库高位元数据槽,
                    换代项->读取预期当前关系().关系.仓库编号)
                || !写入U64元数据(
                    批次预期关系编号低位元数据槽, 批次预期关系编号高位元数据槽,
                    换代项->读取预期当前关系().关系.关系编号)
                || !写入I64元数据(
                    批次预期关系版本元数据槽,
                    static_cast<std::int64_t>(换代项->读取预期当前关系().关系.版本号))
                || !写入U64元数据(
                    批次预期值仓库低位元数据槽, 批次预期值仓库高位元数据槽,
                    换代项->读取预期当前值().仓库编号)
                || !写入U64元数据(
                    批次预期值编号低位元数据槽, 批次预期值编号高位元数据槽,
                    换代项->读取预期当前值().节点编号)
                || !写入I64元数据(
                    批次预期值版本元数据槽,
                    static_cast<std::int64_t>(换代项->读取预期当前值().版本号))
                || !写入U64元数据(
                    批次预期原始版本低位元数据槽, 批次预期原始版本高位元数据槽,
                    换代项->读取预期原始值版本())) return false;
        }
        const auto 来源关系 = 会话.创建关系(
            关系类型::引用, 新值.特征值节点, 来源.来源,
            0);
        if (!来源关系.成功() || !会话.关系可读(*来源关系.值)) return false;
        if (写点回调) 写点回调();
        return true;
    }

    std::optional<特征批次结构参与包> 形成特征批次结构参与包(
        const 特征批次变更规格& 规格) const {
        if (预检特征批次(规格) != 特征批次预检状态::可写) return std::nullopt;
        特征批次结构参与包 包(this, 特征值_, 规格);
        包.换代写前槽位组_.reserve(规格.读取换代项组().size());
        for (const auto& 项 : 规格.读取换代项组()) {
            auto 槽位 = 读取实例特征槽位(项.读取实例槽位());
            if (!槽位.完整()) return std::nullopt;
            包.换代写前槽位组_.push_back(std::move(槽位));
        }
        return 包.完整()
            ? std::optional<特征批次结构参与包>{std::move(包)}
            : std::nullopt;
    }

    static bool 批次规格逐项完整(const 特征批次变更规格& 规格) {
        if (!规格.完整()) return false;
        const auto 数量 = 规格.读取项目数量();
        std::vector<bool> 已有顺序(数量, false);
        std::vector<std::uint64_t> 幂等主键组;
        幂等主键组.reserve(数量 * 2);
        std::vector<节点句柄> 换代槽位组;
        for (const auto& 项 : 规格.读取初始项组()) {
            if (!项.完整() || 项.读取顺序号() >= 数量 || 已有顺序[项.读取顺序号()]
                || 项.读取槽位规格().读取宿主() != 规格.读取候选宿主()) return false;
            已有顺序[项.读取顺序号()] = true;
            幂等主键组.push_back(项.读取槽位规格().读取幂等主键());
            幂等主键组.push_back(项.读取值规格().读取幂等主键());
        }
        for (const auto& 项 : 规格.读取换代项组()) {
            if (!项.完整() || 项.读取顺序号() >= 数量 || 已有顺序[项.读取顺序号()]) return false;
            已有顺序[项.读取顺序号()] = true;
            幂等主键组.push_back(项.读取新值规格().读取幂等主键());
            if (std::find(换代槽位组.begin(), 换代槽位组.end(), 项.读取实例槽位())
                != 换代槽位组.end()) return false;
            换代槽位组.push_back(项.读取实例槽位());
        }
        if (std::find(已有顺序.begin(), 已有顺序.end(), false) != 已有顺序.end()) return false;
        std::sort(幂等主键组.begin(), 幂等主键组.end());
        return std::adjacent_find(幂等主键组.begin(), 幂等主键组.end()) == 幂等主键组.end();
    }

    static 特征批次预检状态 映射批次读取失败(特征体系读取状态 状态) noexcept {
        switch (状态) {
        case 特征体系读取状态::许可拒绝:
            return 特征批次预检状态::许可拒绝;
        case 特征体系读取状态::版本漂移:
            return 特征批次预检状态::版本漂移;
        case 特征体系读取状态::内部不一致:
            return 特征批次预检状态::内部不一致;
        default:
            return 特征批次预检状态::入口拒绝;
        }
    }

    bool 来源版本写前有效(
        const 特征批次来源版本& 来源,
        节点句柄 候选宿主) const {
        if (!来源.完整()) return false;
        const auto 身份 = 读取节点身份(来源.来源);
        if (身份.当前可读()) return true;
        return 来源.来源 == 候选宿主
            && 身份.状态 == 特征体系读取状态::未找到;
    }

    特征批次预检状态 预检特征批次(const 特征批次变更规格& 规格) const {
        if (!有效() || !批次规格逐项完整(规格)) return 特征批次预检状态::入口拒绝;
        const auto 已发布 = 读取特征批次结果(规格);
        if (已发布.完整()) return 特征批次预检状态::已发布同义;
        if (存在历史批次身份(规格)) return 特征批次预检状态::幂等冲突;
        const auto 宿主身份 = 读取节点身份(规格.读取候选宿主());
        const bool 宿主为同层候选 = 宿主身份.状态 == 特征体系读取状态::未找到;
        if (!宿主身份.当前可读() && !宿主为同层候选) {
            return 映射批次读取失败(宿主身份.状态);
        }
        if (宿主身份.当前可读() && !允许特征宿主(宿主身份.类型)) {
            return 特征批次预检状态::入口拒绝;
        }
        for (const auto& 项 : 规格.读取初始项组()) {
            const auto 定义 = 读取特征定义(项.读取槽位规格().读取特征定义());
            if (!定义.完整()) return 映射批次读取失败(定义.状态);
            if (!来源版本写前有效(项.读取来源版本(), 规格.读取候选宿主())) {
                return 特征批次预检状态::入口拒绝;
            }
            const auto 已有槽位 = 读取宿主定义槽位(
                规格.读取候选宿主(), 项.读取槽位规格().读取特征定义());
            if (已有槽位.状态 != 特征体系读取状态::未找到) {
                return 已有槽位.状态 == 特征体系读取状态::已找到
                    ? 特征批次预检状态::幂等冲突 : 映射批次读取失败(已有槽位.状态);
            }
            const auto 主键槽位 = 读取主键实例特征槽位(项.读取槽位规格().读取幂等主键());
            const auto 主键值 = 读取主键当前值候选(项.读取值规格().读取幂等主键());
            if (主键槽位.状态 != 特征体系读取状态::未找到
                || 主键值.状态 != 特征体系读取状态::未找到) {
                if (主键槽位.状态 == 特征体系读取状态::许可拒绝
                    || 主键值.状态 == 特征体系读取状态::许可拒绝) return 特征批次预检状态::许可拒绝;
                if (主键槽位.状态 == 特征体系读取状态::版本漂移
                    || 主键值.状态 == 特征体系读取状态::版本漂移) return 特征批次预检状态::版本漂移;
                if (主键槽位.状态 == 特征体系读取状态::内部不一致
                    || 主键值.状态 == 特征体系读取状态::内部不一致) return 特征批次预检状态::内部不一致;
                return 特征批次预检状态::幂等冲突;
            }
        }
        for (const auto& 项 : 规格.读取换代项组()) {
            if (!来源版本写前有效(项.读取来源版本(), 规格.读取候选宿主())) {
                return 特征批次预检状态::入口拒绝;
            }
            const auto 槽位 = 读取实例特征槽位(项.读取实例槽位());
            if (!槽位.完整()) return 映射批次读取失败(槽位.状态);
            if (槽位.宿主 != 规格.读取候选宿主()) return 特征批次预检状态::入口拒绝;
            const auto 当前 = 读取实例槽位当前值(项.读取实例槽位());
            if (!当前.完整()) return 映射批次读取失败(当前.状态);
            if (当前.当前值关系.关系 != 项.读取预期当前关系().关系
                || 当前.当前值关系.源节点 != 项.读取预期当前关系().源节点
                || 当前.当前值关系.目标节点 != 项.读取预期当前关系().目标节点
                || 当前.特征值节点 != 项.读取预期当前值()
                || 当前.原始值版本 != 项.读取预期原始值版本()) {
                return 特征批次预检状态::版本漂移;
            }
            const auto 主键值 = 读取主键当前值候选(项.读取新值规格().读取幂等主键());
            if (主键值.状态 != 特征体系读取状态::未找到) {
                if (主键值.状态 == 特征体系读取状态::许可拒绝
                    || 主键值.状态 == 特征体系读取状态::版本漂移
                    || 主键值.状态 == 特征体系读取状态::内部不一致) {
                    return 映射批次读取失败(主键值.状态);
                }
                return 特征批次预检状态::幂等冲突;
            }
        }
        return 特征批次预检状态::可写;
    }

    static 特征批次结果 形成批次失败结果(
        const 特征批次变更规格& 规格,
        特征批次预检状态 状态) {
        特征批次结果 输出;
        输出.批次幂等身份 = 规格.读取批次幂等身份();
        输出.规则版本 = 规格.读取规则版本();
        输出.完整载荷摘要 = 规格.读取完整载荷摘要();
        输出.候选宿主 = 规格.读取候选宿主();
        switch (状态) {
        case 特征批次预检状态::幂等冲突:
            输出.状态 = 特征体系业务状态::幂等冲突;
            break;
        case 特征批次预检状态::许可拒绝:
            输出.状态 = 特征体系业务状态::许可拒绝;
            break;
        case 特征批次预检状态::版本漂移:
            输出.状态 = 特征体系业务状态::版本漂移;
            break;
        case 特征批次预检状态::内部不一致:
            输出.状态 = 特征体系业务状态::内部不一致;
            break;
        default:
            输出.状态 = 特征体系业务状态::入口拒绝;
            break;
        }
        return 输出;
    }

    bool 写入特征批次候选_会话(
        结构写入会话& 会话,
        特征批次结构参与包& 参与包) const {
        if (!参与包.完整() || 参与包.所有者_ != this) return false;
        const auto& 规格 = 参与包.规格_;
        const auto 宿主类型 = 会话.读取节点类型(规格.读取候选宿主());
        if (!宿主类型.has_value() || !允许特征宿主(*宿主类型)) return false;
        特征批次结果 候选;
        候选.状态 = 特征体系业务状态::已提交;
        候选.批次幂等身份 = 规格.读取批次幂等身份();
        候选.规则版本 = 规格.读取规则版本();
        候选.完整载荷摘要 = 规格.读取完整载荷摘要();
        候选.候选宿主 = 规格.读取候选宿主();
        候选.有序项目组.resize(规格.读取项目数量());
        std::function<void()> 写点回调;
#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
        写点回调 = [&参与包]() { 参与包.经过候选写点(); };
#endif

        for (std::size_t 顺序 = 0; 顺序 < 规格.读取项目数量(); ++顺序) {
            const auto 初始位置 = std::find_if(
                规格.读取初始项组().begin(), 规格.读取初始项组().end(),
                [&](const auto& 项) { return 项.读取顺序号() == 顺序; });
            if (初始位置 != 规格.读取初始项组().end()) {
                const auto& 项 = *初始位置;
                if (!会话.读取节点类型(项.读取来源版本().来源).has_value()
                    || 会话.读取节点类型(项.读取槽位规格().读取特征定义())
                        != std::optional<节点类型>{节点类型::特征}
                    || 存在宿主定义槽位_会话(
                        会话, 规格.读取候选宿主(), 项.读取槽位规格().读取特征定义())) return false;
                auto& 项结果 = 候选.有序项目组[顺序];
                项结果.种类 = 特征批次项种类::初始;
                项结果.顺序号 = static_cast<std::uint32_t>(顺序);
                if (!写入槽位_会话(会话, 项.读取槽位规格(), 项结果.槽位, 写点回调)
                    || !写入初始值_会话(
                        会话, 参与包.读取内部参与者(), 项结果.槽位.实例槽位,
                        项.读取值规格(), 项结果.当前值, 1, 写点回调)
                    || !写入批次元数据与来源_会话(
                        会话, 规格, 特征批次项种类::初始,
                        项.读取顺序号(), 项.读取来源版本(), 项结果.当前值,
                        nullptr, 写点回调)) return false;
                continue;
            }
            const auto 换代位置 = std::find_if(
                规格.读取换代项组().begin(), 规格.读取换代项组().end(),
                [&](const auto& 项) { return 项.读取顺序号() == 顺序; });
            if (换代位置 == 规格.读取换代项组().end()) return false;
            const auto& 项 = *换代位置;
            if (!会话.读取节点类型(项.读取来源版本().来源).has_value()) return false;
            auto& 项结果 = 候选.有序项目组[顺序];
            项结果.种类 = 特征批次项种类::当前值换代;
            项结果.顺序号 = static_cast<std::uint32_t>(顺序);
            const auto 换代索引 = static_cast<std::size_t>(
                std::distance(规格.读取换代项组().begin(), 换代位置));
            if (换代索引 >= 参与包.换代写前槽位组_.size()) return false;
            const auto& 当前槽位 = 参与包.换代写前槽位组_[换代索引];
            if (!当前槽位.完整() || 当前槽位.宿主 != 规格.读取候选宿主()
                || !验证槽位_会话(会话, 当前槽位)) return false;
            const auto 当前关系组 = 会话.读取关系记录组(项.读取实例槽位(), 关系类型::归属);
            if (当前关系组.size() != 1
                || !关系组包含证据(当前关系组, 项.读取预期当前关系())) return false;
            项结果.槽位 = 当前槽位;
            if (!写入初始值_会话(
                    会话, 参与包.读取内部参与者(), 项.读取实例槽位(),
                    项.读取新值规格(), 项结果.当前值,
                    1, 写点回调)
                || !写入批次元数据与来源_会话(
                    会话, 规格, 特征批次项种类::当前值换代,
                    项.读取顺序号(), 项.读取来源版本(), 项结果.当前值,
                    &项, 写点回调)) return false;
            const auto 失效 = 会话.失效已发布关系(项.读取预期当前关系().关系);
            if (!失效.成功() || !失效.值.has_value()) return false;
            if (写点回调) 写点回调();
            const auto 新当前组 = 会话.读取关系记录组(项.读取实例槽位(), 关系类型::归属);
            if (新当前组.size() != 1
                || !关系组包含证据(新当前组, 项结果.当前值.当前值关系)) return false;
        }
        if (!候选.完整()) return false;
        参与包.候选结果_ = std::move(候选);
        return true;
    }

    static bool 允许特征宿主(节点类型 类型) noexcept {
        return 类型 == 节点类型::存在 || 类型 == 节点类型::场景
            || 类型 == 节点类型::需求 || 类型 == 节点类型::任务
            || 类型 == 节点类型::方法;
    }

    static bool 允许二次特征组成项(节点类型 类型) noexcept {
        return 类型 == 节点类型::基础信息 || 类型 == 节点类型::存在
            || 类型 == 节点类型::场景 || 类型 == 节点类型::特征
            || 类型 == 节点类型::二次特征 || 类型 == 节点类型::因果引用;
    }

    static bool 组成项请求可用(const std::vector<节点句柄>& 组成项组) {
        if (组成项组.empty()) return false;
        for (std::size_t 左 = 0; 左 < 组成项组.size(); ++左) {
            if (!句柄有效(组成项组[左])) return false;
            for (std::size_t 右 = 左 + 1; 右 < 组成项组.size(); ++右) {
                if (组成项组[左] == 组成项组[右]) return false;
            }
        }
        return true;
    }

    特征节点身份 读取节点身份_已许可(
        节点句柄 目标,
        const 结构事务令牌& 令牌) const {
        特征节点身份 输出;
        输出.节点 = 目标;
        if (!句柄有效(目标)) return 输出;
        const auto 记录 = 节点_.读取节点(目标, 令牌);
        if (!记录.has_value()) {
            输出.状态 = 特征体系读取状态::版本漂移;
            return 输出;
        }
        if (!主信息_.读取主信息(记录->主信息, 令牌).has_value()) {
            return 身份内部不一致(目标, L"特征体系节点缺少当前可读主信息锚点。");
        }
        输出.状态 = 特征体系读取状态::已找到;
        输出.类型 = 记录->类型;
        输出.主信息 = 记录->主信息;
        return 输出;
    }

    特征节点身份 身份内部不一致(节点句柄 目标, const wchar_t* 说明) const {
        (void)追根因检查(false, 说明);
        特征节点身份 输出;
        输出.状态 = 特征体系读取状态::内部不一致;
        输出.节点 = 目标;
        return 输出;
    }

    std::optional<特征关系证据> 读取关系证据_已许可(
        const 关系记录& 记录,
        const 结构事务令牌& 令牌) const {
        if (记录.状态 != 记录状态::有效 || !句柄有效(记录.源节点)
            || !句柄有效(记录.目标节点)) return std::nullopt;
        const 关系句柄 句柄{关系仓库编号_, 记录.关系编号, 记录.版本号};
        const auto 当前 = 关系_.读取关系(句柄, 令牌);
        if (!当前.has_value() || 当前->状态 != 记录状态::有效
            || 当前->类型 != 记录.类型 || 当前->源节点 != 记录.源节点
            || 当前->目标节点 != 记录.目标节点 || 当前->顺序号 != 记录.顺序号) {
            return std::nullopt;
        }
        return 特征关系证据{句柄, 记录.类型, 记录.源节点, 记录.目标节点, 记录.顺序号};
    }

    std::optional<std::uint64_t> 读取唯一主键_已许可(
        节点句柄 目标,
        std::optional<std::uint64_t> 期望主键,
        const 结构事务令牌& 令牌) const {
        const auto 主键组 = 索引_.读取节点主键组(目标, 令牌);
        if (主键组.size() != 1 || 主键组.front() == 0) return std::nullopt;
        if (期望主键.has_value() && 主键组.front() != *期望主键) return std::nullopt;
        if (索引_.按主键查节点(主键组.front(), 令牌) != std::optional<节点句柄>{目标}) {
            return std::nullopt;
        }
        return 主键组.front();
    }

    特征定义值式材料 读取特征定义_已许可(
        节点句柄 目标,
        std::optional<std::uint64_t> 期望主键,
        const 结构事务令牌& 令牌) const {
        特征定义值式材料 输出;
        输出.特征定义 = 目标;
        const auto 身份 = 读取节点身份_已许可(目标, 令牌);
        if (!身份.当前可读()) {
            输出.状态 = 身份.状态;
            return 输出;
        }
        if (身份.类型 != 节点类型::特征) {
            输出.状态 = 特征体系读取状态::类型不匹配;
            return 输出;
        }
        if (!关系_.获取关系记录组(目标, 关系类型::模板, 令牌).empty()) {
            输出.状态 = 特征体系读取状态::类型不匹配;
            return 输出;
        }
        const auto 主键 = 读取唯一主键_已许可(目标, 期望主键, 令牌);
        if (!主键.has_value()) return 定义内部不一致(目标, L"特征定义缺少唯一非零主键或索引复核失败。");
        输出.状态 = 特征体系读取状态::已找到;
        输出.幂等主键 = *主键;
        输出.主信息 = 身份.主信息;
        return 输出;
    }

    特征槽位值式材料 读取实例槽位_已许可(
        节点句柄 目标,
        std::optional<std::uint64_t> 期望主键,
        const 结构事务令牌& 令牌) const {
        特征槽位值式材料 输出;
        输出.实例槽位 = 目标;
        const auto 身份 = 读取节点身份_已许可(目标, 令牌);
        if (!身份.当前可读()) {
            输出.状态 = 身份.状态;
            return 输出;
        }
        if (身份.类型 != 节点类型::特征) {
            输出.状态 = 特征体系读取状态::类型不匹配;
            return 输出;
        }
        const auto 主键 = 读取唯一主键_已许可(目标, 期望主键, 令牌);
        if (!主键.has_value()) return 槽位内部不一致(目标, L"实例特征槽位缺少唯一非零主键。");

        const auto 模板组 = 关系_.获取关系记录组(目标, 关系类型::模板, 令牌);
        if (模板组.size() != 1) {
            输出.状态 = 模板组.empty()
                ? 特征体系读取状态::类型不匹配 : 特征体系读取状态::内部不一致;
            return 输出;
        }
        const auto 模板证据 = 读取关系证据_已许可(模板组.front(), 令牌);
        if (!模板证据.has_value()) return 槽位内部不一致(目标, L"实例特征槽位模板关系无法完整读回。");
        const auto 定义 = 读取特征定义_已许可(模板证据->目标节点, std::nullopt, 令牌);
        if (!定义.完整()) return 槽位内部不一致(目标, L"实例特征槽位模板目标不是完整特征定义。");

        const auto 来源组 = 关系_.获取来源关系记录组(目标, 关系类型::归属, 令牌);
        if (来源组.size() != 1) return 槽位内部不一致(目标, L"实例特征槽位没有唯一宿主归属来源。");
        const auto 宿主证据 = 读取关系证据_已许可(来源组.front(), 令牌);
        if (!宿主证据.has_value()) return 槽位内部不一致(目标, L"实例特征槽位宿主关系无法完整读回。");
        const auto 宿主 = 读取节点身份_已许可(宿主证据->源节点, 令牌);
        if (!宿主.当前可读() || !允许特征宿主(宿主.类型)) {
            return 槽位内部不一致(目标, L"实例特征槽位宿主类型不在固定白名单。");
        }

        输出.状态 = 特征体系读取状态::已找到;
        输出.幂等主键 = *主键;
        输出.宿主 = 宿主.节点;
        输出.特征定义 = 定义.特征定义;
        输出.主信息 = 身份.主信息;
        输出.宿主关系 = *宿主证据;
        输出.模板关系 = *模板证据;
        return 输出;
    }

    特征槽位值式材料 读取宿主定义槽位_已许可(
        节点句柄 宿主,
        节点句柄 特征定义,
        const 结构事务令牌& 令牌) const {
        特征槽位值式材料 输出;
        输出.宿主 = 宿主;
        输出.特征定义 = 特征定义;
        const auto 宿主身份 = 读取节点身份_已许可(宿主, 令牌);
        if (!宿主身份.当前可读()) {
            输出.状态 = 宿主身份.状态;
            return 输出;
        }
        if (!允许特征宿主(宿主身份.类型)) return 输出;
        const auto 定义 = 读取特征定义_已许可(特征定义, std::nullopt, 令牌);
        if (!定义.完整()) {
            输出.状态 = 定义.状态;
            return 输出;
        }

        std::optional<特征槽位值式材料> 命中;
        for (const auto& 记录 : 关系_.获取关系记录组(宿主, 关系类型::归属, 令牌)) {
            const auto 证据 = 读取关系证据_已许可(记录, 令牌);
            if (!证据.has_value()) return 槽位内部不一致({}, L"宿主归属候选关系无法完整读回。");
            const auto 目标身份 = 读取节点身份_已许可(记录.目标节点, 令牌);
            if (!目标身份.当前可读()) return 槽位内部不一致({}, L"宿主归属候选端点无法完整读回。");
            if (目标身份.类型 != 节点类型::特征) continue;
            const auto 候选 = 读取实例槽位_已许可(记录.目标节点, std::nullopt, 令牌);
            if (候选.状态 == 特征体系读取状态::类型不匹配) continue;
            if (!候选.完整()) return 候选;
            if (候选.宿主 != 宿主 || 候选.特征定义 != 特征定义) continue;
            if (命中.has_value()) return 槽位内部不一致(候选.实例槽位, L"同一宿主和特征定义出现多个实例槽位。");
            命中 = 候选;
        }
        if (!命中.has_value()) {
            输出.状态 = 特征体系读取状态::未找到;
            return 输出;
        }
        return *命中;
    }

    特征原始值式材料 读取当前值_已许可(
        const 特征槽位值式材料& 槽位,
        const 结构事务令牌& 令牌) const {
        特征原始值式材料 输出;
        输出.实例槽位 = 槽位.实例槽位;
        if (!槽位.完整()) {
            输出.状态 = 槽位.状态;
            return 输出;
        }
        const auto 当前关系组 = 关系_.获取关系记录组(
            槽位.实例槽位, 关系类型::归属, 令牌);
        if (当前关系组.empty()) {
            输出.状态 = 特征体系读取状态::未找到;
            return 输出;
        }
        if (当前关系组.size() != 1) return 值内部不一致(槽位.实例槽位, L"实例槽位出现多个当前特征值关系。");
        const auto 关系证据 = 读取关系证据_已许可(当前关系组.front(), 令牌);
        if (!关系证据.has_value()) return 值内部不一致(槽位.实例槽位, L"当前特征值关系无法完整读回。");
        const auto 身份 = 读取节点身份_已许可(关系证据->目标节点, 令牌);
        if (!身份.当前可读() || 身份.类型 != 节点类型::特征值) {
            return 值内部不一致(槽位.实例槽位, L"当前特征值关系目标不是可读特征值节点。");
        }
        const auto 主键 = 读取唯一主键_已许可(身份.节点, std::nullopt, 令牌);
        if (!主键.has_value()) return 值内部不一致(槽位.实例槽位, L"当前特征值没有唯一非零主键。");

        const auto 侧表 = 侧表访问器_.读取(身份.节点);
        if (侧表.状态 == 特征值侧表读取状态::许可竞争) {
            输出.状态 = 特征体系读取状态::许可拒绝;
            return 输出;
        }
        if (!侧表.可读()) return 值内部不一致(槽位.实例槽位, L"当前特征值侧表材料缺失或互相矛盾。");

        输出.状态 = 特征体系读取状态::已找到;
        输出.幂等主键 = *主键;
        输出.特征值节点 = 身份.节点;
        输出.主信息 = 身份.主信息;
        输出.当前值关系 = *关系证据;
        输出.原始类型 = 侧表.原始类型;
        输出.原始值版本 = 侧表.原始值版本;
        if (侧表.原始类型 == 特征值原始类型::I64) {
            输出.I64值 = 主信息_.读取I64值(身份.主信息, 0, 令牌);
            if (!输出.I64值.has_value()) return 值内部不一致(槽位.实例槽位, L"I64 特征值缺少主信息值。");
        } else {
            if (主信息_.读取I64值(身份.主信息, 0, 令牌).has_value()) {
                return 值内部不一致(槽位.实例槽位, L"Vec 特征值错误携带 I64 主信息值。");
            }
            输出.VecI64值 = 侧表.VecI64值;
            输出.VecU64值 = 侧表.VecU64值;
        }
        return 输出;
    }

    特征原始值式材料 读取主键当前值候选(std::uint64_t 主键) const {
        if (!有效() || 主键 == 0) return {};
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) return {特征体系读取状态::许可拒绝};
        const auto 目标 = 索引_.按主键查节点(主键, 许可.读取令牌());
        if (!目标.has_value()) return {特征体系读取状态::未找到};
        const auto 身份 = 读取节点身份_已许可(*目标, 许可.读取令牌());
        if (!身份.当前可读()) return {身份.状态};
        if (身份.类型 != 节点类型::特征值) return {特征体系读取状态::类型不匹配};
        const auto 来源组 = 关系_.获取来源关系记录组(*目标, 关系类型::归属, 许可.读取令牌());
        if (来源组.size() != 1) return 值内部不一致({}, L"主键特征值没有唯一实例槽位来源。");
        const auto 槽位 = 读取实例槽位_已许可(来源组.front().源节点, std::nullopt, 许可.读取令牌());
        if (!槽位.完整()) return 从槽位失败形成值(槽位);
        auto 输出 = 读取当前值_已许可(槽位, 许可.读取令牌());
        if (输出.完整() && 输出.幂等主键 != 主键) {
            return 值内部不一致(槽位.实例槽位, L"主键特征值反向读回到不同主键。");
        }
        return 输出;
    }

    特征原始值式材料 读取批次已发布值(
        const 特征槽位值式材料& 槽位,
        std::uint64_t 值幂等主键) const {
        特征原始值式材料 输出;
        输出.实例槽位 = 槽位.实例槽位;
        if (!有效() || !槽位.完整() || 值幂等主键 == 0) return 输出;
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) {
            输出.状态 = 特征体系读取状态::许可拒绝;
            return 输出;
        }
        const auto& 令牌 = 许可.读取令牌();
        const auto 值节点 = 索引_.按主键查节点(值幂等主键, 令牌);
        if (!值节点.has_value()) {
            输出.状态 = 特征体系读取状态::未找到;
            return 输出;
        }
        const auto 身份 = 读取节点身份_已许可(*值节点, 令牌);
        if (!身份.当前可读() || 身份.类型 != 节点类型::特征值) {
            输出.状态 = 身份.状态 == 特征体系读取状态::已找到
                ? 特征体系读取状态::类型不匹配 : 身份.状态;
            return 输出;
        }
        const auto 审计关系组 = 关系_.获取关系审计记录组(
            槽位.实例槽位, 关系类型::归属, 令牌);
        std::optional<关系记录> 发布关系;
        for (const auto& 关系 : 审计关系组) {
            if (关系.目标节点 != *值节点
                || (关系.状态 != 记录状态::有效 && 关系.状态 != 记录状态::已失效)) continue;
            if (发布关系.has_value()) return 值内部不一致(
                槽位.实例槽位, L"批次值存在重复的槽位发布关系审计记录。");
            发布关系 = 关系;
        }
        if (!发布关系.has_value()) {
            输出.状态 = 特征体系读取状态::未找到;
            return 输出;
        }
        const auto 发布版本 = 发布关系->状态 == 记录状态::已失效
            ? (发布关系->版本号 > 1 ? 发布关系->版本号 - 1 : 0)
            : 发布关系->版本号;
        if (发布版本 == 0) return 值内部不一致(
            槽位.实例槽位, L"批次值已失效关系缺少可回查的发布版本。");
        const auto 侧表 = 侧表访问器_.读取(*值节点);
        if (侧表.状态 == 特征值侧表读取状态::许可竞争) {
            输出.状态 = 特征体系读取状态::许可拒绝;
            return 输出;
        }
        if (!侧表.可读()) return 值内部不一致(
            槽位.实例槽位, L"批次值原始材料历史缺失或不一致。");
        输出.状态 = 特征体系读取状态::已找到;
        输出.幂等主键 = 值幂等主键;
        输出.特征值节点 = *值节点;
        输出.主信息 = 身份.主信息;
        输出.当前值关系 = {
            {关系仓库编号_, 发布关系->关系编号, 发布版本},
            关系类型::归属, 槽位.实例槽位, *值节点, 发布关系->顺序号};
        输出.原始类型 = 侧表.原始类型;
        输出.原始值版本 = 侧表.原始值版本;
        if (侧表.原始类型 == 特征值原始类型::I64) {
            输出.I64值 = 主信息_.读取I64值(身份.主信息, 0, 令牌);
            if (!输出.I64值.has_value()) return 值内部不一致(
                槽位.实例槽位, L"批次 I64 值历史缺少主信息值。");
        } else {
            if (主信息_.读取I64值(身份.主信息, 0, 令牌).has_value()) {
                return 值内部不一致(槽位.实例槽位, L"批次 Vec 值历史错误携带 I64 主信息值。");
            }
            输出.VecI64值 = 侧表.VecI64值;
            输出.VecU64值 = 侧表.VecU64值;
        }
        return 输出;
    }

    二次特征值式材料 读取二次特征_已许可(
        节点句柄 目标,
        std::optional<std::uint64_t> 期望主键,
        const 结构事务令牌& 令牌) const {
        二次特征值式材料 输出;
        输出.二次特征 = 目标;
        const auto 身份 = 读取节点身份_已许可(目标, 令牌);
        if (!身份.当前可读()) {
            输出.状态 = 身份.状态;
            return 输出;
        }
        if (身份.类型 != 节点类型::二次特征) {
            输出.状态 = 特征体系读取状态::类型不匹配;
            return 输出;
        }
        const auto 主键 = 读取唯一主键_已许可(目标, 期望主键, 令牌);
        if (!主键.has_value()) return 二次特征内部不一致(目标, L"二次特征缺少唯一非零主键。");
        const auto 关系组 = 关系_.获取关系记录组(目标, 关系类型::引用, 令牌);
        if (关系组.empty()) return 二次特征内部不一致(目标, L"二次特征组成项为空。");
        std::vector<std::optional<节点句柄>> 项组(关系组.size());
        std::vector<std::optional<特征关系证据>> 证据组(关系组.size());
        for (const auto& 记录 : 关系组) {
            if (记录.顺序号 < 0 || static_cast<std::size_t>(记录.顺序号) >= 关系组.size()) {
                return 二次特征内部不一致(目标, L"二次特征组成关系顺序号不连续。");
            }
            const auto 位置 = static_cast<std::size_t>(记录.顺序号);
            if (项组[位置].has_value()) return 二次特征内部不一致(目标, L"二次特征组成关系顺序号重复。");
            const auto 证据 = 读取关系证据_已许可(记录, 令牌);
            const auto 项身份 = 读取节点身份_已许可(记录.目标节点, 令牌);
            if (!证据.has_value() || !项身份.当前可读()
                || !允许二次特征组成项(项身份.类型) || 记录.目标节点 == 目标) {
                return 二次特征内部不一致(目标, L"二次特征组成项类型、端点或关系证据无效。");
            }
            for (const auto& 已有 : 项组) {
                if (已有.has_value() && *已有 == 记录.目标节点) {
                    return 二次特征内部不一致(目标, L"二次特征包含重复组成项。");
                }
            }
            项组[位置] = 记录.目标节点;
            证据组[位置] = *证据;
        }
        输出.有序组成项组.reserve(项组.size());
        输出.组成关系组.reserve(证据组.size());
        for (std::size_t 索引 = 0; 索引 < 项组.size(); ++索引) {
            if (!项组[索引].has_value() || !证据组[索引].has_value()) {
                return 二次特征内部不一致(目标, L"二次特征组成关系存在顺序空洞。");
            }
            输出.有序组成项组.push_back(*项组[索引]);
            输出.组成关系组.push_back(*证据组[索引]);
        }
        输出.状态 = 特征体系读取状态::已找到;
        输出.幂等主键 = *主键;
        输出.主信息 = 身份.主信息;
        return 输出;
    }

    特征定义值式材料 定义内部不一致(节点句柄 目标, const wchar_t* 说明) const {
        (void)追根因检查(false, 说明);
        特征定义值式材料 输出;
        输出.状态 = 特征体系读取状态::内部不一致;
        输出.特征定义 = 目标;
        return 输出;
    }

    特征槽位值式材料 槽位内部不一致(节点句柄 目标, const wchar_t* 说明) const {
        (void)追根因检查(false, 说明);
        特征槽位值式材料 输出;
        输出.状态 = 特征体系读取状态::内部不一致;
        输出.实例槽位 = 目标;
        return 输出;
    }

    特征原始值式材料 值内部不一致(节点句柄 槽位, const wchar_t* 说明) const {
        (void)追根因检查(false, 说明);
        特征原始值式材料 输出;
        输出.状态 = 特征体系读取状态::内部不一致;
        输出.实例槽位 = 槽位;
        return 输出;
    }

    二次特征值式材料 二次特征内部不一致(节点句柄 目标, const wchar_t* 说明) const {
        (void)追根因检查(false, 说明);
        二次特征值式材料 输出;
        输出.状态 = 特征体系读取状态::内部不一致;
        输出.二次特征 = 目标;
        return 输出;
    }

    static 特征原始值式材料 从槽位失败形成值(const 特征槽位值式材料& 槽位) {
        特征原始值式材料 输出;
        输出.状态 = 槽位.状态;
        输出.实例槽位 = 槽位.实例槽位;
        return 输出;
    }

    static bool 记录匹配证据(const 关系记录& 记录, const 特征关系证据& 证据) noexcept {
        return 证据.完整() && 记录.关系编号 == 证据.关系.关系编号
            && 记录.版本号 == 证据.关系.版本号 && 记录.类型 == 证据.类型
            && 记录.源节点 == 证据.源节点 && 记录.目标节点 == 证据.目标节点
            && 记录.顺序号 == 证据.顺序号 && 记录.状态 == 记录状态::有效;
    }

    static bool 关系组包含证据(
        const std::vector<关系记录>& 关系组,
        const 特征关系证据& 证据) noexcept {
        return std::count_if(关系组.begin(), 关系组.end(), [&](const auto& 记录) {
            return 记录匹配证据(记录, 证据);
        }) == 1;
    }

    static bool 写入带主键节点_会话(
        结构写入会话& 会话,
        节点类型 类型,
        std::uint64_t 主键,
        主信息句柄& 新主信息,
        节点句柄& 新节点,
        const std::function<void()>& 写点回调 = {}) {
        const auto 主结果 = 会话.创建主信息候选();
        if (!主结果.成功()) return false;
        新主信息 = *主结果.值;
        if (写点回调) 写点回调();
        const auto 节点结果 = 会话.创建节点候选(类型, 新主信息);
        if (!节点结果.成功()) return false;
        新节点 = *节点结果.值;
        if (写点回调) 写点回调();
        if (!会话.绑定主键(形成索引绑定请求(
            主键, 新节点, 索引所有者::特征体系)).成功()) return false;
        if (写点回调) 写点回调();
        return 会话.主信息可读(新主信息) && 会话.节点可读(新节点)
            && 会话.主键绑定匹配(主键, 新节点);
    }

    static bool 验证宿主定义_会话(
        结构写入会话& 会话,
        const 特征节点身份& 宿主,
        const 特征定义值式材料& 定义) {
        return 宿主.当前可读() && 定义.完整()
            && 会话.读取节点类型(宿主.节点) == std::optional<节点类型>{宿主.类型}
            && 会话.读取节点主信息(宿主.节点) == std::optional<主信息句柄>{宿主.主信息}
            && 会话.读取节点类型(定义.特征定义) == std::optional<节点类型>{节点类型::特征}
            && 会话.读取节点主信息(定义.特征定义) == std::optional<主信息句柄>{定义.主信息}
            && 会话.主键绑定匹配(定义.幂等主键, 定义.特征定义)
            && 会话.读取关系记录组(定义.特征定义, 关系类型::模板).empty();
    }

    static bool 存在宿主定义槽位_会话(
        结构写入会话& 会话,
        节点句柄 宿主,
        节点句柄 特征定义) {
        for (const auto& 宿主关系 : 会话.读取关系记录组(宿主, 关系类型::归属)) {
            if (会话.读取节点类型(宿主关系.目标节点)
                != std::optional<节点类型>{节点类型::特征}) continue;
            const auto 模板组 = 会话.读取关系记录组(宿主关系.目标节点, 关系类型::模板);
            for (const auto& 模板 : 模板组) {
                if (模板.目标节点 == 特征定义) return true;
            }
        }
        return false;
    }

    static bool 验证槽位_会话(结构写入会话& 会话, const 特征槽位值式材料& 槽位) {
        if (!槽位.完整()
            || 会话.读取节点类型(槽位.宿主) == std::nullopt
            || 会话.读取节点类型(槽位.实例槽位) != std::optional<节点类型>{节点类型::特征}
            || 会话.读取节点主信息(槽位.实例槽位) != std::optional<主信息句柄>{槽位.主信息}
            || 会话.读取节点类型(槽位.特征定义) != std::optional<节点类型>{节点类型::特征}
            || !会话.主键绑定匹配(槽位.幂等主键, 槽位.实例槽位)) return false;
        const auto 宿主关系组 = 会话.读取关系记录组(槽位.宿主, 关系类型::归属);
        const auto 模板关系组 = 会话.读取关系记录组(槽位.实例槽位, 关系类型::模板);
        return 关系组包含证据(宿主关系组, 槽位.宿主关系)
            && 模板关系组.size() == 1 && 关系组包含证据(模板关系组, 槽位.模板关系);
    }

    static bool 写入槽位_会话(
        结构写入会话& 会话,
        const 特征槽位写入规格& 规格,
        特征槽位值式材料& 输出,
        const std::function<void()>& 写点回调 = {}) {
        主信息句柄 新主信息;
        节点句柄 新槽位;
        if (!写入带主键节点_会话(
                会话, 节点类型::特征, 规格.读取幂等主键(), 新主信息, 新槽位,
                写点回调)) return false;
        const auto 宿主关系 = 会话.创建关系(
            关系类型::归属, 规格.读取宿主(), 新槽位);
        if (!宿主关系.成功()) return false;
        if (写点回调) 写点回调();
        const auto 模板关系 = 会话.创建关系(
            关系类型::模板, 新槽位, 规格.读取特征定义());
        if (!模板关系.成功()) return false;
        if (写点回调) 写点回调();
        if (!会话.关系可读(*宿主关系.值) || !会话.关系可读(*模板关系.值)) return false;
        输出.状态 = 特征体系读取状态::已找到;
        输出.幂等主键 = 规格.读取幂等主键();
        输出.宿主 = 规格.读取宿主();
        输出.特征定义 = 规格.读取特征定义();
        输出.实例槽位 = 新槽位;
        输出.主信息 = 新主信息;
        输出.宿主关系 = {*宿主关系.值, 关系类型::归属, 输出.宿主, 新槽位, 0};
        输出.模板关系 = {*模板关系.值, 关系类型::模板, 新槽位, 输出.特征定义, 0};
        return true;
    }

    static bool 写入初始值_会话(
        结构写入会话& 会话,
        特征值原始材料事务参与者& 参与者,
        节点句柄 实例槽位,
        const 初始特征值写入规格& 规格,
        特征原始值式材料& 输出,
        std::uint64_t 原始值版本 = 1,
        const std::function<void()>& 写点回调 = {}) {
        if (原始值版本 == 0) return false;
        主信息句柄 新主信息;
        节点句柄 新值;
        if (!写入带主键节点_会话(
                会话, 节点类型::特征值, 规格.读取幂等主键(), 新主信息, 新值,
                写点回调)) return false;
        const auto 当前关系 = 会话.创建关系(关系类型::归属, 实例槽位, 新值);
        if (!当前关系.成功()) return false;
        if (写点回调) 写点回调();
        if (规格.读取原始类型() == 特征值原始类型::I64
            && !会话.写入候选I64值(新主信息, 0, *规格.读取I64值()).成功()) return false;
        if (规格.读取原始类型() == 特征值原始类型::I64 && 写点回调) 写点回调();
        特征值初始原始材料 材料{
            新值, 新主信息, 规格.读取原始类型(), 原始值版本,
            规格.读取I64值(), 规格.读取VecI64值(), 规格.读取VecU64值()};
        if (!参与者.登记初始材料(std::move(材料))) return false;
        if (写点回调) 写点回调();
        bool 完整 = 会话.关系可读(*当前关系.值);
        if (规格.读取原始类型() == 特征值原始类型::I64) {
            完整 = 会话.候选I64值匹配(新主信息, 0, *规格.读取I64值()) && 完整;
        }
        if (!完整) return false;
        输出.状态 = 特征体系读取状态::已找到;
        输出.幂等主键 = 规格.读取幂等主键();
        输出.实例槽位 = 实例槽位;
        输出.特征值节点 = 新值;
        输出.主信息 = 新主信息;
        输出.当前值关系 = {*当前关系.值, 关系类型::归属, 实例槽位, 新值, 0};
        输出.原始类型 = 规格.读取原始类型();
        输出.原始值版本 = 原始值版本;
        输出.I64值 = 规格.读取I64值();
        输出.VecI64值 = 规格.读取VecI64值();
        输出.VecU64值 = 规格.读取VecU64值();
        return true;
    }

    static bool 匹配槽位(
        const 特征槽位值式材料& 材料,
        const 特征槽位写入规格& 规格) noexcept {
        return 材料.完整() && 材料.幂等主键 == 规格.读取幂等主键()
            && 材料.宿主 == 规格.读取宿主()
            && 材料.特征定义 == 规格.读取特征定义();
    }

    static bool 匹配原始值(
        const 特征原始值式材料& 材料,
        const 初始特征值写入规格& 规格,
        std::uint64_t 预期原始值版本 = 1) noexcept {
        return 材料.完整() && 材料.幂等主键 == 规格.读取幂等主键()
            && 材料.原始类型 == 规格.读取原始类型()
            && 材料.原始值版本 == 预期原始值版本
            && 材料.I64值 == 规格.读取I64值()
            && 材料.VecI64值 == 规格.读取VecI64值()
            && 材料.VecU64值 == 规格.读取VecU64值();
    }

    static 特征体系业务结果 形成定义结果(
        特征体系业务状态 状态,
        const 特征定义值式材料& 定义) {
        特征体系业务结果 输出;
        输出.状态 = 状态;
        输出.定义 = 定义;
        return 输出;
    }

    static 特征体系业务结果 形成槽位结果(
        特征体系业务状态 状态,
        const 特征槽位值式材料& 槽位) {
        特征体系业务结果 输出;
        输出.状态 = 状态;
        输出.槽位 = 槽位;
        return 输出;
    }

    static 特征体系业务结果 形成值结果(
        特征体系业务状态 状态,
        const 特征槽位值式材料& 槽位,
        const 特征原始值式材料& 当前值) {
        特征体系业务结果 输出;
        输出.状态 = 状态;
        输出.槽位 = 槽位;
        输出.当前值 = 当前值;
        return 输出;
    }

    static 特征体系业务结果 形成二次特征结果(
        特征体系业务状态 状态,
        const 二次特征值式材料& 二次特征) {
        特征体系业务结果 输出;
        输出.状态 = 状态;
        输出.二次特征 = 二次特征;
        return 输出;
    }

    static 特征体系业务结果 合并身份定义失败(
        const 特征节点身份& 身份,
        const 特征定义值式材料& 定义) noexcept {
        if (身份.状态 == 特征体系读取状态::内部不一致
            || 定义.状态 == 特征体系读取状态::内部不一致) return {特征体系业务状态::内部不一致};
        if (身份.状态 == 特征体系读取状态::许可拒绝
            || 定义.状态 == 特征体系读取状态::许可拒绝) return {特征体系业务状态::许可拒绝};
        if (身份.状态 == 特征体系读取状态::版本漂移
            || 定义.状态 == 特征体系读取状态::版本漂移) return {特征体系业务状态::版本漂移};
        return {特征体系业务状态::入口拒绝};
    }

    static 特征体系业务结果 从读取失败形成结果(特征体系读取状态 状态) noexcept {
        switch (状态) {
        case 特征体系读取状态::许可拒绝:
            return {特征体系业务状态::许可拒绝};
        case 特征体系读取状态::版本漂移:
            return {特征体系业务状态::版本漂移};
        case 特征体系读取状态::内部不一致:
            return {特征体系业务状态::内部不一致};
        default:
            return {特征体系业务状态::入口拒绝};
        }
    }

    static 特征体系业务结果 映射结构失败(const 结构写入结果& 结果) {
        switch (结果.状态) {
        case 结构写入状态::许可拒绝:
            return {特征体系业务状态::许可拒绝};
        case 结构写入状态::版本漂移:
            return {特征体系业务状态::版本漂移};
        case 结构写入状态::入口拒绝:
            (void)追根因检查(false, L"特征体系业务准入后结构会话未形成提交决定。");
            return {特征体系业务状态::内部不一致};
        case 结构写入状态::内部不一致:
            (void)追根因检查(false, L"特征体系结构写入或参与者收口内部不一致。");
            return {特征体系业务状态::内部不一致};
        default:
            (void)追根因检查(false, L"特征体系结构会话返回不允许的收口状态。");
            return {特征体系业务状态::内部不一致};
        }
    }

    结构事务接线 接线_;
    主信息仓库& 主信息_;
    节点仓库& 节点_;
    关系仓库& 关系_;
    索引仓库& 索引_;
    特征值服务& 特征值_;
    std::uint64_t 关系仓库编号_ = 0;
    结构写入执行器 执行器_;
    特征值原始材料侧表访问器 侧表访问器_;
};

inline bool 特征批次结构参与包::加入结构写入会话(结构写入会话& 会话) {
    return 完整() && 所有者_->写入特征批次候选_会话(会话, *this);
}

}
