        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) return {特征体系读取状态::许可拒绝};
        const auto 目标 = 索引_.按主键查节点(主键, 许可.读取令牌());
        if (!目标.has_value()) return {特征体系读取状态::未找到};
