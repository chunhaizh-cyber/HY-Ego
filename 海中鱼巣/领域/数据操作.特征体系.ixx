    std::optional<特征批次换代项规格> 形成特征批次换代项规格(
        std::uint32_t 顺序号,
        节点句柄 实例槽位,
        节点句柄 特征定义,
        关系句柄 预期当前关系,
        节点句柄 预期当前值,
        std::uint64_t 预期原始值版本,
        节点句柄 来源,
        初始特征值写入规格 新值规格) const {
        特征批次换代项规格 规格(
            顺序号, 实例槽位, 特征定义, 预期当前关系,
            预期当前值, 预期原始值版本, 来源, std::move(新值规格));
        return 规格.完整()
            ? std::optional<特征批次换代项规格>{std::move(规格)}
            : std::nullopt;
    }

    std::optional<特征批次变更规格> 形成特征批次变更规格(
        特征批次身份 批次,
        std::uint32_t 业务规则版本,
        节点句柄 宿主,
        std::vector<特征批次项目规格> 项目组) const {
        特征批次变更规格 规格(
            批次, 业务规则版本, 宿主, std::move(项目组));
        if (!规格.完整()) return std::nullopt;
        const auto& 项目 = 规格.读取项目组();
        for (std::size_t 左 = 0; 左 < 项目.size(); ++左) {
            const auto 左定义 = std::visit(
                [](const auto& 值) { return 值.读取特征定义(); }, 项目[左]);
            const auto 左新值主键 = std::visit(
                [](const auto& 值) { return 值.读取新值规格().读取幂等主键(); }, 项目[左]);
            for (std::size_t 右 = 左 + 1; 右 < 项目.size(); ++右) {
                const auto 右定义 = std::visit(
                    [](const auto& 值) { return 值.读取特征定义(); }, 项目[右]);
                const auto 右新值主键 = std::visit(
                    [](const auto& 值) { return 值.读取新值规格().读取幂等主键(); }, 项目[右]);
                if (左定义 == 右定义 || 左新值主键 == 右新值主键) return std::nullopt;
                const auto* 左初始 = std::get_if<特征批次初始项规格>(&项目[左]);
                const auto* 右初始 = std::get_if<特征批次初始项规格>(&项目[右]);
                const auto* 左换代 = std::get_if<特征批次换代项规格>(&项目[左]);
                const auto* 右换代 = std::get_if<特征批次换代项规格>(&项目[右]);
                if ((左初始 != nullptr && 右初始 != nullptr
                        && 左初始->读取槽位幂等主键() == 右初始->读取槽位幂等主键())
                    || (左换代 != nullptr && 右换代 != nullptr
                        && 左换代->读取实例槽位() == 右换代->读取实例槽位())) {
                    return std::nullopt;
                }
            }
        }
        return 规格;
    }

    特征节点身份 读取节点身份(节点句柄 目标) const {
        if (!有效() || !句柄有效(目标)) return {};
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) return {特征体系读取状态::许可拒绝};
        return 读取节点身份_已许可(目标, 许可.读取令牌());
    }

    特征定义值式材料 读取特征定义(节点句柄 特征定义) const {
        if (!有效() || !句柄有效(特征定义)) return {};
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) return {特征体系读取状态::许可拒绝};
        return 读取特征定义_已许可(特征定义, std::nullopt, 许可.读取令牌());
    }

    特征定义值式材料 读取主键特征定义(std::uint64_t 主键) const {
        if (!有效() || 主键 == 0) return {};
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) return {特征体系读取状态::许可拒绝};
        const auto 目标 = 索引_.按主键查节点(主键, 许可.读取令牌());
        if (!目标.has_value()) return {特征体系读取状态::未找到};
        return 读取特征定义_已许可(*目标, 主键, 许可.读取令牌());
    }

    特征槽位值式材料 读取实例特征槽位(节点句柄 实例槽位) const {
        if (!有效() || !句柄有效(实例槽位)) return {};
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) return {特征体系读取状态::许可拒绝};
        return 读取实例槽位_已许可(实例槽位, std::nullopt, 许可.读取令牌());
    }

    特征槽位值式材料 读取主键实例特征槽位(std::uint64_t 主键) const {
        if (!有效() || 主键 == 0) return {};
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) return {特征体系读取状态::许可拒绝};
        const auto 目标 = 索引_.按主键查节点(主键, 许可.读取令牌());
        if (!目标.has_value()) return {特征体系读取状态::未找到};
        return 读取实例槽位_已许可(*目标, 主键, 许可.读取令牌());
    }

    特征槽位值式材料 读取宿主定义槽位(节点句柄 宿主, 节点句柄 特征定义) const {
        if (!有效() || !句柄有效(宿主) || !句柄有效(特征定义)) return {};
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) return {特征体系读取状态::许可拒绝};
        return 读取宿主定义槽位_已许可(宿主, 特征定义, 许可.读取令牌());
    }

    特征原始值式材料 读取实例槽位当前值(节点句柄 实例槽位) const {
        if (!有效() || !句柄有效(实例槽位)) return {};
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) return {特征体系读取状态::许可拒绝};
        const auto 槽位 = 读取实例槽位_已许可(实例槽位, std::nullopt, 许可.读取令牌());
        if (!槽位.完整()) return 从槽位失败形成值(槽位);
        return 读取当前值_已许可(槽位, 许可.读取令牌());
    }

    宿主特征状态值式材料 读取宿主特征状态(
        节点句柄 宿主,
        节点句柄 特征定义) const {
        宿主特征状态值式材料 输出;
        输出.宿主 = 宿主;
        输出.特征定义 = 特征定义;
        if (!有效() || !句柄有效(宿主) || !句柄有效(特征定义)) return 输出;
        auto 许可 = 接线_.取得共享许可(接线_.运行期状态);
        if (!许可.有效()) {
            输出.状态 = 特征体系读取状态::许可拒绝;
            return 输出;
        }
        输出.槽位 = 读取宿主定义槽位_已许可(宿主, 特征定义, 许可.读取令牌());
        if (输出.槽位.状态 == 特征体系读取状态::未找到) {
            输出.状态 = 特征体系读取状态::未找到;
            return 输出;
        }
        if (!输出.槽位.完整()) {
            输出.状态 = 输出.槽位.状态;
            return 输出;
        }
        输出.当前值 = 读取当前值_已许可(输出.槽位, 许可.读取令牌());
        输出.状态 = 输出.当前值.状态;
        return 输出;
    }

    二次特征值式材料 读取二次特征(节点句柄 二次特征) const {
