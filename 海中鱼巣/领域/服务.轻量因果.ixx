// 文件规则：轻量因果业务服务必须经动态业务服务取得完整值式证据，不保存来源动态关系。
module;

#include "../核心/句柄.h"

#include <cstdint>

export module 海中鱼巣.领域.服务.轻量因果;

import 海中鱼巣.领域.数据操作.轻量因果;
import 海中鱼巣.领域.服务.动态;

export namespace 海中鱼巣 {

struct 创建轻量因果请求 {
    std::uint64_t 幂等主键 = 0;
    节点句柄 来源动态;
};

class 轻量因果业务服务 final {
public:
    轻量因果业务服务(动态业务服务& 动态服务, 轻量因果数据操作& 数据操作)
        : 动态服务_(动态服务), 数据操作_(数据操作) {}

    轻量因果业务结果 创建轻量因果(const 创建轻量因果请求& 请求) const {
        if (请求.幂等主键 == 0 || !句柄有效(请求.来源动态)) return {};
        const auto 动态材料 = 动态服务_.读取动态材料(请求.来源动态);
        if (!动态材料.完整抽象动态() && !动态材料.完整实例动态()) {
            using 动态读取状态 = decltype(动态材料.状态);
            switch (动态材料.状态) {
            case 动态读取状态::许可拒绝: return {轻量因果业务状态::许可拒绝};
            case 动态读取状态::版本漂移: return {轻量因果业务状态::版本漂移};
            case 动态读取状态::内部不一致: return {轻量因果业务状态::内部不一致};
            default: return {轻量因果业务状态::入口拒绝};
            }
        }
        const auto 规格 = 数据操作_.形成轻量因果写入规格(
            请求.幂等主键, 动态材料.动态节点, 动态材料.主信息);
        return 规格.has_value()
            ? 数据操作_.创建轻量因果(*规格)
            : 轻量因果业务结果{轻量因果业务状态::内部不一致};
    }

    轻量因果值式材料 读取轻量因果(节点句柄 因果引用) const {
        return 句柄有效(因果引用)
            ? 数据操作_.读取因果引用(因果引用)
            : 轻量因果值式材料{};
    }

    轻量因果值式材料 读取主键轻量因果(std::uint64_t 主键) const {
        return 主键 != 0
            ? 数据操作_.读取主键因果引用(主键)
            : 轻量因果值式材料{};
    }

private:
    动态业务服务& 动态服务_;
    轻量因果数据操作& 数据操作_;
};

}
