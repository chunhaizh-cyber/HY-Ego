// 文件规则：任务结果结算组合器只编排业务服务并重读权威材料；不得接触仓库、线程锁或事务能力。
module;

#include "../核心/句柄.h"

#include <array>
#include <cstdint>
#include <limits>
#include <optional>
#include <vector>

export module 海中鱼巣.领域.组合.任务结果结算;

import 海中鱼巣.领域.数据操作.需求任务方法;
import 海中鱼巣.领域.数据操作.状态动态;
import 海中鱼巣.领域.服务.需求;
import 海中鱼巣.领域.服务.任务;
import 海中鱼巣.领域.服务.方法;
import 海中鱼巣.领域.服务.状态;
import 海中鱼巣.领域.服务.动态;
import 海中鱼巣.线程.协议.任务执行请求;
import 海中鱼巣.线程.任务结果回执协议;

export namespace 海中鱼巣 {

enum class 任务结果治理状态 : std::uint8_t {
    入口拒绝 = 0,
    当前性漂移 = 1,
    许可拒绝 = 2,
    版本漂移 = 3,
    内部不一致 = 4,
    未达成已转待重筹办 = 5,
    任务已完成待需求结算 = 6,
    已完成并结算 = 7
};

enum class 任务结果治理拒绝原因 : std::uint8_t {
    无 = 0,
    非新版执行回执 = 1,
    回执协议拒绝 = 2,
    参数无效 = 3,
    幂等用途冲突 = 4,
    时间顺序无效 = 5,
    任务当前性漂移 = 6,
    来源冻结材料漂移 = 7,
    实际状态动态不一致 = 8,
    目标裁决不可用 = 9,
    任务提交未完成 = 10,
    需求结算待重试 = 11
};

enum class 任务结果提示性质 : std::uint8_t {
    无 = 0,
    非权威待结算请求材料 = 1
};

struct 任务结果治理参数 {
    std::uint64_t 当前时间戳 = 0;
    std::uint64_t 待重筹办幂等材料编号 = 0;
    std::uint64_t 待重筹办发生时间戳 = 0;
    std::uint64_t 完成状态幂等主键 = 0;
    std::uint64_t 完成发生时间戳 = 0;
    std::uint64_t 结算状态幂等主键 = 0;
    std::uint64_t 结算发生时间戳 = 0;
    节点句柄 因果引用;
};

struct 任务结果治理请求 {
    任务结果回执材料 回执;
    任务结果治理参数 参数;
};

struct 非权威待需求结算提示 {
    任务结果提示性质 性质 = 任务结果提示性质::无;
    节点句柄 任务;
    节点句柄 需求;
    节点句柄 实际状态;
    节点句柄 动态证据;
    节点句柄 因果引用;
    需求任务方法业务状态 任务完成状态 = 需求任务方法业务状态::入口拒绝;
    需求任务方法业务状态 需求结算状态 = 需求任务方法业务状态::入口拒绝;
    std::uint64_t 结算状态幂等主键 = 0;
    std::uint64_t 结算发生时间戳 = 0;
    bool 承载机器事实 = false;

    bool 完整() const noexcept {
        return 性质 == 任务结果提示性质::非权威待结算请求材料
            && 句柄有效(任务) && 句柄有效(需求) && 句柄有效(实际状态)
            && 句柄有效(动态证据) && 结算状态幂等主键 != 0
            && 结算发生时间戳 != 0 && !承载机器事实;
    }
};

struct 任务结果治理结果 {
    任务结果治理状态 状态 = 任务结果治理状态::入口拒绝;
    任务结果治理拒绝原因 拒绝原因 = 任务结果治理拒绝原因::无;
    任务结果回执准入结果 协议结果;
    需求目标状态达成材料 目标裁决;
    任务提交结果 任务提交;
    需求提交结果 需求结算;
    std::optional<非权威待需求结算提示> 待结算提示;

    bool 已收口() const noexcept {
        return 状态 == 任务结果治理状态::未达成已转待重筹办
            || 状态 == 任务结果治理状态::任务已完成待需求结算
            || 状态 == 任务结果治理状态::已完成并结算;
    }
};

class 任务结果结算组合器 final {
public:
    任务结果结算组合器(
        需求业务服务& 需求服务,
        任务业务服务& 任务服务,
        方法业务服务& 方法服务,
        状态业务服务& 状态服务,
        动态业务服务& 动态服务)
        : 需求服务_(需求服务), 任务服务_(任务服务), 方法服务_(方法服务),
          状态服务_(状态服务), 动态服务_(动态服务) {
    }

    任务结果治理结果 处理任务执行结果(const 任务结果治理请求& 请求) const {
        任务结果治理结果 输出;
        输出.协议结果 = 复核任务结果回执材料(
            请求.回执, 任务结果回执准入上下文{请求.参数.当前时间戳});
        if (请求.回执.材料性质 != 任务结果回执材料性质::非权威任务执行结果证据) {
            输出.拒绝原因 = 任务结果治理拒绝原因::非新版执行回执;
            return 输出;
        }
        if (输出.协议结果.状态 != 任务结果回执准入状态::可准入) {
            输出.状态 = 输出.协议结果.状态 == 任务结果回执准入状态::内部不一致
                ? 任务结果治理状态::内部不一致
                : 任务结果治理状态::入口拒绝;
            输出.拒绝原因 = 任务结果治理拒绝原因::回执协议拒绝;
            return 输出;
        }
        if (!请求.回执.来源执行请求.has_value()) {
            输出.拒绝原因 = 任务结果治理拒绝原因::非新版执行回执;
            return 输出;
        }

        const auto& 来源 = *请求.回执.来源执行请求;
        if (!治理参数有效(请求.参数, 来源)) {
            输出.拒绝原因 = 参数编号冲突(请求.参数, 来源)
                ? 任务结果治理拒绝原因::幂等用途冲突
                : 请求.参数.当前时间戳 == 0
                    ? 任务结果治理拒绝原因::参数无效
                    : 任务结果治理拒绝原因::时间顺序无效;
            return 输出;
        }

        const auto 当前任务 = 任务服务_.读取任务(请求.回执.句柄组.目标任务);
        if (const auto 失败 = 映射读取失败(当前任务.状态); 失败.has_value()) {
            输出.状态 = *失败;
            输出.拒绝原因 = 任务结果治理拒绝原因::任务当前性漂移;
            return 输出;
        }
        if (!当前任务.完整承接()) {
            输出.状态 = 任务结果治理状态::内部不一致;
            输出.拒绝原因 = 任务结果治理拒绝原因::任务当前性漂移;
            return 输出;
        }

        const bool 正在执行 = 当前任务.当前生命周期.阶段
            == 分层任务生命周期阶段::执行中;
        const bool 已经完成 = 当前任务.当前生命周期.阶段
            == 分层任务生命周期阶段::已完成;
        if (!正在执行 && !已经完成) {
            输出.状态 = 任务结果治理状态::当前性漂移;
            输出.拒绝原因 = 任务结果治理拒绝原因::任务当前性漂移;
            return 输出;
        }
        if (已经完成
            && 当前任务.实际结果状态
                != std::optional<节点句柄>{请求.回执.句柄组.实际结果状态}) {
            输出.状态 = 任务结果治理状态::当前性漂移;
            输出.拒绝原因 = 任务结果治理拒绝原因::任务当前性漂移;
            return 输出;
        }
        if (!任务执行任务材料静态相同(转换任务材料(当前任务), 来源.任务材料)) {
            输出.状态 = 任务结果治理状态::当前性漂移;
            输出.拒绝原因 = 任务结果治理拒绝原因::来源冻结材料漂移;
            return 输出;
        }

        const auto 当前需求 = 需求服务_.读取需求(当前任务.来源需求);
        if (const auto 失败 = 映射读取失败(当前需求.状态); 失败.has_value()) {
            输出.状态 = *失败;
            输出.拒绝原因 = 任务结果治理拒绝原因::来源冻结材料漂移;
            return 输出;
        }
        if (!当前需求.完整目标状态需求()) {
            输出.状态 = 任务结果治理状态::内部不一致;
            输出.拒绝原因 = 任务结果治理拒绝原因::来源冻结材料漂移;
            return 输出;
        }
        if (当前需求.身份.节点 != 当前任务.来源需求
            || 当前需求.场景 != 当前任务.场景
            || 当前需求.目标状态 != 当前任务.目标状态
            || 当前任务.来源需求 != 来源.任务材料.来源需求) {
            输出.状态 = 任务结果治理状态::当前性漂移;
            输出.拒绝原因 = 任务结果治理拒绝原因::来源冻结材料漂移;
            return 输出;
        }

        const auto 当前方法 = 方法服务_.读取登记项(来源.方法材料.身份.节点);
        if (const auto 失败 = 映射读取失败(当前方法.状态); 失败.has_value()) {
            输出.状态 = *失败;
            输出.拒绝原因 = 任务结果治理拒绝原因::来源冻结材料漂移;
            return 输出;
        }
        if (!当前方法.完整()) {
            输出.状态 = 任务结果治理状态::内部不一致;
            输出.拒绝原因 = 任务结果治理拒绝原因::来源冻结材料漂移;
            return 输出;
        }
        if (当前方法.生命周期 != 分层方法生命周期::活跃
            || !任务执行方法材料相同(转换方法材料(当前方法), 来源.方法材料)) {
            输出.状态 = 任务结果治理状态::当前性漂移;
            输出.拒绝原因 = 任务结果治理拒绝原因::来源冻结材料漂移;
            return 输出;
        }

        const auto 动作组 = 方法服务_.读取规格组(
            当前方法.身份.节点, 分层方法角色::动作入口);
        if (动作组.size() != 1 || !动作组.front().完整动作入口()) {
            输出.状态 = 动作组.empty()
                ? 任务结果治理状态::当前性漂移
                : 任务结果治理状态::内部不一致;
            输出.拒绝原因 = 任务结果治理拒绝原因::来源冻结材料漂移;
            return 输出;
        }
        if (!任务执行动作材料相同(转换动作材料(动作组.front()), 来源.动作材料)) {
            输出.状态 = 任务结果治理状态::当前性漂移;
            输出.拒绝原因 = 任务结果治理拒绝原因::来源冻结材料漂移;
            return 输出;
        }
        if (正在执行) {
            const auto 动作桥 = 任务服务_.读取动作桥请求(当前任务.身份.节点);
            if (!动作桥.has_value() || !动作桥->完整()
                || 动作桥->任务 != 当前任务.身份.节点
                || 动作桥->方法首 != 来源.方法材料.身份.节点
                || 动作桥->动作入口 != 来源.动作材料.身份.节点
                || 动作桥->稳定动作键 != 来源.动作材料.稳定动作键
                || 动作桥->输入场景 != 当前任务.场景
                || 动作桥->输出场景 != 当前任务.场景) {
                输出.状态 = 任务结果治理状态::内部不一致;
                输出.拒绝原因 = 任务结果治理拒绝原因::来源冻结材料漂移;
                return 输出;
            }
        }

        const auto 实际状态 = 状态服务_.读取状态材料(
            请求.回执.句柄组.实际结果状态);
        if (const auto 失败 = 映射状态读取失败(实际状态); 失败.has_value()) {
            输出.状态 = *失败;
            输出.拒绝原因 = 任务结果治理拒绝原因::实际状态动态不一致;
            return 输出;
        }
        const auto 动态证据 = 动态服务_.读取动态材料(请求.回执.句柄组.动态证据);
        if (const auto 失败 = 映射动态读取失败(动态证据); 失败.has_value()) {
            输出.状态 = *失败;
            输出.拒绝原因 = 任务结果治理拒绝原因::实际状态动态不一致;
            return 输出;
        }
        const auto& 调度 = 来源.调度请求;
        if (!实际状态.完整实例状态() || !动态证据.完整实例动态()
            || 实际状态.状态节点 != 请求.回执.句柄组.实际结果状态
            || 实际状态.幂等主键 != 调度.实际状态幂等主键
            || 实际状态.发生时间戳 != 调度.实际状态时间戳
            || 实际状态.状态值 != 调度.实际状态值
            || 实际状态.场景 != 当前任务.场景
            || 实际状态.主体 != 当前任务.虚拟存在
            || 动态证据.动态节点 != 请求.回执.句柄组.动态证据
            || 动态证据.幂等主键 != 调度.动态幂等主键
            || 动态证据.发生时间戳 != 调度.实际状态时间戳
            || 动态证据.场景 != 当前任务.场景
            || 动态证据.主体 != 当前任务.虚拟存在
            || 动态证据.被改变目标 != 当前任务.目标状态
            || 动态证据.后状态 != 实际状态.状态节点
            || 动态证据.来源动作 != 来源.动作材料.身份.节点
            || 动态证据.发生时间戳 > 请求.回执.发生时间戳) {
            输出.状态 = 任务结果治理状态::内部不一致;
            输出.拒绝原因 = 任务结果治理拒绝原因::实际状态动态不一致;
            return 输出;
        }
        if (!复核执行前状态(当前任务, 动态证据, 调度)) {
            输出.状态 = 任务结果治理状态::内部不一致;
            输出.拒绝原因 = 任务结果治理拒绝原因::实际状态动态不一致;
            return 输出;
        }

        输出.目标裁决 = 需求服务_.判定目标状态达成(
            当前需求.身份.节点, 实际状态.状态节点);
        if (!输出.目标裁决.成功()) {
            if (const auto 失败 = 映射读取失败(输出.目标裁决.状态); 失败.has_value()) {
                输出.状态 = *失败;
            } else {
                输出.状态 = 任务结果治理状态::内部不一致;
            }
            输出.拒绝原因 = 任务结果治理拒绝原因::目标裁决不可用;
            return 输出;
        }
        if (输出.目标裁决.需求 != 当前需求.身份.节点
            || 输出.目标裁决.目标状态 != 当前任务.目标状态
            || 输出.目标裁决.实际状态 != 实际状态.状态节点) {
            输出.状态 = 任务结果治理状态::内部不一致;
            输出.拒绝原因 = 任务结果治理拒绝原因::目标裁决不可用;
            return 输出;
        }

        if (输出.目标裁决.裁决 == 需求目标状态裁决::未达成) {
            if (!正在执行 || 当前需求.当前结算 != 分层需求结算结论::未结算) {
                输出.状态 = 任务结果治理状态::当前性漂移;
                输出.拒绝原因 = 任务结果治理拒绝原因::任务当前性漂移;
                return 输出;
            }
            输出.任务提交 = 任务服务_.迁移生命周期({
                当前任务.身份.节点, 分层任务生命周期阶段::待重筹办,
                请求.参数.待重筹办幂等材料编号,
                请求.参数.待重筹办发生时间戳});
            if (!输出.任务提交.成功()) {
                输出.状态 = 映射提交失败(输出.任务提交.状态);
                输出.拒绝原因 = 任务结果治理拒绝原因::任务提交未完成;
                return 输出;
            }
            if (!输出.任务提交.材料.完整承接()
                || 输出.任务提交.材料.当前生命周期.阶段
                    != 分层任务生命周期阶段::待重筹办
                || !任务执行任务材料静态相同(
                    转换任务材料(输出.任务提交.材料), 来源.任务材料)) {
                输出.状态 = 任务结果治理状态::内部不一致;
                输出.拒绝原因 = 任务结果治理拒绝原因::任务提交未完成;
                return 输出;
            }
            输出.状态 = 任务结果治理状态::未达成已转待重筹办;
            return 输出;
        }
        if (输出.目标裁决.裁决 != 需求目标状态裁决::已达成
            || 当前需求.当前结算 == 分层需求结算结论::未满足) {
            输出.状态 = 任务结果治理状态::内部不一致;
            输出.拒绝原因 = 任务结果治理拒绝原因::目标裁决不可用;
            return 输出;
        }

        输出.任务提交 = 任务服务_.提交实际结果并完成({
            当前任务.身份.节点, 实际状态.状态节点,
            请求.参数.完成状态幂等主键, 请求.参数.完成发生时间戳});
        if (!输出.任务提交.成功()) {
            输出.状态 = 映射提交失败(输出.任务提交.状态);
            输出.拒绝原因 = 任务结果治理拒绝原因::任务提交未完成;
            return 输出;
        }
        if (!复核任务完成读回(输出.任务提交.材料, 请求)) {
            输出.状态 = 任务结果治理状态::内部不一致;
            输出.拒绝原因 = 任务结果治理拒绝原因::任务提交未完成;
            return 输出;
        }

        输出.需求结算 = 需求服务_.提交独立结算({
            当前需求.身份.节点, 当前任务.身份.节点, 实际状态.状态节点,
            动态证据.动态节点, 请求.参数.因果引用,
            请求.参数.结算状态幂等主键, 请求.参数.结算发生时间戳});
        if (输出.需求结算.成功()) {
            if (!输出.需求结算.材料.完整目标状态需求()
                || 输出.需求结算.材料.当前结算 != 分层需求结算结论::已满足
                || !输出.需求结算.材料.最近结算状态.has_value()) {
                输出.状态 = 任务结果治理状态::内部不一致;
                输出.拒绝原因 = 任务结果治理拒绝原因::目标裁决不可用;
                return 输出;
            }
            输出.状态 = 任务结果治理状态::已完成并结算;
            return 输出;
        }
        if (输出.需求结算.状态 == 需求任务方法业务状态::入口拒绝
            || 输出.需求结算.状态 == 需求任务方法业务状态::许可拒绝
            || 输出.需求结算.状态 == 需求任务方法业务状态::版本漂移) {
            输出.状态 = 任务结果治理状态::任务已完成待需求结算;
            输出.拒绝原因 = 任务结果治理拒绝原因::需求结算待重试;
            输出.待结算提示 = 形成待结算提示(请求, 当前任务, 输出);
            return 输出;
        }
        输出.状态 = 任务结果治理状态::内部不一致;
        输出.拒绝原因 = 任务结果治理拒绝原因::目标裁决不可用;
        return 输出;
    }

private:
    static bool 节点句柄为空(const 节点句柄& 句柄) noexcept {
        return 句柄.仓库编号 == 0 && 句柄.节点编号 == 0 && 句柄.版本号 == 0;
    }

    static bool 参数编号冲突(
        const 任务结果治理参数& 参数,
        const 任务执行冻结请求& 来源) noexcept {
        const auto& 调度 = 来源.调度请求;
        if (参数.待重筹办幂等材料编号 != 调度.待重筹办幂等主键
            || 参数.完成状态幂等主键 == 参数.结算状态幂等主键) return true;
        const std::array<std::uint64_t, 10> 已占用{
            调度.排队生命周期幂等主键, 调度.执行生命周期幂等主键,
            调度.待重筹办幂等主键, 调度.实际状态幂等主键,
            调度.动态幂等主键, 调度.请求编号, 调度.幂等键,
            调度.回执编号, 调度.回执幂等键, 调度.任务序号};
        for (const auto 编号 : 已占用) {
            if (参数.完成状态幂等主键 == 编号
                || 参数.结算状态幂等主键 == 编号) return true;
        }
        return false;
    }

    static bool 治理参数有效(
        const 任务结果治理参数& 参数,
        const 任务执行冻结请求& 来源) noexcept {
        const auto& 调度 = 来源.调度请求;
        const auto 最大时间 = static_cast<std::uint64_t>(std::numeric_limits<std::int64_t>::max());
        if (参数.当前时间戳 == 0 || 参数.待重筹办幂等材料编号 == 0
            || 参数.完成状态幂等主键 == 0 || 参数.结算状态幂等主键 == 0
            || 参数.待重筹办发生时间戳 == 0 || 参数.完成发生时间戳 == 0
            || 参数.结算发生时间戳 == 0 || 参数编号冲突(参数, 来源)) return false;
        if (!节点句柄为空(参数.因果引用) && !句柄有效(参数.因果引用)) return false;
        return 参数.待重筹办发生时间戳 == 调度.待重筹办时间戳
            && 参数.待重筹办发生时间戳 >= 调度.执行时间戳
            && 参数.完成发生时间戳 >= 调度.回执时间戳
            && 参数.结算发生时间戳 >= 参数.完成发生时间戳
            && 参数.当前时间戳 <= 调度.截止时间戳
            && 参数.待重筹办发生时间戳 <= 最大时间
            && 参数.完成发生时间戳 <= 最大时间
            && 参数.结算发生时间戳 <= 最大时间;
    }

    static std::optional<任务结果治理状态> 映射读取失败(
        需求任务方法读取状态 状态) noexcept {
        switch (状态) {
        case 需求任务方法读取状态::已找到:
            return std::nullopt;
        case 需求任务方法读取状态::许可拒绝:
            return 任务结果治理状态::许可拒绝;
        case 需求任务方法读取状态::版本漂移:
            return 任务结果治理状态::版本漂移;
        case 需求任务方法读取状态::内部不一致:
            return 任务结果治理状态::内部不一致;
        default:
            return 任务结果治理状态::当前性漂移;
        }
    }

    static std::optional<任务结果治理状态> 映射状态读取失败(
        const 状态值式材料& 材料) noexcept {
        if (材料.状态 == 状态动态读取状态::已找到) return std::nullopt;
        switch (材料.状态) {
        case 状态动态读取状态::许可拒绝:
            return 任务结果治理状态::许可拒绝;
        case 状态动态读取状态::版本漂移:
            return 任务结果治理状态::版本漂移;
        case 状态动态读取状态::内部不一致:
            return 任务结果治理状态::内部不一致;
        default:
            return 任务结果治理状态::当前性漂移;
        }
    }

    static std::optional<任务结果治理状态> 映射动态读取失败(
        const 动态值式材料& 材料) noexcept {
        if (材料.状态 == 状态动态读取状态::已找到) return std::nullopt;
        switch (材料.状态) {
        case 状态动态读取状态::许可拒绝:
            return 任务结果治理状态::许可拒绝;
        case 状态动态读取状态::版本漂移:
            return 任务结果治理状态::版本漂移;
        case 状态动态读取状态::内部不一致:
            return 任务结果治理状态::内部不一致;
        default:
            return 任务结果治理状态::当前性漂移;
        }
    }

    static 任务结果治理状态 映射提交失败(
        需求任务方法业务状态 状态) noexcept {
        switch (状态) {
        case 需求任务方法业务状态::许可拒绝:
            return 任务结果治理状态::许可拒绝;
        case 需求任务方法业务状态::版本漂移:
            return 任务结果治理状态::版本漂移;
        case 需求任务方法业务状态::内部不一致:
            return 任务结果治理状态::内部不一致;
        default:
            return 任务结果治理状态::当前性漂移;
        }
    }

    static 任务执行关系证据 转换关系证据(const 高级关系证据& 证据) {
        return {证据.关系, 证据.类型, 证据.源节点, 证据.目标节点,
            证据.顺序号, 证据.状态};
    }

    static 任务执行节点身份 转换节点身份(const 高级节点身份& 身份) {
        return {身份.幂等主键, 身份.节点, 身份.类型, 身份.主信息};
    }

    static 任务执行选择材料 转换选择材料(const 任务方法选择材料& 材料) {
        return {
            转换节点身份(材料.记录身份), 材料.任务, 材料.方法,
            材料.幂等材料编号, 转换关系证据(材料.方法投影关系),
            转换关系证据(材料.发布关系), 材料.来源生命周期关系,
            材料.来源生命周期版本, 材料.来源方法生命周期关系,
            材料.来源方法生命周期版本, 材料.排序规则版本,
            材料.召回请求规则版本, 材料.来源候选数量};
    }

    static 任务执行任务材料 转换任务材料(const 任务权威材料& 材料) {
        任务执行任务材料 输出;
        输出.身份 = 转换节点身份(材料.身份);
        输出.来源需求 = 材料.来源需求;
        输出.虚拟存在 = 材料.虚拟存在;
        输出.场景 = 材料.场景;
        输出.目标状态 = 材料.目标状态;
        输出.需求拥有任务关系 = 转换关系证据(材料.需求拥有任务关系);
        输出.任务来源需求关系 = 转换关系证据(材料.任务来源需求关系);
        输出.虚拟存在关系 = 转换关系证据(材料.虚拟存在关系);
        输出.场景关系 = 转换关系证据(材料.场景关系);
        输出.目标状态关系 = 转换关系证据(材料.目标状态关系);
        输出.当前生命周期 = {
            转换关系证据(材料.当前生命周期.关系),
            材料.当前生命周期.状态,
            static_cast<任务执行生命周期阶段>(材料.当前生命周期.阶段),
            材料.当前生命周期.版本,
            材料.当前生命周期.发生时间戳,
            材料.当前生命周期.记录阶段};
        if (材料.当前选择.has_value()) 输出.当前选择 = 转换选择材料(*材料.当前选择);
        return 输出;
    }

    static 任务执行方法材料 转换方法材料(const 方法登记项材料& 材料) {
        return {
            转换节点身份(材料.身份), 材料.登记根, 材料.角色状态,
            材料.虚拟存在, 转换关系证据(材料.登记关系),
            转换关系证据(材料.角色关系), 转换关系证据(材料.虚拟存在关系),
            转换关系证据(材料.生命周期关系),
            static_cast<任务执行方法生命周期>(材料.生命周期)};
    }

    static 任务执行动作材料 转换动作材料(const 方法规格材料& 材料) {
        任务执行动作材料 输出;
        输出.身份 = 转换节点身份(材料.身份);
        输出.方法首 = 材料.方法首;
        输出.角色 = static_cast<任务执行方法角色>(材料.角色);
        输出.角色状态 = 材料.角色状态;
        输出.方法角色关系 = 转换关系证据(材料.方法角色关系);
        输出.角色状态关系 = 转换关系证据(材料.角色状态关系);
        if (材料.入口状态.has_value()) 输出.入口状态 = *材料.入口状态;
        if (材料.入口状态关系.has_value()) {
            输出.入口状态关系 = 转换关系证据(*材料.入口状态关系);
        }
        if (材料.输入场景.has_value()) 输出.输入场景 = *材料.输入场景;
        if (材料.输出场景.has_value()) 输出.输出场景 = *材料.输出场景;
        if (材料.输入场景关系.has_value()) {
            输出.输入场景关系 = 转换关系证据(*材料.输入场景关系);
        }
        if (材料.输出场景关系.has_value()) {
            输出.输出场景关系 = 转换关系证据(*材料.输出场景关系);
        }
        输出.稳定动作键 = 材料.稳定动作键;
        return 输出;
    }

    bool 复核执行前状态(
        const 任务权威材料& 当前任务,
        const 动态值式材料& 动态证据,
        const 任务执行调度请求& 调度) const {
        const auto 前状态 = 状态服务_.读取状态材料(动态证据.前状态);
        if (!前状态.完整实例状态()
            || 前状态.幂等主键 != 调度.执行生命周期幂等主键
            || 前状态.发生时间戳 != 调度.执行时间戳
            || 前状态.场景 != 当前任务.场景
            || 前状态.主体 != 当前任务.虚拟存在) return false;
        const auto 历史 = 任务服务_.读取生命周期历史(当前任务.身份.节点);
        std::size_t 匹配数量 = 0;
        for (const auto& 材料 : 历史) {
            if (材料.完整()
                && 材料.阶段 == 分层任务生命周期阶段::执行中
                && 材料.状态 == 动态证据.前状态
                && 材料.发生时间戳 == 调度.执行时间戳) {
                ++匹配数量;
            }
        }
        return 匹配数量 == 1;
    }

    bool 复核任务完成读回(
        const 任务权威材料& 材料,
        const 任务结果治理请求& 请求) const {
        if (!材料.完整承接()
            || 材料.当前生命周期.阶段 != 分层任务生命周期阶段::已完成
            || 材料.实际结果状态
                != std::optional<节点句柄>{请求.回执.句柄组.实际结果状态}
            || !材料.实际结果关系.has_value()
            || !材料.实际结果关系->当前有效()) return false;
        const auto 完成状态 = 状态服务_.读取状态材料(材料.当前生命周期.状态);
        return 完成状态.完整实例状态()
            && 完成状态.幂等主键 == 请求.参数.完成状态幂等主键
            && 完成状态.发生时间戳 == 请求.参数.完成发生时间戳
            && 完成状态.场景 == 材料.场景
            && 完成状态.主体 == 材料.虚拟存在;
    }

    static 非权威待需求结算提示 形成待结算提示(
        const 任务结果治理请求& 请求,
        const 任务权威材料& 任务,
        const 任务结果治理结果& 结果) {
        return {
            任务结果提示性质::非权威待结算请求材料,
            任务.身份.节点, 任务.来源需求,
            请求.回执.句柄组.实际结果状态,
            请求.回执.句柄组.动态证据,
            请求.参数.因果引用,
            结果.任务提交.状态, 结果.需求结算.状态,
            请求.参数.结算状态幂等主键,
            请求.参数.结算发生时间戳,
            false};
    }

    需求业务服务& 需求服务_;
    任务业务服务& 任务服务_;
    方法业务服务& 方法服务_;
    状态业务服务& 状态服务_;
    动态业务服务& 动态服务_;
};

}
