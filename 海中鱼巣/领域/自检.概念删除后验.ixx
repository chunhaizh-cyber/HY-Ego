// 文件规则：概念删除后验自检只承载隔离审计、幂等和等价重建验收，不进入生产依赖。
module;

#include "../核心/主信息仓库.h"
#include "../核心/节点仓库.h"
#include "../核心/关系仓库.h"
#include "../核心/索引仓库.h"
#include "存在服务.h"
#include "动态服务.h"
#include "二次特征服务.h"
#include "因果服务.h"
#include "状态服务.h"
#include "语素服务.h"
#include "概念图服务.h"
#include "初始化.概念图.ixx"
#include "统计服务.h"

#include <algorithm>
#include <array>
#include <atomic>
#include <cstddef>
#include <cstdint>
#include <iostream>
#include <limits>
#include <optional>
#include <thread>
#include <vector>

export module 海中鱼巣.领域.自检.概念删除后验;

import 海中鱼巣.核心.协调.结构事务;
import 海中鱼巣.领域.服务.概念安全删除;
import 海中鱼巣.自检.运行器;

export namespace 海中鱼巣 {

自检单元结果 运行概念删除后验自检() {
    std::array<bool, 12> 验收{};
    try {
        结构事务协调器 协调器(84);
        const auto 接线 = 协调器.生成接线();
        主信息仓库 主信息(184, 接线);
        节点仓库 节点(主信息, 284, 接线);
        关系仓库 关系(节点, 384, 接线);
        索引仓库 索引(节点, 接线);
        存在服务 存在(主信息, 节点, 关系);
        动态服务 动态(主信息, 节点, 关系);
        二次特征服务 二次特征(主信息, 节点, 关系);
        因果服务 因果(主信息, 节点);
        状态服务 状态(主信息, 节点, 关系);
        语素服务 语素(主信息, 节点, 关系, 索引);
        概念图服务 概念图(节点, 关系);
        统计服务 统计;
        概念图初始化服务 初始化(概念图, 存在, 动态, 二次特征, 因果, 状态, 语素);
        const auto 初始化结果 = 初始化.初始化四个根();
        const auto 基础版本 = 概念图.初始化活动图基础版本();

        const auto 来源实例 = 存在.创建实际存在();
        const auto 根支持 = 概念图.确保存在实例根支持(来源实例);
        概念约束材料 约束;
        约束.维度 = 概念约束维度::特征原始值;
        约束.定义节点 = 来源实例;
        约束.值类型 = 概念约束值类型::I64;
        约束.I64值 = 84;
        概念候选输入材料 输入;
        输入.签名 = {概念根类别::存在, 1, {约束}};
        输入.来源实例 = 来源实例;
        输入.定义材料组 = {来源实例};
        const auto 初次候选 = 概念图.计算固定点候选图(
            概念图.读取活动图版本(), {输入}, 32, 8);
        const auto 初次发布 = 概念图.发布候选图版本并返回结果(
            初次候选, 存在, 动态, 二次特征, 因果);
        auto 支持概念组 = 概念图.读取实例支持概念(来源实例);
        支持概念组.erase(std::remove(
            支持概念组.begin(), 支持概念组.end(), 初始化结果.存在根.根节点), 支持概念组.end());
        const 节点句柄 旧概念 = 支持概念组.size() == 1 ? 支持概念组.front() : 节点句柄{};
        const auto 支持记录组 = 关系.获取关系记录组(来源实例, 关系类型::实例支持概念);
        const auto 支持位置 = std::find_if(支持记录组.begin(), 支持记录组.end(), [&旧概念](const auto& 记录) {
            return 记录.目标节点 == 旧概念;
        });
        const 关系句柄 支持关系 = 支持位置 == 支持记录组.end()
            ? 关系句柄{}
            : 关系句柄{384, 支持位置->关系编号, 支持位置->版本号};
        const auto 支持失效 = 概念图.失效活动普通概念实例支持({
            来源实例, 旧概念, 支持关系, 概念图.读取活动图版本()});

        const auto 命名空间 = 统计.定义缓存命名空间(
            缓存类型::概念用途观察, 来源结构类型::概念,
            概念图.读取活动图版本(), 84, 缓存值类型::用途观察,
            false, 缓存失效条件::规则版本变化);
        const auto 缓存 = 统计.记录概念用途观察(
            命名空间, 旧概念, 概念用途类型::一般, 10, 0);
        const 概念生命周期复核规则 规则{84, 100, 90, 80};
        const auto 冷却候选 = 概念图.读取生命周期复核候选(旧概念, 命名空间, 规则, 统计);
        const auto 冷却 = 冷却候选.has_value()
            ? 概念图.转换概念生命周期(
                旧概念, 概念生命周期阶段::冷却, 冷却候选.value(), 规则, 统计)
            : std::nullopt;
        const auto 退役候选 = 概念图.读取生命周期复核候选(旧概念, 命名空间, 规则, 统计);
        const auto 退役 = 退役候选.has_value()
            ? 概念图.转换概念生命周期(
                旧概念, 概念生命周期阶段::退役, 退役候选.value(), 规则, 统计)
            : std::nullopt;
        const bool 主键已绑定 = 索引.绑定主键(84001, 旧概念);
        const auto 影响读取 = 概念图.读取概念删除影响候选({
            旧概念, 概念图.读取活动图版本(), 128,
            std::numeric_limits<std::size_t>::max()});

        std::optional<概念结构写集已补全候选> 待提交;
        if (影响读取.候选.has_value()) {
            auto 许可 = 接线.取得独占许可(接线.运行期状态);
            if (许可.有效()) {
                const auto& 令牌 = 许可.读取令牌();
                const auto& 影响 = 影响读取.候选.value();
                const auto 当前节点 = 节点.读取节点(旧概念, 令牌);
                const auto 当前关系 = 关系.获取节点相关关系记录组(旧概念, 令牌);
                const auto 当前主键 = 索引.读取节点主键组(旧概念, 令牌);
                if (当前节点.has_value()) {
                    const auto 节点包 = 节点.准备节点删除包(旧概念, 令牌);
                    const auto 主信息包 = 主信息.准备主信息删除包(旧概念, 当前节点->主信息, 令牌);
                    const auto 关系包 = 关系.准备节点关系失效包(旧概念, 当前关系, 令牌);
                    const auto 索引包 = 索引.准备节点主键删除包(旧概念, 当前主键, 令牌);
                    const 概念结构所有者清理请求 请求{
                        旧概念, 当前节点->主信息, 概念结构所有者类型::存在服务, true, true};
                    const auto 授权 = 存在.形成概念节点清理授权(请求, 令牌);
                    const auto 缓存包 = 统计.准备概念缓存清理包(旧概念, 令牌);
                    if (节点包.has_value() && 主信息包.has_value() && 关系包.has_value()
                        && 索引包.has_value() && 授权.has_value() && 缓存包.has_value()) {
                        待提交 = 概念图.补全概念删除结构写集(
                            影响, 节点包.value(), 主信息包.value(), 关系包.value(),
                            索引包.value(), 授权.value(), 缓存包.value(), 令牌);
                    }
                }
            }
        }

        领域::概念安全删除编排器 编排器(
            接线, 主信息, 节点, 关系, 索引, 概念图, 统计,
            存在, 动态, 二次特征, 因果);
        const auto 删除回执 = 待提交.has_value()
            ? 编排器.提交安全删除(待提交.value())
            : 领域::概念安全删除回执{};
        const auto 后验 = 编排器.复核删除审计(删除回执);

        验收[0] = 初始化结果.成功() && 基础版本.has_value() && 根支持.has_value()
            && 初次候选.已收敛() && 初次发布.正常成功() && 句柄有效(旧概念)
            && 支持失效.状态 == 实例支持失效状态::已失效
            && 冷却.has_value() && 退役.has_value() && 主键已绑定
            && 删除回执.已提交() && 后验.节点与主信息已删除;
        验收[1] = 后验.关系审计完整
            && !删除回执.关系审计句柄组.empty();
        验收[2] = 后验.索引已清理
            && !索引.按主键查节点(84001).has_value();
        验收[3] = 后验.登记与活动图已清理
            && 后验.缓存已清理 && 缓存.has_value();
        验收[4] = 后验.活动版本已发布 && 后验.完整();

        auto 当前直接边组 = std::vector<概念删除后直接边>{};
        for (const auto& 关系材料 : 概念图.读取活动关系组()) {
            if (关系材料.类型 == 关系类型::概念上下位) {
                当前直接边组.push_back({关系材料.源节点, 关系材料.目标节点});
            }
        }
        const auto 边小于 = [](const auto& 左, const auto& 右) {
            if (左.上位概念.节点编号 != 右.上位概念.节点编号) {
                return 左.上位概念.节点编号 < 右.上位概念.节点编号;
            }
            return 左.下位概念.节点编号 < 右.下位概念.节点编号;
        };
        auto 预期直接边组 = 影响读取.候选.has_value()
            ? 影响读取.候选->删除后直接边组
            : std::vector<概念删除后直接边>{};
        std::sort(当前直接边组.begin(), 当前直接边组.end(), 边小于);
        std::sort(预期直接边组.begin(), 预期直接边组.end(), 边小于);
        const auto 四树 = 概念图.读取全部抽象树视图();
        验收[5] = 当前直接边组.size() == 预期直接边组.size()
            && std::equal(当前直接边组.begin(), 当前直接边组.end(), 预期直接边组.begin(),
                [](const auto& 左, const auto& 右) {
                    return 左.上位概念 == 右.上位概念 && 左.下位概念 == 右.下位概念;
                })
            && 四树.has_value() && 四树->size() == 4;

        const auto 幂等前版本 = 概念图.读取活动图版本();
        const auto 幂等回执 = 待提交.has_value()
            ? 编排器.提交安全删除(待提交.value())
            : 领域::概念安全删除回执{};
        验收[6] = 幂等回执.状态 == 领域::概念安全删除状态::候选已过期
            && 幂等回执.幂等完成 && 幂等回执.已完成()
            && 概念图.读取活动图版本() == 幂等前版本;

        auto 缺项回执 = 删除回执;
        缺项回执.关系审计句柄组.push_back({384, 999999, 1});
        验收[7] = !编排器.复核删除审计(缺项回执).完整();

        const auto 重建候选 = 概念图.计算固定点候选图(
            概念图.读取活动图版本(), {输入}, 32, 8);
        const auto 重建发布 = 概念图.发布候选图版本并返回结果(
            重建候选, 存在, 动态, 二次特征, 因果);
        auto 重建支持组 = 概念图.读取实例支持概念(来源实例);
        重建支持组.erase(std::remove(
            重建支持组.begin(), 重建支持组.end(), 初始化结果.存在根.根节点), 重建支持组.end());
        const 节点句柄 新概念 = 重建支持组.size() == 1 ? 重建支持组.front() : 节点句柄{};
        验收[8] = 重建候选.已收敛() && 重建发布.正常成功()
            && 句柄有效(新概念) && !(新概念 == 旧概念)
            && !节点.读取节点(旧概念).has_value();
        验收[9] = 概念图.读取活动概念签名(新概念).has_value()
            && 概念图.读取概念生命周期(新概念).has_value()
            && !概念图.读取活动概念定义材料(新概念).empty()
            && !概念图.读取活动支持概念的实例(新概念).empty();

        std::atomic_size_t 幂等次数{0};
        std::atomic_size_t 发布次数{0};
        std::atomic_bool 读取异常{false};
        std::thread 幂等线程([&]() {
            for (std::size_t 次数 = 0; 次数 < 50; ++次数) {
                const auto 结果 = 编排器.提交安全删除(待提交.value());
                if (结果.幂等完成 && 结果.已完成()) ++幂等次数;
            }
        });
        std::thread 发布线程([&]() {
            for (std::size_t 次数 = 0; 次数 < 50; ++次数) {
                const auto 结果 = 概念图.发布候选图版本并返回结果(
                    重建候选, 存在, 动态, 二次特征, 因果);
                if (结果.正常成功() || 结果.逻辑内返回()) ++发布次数;
            }
        });
        std::thread 读取线程([&]() {
            for (std::size_t 次数 = 0; 次数 < 50; ++次数) {
                auto 当前 = 概念图.读取实例支持概念(来源实例);
                当前.erase(std::remove(
                    当前.begin(), 当前.end(), 初始化结果.存在根.根节点), 当前.end());
                if (当前.size() != 1 || 当前.front() != 新概念) 读取异常.store(true);
            }
        });
        幂等线程.join();
        发布线程.join();
        读取线程.join();
        const auto 活动节点组 = 概念图.读取活动概念节点组();
        const auto 活动关系组 = 概念图.读取活动关系组();
        验收[10] = 幂等次数 == 50 && 发布次数 == 50 && !读取异常.load()
            && std::count(活动节点组.begin(), 活动节点组.end(), 新概念) == 1
            && std::none_of(活动关系组.begin(), 活动关系组.end(), [&旧概念](const auto& 关系材料) {
                return 关系材料.源节点 == 旧概念 || 关系材料.目标节点 == 旧概念;
            });
        验收[11] = 接线.已接域() && 待提交.has_value()
            && 概念图.读取活动概念根组().size() == 4
            && 编排器.复核删除审计(删除回执).完整();
    } catch (...) {
    }

    std::size_t 失败数量 = 0;
    for (std::size_t 索引 = 0; 索引 < 验收.size(); ++索引) {
        if (!验收[索引]) ++失败数量;
        std::cout << "CONCEPT-S8-S4-A";
        if (索引 + 1 < 10) std::cout << '0';
        std::cout << 索引 + 1 << ": " << (验收[索引] ? "通过" : "失败") << std::endl;
    }
    return {"CONCEPT-S8-S4", "概念删除后验", 失败数量 == 0, 验收.size(), 失败数量};
}

}
