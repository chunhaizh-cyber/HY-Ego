// 文件规则：动态观察组合器只编排完整回执和显式片段请求；不得接入线程路由或持有结构能力。
module;

#include "../核心/句柄.h"

#include <cstddef>
#include <cstdint>
#include <optional>

export module 海中鱼巣.领域.组合.动态观察;

import 海中鱼巣.领域.材料.动态模式;
import 海中鱼巣.领域.算法.动态模式;
import 海中鱼巣.领域.服务.动态模式;
import 海中鱼巣.线程.任务结果回执协议;

export namespace 海中鱼巣 {

class 动态观察组合器 final {
public:
    explicit 动态观察组合器(动态模式业务服务& 服务)
        : 服务_(服务) {
    }

    动态模式窗口结果 形成规范窗口(const 动态模式观察请求& 请求) const {
        const auto 前置 = 复核前置(请求);
        if (前置 != 动态模式拒绝原因::无) {
            return {前置 == 动态模式拒绝原因::规则版本不支持
                    ? 动态模式处理状态::不支持 : 动态模式处理状态::入口拒绝,
                前置,
                {}};
        }
        return 服务_.形成规范窗口(请求);
    }

private:
    static 动态模式拒绝原因 复核前置(const 动态模式观察请求& 请求) {
        if (!请求.数量有效()) return 动态模式拒绝原因::请求不完整;
        for (std::size_t 索引 = 0; 索引 < 请求.片段组.size(); ++索引) {
            const auto& 片段 = 请求.片段组[索引];
            if (片段.片段序号 == 0 || 片段.规则版本 == 0) {
                return 动态模式拒绝原因::请求不完整;
            }
            if (片段.规则版本 != 动态模式规则版本) {
                return 动态模式拒绝原因::规则版本不支持;
            }
            if (片段.回执.材料性质 != 任务结果回执材料性质::非权威任务执行结果证据
                || !片段.回执.来源执行请求.has_value()) {
                return 动态模式拒绝原因::协议不一致;
            }
            const auto 协议 = 复核任务结果回执材料(
                片段.回执, {请求.当前时间戳, std::nullopt, {}, 0});
            if (协议.状态 != 任务结果回执准入状态::可准入) {
                return 动态模式拒绝原因::协议不一致;
            }
            const 动态模式回合身份 当前回合{片段.回执};
            for (std::size_t 已有 = 0; 已有 < 索引; ++已有) {
                const auto& 前片段 = 请求.片段组[已有];
                const 动态模式回合身份 前回合{前片段.回执};
                if (动态模式回合锚点相同(前回合, 当前回合)) {
                    if (!动态模式回合身份相同(前回合, 当前回合)) {
                        return 动态模式拒绝原因::回合材料矛盾;
                    }
                    if (前片段.片段序号 == 片段.片段序号) {
                        return 动态模式拒绝原因::片段序号重复;
                    }
                }
                if (前片段.回执.句柄组.动态证据 == 片段.回执.句柄组.动态证据) {
                    return 动态模式拒绝原因::动态证据重复;
                }
            }
        }
        return 动态模式拒绝原因::无;
    }

    动态模式业务服务& 服务_;
};

}
