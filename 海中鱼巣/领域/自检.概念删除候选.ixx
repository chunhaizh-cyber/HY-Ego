// 文件规则：概念领域自检只承载验收场景，不得成为生产依赖或业务事实来源。
module;

#include "../核心/节点仓库.h"
#include "../核心/关系仓库.h"
#include "../核心/索引仓库.h"
#include "概念图服务.h"
#include "统计服务.h"

#include <atomic>
#include <cstddef>
#include <limits>
#include <numeric>
#include <optional>
#include <thread>
#include <vector>

export module 海中鱼巣.领域.自检.概念删除候选;

import 海中鱼巣.领域.自检.概念生命周期;

export namespace 海中鱼巣 {

struct 概念删除候选自检上下文 {
    概念图服务& 概念图;
    统计服务& 统计;
    节点仓库& 节点;
    关系仓库& 关系;
    索引仓库& 索引;
    const 概念生命周期自检报告& 生命周期报告;
    节点句柄 存在根;
    节点句柄 自我存在;
    bool 第四切片通过 = false;
    bool 第五切片通过 = false;
};

struct 概念删除候选自检报告 {
    bool 总通过 = false;
    std::size_t 失败数量 = 10;
    bool 完整 = false;
};

概念删除候选自检报告 运行概念删除候选自检(const 概念删除候选自检上下文& 上下文) {
    struct 结构数量快照 { std::uint64_t 节点数=0,关系数=0,索引数=0; };const auto 读取结构数量=[&]{return 结构数量快照{上下文.节点.有效节点数量(),上下文.关系.有效关系数量(),上下文.索引.有效主键数量()};};const auto 结构数量相同=[](const auto& 左,const auto& 右){return 左.节点数==右.节点数&&左.关系数==右.关系数&&左.索引数==右.索引数;};auto& 概念图=上下文.概念图;auto& 统计=上下文.统计;auto& 节点=上下文.节点;auto& 关系=上下文.关系;auto& 索引=上下文.索引;
    const auto 概念第八切片目标概念 = 上下文.生命周期报告.目标概念;
    const auto 概念第八切片初始活动版本 = 概念图.读取活动图版本();
    const auto 概念第八切片活跃拒绝 = 概念图.读取概念删除影响候选({
        概念第八切片目标概念,
        概念第八切片初始活动版本,
        128,
        std::numeric_limits<std::size_t>::max()});
    const auto 概念第八切片根拒绝 = 概念图.读取概念删除影响候选({
        上下文.存在根,
        概念第八切片初始活动版本,
        128,
        std::numeric_limits<std::size_t>::max()});
    const auto 概念第八切片非活动拒绝 = 概念图.读取概念删除影响候选({
        上下文.自我存在,
        概念第八切片初始活动版本,
        128,
        std::numeric_limits<std::size_t>::max()});
    const auto 概念第八切片版本漂移拒绝 = 概念图.读取概念删除影响候选({
        概念第八切片目标概念,
        概念第八切片初始活动版本 - 1,
        128,
        std::numeric_limits<std::size_t>::max()});
    const auto 概念第八切片无效请求拒绝 =
        概念图.读取概念删除影响候选({});

    const auto 概念第八切片准备前支持组 = 读取概念目标支持关系组(概念图, 概念第八切片目标概念);
    bool 概念第八切片支持全部失效 = !概念第八切片准备前支持组.empty();
    for (const auto& 支持 : 概念第八切片准备前支持组) {
        const auto 结果 = 概念图.失效活动普通概念实例支持({
            支持.源节点,
            支持.目标节点,
            支持.关系,
            概念图.读取活动图版本()});
        概念第八切片支持全部失效 = 概念第八切片支持全部失效
            && 结果.状态 == 海中鱼巣::实例支持失效状态::已失效
            && 结果.完整();
    }
    const auto 概念第八切片零支持版本 = 概念图.读取活动图版本();
    const auto 概念第八切片命名空间 = 统计.定义缓存命名空间(
        海中鱼巣::缓存类型::概念用途观察,
        海中鱼巣::来源结构类型::概念,
        概念第八切片零支持版本,
        8,
        海中鱼巣::缓存值类型::用途观察,
        false,
        海中鱼巣::缓存失效条件::规则版本变化);
    const 海中鱼巣::概念生命周期复核规则 概念第八切片复核规则{
        8, 9000, 8000, 7000
    };
    const auto 概念第八切片历史观察 = 概念图.记录活动概念用途观察(
        概念第八切片命名空间,
        概念第八切片目标概念,
        海中鱼巣::概念用途类型::一般,
        6000,
        0,
        统计);
    const auto 概念第八切片冷却候选 = 概念图.读取生命周期复核候选(
        概念第八切片目标概念,
        概念第八切片命名空间,
        概念第八切片复核规则,
        统计);
    const auto 概念第八切片转冷却 = 概念第八切片冷却候选.has_value()
        ? 概念图.转换概念生命周期(
            概念第八切片目标概念,
            海中鱼巣::概念生命周期阶段::冷却,
            概念第八切片冷却候选.value(),
            概念第八切片复核规则,
            统计)
        : std::optional<海中鱼巣::概念生命周期转换材料>{};
    const auto 概念第八切片冷却拒绝 = 概念图.读取概念删除影响候选({
        概念第八切片目标概念,
        概念第八切片零支持版本,
        128,
        std::numeric_limits<std::size_t>::max()});
    const auto 概念第八切片退役候选 = 概念图.读取生命周期复核候选(
        概念第八切片目标概念,
        概念第八切片命名空间,
        概念第八切片复核规则,
        统计);
    const auto 概念第八切片转退役 = 概念第八切片退役候选.has_value()
        ? 概念图.转换概念生命周期(
            概念第八切片目标概念,
            海中鱼巣::概念生命周期阶段::退役,
            概念第八切片退役候选.value(),
            概念第八切片复核规则,
            统计)
        : std::optional<海中鱼巣::概念生命周期转换材料>{};
    const auto 概念第八切片退役生命周期 =
        概念图.读取概念生命周期(概念第八切片目标概念);

    const auto 概念第八切片读取前结构数量 = 读取结构数量();
    const auto 概念第八切片读取前活动版本 = 概念图.读取活动图版本();
    const auto 概念第八切片读取前生命周期 =
        概念图.读取概念生命周期(概念第八切片目标概念);
    const auto 概念第八切片读取前缓存 = 统计.读取概念用途观察(
        概念第八切片命名空间,
        概念第八切片目标概念,
        海中鱼巣::概念用途类型::一般);
    const auto 概念第八切片成功结果 = 概念图.读取概念删除影响候选({
        概念第八切片目标概念,
        概念第八切片读取前活动版本,
        128,
        std::numeric_limits<std::size_t>::max()});
    const auto 概念第八切片候选预算不足 = 概念图.读取概念删除影响候选({
        概念第八切片目标概念,
        概念第八切片读取前活动版本,
        1,
        std::numeric_limits<std::size_t>::max()});
    const auto 概念第八切片直接边预算不足 = 概念图.读取概念删除影响候选({
        概念第八切片目标概念,
        概念第八切片读取前活动版本,
        128,
        1});

    const auto* 概念第八切片候选 = 概念第八切片成功结果.候选.has_value()
        ? &概念第八切片成功结果.候选.value()
        : nullptr;
    std::vector<海中鱼巣::概念签名编号材料> 概念第八切片编号签名组;
    if (概念第八切片候选 != nullptr) {
        概念第八切片编号签名组.reserve(概念第八切片候选->完整剩余签名组.size());
        for (std::size_t 索引 = 0; 索引 < 概念第八切片候选->完整剩余签名组.size(); ++索引) {
            概念第八切片编号签名组.push_back({
                static_cast<std::uint64_t>(索引 + 1),
                概念第八切片候选->完整剩余签名组[索引].签名});
        }
    }
    const auto 概念第八切片共享算法结果 = 海中鱼巣::概念图算法::重算完整签名直接边(
        概念第八切片编号签名组,
        std::numeric_limits<std::size_t>::max());
    bool 概念第八切片共享边完全一致 = 概念第八切片候选 != nullptr
        && 概念第八切片共享算法结果.已完成()
        && 概念第八切片共享算法结果.直接边组.size()
            == 概念第八切片候选->删除后直接边组.size();
    if (概念第八切片共享边完全一致) {
        for (std::size_t 索引 = 0;
             索引 < 概念第八切片共享算法结果.直接边组.size();
             ++索引) {
            const auto& 编号边 = 概念第八切片共享算法结果.直接边组[索引];
            const auto& 句柄边 = 概念第八切片候选->删除后直接边组[索引];
            概念第八切片共享边完全一致 = 概念第八切片共享边完全一致
                && 编号边.上位候选编号 != 0
                && 编号边.下位候选编号 != 0
                && 编号边.上位候选编号 <= 概念第八切片候选->完整剩余签名组.size()
                && 编号边.下位候选编号 <= 概念第八切片候选->完整剩余签名组.size()
                && 句柄边.上位概念 == 概念第八切片候选->完整剩余签名组[
                    static_cast<std::size_t>(编号边.上位候选编号 - 1)].概念
                && 句柄边.下位概念 == 概念第八切片候选->完整剩余签名组[
                    static_cast<std::size_t>(编号边.下位候选编号 - 1)].概念;
        }
    }

    bool 概念第八切片矛盾材料已拒绝 = false;
    if (概念第八切片候选 != nullptr
        && 概念第八切片候选->完整当前输入.签名组.size() > 1) {
        auto 矛盾输入 = 概念第八切片候选->完整当前输入;
        矛盾输入.签名组[1].签名 = 矛盾输入.签名组[0].签名;
        概念第八切片矛盾材料已拒绝 = !矛盾输入.完整();
    }
    const 海中鱼巣::概念删除影响候选读取结果 概念第八切片内部错误分类{
        海中鱼巣::概念删除候选读取状态::内部不一致,
        std::nullopt,
        std::nullopt};

    constexpr std::size_t 概念第八切片并发线程数 = 4;
    constexpr std::size_t 概念第八切片每线程读取数 = 10;
    std::atomic_uint64_t 概念第八切片并发成功数{0};
    std::vector<std::thread> 概念第八切片并发线程组;
    概念第八切片并发线程组.reserve(概念第八切片并发线程数);
    for (std::size_t 线程索引 = 0; 线程索引 < 概念第八切片并发线程数; ++线程索引) {
        概念第八切片并发线程组.emplace_back([&]() {
            for (std::size_t 读取索引 = 0; 读取索引 < 概念第八切片每线程读取数; ++读取索引) {
                if (概念图.读取概念删除影响候选({
                        概念第八切片目标概念,
                        概念第八切片读取前活动版本,
                        128,
                        std::numeric_limits<std::size_t>::max()}).正常成功()) {
                    ++概念第八切片并发成功数;
                }
            }
        });
    }
    for (auto& 线程 : 概念第八切片并发线程组) {
        线程.join();
    }

    const auto 概念第八切片读取后结构数量 = 读取结构数量();
    const auto 概念第八切片读取后活动版本 = 概念图.读取活动图版本();
    const auto 概念第八切片读取后生命周期 =
        概念图.读取概念生命周期(概念第八切片目标概念);
    const auto 概念第八切片读取后缓存 = 统计.读取概念用途观察(
        概念第八切片命名空间,
        概念第八切片目标概念,
        海中鱼巣::概念用途类型::一般);
    const auto 概念第八切片活动根组 = 概念图.读取活动概念根组();
    const auto 概念第八切片活动节点组 = 概念图.读取活动概念节点组();
    const auto 概念第八切片活动关系组 = 概念图.读取活动关系组();
    const auto 概念第八切片当前相关关系组 =
        关系.获取节点相关关系记录组(概念第八切片目标概念);
    const auto 概念第八切片当前节点 = 节点.读取节点(概念第八切片目标概念);

    const bool 概念第八切片A01入口拒绝 =
        概念第八切片活跃拒绝.状态 == 海中鱼巣::概念删除候选读取状态::目标不允许
        && 概念第八切片根拒绝.状态 == 海中鱼巣::概念删除候选读取状态::目标不允许
        && 概念第八切片非活动拒绝.状态 == 海中鱼巣::概念删除候选读取状态::目标不允许
        && 概念第八切片版本漂移拒绝.状态
            == 海中鱼巣::概念删除候选读取状态::活动版本已变化
        && 概念第八切片无效请求拒绝.状态 == 海中鱼巣::概念删除候选读取状态::请求拒绝
        && 概念第八切片冷却拒绝.状态 == 海中鱼巣::概念删除候选读取状态::目标不允许
        && 概念第八切片活跃拒绝.逻辑内返回()
        && 概念第八切片冷却拒绝.逻辑内返回();
    const bool 概念第八切片A03目标材料完整 = 概念第八切片候选 != nullptr
        && 概念第八切片当前节点.has_value()
        && 概念第八切片读取前生命周期.has_value()
        && 概念第八切片候选->目标节点记录.节点编号 == 概念第八切片当前节点->节点编号
        && 概念第八切片候选->目标节点记录.版本号 == 概念第八切片当前节点->版本号
        && 概念第八切片候选->目标主信息 == 概念第八切片当前节点->主信息
        && 概念第八切片候选->目标生命周期.关系
            == 概念第八切片读取前生命周期->关系
        && 概念第八切片候选->当前相关有效关系组.size()
            == 概念第八切片当前相关关系组.size();
    const bool 概念第八切片A04完整当前输入 = 概念第八切片候选 != nullptr
        && 概念第八切片候选->完整当前输入.完整()
        && 概念第八切片候选->完整当前输入.活动版本 == 概念第八切片读取前活动版本
        && 概念第八切片候选->完整当前输入.根组 == 概念第八切片活动根组
        && 概念第八切片候选->完整当前输入.签名组.size()
            == 概念第八切片活动节点组.size()
        && 概念第八切片候选->完整当前输入.概念内部关系组.size()
            == 概念第八切片活动关系组.size();
    const bool 概念第八切片A05共享全量重算 =
        概念第八切片共享边完全一致
        && 上下文.第四切片通过
        && 上下文.第五切片通过;
    const auto 概念第八切片根可达总数 = 概念第八切片候选 == nullptr
        ? std::size_t{0}
        : static_cast<std::size_t>(std::accumulate(
            概念第八切片候选->删除后根可达摘要组.begin(),
            概念第八切片候选->删除后根可达摘要组.end(),
            std::size_t{0},
            [](std::size_t 当前, const auto& 摘要) { return 当前 + 摘要.可达概念数量; }));
    const bool 概念第八切片A06无环根可达 = 概念第八切片成功结果.正常成功()
        && 概念第八切片候选 != nullptr
        && 概念第八切片根可达总数 == 概念第八切片候选->完整剩余签名组.size()
        && std::none_of(
            概念第八切片候选->删除后直接边组.begin(),
            概念第八切片候选->删除后直接边组.end(),
            [&](const auto& 边) {
                return 边.上位概念 == 概念第八切片目标概念
                    || 边.下位概念 == 概念第八切片目标概念;
            });
    const bool 概念第八切片A07预算待重算 =
        概念第八切片候选预算不足.状态 == 海中鱼巣::概念删除候选读取状态::待重算
        && 概念第八切片候选预算不足.待重算材料.has_value()
        && 概念第八切片候选预算不足.待重算材料->完整()
        && 概念第八切片候选预算不足.待重算材料->原因
            == 海中鱼巣::概念删除待重算原因::候选数量预算不足
        && 概念第八切片直接边预算不足.状态 == 海中鱼巣::概念删除候选读取状态::待重算
        && 概念第八切片直接边预算不足.待重算材料.has_value()
        && 概念第八切片直接边预算不足.待重算材料->完整()
        && 概念第八切片直接边预算不足.待重算材料->原因
            == 海中鱼巣::概念删除待重算原因::直接边计算预算不足;
    const bool 概念第八切片A08矛盾追根因 = 概念第八切片矛盾材料已拒绝
        && 概念第八切片内部错误分类.状态
            == 海中鱼巣::概念删除候选读取状态::内部不一致
        && !概念第八切片内部错误分类.逻辑内返回();
    const std::vector<海中鱼巣::概念删除待补全结构所有者> 概念第八切片预期所有者组{
        海中鱼巣::概念删除待补全结构所有者::索引反查,
        海中鱼巣::概念删除待补全结构所有者::存在服务,
        海中鱼巣::概念删除待补全结构所有者::概念图登记,
        海中鱼巣::概念删除待补全结构所有者::统计缓存
    };
    const bool 概念第八切片A09不可提交 = 概念第八切片候选 != nullptr
        && 概念第八切片候选->完备阶段 == 海中鱼巣::删除候选完备阶段::领域影响已形成
        && 概念第八切片候选->待补全结构所有者组 == 概念第八切片预期所有者组
        && !概念第八切片候选->可提交();
    const bool 概念第八切片缓存相同 =
        概念第八切片读取前缓存.has_value()
        && 概念第八切片读取后缓存.has_value()
        && 概念第八切片读取前缓存->观察次数候选
            == 概念第八切片读取后缓存->观察次数候选
        && 概念第八切片读取前缓存->最近观察时间戳
            == 概念第八切片读取后缓存->最近观察时间戳
        && 概念第八切片读取前缓存->累计结果效用候选
            == 概念第八切片读取后缓存->累计结果效用候选;
    const bool 概念第八切片A10只读与并发 =
        结构数量相同(概念第八切片读取前结构数量, 概念第八切片读取后结构数量)
        && 概念第八切片读取前活动版本 == 概念第八切片读取后活动版本
        && 概念第八切片读取前生命周期.has_value()
        && 概念第八切片读取后生命周期.has_value()
        && 概念第八切片读取前生命周期->关系 == 概念第八切片读取后生命周期->关系
        && 概念第八切片缓存相同
        && 概念第八切片并发成功数.load()
            == 概念第八切片并发线程数 * 概念第八切片每线程读取数;
    const bool 概念第八切片缓存已清空 = 统计.清空概念用途观察(概念第八切片命名空间);

    const bool 概念第八切片新增支持 = 上下文.生命周期报告.支持实例.has_value()
        && 概念图.绑定实例支持概念(
            上下文.生命周期报告.支持实例.value(),
            概念第八切片目标概念);
    const auto 概念第八切片支持阻止结果 = 概念图.读取概念删除影响候选({
        概念第八切片目标概念,
        概念第八切片读取后活动版本,
        128,
        std::numeric_limits<std::size_t>::max()});
    const bool 概念第八切片A02当前关系阻止 = 概念第八切片新增支持
        && 概念第八切片支持阻止结果.状态
            == 海中鱼巣::概念删除候选读取状态::当前关系阻止
        && 概念第八切片支持阻止结果.逻辑内返回()
        && !概念第八切片支持阻止结果.候选.has_value();
    const bool 概念第八切片准备完成 =
        概念第八切片支持全部失效
        && 概念第八切片历史观察.has_value()
        && 概念第八切片冷却候选.has_value()
        && 概念第八切片冷却候选->建议 == 海中鱼巣::概念生命周期复核建议::建议冷却
        && 概念第八切片转冷却.has_value()
        && 概念第八切片退役候选.has_value()
        && 概念第八切片退役候选->建议 == 海中鱼巣::概念生命周期复核建议::建议退役复核
        && 概念第八切片转退役.has_value()
        && 概念第八切片退役生命周期.has_value()
        && 概念第八切片退役生命周期->阶段 == 海中鱼巣::概念生命周期阶段::退役;
    const bool 概念第八切片通过 =
        概念第八切片准备完成
        && 概念第八切片A01入口拒绝
        && 概念第八切片A02当前关系阻止
        && 概念第八切片A03目标材料完整
        && 概念第八切片A04完整当前输入
        && 概念第八切片A05共享全量重算
        && 概念第八切片A06无环根可达
        && 概念第八切片A07预算待重算
        && 概念第八切片A08矛盾追根因
        && 概念第八切片A09不可提交
        && 概念第八切片A10只读与并发
        && 概念第八切片缓存已清空;
    概念删除候选自检报告 报告;报告.总通过=概念第八切片通过;报告.完整=true;报告.失败数量=报告.总通过 ? 0 : 10;return 报告;
}

}
