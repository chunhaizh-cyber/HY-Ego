// 文件规则：语素业务服务只裁决文本、目标白名单和关系角色，不接触仓库或事务能力。
module;

#include "../核心/句柄.h"

#include <cstdint>
#include <cwctype>
#include <optional>
#include <string>

export module 海中鱼巣.领域.服务.语素;

import 海中鱼巣.领域.数据操作.语素基础;

export namespace 海中鱼巣 {

struct 创建语素入口请求 {
    std::uint64_t 幂等主键 = 0;
    节点句柄 对应信息;
};

struct 创建语素概念入口请求 {
    std::uint64_t 幂等主键 = 0;
    std::wstring 文本;
    节点句柄 对应信息;
    节点句柄 概念追溯;
};

struct 追加语素关系请求 {
    节点句柄 语素入口;
    节点句柄 目标;
    语素关系角色 关系角色 = 语素关系角色::未定义;
};

enum class 语素文本准入状态 : std::uint8_t {
    可作为最小词单元 = 1,
    空文本 = 2,
    含空白 = 3,
    含组合分隔符 = 4,
    超出第一轮长度 = 5
};

enum class 语素规格状态 : std::uint8_t {
    已形成 = 1,
    入口拒绝 = 2,
    许可拒绝 = 3,
    版本漂移 = 4,
    内部不一致 = 5
};

struct 语素入口规格结果 {
    语素规格状态 状态 = 语素规格状态::入口拒绝;
    std::optional<语素入口写入规格> 规格;

    bool 成功() const noexcept {
        return 状态 == 语素规格状态::已形成 && 规格.has_value() && 规格->完整();
    }
};

class 语素业务服务 final {
public:
    explicit 语素业务服务(语素基础数据操作& 数据操作) : 数据操作_(数据操作) {}

    语素文本准入状态 判断文本是否可作为最小词单元(const std::wstring& 文本) const noexcept {
        if (文本.empty()) return 语素文本准入状态::空文本;
        std::uint64_t 有效字符数 = 0;
        for (const wchar_t 字符 : 文本) {
            if (std::iswspace(字符) != 0) return 语素文本准入状态::含空白;
            if (字符是组合分隔符(字符)) return 语素文本准入状态::含组合分隔符;
            ++有效字符数;
        }
        return 有效字符数 <= 3
            ? 语素文本准入状态::可作为最小词单元
            : 语素文本准入状态::超出第一轮长度;
    }

    语素入口规格结果 形成语素入口规格(const 创建语素入口请求& 请求) const {
        if (请求.幂等主键 == 0 || !句柄有效(请求.对应信息)) return {};
        const auto 对应身份 = 数据操作_.读取节点身份(请求.对应信息);
        if (!对应身份.当前可读()) return {映射读取失败(对应身份.状态)};
        if (!允许对应信息角色(对应身份.角色)) return {};
        const auto 规格 = 数据操作_.形成语素入口写入规格(
            请求.幂等主键, 请求.对应信息, 对应身份.角色,
            std::nullopt, 语义节点角色::未定义);
        if (!规格.has_value()) return {语素规格状态::内部不一致};
        语素入口规格结果 输出;
        输出.状态 = 语素规格状态::已形成;
        输出.规格 = *规格;
        return 输出;
    }

    语素入口规格结果 形成语素概念入口规格(
        const 创建语素概念入口请求& 请求) const {
        if (请求.幂等主键 == 0 || !句柄有效(请求.对应信息)
            || !句柄有效(请求.概念追溯)
            || 判断文本是否可作为最小词单元(请求.文本)
                != 语素文本准入状态::可作为最小词单元) return {};
        const auto 对应身份 = 数据操作_.读取节点身份(请求.对应信息);
        const auto 追溯身份 = 数据操作_.读取节点身份(请求.概念追溯);
        if (!对应身份.当前可读() || !追溯身份.当前可读()) {
            return {合并读取失败(对应身份.状态, 追溯身份.状态)};
        }
        if (!允许对应信息角色(对应身份.角色)
            || !允许概念追溯角色(追溯身份.角色)) return {};
        const auto 规格 = 数据操作_.形成语素入口写入规格(
            请求.幂等主键, 请求.对应信息, 对应身份.角色,
            请求.概念追溯, 追溯身份.角色);
        if (!规格.has_value()) return {语素规格状态::内部不一致};
        语素入口规格结果 输出;
        输出.状态 = 语素规格状态::已形成;
        输出.规格 = *规格;
        return 输出;
    }

    语义基础业务结果 创建语素入口(const 创建语素入口请求& 请求) const {
        const auto 规格 = 形成语素入口规格(请求);
        return 规格.成功() ? 数据操作_.创建语素入口(*规格.规格) : 映射规格失败(规格.状态);
    }

    语义基础业务结果 追加语素关系(const 追加语素关系请求& 请求) const {
        if (!句柄有效(请求.语素入口) || !句柄有效(请求.目标)
            || (请求.关系角色 != 语素关系角色::对应信息
                && 请求.关系角色 != 语素关系角色::概念追溯)) return {};
        const auto 目标身份 = 数据操作_.读取节点身份(请求.目标);
        if (!目标身份.当前可读()) return 映射读取失败为业务结果(目标身份.状态);
        const bool 允许 = 请求.关系角色 == 语素关系角色::对应信息
            ? 允许对应信息角色(目标身份.角色)
            : 允许概念追溯角色(目标身份.角色);
        if (!允许) return {};
        return 数据操作_.追加语素关系(
            请求.语素入口, 请求.目标, 请求.关系角色, 目标身份.角色);
    }

    语素入口值式材料 读取语素入口(节点句柄 语素入口) const {
        return 句柄有效(语素入口) ? 数据操作_.读取语素入口(语素入口) : 语素入口值式材料{};
    }

    语素入口值式材料 读取主键语素入口(std::uint64_t 主键) const {
        return 主键 != 0 ? 数据操作_.读取主键语素入口(主键) : 语素入口值式材料{};
    }

    概念名称入口组读取结果 读取概念名称入口组(节点句柄 概念) const {
        return 句柄有效(概念)
            ? 数据操作_.读取概念名称入口组(概念)
            : 概念名称入口组读取结果{};
    }

    static 语义基础业务结果 映射规格失败(语素规格状态 状态) noexcept {
        switch (状态) {
        case 语素规格状态::许可拒绝: return {语义基础业务状态::许可拒绝};
        case 语素规格状态::版本漂移: return {语义基础业务状态::版本漂移};
        case 语素规格状态::内部不一致: return {语义基础业务状态::内部不一致};
        default: return {语义基础业务状态::入口拒绝};
        }
    }

private:
    static bool 字符是组合分隔符(wchar_t 字符) noexcept {
        return 字符 == L'/' || 字符 == L'\\' || 字符 == L'-' || 字符 == L'_'
            || 字符 == L'+' || 字符 == L',' || 字符 == L'.' || 字符 == L';'
            || 字符 == L':' || 字符 == L'，' || 字符 == L'。' || 字符 == L'；'
            || 字符 == L'：' || 字符 == L'、';
    }

    static bool 允许对应信息角色(语义节点角色 角色) noexcept {
        return 角色 == 语义节点角色::基础信息 || 角色 == 语义节点角色::存在
            || 角色 == 语义节点角色::场景 || 角色 == 语义节点角色::特征
            || 角色 == 语义节点角色::抽象状态 || 角色 == 语义节点角色::抽象动态
            || 角色 == 语义节点角色::二次特征 || 角色 == 语义节点角色::因果引用
            || 角色 == 语义节点角色::需求 || 角色 == 语义节点角色::任务
            || 角色 == 语义节点角色::方法;
    }

    static bool 允许概念追溯角色(语义节点角色 角色) noexcept {
        return 角色 == 语义节点角色::基础信息 || 角色 == 语义节点角色::存在
            || 角色 == 语义节点角色::特征 || 角色 == 语义节点角色::抽象状态
            || 角色 == 语义节点角色::抽象动态 || 角色 == 语义节点角色::二次特征
            || 角色 == 语义节点角色::因果引用;
    }

    static 语素规格状态 映射读取失败(语义基础读取状态 状态) noexcept {
        switch (状态) {
        case 语义基础读取状态::许可拒绝: return 语素规格状态::许可拒绝;
        case 语义基础读取状态::版本漂移: return 语素规格状态::版本漂移;
        case 语义基础读取状态::内部不一致: return 语素规格状态::内部不一致;
        default: return 语素规格状态::入口拒绝;
        }
    }

    static 语素规格状态 合并读取失败(
        语义基础读取状态 左,
        语义基础读取状态 右) noexcept {
        if (左 == 语义基础读取状态::内部不一致 || 右 == 语义基础读取状态::内部不一致) {
            return 语素规格状态::内部不一致;
        }
        if (左 == 语义基础读取状态::许可拒绝 || 右 == 语义基础读取状态::许可拒绝) {
            return 语素规格状态::许可拒绝;
        }
        if (左 == 语义基础读取状态::版本漂移 || 右 == 语义基础读取状态::版本漂移) {
            return 语素规格状态::版本漂移;
        }
        return 语素规格状态::入口拒绝;
    }

    static 语义基础业务结果 映射读取失败为业务结果(语义基础读取状态 状态) noexcept {
        return 映射规格失败(映射读取失败(状态));
    }

    语素基础数据操作& 数据操作_;
};

}
