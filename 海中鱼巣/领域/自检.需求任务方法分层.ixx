            错主体写前拒绝 = 错主体写入规格.has_value()
                && 高级数据操作.提交需求结算(*错主体写入规格).状态
                    == 需求任务方法业务状态::入口拒绝;
        }
        验收[26] = 主正式结算.has_value() && 主正式结算->完整()
            && 主正式结算->需求 == 主需求 && 主正式结算->来源任务 == 主任务
            && 主正式结算->实际状态 == 实际状态
            && 主正式结算->动态证据 == 动态证据
            && 主正式结算->因果引用 == std::optional<节点句柄>{因果引用}
            && 未满足规格拒绝 && 混合值规格拒绝
            && 错场景写前拒绝 && 错主体写前拒绝
            && 读取数量() == 规格门禁前;
        }();

        [&] {
        const auto 不相等需求 = 创建测试需求(20);
        const auto 不相等夹具 = 不相等需求.成功()
