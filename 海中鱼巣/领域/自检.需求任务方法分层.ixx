            const auto 状态读回 = 状态服务.读取主键状态材料(故障需求请求.目标状态幂等主键);
            新建故障全部撤销 = 新建故障全部撤销 && 结果.故障已命中
                && !需求读回.完整目标状态需求() && !状态读回.当前可读()
                && 读取数量() == 故障需求前;
        }
        验收[19] = 新建故障全部撤销;

        const auto 建立故障任务 = [&](std::uint64_t 任务键, std::uint64_t 虚拟键,
                                     std::uint64_t 状态键, std::uint64_t 时间) {
            return 任务服务.创建承接任务({
                任务键, 虚拟键, 状态键, 主需求, 时间});
        };
        const auto 关系故障探针任务 = 建立故障任务(
            新主键(), 新主键(), 新主键(), 新时间());
        const 迁移任务生命周期请求 关系故障探针请求{
            关系故障探针任务.材料.身份.节点,
            分层任务生命周期阶段::已承接, 新主键(), 新时间()};
        const auto 关系故障探针 = 任务服务.执行生命周期固定故障自检(
            关系故障探针请求, 0);
        const auto 关系故障任务 = 建立故障任务(
            新主键(), 新主键(), 新主键(), 新时间());
        const 迁移任务生命周期请求 关系故障请求{
            关系故障任务.材料.身份.节点,
            分层任务生命周期阶段::已承接, 新主键(), 新时间()};
        const auto 关系故障写前任务 = 任务服务.读取任务(关系故障请求.任务);
        const auto 关系故障写前记录 = 关系.读取关系审计(
            关系故障写前任务.当前生命周期.关系.关系);
        const auto 关系故障前数量 = 读取数量();
        bool 关系故障全部恢复 = 关系故障探针.状态 == 需求任务方法业务状态::已提交
            && 关系故障探针.已执行写点 > 0;
        for (std::size_t 写点 = 1; 写点 <= 关系故障探针.已执行写点; ++写点) {
            const auto 结果 = 任务服务.执行生命周期固定故障自检(关系故障请求, 写点);
            const auto 当前 = 任务服务.读取任务(关系故障请求.任务);
            const auto 旧关系 = 关系.读取关系审计(
                关系故障写前任务.当前生命周期.关系.关系);
            const auto 新状态 = 状态服务.读取主键状态材料(关系故障请求.幂等材料编号);
            关系故障全部恢复 = 关系故障全部恢复 && 结果.故障已命中
                && 当前.当前生命周期.关系.关系
                    == 关系故障写前任务.当前生命周期.关系.关系
                && 当前.当前生命周期.阶段 == 分层任务生命周期阶段::已创建
                && 旧关系.has_value() && 关系故障写前记录.has_value()
                && 旧关系->状态 == 记录状态::有效
                && 旧关系->版本号 == 关系故障写前记录->版本号
                && !新状态.当前可读() && 读取数量() == 关系故障前数量;
        }
        const auto 关系故障最终提交 = 任务服务.迁移生命周期(关系故障请求);
        验收[20] = 关系故障全部恢复 && 关系故障最终提交.成功();

        const 创建完整目标状态需求请求 并发需求请求{
            新主键(), 新主键(), 主体, 主体, 场景, 特征定义,
            特征当前值.特征值节点, 50};
        constexpr std::size_t 并发数量 = 8;
        std::array<需求任务方法业务状态, 并发数量> 并发状态{};
        std::vector<std::thread> 并发线程组;
        并发线程组.reserve(并发数量);
        for (std::size_t 索引号 = 0; 索引号 < 并发数量; ++索引号) {
            并发线程组.emplace_back([&, 索引号] {
                并发状态[索引号] = 需求服务.创建完整目标状态需求(并发需求请求).状态;
            });
        }
        for (auto& 线程 : 并发线程组) 线程.join();
        const auto 并发提交数量 = std::count(
            并发状态.begin(), 并发状态.end(), 需求任务方法业务状态::已提交);
        const auto 并发幂等数量 = std::count(
            并发状态.begin(), 并发状态.end(), 需求任务方法业务状态::幂等读回);
        auto 并发冲突请求 = 并发需求请求;
        并发冲突请求.目标状态幂等主键 = 新主键();
        ++并发冲突请求.目标状态值;
        const auto 并发冲突前 = 读取数量();
        const auto 并发冲突 = 需求服务.创建完整目标状态需求(并发冲突请求);
        验收[21] = 并发提交数量 == 1
            && 并发幂等数量 == static_cast<std::ptrdiff_t>(并发数量 - 1)
            && 需求服务.读取主键需求(并发需求请求.需求幂等主键).完整目标状态需求()
            && 并发冲突.状态 == 需求任务方法业务状态::幂等冲突
            && 读取数量() == 并发冲突前;

        struct 结算测试夹具 {
