                特征当前值.特征值节点, 目标值});
        };
        const auto 创建执行中任务 = [&](节点句柄 需求) {
            const auto 创建 = 任务服务.创建承接任务({
                新主键(), 新主键(), 新主键(), 需求, 新时间()});
            if (!创建.成功()) return 任务权威材料{};
            const auto 任务 = 创建.材料.身份.节点;
            (void)任务服务.迁移生命周期({
                任务, 分层任务生命周期阶段::已承接, 新主键(), 新时间()});
            (void)任务服务.迁移生命周期({
                任务, 分层任务生命周期阶段::筹办中, 新主键(), 新时间()});
            (void)任务服务.迁移生命周期({
                任务, 分层任务生命周期阶段::排队中, 新主键(), 新时间()});
            (void)任务服务.迁移生命周期({
                任务, 分层任务生命周期阶段::执行中, 新主键(), 新时间()});
            return 任务服务.读取任务(任务);
        };
        const auto 创建已完成结算夹具 = [&](节点句柄 需求, std::int64_t 实际值,
                                             bool 创建因果) {
            结算测试夹具 夹具;
            夹具.需求 = 需求;
            const auto 执行中 = 创建执行中任务(需求);
            if (!执行中.完整承接()
                || 执行中.当前生命周期.阶段 != 分层任务生命周期阶段::执行中) return 夹具;
            夹具.任务 = 执行中.身份.节点;
            const auto 实际 = 状态服务.创建完整实例状态({
                新主键(), 执行中.场景, 执行中.虚拟存在, 新时间(), 实际值});
            if (!实际.成功()) return 夹具;
            夹具.实际状态 = 实际.状态材料.状态节点;
            const auto 动态 = 动态服务.记录已有状态变化动态({
