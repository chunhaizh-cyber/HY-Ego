            && 组合不相等任务后.当前生命周期.阶段 == 分层任务生命周期阶段::执行中
            && 组合不相等需求后.当前结算 == 分层需求结算结论::未结算
            && 读取数量() == 组合不相等前;
        }();

        [&] {
        const auto 主正式结算 = 需求服务.读取需求(主需求).正式结算;
        const auto 同义前 = 读取数量();
        const auto 同义重复 = 需求服务.提交独立结算(正确结算请求);
        auto 异键请求 = 正确结算请求;
        异键请求.结算状态幂等主键 = 新主键();
        const auto 异键冲突 = 需求服务.提交独立结算(异键请求);
        auto 异时请求 = 正确结算请求;
        异时请求.发生时间戳 = 新时间();
        const auto 异时冲突 = 需求服务.提交独立结算(异时请求);
        const auto 同义后读回 = 需求服务.读取需求(主需求);
        验收[29] = 同义重复.状态 == 需求任务方法业务状态::幂等读回
            && 异键冲突.状态 == 需求任务方法业务状态::幂等冲突
            && 异时冲突.状态 == 需求任务方法业务状态::幂等冲突
            && 主正式结算.has_value() && 同义后读回.正式结算.has_value()
            && 同义后读回.正式结算->结算状态.状态节点
                == 主正式结算->结算状态.状态节点
            && 读取数量() == 同义前;
        }();

        [&] {
        const auto 第二来源夹具 = 创建已完成结算夹具(主需求, 20, false);
        const auto 第二来源前 = 读取数量();
        const auto 第二来源冲突 = 第二来源夹具.完整
            ? 需求服务.提交独立结算(第二来源夹具.请求)
            : 需求提交结果{};
        验收[30] = 第二来源夹具.完整
            && 第二来源冲突.状态 == 需求任务方法业务状态::幂等冲突
            && 读取数量() == 第二来源前;
        }();

        [&] {
        const auto 替代实际 = 状态服务.创建完整实例状态({
            新主键(), 完成任务读回.场景, 完成任务读回.虚拟存在, 新时间(), 20});
        const auto 替代动态 = 替代实际.成功()
            ? 动态服务.记录已有状态变化动态({
