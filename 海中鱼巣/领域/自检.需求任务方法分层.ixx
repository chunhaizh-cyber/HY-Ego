            if (创建因果) {
                const auto 因果 = 因果服务.创建轻量因果({新主键(), 夹具.动态证据});
                if (!因果.成功()) return 夹具;
                夹具.因果引用 = 因果.因果.因果引用;
            }
            const auto 完成 = 任务服务.提交实际结果并完成({
                夹具.任务, 夹具.实际状态, 新主键(), 新时间()});
            if (!完成.成功()) return 夹具;
            夹具.请求 = {
                需求, 夹具.任务, 夹具.实际状态, 夹具.动态证据, 夹具.因果引用,
                新主键(), 新时间()};
            夹具.完整 = true;
            return 夹具;
        };

        [&] {
        const auto 主正式结算 = 结算需求读回.正式结算;
        const auto 规格门禁需求 = 创建测试需求(20);
