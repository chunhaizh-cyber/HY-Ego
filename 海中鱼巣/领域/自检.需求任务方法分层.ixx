            未满足规格拒绝 = !未满足写入规格.has_value();
        }
        auto 混合值状态规格 = 状态服务.形成实例状态写入规格({
            新主键(), 规格门禁任务.场景, 规格门禁任务.虚拟存在,
            新时间(), static_cast<std::int64_t>(分层需求结算结论::未满足)});
        bool 混合值规格拒绝 = false;
        if (规格门禁夹具.完整 && 混合值状态规格.成功()) {
