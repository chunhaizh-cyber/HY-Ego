// 文件规则：需求任务方法分层自检只验证隔离新路径、故障和并发收口，不进入生产依赖。
module;

#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
#include "../核心/主信息仓库.h"
#include "../核心/节点仓库.h"
#include "../核心/关系仓库.h"
#include "../核心/索引仓库.h"
#include "特征值服务.h"

#include <algorithm>
#include <array>
#include <cstddef>
#include <cstdint>
#include <iostream>
#include <optional>
#include <thread>
#include <type_traits>
#include <utility>
#include <vector>
#endif

export module 海中鱼巣.领域.自检.需求任务方法分层;

#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
import 海中鱼巣.核心.协调.结构事务;
import 海中鱼巣.核心.执行器.结构写入;
import 海中鱼巣.领域.数据操作.存在场景;
import 海中鱼巣.领域.数据操作.状态动态;
import 海中鱼巣.领域.数据操作.特征体系;
import 海中鱼巣.领域.数据操作.轻量因果;
import 海中鱼巣.领域.数据操作.需求任务方法;
import 海中鱼巣.领域.服务.存在;
import 海中鱼巣.领域.服务.场景;
import 海中鱼巣.领域.服务.状态;
import 海中鱼巣.领域.服务.动态;
import 海中鱼巣.领域.服务.特征;
import 海中鱼巣.领域.服务.轻量因果;
import 海中鱼巣.领域.服务.需求;
import 海中鱼巣.领域.服务.任务;
import 海中鱼巣.领域.服务.方法;
import 海中鱼巣.领域.服务.方法召回;
import 海中鱼巣.领域.组合.需求任务方法;
import 海中鱼巣.自检.运行器;

export namespace 海中鱼巣 {

namespace 需求任务方法分层自检内部 {

struct 结构数量 {
    std::uint64_t 节点 = 0;
    std::uint64_t 关系 = 0;
    std::uint64_t 主键 = 0;

    bool operator==(const 结构数量&) const = default;
};

struct 方法夹具 {
    方法提交结果 方法首;
    方法提交结果 条件;
    方法提交结果 结果;
    方法提交结果 动作;

    bool 完整() const noexcept {
        return 方法首.成功() && 方法首.登记项.完整()
            && 条件.成功() && 条件.规格.完整条件()
            && 结果.成功() && 结果.规格.完整结果()
            && 动作.成功() && 动作.规格.完整动作入口();
    }
};

}

自检单元结果 运行需求任务方法分层自检(
    bool 仓库合同回归通过,
    bool 结构写入会话回归通过,
    bool 存在场景回归通过,
    bool 会话材料回归通过,
    bool 状态动态回归通过,
    bool 特征体系回归通过,
    bool 语义基础回归通过,
    bool 概念图回归通过,
    bool 关系换代回归通过,
    bool 存在状态同会话回归通过) {
    using namespace 需求任务方法分层自检内部;

    static_assert(!std::is_default_constructible_v<完整需求写入规格>);
    static_assert(!std::is_default_constructible_v<任务承接写入规格>);
    static_assert(!std::is_default_constructible_v<方法登记根写入规格>);
    static_assert(std::is_same_v<
        decltype(std::declval<const 需求业务服务&>().创建完整目标状态需求(
            创建完整目标状态需求请求{})),
        需求提交结果>);
    static_assert(std::is_same_v<
        decltype(std::declval<const 任务业务服务&>().创建承接任务(
            创建任务承接请求{})),
        任务提交结果>);
    static_assert(std::is_same_v<
        decltype(std::declval<const 方法业务服务&>().创建登记根(
            创建方法登记根请求{})),
        方法提交结果>);

    std::array<bool, 38> 验收{};
    try {
        constexpr std::uint64_t 关系仓库编号 = 7603;
        结构事务协调器 协调器(760);
        const auto 接线 = 协调器.生成接线();
        主信息仓库 主信息(7601, 接线);
        节点仓库 节点(主信息, 7602, 接线);
        关系仓库 关系(节点, 关系仓库编号, 接线);
        索引仓库 索引(节点, 接线);
        特征值服务 特征值(主信息, 节点);

        存在场景数据操作 存在数据操作(
            接线, 主信息, 节点, 关系, 索引, 关系仓库编号);
        状态动态数据操作 状态数据操作(
            接线, 主信息, 节点, 关系, 索引, 关系仓库编号);
        特征体系数据操作 特征数据操作(
            接线, 主信息, 节点, 关系, 索引, 特征值, 关系仓库编号);
        轻量因果数据操作 因果数据操作(接线, 主信息, 节点, 关系, 索引);
        需求任务方法数据操作 高级数据操作(
            接线, 主信息, 节点, 关系, 索引, 关系仓库编号,
            存在数据操作, 状态数据操作);

        存在业务服务 存在服务(存在数据操作);
        场景业务服务 场景服务(存在数据操作);
        状态业务服务 状态服务(状态数据操作);
        动态业务服务 动态服务(状态服务, 状态数据操作);
        特征业务服务 特征服务(特征数据操作);
        轻量因果业务服务 因果服务(动态服务, 因果数据操作);
        需求业务服务 需求服务(高级数据操作, 状态服务);
        任务业务服务 任务服务(
            高级数据操作, 需求服务, 存在服务, 状态服务);
        方法业务服务 方法服务(高级数据操作, 存在服务, 状态服务);
        方法召回业务服务 召回服务(
            需求服务, 任务服务, 方法服务, 特征服务, 状态服务);
        需求任务方法组合器 组合器(需求服务, 任务服务, 召回服务);

        std::uint64_t 主键序号 = 0x0760'0000'0000'1000ULL;
        std::uint64_t 时间序号 = 760'000;
        const auto 新主键 = [&]() noexcept { return ++主键序号; };
        const auto 新时间 = [&]() noexcept { return ++时间序号; };
        const auto 读取数量 = [&]() noexcept {
            return 结构数量{
                节点.有效节点数量(), 关系.有效关系数量(), 索引.有效主键数量()};
        };
        const auto 读取当前审计 = [&](const 高级关系证据& 证据) {
            const auto 记录组 = 关系.获取关系审计记录组(证据.源节点, 证据.类型);
            const auto 位置 = std::find_if(记录组.begin(), 记录组.end(), [&](const auto& 记录) {
                return 记录.关系编号 == 证据.关系.关系编号;
            });
            return 位置 == 记录组.end()
                ? std::optional<关系记录>{}
                : std::optional<关系记录>{*位置};
        };

        验收[0] = 接线.已接域() && 存在数据操作.有效() && 状态数据操作.有效()
            && 特征数据操作.有效() && 因果数据操作.有效() && 高级数据操作.有效();
        验收[1] = std::is_same_v<
                decltype(std::declval<const 需求业务服务&>().读取需求(节点句柄{})),
                需求权威材料>
            && std::is_same_v<
                decltype(std::declval<const 任务业务服务&>().读取任务(节点句柄{})),
                任务权威材料>
            && std::is_same_v<
                decltype(std::declval<const 方法业务服务&>().读取登记项(节点句柄{})),
                方法登记项材料>;
        验收[2] = 验收[0] && !std::is_default_constructible_v<完整需求写入规格>
            && !std::is_default_constructible_v<任务承接写入规格>
            && !std::is_default_constructible_v<方法登记根写入规格>;
        验收[3] = 存在状态同会话回归通过 && 关系换代回归通过;

        const auto 主体结果 = 存在服务.创建实际存在({新主键()});
        const auto 主体 = 主体结果.存在;
        const auto 场景结果 = 场景服务.创建场景({新主键()});
        const auto 场景 = 场景结果.场景;
        const auto 输出场景结果 = 场景服务.创建场景({新主键()});
        const auto 输出场景 = 输出场景结果.场景;
        const auto 场景接纳 = 场景服务.接纳已有存在({场景, 主体});
        const auto 特征定义结果 = 特征服务.创建特征定义({新主键()});
        const auto 特征定义 = 特征定义结果.定义.特征定义;
        const auto 特征槽位结果 = 特征服务.创建实例特征槽位(
            {新主键(), 主体, 特征定义});
        const auto 特征槽位 = 特征槽位结果.槽位.实例槽位;
        const auto 特征当前值结果 = 特征服务.发布初始特征状态({
            新主键(), 特征槽位,
            {特征值原始类型::I64, std::int64_t{10}, {}, {}}});
        const auto 特征当前值 = 特征当前值结果.当前值;
        const auto 条件状态结果 = 状态服务.创建抽象状态({新主键(), 10});
        const auto 条件状态 = 条件状态结果.状态材料.状态节点;

        const 创建完整目标状态需求请求 根需求请求{
            新主键(), 新主键(), 主体, 主体, 场景, 特征定义,
            特征当前值.特征值节点, 20};
        const auto 根需求首次 = 需求服务.创建完整目标状态需求(根需求请求);
        const auto 根需求重复 = 需求服务.创建完整目标状态需求(根需求请求);
        auto 根需求冲突请求 = 根需求请求;
        根需求冲突请求.目标状态幂等主键 = 新主键();
        const auto 根冲突前 = 读取数量();
        const auto 根需求冲突 = 需求服务.创建完整目标状态需求(根需求冲突请求);
        const auto 根冲突后 = 读取数量();

        const 创建完整目标状态需求请求 第二父需求请求{
            新主键(), 新主键(), 主体, 主体, 场景, 特征定义,
            特征当前值.特征值节点, 30};
        const 创建完整目标状态需求请求 子需求请求{
            新主键(), 新主键(), 主体, 主体, 场景, 特征定义,
            特征当前值.特征值节点, 20};
        const auto 第二父需求 = 需求服务.创建完整目标状态需求(第二父需求请求);
        const auto 子需求 = 需求服务.创建完整目标状态需求(子需求请求);
        const auto 首次挂载 = 需求服务.更新父需求({
            子需求.材料.身份.节点, 根需求首次.材料.身份.节点});
        const auto 首次父子 = 需求服务.读取需求(子需求.材料.身份.节点).父子关系;
        const auto 幂等挂载 = 需求服务.更新父需求({
            子需求.材料.身份.节点, 根需求首次.材料.身份.节点});
        const auto 成环前 = 读取数量();
        const auto 成环拒绝 = 需求服务.更新父需求({
            根需求首次.材料.身份.节点, 子需求.材料.身份.节点});
        const auto 自身拒绝 = 需求服务.更新父需求({
            子需求.材料.身份.节点, 子需求.材料.身份.节点});
        const auto 成环与自身拒绝后 = 读取数量();
        const auto 合法重挂 = 需求服务.更新父需求({
            子需求.材料.身份.节点, 第二父需求.材料.身份.节点});
        const auto 合法重挂后 = 读取数量();
        const auto 重挂读回 = 需求服务.读取需求(子需求.材料.身份.节点);
        const auto 重挂父子审计 = 重挂读回.父子关系.has_value()
            ? 读取当前审计(*重挂读回.父子关系)
            : std::optional<关系记录>{};
        验收[4] = 首次挂载.成功() && 幂等挂载.成功()
            && 幂等挂载.状态 == 需求任务方法业务状态::幂等读回
            && 成环拒绝.状态 == 需求任务方法业务状态::入口拒绝
            && 自身拒绝.状态 == 需求任务方法业务状态::入口拒绝
            && 成环与自身拒绝后 == 成环前
            && 合法重挂.成功() && 重挂读回.父需求
                == std::optional<节点句柄>{第二父需求.材料.身份.节点}
            && 首次父子.has_value() && 重挂读回.父子关系.has_value()
            && 重挂读回.父子关系->关系.关系编号 == 首次父子->关系.关系编号
            && 重挂读回.父子关系->关系.版本号 == 首次父子->关系.版本号 + 1
            && 重挂父子审计.has_value() && 重挂父子审计->状态 == 记录状态::有效
            && 合法重挂后 == 成环前;

        const 创建概念命名需求请求 命名需求请求{
            新主键(), 主体, 主体, 场景, 特征定义,
            特征当前值.特征值节点, 根需求首次.材料.目标状态,
            特征定义, 根需求首次.材料.身份.节点};
        const auto 命名需求 = 需求服务.创建概念命名需求(命名需求请求);
        const auto 命名需求读回 = 需求服务.读取需求(命名需求.材料.身份.节点);
        const auto 根目标状态 = 状态服务.读取状态材料(根需求首次.材料.目标状态);
        验收[5] = 主体结果.成功() && 场景结果.成功() && 输出场景结果.成功()
            && 场景接纳.成功() && 特征定义结果.成功() && 特征槽位结果.成功()
            && 特征当前值结果.成功() && 条件状态结果.成功()
            && 根需求首次.成功() && 根需求重复.状态 == 需求任务方法业务状态::幂等读回
            && 根需求冲突.状态 == 需求任务方法业务状态::幂等冲突
            && 根冲突前 == 根冲突后 && 根目标状态.完整抽象状态()
            && 根目标状态.幂等主键 == 根需求请求.目标状态幂等主键
            && 根目标状态.状态值 == 根需求请求.目标状态值
            && 命名需求.成功() && 命名需求读回.完整概念命名需求()
            && 命名需求读回.目标概念 == std::optional<节点句柄>{特征定义}
            && 命名需求读回.父需求
                == std::optional<节点句柄>{根需求首次.材料.身份.节点};

        创建需求并承接任务请求 组合创建请求;
        组合创建请求.需求 = {
            新主键(), 新主键(), 主体, 主体, 场景, 特征定义,
            特征当前值.特征值节点, 20};
        组合创建请求.任务幂等主键 = 新主键();
        组合创建请求.任务虚拟存在幂等主键 = 新主键();
        组合创建请求.任务初始状态幂等主键 = 新主键();
        组合创建请求.任务创建时间戳 = 新时间();
        const auto 组合创建 = 组合器.创建需求并承接任务(组合创建请求);
        const auto 组合重复 = 组合器.创建需求并承接任务(组合创建请求);
        const auto 主任务 = 组合创建.任务.材料.身份.节点;
        const auto 主需求 = 组合创建.需求.材料.身份.节点;
        const auto 主任务读回 = 任务服务.读取任务(主任务);
        const auto 任务虚拟存在 = 存在数据操作.读取主键身份(
            组合创建请求.任务虚拟存在幂等主键);
        const auto 任务初始状态 = 状态服务.读取状态材料(
            主任务读回.当前生命周期.状态);
        auto 任务冲突请求 = 创建任务承接请求{
            组合创建请求.任务幂等主键, 新主键(), 新主键(),
            主需求, 组合创建请求.任务创建时间戳};
        const auto 任务冲突前 = 读取数量();
        const auto 任务冲突 = 任务服务.创建承接任务(任务冲突请求);
        验收[6] = 组合创建.成功() && 组合重复.成功()
            && 组合重复.任务.状态 == 需求任务方法业务状态::幂等读回
            && 主任务读回.完整承接() && 任务虚拟存在.当前可读()
            && 任务虚拟存在.类型 == 节点类型::存在
            && 任务虚拟存在.虚拟来源 == std::optional<节点句柄>{主任务}
            && 任务初始状态.完整实例状态()
            && 任务初始状态.幂等主键 == 组合创建请求.任务初始状态幂等主键
            && 任务初始状态.主体 == 主任务读回.虚拟存在
            && 任务冲突.状态 == 需求任务方法业务状态::幂等冲突
            && 读取数量() == 任务冲突前;

        const 迁移任务生命周期请求 承接请求{
            主任务, 分层任务生命周期阶段::已承接, 新主键(), 新时间()};
        const auto 承接 = 任务服务.迁移生命周期(承接请求);
        const auto 承接重复 = 任务服务.迁移生命周期(承接请求);
        const auto 非法迁移前 = 读取数量();
        const 迁移任务生命周期请求 非法迁移请求{
            主任务, 分层任务生命周期阶段::执行中, 新主键(), 新时间()};
        const auto 非法迁移 = 任务服务.迁移生命周期(非法迁移请求);
        const auto 非法迁移后 = 读取数量();
        const auto 筹办 = 任务服务.迁移生命周期({
            主任务, 分层任务生命周期阶段::筹办中, 新主键(), 新时间()});
        const auto 生命周期历史 = 任务服务.读取生命周期历史(主任务);
        const auto 当前筹办任务 = 任务服务.读取任务(主任务);
        const auto 当前关系数量 = static_cast<std::size_t>(std::count_if(
            生命周期历史.begin(), 生命周期历史.end(), [](const auto& 项) { return 项.当前(); }));
        验收[7] = 承接.成功() && 承接重复.状态 == 需求任务方法业务状态::幂等读回
            && 非法迁移.状态 == 需求任务方法业务状态::入口拒绝
            && 非法迁移后 == 非法迁移前 && 筹办.成功()
            && 当前筹办任务.当前生命周期.阶段 == 分层任务生命周期阶段::筹办中
            && 当前筹办任务.当前生命周期.版本 == 3
            && 生命周期历史.size() == 3 && 当前关系数量 == 1;

        const 创建方法登记根请求 登记根请求{
            新主键(), 新主键(), 新主键(), 新主键()};
        const auto 登记根 = 方法服务.创建登记根(登记根请求);
        const auto 登记根重复 = 方法服务.创建登记根(登记根请求);
        const auto 登记根节点 = 登记根.根.身份.节点;
        const auto 登记根角色 = 状态服务.读取状态材料(登记根.根.角色状态);
