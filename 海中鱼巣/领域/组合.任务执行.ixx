// 文件规则：任务执行组合器只编排任务、方法和状态动态业务服务；不得接触仓库、队列锁或事务能力。
module;

#include "../核心/句柄.h"

#include <cstdint>
#include <optional>
#include <utility>
#include <vector>

export module 海中鱼巣.领域.组合.任务执行;

import 海中鱼巣.领域.服务.任务;
import 海中鱼巣.领域.服务.方法;
import 海中鱼巣.领域.数据操作.需求任务方法;
import 海中鱼巣.领域.数据操作.状态动态;
import 海中鱼巣.领域.组合.状态动态;
import 海中鱼巣.线程.协议.任务执行请求;

export namespace 海中鱼巣 {

enum class 任务执行组合状态 : std::uint8_t {
    入口拒绝 = 0,
    已冻结 = 1,
    已排队 = 2,
    已执行 = 3,
    已收口待重筹办 = 4,
    当前性漂移 = 5,
    许可拒绝 = 6,
    版本漂移 = 7,
    内部不一致 = 8
};

struct 任务执行组合结果 {
    任务执行组合状态 状态 = 任务执行组合状态::入口拒绝;
    std::optional<任务执行冻结请求> 冻结请求;
    状态值式材料 实际状态;
    动态值式材料 动态证据;

    bool 已冻结() const noexcept {
        return 状态 == 任务执行组合状态::已冻结 && 冻结请求.has_value();
    }

    bool 已排队() const noexcept {
        return 状态 == 任务执行组合状态::已排队 && 冻结请求.has_value();
    }

    bool 已执行() const noexcept {
        return 状态 == 任务执行组合状态::已执行 && 冻结请求.has_value()
            && 实际状态.完整实例状态() && 动态证据.完整实例动态();
    }
};

class 任务执行组合器 final {
public:
    任务执行组合器(
        任务业务服务& 任务服务,
        方法业务服务& 方法服务,
        状态动态组合器& 状态动态,
        std::uint64_t 支持的稳定动作键)
        : 任务服务_(任务服务), 方法服务_(方法服务), 状态动态_(状态动态),
          支持的稳定动作键_(支持的稳定动作键) {
    }

    任务执行组合结果 冻结任务执行请求(
        const 任务执行调度请求& 请求) const {
        if (支持的稳定动作键_ == 0 || !复核任务执行调度请求(请求).成功()) return {};
        const auto 任务 = 任务服务_.读取任务(请求.任务);
        const auto 任务失败 = 映射任务读取失败(任务.状态);
        if (任务失败 != 任务执行组合状态::入口拒绝) return {任务失败};
        if (!任务.完整承接() || 任务.当前生命周期.阶段 != 分层任务生命周期阶段::筹办中
            || !任务.当前选择.has_value()) return {};
        if (!任务.当前选择->完整()) return {任务执行组合状态::内部不一致};

        const auto 方法 = 方法服务_.读取登记项(任务.当前选择->方法);
        const auto 方法失败 = 映射任务读取失败(方法.状态);
        if (方法失败 != 任务执行组合状态::入口拒绝) return {方法失败};
        if (!方法.完整() || 方法.生命周期 != 分层方法生命周期::活跃) return {};
        const auto 动作组 = 方法服务_.读取规格组(方法.身份.节点, 分层方法角色::动作入口);
        if (动作组.empty()) return {};
        if (动作组.size() != 1 || !动作组.front().完整动作入口()) {
            return {任务执行组合状态::内部不一致};
        }
        const auto& 动作 = 动作组.front();
        if (动作.稳定动作键 != 支持的稳定动作键_
            || 动作.输入场景 != std::optional<节点句柄>{任务.场景}
            || 动作.输出场景 != std::optional<节点句柄>{任务.场景}) return {};

        任务执行冻结请求 冻结{
            请求, 转换任务材料(任务), 转换方法材料(方法), 转换动作材料(动作),
            任务执行适配器种类::任务目标状态值变化};
        if (!冻结任务执行请求完整(冻结)) {
            return {任务执行组合状态::内部不一致};
        }
        return {任务执行组合状态::已冻结, std::move(冻结)};
    }

    任务执行组合结果 确认任务进入排队中(
        const 任务执行冻结请求& 冻结) const {
        if (!冻结任务执行请求完整(冻结)) return {};
        const auto 当前性 = 复核冻结当前性(冻结, 分层任务生命周期阶段::筹办中);
        if (当前性 != 任务执行组合状态::已冻结) return {当前性};
        const auto& 请求 = 冻结.调度请求;
        const auto 迁移 = 任务服务_.迁移生命周期({
            请求.任务, 分层任务生命周期阶段::排队中,
            请求.排队生命周期幂等主键, 请求.排队时间戳});
        if (!迁移.成功()) return {映射任务提交失败(迁移.状态)};
        if (!迁移.材料.完整承接()
            || 迁移.材料.当前生命周期.阶段 != 分层任务生命周期阶段::排队中
            || !任务执行任务材料静态相同(
                转换任务材料(迁移.材料), 冻结.任务材料)) {
            return {任务执行组合状态::内部不一致};
        }
        return {任务执行组合状态::已排队, 冻结};
    }

    任务执行组合结果 执行任务目标状态值变化(
        const 任务执行冻结请求& 冻结,
        std::uint64_t 当前时间戳) const {
        if (!冻结任务执行请求完整(冻结) || 当前时间戳 == 0) return {};
        if (当前时间戳 > 冻结.调度请求.截止时间戳) {
            return 收口过期或允许拒绝请求(冻结, 分层任务生命周期阶段::排队中);
        }
        const auto 当前性 = 复核冻结当前性(冻结, 分层任务生命周期阶段::排队中);
        if (当前性 != 任务执行组合状态::已冻结) return {当前性};
        const auto& 请求 = 冻结.调度请求;
        const auto 执行迁移 = 任务服务_.迁移生命周期({
            请求.任务, 分层任务生命周期阶段::执行中,
            请求.执行生命周期幂等主键, 请求.执行时间戳});
        if (!执行迁移.成功()) return {映射任务提交失败(执行迁移.状态)};
        if (!执行迁移.材料.完整承接()
            || 执行迁移.材料.当前生命周期.阶段 != 分层任务生命周期阶段::执行中
            || !任务执行任务材料静态相同(
                转换任务材料(执行迁移.材料), 冻结.任务材料)) {
            return {任务执行组合状态::内部不一致};
        }

        const auto 动作桥 = 任务服务_.读取动作桥请求(请求.任务);
        if (!动作桥.has_value() || !动作桥->完整()
            || 动作桥->任务 != 请求.任务
            || 动作桥->方法首 != 冻结.方法材料.身份.节点
            || 动作桥->动作入口 != 冻结.动作材料.身份.节点
            || 动作桥->稳定动作键 != 支持的稳定动作键_
            || 动作桥->输入场景 != 冻结.任务材料.场景
            || 动作桥->输出场景 != 冻结.任务材料.场景) {
            return {任务执行组合状态::内部不一致};
        }

        const 使用已有前状态记录动态请求 动态请求{
            执行迁移.材料.当前生命周期.状态,
            请求.实际状态幂等主键,
            请求.动态幂等主键,
            请求.实际状态时间戳,
            请求.实际状态值,
            冻结.任务材料.目标状态,
            冻结.动作材料.身份.节点};
        const auto 动态结果 = 状态动态_.使用已有前状态创建后状态并记录动态(动态请求);
        if (!动态结果.成功()) {
            if (动态结果.状态 == 状态动态业务状态::内部不一致) {
                return {任务执行组合状态::内部不一致};
            }
            const auto 收口 = 收口过期或允许拒绝请求(
                冻结, 分层任务生命周期阶段::执行中);
            return 收口.状态 == 任务执行组合状态::已收口待重筹办
                ? 收口 : 任务执行组合结果{收口.状态};
        }
        if (!动态结果.后状态材料.完整实例状态()
            || !动态结果.动态材料.完整实例动态()
            || 动态结果.后状态材料.幂等主键 != 请求.实际状态幂等主键
            || 动态结果.后状态材料.状态值 != 请求.实际状态值
            || 动态结果.后状态材料.场景 != 冻结.任务材料.场景
            || 动态结果.后状态材料.主体 != 冻结.任务材料.虚拟存在
            || 动态结果.动态材料.幂等主键 != 请求.动态幂等主键
            || 动态结果.动态材料.被改变目标 != 冻结.任务材料.目标状态
            || 动态结果.动态材料.来源动作 != 冻结.动作材料.身份.节点
            || 动态结果.动态材料.前状态
                != 执行迁移.材料.当前生命周期.状态
            || 动态结果.动态材料.后状态 != 动态结果.后状态材料.状态节点) {
            return {任务执行组合状态::内部不一致};
        }
        任务执行组合结果 输出;
        输出.状态 = 任务执行组合状态::已执行;
        输出.冻结请求 = 冻结;
        输出.实际状态 = 动态结果.后状态材料;
        输出.动态证据 = 动态结果.动态材料;
        return 输出;
    }

    任务执行组合结果 收口过期或允许拒绝请求(
        const 任务执行冻结请求& 冻结,
        分层任务生命周期阶段 当前阶段) const {
        if (!冻结任务执行请求完整(冻结)
            || (当前阶段 != 分层任务生命周期阶段::排队中
                && 当前阶段 != 分层任务生命周期阶段::执行中
                && 当前阶段 != 分层任务生命周期阶段::等待中)) return {};
        const auto 当前 = 任务服务_.读取任务(冻结.调度请求.任务);
        const auto 读取失败 = 映射任务读取失败(当前.状态);
        if (读取失败 != 任务执行组合状态::入口拒绝) return {读取失败};
        if (!当前.完整承接() || 当前.当前生命周期.阶段 != 当前阶段
            || !任务执行任务材料静态相同(
                转换任务材料(当前), 冻结.任务材料)) {
            return {任务执行组合状态::当前性漂移};
        }
        const auto 迁移 = 任务服务_.迁移生命周期({
            冻结.调度请求.任务, 分层任务生命周期阶段::待重筹办,
            冻结.调度请求.待重筹办幂等主键,
            冻结.调度请求.待重筹办时间戳});
        if (!迁移.成功()) return {映射任务提交失败(迁移.状态)};
        if (!迁移.材料.完整承接()
            || 迁移.材料.当前生命周期.阶段 != 分层任务生命周期阶段::待重筹办) {
            return {任务执行组合状态::内部不一致};
        }
        return {任务执行组合状态::已收口待重筹办, 冻结};
    }

private:
    static 任务执行关系证据 转换关系证据(const 高级关系证据& 证据) {
        return {证据.关系, 证据.类型, 证据.源节点, 证据.目标节点,
            证据.顺序号, 证据.状态};
    }

    static 任务执行节点身份 转换节点身份(const 高级节点身份& 身份) {
        return {身份.幂等主键, 身份.节点, 身份.类型, 身份.主信息};
    }

    static 任务执行选择材料 转换选择材料(const 任务方法选择材料& 材料) {
        return {
            转换节点身份(材料.记录身份), 材料.任务, 材料.方法,
            材料.幂等材料编号, 转换关系证据(材料.方法投影关系),
            转换关系证据(材料.发布关系), 材料.来源生命周期关系,
            材料.来源生命周期版本, 材料.来源方法生命周期关系,
            材料.来源方法生命周期版本, 材料.排序规则版本,
            材料.召回请求规则版本, 材料.来源候选数量};
    }

    static 任务执行任务材料 转换任务材料(const 任务权威材料& 材料) {
        任务执行任务材料 输出;
        输出.身份 = 转换节点身份(材料.身份);
        输出.来源需求 = 材料.来源需求;
        输出.虚拟存在 = 材料.虚拟存在;
        输出.场景 = 材料.场景;
        输出.目标状态 = 材料.目标状态;
        输出.需求拥有任务关系 = 转换关系证据(材料.需求拥有任务关系);
        输出.任务来源需求关系 = 转换关系证据(材料.任务来源需求关系);
        输出.虚拟存在关系 = 转换关系证据(材料.虚拟存在关系);
        输出.场景关系 = 转换关系证据(材料.场景关系);
        输出.目标状态关系 = 转换关系证据(材料.目标状态关系);
        输出.当前生命周期 = {
            转换关系证据(材料.当前生命周期.关系),
            材料.当前生命周期.状态,
            static_cast<任务执行生命周期阶段>(材料.当前生命周期.阶段),
            材料.当前生命周期.版本,
            材料.当前生命周期.发生时间戳,
            材料.当前生命周期.记录阶段};
        if (材料.当前选择.has_value()) {
            输出.当前选择 = 转换选择材料(*材料.当前选择);
        }
        return 输出;
    }

    static 任务执行方法材料 转换方法材料(const 方法登记项材料& 材料) {
        return {
            转换节点身份(材料.身份), 材料.登记根, 材料.角色状态,
            材料.虚拟存在, 转换关系证据(材料.登记关系),
            转换关系证据(材料.角色关系), 转换关系证据(材料.虚拟存在关系),
            转换关系证据(材料.生命周期关系),
            static_cast<任务执行方法生命周期>(材料.生命周期)};
    }

    static 任务执行动作材料 转换动作材料(const 方法规格材料& 材料) {
        任务执行动作材料 输出;
        输出.身份 = 转换节点身份(材料.身份);
        输出.方法首 = 材料.方法首;
        输出.角色 = static_cast<任务执行方法角色>(材料.角色);
        输出.角色状态 = 材料.角色状态;
        输出.方法角色关系 = 转换关系证据(材料.方法角色关系);
        输出.角色状态关系 = 转换关系证据(材料.角色状态关系);
        if (材料.入口状态.has_value()) 输出.入口状态 = *材料.入口状态;
        if (材料.入口状态关系.has_value()) {
            输出.入口状态关系 = 转换关系证据(*材料.入口状态关系);
        }
        if (材料.输入场景.has_value()) 输出.输入场景 = *材料.输入场景;
        if (材料.输出场景.has_value()) 输出.输出场景 = *材料.输出场景;
        if (材料.输入场景关系.has_value()) {
            输出.输入场景关系 = 转换关系证据(*材料.输入场景关系);
        }
        if (材料.输出场景关系.has_value()) {
            输出.输出场景关系 = 转换关系证据(*材料.输出场景关系);
        }
        输出.稳定动作键 = 材料.稳定动作键;
        return 输出;
    }

    任务执行组合状态 复核冻结当前性(
        const 任务执行冻结请求& 冻结,
        分层任务生命周期阶段 预期阶段) const {
        const auto 当前任务 = 任务服务_.读取任务(冻结.调度请求.任务);
        const auto 任务失败 = 映射任务读取失败(当前任务.状态);
        if (任务失败 != 任务执行组合状态::入口拒绝) return 任务失败;
        if (!当前任务.完整承接() || 当前任务.当前生命周期.阶段 != 预期阶段
            || !任务执行任务材料静态相同(
                转换任务材料(当前任务), 冻结.任务材料)) {
            return 任务执行组合状态::当前性漂移;
        }
        const auto 当前方法 = 方法服务_.读取登记项(冻结.方法材料.身份.节点);
        const auto 方法失败 = 映射任务读取失败(当前方法.状态);
        if (方法失败 != 任务执行组合状态::入口拒绝) return 方法失败;
        if (!当前方法.完整() || 当前方法.生命周期 != 分层方法生命周期::活跃
            || !任务执行方法材料相同(
                转换方法材料(当前方法), 冻结.方法材料)) {
            return 任务执行组合状态::当前性漂移;
        }
        const auto 动作组 = 方法服务_.读取规格组(
            当前方法.身份.节点, 分层方法角色::动作入口);
        if (动作组.size() != 1 || !动作组.front().完整动作入口()) {
            return 任务执行组合状态::内部不一致;
        }
        return 任务执行动作材料相同(
                转换动作材料(动作组.front()), 冻结.动作材料)
            ? 任务执行组合状态::已冻结
            : 任务执行组合状态::当前性漂移;
    }

    static 任务执行组合状态 映射任务读取失败(
        需求任务方法读取状态 状态) noexcept {
        switch (状态) {
        case 需求任务方法读取状态::许可拒绝:
            return 任务执行组合状态::许可拒绝;
        case 需求任务方法读取状态::版本漂移:
            return 任务执行组合状态::版本漂移;
        case 需求任务方法读取状态::内部不一致:
            return 任务执行组合状态::内部不一致;
        default:
            return 任务执行组合状态::入口拒绝;
        }
    }

    static 任务执行组合状态 映射任务提交失败(
        需求任务方法业务状态 状态) noexcept {
        switch (状态) {
        case 需求任务方法业务状态::许可拒绝:
            return 任务执行组合状态::许可拒绝;
        case 需求任务方法业务状态::版本漂移:
            return 任务执行组合状态::版本漂移;
        case 需求任务方法业务状态::内部不一致:
            return 任务执行组合状态::内部不一致;
        default:
            return 任务执行组合状态::当前性漂移;
        }
    }

    任务业务服务& 任务服务_;
    方法业务服务& 方法服务_;
    状态动态组合器& 状态动态_;
    std::uint64_t 支持的稳定动作键_ = 0;
};

}
