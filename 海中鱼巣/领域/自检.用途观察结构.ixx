// 文件规则：用途观察结构自检只构造隔离仓库并验证 O1 正式公开面；不得进入生产依赖或承载运行期修复逻辑。
module;

#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
#include "../核心/主信息仓库.h"
#include "../核心/节点仓库.h"
#include "../核心/关系仓库.h"
#include "../核心/索引仓库.h"

#include <algorithm>
#include <array>
#include <cstddef>
#include <cstdint>
#include <iostream>
#include <optional>
#include <type_traits>
#include <utility>
#include <vector>
#endif

export module 海中鱼巣.领域.自检.用途观察结构;

#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
import 海中鱼巣.核心.协调.结构事务;
import 海中鱼巣.领域.材料.用途观察;
import 海中鱼巣.领域.材料.因果模式;
import 海中鱼巣.领域.材料.用途事件;
import 海中鱼巣.领域.算法.用途观察;
import 海中鱼巣.领域.数据操作.用途观察;
import 海中鱼巣.领域.服务.用途观察;
import 海中鱼巣.自检.运行器;

export namespace 海中鱼巣 {

namespace 用途观察结构自检内部 {

struct 结构计数 {
    std::uint64_t 节点 = 0;
    std::uint64_t 关系 = 0;
    std::uint64_t 主键 = 0;

    bool operator==(const 结构计数&) const = default;
};

struct 测试环境 {
    explicit 测试环境(std::uint64_t 域编号)
        : 协调器(域编号),
          接线(协调器.生成接线()),
          主信息(域编号 + 1000, 接线),
          节点(主信息, 域编号 + 2000, 接线),
          关系(节点, 域编号 + 3000, 接线),
          索引(节点, 接线),
          数据操作(接线, 主信息, 节点, 关系, 索引, 域编号 + 3000),
          服务(数据操作) {
        初始化完成 = 初始化端点();
    }

    用途观察纯值候选 形成候选(
        用途观察阶段 阶段,
        std::uint64_t 任务序号 = 9001) const {
        用途观察纯值候选 候选;
        候选.身份 = {节点组[1], 任务序号};
        auto& 核心 = 候选.不可变核心;
        核心.需求 = 节点组[2];
        核心.选择记录 = 节点组[3];
        核心.方法 = 节点组[4];
        核心.动作 = 节点组[5];
        核心.场景 = 节点组[6];
        核心.主体 = 节点组[7];
        核心.目标状态 = 节点组[8];
        核心.实际状态 = 节点组[9];
        核心.动态证据 = 节点组[10];
        auto& 因果 = 核心.历史概率.因果身份;
        因果.原因动态键 = {
            节点组[11], 10, 20, true, 节点组[12], 1, std::nullopt};
        因果.结果动态键 = {
            节点组[13], 20, 30, true, 节点组[14], 1, std::nullopt};
        因果.因果规则版本 = 1;
        因果.格式版本 = 1;
        核心.历史概率.机会数 = 2;
        核心.历史概率.正结果数 = 1;
        核心.历史概率.负结果数 = 1;
        核心.历史概率.Q10000 = 5000;
        switch (阶段) {
        case 用途观察阶段::尝试未达成:
            候选.阶段负载 = {用途正式结果分类::未达成已转待重筹办,
                任务达成分量::未达成, 需求结算分量::未形成,
                用途观察阶段::尝试未达成, std::nullopt};
            break;
        case 用途观察阶段::待结算:
            候选.阶段负载 = {用途正式结果分类::任务已完成待需求结算,
                任务达成分量::已达成, 需求结算分量::待结算,
                用途观察阶段::待结算, std::nullopt};
            break;
        case 用途观察阶段::最终已结算:
            候选.阶段负载 = {用途正式结果分类::已完成并结算,
                任务达成分量::已达成, 需求结算分量::已满足,
                用途观察阶段::最终已结算, 节点组[15]};
            break;
        default:
            break;
        }
        return 候选;
    }

    结构计数 读取计数() const {
        auto 许可 = 接线.取得共享许可(接线.运行期状态);
        if (!许可.有效()) return {};
        return {节点.有效节点数量(许可.读取令牌()),
            关系.有效关系数量(许可.读取令牌()),
            索引.有效主键数量(许可.读取令牌())};
    }

    std::vector<关系记录> 读取用途关系(节点句柄 观察) const {
        auto 许可 = 接线.取得共享许可(接线.运行期状态);
        return 许可.有效()
            ? 关系.获取关系审计记录组(
                观察, 关系类型::用途观察证据角色, 许可.读取令牌())
            : std::vector<关系记录>{};
    }

    bool 绑定探测键到普通节点(
        const 用途观察语义身份& 身份,
        std::size_t 数量) {
        auto 许可 = 接线.取得独占许可(接线.运行期状态);
        if (!许可.有效() || 数量 > 用途观察最大探测次数) return false;
        for (std::size_t 序号 = 0; 序号 < 数量; ++序号) {
            const auto 键 = 形成用途观察物理键(身份, 1, 序号);
            if (!键.has_value()
                || !索引.绑定主键(*键, 节点组[17], 许可.读取令牌())) return false;
        }
        return true;
    }

    结构事务协调器 协调器;
    结构事务接线 接线;
    主信息仓库 主信息;
    节点仓库 节点;
    关系仓库 关系;
    索引仓库 索引;
    用途观察数据操作 数据操作;
    用途观察业务服务 服务;
    std::array<节点句柄, 19> 节点组{};
    bool 初始化完成 = false;

    bool 未知类型仍拒绝() {
        auto 许可 = 接线.取得独占许可(接线.运行期状态);
        if (!许可.有效()) return false;
        const auto& 令牌 = 许可.读取令牌();
        const auto 主信息句柄值 = 主信息.创建主信息(令牌);
        if (!句柄有效(主信息句柄值)) return false;
        const auto 错误节点 = 节点.创建节点(
            static_cast<节点类型>(999), 主信息句柄值, 令牌);
        const auto 错误关系 = 关系.创建关系(
            static_cast<关系类型>(999), 节点组[1], 节点组[2], 0, 令牌);
        return !句柄有效(错误节点) && !句柄有效(错误关系);
    }

    std::size_t 读取任务角色一数量(节点句柄 任务) const {
        auto 许可 = 接线.取得共享许可(接线.运行期状态);
        if (!许可.有效()) return 0;
        const auto 关系组 = 关系.获取来源关系记录组(
            任务, 关系类型::用途观察证据角色, 许可.读取令牌());
        return static_cast<std::size_t>(std::count_if(
            关系组.cbegin(), 关系组.cend(), [&](const auto& 记录) {
                return 记录.状态 == 记录状态::有效 && 记录.顺序号 == 1
                    && 记录.目标节点 == 任务;
            }));
    }

    std::optional<节点句柄> 构造异常观察(
        const 用途观察纯值候选& 候选,
        std::optional<std::size_t> 跳过槽,
        std::optional<std::pair<std::size_t, std::int64_t>> 覆盖槽 = std::nullopt) {
        if (!候选.合法()) return std::nullopt;
        const auto& 因果 = 候选.不可变核心.历史概率.因果身份;
        const auto& 概率 = 候选.不可变核心.历史概率;
        std::array<std::int64_t, 15> 槽{
            static_cast<std::int64_t>(候选.格式版本),
            static_cast<std::int64_t>(候选.身份.任务序号 >> 32),
            static_cast<std::int64_t>(候选.身份.任务序号 & 0xffffffffULL),
            因果.原因动态键.前状态值,
            因果.原因动态键.后状态值,
            static_cast<std::int64_t>(因果.原因动态键.规则版本),
            因果.结果动态键.前状态值,
            因果.结果动态键.后状态值,
            static_cast<std::int64_t>(因果.结果动态键.规则版本),
            static_cast<std::int64_t>(因果.因果规则版本),
            static_cast<std::int64_t>(因果.格式版本),
            static_cast<std::int64_t>(概率.机会数),
            static_cast<std::int64_t>(概率.正结果数),
            static_cast<std::int64_t>(概率.负结果数),
            static_cast<std::int64_t>(概率.Q10000)};
        if (覆盖槽.has_value()) {
            if (覆盖槽->first >= 槽.size()) return std::nullopt;
            槽[覆盖槽->first] = 覆盖槽->second;
        }
        auto 许可 = 接线.取得独占许可(接线.运行期状态);
        if (!许可.有效()) return std::nullopt;
        const auto& 令牌 = 许可.读取令牌();
        const auto 主信息句柄值 = 主信息.创建主信息(令牌);
        if (!句柄有效(主信息句柄值)) return std::nullopt;
        for (std::size_t 索引值 = 0; 索引值 < 槽.size(); ++索引值) {
            if (跳过槽 == std::optional<std::size_t>{索引值}) continue;
            if (!主信息.写入I64值(主信息句柄值, 索引值, 槽[索引值], 令牌)) {
                return std::nullopt;
            }
        }
        const auto 观察 = 节点.创建节点(
            节点类型::用途观察记录, 主信息句柄值, 令牌);
        const auto 物理键 = 形成用途观察物理键(候选.身份, 候选.格式版本, 0);
        if (!句柄有效(观察) || !物理键.has_value()
            || !索引.绑定主键(*物理键, 观察, 令牌)) return std::nullopt;
        const auto& 核心 = 候选.不可变核心;
        const std::array<节点句柄, 14> 目标组{
            候选.身份.任务, 核心.需求, 核心.选择记录, 核心.方法,
            核心.动作, 核心.场景, 核心.主体, 核心.目标状态,
            核心.实际状态, 核心.动态证据,
            因果.原因动态键.被改变目标, 因果.原因动态键.来源动作,
            因果.结果动态键.被改变目标, 因果.结果动态键.来源动作};
        for (std::size_t 索引值 = 0; 索引值 < 目标组.size(); ++索引值) {
            if (!句柄有效(关系.创建关系(
                    关系类型::用途观察证据角色, 观察, 目标组[索引值],
                    static_cast<std::int64_t>(索引值 + 1), 令牌))) {
                return std::nullopt;
            }
        }
        if (!句柄有效(关系.创建关系(
                关系类型::用途观察证据角色, 观察,
                候选.不可变核心.实际状态, 30, 令牌))) return std::nullopt;
        return 观察;
    }

private:
    bool 初始化端点() {
        static constexpr std::array<节点类型, 18> 类型组{
            节点类型::任务,
            节点类型::需求,
            节点类型::任务方法选择记录,
            节点类型::方法,
            节点类型::方法,
            节点类型::场景,
            节点类型::存在,
            节点类型::状态,
            节点类型::状态,
            节点类型::动态,
            节点类型::状态,
            节点类型::方法,
            节点类型::状态,
            节点类型::方法,
            节点类型::状态,
            节点类型::需求,
            节点类型::基础信息,
            节点类型::任务};
        auto 许可 = 接线.取得独占许可(接线.运行期状态);
        if (!许可.有效()) return false;
        for (std::size_t 索引值 = 0; 索引值 < 类型组.size(); ++索引值) {
            const auto 主信息句柄值 = 主信息.创建主信息(许可.读取令牌());
            const auto 节点句柄值 = 节点.创建节点(
                类型组[索引值], 主信息句柄值, 许可.读取令牌());
            if (!句柄有效(主信息句柄值) || !句柄有效(节点句柄值)) return false;
            节点组[索引值 + 1] = 节点句柄值;
        }
        return 数据操作.有效();
    }
};

bool FNV字节与常量正确() {
    const 用途观察语义身份 身份{
        {0x0102030405060708ULL, 0x1112131415161718ULL, 0x21222324U},
        0x3132333435363738ULL};
    const auto 字节 = 形成用途观察物理身份字节(身份, 1);
    const std::array<std::uint8_t, 36> 预期{
        0x32,0x53,0x31,0x4f,0x01,0x00,0x00,0x00,
        0x08,0x07,0x06,0x05,0x04,0x03,0x02,0x01,
        0x18,0x17,0x16,0x15,0x14,0x13,0x12,0x11,
        0x24,0x23,0x22,0x21,
        0x38,0x37,0x36,0x35,0x34,0x33,0x32,0x31};
    const auto 哈希 = 计算用途观察物理哈希(身份, 1);
    bool 探测均非零且唯一 = true;
    std::vector<std::uint64_t> 键组;
    for (std::size_t 序号 = 0; 序号 < 用途观察最大探测次数; ++序号) {
        const auto 键 = 形成用途观察物理键(身份, 1, 序号);
        if (!键.has_value() || *键 == 0
            || std::find(键组.cbegin(), 键组.cend(), *键) != 键组.cend()) {
            探测均非零且唯一 = false;
            break;
        }
        键组.push_back(*键);
    }
    return 字节 == std::optional<std::array<std::uint8_t, 36>>{预期}
        && 哈希 == std::optional<std::uint64_t>{0x6dfbba959576bfdbULL}
        && 形成用途观察物理键(身份, 1, 0) == 哈希
        && !形成用途观察物理键(身份, 1, 用途观察最大探测次数).has_value()
        && 探测均非零且唯一;
}

bool 低层关系合同正确(测试环境& 环境, const 用途观察结构业务结果& 新建) {
    if (!新建.成功()) return false;
    const auto 观察 = 新建.材料->观察节点;
    const auto 关系组 = 环境.读取用途关系(观察);
    const auto 阶段 = std::find_if(关系组.cbegin(), 关系组.cend(),
        [](const auto& 记录) { return 记录.顺序号 == 30 && 记录.状态 == 记录状态::有效; });
    const auto 角色九 = std::find_if(关系组.cbegin(), 关系组.cend(),
        [](const auto& 记录) { return 记录.顺序号 == 9 && 记录.状态 == 记录状态::有效; });
    if (阶段 == 关系组.cend() || 角色九 == 关系组.cend()
        || 阶段->目标节点 != 角色九->目标节点) return false;
    auto 许可 = 环境.接线.取得独占许可(环境.接线.运行期状态);
    if (!许可.有效()) return false;
    const auto& 令牌 = 许可.读取令牌();
    const auto 重复角色 = 环境.关系.创建关系(
        关系类型::用途观察证据角色, 观察, 环境.节点组[1], 1, 令牌);
    const auto 非法角色 = 环境.关系.创建关系(
        关系类型::用途观察证据角色, 观察, 环境.节点组[1], 16, 令牌);
    const auto 错误源 = 环境.关系.创建关系(
        关系类型::用途观察证据角色, 环境.节点组[17], 环境.节点组[1], 1, 令牌);
    const auto 错误目标 = 环境.关系.创建关系(
        关系类型::用途观察证据角色, 观察, 环境.节点组[2], 1, 令牌);
    const 关系句柄 阶段句柄{
        环境.协调器.读取域编号() + 3000, 阶段->关系编号, 阶段->版本号};
    const auto 非法失效 = 环境.关系.失效关系(阶段句柄, 令牌);
    const bool 删除拒绝 = !环境.关系.删除关系(阶段句柄, 令牌);
    const bool 重挂拒绝 = !环境.关系.重挂关系(
        阶段句柄, 观察, 环境.节点组[8], 令牌);
    return !句柄有效(重复角色) && !句柄有效(非法角色)
        && !句柄有效(错误源) && !句柄有效(错误目标)
        && 非法失效.状态 == 关系状态变更状态::状态转换不允许
        && 删除拒绝 && 重挂拒绝;
}

bool 破坏索引双证后拒绝且可恢复(
    测试环境& 环境,
    const 用途观察结构业务结果& 已发布) {
    if (!已发布.成功()) return false;
    const auto& 材料 = *已发布.材料;
    auto 许可 = 环境.接线.取得独占许可(环境.接线.运行期状态);
    if (!许可.有效()) return false;
    const bool 已破坏 = 环境.索引.自检删除反向绑定(
        材料.物理键, 材料.观察节点, 许可.读取令牌());
    if (!已破坏) return false;
    许可 = {};
    const auto 破坏后 = 环境.数据操作.读取完整身份(材料.候选.身份);
    auto 恢复许可 = 环境.接线.取得独占许可(环境.接线.运行期状态);
    const bool 已恢复 = 恢复许可.有效() && 环境.索引.自检追加反向绑定(
        材料.物理键, 材料.观察节点, 恢复许可.读取令牌());
    恢复许可 = {};
    const auto 恢复后 = 环境.数据操作.读取完整身份(材料.候选.身份);
    return 破坏后.状态 == 用途观察结构读取状态::内部不一致
        && 已恢复 && 恢复后.成功();
}

}

自检单元结果 运行用途观察结构自检(
    bool 许可内原子收口回归通过,
    bool 完整主信息投影回归通过,
    bool 用途观察纯值回归通过) {
    using namespace 用途观察结构自检内部;
    std::array<bool, 20> 验收{};
    try {
        测试环境 尝试环境(18801);
        测试环境 待结算环境(18802);
        测试环境 最终环境(18803);
        测试环境 碰撞环境(18804);
        测试环境 耗尽环境(18805);
        测试环境 资源失败环境(18806);
        测试环境 计数环境(18807);
        测试环境 未知类型环境(18808);
        测试环境 空投影环境(18809);
        测试环境 缺槽环境(18810);
        测试环境 空槽环境(18811);
        测试环境 未知格式环境(18812);
        测试环境 数值异常环境(18813);
        测试环境 公式异常环境(18814);

        验收[0] = 许可内原子收口回归通过 && 完整主信息投影回归通过
            && 用途观察纯值回归通过 && 尝试环境.初始化完成
            && 待结算环境.初始化完成 && 最终环境.初始化完成;
        验收[1] = static_cast<std::uint32_t>(节点类型::用途观察记录) == 15
            && static_cast<std::uint32_t>(关系类型::用途观察证据角色) == 18
            && 用途观察索引命名域 == 0x4F315332U
            && 用途观察索引规则版本 == 1
            && 单任务用途观察上限 == 1024 && 全局用途观察上限 == 65536
            && 单条用途观察规范字节上限 == 2048
            && 全部用途观察规范字节上限 == 134217728
            && 未知类型环境.初始化完成 && 未知类型环境.未知类型仍拒绝();

        const auto 尝试候选 = 尝试环境.形成候选(用途观察阶段::尝试未达成);
        const auto 尝试新建 = 尝试环境.数据操作.发布候选(尝试候选);
        验收[2] = 低层关系合同正确(尝试环境, 尝试新建);

        const auto 服务入口拒绝 = 尝试环境.服务.发布用途观察(用途事件结果{}, 1);
        const 用途事件结果 上游不支持{
            用途事件处理状态::不支持,
            用途事件拒绝原因::规则版本不支持,
            std::nullopt};
        const 用途事件结果 上游内部不一致{
            用途事件处理状态::内部不一致,
            用途事件拒绝原因::算法不变量破坏,
            std::nullopt};
        const auto 服务不支持 = 尝试环境.服务.发布用途观察(上游不支持, 1);
        const auto 服务内部不一致 = 尝试环境.服务.发布用途观察(上游内部不一致, 1);
        const auto 服务读回 = 尝试新建.成功()
            ? 尝试环境.服务.读取用途观察(尝试新建.材料->观察节点)
            : 用途观察结构读取结果{};
        验收[4] = 服务入口拒绝.状态 == 用途观察结构业务状态::入口拒绝
            && 服务入口拒绝.原因 == 用途观察结构业务原因::纯值入口拒绝
            && 服务不支持.状态 == 用途观察结构业务状态::不支持
            && 服务不支持.原因 == 用途观察结构业务原因::纯值不支持
            && 服务内部不一致.状态 == 用途观察结构业务状态::内部不一致
            && 服务内部不一致.原因 == 用途观察结构业务原因::纯值内部不一致
            && !服务入口拒绝.成功() && !服务不支持.成功()
            && !服务内部不一致.成功() && 服务读回.成功();

        测试环境 类型拒绝环境(18815);
        auto 类型错误候选 = 类型拒绝环境.形成候选(用途观察阶段::尝试未达成);
        类型错误候选.不可变核心.需求 = 类型拒绝环境.节点组[4];
        const auto 类型拒绝前 = 类型拒绝环境.读取计数();
        const auto 类型拒绝 = 类型拒绝环境.数据操作.发布候选(类型错误候选);
        const bool 类型拒绝零写 = 类型拒绝.状态 == 用途观察结构业务状态::入口拒绝
            && 类型拒绝.原因 == 用途观察结构业务原因::句柄类型不匹配
            && 类型拒绝环境.读取计数() == 类型拒绝前;

        验收[5] = FNV字节与常量正确();
        验收[6] = 尝试新建.状态 == 用途观察结构业务状态::已新建
            && 尝试新建.成功() && 尝试新建.材料->生命周期关系数量 == 15
            && 尝试新建.材料->当前角色目标[30]
                == std::optional<节点句柄>{尝试候选.不可变核心.实际状态}
            && 尝试环境.数据操作.读取观察节点(
                尝试新建.材料->观察节点).成功();

        const auto 待候选 = 待结算环境.形成候选(用途观察阶段::待结算);
        const auto 待新建 = 待结算环境.数据操作.发布候选(待候选);
        验收[7] = 待新建.状态 == 用途观察结构业务状态::已新建
            && 待新建.成功() && 待新建.材料->生命周期关系数量 == 15
            && 待新建.材料->当前角色目标[31]
                == std::optional<节点句柄>{待候选.不可变核心.实际状态};

        const auto 最终候选 = 最终环境.形成候选(用途观察阶段::最终已结算);
        const auto 最终新建 = 最终环境.数据操作.发布候选(最终候选);
        验收[8] = 最终新建.状态 == 用途观察结构业务状态::已新建
            && 最终新建.成功() && 最终新建.材料->生命周期关系数量 == 16
            && 最终新建.材料->当前角色目标[15] == 最终候选.阶段负载.正式结算状态
            && 最终新建.材料->当前角色目标[32] == 最终候选.阶段负载.正式结算状态;

        const auto 幂等前 = 尝试环境.读取计数();
        const auto 幂等 = 尝试环境.数据操作.发布候选(尝试候选);
        验收[9] = 幂等.状态 == 用途观察结构业务状态::已幂等
            && 幂等.成功() && 幂等.材料->观察节点 == 尝试新建.材料->观察节点
            && 幂等.材料->主信息 == 尝试新建.材料->主信息
            && 幂等.材料->物理键 == 尝试新建.材料->物理键
            && 尝试环境.读取计数() == 幂等前;

        auto 核心冲突候选 = 尝试候选;
        核心冲突候选.不可变核心.需求 = 尝试环境.节点组[16];
        const auto 冲突前 = 尝试环境.读取计数();
        const auto 核心冲突 = 尝试环境.数据操作.发布候选(核心冲突候选);
        const auto 阶段冲突 = 尝试环境.数据操作.发布候选(
            尝试环境.形成候选(用途观察阶段::待结算));
        验收[10] = 核心冲突.状态 == 用途观察结构业务状态::同账冲突
            && 核心冲突.原因 == 用途观察结构业务原因::不可变核心不同
            && 阶段冲突.状态 == 用途观察结构业务状态::同账冲突
            && 阶段冲突.原因 == 用途观察结构业务原因::阶段转换不允许
            && 尝试环境.读取计数() == 冲突前;

        const auto 推进前节点 = 待新建.材料->观察节点;
        const auto 推进前主信息 = 待新建.材料->主信息;
        const auto 推进前物理键 = 待新建.材料->物理键;
        const auto 推进 = 待结算环境.数据操作.发布候选(
            待结算环境.形成候选(用途观察阶段::最终已结算));
        验收[11] = 推进.状态 == 用途观察结构业务状态::已推进最终
            && 推进.成功() && 推进.材料->观察节点 == 推进前节点
            && 推进.材料->主信息 == 推进前主信息
            && 推进.材料->物理键 == 推进前物理键
            && 推进.材料->生命周期关系数量 == 17
            && 推进.材料->曾由待结算推进
            && 推进.材料->当前角色目标[15] == 推进.材料->当前角色目标[32];

        资源失败环境.节点.自检注入下一次节点记录组资源失败();
        const auto 资源失败前 = 资源失败环境.读取计数();
        const auto 资源失败 = 资源失败环境.数据操作.发布候选(
            资源失败环境.形成候选(用途观察阶段::尝试未达成));
        const auto 空读取 = 空投影环境.数据操作.读取完整身份(
            空投影环境.形成候选(用途观察阶段::尝试未达成).身份);
        std::cout << "CAUSAL-USE-O1-S2-EVIDENCE empty-read="
            << static_cast<int>(空读取.状态) << " resource-status="
            << static_cast<int>(资源失败.状态) << " resource-reason="
            << static_cast<int>(资源失败.原因) << '\n';
        验收[3] = 尝试新建.成功()
            && 空读取.状态 == 用途观察结构读取状态::未找到
            && 资源失败.状态 == 用途观察结构业务状态::内部不一致
            && 资源失败.原因 == 用途观察结构业务原因::读取资源失败;
        验收[12] = 破坏索引双证后拒绝且可恢复(尝试环境, 尝试新建)
            && 资源失败.状态 == 用途观察结构业务状态::内部不一致
            && 资源失败环境.读取计数() == 资源失败前;

        const auto 碰撞候选 = 碰撞环境.形成候选(用途观察阶段::尝试未达成);
        const bool 首键已占用 = 碰撞环境.绑定探测键到普通节点(碰撞候选.身份, 1);
        const auto 碰撞新建 = 碰撞环境.数据操作.发布候选(碰撞候选);
        const auto 耗尽候选 = 耗尽环境.形成候选(用途观察阶段::尝试未达成);
        const bool 全部键已占用 = 耗尽环境.绑定探测键到普通节点(
            耗尽候选.身份, 用途观察最大探测次数);
        const auto 耗尽前 = 耗尽环境.读取计数();
        const auto 耗尽 = 耗尽环境.数据操作.发布候选(耗尽候选);
        验收[13] = 首键已占用 && 碰撞新建.成功()
            && 碰撞新建.材料->探测序号 == 1
            && 全部键已占用
            && 耗尽.状态 == 用途观察结构业务状态::容量拒绝
            && 耗尽.原因 == 用途观察结构业务原因::物理键探测耗尽
            && 耗尽环境.读取计数() == 耗尽前;

        bool 槽完整 = false;
        {
            auto 许可 = 最终环境.接线.取得共享许可(最终环境.接线.运行期状态);
            const auto 记录 = 许可.有效() ? 最终环境.主信息.读取主信息(
                最终新建.材料->主信息, 许可.读取令牌()) : std::nullopt;
            槽完整 = 记录.has_value() && 记录->值容器.size() == 15
                && std::all_of(记录->值容器.cbegin(), 记录->值容器.cend(),
                    [](const auto& 值) { return 值.has_value(); });
        }
        {
            auto 许可 = 最终环境.接线.取得独占许可(最终环境.接线.运行期状态);
            if (许可.有效()) (void)最终环境.主信息.写入I64值(
                最终新建.材料->主信息, 15, 7, 许可.读取令牌());
        }
        const auto 多槽读回 = 最终环境.数据操作.读取观察节点(
            最终新建.材料->观察节点);
        const auto 缺槽观察 = 缺槽环境.构造异常观察(
            缺槽环境.形成候选(用途观察阶段::尝试未达成), 14);
        const auto 空槽观察 = 空槽环境.构造异常观察(
            空槽环境.形成候选(用途观察阶段::尝试未达成), 7);
        const auto 未知格式观察 = 未知格式环境.构造异常观察(
            未知格式环境.形成候选(用途观察阶段::尝试未达成),
            std::nullopt, std::pair<std::size_t, std::int64_t>{0, 2});
        const auto 数值异常观察 = 数值异常环境.构造异常观察(
            数值异常环境.形成候选(用途观察阶段::尝试未达成),
            std::nullopt, std::pair<std::size_t, std::int64_t>{11, 0});
        const auto 公式异常观察 = 公式异常环境.构造异常观察(
            公式异常环境.形成候选(用途观察阶段::尝试未达成),
            std::nullopt, std::pair<std::size_t, std::int64_t>{14, 4999});
        const auto 异常读回拒绝 = [](测试环境& 环境, const auto& 观察) {
            return 观察.has_value()
                && 环境.数据操作.读取观察节点(*观察).状态
                    == 用途观察结构读取状态::内部不一致;
        };
        验收[14] = 槽完整
            && 多槽读回.状态 == 用途观察结构读取状态::内部不一致
            && 异常读回拒绝(缺槽环境, 缺槽观察)
            && 异常读回拒绝(空槽环境, 空槽观察)
            && 异常读回拒绝(未知格式环境, 未知格式观察)
            && 异常读回拒绝(数值异常环境, 数值异常观察)
            && 异常读回拒绝(公式异常环境, 公式异常观察);

        const auto 计数一 = 计数环境.数据操作.发布候选(
            计数环境.形成候选(用途观察阶段::尝试未达成, 7001));
        const auto 计数二 = 计数环境.数据操作.发布候选(
            计数环境.形成候选(用途观察阶段::待结算, 7002));
        auto 第二任务候选 = 计数环境.形成候选(用途观察阶段::尝试未达成, 7003);
        第二任务候选.身份.任务 = 计数环境.节点组[18];
        const auto 计数三 = 计数环境.数据操作.发布候选(第二任务候选);
        std::size_t 用途节点数 = 0;
        std::uint64_t 用途索引数 = 0;
        {
            auto 许可 = 计数环境.接线.取得共享许可(计数环境.接线.运行期状态);
            const auto 节点读取 = 许可.有效()
                ? 计数环境.节点.读取指定类型有效节点记录组(
                    节点类型::用途观察记录, 许可.读取令牌())
                : 节点记录组读取结果{};
            if (节点读取.状态 == 节点记录组读取状态::已形成) {
                用途节点数 = 节点读取.记录组.size();
                用途索引数 = 计数环境.索引.有效主键数量(许可.读取令牌());
            }
        }
        验收[15] = 计数一.成功() && 计数二.成功() && 计数三.成功()
            && 用途节点数 == 3 && 用途索引数 == 3
            && 计数环境.读取任务角色一数量(计数环境.节点组[1]) == 2
            && 计数环境.读取任务角色一数量(计数环境.节点组[18]) == 1
            && 3 * 单条用途观察规范字节上限 == 6144
            && 全局用途观察上限 * 单条用途观察规范字节上限
                == 全部用途观察规范字节上限;

        验收[16] = 类型拒绝零写 && 验收[12] && 许可内原子收口回归通过
            && 资源失败环境.读取计数() == 资源失败前;
        验收[17] = std::is_constructible_v<用途观察数据操作,
                结构事务接线, 主信息仓库&, 节点仓库&, 关系仓库&, 索引仓库&, std::uint64_t>
            && std::is_constructible_v<用途观察业务服务, 用途观察数据操作&>
            && std::is_same_v<decltype(std::declval<const 用途观察业务服务&>()
                .发布用途观察(std::declval<const 用途事件结果&>(), std::uint32_t{})),
                用途观察结构业务结果>
            && !std::is_pointer_v<用途观察完整值式材料>;
        验收[18] = std::all_of(
            验收.begin(), 验收.begin() + 18, [](bool 当前) { return 当前; });
        验收[19] = 验收[18] && 许可内原子收口回归通过
            && 完整主信息投影回归通过 && 用途观察纯值回归通过;
    } catch (...) {
        验收.fill(false);
    }

    const auto 失败数量 = static_cast<std::size_t>(std::count(
        验收.cbegin(), 验收.cend(), false));
    for (std::size_t 索引 = 0; 索引 < 验收.size(); ++索引) {
        std::cout << "CAUSAL-USE-O1-S2-A" << (索引 + 1 < 10 ? "0" : "")
            << 索引 + 1 << '=' << (验收[索引] ? "PASS" : "FAIL") << '\n';
    }
    return {"CAUSAL-USE-O1-S2", "权威用途观察运行期结构发布与完整读回",
        失败数量 == 0, 验收.size(), 失败数量};
}

}
#endif
