// 文件规则：概念结构发布组合器只组合根角色复核和一组创建型概念关系。
module;

#include <vector>

export module 海中鱼巣.领域.组合.概念结构发布;

import 海中鱼巣.领域.数据操作.概念图结构;
import 海中鱼巣.领域.服务.概念图结构;

export namespace 海中鱼巣 {

struct 发布概念结构请求 {
    复核概念根角色请求 根角色;
    std::vector<概念结构关系请求> 关系组;
};

struct 概念结构发布结果 {
    概念根角色组值式材料 根角色;
    概念图结构业务结果 关系结果;

    bool 成功() const noexcept {
        return 根角色.完整() && 关系结果.成功();
    }
};

class 概念结构发布组合器 final {
public:
    explicit 概念结构发布组合器(概念图结构业务服务& 业务服务)
        : 业务服务_(业务服务) {}

    概念结构发布结果 发布(const 发布概念结构请求& 请求) const {
        概念结构发布结果 输出;
        if (请求.关系组.empty()) return 输出;
        输出.根角色 = 业务服务_.复核根角色组(请求.根角色);
        if (!输出.根角色.完整()) return 输出;
        输出.关系结果 = 业务服务_.创建关系组({
            输出.根角色.根角色, 请求.关系组});
        return 输出;
    }

private:
    概念图结构业务服务& 业务服务_;
};

}
