// 文件规则：本模块只编排关系 19/20、状态/动态记录、索引和核心事务，并导出两个窄提供者。
module;

#include "../核心/句柄.h"
#include "节点直接领域合同.数据.h"

#include <algorithm>
#include <array>
#include <cstddef>
#include <cstdint>
#include <functional>
#include <limits>
#include <new>
#include <optional>
#include <span>
#include <utility>
#include <vector>

export module 海中鱼巣.领域.数据操作.节点直接状态动态;

export import 海中鱼巣.领域.参与者.状态动态类型化记录;

export namespace 海中鱼巣 {

class 节点直接状态动态数据操作;

class 状态动态冻结提供者 final {
public:
    状态动态冻结提供者(const 状态动态冻结提供者&) = delete;
    状态动态冻结提供者& operator=(const 状态动态冻结提供者&) = delete;
    状态动态冻结提供者(状态动态冻结提供者&& 来源) noexcept
        : 数据操作_(std::exchange(来源.数据操作_, nullptr)) {
    }
    状态动态冻结提供者& operator=(状态动态冻结提供者&& 来源) noexcept {
        if (this != &来源) 数据操作_ = std::exchange(来源.数据操作_, nullptr);
        return *this;
    }

    bool 有效() const noexcept;

    状态动态同代次冻结结果 复制同代次状态动态全量(
        const 节点直接统一冻结许可& 许可) const;

private:
    friend class 节点直接状态动态数据操作;
    explicit 状态动态冻结提供者(
        const 节点直接状态动态数据操作& 数据操作) noexcept
        : 数据操作_(&数据操作) {
    }

    const 节点直接状态动态数据操作* 数据操作_ = nullptr;
};

class 状态动态记录退役提供者 final {
public:
    状态动态记录退役提供者(const 状态动态记录退役提供者&) = delete;
    状态动态记录退役提供者& operator=(const 状态动态记录退役提供者&) = delete;
    状态动态记录退役提供者(状态动态记录退役提供者&& 来源) noexcept
        : 数据操作_(std::exchange(来源.数据操作_, nullptr)) {
    }
    状态动态记录退役提供者& operator=(状态动态记录退役提供者&& 来源) noexcept {
        if (this != &来源) 数据操作_ = std::exchange(来源.数据操作_, nullptr);
        return *this;
    }

    bool 有效() const noexcept;

    状态记录退役参与包形成结果 形成状态记录退役参与包(
        const 状态退役规格& 规格) const;

    动态记录退役参与包形成结果 形成动态记录退役参与包(
        const 动态退役规格& 规格) const;

private:
    friend class 节点直接状态动态数据操作;
    explicit 状态动态记录退役提供者(
        const 节点直接状态动态数据操作& 数据操作) noexcept
        : 数据操作_(&数据操作) {
    }

    const 节点直接状态动态数据操作* 数据操作_ = nullptr;
};

class 节点直接状态动态数据操作 final {
public:
    节点直接状态动态数据操作(
        节点直接身份结构事务域& 事务域,
        节点直接身份仓库& 节点,
        正式关系仓库& 关系,
        可重建索引仓库& 索引,
        状态类型化记录仓& 状态记录仓,
        动态类型化记录仓& 动态记录仓) noexcept
        : 事务域_(&事务域), 节点_(&节点), 关系_(&关系), 索引_(&索引),
          状态记录仓_(&状态记录仓), 动态记录仓_(&动态记录仓) {
    }

    bool 有效() const noexcept {
        return 事务域_ != nullptr && 节点_ != nullptr && 关系_ != nullptr
            && 索引_ != nullptr && 状态记录仓_ != nullptr
            && 动态记录仓_ != nullptr && !事务域_->已隔离();
    }

    完整状态写入结果 创建完整状态事实(
        const 完整实例状态请求& 请求) {
        if (!状态请求字段有效(请求)) {
            return {合同结果状态::入口拒绝, 合同结果原因::无效身份};
        }
        auto 许可 = 事务域_->取得读取许可();
        if (!许可.有效()) {
            return {合同结果状态::许可竞争, 合同结果原因::并发许可失败};
        }
        const auto 写前 = 复核状态请求_已许可(请求);
        if (写前.状态 == 合同结果状态::幂等读回 && 写前.材料.has_value()) {
            return {合同结果状态::幂等读回, 合同结果原因::无,
                std::move(写前.材料), 状态记录结构版本()};
        }
        if (写前.状态 != 合同结果状态::合法未找到) {
            return {写前.状态, 写前.原因};
        }
        许可 = {};

        状态类型化记录事务参与者 记录参与者(*状态记录仓_);
        节点句柄 新状态;
        std::optional<无值映射结果> 锁内失败;
        节点直接身份结构写入执行器 执行器(事务域_, 节点_, 关系_, 索引_);
        const auto 执行结果 = 执行器.执行(
            [&](节点直接身份结构写入会话& 会话) {
                const auto 锁内复核 = 复核状态请求_会话(会话, 请求);
                if (锁内复核.状态 != 合同结果状态::合法未找到) {
                    锁内失败 = {锁内复核.状态, 锁内复核.原因};
                    return;
                }
                const auto 节点结果 = 会话.创建节点候选(
                    节点类型::状态, 请求.状态稳定主键);
                if (!节点结果.成功()) {
                    锁内失败 = 映射结构写入结果(节点结果.操作);
                    return;
                }
                新状态 = *节点结果.值;
                if (!写入状态关系组_会话(会话, 新状态, 请求)
                    || !记录参与者.登记初始记录({
                        新状态, 请求.发生时间, 请求.接收时间, 请求.记录模式})
                    || !写入节点索引_会话(
                        会话, 请求.状态稳定主键, 新状态, 状态索引命名域)) {
                    抛出事务内部不一致();
                }
                会话.请求提交();
            },
            记录参与者);
        if (锁内失败.has_value()) {
            return {锁内失败->状态, 锁内失败->原因};
        }
        const auto 映射 = 映射结构写入结果(执行结果);
        if (映射.状态 != 合同结果状态::成功
            && 映射.状态 != 合同结果状态::幂等读回) {
            return {映射.状态, 映射.原因};
        }
        const auto 读回 = 读取完整状态事实(新状态);
        if (!读回.成功()) {
            return {合同结果状态::内部错误,
                合同结果原因::权威读回不一致};
        }
        return {映射.状态, 合同结果原因::无, 读回.材料,
            状态记录结构版本()};
    }

    完整状态读取结果 读取完整状态事实(节点句柄 状态) const {
        if (!有效() || !句柄有效(状态)) {
            return {合同结果状态::入口拒绝, 合同结果原因::无效身份};
        }
        auto 许可 = 事务域_->取得读取许可();
        if (!许可.有效()) {
            return {合同结果状态::许可竞争, 合同结果原因::并发许可失败};
        }
        return 读取完整状态事实_已许可(状态);
    }

    主体状态事实组读取结果 读取主体状态事实组(
        节点句柄 主体) const {
        if (!有效() || !句柄有效(主体)) {
            return {合同结果状态::入口拒绝, 合同结果原因::无效身份};
        }
        auto 许可 = 事务域_->取得读取许可();
        if (!许可.有效()) {
            return {合同结果状态::许可竞争, 合同结果原因::并发许可失败};
        }
        const auto 主体节点 = 节点_->读取节点(主体);
        if (!主体节点.has_value()) {
            return {合同结果状态::入口拒绝, 合同结果原因::错版本};
        }
        if (主体节点->类型 != 节点类型::存在) {
            return {合同结果状态::入口拒绝, 合同结果原因::错类型};
        }
        主体状态事实组值式材料 材料;
        材料.主体 = 主体;
        材料.读取结构版本 = 状态类型化记录只读访问器(
            *状态记录仓_).读取结构版本();
        if (材料.读取结构版本 == 0) {
            return {合同结果状态::许可竞争, 合同结果原因::并发许可失败};
        }
        const auto 入向 = 关系_->读取指向有效关系组(
            主体, 关系类型::状态事实角色);
        try {
            for (const auto& 证据 : 入向) {
                if (证据.顺序号 != 状态主体角色) continue;
                const auto 项目 = 读取完整状态事实_已许可(证据.源节点);
                if (!项目.成功()
                    || !正式关系记录完整(证据)
                    || 证据.类型 != 关系类型::状态事实角色
                    || 证据.目标节点 != 主体
                    || 证据.状态 != 记录状态::有效
                    || 项目.材料->主体证据.目标节点 != 主体
                    || std::find_if(
                        材料.项目组.cbegin(), 材料.项目组.cend(),
                        [&项目](const auto& 已有) {
                            return 已有.状态 == 项目.材料->状态;
                        }) != 材料.项目组.cend()) {
                    return {合同结果状态::内部错误,
                        合同结果原因::权威读回不一致};
                }
                材料.项目组.push_back(*项目.材料);
            }
        } catch (...) {
            return {合同结果状态::内部错误,
                合同结果原因::权威读回不一致};
        }
        std::sort(材料.项目组.begin(), 材料.项目组.end(),
            [](const auto& 左, const auto& 右) {
                if (左.发生时间 != 右.发生时间) return 左.发生时间 < 右.发生时间;
                return 句柄小于(左.状态, 右.状态);
            });
        const auto 状态 = 材料.项目组.empty()
            ? 合同结果状态::合法空组 : 合同结果状态::成功;
        return {状态, 合同结果原因::无, std::move(材料)};
    }

    状态动态迁移写入结果 创建完整状态并记录迁移动能(
        const 完整实例状态请求& 前请求,
        const 完整实例状态请求& 后请求,
        const 节点稳定主键& 动态稳定主键,
        节点句柄 被改变目标) {
        if (!状态迁移组合字段有效(
                前请求, 后请求, 动态稳定主键, 被改变目标)) {
            return {合同结果状态::入口拒绝,
                合同结果原因::关系角色不合法};
        }
        auto 许可 = 事务域_->取得读取许可();
        if (!许可.有效()) {
            return {合同结果状态::许可竞争,
                合同结果原因::并发许可失败};
        }
        const auto 前写前 = 复核状态请求_已许可(前请求);
        const auto 后写前 = 复核状态请求_已许可(后请求);
        if (前写前.状态 == 合同结果状态::幂等读回
            && 后写前.状态 == 合同结果状态::幂等读回
            && 前写前.材料.has_value() && 后写前.材料.has_value()) {
            const auto 动态请求 = 形成迁移动能请求(
                动态稳定主键, 被改变目标,
                前写前.材料->状态, 后写前.材料->状态, 后请求);
            const auto 动态写前 = 复核动态请求_已许可(动态请求);
            if (动态写前.状态 != 合同结果状态::幂等读回
                || !动态写前.材料.has_value()) {
                return {动态写前.状态 == 合同结果状态::合法未找到
                        ? 合同结果状态::写前漂移 : 动态写前.状态,
                    动态写前.状态 == 合同结果状态::合法未找到
                        ? 合同结果原因::同键异义 : 动态写前.原因};
            }
            const auto 状态版本 = 状态记录结构版本();
            const auto 动态版本 = 动态记录结构版本();
            if (状态版本 == 0 || 动态版本 == 0) {
                return {合同结果状态::许可竞争,
                    合同结果原因::并发许可失败};
            }
            return {合同结果状态::幂等读回, 合同结果原因::无,
                状态动态迁移值式材料{
                    *前写前.材料, *后写前.材料, *动态写前.材料},
                状态版本, 动态版本};
        }
        if (前写前.状态 != 合同结果状态::合法未找到
            || 后写前.状态 != 合同结果状态::合法未找到) {
            if ((前写前.状态 == 合同结果状态::幂等读回
                    && 后写前.状态 == 合同结果状态::合法未找到)
                || (后写前.状态 == 合同结果状态::幂等读回
                    && 前写前.状态 == 合同结果状态::合法未找到)) {
                return {合同结果状态::写前漂移,
                    合同结果原因::同键异义};
            }
            const auto& 失败 = 前写前.状态 != 合同结果状态::合法未找到
                ? 前写前 : 后写前;
            return {失败.状态, 失败.原因};
        }
        const auto 动态当前 = 节点_->读取稳定主键当前身份(动态稳定主键);
        if (动态当前.状态 == 稳定主键当前身份状态::内部不一致) {
            return {合同结果状态::内部错误,
                合同结果原因::权威读回不一致};
        }
        if (动态当前.状态 != 稳定主键当前身份状态::未占用) {
            return {合同结果状态::入口拒绝,
                合同结果原因::同键异义};
        }
        许可 = {};

        状态类型化记录事务参与者 状态记录参与者(*状态记录仓_);
        动态类型化记录事务参与者 动态记录参与者(*动态记录仓_);
        节点句柄 前状态;
        节点句柄 后状态;
        节点句柄 迁移动能;
        std::optional<无值映射结果> 锁内失败;
        节点直接身份结构写入执行器 执行器(
            事务域_, 节点_, 关系_, 索引_);
        std::array<节点直接身份结构写入事务参与者*, 2> 参与者组{
            &状态记录参与者, &动态记录参与者};
        const auto 执行结果 = 执行器.执行(
            [&](节点直接身份结构写入会话& 会话) {
                const auto 前复核 = 复核状态请求_会话(会话, 前请求);
                const auto 后复核 = 复核状态请求_会话(会话, 后请求);
                if (前复核.状态 != 合同结果状态::合法未找到
                    || 后复核.状态 != 合同结果状态::合法未找到) {
                    const auto& 失败 =
                        前复核.状态 != 合同结果状态::合法未找到
                        ? 前复核 : 后复核;
                    锁内失败 = {失败.状态, 失败.原因};
                    return;
                }
                const auto 动态复核 =
                    会话.读取稳定主键当前身份(动态稳定主键);
                if (动态复核.状态 != 稳定主键当前身份状态::未占用) {
                    锁内失败 = {合同结果状态::写前漂移,
                        合同结果原因::同键异义};
                    return;
                }

                const auto 前节点 = 会话.创建节点候选(
                    节点类型::状态, 前请求.状态稳定主键);
                const auto 后节点 = 会话.创建节点候选(
                    节点类型::状态, 后请求.状态稳定主键);
                if (!前节点.成功() || !后节点.成功()) {
                    锁内失败 = !前节点.成功()
                        ? 映射结构写入结果(前节点.操作)
                        : 映射结构写入结果(后节点.操作);
                    return;
                }
                前状态 = *前节点.值;
                后状态 = *后节点.值;
                if (!写入状态关系组_会话(会话, 前状态, 前请求)
                    || !写入状态关系组_会话(会话, 后状态, 后请求)
                    || !状态记录参与者.登记初始记录({
                        前状态, 前请求.发生时间,
                        前请求.接收时间, 前请求.记录模式})
                    || !状态记录参与者.登记初始记录({
                        后状态, 后请求.发生时间,
                        后请求.接收时间, 后请求.记录模式})
                    || !写入节点索引_会话(
                        会话, 前请求.状态稳定主键,
                        前状态, 状态索引命名域)
                    || !写入节点索引_会话(
                        会话, 后请求.状态稳定主键,
                        后状态, 状态索引命名域)) {
                    抛出事务内部不一致();
                }

                const auto 动态请求 = 形成迁移动能请求(
                    动态稳定主键, 被改变目标,
                    前状态, 后状态, 后请求);
                const auto 动态端点复核 =
                    复核动态请求_会话(会话, 动态请求);
                if (动态端点复核.状态
                    != 合同结果状态::合法未找到) {
                    锁内失败 = {
                        动态端点复核.状态, 动态端点复核.原因};
                    return;
                }
                const auto 动态节点 = 会话.创建节点候选(
                    节点类型::动态, 动态稳定主键);
                if (!动态节点.成功()) {
                    锁内失败 = 映射结构写入结果(动态节点.操作);
                    return;
                }
                迁移动能 = *动态节点.值;
                if (!写入动态关系组_会话(
                        会话, 迁移动能, 动态请求)
                    || !动态记录参与者.登记初始记录({
                        迁移动能, 动态请求.发生时间,
                        动态请求.种类, 动态请求.聚合规则版本})
                    || !写入节点索引_会话(
                        会话, 动态稳定主键,
                        迁移动能, 动态索引命名域)) {
                    抛出事务内部不一致();
                }
                会话.请求提交();
            },
            std::span<节点直接身份结构写入事务参与者* const>(参与者组));
        if (锁内失败.has_value()) {
            return {锁内失败->状态, 锁内失败->原因};
        }
        const auto 映射 = 映射结构写入结果(执行结果);
        if (映射.状态 != 合同结果状态::成功) {
            return {映射.状态, 映射.原因};
        }
        const auto 前读回 = 读取完整状态事实(前状态);
        const auto 后读回 = 读取完整状态事实(后状态);
        const auto 动态读回 = 读取完整动态事实(迁移动能);
        const auto 状态版本 = 状态记录结构版本();
        const auto 动态版本 = 动态记录结构版本();
        if (!前读回.成功() || !后读回.成功() || !动态读回.成功()
            || 状态版本 == 0 || 动态版本 == 0) {
            return {合同结果状态::内部错误,
                合同结果原因::权威读回不一致};
        }
        return {合同结果状态::成功, 合同结果原因::无,
            状态动态迁移值式材料{
                *前读回.材料, *后读回.材料, *动态读回.材料},
            状态版本, 动态版本};
    }

    完整动态写入结果 创建完整动态事实(
        const 完整动态请求& 请求) {
        if (!动态请求字段有效(请求)) {
            return {合同结果状态::入口拒绝, 合同结果原因::无效身份};
        }
        auto 许可 = 事务域_->取得读取许可();
        if (!许可.有效()) {
            return {合同结果状态::许可竞争, 合同结果原因::并发许可失败};
        }
        const auto 写前 = 复核动态请求_已许可(请求);
        if (写前.状态 == 合同结果状态::幂等读回 && 写前.材料.has_value()) {
            return {合同结果状态::幂等读回, 合同结果原因::无,
                std::move(写前.材料), 动态记录结构版本()};
        }
        if (写前.状态 != 合同结果状态::合法未找到) {
            return {写前.状态, 写前.原因};
        }
        许可 = {};

        动态类型化记录事务参与者 记录参与者(*动态记录仓_);
        节点句柄 新动态;
        std::optional<无值映射结果> 锁内失败;
        节点直接身份结构写入执行器 执行器(事务域_, 节点_, 关系_, 索引_);
        const auto 执行结果 = 执行器.执行(
            [&](节点直接身份结构写入会话& 会话) {
                const auto 锁内复核 = 复核动态请求_会话(会话, 请求);
                if (锁内复核.状态 != 合同结果状态::合法未找到) {
                    锁内失败 = {锁内复核.状态, 锁内复核.原因};
                    return;
                }
                const auto 节点结果 = 会话.创建节点候选(
                    节点类型::动态, 请求.动态稳定主键);
                if (!节点结果.成功()) {
                    锁内失败 = 映射结构写入结果(节点结果.操作);
                    return;
                }
                新动态 = *节点结果.值;
                if (!写入动态关系组_会话(会话, 新动态, 请求)
                    || !记录参与者.登记初始记录({
                        新动态, 请求.发生时间, 请求.种类, 请求.聚合规则版本})
                    || !写入节点索引_会话(
                        会话, 请求.动态稳定主键, 新动态, 动态索引命名域)) {
                    抛出事务内部不一致();
                }
                会话.请求提交();
            },
            记录参与者);
        if (锁内失败.has_value()) {
            return {锁内失败->状态, 锁内失败->原因};
        }
        const auto 映射 = 映射结构写入结果(执行结果);
        if (映射.状态 != 合同结果状态::成功
            && 映射.状态 != 合同结果状态::幂等读回) {
            return {映射.状态, 映射.原因};
        }
        const auto 读回 = 读取完整动态事实(新动态);
        if (!读回.成功()) {
            return {合同结果状态::内部错误,
                合同结果原因::权威读回不一致};
        }
        return {映射.状态, 合同结果原因::无, 读回.材料,
            动态记录结构版本()};
    }

    完整动态读取结果 读取完整动态事实(节点句柄 动态) const {
        if (!有效() || !句柄有效(动态)) {
            return {合同结果状态::入口拒绝, 合同结果原因::无效身份};
        }
        auto 许可 = 事务域_->取得读取许可();
        if (!许可.有效()) {
            return {合同结果状态::许可竞争, 合同结果原因::并发许可失败};
        }
        return 读取完整动态事实_已许可(动态);
    }

    主体动态事实组读取结果 读取主体动态事实组(
        节点句柄 主体) const {
        if (!有效() || !句柄有效(主体)) {
            return {合同结果状态::入口拒绝, 合同结果原因::无效身份};
        }
        auto 许可 = 事务域_->取得读取许可();
        if (!许可.有效()) {
            return {合同结果状态::许可竞争, 合同结果原因::并发许可失败};
        }
        const auto 主体节点 = 节点_->读取节点(主体);
        if (!主体节点.has_value()) {
            return {合同结果状态::入口拒绝, 合同结果原因::错版本};
        }
        if (主体节点->类型 != 节点类型::存在) {
            return {合同结果状态::入口拒绝, 合同结果原因::错类型};
        }
        主体动态事实组值式材料 材料;
        材料.主体 = 主体;
        材料.读取结构版本 = 动态类型化记录只读访问器(
            *动态记录仓_).读取结构版本();
        if (材料.读取结构版本 == 0) {
            return {合同结果状态::许可竞争, 合同结果原因::并发许可失败};
        }
        const auto 入向 = 关系_->读取指向有效关系组(
            主体, 关系类型::动态事实角色);
        try {
            for (const auto& 证据 : 入向) {
                if (证据.顺序号 != 动态主体角色) continue;
                const auto 项目 = 读取完整动态事实_已许可(证据.源节点);
                if (!项目.成功()
                    || !正式关系记录完整(证据)
                    || 证据.类型 != 关系类型::动态事实角色
                    || 证据.目标节点 != 主体
                    || 证据.状态 != 记录状态::有效
                    || 项目.材料->主体证据.目标节点 != 主体
                    || std::find_if(
                        材料.项目组.cbegin(), 材料.项目组.cend(),
                        [&项目](const auto& 已有) {
                            return 已有.动态 == 项目.材料->动态;
                        }) != 材料.项目组.cend()) {
                    return {合同结果状态::内部错误,
                        合同结果原因::权威读回不一致};
                }
                材料.项目组.push_back(*项目.材料);
            }
        } catch (...) {
            return {合同结果状态::内部错误,
                合同结果原因::权威读回不一致};
        }
        std::sort(材料.项目组.begin(), 材料.项目组.end(),
            [](const auto& 左, const auto& 右) {
                if (左.发生时间 != 右.发生时间) return 左.发生时间 < 右.发生时间;
                return 句柄小于(左.动态, 右.动态);
            });
        const auto 状态 = 材料.项目组.empty()
            ? 合同结果状态::合法空组 : 合同结果状态::成功;
        return {状态, 合同结果原因::无, std::move(材料)};
    }

    状态退役规格结果 形成状态退役规格(
        节点句柄 状态,
        std::uint32_t 预期节点版本) const {
        if (!句柄有效(状态) || 预期节点版本 == 0) {
            return {合同结果状态::入口拒绝, 合同结果原因::无效身份};
        }
        const auto 材料 = 读取完整状态事实(状态);
        if (!材料.成功()) return {材料.状态, 材料.原因};
        if (材料.材料->节点版本 != 预期节点版本) {
            return {合同结果状态::写前漂移, 合同结果原因::错版本};
        }
        return {合同结果状态::成功, 合同结果原因::无,
            状态退役规格{状态, 预期节点版本}};
    }

    动态退役规格结果 形成动态退役规格(
        节点句柄 动态,
        std::uint32_t 预期节点版本) const {
        if (!句柄有效(动态) || 预期节点版本 == 0) {
            return {合同结果状态::入口拒绝, 合同结果原因::无效身份};
        }
        const auto 材料 = 读取完整动态事实(动态);
        if (!材料.成功()) return {材料.状态, 材料.原因};
        if (材料.材料->节点版本 != 预期节点版本) {
            return {合同结果状态::写前漂移, 合同结果原因::错版本};
        }
        return {合同结果状态::成功, 合同结果原因::无,
            动态退役规格{动态, 预期节点版本}};
    }

    带值读取结果<状态退役材料> 读取状态退役材料(
        节点句柄 状态) const {
        if (!有效() || !句柄有效(状态)) {
            return {合同结果状态::入口拒绝,
                合同结果原因::无效身份};
        }
        auto 许可 = 事务域_->取得读取许可();
        if (!许可.有效()) {
            return {合同结果状态::许可竞争,
                合同结果原因::并发许可失败};
        }
        const auto 事实 = 读取完整状态事实_已许可(状态);
        if (!事实.成功()) return {事实.状态, 事实.原因};
        状态退役材料 材料;
        材料.状态 = 状态;
        材料.节点版本 = 事实.材料->节点版本;
        材料.记录版本 = 事实.材料->记录版本;
        材料.关系19组 = 关系_->读取有效关系组(
            状态, 关系类型::状态事实角色);
        const auto 被引用 = 关系_->读取指向有效关系组(
            状态, 关系类型::动态事实角色);
        for (const auto& 关系 : 被引用) {
            if (关系.顺序号 == 动态前状态角色
                || 关系.顺序号 == 动态后状态角色) {
                材料.被动态引用组.push_back(关系);
            }
        }
        return {合同结果状态::成功, 合同结果原因::无, std::move(材料)};
    }

    带值读取结果<动态退役材料> 读取动态退役材料(
        节点句柄 动态) const {
        if (!有效() || !句柄有效(动态)) {
            return {合同结果状态::入口拒绝,
                合同结果原因::无效身份};
        }
        auto 许可 = 事务域_->取得读取许可();
        if (!许可.有效()) {
            return {合同结果状态::许可竞争,
                合同结果原因::并发许可失败};
        }
        const auto 事实 = 读取完整动态事实_已许可(动态);
        if (!事实.成功()) return {事实.状态, 事实.原因};
        动态退役材料 材料;
        材料.动态 = 动态;
        材料.节点版本 = 事实.材料->节点版本;
        材料.记录版本 = 事实.材料->记录版本;
        材料.关系20组 = 关系_->读取有效关系组(
            动态, 关系类型::动态事实角色);
        const auto 被引用 = 关系_->读取指向有效关系组(
            动态, 关系类型::动态事实角色);
        for (const auto& 关系 : 被引用) {
            if (关系.顺序号 == 动态来源低层角色
                || 关系.顺序号 == 动态同源迁移角色) {
                材料.被聚合或同源引用组.push_back(关系);
            }
        }
        return {合同结果状态::成功, 合同结果原因::无, std::move(材料)};
    }

    状态动态记录退役提供者 形成记录退役提供者() noexcept {
        return 状态动态记录退役提供者(*this);
    }

    状态动态冻结提供者 形成冻结提供者() const noexcept {
        return 状态动态冻结提供者(*this);
    }

private:
    friend class 状态动态冻结提供者;
    friend class 状态动态记录退役提供者;

    struct 事务内部不一致异常 final {
    };

    struct 无值映射结果 final {
        合同结果状态 状态 = 合同结果状态::入口拒绝;
        合同结果原因 原因 = 合同结果原因::无效身份;
    };

    static constexpr std::int64_t 状态主体角色 = 1;
    static constexpr std::int64_t 状态场景角色 = 2;
    static constexpr std::int64_t 状态特征角色 = 3;
    static constexpr std::int64_t 状态值角色 = 4;
    static constexpr std::int64_t 状态来源存在角色 = 5;
    static constexpr std::int64_t 动态主体角色 = 1;
    static constexpr std::int64_t 动态场景角色 = 2;
    static constexpr std::int64_t 动态目标角色 = 3;
    static constexpr std::int64_t 动态前状态角色 = 4;
    static constexpr std::int64_t 动态后状态角色 = 5;
    static constexpr std::int64_t 动态来源动作角色 = 6;
    static constexpr std::int64_t 动态来源低层角色 = 7;
    static constexpr std::int64_t 动态同源迁移角色 = 8;
    static constexpr std::int64_t 动态来源存在角色 = 9;
    static constexpr std::uint64_t 索引所有者身份 = 0x4E54503242000001ULL;
    static constexpr std::uint32_t 状态索引命名域 = 1;
    static constexpr std::uint32_t 动态索引命名域 = 2;

    [[noreturn]] static void 抛出事务内部不一致() {
        throw 事务内部不一致异常{};
    }

    static bool 句柄小于(节点句柄 左, 节点句柄 右) noexcept {
        if (左.仓库编号 != 右.仓库编号) return 左.仓库编号 < 右.仓库编号;
        if (左.节点编号 != 右.节点编号) return 左.节点编号 < 右.节点编号;
        return 左.版本号 < 右.版本号;
    }

    static bool 主键属于(
        const 节点稳定主键& 主键,
        节点稳定主键命名域 命名域) noexcept {
        return 稳定主键有效(主键)
            && 主键.命名域 == static_cast<std::uint64_t>(命名域);
    }

    static bool 状态请求字段有效(const 完整实例状态请求& 请求) noexcept {
        return 主键属于(请求.状态稳定主键, 节点稳定主键命名域::状态身份)
            && 句柄有效(请求.主体) && 句柄有效(请求.场景)
            && 句柄有效(请求.特征) && 句柄有效(请求.特征值)
            && 句柄有效(请求.来源存在) && 请求.发生时间 != 0
            && (!请求.接收时间.has_value()
                || *请求.接收时间 >= 请求.发生时间)
            && 状态记录模式有效(请求.记录模式);
    }

    static bool 动态请求字段有效(const 完整动态请求& 请求) noexcept {
        if (!主键属于(请求.动态稳定主键, 节点稳定主键命名域::动态身份)
            || !句柄有效(请求.主体) || !句柄有效(请求.场景)
            || !句柄有效(请求.被改变目标) || !句柄有效(请求.前状态)
            || !句柄有效(请求.后状态) || !句柄有效(请求.来源存在)
            || 请求.前状态 == 请求.后状态 || 请求.发生时间 == 0
            || !动态种类有效(请求.种类)) {
            return false;
        }
        for (std::size_t 序号 = 0; 序号 < 请求.来源低层动态组.size(); ++序号) {
            if (!句柄有效(请求.来源低层动态组[序号])) return false;
            for (std::size_t 已有 = 0; 已有 < 序号; ++已有) {
                if (请求.来源低层动态组[已有]
                    == 请求.来源低层动态组[序号]) {
                    return false;
                }
            }
        }
        if (请求.种类 == 动态种类::聚合动态) {
            return 请求.聚合规则版本 != 0
                && !请求.来源动作.has_value()
                && !请求.同源状态迁移动能.has_value()
                && !请求.来源低层动态组.empty();
        }
        if (请求.聚合规则版本 != 0 || !请求.来源低层动态组.empty()) {
            return false;
        }
        if (请求.种类 == 动态种类::动作致变) {
            return 请求.来源动作.has_value()
                && 句柄有效(*请求.来源动作)
                && 请求.同源状态迁移动能.has_value()
                && 句柄有效(*请求.同源状态迁移动能);
        }
        return !请求.来源动作.has_value()
            && !请求.同源状态迁移动能.has_value();
    }

    static bool 状态迁移组合字段有效(
        const 完整实例状态请求& 前请求,
        const 完整实例状态请求& 后请求,
        const 节点稳定主键& 动态稳定主键,
        节点句柄 被改变目标) noexcept {
        return 状态请求字段有效(前请求)
            && 状态请求字段有效(后请求)
            && 前请求.状态稳定主键 != 后请求.状态稳定主键
            && 主键属于(
                动态稳定主键, 节点稳定主键命名域::动态身份)
            && 前请求.主体 == 后请求.主体
            && 前请求.场景 == 后请求.场景
            && 前请求.特征 == 后请求.特征
            && 前请求.来源存在 == 后请求.来源存在
            && 前请求.发生时间 <= 后请求.发生时间
            && (被改变目标 == 后请求.特征
                || 被改变目标 == 后请求.特征值);
    }

    static 完整动态请求 形成迁移动能请求(
        const 节点稳定主键& 动态稳定主键,
        节点句柄 被改变目标,
        节点句柄 前状态,
        节点句柄 后状态,
        const 完整实例状态请求& 后请求) {
        return {
            动态稳定主键,
            动态种类::状态迁移动能,
            后请求.主体,
            后请求.场景,
            被改变目标,
            前状态,
            后状态,
            后请求.来源存在,
            std::nullopt,
            {},
            std::nullopt,
            后请求.发生时间,
            0};
    }

    完整状态读取结果 复核状态请求_已许可(
        const 完整实例状态请求& 请求) const {
        const auto 当前 = 节点_->读取稳定主键当前身份(请求.状态稳定主键);
        if (当前.状态 == 稳定主键当前身份状态::历史占用) {
            return {合同结果状态::入口拒绝, 合同结果原因::同键异义};
        }
        if (当前.状态 == 稳定主键当前身份状态::内部不一致) {
            return {合同结果状态::内部错误,
                合同结果原因::权威读回不一致};
        }
        const auto 端点 = 复核状态端点_已许可(请求);
        if (端点.状态 != 合同结果状态::成功) return {端点.状态, 端点.原因};
        if (当前.状态 == 稳定主键当前身份状态::未占用) {
            return {合同结果状态::合法未找到, 合同结果原因::无};
        }
        if (当前.状态 != 稳定主键当前身份状态::当前有效
            || !当前.当前身份.has_value()) {
            return {合同结果状态::入口拒绝, 合同结果原因::同键异义};
        }
        auto 已有 = 读取完整状态事实_已许可(*当前.当前身份);
        if (!已有.成功()) {
            return {合同结果状态::内部错误,
                合同结果原因::权威读回不一致};
        }
        if (状态材料同义(*已有.材料, 请求)) {
            已有.状态 = 合同结果状态::幂等读回;
            return 已有;
        }
        return {合同结果状态::入口拒绝, 合同结果原因::同键异义};
    }

    完整状态读取结果 复核状态请求_会话(
        节点直接身份结构写入会话& 会话,
        const 完整实例状态请求& 请求) const {
        const auto 当前 = 会话.读取稳定主键当前身份(请求.状态稳定主键);
        if (当前.状态 != 稳定主键当前身份状态::未占用) {
            return {合同结果状态::写前漂移, 合同结果原因::同键异义};
        }
        const auto 主体 = 会话.读取节点(请求.主体);
        const auto 场景 = 会话.读取节点(请求.场景);
        const auto 特征 = 会话.读取节点(请求.特征);
        const auto 值 = 会话.读取节点(请求.特征值);
        const auto 来源 = 会话.读取节点(请求.来源存在);
        if (!主体.has_value() || !场景.has_value() || !特征.has_value()
            || !值.has_value() || !来源.has_value()) {
            return {合同结果状态::写前漂移, 合同结果原因::错版本};
        }
        if (主体->类型 != 节点类型::存在 || 场景->类型 != 节点类型::场景
            || 特征->类型 != 节点类型::特征 || 值->类型 != 节点类型::特征值
            || 来源->类型 != 节点类型::存在) {
            return {合同结果状态::入口拒绝, 合同结果原因::错类型};
        }
        return {合同结果状态::合法未找到, 合同结果原因::无};
    }

    合同无值结果 复核状态端点_已许可(
        const 完整实例状态请求& 请求) const {
        const auto 主体 = 节点_->读取节点(请求.主体);
        const auto 场景 = 节点_->读取节点(请求.场景);
        const auto 特征 = 节点_->读取节点(请求.特征);
        const auto 值 = 节点_->读取节点(请求.特征值);
        const auto 来源 = 节点_->读取节点(请求.来源存在);
        if (!主体.has_value() || !场景.has_value() || !特征.has_value()
            || !值.has_value() || !来源.has_value()) {
            return {合同结果状态::入口拒绝, 合同结果原因::错版本};
        }
        if (主体->类型 != 节点类型::存在 || 场景->类型 != 节点类型::场景
            || 特征->类型 != 节点类型::特征 || 值->类型 != 节点类型::特征值
            || 来源->类型 != 节点类型::存在) {
            return {合同结果状态::入口拒绝, 合同结果原因::错类型};
        }
        return {合同结果状态::成功, 合同结果原因::无};
    }

    完整动态读取结果 复核动态请求_已许可(
        const 完整动态请求& 请求) const {
        const auto 当前 = 节点_->读取稳定主键当前身份(请求.动态稳定主键);
        if (当前.状态 == 稳定主键当前身份状态::历史占用) {
            return {合同结果状态::入口拒绝, 合同结果原因::同键异义};
        }
        if (当前.状态 == 稳定主键当前身份状态::内部不一致) {
            return {合同结果状态::内部错误,
                合同结果原因::权威读回不一致};
        }
        const auto 端点 = 复核动态端点_已许可(请求);
        if (端点.状态 != 合同结果状态::成功) return {端点.状态, 端点.原因};
        if (当前.状态 == 稳定主键当前身份状态::未占用) {
            return {合同结果状态::合法未找到, 合同结果原因::无};
        }
        if (当前.状态 != 稳定主键当前身份状态::当前有效
            || !当前.当前身份.has_value()) {
            return {合同结果状态::入口拒绝, 合同结果原因::同键异义};
        }
        auto 已有 = 读取完整动态事实_已许可(*当前.当前身份);
        if (!已有.成功()) {
            return {合同结果状态::内部错误,
                合同结果原因::权威读回不一致};
        }
        if (动态材料同义(*已有.材料, 请求)) {
            已有.状态 = 合同结果状态::幂等读回;
            return 已有;
        }
        return {合同结果状态::入口拒绝, 合同结果原因::同键异义};
    }

    完整动态读取结果 复核动态请求_会话(
        节点直接身份结构写入会话& 会话,
        const 完整动态请求& 请求) const {
        const auto 当前 = 会话.读取稳定主键当前身份(请求.动态稳定主键);
        if (当前.状态 != 稳定主键当前身份状态::未占用) {
            return {合同结果状态::写前漂移, 合同结果原因::同键异义};
        }
        const auto 主体 = 会话.读取节点(请求.主体);
        const auto 场景 = 会话.读取节点(请求.场景);
        const auto 目标 = 会话.读取节点(请求.被改变目标);
        const auto 前 = 会话.读取节点(请求.前状态);
        const auto 后 = 会话.读取节点(请求.后状态);
        const auto 来源 = 会话.读取节点(请求.来源存在);
        if (!主体.has_value() || !场景.has_value() || !目标.has_value()
            || !前.has_value() || !后.has_value() || !来源.has_value()) {
            return {合同结果状态::写前漂移, 合同结果原因::错版本};
        }
        if (主体->类型 != 节点类型::存在 || 场景->类型 != 节点类型::场景
            || (目标->类型 != 节点类型::特征
                && 目标->类型 != 节点类型::特征值)
            || 前->类型 != 节点类型::状态 || 后->类型 != 节点类型::状态
            || 来源->类型 != 节点类型::存在) {
            return {合同结果状态::入口拒绝, 合同结果原因::错类型};
        }
        return {合同结果状态::合法未找到, 合同结果原因::无};
    }

    合同无值结果 复核动态端点_已许可(
        const 完整动态请求& 请求) const {
        const auto 主体 = 节点_->读取节点(请求.主体);
        const auto 场景 = 节点_->读取节点(请求.场景);
        const auto 目标 = 节点_->读取节点(请求.被改变目标);
        const auto 来源 = 节点_->读取节点(请求.来源存在);
        if (!主体.has_value() || !场景.has_value()
            || !目标.has_value() || !来源.has_value()) {
            return {合同结果状态::入口拒绝, 合同结果原因::错版本};
        }
        if (主体->类型 != 节点类型::存在 || 场景->类型 != 节点类型::场景
            || (目标->类型 != 节点类型::特征
                && 目标->类型 != 节点类型::特征值)
            || 来源->类型 != 节点类型::存在) {
            return {合同结果状态::入口拒绝, 合同结果原因::错类型};
        }
        const auto 前 = 读取完整状态事实_已许可(请求.前状态);
        const auto 后 = 读取完整状态事实_已许可(请求.后状态);
        if (!前.成功() || !后.成功()) {
            return {合同结果状态::入口拒绝, 合同结果原因::错版本};
        }
        if (前.材料->主体证据.目标节点 != 请求.主体
            || 后.材料->主体证据.目标节点 != 请求.主体
            || 前.材料->场景证据.目标节点 != 请求.场景
            || 后.材料->场景证据.目标节点 != 请求.场景
            || 前.材料->特征证据.目标节点 != 后.材料->特征证据.目标节点
            || 前.材料->发生时间 > 后.材料->发生时间
            || 请求.发生时间 != 后.材料->发生时间
            || (请求.被改变目标 != 后.材料->特征证据.目标节点
                && 请求.被改变目标 != 后.材料->值证据.目标节点)) {
            return {合同结果状态::入口拒绝,
                合同结果原因::关系角色不合法};
        }
        if (请求.来源动作.has_value()) {
            const auto 动作 = 节点_->读取节点(*请求.来源动作);
            if (!动作.has_value() || 动作->类型 != 节点类型::方法) {
                return {合同结果状态::入口拒绝, 合同结果原因::错类型};
            }
        }
        for (const auto& 低层 : 请求.来源低层动态组) {
            const auto 低层事实 = 读取完整动态事实_已许可(低层);
            if (!低层事实.成功()
                || 低层事实.材料->主体证据.目标节点 != 请求.主体
                || 低层事实.材料->场景证据.目标节点 != 请求.场景
                || 低层事实.材料->发生时间 > 请求.发生时间) {
                return {合同结果状态::入口拒绝,
                    合同结果原因::关系角色不合法};
            }
        }
        if (请求.同源状态迁移动能.has_value()) {
            const auto 同源 = 读取完整动态事实_已许可(*请求.同源状态迁移动能);
            if (!同源.成功()
                || 同源.材料->种类 != 动态种类::状态迁移动能
                || 同源.材料->主体证据.目标节点 != 请求.主体
                || 同源.材料->场景证据.目标节点 != 请求.场景
                || 同源.材料->前状态证据.目标节点 != 请求.前状态
                || 同源.材料->后状态证据.目标节点 != 请求.后状态) {
                return {合同结果状态::入口拒绝,
                    合同结果原因::关系角色不合法};
            }
        }
        return {合同结果状态::成功, 合同结果原因::无};
    }

    完整状态读取结果 读取完整状态事实_已许可(
        节点句柄 状态) const {
        const auto 节点 = 节点_->读取节点(状态);
        if (!节点.has_value()) {
            return {合同结果状态::合法未找到, 合同结果原因::无};
        }
        if (节点->类型 != 节点类型::状态
            || 节点->稳定主键.命名域 != static_cast<std::uint64_t>(
                节点稳定主键命名域::状态身份)) {
            return {合同结果状态::入口拒绝, 合同结果原因::错类型};
        }
        const auto 记录 = 状态类型化记录只读访问器(
            *状态记录仓_).读取当前记录(状态);
        if (记录.状态 == 状态动态记录读取状态::许可竞争) {
            return {合同结果状态::许可竞争, 合同结果原因::并发许可失败};
        }
        if (!记录.可读()) {
            return {记录.状态 == 状态动态记录读取状态::合法未找到
                    ? 合同结果状态::合法未找到 : 合同结果状态::内部错误,
                记录.状态 == 状态动态记录读取状态::合法未找到
                    ? 合同结果原因::无 : 合同结果原因::权威读回不一致};
        }
        const auto 关系组 = 关系_->读取有效关系组(
            状态, 关系类型::状态事实角色);
        const auto 主体 = 唯一角色(关系组, 状态主体角色);
        const auto 场景 = 唯一角色(关系组, 状态场景角色);
        const auto 特征 = 唯一角色(关系组, 状态特征角色);
        const auto 值 = 唯一角色(关系组, 状态值角色);
        const auto 来源 = 唯一角色(关系组, 状态来源存在角色);
        if (关系组.size() != 5
            || !关系组属于(关系组, 状态, 关系类型::状态事实角色)
            || !主体.has_value() || !场景.has_value()
            || !特征.has_value() || !值.has_value() || !来源.has_value()
            || !端点类型匹配(*主体, 节点类型::存在)
            || !端点类型匹配(*场景, 节点类型::场景)
            || !端点类型匹配(*特征, 节点类型::特征)
            || !端点类型匹配(*值, 节点类型::特征值)
            || !端点类型匹配(*来源, 节点类型::存在)) {
            return {合同结果状态::内部错误,
                合同结果原因::权威读回不一致};
        }
        状态事实值式材料 材料{
            状态,
            节点->稳定主键,
            节点->版本号,
            记录.记录->记录版本,
            记录.记录->发生时间,
            记录.记录->接收时间,
            记录.记录->记录模式,
            *主体, *场景, *特征, *值, *来源};
        return {合同结果状态::成功, 合同结果原因::无, std::move(材料)};
    }

    完整动态读取结果 读取完整动态事实_已许可(
        节点句柄 动态) const {
        const auto 节点 = 节点_->读取节点(动态);
        if (!节点.has_value()) {
            return {合同结果状态::合法未找到, 合同结果原因::无};
        }
        if (节点->类型 != 节点类型::动态
            || 节点->稳定主键.命名域 != static_cast<std::uint64_t>(
                节点稳定主键命名域::动态身份)) {
            return {合同结果状态::入口拒绝, 合同结果原因::错类型};
        }
        const auto 记录 = 动态类型化记录只读访问器(
            *动态记录仓_).读取当前记录(动态);
        if (记录.状态 == 状态动态记录读取状态::许可竞争) {
            return {合同结果状态::许可竞争, 合同结果原因::并发许可失败};
        }
        if (!记录.可读()) {
            return {记录.状态 == 状态动态记录读取状态::合法未找到
                    ? 合同结果状态::合法未找到 : 合同结果状态::内部错误,
                记录.状态 == 状态动态记录读取状态::合法未找到
                    ? 合同结果原因::无 : 合同结果原因::权威读回不一致};
        }
        const auto 关系组 = 关系_->读取有效关系组(
            动态, 关系类型::动态事实角色);
        const auto 主体 = 唯一角色(关系组, 动态主体角色);
        const auto 场景 = 唯一角色(关系组, 动态场景角色);
        const auto 目标 = 唯一角色(关系组, 动态目标角色);
        const auto 前 = 唯一角色(关系组, 动态前状态角色);
        const auto 后 = 唯一角色(关系组, 动态后状态角色);
        const auto 动作 = 可选唯一角色(关系组, 动态来源动作角色);
        const auto 低层 = 多项目角色(关系组, 动态来源低层角色);
        const auto 同源 = 可选唯一角色(关系组, 动态同源迁移角色);
        const auto 来源 = 唯一角色(关系组, 动态来源存在角色);
        const std::size_t 预期数量 = 6 + (动作.has_value() ? 1 : 0)
            + 低层.size() + (同源.has_value() ? 1 : 0);
        if (关系组.size() != 预期数量
            || !关系组属于(关系组, 动态, 关系类型::动态事实角色)
            || !主体.has_value()
            || !场景.has_value() || !目标.has_value() || !前.has_value()
            || !后.has_value() || !来源.has_value()
            || !端点类型匹配(*主体, 节点类型::存在)
            || !端点类型匹配(*场景, 节点类型::场景)
            || !端点类型匹配任一(*目标, 节点类型::特征, 节点类型::特征值)
            || !端点类型匹配(*前, 节点类型::状态)
            || !端点类型匹配(*后, 节点类型::状态)
            || !端点类型匹配(*来源, 节点类型::存在)) {
            return {合同结果状态::内部错误,
                合同结果原因::权威读回不一致};
        }
        if ((动作.has_value() && !端点类型匹配(*动作, 节点类型::方法))
            || (同源.has_value() && !端点类型匹配(*同源, 节点类型::动态))) {
            return {合同结果状态::内部错误, 合同结果原因::错类型};
        }
        for (const auto& 项目 : 低层) {
            if (!端点类型匹配(项目, 节点类型::动态)) {
                return {合同结果状态::内部错误, 合同结果原因::错类型};
            }
            const auto 低层记录 = 动态类型化记录只读访问器(
                *动态记录仓_).读取当前记录(项目.目标节点);
            if (!低层记录.可读()) {
                return {合同结果状态::内部错误,
                    合同结果原因::权威读回不一致};
            }
        }
        if (同源.has_value()) {
            const auto 同源记录 = 动态类型化记录只读访问器(
                *动态记录仓_).读取当前记录(同源->目标节点);
            if (!同源记录.可读()
                || 同源记录.记录->种类 != 动态种类::状态迁移动能) {
                return {合同结果状态::内部错误,
                    合同结果原因::关系角色不合法};
            }
        }
        if (!动态角色组合匹配(
                记录.记录->种类, 动作, 低层, 同源, 记录.记录->聚合规则版本)) {
            return {合同结果状态::内部错误,
                合同结果原因::关系角色不合法};
        }
        动态事实值式材料 材料{
            动态,
            节点->稳定主键,
            节点->版本号,
            记录.记录->记录版本,
            记录.记录->发生时间,
            记录.记录->聚合规则版本,
            记录.记录->种类,
            *主体, *场景, *目标, *前, *后, *来源,
            动作, 低层, 同源};
        return {合同结果状态::成功, 合同结果原因::无, std::move(材料)};
    }

    static bool 状态材料同义(
        const 状态事实值式材料& 材料,
        const 完整实例状态请求& 请求) noexcept {
        return 材料.稳定主键 == 请求.状态稳定主键
            && 材料.发生时间 == 请求.发生时间
            && 材料.接收时间 == 请求.接收时间
            && 材料.记录模式 == 请求.记录模式
            && 材料.主体证据.目标节点 == 请求.主体
            && 材料.场景证据.目标节点 == 请求.场景
            && 材料.特征证据.目标节点 == 请求.特征
            && 材料.值证据.目标节点 == 请求.特征值
            && 材料.来源存在证据.目标节点 == 请求.来源存在;
    }

    static bool 动态材料同义(
        const 动态事实值式材料& 材料,
        const 完整动态请求& 请求) {
        if (材料.稳定主键 != 请求.动态稳定主键
            || 材料.种类 != 请求.种类
            || 材料.发生时间 != 请求.发生时间
            || 材料.聚合规则版本 != 请求.聚合规则版本
            || 材料.主体证据.目标节点 != 请求.主体
            || 材料.场景证据.目标节点 != 请求.场景
            || 材料.被改变目标证据.目标节点 != 请求.被改变目标
            || 材料.前状态证据.目标节点 != 请求.前状态
            || 材料.后状态证据.目标节点 != 请求.后状态
            || 材料.来源存在证据.目标节点 != 请求.来源存在
            || 提取可选目标(材料.来源动作证据) != 请求.来源动作
            || 提取可选目标(材料.同源状态迁移动能证据)
                != 请求.同源状态迁移动能
            || 材料.来源低层动态证据组.size()
                != 请求.来源低层动态组.size()) {
            return false;
        }
        std::vector<节点句柄> 已有;
        for (const auto& 证据 : 材料.来源低层动态证据组) {
            已有.push_back(证据.目标节点);
        }
        auto 请求组 = 请求.来源低层动态组;
        std::sort(已有.begin(), 已有.end(), 句柄小于);
        std::sort(请求组.begin(), 请求组.end(), 句柄小于);
        return 已有 == 请求组;
    }

    bool 写入状态关系组_会话(
        节点直接身份结构写入会话& 会话,
        节点句柄 状态,
        const 完整实例状态请求& 请求) const {
        const std::array<std::pair<节点句柄, std::int64_t>, 5> 角色组{{
            {请求.主体, 状态主体角色},
            {请求.场景, 状态场景角色},
            {请求.特征, 状态特征角色},
            {请求.特征值, 状态值角色},
            {请求.来源存在, 状态来源存在角色}}};
        for (const auto& [目标, 角色] : 角色组) {
            const auto 结果 = 会话.创建关系候选(
                关系类型::状态事实角色, 状态, 目标, 角色);
            if (!结果.成功()) return false;
            const auto 读回 = 会话.读取关系(*结果.值);
            if (!读回.has_value()
                || 读回->类型 != 关系类型::状态事实角色
                || 读回->源节点 != 状态 || 读回->目标节点 != 目标
                || 读回->顺序号 != 角色
                || 读回->状态 != 记录状态::有效) {
                return false;
            }
        }
        return true;
    }

    bool 写入动态关系组_会话(
        节点直接身份结构写入会话& 会话,
        节点句柄 动态,
        const 完整动态请求& 请求) const {
        const std::array<std::pair<节点句柄, std::int64_t>, 6> 必需角色{{
            {请求.主体, 动态主体角色},
            {请求.场景, 动态场景角色},
            {请求.被改变目标, 动态目标角色},
            {请求.前状态, 动态前状态角色},
            {请求.后状态, 动态后状态角色},
            {请求.来源存在, 动态来源存在角色}}};
        for (const auto& [目标, 角色] : 必需角色) {
            const auto 结果 = 会话.创建关系候选(
                关系类型::动态事实角色, 动态, 目标, 角色);
            if (!结果.成功()) return false;
            const auto 读回 = 会话.读取关系(*结果.值);
            if (!关系候选读回匹配(
                    读回, 动态, 目标, 角色)) return false;
        }
        if (请求.来源动作.has_value()) {
            const auto 结果 = 会话.创建关系候选(
                关系类型::动态事实角色, 动态,
                *请求.来源动作, 动态来源动作角色);
            if (!结果.成功()) return false;
            const auto 读回 = 会话.读取关系(*结果.值);
            if (!关系候选读回匹配(
                    读回, 动态,
                    *请求.来源动作, 动态来源动作角色)) return false;
        }
        for (const auto& 低层 : 请求.来源低层动态组) {
            const auto 结果 = 会话.创建关系候选(
                关系类型::动态事实角色, 动态, 低层, 动态来源低层角色);
            if (!结果.成功()) return false;
            const auto 读回 = 会话.读取关系(*结果.值);
            if (!关系候选读回匹配(
                    读回, 动态, 低层,
                    动态来源低层角色)) return false;
        }
        if (请求.同源状态迁移动能.has_value()) {
            const auto 结果 = 会话.创建关系候选(
                关系类型::动态事实角色, 动态,
                *请求.同源状态迁移动能, 动态同源迁移角色);
            if (!结果.成功()) return false;
            const auto 读回 = 会话.读取关系(*结果.值);
            if (!关系候选读回匹配(
                    读回, 动态,
                    *请求.同源状态迁移动能,
                    动态同源迁移角色)) return false;
        }
        return true;
    }

    static bool 关系候选读回匹配(
        const std::optional<正式关系记录>& 读回,
        节点句柄 动态,
        节点句柄 目标,
        std::int64_t 角色) noexcept {
        return 读回.has_value()
            && 读回->类型 == 关系类型::动态事实角色
            && 读回->源节点 == 动态 && 读回->目标节点 == 目标
            && 读回->顺序号 == 角色
            && 读回->状态 == 记录状态::有效;
    }

    bool 写入节点索引_会话(
        节点直接身份结构写入会话& 会话,
        const 节点稳定主键& 主键,
        节点句柄 节点,
        std::uint32_t 命名域) const {
        可重建索引记录 记录;
        记录.物理键 = {索引所有者身份, 命名域, 1, 1, 主键.键值};
        记录.目标种类 = 索引目标种类::节点;
        记录.节点 = 节点;
        const auto 结果 = 会话.创建索引候选(记录);
        if (!结果.成功()) return false;
        const auto 读回 = 会话.读取索引物理键(记录.物理键);
        return 读回.has_value() && 读回->物理键 == 记录.物理键
            && 读回->目标种类 == 索引目标种类::节点
            && 读回->节点 == 节点 && !句柄有效(读回->关系);
    }

    std::optional<正式关系记录> 唯一角色(
        const std::vector<正式关系记录>& 关系组,
        std::int64_t 角色) const {
        std::optional<正式关系记录> 输出;
        for (const auto& 关系 : 关系组) {
            if (关系.顺序号 != 角色) continue;
            if (输出.has_value()) return std::nullopt;
            输出 = 关系;
        }
        return 输出;
    }

    std::optional<正式关系记录> 可选唯一角色(
        const std::vector<正式关系记录>& 关系组,
        std::int64_t 角色) const {
        return 唯一角色(关系组, 角色);
    }

    std::vector<正式关系记录> 多项目角色(
        const std::vector<正式关系记录>& 关系组,
        std::int64_t 角色) const {
        std::vector<正式关系记录> 输出;
        for (const auto& 关系 : 关系组) {
            if (关系.顺序号 != 角色) continue;
            const auto 重复 = std::find_if(
                输出.cbegin(), 输出.cend(),
                [&关系](const auto& 已有) {
                    return 已有.目标节点 == 关系.目标节点;
                });
            if (重复 != 输出.cend()) return {};
            输出.push_back(关系);
        }
        std::sort(输出.begin(), 输出.end(),
            [](const auto& 左, const auto& 右) {
                return 句柄小于(左.目标节点, 右.目标节点);
            });
        return 输出;
    }

    bool 端点类型匹配(
        const 正式关系记录& 关系,
        节点类型 类型) const {
        const auto 目标 = 节点_->读取节点(关系.目标节点);
        return 目标.has_value() && 目标->类型 == 类型;
    }

    bool 端点类型匹配任一(
        const 正式关系记录& 关系,
        节点类型 第一,
        节点类型 第二) const {
        const auto 目标 = 节点_->读取节点(关系.目标节点);
        return 目标.has_value()
            && (目标->类型 == 第一 || 目标->类型 == 第二);
    }

    static bool 关系组属于(
        const std::vector<正式关系记录>& 关系组,
        节点句柄 源节点,
        关系类型 类型) noexcept {
        for (const auto& 关系 : 关系组) {
            if (!正式关系记录完整(关系)
                || 关系.类型 != 类型 || 关系.源节点 != 源节点
                || 关系.状态 != 记录状态::有效) {
                return false;
            }
        }
        return true;
    }

    static bool 动态角色组合匹配(
        动态种类 种类,
        const std::optional<正式关系记录>& 动作,
        const std::vector<正式关系记录>& 低层,
        const std::optional<正式关系记录>& 同源,
        std::uint64_t 聚合规则版本) noexcept {
        if (种类 == 动态种类::动作致变) {
            return 动作.has_value() && 同源.has_value()
                && 低层.empty() && 聚合规则版本 == 0;
        }
        if (种类 == 动态种类::聚合动态) {
            return !动作.has_value() && !同源.has_value()
                && !低层.empty() && 聚合规则版本 != 0;
        }
        return !动作.has_value() && !同源.has_value()
            && 低层.empty() && 聚合规则版本 == 0;
    }

    static std::optional<节点句柄> 提取可选目标(
        const std::optional<正式关系记录>& 关系) noexcept {
        return 关系.has_value()
            ? std::optional<节点句柄>{关系->目标节点} : std::nullopt;
    }

    std::uint64_t 状态记录结构版本() const noexcept {
        return 状态类型化记录只读访问器(*状态记录仓_).读取结构版本();
    }

    std::uint64_t 动态记录结构版本() const noexcept {
        return 动态类型化记录只读访问器(*动态记录仓_).读取结构版本();
    }

    static 无值映射结果 映射结构写入结果(
        const 节点直接身份结构写入结果& 结果) noexcept {
        switch (结果.状态) {
        case 节点直接身份结构写入状态::已提交:
            return {合同结果状态::成功, 合同结果原因::无};
        case 节点直接身份结构写入状态::幂等读回:
            return {合同结果状态::幂等读回, 合同结果原因::无};
        case 节点直接身份结构写入状态::许可拒绝:
            return {合同结果状态::许可竞争, 合同结果原因::并发许可失败};
        case 节点直接身份结构写入状态::版本漂移:
            return {合同结果状态::写前漂移, 合同结果原因::错版本};
        case 节点直接身份结构写入状态::身份冲突:
            return {合同结果状态::入口拒绝, 合同结果原因::同键异义};
        case 节点直接身份结构写入状态::入口拒绝:
            return {合同结果状态::入口拒绝, 合同结果原因::无效身份};
        default:
            return {合同结果状态::内部错误,
                合同结果原因::事务阶段不一致};
        }
    }

    节点直接身份结构事务域* 事务域_ = nullptr;
    节点直接身份仓库* 节点_ = nullptr;
    正式关系仓库* 关系_ = nullptr;
    可重建索引仓库* 索引_ = nullptr;
    状态类型化记录仓* 状态记录仓_ = nullptr;
    动态类型化记录仓* 动态记录仓_ = nullptr;
};

inline bool 状态动态冻结提供者::有效() const noexcept {
    return 数据操作_ != nullptr && 数据操作_->有效();
}

inline 状态动态同代次冻结结果
状态动态冻结提供者::复制同代次状态动态全量(
    const 节点直接统一冻结许可& 许可) const {
    if (!有效() || !许可.有效()
        || !数据操作_->事务域_->冻结许可属于本域(许可)) {
        return {状态动态冻结状态::入口拒绝, std::nullopt};
    }
    const auto 首次见证 = 许可.读取见证();
    if (首次见证.冻结域身份 == 0 || 首次见证.已发布代次 == 0
        || 首次见证.冻结规则版本 != 1) {
        return {状态动态冻结状态::入口拒绝, std::nullopt};
    }
    auto 状态副本 = 状态类型化记录只读访问器(
        *数据操作_->状态记录仓_).复制全部已发布记录();
    if (状态副本.状态 != 状态动态记录全量读取状态::已形成) {
        return {状态副本.状态 == 状态动态记录全量读取状态::资源失败
                ? 状态动态冻结状态::资源失败
                : 状态动态冻结状态::内部不一致,
            std::nullopt};
    }
    auto 动态副本 = 动态类型化记录只读访问器(
        *数据操作_->动态记录仓_).复制全部已发布记录();
    if (动态副本.状态 != 状态动态记录全量读取状态::已形成) {
        return {动态副本.状态 == 状态动态记录全量读取状态::资源失败
                ? 状态动态冻结状态::资源失败
                : 状态动态冻结状态::内部不一致,
            std::nullopt};
    }
    const auto 再次见证 = 许可.读取见证();
    if (!数据操作_->事务域_->冻结许可属于本域(许可)
        || 首次见证.冻结域身份 != 再次见证.冻结域身份
        || 首次见证.已发布代次 != 再次见证.已发布代次
        || 首次见证.冻结规则版本 != 再次见证.冻结规则版本) {
        return {状态动态冻结状态::内部不一致, std::nullopt};
    }
    const auto 状态复核 = 状态类型化记录只读访问器(
        *数据操作_->状态记录仓_).复制全部已发布记录();
    const auto 动态复核 = 动态类型化记录只读访问器(
        *数据操作_->动态记录仓_).复制全部已发布记录();
    if (状态复核.状态 == 状态动态记录全量读取状态::资源失败
        || 动态复核.状态 == 状态动态记录全量读取状态::资源失败) {
        return {状态动态冻结状态::资源失败, std::nullopt};
    }
    if (状态复核.状态 != 状态动态记录全量读取状态::已形成
        || 动态复核.状态 != 状态动态记录全量读取状态::已形成
        || 状态副本.结构版本 != 状态复核.结构版本
        || 动态副本.结构版本 != 动态复核.结构版本
        || 状态副本.记录数量 != 状态复核.记录数量
        || 动态副本.记录数量 != 动态复核.记录数量) {
        return {状态动态冻结状态::内部不一致, std::nullopt};
    }
    std::sort(状态副本.记录组.begin(), 状态副本.记录组.end(),
        [](const auto& 左, const auto& 右) {
            if (左.所属状态 != 右.所属状态) {
                return 节点直接状态动态数据操作::句柄小于(
                    左.所属状态, 右.所属状态);
            }
            if (左.记录版本 != 右.记录版本) return 左.记录版本 < 右.记录版本;
            return static_cast<std::uint32_t>(左.状态)
                < static_cast<std::uint32_t>(右.状态);
        });
    std::sort(动态副本.记录组.begin(), 动态副本.记录组.end(),
        [](const auto& 左, const auto& 右) {
            if (左.所属动态 != 右.所属动态) {
                return 节点直接状态动态数据操作::句柄小于(
                    左.所属动态, 右.所属动态);
            }
            if (左.记录版本 != 右.记录版本) return 左.记录版本 < 右.记录版本;
            return static_cast<std::uint32_t>(左.状态)
                < static_cast<std::uint32_t>(右.状态);
        });
    状态动态同代次冻结材料 材料;
    材料.见证 = 首次见证;
    材料.状态记录结构版本 = 状态副本.结构版本;
    材料.动态记录结构版本 = 动态副本.结构版本;
    材料.状态记录数量 = 状态副本.记录数量;
    材料.动态记录数量 = 动态副本.记录数量;
    材料.状态记录组 = std::move(状态副本.记录组);
    材料.动态记录组 = std::move(动态副本.记录组);
    return {状态动态冻结状态::已形成, std::move(材料)};
}

inline bool 状态动态记录退役提供者::有效() const noexcept {
    return 数据操作_ != nullptr && 数据操作_->有效();
}

inline 状态记录退役参与包形成结果
状态动态记录退役提供者::形成状态记录退役参与包(
    const 状态退役规格& 规格) const {
    if (!有效() || !句柄有效(规格.状态) || 规格.预期节点版本 == 0) {
        return {退役参与包形成状态::入口拒绝, std::nullopt};
    }
    auto 许可 = 数据操作_->事务域_->取得读取许可();
    if (!许可.有效()) {
        return {退役参与包形成状态::许可竞争, std::nullopt};
    }
    const auto 节点 = 数据操作_->节点_->读取节点(规格.状态);
    if (!节点.has_value()) {
        return {退役参与包形成状态::合法未找到, std::nullopt};
    }
    if (节点->类型 != 节点类型::状态) {
        return {退役参与包形成状态::入口拒绝, std::nullopt};
    }
    if (节点->版本号 != 规格.预期节点版本) {
        return {退役参与包形成状态::版本漂移, std::nullopt};
    }
    const auto 记录 = 状态类型化记录只读访问器(
        *数据操作_->状态记录仓_).读取当前记录(规格.状态);
    if (记录.状态 == 状态动态记录读取状态::许可竞争) {
        return {退役参与包形成状态::许可竞争, std::nullopt};
    }
    if (记录.状态 == 状态动态记录读取状态::合法未找到) {
        return {退役参与包形成状态::合法未找到, std::nullopt};
    }
    if (!记录.可读()) {
        return {退役参与包形成状态::内部不一致, std::nullopt};
    }
    if (记录.记录->状态 != 记录状态::有效
        || 记录.记录->记录版本
            == std::numeric_limits<std::uint64_t>::max()) {
        return {退役参与包形成状态::内部不一致, std::nullopt};
    }
    try {
        return {退役参与包形成状态::已形成,
            状态动态记录退役包工厂::形成状态包(
                *数据操作_->状态记录仓_, 规格, *记录.记录)};
    } catch (const std::bad_alloc&) {
        return {退役参与包形成状态::资源失败, std::nullopt};
    } catch (...) {
        return {退役参与包形成状态::内部不一致, std::nullopt};
    }
}

inline 动态记录退役参与包形成结果
状态动态记录退役提供者::形成动态记录退役参与包(
    const 动态退役规格& 规格) const {
    if (!有效() || !句柄有效(规格.动态) || 规格.预期节点版本 == 0) {
        return {退役参与包形成状态::入口拒绝, std::nullopt};
    }
    auto 许可 = 数据操作_->事务域_->取得读取许可();
    if (!许可.有效()) {
        return {退役参与包形成状态::许可竞争, std::nullopt};
    }
    const auto 节点 = 数据操作_->节点_->读取节点(规格.动态);
    if (!节点.has_value()) {
        return {退役参与包形成状态::合法未找到, std::nullopt};
    }
    if (节点->类型 != 节点类型::动态) {
        return {退役参与包形成状态::入口拒绝, std::nullopt};
    }
    if (节点->版本号 != 规格.预期节点版本) {
        return {退役参与包形成状态::版本漂移, std::nullopt};
    }
    const auto 记录 = 动态类型化记录只读访问器(
        *数据操作_->动态记录仓_).读取当前记录(规格.动态);
    if (记录.状态 == 状态动态记录读取状态::许可竞争) {
        return {退役参与包形成状态::许可竞争, std::nullopt};
    }
    if (记录.状态 == 状态动态记录读取状态::合法未找到) {
        return {退役参与包形成状态::合法未找到, std::nullopt};
    }
    if (!记录.可读()) {
        return {退役参与包形成状态::内部不一致, std::nullopt};
    }
    if (记录.记录->状态 != 记录状态::有效
        || 记录.记录->记录版本
            == std::numeric_limits<std::uint64_t>::max()) {
        return {退役参与包形成状态::内部不一致, std::nullopt};
    }
    try {
        return {退役参与包形成状态::已形成,
            状态动态记录退役包工厂::形成动态包(
                *数据操作_->动态记录仓_, 规格, *记录.记录)};
    } catch (const std::bad_alloc&) {
        return {退役参与包形成状态::资源失败, std::nullopt};
    } catch (...) {
        return {退役参与包形成状态::内部不一致, std::nullopt};
    }
}

}
