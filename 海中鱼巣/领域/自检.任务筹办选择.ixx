// 文件规则：任务筹办选择自检只使用隔离接域仓库验证选择记录，不写生产运行期事实。
module;
#include "../核心/主信息仓库.h"
#include "../核心/节点仓库.h"
#include "../核心/关系仓库.h"
#include "需求服务.h"
#include "存在服务.h"
#include "状态服务.h"
#include "任务服务.h"
#include <array>
#include <atomic>
#include <iostream>
#include <thread>
#include <vector>
export module 海中鱼巣.领域.自检.任务筹办选择;
import 海中鱼巣.核心.协调.结构事务;
import 海中鱼巣.自检.运行器;

export namespace 海中鱼巣 {
自检单元结果 运行任务筹办选择自检() {
    std::array<bool, 15> 验收{};
    try {
        结构事务协调器 协调(223); auto 接线=协调.生成接线();
        主信息仓库 主信息(223,接线); 节点仓库 节点(主信息,223,接线); 关系仓库 关系(节点,223,接线);
        需求服务 需求(主信息,节点,关系,接线); 存在服务 存在(主信息,节点,关系,接线);
        状态服务 状态(主信息,节点,关系,接线); 任务服务 任务(主信息,节点,关系,接线);
        auto 创建节点=[&](节点类型 类型){auto 主=主信息.创建主信息();return 节点.创建节点(类型,主);};
        auto 主体=存在.创建实际存在(); auto 宿主=存在.创建实际存在(); auto 场景=创建节点(节点类型::场景);
        auto 目标状态=创建节点(节点类型::状态); auto 方法=创建节点(节点类型::方法); auto 需求节点=需求.创建需求();
        (void)关系.创建关系(关系类型::引用,需求节点,主体,1);(void)关系.创建关系(关系类型::引用,需求节点,宿主,2);
        (void)关系.创建关系(关系类型::引用,需求节点,场景,3);(void)关系.创建关系(关系类型::模板,需求节点,目标状态);
        auto 许可=接线.取得独占许可(接线.运行期状态);auto 令牌=许可.读取令牌();
        auto 任务节点=任务.按需求创建任务(需求节点,需求,存在,状态,100,令牌);auto 当前=任务.读取任务生命周期当前材料(任务节点,状态,令牌);if(!当前)throw 1;
        auto 迁移=[&](任务生命周期状态 目标,std::uint64_t 幂等,std::uint64_t 时间){任务生命周期提交请求 r{任务节点,当前->关系,当前->版本,目标,时间,幂等,{任务节点,方法}};auto o=任务.提交任务生命周期迁移(r,状态,令牌);当前=任务.读取任务生命周期当前材料(任务节点,状态,令牌);return o.状态==任务生命周期提交状态::已提交&&当前.has_value();};
        if(!迁移(任务生命周期状态::已承接,1,101)||!迁移(任务生命周期状态::筹办中,2,102))throw 2;
        auto 授权=任务.读取任务承接授权材料(任务节点,令牌);if(!授权)throw 3;
        任务方法选择请求 请求;请求.任务=任务节点;请求.来源需求=需求节点;请求.承接授权=*授权;请求.生命周期关系=当前->关系;请求.生命周期版本=当前->版本;
        请求.方法=方法;请求.幂等材料编号=0x100000001ULL;请求.排序规则版本=1;请求.召回请求规则版本=1;请求.索引发布版本=9;请求.来源候选数量=1;请求.建议状态=4;
        请求.完整有序候选规范元组={1,3,1,static_cast<std::int64_t>(方法.仓库编号),static_cast<std::int64_t>(方法.节点编号),static_cast<std::int64_t>(方法.版本号)};
        请求.权威节点来源组={{任务节点,节点类型::任务},{需求节点,节点类型::需求},{方法,节点类型::方法}};
        请求.权威关系来源组={{授权->需求拥有任务关系,关系类型::归属,需求节点,任务节点,0},{授权->任务来源需求关系,关系类型::引用,任务节点,需求节点,0}};
        auto 首次=任务.提交任务方法选择(请求,状态,令牌);auto 当前选择=任务.读取当前任务方法选择材料(任务节点,状态,令牌);
        验收[0]=授权->任务==任务节点&&授权->需求==需求节点&&句柄有效(授权->需求拥有任务关系)&&句柄有效(授权->任务来源需求关系);
        验收[1]=当前->阶段==任务生命周期状态::筹办中;验收[2]=首次.状态==任务方法选择提交状态::已提交&&当前选择.has_value();
        验收[3]=当前选择&&当前选择->记录.请求==请求&&任务.读取任务方法选择审计(当前选择->记录.记录节点,令牌).has_value();
        验收[4]=当前选择&&关系.存在关系(关系类型::引用,任务节点,方法,令牌);
        验收[5]=任务.提交任务方法选择(请求,状态,令牌).状态==任务方法选择提交状态::幂等读回;
        auto 异义=请求;异义.索引发布版本=10;验收[6]=任务.提交任务方法选择(异义,状态,令牌).状态==任务方法选择提交状态::已拒绝;
        auto 其它=请求;其它.幂等材料编号=2;验收[7]=任务.提交任务方法选择(其它,状态,令牌).状态==任务方法选择提交状态::已拒绝;
        许可={};std::atomic<int> 已提交{0},幂等{0};std::vector<std::thread> 线程组;for(int i=0;i<50;++i)线程组.emplace_back([&]{auto p=接线.取得独占许可(接线.运行期状态);auto o=任务.提交任务方法选择(请求,状态,p.读取令牌());if(o.状态==任务方法选择提交状态::已提交)++已提交;if(o.状态==任务方法选择提交状态::幂等读回)++幂等;});for(auto& x:线程组)x.join();验收[8]=已提交==0&&幂等==50;
        许可=接线.取得独占许可(接线.运行期状态);auto 后续令牌=许可.读取令牌();当前=任务.读取任务生命周期当前材料(任务节点,状态,后续令牌);
        auto 后续迁移=[&](任务生命周期状态 目标,std::uint64_t 幂等值,std::uint64_t 时间){任务生命周期提交请求 r{任务节点,当前->关系,当前->版本,目标,时间,幂等值,{任务节点,方法}};auto o=任务.提交任务生命周期迁移(r,状态,后续令牌);当前=任务.读取任务生命周期当前材料(任务节点,状态,后续令牌);return o.状态==任务生命周期提交状态::已提交&&当前.has_value();};
        const bool 到排队=后续迁移(任务生命周期状态::排队中,3,103);
        const bool 到执行=到排队&&后续迁移(任务生命周期状态::执行中,4,104);
        const bool 到等待=到执行&&后续迁移(任务生命周期状态::等待中,5,105);
        const bool 到重筹办=到等待&&后续迁移(任务生命周期状态::待重筹办,6,106);
        const bool 返回筹办=到重筹办&&后续迁移(任务生命周期状态::筹办中,7,107);
        bool 换代=返回筹办;
        验收[9]=换代&&!任务.读取当前任务方法选择材料(任务节点,状态,后续令牌).has_value();验收[10]=当前选择&&任务.读取任务方法选择审计(当前选择->记录.记录节点,后续令牌).has_value();
        auto 节点数=节点.有效节点数量(后续令牌);auto 关系数=关系.有效关系数量(后续令牌);auto 记录主=主信息.创建主信息(后续令牌);auto 记录节点=节点.创建节点(节点类型::任务方法选择记录,记录主,后续令牌);
        auto 记录读回=节点.读取节点(记录节点,后续令牌);验收[11]=记录读回&&记录读回->类型==节点类型::任务方法选择记录;
        auto 未知主=主信息.创建主信息(后续令牌);auto 未知节点=节点.创建节点(static_cast<节点类型>(15),未知主,后续令牌);bool 已清理=!句柄有效(未知节点)&&主信息.删除主信息(未知主,后续令牌);
        验收[12]=已清理&&节点.有效节点数量(后续令牌)==节点数+1&&关系.有效关系数量(后续令牌)==关系数;
        auto 错目标=关系.创建关系(关系类型::任务方法选择,任务节点,方法,30,后续令牌);auto 未知关系=关系.创建关系(static_cast<关系类型>(18),任务节点,记录节点,30,后续令牌);
        auto 普通=关系.创建关系(关系类型::引用,记录节点,方法,99,后续令牌);auto 普通重复=关系.创建关系(关系类型::引用,记录节点,方法,100,后续令牌);
        验收[13]=static_cast<std::uint32_t>(关系类型::任务生命周期证据)==15&&static_cast<std::uint32_t>(关系类型::任务方法选择)==16&&!句柄有效(错目标)&&!句柄有效(未知关系)&&句柄有效(普通)&&!句柄有效(普通重复);
        验收[14]=接线.已接域();
    }catch(...){}
    static constexpr std::array<const char*,15> 名称{
        "A01 双向承接授权","A02 精确筹办周期","A03 选择唯一发布","A04 完整记录审计","A05 方法投影",
        "A06 同键同义幂等","A07 同键异义拒绝","A08 同周期其它选择拒绝","A09 并发单一当前","A10 重筹办换代",
        "A11 旧记录审计保留","A12 节点14创建读回","A13 未知节点15写前拒绝","A14 关系16与未知17","A15 接域边界"};
    std::size_t 失败=0;for(std::size_t i=0;i<验收.size();++i){if(!验收[i])++失败;std::cout<<"TASK-PLANNING-S1-"<<名称[i]<<": "<<(验收[i]?"通过":"失败")<<'\n';}
    return{"TASK-PLANNING-S1","任务筹办选择",失败==0,验收.size(),失败};
}
}
