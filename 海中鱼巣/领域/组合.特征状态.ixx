// 文件规则：特征状态组合器只编排槽位和值规格的一次提交，不接触仓库或事务能力。
module;

#include "../核心/句柄.h"
#include "特征值服务.h"

#include <cstdint>

export module 海中鱼巣.领域.组合.特征状态;

import 海中鱼巣.领域.数据操作.特征体系;
import 海中鱼巣.领域.服务.特征;

export namespace 海中鱼巣 {

struct 创建槽位并发布初始状态请求 {
    std::uint64_t 槽位幂等主键 = 0;
    std::uint64_t 特征值幂等主键 = 0;
    节点句柄 宿主;
    节点句柄 特征定义;
    初始特征原始值请求 原始值;
};

class 特征状态组合器 final {
public:
    特征状态组合器(特征业务服务& 特征服务, 特征体系数据操作& 数据操作)
        : 特征服务_(特征服务), 数据操作_(数据操作) {}

    特征体系业务结果 创建槽位并发布初始状态(
        const 创建槽位并发布初始状态请求& 请求) const {
        if (请求.槽位幂等主键 == 0 || 请求.特征值幂等主键 == 0
            || 请求.槽位幂等主键 == 请求.特征值幂等主键
            || !句柄有效(请求.宿主) || !句柄有效(请求.特征定义)) return {};
        const auto 槽位规格 = 特征服务_.形成实例特征槽位规格({
            请求.槽位幂等主键, 请求.宿主, 请求.特征定义});
        if (!槽位规格.成功()) return 映射规格失败(槽位规格.状态);
        const auto 值规格 = 特征服务_.形成初始特征值规格(
            请求.特征值幂等主键, 请求.原始值);
        if (!值规格.成功()) return 映射规格失败(值规格.状态);
        return 数据操作_.创建槽位并发布初始状态(*槽位规格.规格, *值规格.规格);
    }

private:
    static 特征体系业务结果 映射规格失败(特征规格状态 状态) noexcept {
        switch (状态) {
        case 特征规格状态::许可拒绝:
            return {特征体系业务状态::许可拒绝};
        case 特征规格状态::版本漂移:
            return {特征体系业务状态::版本漂移};
        case 特征规格状态::内部不一致:
            return {特征体系业务状态::内部不一致};
        default:
            return {特征体系业务状态::入口拒绝};
        }
    }

    特征业务服务& 特征服务_;
    特征体系数据操作& 数据操作_;
};

}
