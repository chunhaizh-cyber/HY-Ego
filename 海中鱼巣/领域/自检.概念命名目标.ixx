// 文件规则：概念命名目标自检只承载隔离验收，不得成为生产依赖或业务事实来源。
module;

#include "../核心/主信息仓库.h"
#include "../核心/节点仓库.h"
#include "../核心/关系仓库.h"
#include "../核心/索引仓库.h"
#include "存在服务.h"
#include "场景服务.h"
#include "状态服务.h"
#include "动态服务.h"
#include "二次特征服务.h"
#include "因果服务.h"
#include "特征值服务.h"
#include "特征服务.h"
#include "语素服务.h"
#include "需求服务.h"
#include "世界服务.h"

#include <array>
#include <cstddef>
#include <iostream>
#include <optional>

export module 海中鱼巣.领域.自检.概念命名目标;

import 海中鱼巣.领域.初始化.世界树;
import 海中鱼巣.领域.初始化.需求;
import 海中鱼巣.自检.运行器;

export namespace 海中鱼巣 {

自检单元结果 运行概念命名目标自检() {
    主信息仓库 主信息;
    节点仓库 节点(主信息);
    关系仓库 关系(节点);
    索引仓库 索引(节点);
    存在服务 存在(主信息, 节点, 关系);
    场景服务 场景(主信息, 节点, 关系);
    状态服务 状态(主信息, 节点, 关系);
    动态服务 动态(主信息, 节点, 关系);
    二次特征服务 二次特征(主信息, 节点, 关系);
    因果服务 因果(主信息, 节点);
    特征值服务 特征值(主信息, 节点);
    特征服务 特征(主信息, 节点, 关系, 二次特征, 特征值);
    语素服务 语素(主信息, 节点, 关系, 索引);
    需求服务 需求(主信息, 节点, 关系);
    世界服务 世界(主信息, 节点, 存在, 场景, 特征, 状态, 动态, 二次特征, 因果);
    世界树初始化服务 世界树初始化(主信息, 节点, 关系, 世界, 场景, 存在);
    需求初始化服务 需求初始化(特征, 语素, 需求, 状态);

    const bool A01关系数值锁定 = static_cast<std::uint32_t>(关系类型::概念生命周期) == 12
        && static_cast<std::uint32_t>(关系类型::需求目标概念) == 13
        && static_cast<std::uint32_t>(关系类型::任务生命周期) == 14
        && static_cast<std::uint32_t>(关系类型::任务生命周期证据) == 15
        && static_cast<std::uint32_t>(关系类型::任务方法选择) == 16;
    const auto 世界树 = 世界树初始化.初始化自我世界树();
    const auto 拒绝前节点数 = 节点.有效节点数量();
    const auto 拒绝前关系数 = 关系.有效关系数量();
    const auto 无效初始化 = 需求初始化.初始化两个根需求({}, {1001, 1002, 1, 10, 1, 10});
    const bool A06无效前置写前拒绝 = !无效初始化.成功()
        && 节点.有效节点数量() == 拒绝前节点数
        && 关系.有效关系数量() == 拒绝前关系数;
    const auto 根需求 = 需求初始化.初始化两个根需求(世界树, {1001, 1002, 1, 10, 1, 10});
    const auto 共享状态值 = 状态.读取状态值(根需求.概念命名目标状态);
    const bool A03共享抽象状态 = 根需求.成功()
        && 共享状态值 == std::optional<std::int64_t>{1}
        && !状态.状态是否实例状态(根需求.概念命名目标状态);
    const bool A04两个根保持独立 = 根需求.安全根需求.成功() && 根需求.服务根需求.成功()
        && !(根需求.安全根需求.根需求 == 根需求.服务根需求.根需求)
        && 状态.读取状态值(根需求.安全根需求.目标状态) == std::optional<std::int64_t>{10}
        && 状态.读取状态值(根需求.服务根需求.目标状态) == std::optional<std::int64_t>{10};
    const bool A05状态值只作材料 = 根需求.概念命名目标状态 != 根需求.安全根需求.目标状态
        && 根需求.概念命名目标状态 != 根需求.服务根需求.目标状态;
    const bool A07最后写入可读 = A03共享抽象状态;

    const auto 目标概念主信息 = 主信息.创建主信息();
    const auto 目标概念 = 节点.创建节点(节点类型::基础信息, 目标概念主信息);
    const auto 目标关系 = 关系.创建关系(
        关系类型::需求目标概念, 根需求.安全根需求.根需求, 目标概念);
    const auto 目标关系读回 = 关系.读取关系(目标关系);
    const auto 未知关系前数量 = 关系.有效关系数量();
    const auto 未知关系 = 关系.创建关系(
        static_cast<关系类型>(17), 根需求.服务根需求.根需求, 目标概念);
    const bool A02关系仓库接受十三 = 目标关系读回.has_value()
        && 目标关系读回->类型 == 关系类型::需求目标概念
        && !句柄有效(未知关系)
        && 关系.有效关系数量() == 未知关系前数量;
    const bool A08生命周期类型分流 = 关系类型::需求目标概念 != 关系类型::概念生命周期
        && 关系类型::需求目标概念 != 关系类型::实例支持概念;
    const bool A09删除阻断关系保留 = 关系.存在关系(
        关系类型::需求目标概念, 根需求.安全根需求.根需求, 目标概念);
    const bool A10模块边界 = 世界树.成功() && 根需求.成功();

    const std::array 结果组{A01关系数值锁定, A02关系仓库接受十三, A03共享抽象状态,
        A04两个根保持独立, A05状态值只作材料, A06无效前置写前拒绝,
        A07最后写入可读, A08生命周期类型分流, A09删除阻断关系保留, A10模块边界};
    std::size_t 失败数量 = 0;
    for (std::size_t 索引值 = 0; 索引值 < 结果组.size(); ++索引值) {
        const bool 通过 = 结果组[索引值];
        if (!通过) ++失败数量;
        std::cout << "CONCEPT-NAMING-S2-A" << (索引值 + 1) << ": " << (通过 ? "通过" : "失败") << '\n';
    }
    return {"CONCEPT-NAMING-S2", "概念命名目标", 失败数量 == 0, 结果组.size(), 失败数量};
}

}
