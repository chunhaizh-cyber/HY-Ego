// 文件规则：用途事件算法只做不可变值的深度复核、完整回合比较和三分量映射；不得读取仓库、时间源或线程状态。
module;

#include "../核心/句柄.h"

#include <array>
#include <cstddef>
#include <cstdint>
#include <limits>
#include <optional>
#include <set>
#include <tuple>
#include <utility>
#include <vector>

export module 海中鱼巣.领域.算法.用途事件;

import 海中鱼巣.领域.材料.用途事件;
import 海中鱼巣.领域.材料.动态模式;
import 海中鱼巣.领域.材料.因果模式;
import 海中鱼巣.领域.算法.动态模式;
import 海中鱼巣.领域.数据操作.需求任务方法;
import 海中鱼巣.领域.服务.需求;
import 海中鱼巣.线程.协议.任务执行请求;
import 海中鱼巣.线程.任务结果回执协议;

namespace 海中鱼巣 {

namespace 用途事件算法内部 {

用途来源冻结结果 冻结入口拒绝(用途事件拒绝原因 原因) {
    return {用途事件处理状态::入口拒绝, 原因, std::nullopt};
}

用途来源冻结结果 冻结不支持(用途事件拒绝原因 原因) {
    return {用途事件处理状态::不支持, 原因, std::nullopt};
}

用途来源冻结结果 冻结内部不一致(用途事件拒绝原因 原因) {
    return {用途事件处理状态::内部不一致, 原因, std::nullopt};
}

用途事件结果 事件入口拒绝(用途事件拒绝原因 原因) {
    return {用途事件处理状态::入口拒绝, 原因, std::nullopt};
}

用途事件结果 事件不支持(用途事件拒绝原因 原因) {
    return {用途事件处理状态::不支持, 原因, std::nullopt};
}

用途事件结果 事件内部不一致(用途事件拒绝原因 原因) {
    return {用途事件处理状态::内部不一致, 原因, std::nullopt};
}

bool 节点句柄为空(const 节点句柄& 句柄) noexcept {
    return 句柄.仓库编号 == 0 && 句柄.节点编号 == 0 && 句柄.版本号 == 0;
}

bool 回执协议完整(const 任务结果回执材料& 回执, std::uint64_t 当前时间戳) {
    if (当前时间戳 == 0) return false;
    const auto 复核 = 复核任务结果回执材料(
        回执, 任务结果回执准入上下文{当前时间戳});
    return 复核.状态 == 任务结果回执准入状态::可准入
        && 复核.拒绝原因 == 任务结果回执拒绝原因::无;
}

bool 实例自洽(const 单步片段实例候选& 实例) noexcept {
    if (!实例.完整()
        || 实例.结构键哈希 != 计算动态模式结构键稳定哈希(实例.结构键)
        || !动态模式结构键相同(实例.结构键, 实例.来源步骤.结构键)
        || 实例.来源步骤.来源批次.请求.片段序号 != 实例.来源步骤.片段序号
        || 实例.来源步骤.来源批次.请求.规则版本 != 实例.结构键.规则版本
        || 实例.来源步骤.来源动态
            != 实例.来源步骤.来源批次.动态.身份.节点
        || 实例.来源步骤.场景 != 实例.来源步骤.来源批次.场景.节点
        || 实例.来源步骤.主体 != 实例.来源步骤.来源批次.主体.节点
        || 实例.来源步骤.任务 != 实例.来源步骤.来源批次.任务.节点
        || 实例.来源步骤.方法 != 实例.来源步骤.来源批次.方法.节点) {
        return false;
    }
    return 动态模式回合身份相同(
        实例.来源步骤.回合,
        动态模式回合身份{实例.来源步骤.来源批次.请求.回执});
}

bool 实例属于回合与结构键(
    const 单步片段实例候选& 实例,
    const 动态模式回合身份& 回合,
    const 动态模式结构键& 结构键) noexcept {
    return 实例自洽(实例)
        && 动态模式回合身份相同(实例.来源步骤.回合, 回合)
        && 动态模式结构键相同(实例.结构键, 结构键);
}

auto 回合锚点(const 动态模式回合身份& 回合) noexcept {
    const auto& 回执 = 回合.回执;
    const auto 请求编号 = 回执.来源执行请求.has_value()
        ? 回执.来源执行请求->调度请求.请求编号 : 0;
    return std::tuple{
        请求编号, 回执.回执编号, 回执.幂等键,
        回执.来源任务序号, 回执.批次编号};
}

auto 句柄排序键(const 节点句柄& 句柄) noexcept {
    return std::tuple{句柄.仓库编号, 句柄.节点编号, 句柄.版本号};
}

auto 实例排序键(const 单步片段实例候选& 实例) noexcept {
    return std::tuple{
        回合锚点(实例.来源步骤.回合), 实例.来源步骤.片段序号,
        实例.来源步骤.发生时间戳, 句柄排序键(实例.来源步骤.来源动态)};
}

bool 实例组严格有序(const std::vector<单步片段实例候选>& 实例组) noexcept {
    for (std::size_t 索引 = 1; 索引 < 实例组.size(); ++索引) {
        if (!(实例排序键(实例组[索引 - 1]) < 实例排序键(实例组[索引]))) {
            return false;
        }
    }
    return true;
}

bool 因果候选深度自洽(const 因果概率候选& 候选) {
    if (!候选.完整() || 候选.机会证据组.size() < 2
        || 候选.规则版本 != 因果模式规则版本
        || 候选.原因结构键.规则版本 != 候选.规则版本
        || 候选.结果结构键.规则版本 != 候选.规则版本
        || 动态模式结构键相同(候选.原因结构键, 候选.结果结构键)) {
        return false;
    }

    std::uint64_t 正结果数量 = 0;
    std::uint64_t 负结果数量 = 0;
    std::set<decltype(回合锚点(动态模式回合身份{}))> 已见回合;
    for (std::size_t 证据索引 = 0; 证据索引 < 候选.机会证据组.size(); ++证据索引) {
        const auto& 证据 = 候选.机会证据组[证据索引];
        if (!证据.完整()
            || !已见回合.insert(回合锚点(证据.回合)).second
            || (证据索引 != 0
                && !(回合锚点(候选.机会证据组[证据索引 - 1].回合)
                    < 回合锚点(证据.回合)))
            || !实例组严格有序(证据.原因前结果组)
            || !实例组严格有序(证据.原因后结果组)
            || !实例属于回合与结构键(
                证据.原因实例, 证据.回合, 候选.原因结构键)) {
            return false;
        }
        const auto 原因片段 = 证据.原因实例.来源步骤.片段序号;
        for (const auto& 实例 : 证据.原因前结果组) {
            if (!实例属于回合与结构键(实例, 证据.回合, 候选.结果结构键)
                || 实例.来源步骤.片段序号 >= 原因片段) return false;
        }
        for (const auto& 实例 : 证据.原因后结果组) {
            if (!实例属于回合与结构键(实例, 证据.回合, 候选.结果结构键)
                || 实例.来源步骤.片段序号 <= 原因片段) return false;
        }
        if (证据.分类 == 因果机会结果分类::正结果
            && !证据.原因后结果组.empty()) {
            ++正结果数量;
        } else if (证据.分类 == 因果机会结果分类::负结果
            && 证据.原因后结果组.empty()) {
            ++负结果数量;
        } else {
            return false;
        }
    }
    return 正结果数量 == 候选.正结果数
        && 负结果数量 == 候选.负结果数
        && 正结果数量 + 负结果数量 == 候选.机会数;
}

bool 冻结材料完整(const 用途来源冻结材料& 冻结) {
    return 冻结.冻结键与观察主键 != 0
        && 冻结.规则版本 == 用途事件规则版本
        && 冻结.冻结任务序号 != 0 && 冻结.冻结时间戳 != 0
        && 冻结.冻结任务序号 == 冻结.任务执行请求.调度请求.任务序号
        && 冻结.任务执行请求.任务材料.当前生命周期.发生时间戳
            <= 冻结.冻结时间戳
        && 冻结.冻结时间戳 >= 冻结.任务执行请求.调度请求.创建时间戳
        && 冻结.冻结时间戳 <= 冻结.任务执行请求.调度请求.执行时间戳
        && 冻结任务执行请求完整(冻结.任务执行请求)
        && 因果候选深度自洽(冻结.因果候选);
}

bool 参数完整(
    const 规范化任务结果参数& 参数,
    const 任务执行冻结请求& 来源) noexcept {
    const auto& 调度 = 来源.调度请求;
    const auto 最大时间 = static_cast<std::uint64_t>(std::numeric_limits<std::int64_t>::max());
    if (参数.当前时间戳 == 0 || 参数.待重筹办幂等材料编号 == 0
        || 参数.完成状态幂等主键 == 0 || 参数.结算状态幂等主键 == 0
        || 参数.待重筹办发生时间戳 == 0 || 参数.完成发生时间戳 == 0
        || 参数.结算发生时间戳 == 0
        || 参数.待重筹办幂等材料编号 != 调度.待重筹办幂等主键
        || 参数.完成状态幂等主键 == 参数.结算状态幂等主键
        || (!节点句柄为空(参数.因果引用) && !句柄有效(参数.因果引用))) {
        return false;
    }
    const std::array<std::uint64_t, 10> 已占用{
        调度.排队生命周期幂等主键, 调度.执行生命周期幂等主键,
        调度.待重筹办幂等主键, 调度.实际状态幂等主键,
        调度.动态幂等主键, 调度.请求编号, 调度.幂等键,
        调度.回执编号, 调度.回执幂等键, 调度.任务序号};
    for (const auto 编号 : 已占用) {
        if (参数.完成状态幂等主键 == 编号
            || 参数.结算状态幂等主键 == 编号) return false;
    }
    return 参数.待重筹办发生时间戳 == 调度.待重筹办时间戳
        && 参数.待重筹办发生时间戳 >= 调度.执行时间戳
        && 参数.完成发生时间戳 >= 调度.回执时间戳
        && 参数.结算发生时间戳 >= 参数.完成发生时间戳
        && 参数.当前时间戳 <= 调度.截止时间戳
        && 参数.待重筹办发生时间戳 <= 最大时间
        && 参数.完成发生时间戳 <= 最大时间
        && 参数.结算发生时间戳 <= 最大时间;
}

bool 高级身份与冻结身份相同(
    const 高级节点身份& 当前,
    const 任务执行节点身份& 冻结) noexcept {
    return 当前.当前可读() && 冻结.当前可读()
        && 当前.幂等主键 == 冻结.幂等主键
        && 当前.节点 == 冻结.节点 && 当前.类型 == 冻结.类型
        && 当前.主信息 == 冻结.主信息;
}

bool 高级关系与冻结关系相同(
    const 高级关系证据& 当前,
    const 任务执行关系证据& 冻结) noexcept {
    return 当前.当前有效() && 冻结.当前有效()
        && 当前.关系 == 冻结.关系 && 当前.类型 == 冻结.类型
        && 当前.源节点 == 冻结.源节点 && 当前.目标节点 == 冻结.目标节点
        && 当前.顺序号 == 冻结.顺序号;
}

bool 选择材料与冻结相同(
    const 任务方法选择材料& 当前,
    const 任务执行选择材料& 冻结) noexcept {
    return 当前.完整() && 冻结.完整()
        && 高级身份与冻结身份相同(当前.记录身份, 冻结.记录身份)
        && 当前.任务 == 冻结.任务 && 当前.方法 == 冻结.方法
        && 当前.幂等材料编号 == 冻结.幂等材料编号
        && 高级关系与冻结关系相同(当前.方法投影关系, 冻结.方法投影关系)
        && 高级关系与冻结关系相同(当前.发布关系, 冻结.发布关系)
        && 当前.来源生命周期关系 == 冻结.来源生命周期关系
        && 当前.来源生命周期版本 == 冻结.来源生命周期版本
        && 当前.来源方法生命周期关系 == 冻结.来源方法生命周期关系
        && 当前.来源方法生命周期版本 == 冻结.来源方法生命周期版本
        && 当前.排序规则版本 == 冻结.排序规则版本
        && 当前.召回请求规则版本 == 冻结.召回请求规则版本
        && 当前.来源候选数量 == 冻结.来源候选数量;
}

bool 任务提交身份一致(
    const 任务提交结果& 提交,
    const 任务执行冻结请求& 冻结,
    分层任务生命周期阶段 阶段) noexcept {
    const auto& 当前 = 提交.材料;
    const auto& 来源 = 冻结.任务材料;
    if (!提交.成功() || !当前.完整承接()
        || !高级身份与冻结身份相同(当前.身份, 来源.身份)
        || 当前.来源需求 != 来源.来源需求 || 当前.虚拟存在 != 来源.虚拟存在
        || 当前.场景 != 来源.场景 || 当前.目标状态 != 来源.目标状态
        || !高级关系与冻结关系相同(
            当前.需求拥有任务关系, 来源.需求拥有任务关系)
        || !高级关系与冻结关系相同(
            当前.任务来源需求关系, 来源.任务来源需求关系)
        || !高级关系与冻结关系相同(
            当前.虚拟存在关系, 来源.虚拟存在关系)
        || !高级关系与冻结关系相同(当前.场景关系, 来源.场景关系)
        || !高级关系与冻结关系相同(当前.目标状态关系, 来源.目标状态关系)
        || 当前.当前生命周期.阶段 != 阶段
        || !来源.当前选择.has_value() || !当前.当前选择.has_value()) return false;
    return 选择材料与冻结相同(*当前.当前选择, *来源.当前选择);
}

bool 实际结果关系一致(
    const 任务提交结果& 提交,
    节点句柄 实际状态) noexcept {
    if (!提交.材料.实际结果状态.has_value()
        || !提交.材料.实际结果关系.has_value()) return false;
    const auto& 关系 = *提交.材料.实际结果关系;
    return *提交.材料.实际结果状态 == 实际状态
        && 关系.当前有效() && 关系.类型 == 关系类型::引用
        && 关系.源节点 == 提交.材料.身份.节点
        && 关系.目标节点 == 实际状态 && 关系.顺序号 == 20;
}

bool 需求结算未承载正式材料(const 需求提交结果& 结算) noexcept {
    return !结算.成功()
        && 结算.材料.状态 == 需求任务方法读取状态::入口拒绝
        && !结算.材料.身份.当前可读()
        && !结算.材料.完整目标状态需求()
        && 结算.材料.当前结算 == 分层需求结算结论::未结算
        && !结算.材料.最近结算状态.has_value();
}

bool 需求关系语义相同(
    const 高级关系证据& 关系,
    关系类型 类型,
    节点句柄 源节点,
    节点句柄 目标节点,
    std::int64_t 顺序号) noexcept {
    return 关系.当前有效() && 关系.类型 == 类型
        && 关系.源节点 == 源节点 && 关系.目标节点 == 目标节点
        && 关系.顺序号 == 顺序号;
}

bool 已满足需求材料与冻结一致(
    const 需求权威材料& 需求,
    const 任务执行冻结请求& 冻结) noexcept {
    const auto 需求节点 = 冻结.任务材料.来源需求;
    const auto 主体 = 冻结.任务材料.虚拟存在;
    const bool 宿主关系一致 = 需求.主体 == 需求.目标宿主
        ? 需求关系语义相同(
            需求.目标宿主关系, 关系类型::引用,
            需求.目标宿主, 需求节点, 2)
        : 需求关系语义相同(
            需求.目标宿主关系, 关系类型::引用,
            需求节点, 需求.目标宿主, 2);
    return 需求.完整目标状态需求()
        && 需求.身份.节点 == 需求节点 && 需求.身份.类型 == 节点类型::需求
        && 需求.主体 == 主体 && 需求.场景 == 冻结.任务材料.场景
        && 需求.目标状态 == 冻结.任务材料.目标状态
        && 需求关系语义相同(
            需求.主体关系, 关系类型::引用, 需求节点, 需求.主体, 1)
        && 宿主关系一致
        && 需求关系语义相同(
            需求.场景关系, 关系类型::引用, 需求节点, 需求.场景, 3)
        && 需求关系语义相同(
            需求.目标特征关系, 关系类型::引用,
            需求节点, 需求.目标特征, 4)
        && 需求关系语义相同(
            需求.当前特征状态关系, 关系类型::引用,
            需求节点, 需求.当前特征状态材料, 5)
        && 需求关系语义相同(
            需求.目标状态关系, 关系类型::模板,
            需求节点, 需求.目标状态, 0);
}

bool 共同身份一致(
    const 用途来源冻结材料& 冻结,
    const 规范化任务结果来源& 结果) noexcept {
    if (!结果.完整回执.来源执行请求.has_value()
        || !冻结任务执行请求相同(
            冻结.任务执行请求, *结果.完整回执.来源执行请求)) return false;
    const auto& 请求 = 冻结.任务执行请求;
    const auto& 任务 = 请求.任务材料;
    const auto& 方法 = 请求.方法材料;
    const auto& 动作 = 请求.动作材料;
    const auto& 回执 = 结果.完整回执;
    const auto& 裁决 = 结果.目标裁决;
    return 任务.当前选择.has_value()
        && 回执.来源任务序号 == 冻结.冻结任务序号
        && 回执.发生时间戳 >= 冻结.冻结时间戳
        && 回执.句柄组.目标任务 == 任务.身份.节点
        && 回执.句柄组.目标方法 == 方法.身份.节点
        && 回执.句柄组.目标动作入口 == 动作.身份.节点
        && 回执.句柄组.场景 == 任务.场景
        && 回执.句柄组.主体 == 任务.虚拟存在
        && 裁决.需求 == 任务.来源需求
        && 裁决.目标状态 == 任务.目标状态
        && 裁决.实际状态 == 回执.句柄组.实际结果状态
        && 裁决.目标状态材料.完整抽象状态()
        && 裁决.实际状态材料.完整实例状态()
        && 裁决.目标状态材料.状态节点 == 任务.目标状态
        && 裁决.实际状态材料.状态节点 == 回执.句柄组.实际结果状态
        && 裁决.实际状态材料.幂等主键
            == 请求.调度请求.实际状态幂等主键
        && 裁决.实际状态材料.场景 == 任务.场景
        && 裁决.实际状态材料.主体 == 任务.虚拟存在
        && 裁决.实际状态材料.状态值 == 请求.调度请求.实际状态值
        && 裁决.实际状态材料.发生时间戳 == 请求.调度请求.实际状态时间戳;
}

bool 待结算提示一致(
    const 规范化待需求结算提示& 提示,
    const 规范化任务结果来源& 结果,
    const 任务执行冻结请求& 冻结) noexcept {
    return 提示.任务 == 冻结.任务材料.身份.节点
        && 提示.需求 == 冻结.任务材料.来源需求
        && 提示.实际状态 == 结果.完整回执.句柄组.实际结果状态
        && 提示.动态证据 == 结果.完整回执.句柄组.动态证据
        && 提示.因果引用 == 结果.参数.因果引用
        && 提示.任务完成状态 == 结果.任务提交.状态
        && 提示.需求结算状态 == 结果.需求结算.状态
        && 提示.结算状态幂等主键 == 结果.参数.结算状态幂等主键
        && 提示.结算发生时间戳 == 结果.参数.结算发生时间戳
        && 提示.承载性质 == 待结算提示承载性质::仅非权威请求材料;
}

bool 正式结果组合一致(
    const 规范化任务结果来源& 结果,
    const 任务执行冻结请求& 冻结) noexcept {
    if (!结果.目标裁决.成功()) return false;
    switch (结果.正式结果) {
    case 用途正式结果分类::未达成已转待重筹办:
        return 结果.收口原因 == 用途结果收口原因::无
            && 结果.目标裁决.裁决 == 需求目标状态裁决::未达成
            && 结果.目标裁决.目标状态材料.状态值
                != 结果.目标裁决.实际状态材料.状态值
            && 任务提交身份一致(
                结果.任务提交, 冻结, 分层任务生命周期阶段::待重筹办)
            && 结果.任务提交.材料.当前生命周期.发生时间戳
                == 结果.参数.待重筹办发生时间戳
            && !结果.任务提交.材料.实际结果状态.has_value()
            && !结果.任务提交.材料.实际结果关系.has_value()
            && 结果.需求结算.状态 == 需求任务方法业务状态::入口拒绝
            && 需求结算未承载正式材料(结果.需求结算)
            && !结果.待结算提示.has_value();
    case 用途正式结果分类::任务已完成待需求结算:
        return 结果.收口原因 == 用途结果收口原因::需求结算待重试
            && 结果.目标裁决.裁决 == 需求目标状态裁决::已达成
            && 结果.目标裁决.目标状态材料.状态值
                == 结果.目标裁决.实际状态材料.状态值
            && 任务提交身份一致(
                结果.任务提交, 冻结, 分层任务生命周期阶段::已完成)
            && 结果.任务提交.材料.当前生命周期.发生时间戳
                == 结果.参数.完成发生时间戳
            && 实际结果关系一致(
                结果.任务提交, 结果.完整回执.句柄组.实际结果状态)
            && (结果.需求结算.状态 == 需求任务方法业务状态::入口拒绝
                || 结果.需求结算.状态 == 需求任务方法业务状态::许可拒绝
                || 结果.需求结算.状态 == 需求任务方法业务状态::版本漂移)
            && 需求结算未承载正式材料(结果.需求结算)
            && 结果.待结算提示.has_value()
            && 待结算提示一致(*结果.待结算提示, 结果, 冻结);
    case 用途正式结果分类::已完成并结算:
        return 结果.收口原因 == 用途结果收口原因::无
            && 结果.目标裁决.裁决 == 需求目标状态裁决::已达成
            && 结果.目标裁决.目标状态材料.状态值
                == 结果.目标裁决.实际状态材料.状态值
            && 任务提交身份一致(
                结果.任务提交, 冻结, 分层任务生命周期阶段::已完成)
            && 结果.任务提交.材料.当前生命周期.发生时间戳
                == 结果.参数.完成发生时间戳
            && 实际结果关系一致(
                结果.任务提交, 结果.完整回执.句柄组.实际结果状态)
            && 结果.需求结算.成功()
            && 已满足需求材料与冻结一致(结果.需求结算.材料, 冻结)
            && 结果.需求结算.材料.当前结算 == 分层需求结算结论::已满足
            && 结果.需求结算.材料.最近结算状态.has_value()
            && 句柄有效(*结果.需求结算.材料.最近结算状态)
            && !结果.待结算提示.has_value();
    default:
        return false;
    }
}

结构化结果效用 形成效用(
    用途正式结果分类 正式结果,
    const 因果概率候选& 候选) {
    结构化结果效用 输出;
    输出.正式结果 = 正式结果;
    输出.历史概率 = {
        候选.原因结构键, 候选.结果结构键, 候选.规则版本,
        候选.机会数, 候选.正结果数, 候选.负结果数, 候选.Q10000};
    switch (正式结果) {
    case 用途正式结果分类::未达成已转待重筹办:
        输出.任务达成 = 任务达成分量::未达成;
        输出.需求结算 = 需求结算分量::未形成;
        输出.观察阶段 = 用途观察阶段::尝试未达成;
        break;
    case 用途正式结果分类::任务已完成待需求结算:
        输出.任务达成 = 任务达成分量::已达成;
        输出.需求结算 = 需求结算分量::待结算;
        输出.观察阶段 = 用途观察阶段::待结算;
        break;
    case 用途正式结果分类::已完成并结算:
        输出.任务达成 = 任务达成分量::已达成;
        输出.需求结算 = 需求结算分量::已满足;
        输出.观察阶段 = 用途观察阶段::最终已结算;
        break;
    default:
        break;
    }
    return 输出;
}

}

}

export namespace 海中鱼巣 {

用途来源冻结结果 执行用途来源冻结(const 用途来源冻结请求& 请求) {
    using namespace 用途事件算法内部;
    if (请求.规则版本 != 用途事件规则版本) {
        return 冻结不支持(用途事件拒绝原因::规则版本不支持);
    }
    if (请求.冻结键 == 0 || 请求.冻结任务序号 == 0 || 请求.冻结时间戳 == 0
        || !冻结任务执行请求完整(请求.任务执行请求)) {
        return 冻结入口拒绝(用途事件拒绝原因::来源冻结不完整);
    }
    if (请求.冻结任务序号 != 请求.任务执行请求.调度请求.任务序号) {
        return 冻结入口拒绝(用途事件拒绝原因::来源冻结不完整);
    }
    if (请求.冻结时间戳
            < 请求.任务执行请求.任务材料.当前生命周期.发生时间戳
        || 请求.冻结时间戳 < 请求.任务执行请求.调度请求.创建时间戳
        || 请求.冻结时间戳 > 请求.任务执行请求.调度请求.执行时间戳) {
        return 冻结入口拒绝(用途事件拒绝原因::来源冻结不完整);
    }
    if (!因果候选深度自洽(请求.因果候选)) {
        return 冻结入口拒绝(用途事件拒绝原因::因果候选不完整);
    }
    用途来源冻结材料 材料{
        请求.因果候选, 请求.任务执行请求, 请求.冻结键,
        请求.规则版本, 请求.冻结任务序号, 请求.冻结时间戳};
    if (!冻结材料完整(材料)) {
        return 冻结内部不一致(用途事件拒绝原因::算法不变量破坏);
    }
    return {用途事件处理状态::已形成, 用途事件拒绝原因::无, std::move(材料)};
}

用途事件结果 执行结构化结果效用(const 用途事件请求& 请求) {
    using namespace 用途事件算法内部;
    if (请求.规则版本 != 用途事件规则版本
        || 请求.冻结来源.规则版本 != 请求.规则版本) {
        return 事件不支持(用途事件拒绝原因::规则版本不支持);
    }
    if (!冻结材料完整(请求.冻结来源)) {
        return 事件入口拒绝(用途事件拒绝原因::来源冻结不完整);
    }
    const auto& 结果 = 请求.结果来源;
    if (结果.正式结果 == 用途正式结果分类::未定义) {
        return 事件入口拒绝(用途事件拒绝原因::结果尚未正式收口);
    }
    if (结果.完整回执.材料性质
            != 任务结果回执材料性质::非权威任务执行结果证据
        || 结果.协议结果.状态 != 任务结果回执准入状态::可准入
        || 结果.协议结果.拒绝原因 != 任务结果回执拒绝原因::无
        || !回执协议完整(结果.完整回执, 结果.参数.当前时间戳)) {
        return 事件入口拒绝(用途事件拒绝原因::非新版完整回执);
    }
    if (!结果.完整回执.来源执行请求.has_value()
        || !冻结任务执行请求相同(
            请求.冻结来源.任务执行请求,
            *结果.完整回执.来源执行请求)) {
        return 事件入口拒绝(用途事件拒绝原因::来源冻结回合不一致);
    }
    if (!参数完整(结果.参数, 请求.冻结来源.任务执行请求)) {
        return 事件内部不一致(用途事件拒绝原因::正式结果材料矛盾);
    }
    if (!共同身份一致(请求.冻结来源, 结果)) {
        return 事件内部不一致(用途事件拒绝原因::身份材料矛盾);
    }
    if (!正式结果组合一致(结果, 请求.冻结来源.任务执行请求)) {
        return 事件内部不一致(用途事件拒绝原因::正式结果材料矛盾);
    }

    const auto& 冻结请求 = 请求.冻结来源.任务执行请求;
    用途事件材料 事件;
    事件.冻结来源 = 请求.冻结来源;
    事件.结果来源 = 结果;
    事件.需求 = 冻结请求.任务材料.来源需求;
    事件.任务 = 冻结请求.任务材料.身份.节点;
    事件.选择记录 = 冻结请求.任务材料.当前选择->记录身份.节点;
    事件.方法 = 冻结请求.方法材料.身份.节点;
    事件.动作 = 冻结请求.动作材料.身份.节点;
    事件.场景 = 冻结请求.任务材料.场景;
    事件.主体 = 冻结请求.任务材料.虚拟存在;
    事件.目标状态 = 冻结请求.任务材料.目标状态;
    事件.实际状态 = 结果.完整回执.句柄组.实际结果状态;
    事件.动态证据 = 结果.完整回执.句柄组.动态证据;
    事件.目标状态值 = 结果.目标裁决.目标状态材料.状态值;
    事件.实际状态值 = 结果.目标裁决.实际状态材料.状态值;
    事件.效用 = 形成效用(结果.正式结果, 请求.冻结来源.因果候选);
    return {用途事件处理状态::已形成, 用途事件拒绝原因::无, std::move(事件)};
}

}
