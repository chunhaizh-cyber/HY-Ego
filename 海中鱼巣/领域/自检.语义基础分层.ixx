// 文件规则：语义基础分层自检只验证七个隔离模块，不进入生产依赖。
module;

#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
#include "../核心/主信息仓库.h"
#include "../核心/节点仓库.h"
#include "../核心/关系仓库.h"
#include "../核心/索引仓库.h"

#include <algorithm>
#include <array>
#include <cstddef>
#include <cstdint>
#include <iostream>
#include <optional>
#include <stdexcept>
#include <string_view>
#include <thread>
#include <type_traits>
#include <utility>
#include <vector>
#endif

export module 海中鱼巣.领域.自检.语义基础分层;

#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
import 海中鱼巣.核心.协调.结构事务;
import 海中鱼巣.核心.执行器.结构写入;
import 海中鱼巣.领域.数据操作.状态动态;
import 海中鱼巣.领域.服务.状态;
import 海中鱼巣.领域.服务.动态;
import 海中鱼巣.领域.数据操作.语素基础;
import 海中鱼巣.领域.服务.基础信息;
import 海中鱼巣.领域.服务.语素;
import 海中鱼巣.领域.组合.语素概念入口;
import 海中鱼巣.领域.数据操作.轻量因果;
import 海中鱼巣.领域.服务.轻量因果;
import 海中鱼巣.自检.运行器;

export namespace 海中鱼巣 {

namespace 语义基础分层自检内部 {

struct 结构数量 {
    std::uint64_t 节点 = 0;
    std::uint64_t 关系 = 0;
    std::uint64_t 索引 = 0;

    bool operator==(const 结构数量&) const = default;
};

struct 节点夹具 {
    节点句柄 节点;
    主信息句柄 主信息;

    bool 完整() const noexcept {
        return 句柄有效(节点) && 句柄有效(主信息);
    }
};

template <typename 调用>
bool 验证语义单提交竞争(std::string_view 标签, 调用&& 执行调用) {
    constexpr std::size_t 线程数量 = 6;
    std::vector<语义基础业务结果> 结果组(线程数量);
    std::vector<std::thread> 线程组;
    for (std::size_t 索引 = 0; 索引 < 线程数量; ++索引) {
        线程组.emplace_back([&, 索引] { 结果组[索引] = 执行调用(); });
    }
    for (auto& 线程 : 线程组) 线程.join();
    const auto 提交数 = std::count_if(结果组.begin(), 结果组.end(), [](const auto& 结果) {
        return 结果.状态 == 语义基础业务状态::已提交;
    });
    const auto 合法收口数 = std::count_if(结果组.begin(), 结果组.end(), [](const auto& 结果) {
        return 结果.状态 == 语义基础业务状态::已提交
            || 结果.状态 == 语义基础业务状态::幂等读回
            || 结果.状态 == 语义基础业务状态::许可拒绝;
    });
    std::cout << "SERVICE-DATA-S4-EVIDENCE concurrent-" << 标签
        << " committed=" << 提交数 << " closed=" << 合法收口数 << '\n';
    return 提交数 == 1 && 合法收口数 == 线程数量;
}

template <typename 调用>
bool 验证因果单提交竞争(std::string_view 标签, 调用&& 执行调用) {
    constexpr std::size_t 线程数量 = 6;
    std::vector<轻量因果业务结果> 结果组(线程数量);
    std::vector<std::thread> 线程组;
    for (std::size_t 索引 = 0; 索引 < 线程数量; ++索引) {
        线程组.emplace_back([&, 索引] { 结果组[索引] = 执行调用(); });
    }
    for (auto& 线程 : 线程组) 线程.join();
    const auto 提交数 = std::count_if(结果组.begin(), 结果组.end(), [](const auto& 结果) {
        return 结果.状态 == 轻量因果业务状态::已提交;
    });
    const auto 合法收口数 = std::count_if(结果组.begin(), 结果组.end(), [](const auto& 结果) {
        return 结果.状态 == 轻量因果业务状态::已提交
            || 结果.状态 == 轻量因果业务状态::幂等读回
            || 结果.状态 == 轻量因果业务状态::许可拒绝;
    });
    std::cout << "SERVICE-DATA-S4-EVIDENCE concurrent-" << 标签
        << " committed=" << 提交数 << " closed=" << 合法收口数 << '\n';
    return 提交数 == 1 && 合法收口数 == 线程数量;
}

}

自检单元结果 运行语义基础分层自检(
    bool 仓库合同回归通过,
    bool 会话回归通过,
    bool 存在场景回归通过,
    bool 会话材料回归通过,
    bool 状态动态回归通过,
    bool 特征值事务回归通过,
    bool 特征体系回归通过) {
    using namespace 语义基础分层自检内部;

    static_assert(!std::is_default_constructible_v<语素入口写入规格>);
    static_assert(!std::is_default_constructible_v<轻量因果写入规格>);
    static_assert(!std::is_pointer_v<decltype(语素入口值式材料{}.语素入口)>);
    static_assert(!std::is_pointer_v<decltype(轻量因果值式材料{}.因果引用)>);
    static_assert(std::is_same_v<
        decltype(std::declval<const 基础信息业务服务&>().创建基础信息身份({})),
        语义基础业务结果>);
    static_assert(std::is_same_v<
        decltype(std::declval<const 轻量因果业务服务&>().创建轻量因果({})),
        轻量因果业务结果>);

    std::array<bool, 20> 验收{};
    try {
        constexpr std::uint64_t 关系仓库编号 = 75003;
        结构事务协调器 协调器(750);
        const auto 接线 = 协调器.生成接线();
        主信息仓库 主信息(75001, 接线);
        节点仓库 节点(主信息, 75002, 接线);
        关系仓库 关系(节点, 关系仓库编号, 接线);
        索引仓库 索引(节点, 接线);
        结构写入执行器 夹具执行器(接线, &主信息, &节点, &关系, &索引);
        状态动态数据操作 状态动态数据(接线, 主信息, 节点, 关系, 索引, 关系仓库编号);
        状态业务服务 状态服务(状态动态数据);
        动态业务服务 动态服务(状态服务, 状态动态数据);
        语素基础数据操作 语素数据(接线, 主信息, 节点, 关系, 索引, 关系仓库编号);
        基础信息业务服务 基础服务(语素数据);
        语素业务服务 语素服务(语素数据);
        语素概念入口组合器 语素组合器(语素服务, 语素数据);
        轻量因果数据操作 因果数据(接线, 主信息, 节点, 关系, 索引);
        轻量因果业务服务 因果服务(动态服务, 因果数据);

        const auto 读取数量 = [&] {
            return 结构数量{节点.有效节点数量(), 关系.有效关系数量(), 索引.有效主键数量()};
        };

        const auto 创建夹具节点 = [&](节点类型 类型, std::uint64_t 主键 = 0) {
            节点夹具 输出;
            const auto 结果 = 夹具执行器.执行([&](结构写入会话& 会话) {
                const auto 主结果 = 会话.创建主信息候选();
                if (!主结果.成功() || !主结果.值.has_value()) return;
                输出.主信息 = *主结果.值;
                const auto 节点结果 = 会话.创建节点候选(类型, 输出.主信息);
                if (!节点结果.成功() || !节点结果.值.has_value()) return;
                输出.节点 = *节点结果.值;
                if (主键 != 0 && !会话.绑定主键(主键, 输出.节点).成功()) return;
                bool 完整 = 会话.主信息可读(输出.主信息) && 会话.节点可读(输出.节点);
                if (主键 != 0) 完整 = 会话.主键绑定匹配(主键, 输出.节点) && 完整;
                if (完整) (void)会话.请求提交();
            });
            return 结果.状态 == 结构写入状态::已提交 ? 输出 : 节点夹具{};
        };

        const auto 存在 = 创建夹具节点(节点类型::存在);
        const auto 场景 = 创建夹具节点(节点类型::场景);
        const auto 特征 = 创建夹具节点(节点类型::特征);
        const auto 特征值 = 创建夹具节点(节点类型::特征值);
        const auto 二次特征 = 创建夹具节点(节点类型::二次特征);
        const auto 因果目标 = 创建夹具节点(节点类型::因果引用);
        const auto 需求 = 创建夹具节点(节点类型::需求);
        const auto 任务 = 创建夹具节点(节点类型::任务);
        const auto 方法 = 创建夹具节点(节点类型::方法);
        constexpr std::uint64_t 基础冲突主键 = 0x0750'0000'0000'0001ULL;
        constexpr std::uint64_t 因果冲突主键 = 0x0750'0000'0000'0002ULL;
        const auto 基础冲突节点 = 创建夹具节点(节点类型::任务, 基础冲突主键);
        const auto 因果冲突节点 = 创建夹具节点(节点类型::存在, 因果冲突主键);

        const auto 抽象状态结果 = 状态服务.创建抽象状态({0x0750'0000'0000'0010ULL, 10});
        const auto 抽象动态结果 = 动态服务.创建抽象动态({0x0750'0000'0000'0011ULL, 11});
        const auto 前状态结果 = 状态服务.创建完整实例状态({
            0x0750'0000'0000'0012ULL, 场景.节点, 存在.节点, 100, 1});
        const auto 后状态结果 = 状态服务.创建完整实例状态({
            0x0750'0000'0000'0013ULL, 场景.节点, 存在.节点, 120, 2});
        const auto 前状态 = 状态服务.读取主键状态材料(0x0750'0000'0000'0012ULL);
        const auto 后状态 = 状态服务.读取主键状态材料(0x0750'0000'0000'0013ULL);
        const auto 实例动态结果 = 动态服务.记录已有状态变化动态({
            0x0750'0000'0000'0014ULL, 前状态.状态节点, 后状态.状态节点,
            特征.节点, {}});
        const auto 抽象状态 = 状态服务.读取主键状态材料(0x0750'0000'0000'0010ULL);
        const auto 抽象动态 = 动态服务.读取主键动态材料(0x0750'0000'0000'0011ULL);
        const auto 实例动态 = 动态服务.读取主键动态材料(0x0750'0000'0000'0014ULL);

        验收[0] = 接线.已接域() && 夹具执行器.有效() && 语素数据.有效() && 因果数据.有效()
            && !std::is_constructible_v<基础信息业务服务, 主信息仓库&>
            && !std::is_constructible_v<语素业务服务, 结构事务令牌>
            && !std::is_constructible_v<轻量因果业务服务, 结构写入执行器&>;
        验收[1] = 存在.完整() && 场景.完整() && 特征.完整() && 特征值.完整()
            && 二次特征.完整() && 因果目标.完整() && 需求.完整() && 任务.完整()
            && 方法.完整() && 基础冲突节点.完整() && 因果冲突节点.完整()
            && 抽象状态结果.成功() && 抽象动态结果.成功()
            && 前状态结果.成功() && 后状态结果.成功() && 实例动态结果.成功()
            && 抽象状态.完整抽象状态() && 抽象动态.完整抽象动态()
            && 前状态.完整实例状态() && 实例动态.完整实例动态();

        constexpr std::uint64_t 基础主键 = 0x0750'0000'0000'0100ULL;
        const auto 基础前 = 读取数量();
        const auto 基础创建 = 基础服务.创建基础信息身份({基础主键});
        const auto 基础后 = 读取数量();
        const auto 基础重复 = 基础服务.创建基础信息身份({基础主键});
        const auto 基础冲突 = 基础服务.创建基础信息身份({基础冲突主键});
        const auto 基础材料 = 基础服务.读取主键基础信息(基础主键);
        验收[2] = 基础创建.状态 == 语义基础业务状态::已提交
            && 基础重复.状态 == 语义基础业务状态::幂等读回
            && 基础冲突.状态 == 语义基础业务状态::幂等冲突
            && 基础材料.完整() && 基础材料.基础信息 == 基础创建.基础信息.基础信息
            && 基础后.节点 == 基础前.节点 + 1 && 基础后.关系 == 基础前.关系
            && 基础后.索引 == 基础前.索引 + 1 && 读取数量() == 基础后;

        const auto 文本拒绝前 = 读取数量();
        const std::array<创建语素概念入口请求, 4> 文本拒绝请求组{{
            {0x0750'0000'0000'0200ULL, L"", 基础材料.基础信息, 特征.节点},
            {0x0750'0000'0000'0201ULL, L"鱼 巢", 基础材料.基础信息, 特征.节点},
            {0x0750'0000'0000'0202ULL, L"鱼/巢", 基础材料.基础信息, 特征.节点},
            {0x0750'0000'0000'0203ULL, L"海中鱼巢", 基础材料.基础信息, 特征.节点}}};
        bool 文本全部拒绝 = true;
        for (const auto& 请求 : 文本拒绝请求组) {
            文本全部拒绝 = 文本全部拒绝
                && 语素组合器.创建语素概念入口(请求).状态 == 语义基础业务状态::入口拒绝;
        }
        验收[3] = 文本全部拒绝 && 读取数量() == 文本拒绝前;

        const std::vector<节点句柄> 对应白名单{
            基础材料.基础信息, 存在.节点, 场景.节点, 特征.节点,
            抽象状态.状态节点, 抽象动态.动态节点, 二次特征.节点,
            因果目标.节点, 需求.节点, 任务.节点, 方法.节点};
        bool 对应白名单通过 = true;
        std::uint64_t 对应主键 = 0x0750'0000'0000'0300ULL;
        for (const auto 目标 : 对应白名单) {
            const auto 结果 = 语素服务.创建语素入口({对应主键++, 目标});
            对应白名单通过 = 对应白名单通过 && 结果.状态 == 语义基础业务状态::已提交
                && 结果.语素.完整() && 结果.语素.包含关系(语素关系角色::对应信息, 目标);
        }
        const auto 对应拒绝前 = 读取数量();
        const std::array<节点句柄, 3> 对应拒绝组{
            特征值.节点, 前状态.状态节点, 实例动态.动态节点};
        for (const auto 目标 : 对应拒绝组) {
            对应白名单通过 = 对应白名单通过
                && 语素服务.创建语素入口({对应主键++, 目标}).状态 == 语义基础业务状态::入口拒绝;
        }
        验收[4] = 对应白名单通过 && 读取数量() == 对应拒绝前;

        const std::vector<节点句柄> 追溯白名单{
            基础材料.基础信息, 存在.节点, 特征.节点, 抽象状态.状态节点,
            抽象动态.动态节点, 二次特征.节点, 因果目标.节点};
        bool 追溯白名单通过 = true;
        std::uint64_t 追溯主键 = 0x0750'0000'0000'0400ULL;
        for (const auto 目标 : 追溯白名单) {
            const auto 结果 = 语素组合器.创建语素概念入口({
                追溯主键++, L"鱼", 基础材料.基础信息, 目标});
            追溯白名单通过 = 追溯白名单通过 && 结果.状态 == 语义基础业务状态::已提交
                && 结果.语素.完整()
                && 结果.语素.包含关系(语素关系角色::概念追溯, 目标);
        }
        const auto 追溯拒绝前 = 读取数量();
        const std::array<节点句柄, 6> 追溯拒绝组{
            场景.节点, 需求.节点, 任务.节点, 方法.节点,
            前状态.状态节点, 实例动态.动态节点};
        for (const auto 目标 : 追溯拒绝组) {
            追溯白名单通过 = 追溯白名单通过
                && 语素组合器.创建语素概念入口({
                    追溯主键++, L"鱼", 基础材料.基础信息, 目标}).状态
                    == 语义基础业务状态::入口拒绝;
        }
        验收[5] = 追溯白名单通过 && 读取数量() == 追溯拒绝前;

        constexpr std::uint64_t 单入口主键 = 0x0750'0000'0000'0500ULL;
        const auto 单入口前 = 读取数量();
        const auto 单入口 = 语素服务.创建语素入口({单入口主键, 需求.节点});
        const auto 单入口后 = 读取数量();
        const auto 单入口读回 = 语素服务.读取主键语素入口(单入口主键);
        验收[6] = 单入口.状态 == 语义基础业务状态::已提交 && 单入口读回.完整()
            && 单入口读回.对应信息组.size() == 1 && 单入口读回.对应关系组.size() == 1
            && 单入口读回.对应关系组.front().完整()
            && 单入口后.节点 == 单入口前.节点 + 1
            && 单入口后.关系 == 单入口前.关系 + 1
            && 单入口后.索引 == 单入口前.索引 + 1;

        constexpr std::uint64_t 概念入口主键 = 0x0750'0000'0000'0501ULL;
        constexpr std::uint64_t 失败概念主键 = 0x0750'0000'0000'0502ULL;
        const auto 概念入口前 = 读取数量();
        const auto 概念入口 = 语素组合器.创建语素概念入口({
            概念入口主键, L"巢", 基础材料.基础信息, 特征.节点});
        const auto 概念入口后 = 读取数量();
        const auto 失败概念前 = 读取数量();
        const auto 失败概念 = 语素组合器.创建语素概念入口({
            失败概念主键, L"巢", 基础材料.基础信息, 需求.节点});
        验收[7] = 概念入口.状态 == 语义基础业务状态::已提交 && 概念入口.语素.完整()
            && 概念入口.语素.对应关系组.size() == 1
            && 概念入口.语素.追溯关系组.size() == 1
            && 概念入口后.节点 == 概念入口前.节点 + 1
            && 概念入口后.关系 == 概念入口前.关系 + 2
            && 概念入口后.索引 == 概念入口前.索引 + 1
            && 失败概念.状态 == 语义基础业务状态::入口拒绝
            && 读取数量() == 失败概念前
            && 语素服务.读取主键语素入口(失败概念主键).状态 == 语义基础读取状态::未找到;

        const auto 追加前 = 读取数量();
        const auto 追加对应 = 语素服务.追加语素关系({
            单入口.语素.语素入口, 任务.节点, 语素关系角色::对应信息});
        const auto 追加追溯 = 语素服务.追加语素关系({
            单入口.语素.语素入口, 特征.节点, 语素关系角色::概念追溯});
        const auto 追加后 = 读取数量();
        const auto 追加读回 = 语素服务.读取语素入口(单入口.语素.语素入口);
        验收[8] = 追加对应.状态 == 语义基础业务状态::已提交
            && 追加追溯.状态 == 语义基础业务状态::已提交
            && 追加读回.完整() && 追加读回.对应信息组.size() == 2
            && 追加读回.概念追溯组.size() == 1
            && 追加读回.包含关系(语素关系角色::对应信息, 任务.节点)
            && 追加读回.包含关系(语素关系角色::概念追溯, 特征.节点)
            && 追加后.节点 == 追加前.节点 && 追加后.关系 == 追加前.关系 + 2
            && 追加后.索引 == 追加前.索引;

        const auto 重复前 = 读取数量();
        const auto 重复关系 = 语素服务.追加语素关系({
            单入口.语素.语素入口, 任务.节点, 语素关系角色::对应信息});
        const auto 非法角色 = 语素服务.追加语素关系({
            单入口.语素.语素入口, 特征.节点, static_cast<语素关系角色>(99)});
        const auto 错误入口 = 语素服务.追加语素关系({
            基础材料.基础信息, 特征.节点, 语素关系角色::对应信息});
        验收[9] = 重复关系.状态 == 语义基础业务状态::幂等读回
            && 非法角色.状态 == 语义基础业务状态::入口拒绝
            && 错误入口.状态 == 语义基础业务状态::入口拒绝
            && 读取数量() == 重复前;

        const auto 因果关系前 = 关系.有效关系数量();
        const auto 抽象因果 = 因果服务.创建轻量因果({
            0x0750'0000'0000'0600ULL, 抽象动态.动态节点});
        const auto 实例因果 = 因果服务.创建轻量因果({
            0x0750'0000'0000'0601ULL, 实例动态.动态节点});
        验收[10] = 抽象因果.状态 == 轻量因果业务状态::已提交 && 抽象因果.因果.完整()
            && 实例因果.状态 == 轻量因果业务状态::已提交 && 实例因果.因果.完整()
            && 关系.有效关系数量() == 因果关系前;

        const auto 无效因果前 = 读取数量();
        节点句柄 过期动态 = 抽象动态.动态节点;
        ++过期动态.版本号;
        const auto 无效动态因果 = 因果服务.创建轻量因果({
            0x0750'0000'0000'0602ULL, 过期动态});
        const auto 非动态因果 = 因果服务.创建轻量因果({
            0x0750'0000'0000'0603ULL, 前状态.状态节点});
        验收[11] = (无效动态因果.状态 == 轻量因果业务状态::版本漂移
                || 无效动态因果.状态 == 轻量因果业务状态::入口拒绝)
            && 非动态因果.状态 == 轻量因果业务状态::入口拒绝
            && 读取数量() == 无效因果前;

        const auto 因果重复前 = 读取数量();
        const auto 因果重复 = 因果服务.创建轻量因果({
            0x0750'0000'0000'0600ULL, 抽象动态.动态节点});
        const auto 因果冲突 = 因果服务.创建轻量因果({
            因果冲突主键, 抽象动态.动态节点});
        验收[12] = 因果重复.状态 == 轻量因果业务状态::幂等读回
            && 因果冲突.状态 == 轻量因果业务状态::幂等冲突
            && 读取数量() == 因果重复前;

        bool 写点全部回前态 = true;
        for (int 故障点 = 1; 故障点 <= 5; ++故障点) {
            const auto 基线 = 读取数量();
            const auto 故障主键 = 0x0750'1000'0000'0000ULL + static_cast<std::uint64_t>(故障点);
            主信息句柄 候选主信息;
            节点句柄 候选语素;
            关系句柄 候选对应关系;
            关系句柄 候选追溯关系;
            int 当前写点 = 0;
            const auto 执行一步 = [&](bool 成功) {
                if (!成功) return false;
                if (++当前写点 == 故障点) throw std::runtime_error("semantic-write-fault");
                return true;
            };
            const auto 故障结果 = 夹具执行器.执行([&](结构写入会话& 会话) {
                const auto 主结果 = 会话.创建主信息候选();
                if (!主结果.成功() || !主结果.值.has_value()) return;
                候选主信息 = *主结果.值;
                if (!执行一步(true)) return;
                const auto 节点结果 = 会话.创建节点候选(节点类型::语素, 候选主信息);
                if (!节点结果.成功() || !节点结果.值.has_value()) return;
                候选语素 = *节点结果.值;
                if (!执行一步(true)) return;
                if (!执行一步(会话.绑定主键(故障主键, 候选语素).成功())) return;
                const auto 对应结果 = 会话.创建关系(
                    关系类型::语素对应信息, 候选语素, 基础材料.基础信息);
                if (!对应结果.成功() || !对应结果.值.has_value()) return;
                候选对应关系 = *对应结果.值;
                if (!执行一步(true)) return;
                const auto 追溯结果 = 会话.创建关系(
                    关系类型::语素概念追溯, 候选语素, 特征.节点);
                if (!追溯结果.成功() || !追溯结果.值.has_value()) return;
                候选追溯关系 = *追溯结果.值;
                if (!执行一步(true)) return;
                (void)会话.请求提交();
            });
            const bool 当前回前态 = 故障结果.状态 == 结构写入状态::内部不一致
                && 读取数量() == 基线 && !索引.按主键查节点(故障主键).has_value()
                && (!句柄有效(候选主信息) || !主信息.读取主信息(候选主信息).has_value())
                && (!句柄有效(候选语素) || !节点.读取节点(候选语素).has_value())
                && (!句柄有效(候选对应关系) || !关系.读取关系(候选对应关系).has_value())
                && (!句柄有效(候选追溯关系) || !关系.读取关系(候选追溯关系).has_value());
            写点全部回前态 = 写点全部回前态 && 当前回前态;
            std::cout << "SERVICE-DATA-S4-EVIDENCE fault-point=" << 故障点
                << " restored=" << 当前回前态 << '\n';
        }
        验收[13] = 写点全部回前态;

        const auto 并发基础 = 验证语义单提交竞争("base", [&] {
            return 基础服务.创建基础信息身份({0x0750'0000'0000'0700ULL});
        });
        const auto 并发语素 = 验证语义单提交竞争("morpheme", [&] {
            return 语素服务.创建语素入口({0x0750'0000'0000'0701ULL, 需求.节点});
        });
        const auto 并发概念 = 验证语义单提交竞争("concept-entry", [&] {
            return 语素组合器.创建语素概念入口({
                0x0750'0000'0000'0702ULL, L"海", 基础材料.基础信息, 特征.节点});
        });
        const auto 并发追加入口 = 语素服务.创建语素入口({
            0x0750'0000'0000'0703ULL, 基础材料.基础信息});
        const auto 并发追加 = 验证语义单提交竞争("append", [&] {
            return 语素服务.追加语素关系({
                并发追加入口.语素.语素入口, 二次特征.节点, 语素关系角色::概念追溯});
        });
        const auto 并发因果 = 验证因果单提交竞争("causal", [&] {
            return 因果服务.创建轻量因果({
                0x0750'0000'0000'0704ULL, 抽象动态.动态节点});
        });
        验收[14] = 并发基础 && 并发语素 && 并发概念 && 并发追加 && 并发因果
            && 基础服务.读取主键基础信息(0x0750'0000'0000'0700ULL).完整()
            && 语素服务.读取主键语素入口(0x0750'0000'0000'0701ULL).完整()
            && 语素服务.读取主键语素入口(0x0750'0000'0000'0702ULL).完整()
            && 因果服务.读取主键轻量因果(0x0750'0000'0000'0704ULL).完整();

        验收[15] = !std::is_constructible_v<语素业务服务, 主信息仓库&, 节点仓库&>
            && !std::is_constructible_v<轻量因果业务服务, 关系仓库&>
            && std::is_same_v<decltype(语素服务.读取语素入口({})), 语素入口值式材料>;
        验收[16] = 仓库合同回归通过 && 会话回归通过 && 存在场景回归通过
            && 会话材料回归通过 && 状态动态回归通过
            && 特征值事务回归通过 && 特征体系回归通过;
        验收[17] = std::all_of(验收.begin(), 验收.begin() + 17, [](bool 通过) { return 通过; });
        验收[18] = !std::is_default_constructible_v<语素入口写入规格>
            && !std::is_default_constructible_v<轻量因果写入规格>;
        验收[19] = std::all_of(验收.begin(), 验收.begin() + 19, [](bool 通过) { return 通过; });
    } catch (...) {
    }

    constexpr std::array<const char*, 20> 名称组{
        "公开请求结果无事务能力或内部指针",
        "两个数据操作层和动态材料前置完整",
        "基础信息主键创建幂等冲突与完整读回",
        "语素文本拒绝时四仓库零变化",
        "对应信息白名单逐类通过且临时节点拒绝",
        "概念追溯白名单逐类通过且高级节点拒绝",
        "语素入口形成主信息节点主键和对应关系",
        "概念入口一次形成两类关系且失败无半入口",
        "已有语素追加两类关系并集合完整读回",
        "非法角色重复新增和错误入口写前拒绝",
        "抽象与完整实例动态可作为轻量因果证据",
        "无效或非动态材料拒绝且关系数量不增长",
        "轻量因果主键幂等与错误类型冲突",
        "五个结构写点故障后完整回前态",
        "五类同事实并发单提交与合法收口",
        "既有兼容服务边界保持隔离",
        "仓库会话存在状态特征体系完整回归",
        "Debug完整自检和外部严格验证前置",
        "Release隔离登记与生产故障符号前置",
        "入口最小登记和值式总汇总前置"};
    std::size_t 失败数量 = 0;
    for (std::size_t 索引 = 0; 索引 < 验收.size(); ++索引) {
        if (!验收[索引]) ++失败数量;
        std::cout << "SERVICE-DATA-S4-A" << (索引 + 1 < 10 ? "0" : "") << 索引 + 1
            << ' ' << 名称组[索引] << ": " << (验收[索引] ? "通过" : "失败") << '\n';
    }
    return {"SERVICE-DATA-S4", "语义基础服务分层迁移",
        失败数量 == 0, 验收.size(), 失败数量};
}

}
#endif
