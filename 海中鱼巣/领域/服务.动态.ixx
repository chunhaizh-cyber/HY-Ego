// 文件规则：动态业务服务只裁决抽象动态和已有完整状态变化，不创建裸值材料状态。
module;

#include "../核心/句柄.h"

#include <cstdint>

export module 海中鱼巣.领域.服务.动态;

import 海中鱼巣.领域.数据操作.状态动态;
import 海中鱼巣.领域.服务.状态;

export namespace 海中鱼巣 {

struct 创建抽象动态请求 {
    std::uint64_t 幂等主键 = 0;
    std::int64_t 动态材料 = 0;
};

struct 记录已有状态变化动态请求 {
    std::uint64_t 幂等主键 = 0;
    节点句柄 前状态;
    节点句柄 后状态;
    节点句柄 被改变目标;
    节点句柄 来源动作;
};

class 动态业务服务 final {
public:
    动态业务服务(状态业务服务& 状态服务, 状态动态数据操作& 数据操作)
        : 状态服务_(状态服务), 数据操作_(数据操作) {
    }

    状态动态业务结果 创建抽象动态(const 创建抽象动态请求& 请求) const {
        if (请求.幂等主键 == 0) return {};
        return 数据操作_.创建抽象动态(请求.幂等主键, 请求.动态材料);
    }

    状态动态业务结果 记录已有状态变化动态(
        const 记录已有状态变化动态请求& 请求) const {
        if (请求.幂等主键 == 0 || !句柄有效(请求.前状态)
            || !句柄有效(请求.后状态) || !句柄有效(请求.被改变目标)) return {};
        const auto 前材料 = 状态服务_.读取状态材料(请求.前状态);
        const auto 后材料 = 状态服务_.读取状态材料(请求.后状态);
        if (!前材料.完整实例状态() || !后材料.完整实例状态()) {
            return 映射两个状态失败(前材料.状态, 后材料.状态);
        }
        if (前材料.主体 != 后材料.主体 || 前材料.场景 != 后材料.场景
            || 前材料.发生时间戳 > 后材料.发生时间戳) return {};
        const auto 目标身份 = 数据操作_.读取节点身份(请求.被改变目标);
        if (!目标身份.当前可读()) return 映射读取失败(目标身份.状态);
        if (句柄有效(请求.来源动作)) {
            const auto 角色 = 数据操作_.读取来源动作角色(请求.来源动作);
            if (!角色.是动作入口()) return 映射读取失败(角色.状态);
        }
        return 数据操作_.记录已有状态变化动态(
            请求.幂等主键, 请求.前状态, 请求.后状态,
            请求.被改变目标, 请求.来源动作);
    }

    动态值式材料 读取动态材料(节点句柄 动态节点) const {
        if (!句柄有效(动态节点)) return {};
        return 数据操作_.读取动态材料(动态节点);
    }

    动态值式材料 读取主键动态材料(std::uint64_t 主键) const {
        if (主键 == 0) return {};
        return 数据操作_.读取主键动态材料(主键);
    }

private:
    static 状态动态业务结果 映射读取失败(状态动态读取状态 状态) noexcept {
        switch (状态) {
        case 状态动态读取状态::许可拒绝:
            return {状态动态业务状态::许可拒绝};
        case 状态动态读取状态::版本漂移:
            return {状态动态业务状态::版本漂移};
        case 状态动态读取状态::内部不一致:
            return {状态动态业务状态::内部不一致};
        default:
            return {状态动态业务状态::入口拒绝};
        }
    }

    static 状态动态业务结果 映射两个状态失败(
        状态动态读取状态 左,
        状态动态读取状态 右) noexcept {
        if (左 == 状态动态读取状态::内部不一致
            || 右 == 状态动态读取状态::内部不一致) return {状态动态业务状态::内部不一致};
        if (左 == 状态动态读取状态::许可拒绝
            || 右 == 状态动态读取状态::许可拒绝) return {状态动态业务状态::许可拒绝};
        if (左 == 状态动态读取状态::版本漂移
            || 右 == 状态动态读取状态::版本漂移) return {状态动态业务状态::版本漂移};
        return {状态动态业务状态::入口拒绝};
    }

    状态业务服务& 状态服务_;
    状态动态数据操作& 数据操作_;
};

}
