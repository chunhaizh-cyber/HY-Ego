// 文件规则：概念图结构业务服务只裁决创建型概念关系，不接触仓库或事务能力。
module;

#include "../核心/句柄.h"

#include <cstdint>
#include <vector>

export module 海中鱼巣.领域.服务.概念图结构;

import 海中鱼巣.领域.数据操作.概念图结构;

export namespace 海中鱼巣 {

struct 概念根身份请求 {
    std::uint64_t 稳定主键 = 0;
    节点句柄 节点;

    bool 完整() const noexcept {
        return 稳定主键 != 0 && 句柄有效(节点);
    }
};

struct 复核概念根角色请求 {
    概念根身份请求 存在根;
    概念根身份请求 动态根;
    概念根身份请求 关系根;
    概念根身份请求 因果根;

    bool 完整() const noexcept {
        return 存在根.完整() && 动态根.完整()
            && 关系根.完整() && 因果根.完整();
    }
};

struct 概念结构关系请求 {
    关系类型 类型 = 关系类型::普通父子;
    概念根类别 根类别 = 概念根类别::未定义;
    节点句柄 源节点;
    节点句柄 目标节点;
    std::int64_t 顺序号 = 0;

    bool 完整() const noexcept {
        return 根类别 != 概念根类别::未定义
            && 句柄有效(源节点) && 句柄有效(目标节点);
    }
};

struct 创建实例支持概念请求 {
    概念根角色组 根角色组;
    概念根类别 根类别 = 概念根类别::未定义;
    节点句柄 实例;
    节点句柄 概念;
    std::int64_t 顺序号 = 0;
};

struct 创建概念上下位请求 {
    概念根角色组 根角色组;
    概念根类别 根类别 = 概念根类别::未定义;
    节点句柄 上位概念;
    节点句柄 下位概念;
    std::int64_t 顺序号 = 0;
};

struct 创建概念定义材料请求 {
    概念根角色组 根角色组;
    概念根类别 根类别 = 概念根类别::未定义;
    节点句柄 概念;
    节点句柄 定义材料;
    std::int64_t 顺序号 = 0;
};

struct 创建概念关系组请求 {
    概念根角色组 根角色组;
    std::vector<概念结构关系请求> 关系组;
};

class 概念图结构业务服务 final {
public:
    explicit 概念图结构业务服务(概念图结构数据操作& 数据操作)
        : 数据操作_(数据操作) {}

    概念根角色组值式材料 复核根角色组(
        const 复核概念根角色请求& 请求) const {
        if (!请求.完整()) return {};
        return 数据操作_.复核根角色组({
            {概念根类别::存在, 请求.存在根.稳定主键, 请求.存在根.节点},
            {概念根类别::动态, 请求.动态根.稳定主键, 请求.动态根.节点},
            {概念根类别::关系, 请求.关系根.稳定主键, 请求.关系根.节点},
            {概念根类别::因果, 请求.因果根.稳定主键, 请求.因果根.节点}});
    }

    概念图结构业务结果 创建实例支持概念(
        const 创建实例支持概念请求& 请求) const {
        return 创建关系组({请求.根角色组, {{
            关系类型::实例支持概念, 请求.根类别,
            请求.实例, 请求.概念, 请求.顺序号}}});
    }

    概念图结构业务结果 创建概念上下位(
        const 创建概念上下位请求& 请求) const {
        return 创建关系组({请求.根角色组, {{
            关系类型::概念上下位, 请求.根类别,
            请求.上位概念, 请求.下位概念, 请求.顺序号}}});
    }

    概念图结构业务结果 创建概念定义材料(
        const 创建概念定义材料请求& 请求) const {
        return 创建关系组({请求.根角色组, {{
            关系类型::概念定义材料, 请求.根类别,
            请求.概念, 请求.定义材料, 请求.顺序号}}});
    }

    概念图结构业务结果 创建关系组(
        const 创建概念关系组请求& 请求) const {
        if (!请求.根角色组.完整() || 请求.关系组.empty()) return {};
        std::vector<概念关系写入规格> 写入组;
        写入组.reserve(请求.关系组.size());
        for (const auto& 关系 : 请求.关系组) {
            if (!关系.完整() || !是创建型关系(关系.类型)
                || !是根类别(关系.根类别)) return {};
            写入组.push_back(概念关系写入规格(
                关系.类型, 关系.根类别,
                关系.源节点, 关系.目标节点, 关系.顺序号));
        }
        return 数据操作_.创建关系组(请求.根角色组, 写入组);
    }

    概念关系组值式材料 读取正向关系组(
        节点句柄 源节点,
        关系类型 类型) const {
        return 句柄有效(源节点) && 是创建型关系(类型)
            ? 数据操作_.读取关系组(源节点, 类型)
            : 概念关系组值式材料{};
    }

    概念关系组值式材料 读取反向关系组(
        节点句柄 目标节点,
        关系类型 类型) const {
        return 句柄有效(目标节点) && 是创建型关系(类型)
            ? 数据操作_.读取来源关系组(目标节点, 类型)
            : 概念关系组值式材料{};
    }

private:
    static bool 是根类别(概念根类别 类别) noexcept {
        return 类别 == 概念根类别::存在 || 类别 == 概念根类别::动态
            || 类别 == 概念根类别::关系 || 类别 == 概念根类别::因果;
    }

    static bool 是创建型关系(关系类型 类型) noexcept {
        return 类型 == 关系类型::实例支持概念
            || 类型 == 关系类型::概念上下位
            || 类型 == 关系类型::概念定义材料;
    }

    概念图结构数据操作& 数据操作_;
};

}
