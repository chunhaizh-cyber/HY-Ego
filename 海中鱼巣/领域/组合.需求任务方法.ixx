// 文件规则：需求任务方法组合器只组合三个跨服务边界，不持事务能力或执行真实动作。
module;

#include "../核心/句柄.h"

#include <cstdint>
#include <limits>

export module 海中鱼巣.领域.组合.需求任务方法;

import 海中鱼巣.领域.数据操作.需求任务方法;
import 海中鱼巣.领域.服务.需求;
import 海中鱼巣.领域.服务.任务;
import 海中鱼巣.领域.服务.方法召回;

export namespace 海中鱼巣 {

struct 创建需求并承接任务请求 {
    创建完整目标状态需求请求 需求;
    std::uint64_t 任务幂等主键 = 0;
    std::uint64_t 任务虚拟存在幂等主键 = 0;
    std::uint64_t 任务初始状态幂等主键 = 0;
    std::uint64_t 任务创建时间戳 = 0;
};

struct 创建需求并承接任务结果 {
    需求提交结果 需求;
    任务提交结果 任务;

    bool 成功() const noexcept {
        return 需求.成功() && 任务.成功();
    }
};

struct 召回并提交唯一选择请求 {
    方法召回请求 召回;
    std::uint64_t 选择记录幂等主键 = 0;
    std::uint64_t 选择幂等材料编号 = 0;
};

struct 召回并提交唯一选择结果 {
    方法召回结果 召回;
    任务提交结果 选择;

    bool 成功() const noexcept {
        return 召回.有唯一建议() && 选择.成功();
    }
};

struct 完成任务并独立结算请求 {
    完成任务请求 完成;
    std::uint64_t 结算状态幂等主键 = 0;
    std::uint64_t 结算时间戳 = 0;
    节点句柄 动态证据;
    节点句柄 因果引用;
};

struct 完成任务并独立结算结果 {
    任务提交结果 完成;
    需求提交结果 结算;

    bool 任务已完成() const noexcept {
        return 完成.成功()
            && 完成.材料.当前生命周期.阶段 == 分层任务生命周期阶段::已完成;
    }

    bool 全部成功() const noexcept {
        return 任务已完成() && 结算.成功();
    }
};

class 需求任务方法组合器 final {
public:
    需求任务方法组合器(
        需求业务服务& 需求服务,
        任务业务服务& 任务服务,
        方法召回业务服务& 召回服务)
        : 需求服务_(需求服务), 任务服务_(任务服务), 召回服务_(召回服务) {
    }

    创建需求并承接任务结果 创建需求并承接任务(
        const 创建需求并承接任务请求& 请求) const {
        创建需求并承接任务结果 输出;
        输出.需求 = 需求服务_.创建完整目标状态需求(请求.需求);
        if (!输出.需求.成功()) return 输出;
        输出.任务 = 任务服务_.创建承接任务({
            请求.任务幂等主键, 请求.任务虚拟存在幂等主键,
            请求.任务初始状态幂等主键, 输出.需求.材料.身份.节点,
            请求.任务创建时间戳});
        return 输出;
    }

    召回并提交唯一选择结果 召回并提交唯一选择(
        const 召回并提交唯一选择请求& 请求) const {
        召回并提交唯一选择结果 输出;
        输出.召回 = 召回服务_.召回(请求.召回);
        const auto 选择请求 = 召回服务_.适配唯一建议(
            输出.召回, 请求.选择记录幂等主键, 请求.选择幂等材料编号);
        if (选择请求.has_value()) 输出.选择 = 任务服务_.提交方法选择(*选择请求);
        return 输出;
    }

    完成任务并独立结算结果 完成任务并独立结算(
        const 完成任务并独立结算请求& 请求) const {
        完成任务并独立结算结果 输出;
        if (!句柄有效(请求.完成.任务) || !句柄有效(请求.完成.实际状态)
            || !句柄有效(请求.动态证据)
            || (!节点句柄全零(请求.因果引用) && !句柄有效(请求.因果引用))
            || 请求.完成.完成状态幂等主键 == 0 || 请求.完成.发生时间戳 == 0
            || 请求.结算状态幂等主键 == 0 || 请求.结算时间戳 == 0
            || 请求.完成.发生时间戳
                > static_cast<std::uint64_t>(std::numeric_limits<std::int64_t>::max())
            || 请求.结算时间戳
                > static_cast<std::uint64_t>(std::numeric_limits<std::int64_t>::max())) return 输出;
        const auto 当前任务 = 任务服务_.读取任务(请求.完成.任务);
        if (当前任务.状态 != 需求任务方法读取状态::已找到) {
            输出.完成.状态 = 映射读取失败为业务状态(当前任务.状态);
            return 输出;
        }
        if (!当前任务.完整承接()) {
            输出.完成.状态 = 需求任务方法业务状态::内部不一致;
            return 输出;
        }
        const auto 裁决 = 需求服务_.判定目标状态达成(
            当前任务.来源需求, 请求.完成.实际状态);
        if (!裁决.成功()) {
            输出.结算.状态 = 映射读取失败为业务状态(裁决.状态);
            return 输出;
        }
        if (裁决.裁决 != 需求目标状态裁决::已达成
            || 裁决.实际状态材料.场景 != 当前任务.场景
            || 裁决.实际状态材料.主体 != 当前任务.虚拟存在) return 输出;
        const auto 证据状态 = 需求服务_.复核独立结算证据(
            请求.动态证据, 请求.因果引用);
        if (证据状态 != 需求任务方法读取状态::已找到) {
            输出.结算.状态 = 映射读取失败为业务状态(证据状态);
            return 输出;
        }
        输出.完成 = 任务服务_.提交实际结果并完成(请求.完成);
        if (!输出.完成.成功()) return 输出;
        输出.结算 = 需求服务_.提交独立结算({
            输出.完成.材料.来源需求, 请求.完成.任务, 请求.完成.实际状态,
            请求.动态证据, 请求.因果引用,
            请求.结算状态幂等主键, 请求.结算时间戳});
        return 输出;
    }

private:
    static bool 节点句柄全零(const 节点句柄& 句柄) noexcept {
        return 句柄.仓库编号 == 0 && 句柄.节点编号 == 0 && 句柄.版本号 == 0;
    }

    static 需求任务方法业务状态 映射读取失败为业务状态(
        需求任务方法读取状态 状态) noexcept {
        switch (状态) {
        case 需求任务方法读取状态::许可拒绝:
            return 需求任务方法业务状态::许可拒绝;
        case 需求任务方法读取状态::版本漂移:
            return 需求任务方法业务状态::版本漂移;
        case 需求任务方法读取状态::内部不一致:
        case 需求任务方法读取状态::已找到:
            return 需求任务方法业务状态::内部不一致;
        default:
            return 需求任务方法业务状态::入口拒绝;
        }
    }

    需求业务服务& 需求服务_;
    任务业务服务& 任务服务_;
    方法召回业务服务& 召回服务_;
};

}
