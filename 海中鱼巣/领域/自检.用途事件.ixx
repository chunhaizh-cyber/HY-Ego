// 文件规则：用途事件自检只构造隔离值式材料并验证 A01-A16；不得进入生产依赖或写入任何权威结构。
module;

#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
#include "../核心/句柄.h"

#include <algorithm>
#include <array>
#include <cstddef>
#include <cstdint>
#include <iostream>
#include <optional>
#include <type_traits>
#include <utility>
#include <vector>
#endif

export module 海中鱼巣.领域.自检.用途事件;

#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
import 海中鱼巣.领域.材料.动态模式;
import 海中鱼巣.领域.算法.动态模式;
import 海中鱼巣.领域.材料.因果模式;
import 海中鱼巣.领域.算法.因果模式;
import 海中鱼巣.领域.材料.用途事件;
import 海中鱼巣.领域.算法.用途事件;
import 海中鱼巣.领域.服务.用途事件;
import 海中鱼巣.领域.组合.用途事件;
import 海中鱼巣.领域.组合.任务结果结算;
import 海中鱼巣.领域.数据操作.需求任务方法;
import 海中鱼巣.领域.数据操作.状态动态;
import 海中鱼巣.领域.服务.需求;
import 海中鱼巣.线程.协议.任务执行请求;
import 海中鱼巣.线程.任务结果回执协议;
import 海中鱼巣.自检.运行器;

namespace 海中鱼巣 {

namespace 用途事件自检内部 {

节点句柄 形成节点(std::uint64_t 编号) noexcept {
    return {8501, 编号, 1};
}

主信息句柄 形成主信息(std::uint64_t 编号) noexcept {
    return {8502, 编号, 1};
}

关系句柄 形成关系句柄(std::uint64_t 编号) noexcept {
    return {8503, 编号, 1};
}

任务执行关系证据 形成任务关系(
    std::uint64_t 编号,
    关系类型 类型,
    节点句柄 源节点,
    节点句柄 目标节点,
    std::int64_t 顺序号) noexcept {
    return {形成关系句柄(编号), 类型, 源节点, 目标节点, 顺序号,
        记录状态::有效};
}

高级关系证据 形成高级关系(
    std::uint64_t 编号,
    关系类型 类型,
    节点句柄 源节点,
    节点句柄 目标节点,
    std::int64_t 顺序号) noexcept {
    return {形成关系句柄(编号), 类型, 源节点, 目标节点, 顺序号,
        记录状态::有效};
}

高级关系证据 转换高级关系(const 任务执行关系证据& 关系) noexcept {
    return {关系.关系, 关系.类型, 关系.源节点, 关系.目标节点,
        关系.顺序号, 关系.状态};
}

关系值式证据 形成状态关系(
    std::uint64_t 编号,
    关系类型 类型,
    节点句柄 源节点,
    节点句柄 目标节点,
    std::int64_t 顺序号) noexcept {
    return {形成关系句柄(编号), 类型, 源节点, 目标节点, 顺序号};
}

任务执行冻结请求 形成冻结请求(std::uint64_t 基数, std::int64_t 实际状态值 = 20) {
    const auto 需求 = 形成节点(基数 + 1);
    const auto 任务 = 形成节点(基数 + 2);
    const auto 主体 = 形成节点(基数 + 3);
    const auto 场景 = 形成节点(基数 + 4);
    const auto 目标状态 = 形成节点(基数 + 5);
    const auto 方法 = 形成节点(基数 + 6);
    const auto 动作 = 形成节点(基数 + 7);
    const auto 选择记录 = 形成节点(基数 + 8);
    const auto 任务生命周期状态 = 形成节点(基数 + 9);
    const auto 登记根 = 形成节点(基数 + 10);
    const auto 方法角色状态 = 形成节点(基数 + 11);
    const auto 动作角色状态 = 形成节点(基数 + 12);
    const auto 动作入口状态 = 形成节点(基数 + 13);

    任务执行冻结请求 输出;
    auto& 调度 = 输出.调度请求;
    调度.协议版本 = 任务执行请求协议版本;
    调度.请求编号 = 基数 + 1001;
    调度.幂等键 = 基数 + 1002;
    调度.任务序号 = 基数 + 1003;
    调度.批次编号 = 基数 + 1004;
    调度.任务 = 任务;
    调度.创建时间戳 = 基数 + 2001;
    调度.截止时间戳 = 基数 + 2100;
    调度.排队生命周期幂等主键 = 基数 + 1005;
    调度.排队时间戳 = 基数 + 2002;
    调度.执行生命周期幂等主键 = 基数 + 1006;
    调度.执行时间戳 = 基数 + 2003;
    调度.待重筹办幂等主键 = 基数 + 1007;
    调度.待重筹办时间戳 = 基数 + 2006;
    调度.实际状态幂等主键 = 基数 + 1008;
    调度.实际状态时间戳 = 基数 + 2004;
    调度.实际状态值 = 实际状态值;
    调度.动态幂等主键 = 基数 + 1009;
    调度.回执编号 = 基数 + 1010;
    调度.回执幂等键 = 基数 + 1011;
    调度.回执时间戳 = 基数 + 2005;

    auto& 任务材料 = 输出.任务材料;
    任务材料.身份 = {基数 + 3001, 任务, 节点类型::任务,
        形成主信息(基数 + 2)};
    任务材料.来源需求 = 需求;
    任务材料.虚拟存在 = 主体;
    任务材料.场景 = 场景;
    任务材料.目标状态 = 目标状态;
    任务材料.需求拥有任务关系 = 形成任务关系(
        基数 + 4001, 关系类型::归属, 需求, 任务, 0);
    任务材料.任务来源需求关系 = 形成任务关系(
        基数 + 4002, 关系类型::引用, 任务, 需求, 0);
    任务材料.虚拟存在关系 = 形成任务关系(
        基数 + 4003, 关系类型::引用, 任务, 主体, 0);
    任务材料.场景关系 = 形成任务关系(
        基数 + 4004, 关系类型::引用, 任务, 场景, 0);
    任务材料.目标状态关系 = 形成任务关系(
        基数 + 4005, 关系类型::模板, 任务, 目标状态, 0);
    任务材料.当前生命周期 = {
        形成任务关系(
            基数 + 4006, 关系类型::任务生命周期,
            任务, 任务生命周期状态, 1),
        任务生命周期状态, 任务执行生命周期阶段::筹办中,
        1, 基数 + 1999, 记录状态::有效};

    任务执行选择材料 选择;
    选择.记录身份 = {基数 + 3002, 选择记录,
        节点类型::任务方法选择记录, 形成主信息(基数 + 8)};
    选择.任务 = 任务;
    选择.方法 = 方法;
    选择.幂等材料编号 = 基数 + 3003;
    选择.方法投影关系 = 形成任务关系(
        基数 + 4007, 关系类型::引用, 任务, 方法, 30);
    选择.发布关系 = 形成任务关系(
        基数 + 4008, 关系类型::任务方法选择, 任务, 选择记录, 30);
    选择.来源生命周期关系 = 任务材料.当前生命周期.关系.关系;
    选择.来源生命周期版本 = 任务材料.当前生命周期.版本;
    选择.来源方法生命周期关系 = 形成关系句柄(基数 + 4012);
    选择.来源方法生命周期版本 = 1;
    选择.排序规则版本 = 1;
    选择.召回请求规则版本 = 1;
    选择.来源候选数量 = 1;
    任务材料.当前选择 = 选择;

    auto& 方法材料 = 输出.方法材料;
    方法材料.身份 = {基数 + 3004, 方法, 节点类型::方法,
        形成主信息(基数 + 6)};
    方法材料.登记根 = 登记根;
    方法材料.角色状态 = 方法角色状态;
    方法材料.虚拟存在 = 主体;
    方法材料.登记关系 = 形成任务关系(
        基数 + 4009, 关系类型::归属, 登记根, 方法, 0);
    方法材料.角色关系 = 形成任务关系(
        基数 + 4010, 关系类型::模板, 方法, 方法角色状态, 0);
    方法材料.虚拟存在关系 = 形成任务关系(
        基数 + 4011, 关系类型::引用, 方法, 主体, 0);
    方法材料.生命周期关系 = 形成任务关系(
        基数 + 4012, 关系类型::模板,
        方法, 形成节点(基数 + 14), 1);
    方法材料.生命周期 = 任务执行方法生命周期::活跃;

    auto& 动作材料 = 输出.动作材料;
    动作材料.身份 = {基数 + 3005, 动作, 节点类型::方法,
        形成主信息(基数 + 7)};
    动作材料.方法首 = 方法;
    动作材料.角色 = 任务执行方法角色::动作入口;
    动作材料.角色状态 = 动作角色状态;
    动作材料.方法角色关系 = 形成任务关系(
        基数 + 4013, 关系类型::模板, 方法, 动作,
        static_cast<std::int64_t>(任务执行方法角色::动作入口));
    动作材料.角色状态关系 = 形成任务关系(
        基数 + 4014, 关系类型::模板, 动作, 动作角色状态, 0);
    动作材料.入口状态 = 动作入口状态;
    动作材料.入口状态关系 = 形成任务关系(
        基数 + 4015, 关系类型::模板, 动作, 动作入口状态, 1);
    动作材料.输入场景 = 场景;
    动作材料.输出场景 = 场景;
    动作材料.输入场景关系 = 形成任务关系(
        基数 + 4016, 关系类型::方法动作场景, 动作, 场景, 1);
    动作材料.输出场景关系 = 形成任务关系(
        基数 + 4017, 关系类型::方法动作场景, 动作, 场景, 2);
    动作材料.稳定动作键 = 基数 + 3006;
    输出.适配器 = 任务执行适配器种类::任务目标状态值变化;
    return 输出;
}

任务结果回执材料 形成任务结果回执(
    const 任务执行冻结请求& 冻结,
    节点句柄 实际状态,
    节点句柄 动态证据) {
    const auto& 调度 = 冻结.调度请求;
    任务结果回执材料 回执;
    回执.协议版本 = 任务结果回执协议版本;
    回执.回执编号 = 调度.回执编号;
    回执.发生时间戳 = 调度.回执时间戳;
    回执.幂等键 = 调度.回执幂等键;
    回执.来源任务序号 = 调度.任务序号;
    回执.批次编号 = 调度.批次编号;
    回执.非权威材料摘要 = 调度.请求编号 + 850;
    回执.材料性质 = 任务结果回执材料性质::非权威任务执行结果证据;
    回执.过期策略 = 任务结果回执过期策略::截止时间;
    回执.截止时间戳 = 调度.截止时间戳;
    回执.只读材料说明 = true;
    回执.承载机器事实 = false;
    回执.句柄组 = {
        冻结.任务材料.身份.节点, 实际状态, 动态证据,
        冻结.方法材料.身份.节点, 冻结.动作材料.身份.节点,
        冻结.任务材料.场景, 冻结.任务材料.虚拟存在};
    回执.来源执行请求 = 冻结;
    return 回执;
}

状态值式材料 形成抽象状态值(
    节点句柄 状态,
    std::int64_t 值,
    std::uint64_t 基数) {
    状态值式材料 输出;
    输出.状态 = 状态动态读取状态::已找到;
    输出.种类 = 状态动态材料种类::抽象状态;
    输出.幂等主键 = 基数 + 1;
    输出.状态节点 = 状态;
    输出.主信息 = 形成主信息(基数 + 2);
    输出.状态值 = 值;
    return 输出;
}

状态值式材料 形成实例状态值(
    节点句柄 状态,
    std::int64_t 值,
    std::uint64_t 时间戳,
    节点句柄 场景,
    节点句柄 主体,
    std::uint64_t 幂等主键,
    std::uint64_t 基数) {
    状态值式材料 输出;
    输出.状态 = 状态动态读取状态::已找到;
    输出.种类 = 状态动态材料种类::实例状态;
    输出.幂等主键 = 幂等主键;
    输出.状态节点 = 状态;
    输出.主信息 = 形成主信息(基数 + 2);
    输出.状态值 = 值;
    输出.发生时间戳 = 时间戳;
    输出.场景 = 场景;
    输出.主体 = 主体;
    输出.场景临时关系 = 形成状态关系(
        基数 + 3, 关系类型::运行期临时, 场景, 状态, 0);
    输出.主体关系 = 形成状态关系(
        基数 + 4, 关系类型::引用, 状态, 主体, 0);
    输出.场景关系 = 形成状态关系(
        基数 + 5, 关系类型::引用, 状态, 场景, 0);
    return 输出;
}

任务方法选择材料 形成权威选择(
    const 任务执行选择材料& 冻结选择,
    std::uint64_t 基数) {
    任务方法选择材料 输出;
    输出.记录身份 = {需求任务方法读取状态::已找到,
        冻结选择.记录身份.幂等主键, 冻结选择.记录身份.节点,
        冻结选择.记录身份.类型, 冻结选择.记录身份.主信息};
    输出.任务 = 冻结选择.任务;
    输出.方法 = 冻结选择.方法;
    输出.幂等材料编号 = 冻结选择.幂等材料编号;
    输出.方法投影关系 = 转换高级关系(冻结选择.方法投影关系);
    输出.发布关系 = 转换高级关系(冻结选择.发布关系);
    输出.来源生命周期关系 = 冻结选择.来源生命周期关系;
    输出.来源生命周期版本 = 冻结选择.来源生命周期版本;
    输出.来源方法生命周期关系 = 冻结选择.来源方法生命周期关系;
    输出.来源方法生命周期版本 = 冻结选择.来源方法生命周期版本;
    输出.排序规则版本 = 冻结选择.排序规则版本;
    输出.召回请求规则版本 = 冻结选择.召回请求规则版本;
    输出.来源候选数量 = 冻结选择.来源候选数量;
    return 输出;
}

任务权威材料 形成任务权威材料(
    const 任务执行冻结请求& 冻结,
    分层任务生命周期阶段 阶段,
    std::uint64_t 发生时间戳,
    std::optional<节点句柄> 实际状态,
    std::uint64_t 基数) {
    const auto& 来源 = 冻结.任务材料;
    任务权威材料 输出;
    输出.状态 = 需求任务方法读取状态::已找到;
    输出.身份 = {需求任务方法读取状态::已找到,
        来源.身份.幂等主键, 来源.身份.节点, 来源.身份.类型, 来源.身份.主信息};
    输出.来源需求 = 来源.来源需求;
    输出.虚拟存在 = 来源.虚拟存在;
    输出.场景 = 来源.场景;
    输出.目标状态 = 来源.目标状态;
    输出.需求拥有任务关系 = 转换高级关系(来源.需求拥有任务关系);
    输出.任务来源需求关系 = 转换高级关系(来源.任务来源需求关系);
    输出.虚拟存在关系 = 转换高级关系(来源.虚拟存在关系);
    输出.场景关系 = 转换高级关系(来源.场景关系);
    输出.目标状态关系 = 转换高级关系(来源.目标状态关系);
    const auto 生命周期状态 = 形成节点(基数 + 6);
    输出.当前生命周期 = {
        形成高级关系(
            基数 + 7, 关系类型::任务生命周期,
            输出.身份.节点, 生命周期状态, 2),
        生命周期状态, 阶段, 2, 发生时间戳, 记录状态::有效};
    if (实际状态.has_value()) {
        输出.实际结果状态 = *实际状态;
        输出.实际结果关系 = 形成高级关系(
            基数 + 8, 关系类型::引用,
            输出.身份.节点, *实际状态, 20);
    }
    if (来源.当前选择.has_value()) {
        输出.当前选择 = 形成权威选择(*来源.当前选择, 基数 + 20);
    }
    return 输出;
}

需求权威材料 形成需求权威材料(
    const 任务执行冻结请求& 冻结,
    分层需求结算结论 结论,
    std::optional<节点句柄> 最近结算状态,
    std::uint64_t 基数) {
    const auto& 来源 = 冻结.任务材料;
    需求权威材料 输出;
    输出.状态 = 需求任务方法读取状态::已找到;
    输出.身份 = {需求任务方法读取状态::已找到,
        基数 + 1, 来源.来源需求, 节点类型::需求,
        形成主信息(基数 + 2)};
    输出.主体 = 来源.虚拟存在;
    输出.目标宿主 = 来源.虚拟存在;
    输出.场景 = 来源.场景;
    输出.目标特征 = 形成节点(基数 + 3);
    输出.当前特征状态材料 = 形成节点(基数 + 4);
    输出.目标状态 = 来源.目标状态;
    输出.主体关系 = 形成高级关系(
        基数 + 5, 关系类型::引用, 输出.身份.节点, 输出.主体, 1);
    输出.目标宿主关系 = 形成高级关系(
        基数 + 6, 关系类型::引用, 输出.目标宿主, 输出.身份.节点, 2);
    输出.场景关系 = 形成高级关系(
        基数 + 7, 关系类型::引用, 输出.身份.节点, 输出.场景, 3);
    输出.目标特征关系 = 形成高级关系(
        基数 + 8, 关系类型::引用, 输出.身份.节点, 输出.目标特征, 4);
    输出.当前特征状态关系 = 形成高级关系(
        基数 + 9, 关系类型::引用,
        输出.身份.节点, 输出.当前特征状态材料, 5);
    输出.目标状态关系 = 形成高级关系(
        基数 + 10, 关系类型::模板, 输出.身份.节点, 输出.目标状态, 0);
    输出.当前结算 = 结论;
    输出.最近结算状态 = 最近结算状态;
    return 输出;
}

struct 任务结果效用夹具 {
    任务结果治理请求 请求;
    任务结果治理结果 结果;
};

任务结果效用夹具 形成任务结果夹具(
    const 任务执行冻结请求& 冻结,
    任务结果治理状态 状态,
    std::uint64_t 基数) {
    const auto 实际状态 = 形成节点(基数 + 1);
    const auto 动态证据 = 形成节点(基数 + 2);
    任务结果效用夹具 输出;
    输出.请求.回执 = 形成任务结果回执(冻结, 实际状态, 动态证据);
    输出.请求.参数 = {
        冻结.调度请求.回执时间戳,
        冻结.调度请求.待重筹办幂等主键,
        冻结.调度请求.待重筹办时间戳,
        基数 + 101,
        冻结.调度请求.回执时间戳 + 1,
        基数 + 102,
        冻结.调度请求.回执时间戳 + 2,
        形成节点(基数 + 3)};
    输出.结果.协议结果 = 复核任务结果回执材料(
        输出.请求.回执,
        任务结果回执准入上下文{输出.请求.参数.当前时间戳});
    输出.结果.目标裁决.状态 = 需求任务方法读取状态::已找到;
    输出.结果.目标裁决.裁决 = 状态 == 任务结果治理状态::未达成已转待重筹办
        ? 需求目标状态裁决::未达成 : 需求目标状态裁决::已达成;
    输出.结果.目标裁决.需求 = 冻结.任务材料.来源需求;
    输出.结果.目标裁决.目标状态 = 冻结.任务材料.目标状态;
    输出.结果.目标裁决.实际状态 = 实际状态;
    const auto 目标状态值 = 状态 == 任务结果治理状态::未达成已转待重筹办
        ? 冻结.调度请求.实际状态值 + 1 : 冻结.调度请求.实际状态值;
    输出.结果.目标裁决.目标状态材料 = 形成抽象状态值(
        冻结.任务材料.目标状态, 目标状态值, 基数 + 200);
    输出.结果.目标裁决.实际状态材料 = 形成实例状态值(
        实际状态, 冻结.调度请求.实际状态值,
        冻结.调度请求.实际状态时间戳,
        冻结.任务材料.场景, 冻结.任务材料.虚拟存在,
        冻结.调度请求.实际状态幂等主键, 基数 + 210);

    if (状态 == 任务结果治理状态::未达成已转待重筹办) {
        输出.结果.状态 = 状态;
        输出.结果.拒绝原因 = 任务结果治理拒绝原因::无;
        输出.结果.任务提交 = {
            需求任务方法业务状态::已提交,
            形成任务权威材料(
                冻结, 分层任务生命周期阶段::待重筹办,
                输出.请求.参数.待重筹办发生时间戳, std::nullopt, 基数 + 300)};
        return 输出;
    }

    输出.结果.任务提交 = {
        需求任务方法业务状态::已提交,
        形成任务权威材料(
            冻结, 分层任务生命周期阶段::已完成,
            输出.请求.参数.完成发生时间戳, 实际状态, 基数 + 300)};
    if (状态 == 任务结果治理状态::任务已完成待需求结算) {
        输出.结果.状态 = 状态;
        输出.结果.拒绝原因 = 任务结果治理拒绝原因::需求结算待重试;
        输出.结果.需求结算.状态 = 需求任务方法业务状态::许可拒绝;
        输出.结果.待结算提示 = 非权威待需求结算提示{
            任务结果提示性质::非权威待结算请求材料,
            冻结.任务材料.身份.节点, 冻结.任务材料.来源需求,
            实际状态, 动态证据, 输出.请求.参数.因果引用,
            输出.结果.任务提交.状态, 输出.结果.需求结算.状态,
            输出.请求.参数.结算状态幂等主键,
            输出.请求.参数.结算发生时间戳, false};
        return 输出;
    }

    输出.结果.状态 = 任务结果治理状态::已完成并结算;
    输出.结果.拒绝原因 = 任务结果治理拒绝原因::无;
    输出.结果.需求结算 = {
        需求任务方法业务状态::已提交,
        形成需求权威材料(
            冻结, 分层需求结算结论::已满足,
            形成节点(基数 + 4), 基数 + 400)};
    return 输出;
}

动态模式节点材料 形成动态节点材料(
    std::uint64_t 编号,
    节点类型 类型) {
    return {形成节点(编号), 类型, 形成主信息(编号),
        {0x0850'0000'0000'0000ULL + 编号}};
}

动态模式关系材料 形成动态关系材料(
    std::uint64_t 编号,
    节点句柄 源节点,
    节点句柄 目标节点,
    std::int64_t 顺序号,
    关系类型 类型 = 关系类型::归属) noexcept {
    const auto 句柄 = 形成关系句柄(编号);
    return {句柄, 句柄, 类型, 源节点, 目标节点, 顺序号,
        动态模式关系阶段::当前有效};
}

动态模式状态材料 形成动态抽象状态(
    节点句柄 节点,
    std::int64_t 状态值) {
    动态模式状态材料 输出;
    输出.身份 = {节点, 节点类型::状态, 形成主信息(节点.节点编号),
        {0x0850'1000'0000'0000ULL + 节点.节点编号}};
    输出.状态值 = 状态值;
    return 输出;
}

动态模式状态材料 形成动态实例状态(
    节点句柄 节点,
    std::int64_t 状态值,
    std::uint64_t 发生时间戳,
    节点句柄 场景,
    节点句柄 主体,
    std::uint64_t 基数) {
    动态模式状态材料 输出;
    输出.身份 = {节点, 节点类型::状态, 形成主信息(节点.节点编号),
        {0x0850'2000'0000'0000ULL + 节点.节点编号}};
    输出.状态值 = 状态值;
    输出.发生时间戳 = 发生时间戳;
    输出.场景 = 场景;
    输出.主体 = 主体;
    输出.场景临时关系 = 形成动态关系材料(
        基数 + 1, 场景, 节点, 0, 关系类型::运行期临时);
    输出.主体关系 = 形成动态关系材料(
        基数 + 2, 节点, 主体, 0);
    输出.场景关系 = 形成动态关系材料(
        基数 + 3, 节点, 场景, 0);
    return 输出;
}

动态模式动作材料 形成动态动作材料(
    节点句柄 动作,
    std::uint64_t 基数) {
    动态模式动作材料 输出;
    输出.身份 = {动作, 节点类型::方法, 形成主信息(动作.节点编号),
        {0x0850'3000'0000'0000ULL + 动作.节点编号}};
    输出.角色状态 = 形成动态抽象状态(形成节点(基数 + 1), 5);
    输出.入口状态 = 形成动态抽象状态(形成节点(基数 + 2), 1);
    输出.角色关系 = 形成动态关系材料(
        基数 + 3, 动作, 输出.角色状态.身份.节点, 0, 关系类型::模板);
    输出.入口关系 = 形成动态关系材料(
        基数 + 4, 动作, 输出.入口状态.身份.节点, 1, 关系类型::模板);
    return 输出;
}

动态模式权威批次 形成来源批次(
    const 任务结果回执材料& 回执,
    std::uint64_t 片段序号,
    const 动态模式结构键& 结构键,
    节点句柄 来源动态,
    std::uint64_t 发生时间戳,
    std::uint64_t 基数) {
    动态模式权威批次 输出;
    输出.请求 = {回执, 片段序号, 结构键.规则版本};
    输出.任务 = 形成动态节点材料(基数 + 1, 节点类型::任务);
    输出.需求 = 形成动态节点材料(基数 + 2, 节点类型::需求);
    输出.场景 = 形成动态节点材料(基数 + 3, 节点类型::场景);
    输出.主体 = 形成动态节点材料(基数 + 4, 节点类型::存在);
    输出.方法 = 形成动态节点材料(基数 + 5, 节点类型::方法);
    输出.冻结支持节点组 = {输出.任务, 输出.需求};
    输出.冻结关系组 = {形成动态关系材料(
        基数 + 10, 输出.需求.节点, 输出.任务.节点, 0)};
    输出.被改变目标 = 形成动态抽象状态(
        结构键.被改变目标, 结构键.后状态值);
    输出.前状态 = 形成动态实例状态(
        形成节点(基数 + 20), 结构键.前状态值, 发生时间戳 - 1,
        输出.场景.节点, 输出.主体.节点, 基数 + 100);
    输出.后状态 = 形成动态实例状态(
        形成节点(基数 + 21), 结构键.后状态值, 发生时间戳,
        输出.场景.节点, 输出.主体.节点, 基数 + 110);
    输出.来源动作 = 形成动态动作材料(结构键.来源动作, 基数 + 200);
    输出.动态.身份 = {来源动态, 节点类型::动态,
        形成主信息(来源动态.节点编号),
        {0x0850'4000'0000'0000ULL + 来源动态.节点编号}};
    输出.动态.发生时间戳 = 发生时间戳;
    输出.动态.场景 = 输出.场景.节点;
    输出.动态.主体 = 输出.主体.节点;
    输出.动态.被改变目标 = 结构键.被改变目标;
    输出.动态.前状态 = 输出.前状态.身份.节点;
    输出.动态.后状态 = 输出.后状态.身份.节点;
    输出.动态.来源动作 = 结构键.来源动作;
    输出.动态.场景临时关系 = 形成动态关系材料(
        基数 + 300, 输出.场景.节点, 来源动态, 0,
        关系类型::运行期临时);
    输出.动态.主体关系 = 形成动态关系材料(
        基数 + 301, 来源动态, 输出.主体.节点, 0);
    输出.动态.场景关系 = 形成动态关系材料(
        基数 + 302, 来源动态, 输出.场景.节点, 0);
    输出.动态.目标关系 = 形成动态关系材料(
        基数 + 303, 来源动态, 结构键.被改变目标, 1, 关系类型::引用);
    输出.动态.前状态关系 = 形成动态关系材料(
        基数 + 304, 来源动态, 输出.前状态.身份.节点, 2, 关系类型::引用);
    输出.动态.后状态关系 = 形成动态关系材料(
        基数 + 305, 来源动态, 输出.后状态.身份.节点, 3, 关系类型::引用);
    输出.动态.来源动作关系 = 形成动态关系材料(
        基数 + 306, 来源动态, 结构键.来源动作, 4, 关系类型::引用);
    return 输出;
}

单步片段实例候选 形成实例(
    const 任务结果回执材料& 回执,
    std::uint64_t 片段序号,
    const 动态模式结构键& 结构键,
    std::uint64_t 动态编号,
    std::uint64_t 基数) {
    const auto 来源动态 = 形成节点(动态编号);
    const auto 发生时间戳 = 基数 + 500;
    auto 来源批次 = 形成来源批次(
        回执, 片段序号, 结构键, 来源动态, 发生时间戳, 基数);
    规范动态步 步骤{
        {回执}, 片段序号, 结构键, 发生时间戳, 来源动态,
        来源批次.场景.节点, 来源批次.主体.节点,
        来源批次.任务.节点, 来源批次.方法.节点, std::move(来源批次)};
    return {计算动态模式结构键稳定哈希(结构键), 结构键, std::move(步骤)};
}

因果概率候选 形成因果候选(const 任务执行冻结请求& 当前冻结) {
    const auto 第一冻结 = 形成冻结请求(94'000, 当前冻结.调度请求.实际状态值);
    const auto 第二冻结 = 形成冻结请求(95'000, 当前冻结.调度请求.实际状态值);
    const auto 第一回执 = 形成任务结果回执(
        第一冻结, 形成节点(96'001), 形成节点(96'002));
    const auto 第二回执 = 形成任务结果回执(
        第二冻结, 形成节点(96'003), 形成节点(96'004));
    const 动态模式结构键 原因键{
        形成节点(96'100), 10, 20, true, 形成节点(96'101),
        动态模式规则版本, std::nullopt};
    const 动态模式结构键 结果键{
        形成节点(96'100), 20, 30, true, 形成节点(96'101),
        动态模式规则版本, std::nullopt};
    auto 第一原因 = 形成实例(第一回执, 1, 原因键, 96'200, 100'000);
    auto 第一结果 = 形成实例(第一回执, 2, 结果键, 96'201, 102'000);
    auto 第二原因 = 形成实例(第二回执, 1, 原因键, 96'202, 104'000);
    因果机会证据 正机会{
        {第一回执}, std::move(第一原因), {}, {std::move(第一结果)},
        因果机会结果分类::正结果};
    因果机会证据 负机会{
        {第二回执}, std::move(第二原因), {}, {},
        因果机会结果分类::负结果};
    return {原因键, 结果键, 因果模式规则版本,
        {std::move(正机会), std::move(负机会)}, 2, 1, 1, 5'000};
}

bool 动态关系材料相同(
    const 动态模式关系材料& 左,
    const 动态模式关系材料& 右) noexcept {
    return 左.来源句柄 == 右.来源句柄 && 左.当前句柄 == 右.当前句柄
        && 左.类型 == 右.类型 && 左.源节点 == 右.源节点
        && 左.目标节点 == 右.目标节点 && 左.顺序号 == 右.顺序号
        && 左.阶段 == 右.阶段;
}

bool 可选动态关系材料相同(
    const std::optional<动态模式关系材料>& 左,
    const std::optional<动态模式关系材料>& 右) noexcept {
    return 左.has_value() == 右.has_value()
        && (!左.has_value() || 动态关系材料相同(*左, *右));
}

bool 动态节点材料相同(
    const 动态模式节点材料& 左,
    const 动态模式节点材料& 右) noexcept {
    return 左.节点 == 右.节点 && 左.类型 == 右.类型
        && 左.主信息 == 右.主信息 && 左.主键组 == 右.主键组;
}

bool 动态状态材料相同(
    const 动态模式状态材料& 左,
    const 动态模式状态材料& 右) noexcept {
    return 动态节点材料相同(左.身份, 右.身份)
        && 左.状态值 == 右.状态值 && 左.发生时间戳 == 右.发生时间戳
        && 左.场景 == 右.场景 && 左.主体 == 右.主体
        && 可选动态关系材料相同(左.场景临时关系, 右.场景临时关系)
        && 可选动态关系材料相同(左.主体关系, 右.主体关系)
        && 可选动态关系材料相同(左.场景关系, 右.场景关系);
}

bool 动态动作材料相同(
    const 动态模式动作材料& 左,
    const 动态模式动作材料& 右) noexcept {
    return 动态节点材料相同(左.身份, 右.身份)
        && 动态状态材料相同(左.角色状态, 右.角色状态)
        && 动态状态材料相同(左.入口状态, 右.入口状态)
        && 动态关系材料相同(左.角色关系, 右.角色关系)
        && 动态关系材料相同(左.入口关系, 右.入口关系);
}

bool 动态证据材料相同(
    const 动态模式动态材料& 左,
    const 动态模式动态材料& 右) noexcept {
    return 动态节点材料相同(左.身份, 右.身份)
        && 左.发生时间戳 == 右.发生时间戳
        && 左.场景 == 右.场景 && 左.主体 == 右.主体
        && 左.被改变目标 == 右.被改变目标
        && 左.前状态 == 右.前状态 && 左.后状态 == 右.后状态
        && 左.来源动作 == 右.来源动作
        && 动态关系材料相同(左.场景临时关系, 右.场景临时关系)
        && 动态关系材料相同(左.主体关系, 右.主体关系)
        && 动态关系材料相同(左.场景关系, 右.场景关系)
        && 动态关系材料相同(左.目标关系, 右.目标关系)
        && 动态关系材料相同(左.前状态关系, 右.前状态关系)
        && 动态关系材料相同(左.后状态关系, 右.后状态关系)
        && 可选动态关系材料相同(左.来源动作关系, 右.来源动作关系);
}

bool 动态节点材料组相同(
    const std::vector<动态模式节点材料>& 左,
    const std::vector<动态模式节点材料>& 右) noexcept {
    return 左.size() == 右.size()
        && std::equal(左.begin(), 左.end(), 右.begin(), 动态节点材料相同);
}

bool 动态关系材料组相同(
    const std::vector<动态模式关系材料>& 左,
    const std::vector<动态模式关系材料>& 右) noexcept {
    return 左.size() == 右.size()
        && std::equal(左.begin(), 左.end(), 右.begin(), 动态关系材料相同);
}

bool 权威批次完整相同(
    const 动态模式权威批次& 左,
    const 动态模式权威批次& 右) noexcept {
    return 任务结果回执材料相同(左.请求.回执, 右.请求.回执)
        && 左.请求.片段序号 == 右.请求.片段序号
        && 左.请求.规则版本 == 右.请求.规则版本
        && 动态节点材料相同(左.任务, 右.任务)
        && 动态节点材料相同(左.需求, 右.需求)
        && 动态节点材料相同(左.场景, 右.场景)
        && 动态节点材料相同(左.主体, 右.主体)
        && 动态节点材料相同(左.方法, 右.方法)
        && 动态节点材料组相同(左.冻结支持节点组, 右.冻结支持节点组)
        && 动态关系材料组相同(左.冻结关系组, 右.冻结关系组)
        && 动态状态材料相同(左.被改变目标, 右.被改变目标)
        && 动态状态材料相同(左.前状态, 右.前状态)
        && 动态状态材料相同(左.后状态, 右.后状态)
        && 动态动作材料相同(左.来源动作, 右.来源动作)
        && 动态证据材料相同(左.动态, 右.动态);
}

bool 实例来源相同(
    const 单步片段实例候选& 左,
    const 单步片段实例候选& 右) noexcept {
    return 左.结构键哈希 == 右.结构键哈希
        && 动态模式结构键相同(左.结构键, 右.结构键)
        && 动态模式回合身份相同(左.来源步骤.回合, 右.来源步骤.回合)
        && 左.来源步骤.片段序号 == 右.来源步骤.片段序号
        && 左.来源步骤.发生时间戳 == 右.来源步骤.发生时间戳
        && 左.来源步骤.来源动态 == 右.来源步骤.来源动态
        && 左.来源步骤.场景 == 右.来源步骤.场景
        && 左.来源步骤.主体 == 右.来源步骤.主体
        && 左.来源步骤.任务 == 右.来源步骤.任务
        && 左.来源步骤.方法 == 右.来源步骤.方法
        && 权威批次完整相同(
            左.来源步骤.来源批次, 右.来源步骤.来源批次);
}

bool 实例组相同(
    const std::vector<单步片段实例候选>& 左,
    const std::vector<单步片段实例候选>& 右) noexcept {
    return 左.size() == 右.size()
        && std::equal(左.begin(), 左.end(), 右.begin(), 实例来源相同);
}

bool 因果候选相同(
    const 因果概率候选& 左,
    const 因果概率候选& 右) noexcept {
    if (!动态模式结构键相同(左.原因结构键, 右.原因结构键)
        || !动态模式结构键相同(左.结果结构键, 右.结果结构键)
        || 左.规则版本 != 右.规则版本 || 左.机会数 != 右.机会数
        || 左.正结果数 != 右.正结果数 || 左.负结果数 != 右.负结果数
        || 左.Q10000 != 右.Q10000
        || 左.机会证据组.size() != 右.机会证据组.size()) {
        return false;
    }
    for (std::size_t 索引 = 0; 索引 < 左.机会证据组.size(); ++索引) {
        const auto& 左证据 = 左.机会证据组[索引];
        const auto& 右证据 = 右.机会证据组[索引];
        if (!动态模式回合身份相同(左证据.回合, 右证据.回合)
            || !实例来源相同(左证据.原因实例, 右证据.原因实例)
            || !实例组相同(左证据.原因前结果组, 右证据.原因前结果组)
            || !实例组相同(左证据.原因后结果组, 右证据.原因后结果组)
            || 左证据.分类 != 右证据.分类) {
            return false;
        }
    }
    return true;
}

bool 因果历史早于冻结(
    const 因果概率候选& 候选,
    std::uint64_t 冻结时间戳) noexcept {
    for (const auto& 证据 : 候选.机会证据组) {
        if (证据.回合.回执.发生时间戳 >= 冻结时间戳
            || 证据.原因实例.来源步骤.发生时间戳 >= 冻结时间戳) {
            return false;
        }
        for (const auto& 实例 : 证据.原因前结果组) {
            if (实例.来源步骤.发生时间戳 >= 冻结时间戳) return false;
        }
        for (const auto& 实例 : 证据.原因后结果组) {
            if (实例.来源步骤.发生时间戳 >= 冻结时间戳) return false;
        }
    }
    return true;
}

bool 任务结果参数相同(
    const 规范化任务结果参数& 左,
    const 任务结果治理参数& 右) noexcept {
    return 左.当前时间戳 == 右.当前时间戳
        && 左.待重筹办幂等材料编号 == 右.待重筹办幂等材料编号
        && 左.待重筹办发生时间戳 == 右.待重筹办发生时间戳
        && 左.完成状态幂等主键 == 右.完成状态幂等主键
        && 左.完成发生时间戳 == 右.完成发生时间戳
        && 左.结算状态幂等主键 == 右.结算状态幂等主键
        && 左.结算发生时间戳 == 右.结算发生时间戳
        && 左.因果引用 == 右.因果引用;
}

bool 待结算提示相同(
    const 规范化待需求结算提示& 左,
    const 非权威待需求结算提示& 右) noexcept {
    return 左.任务 == 右.任务 && 左.需求 == 右.需求
        && 左.实际状态 == 右.实际状态 && 左.动态证据 == 右.动态证据
        && 左.因果引用 == 右.因果引用
        && 左.任务完成状态 == 右.任务完成状态
        && 左.需求结算状态 == 右.需求结算状态
        && 左.结算状态幂等主键 == 右.结算状态幂等主键
        && 左.结算发生时间戳 == 右.结算发生时间戳
        && 左.承载性质 == 待结算提示承载性质::仅非权威请求材料
        && !右.承载机器事实;
}

bool 高级关系相同(
    const 高级关系证据& 左,
    const 高级关系证据& 右) noexcept {
    return 左.关系 == 右.关系 && 左.类型 == 右.类型
        && 左.源节点 == 右.源节点 && 左.目标节点 == 右.目标节点
        && 左.顺序号 == 右.顺序号 && 左.状态 == 右.状态;
}

bool 高级身份相同(
    const 高级节点身份& 左,
    const 高级节点身份& 右) noexcept {
    return 左.状态 == 右.状态 && 左.幂等主键 == 右.幂等主键
        && 左.节点 == 右.节点 && 左.类型 == 右.类型
        && 左.主信息 == 右.主信息;
}

bool 选择材料相同(
    const 任务方法选择材料& 左,
    const 任务方法选择材料& 右) noexcept {
    return 高级身份相同(左.记录身份, 右.记录身份)
        && 左.任务 == 右.任务 && 左.方法 == 右.方法
        && 左.幂等材料编号 == 右.幂等材料编号
        && 高级关系相同(左.方法投影关系, 右.方法投影关系)
        && 高级关系相同(左.发布关系, 右.发布关系)
        && 左.来源生命周期关系 == 右.来源生命周期关系
        && 左.来源生命周期版本 == 右.来源生命周期版本
        && 左.来源方法生命周期关系 == 右.来源方法生命周期关系
        && 左.来源方法生命周期版本 == 右.来源方法生命周期版本
        && 左.排序规则版本 == 右.排序规则版本
        && 左.召回请求规则版本 == 右.召回请求规则版本
        && 左.来源候选数量 == 右.来源候选数量;
}

bool 任务材料相同(
    const 任务权威材料& 左,
    const 任务权威材料& 右) noexcept {
    if (左.状态 != 右.状态 || !高级身份相同(左.身份, 右.身份)
        || 左.来源需求 != 右.来源需求 || 左.虚拟存在 != 右.虚拟存在
        || 左.场景 != 右.场景 || 左.目标状态 != 右.目标状态
        || !高级关系相同(左.需求拥有任务关系, 右.需求拥有任务关系)
        || !高级关系相同(左.任务来源需求关系, 右.任务来源需求关系)
        || !高级关系相同(左.虚拟存在关系, 右.虚拟存在关系)
        || !高级关系相同(左.场景关系, 右.场景关系)
        || !高级关系相同(左.目标状态关系, 右.目标状态关系)
        || !高级关系相同(左.当前生命周期.关系, 右.当前生命周期.关系)
        || 左.当前生命周期.状态 != 右.当前生命周期.状态
        || 左.当前生命周期.阶段 != 右.当前生命周期.阶段
        || 左.当前生命周期.版本 != 右.当前生命周期.版本
        || 左.当前生命周期.发生时间戳 != 右.当前生命周期.发生时间戳
        || 左.当前生命周期.记录阶段 != 右.当前生命周期.记录阶段
        || 左.实际结果状态 != 右.实际结果状态
        || 左.实际结果关系.has_value() != 右.实际结果关系.has_value()
        || 左.当前选择.has_value() != 右.当前选择.has_value()) {
        return false;
    }
    if (左.实际结果关系.has_value()
        && !高级关系相同(*左.实际结果关系, *右.实际结果关系)) return false;
    return !左.当前选择.has_value()
        || 选择材料相同(*左.当前选择, *右.当前选择);
}

bool 需求材料相同(
    const 需求权威材料& 左,
    const 需求权威材料& 右) noexcept {
    return 左.状态 == 右.状态 && 高级身份相同(左.身份, 右.身份)
        && 左.主体 == 右.主体 && 左.目标宿主 == 右.目标宿主
        && 左.场景 == 右.场景 && 左.目标特征 == 右.目标特征
        && 左.当前特征状态材料 == 右.当前特征状态材料
        && 左.目标状态 == 右.目标状态
        && 高级关系相同(左.主体关系, 右.主体关系)
        && 高级关系相同(左.目标宿主关系, 右.目标宿主关系)
        && 高级关系相同(左.场景关系, 右.场景关系)
        && 高级关系相同(左.目标特征关系, 右.目标特征关系)
        && 高级关系相同(左.当前特征状态关系, 右.当前特征状态关系)
        && 高级关系相同(左.目标状态关系, 右.目标状态关系)
        && 左.目标概念 == 右.目标概念
        && 左.目标概念关系.has_value() == 右.目标概念关系.has_value()
        && 左.父需求 == 右.父需求
        && 左.父子关系.has_value() == 右.父子关系.has_value()
        && 左.当前结算 == 右.当前结算
        && 左.最近结算状态 == 右.最近结算状态;
}

enum class 正式结果篡改种类 : std::uint8_t {
    实际状态幂等主键,
    任务场景关系句柄,
    选择排序规则版本,
    选择发布关系目标,
    实际结果关系顺序,
    需求主体关系顺序,
    删除待结算提示,
    已结算结论,
    已达成状态值,
    未达成状态值,
    失败状态夹带已满足材料,
    未达成需求提交状态,
    无效最近结算句柄
};

bool 正式结果矛盾被拒绝(
    const 用途来源冻结材料& 冻结来源,
    const 任务结果治理请求& 请求,
    const 任务结果治理结果& 基础结果,
    正式结果篡改种类 种类,
    const 需求提交结果* 已满足材料来源 = nullptr) {
    auto 篡改结果 = 基础结果;
    switch (种类) {
    case 正式结果篡改种类::实际状态幂等主键:
        ++篡改结果.目标裁决.实际状态材料.幂等主键;
        break;
    case 正式结果篡改种类::任务场景关系句柄:
        ++篡改结果.任务提交.材料.场景关系.关系.关系编号;
        break;
    case 正式结果篡改种类::选择排序规则版本:
        if (!篡改结果.任务提交.材料.当前选择.has_value()) return false;
        ++篡改结果.任务提交.材料.当前选择->排序规则版本;
        break;
    case 正式结果篡改种类::选择发布关系目标:
        if (!篡改结果.任务提交.材料.当前选择.has_value()) return false;
        篡改结果.任务提交.材料.当前选择->发布关系.目标节点 = 形成节点(999'991);
        break;
    case 正式结果篡改种类::实际结果关系顺序:
        if (!篡改结果.任务提交.材料.实际结果关系.has_value()) return false;
        ++篡改结果.任务提交.材料.实际结果关系->顺序号;
        break;
    case 正式结果篡改种类::需求主体关系顺序:
        篡改结果.需求结算.材料.主体关系.顺序号 = 0;
        break;
    case 正式结果篡改种类::删除待结算提示:
        篡改结果.待结算提示.reset();
        break;
    case 正式结果篡改种类::已结算结论:
        篡改结果.需求结算.材料.当前结算 = 分层需求结算结论::未结算;
        break;
    case 正式结果篡改种类::已达成状态值:
        ++篡改结果.目标裁决.目标状态材料.状态值;
        break;
    case 正式结果篡改种类::未达成状态值:
        篡改结果.目标裁决.目标状态材料.状态值
            = 篡改结果.目标裁决.实际状态材料.状态值;
        break;
    case 正式结果篡改种类::失败状态夹带已满足材料:
        if (已满足材料来源 == nullptr) return false;
        篡改结果.需求结算.材料 = 已满足材料来源->材料;
        break;
    case 正式结果篡改种类::未达成需求提交状态:
        篡改结果.需求结算.状态 = 需求任务方法业务状态::幂等冲突;
        break;
    case 正式结果篡改种类::无效最近结算句柄:
        篡改结果.需求结算.材料.最近结算状态 = 节点句柄{};
        break;
    }
    const auto 结果 = 用途事件组合器::形成用途事件候选(
        冻结来源, 请求, 篡改结果);
    const auto 期望原因 = 种类 == 正式结果篡改种类::实际状态幂等主键
        ? 用途事件拒绝原因::身份材料矛盾
        : 用途事件拒绝原因::正式结果材料矛盾;
    return 结果.状态 == 用途事件处理状态::内部不一致
        && 结果.拒绝原因 == 期望原因
        && !结果.事件.has_value();
}

enum class 因果候选篡改种类 : std::uint8_t {
    单机会,
    反转机会顺序,
    重复后结果实例,
    候选规则版本
};

bool 因果候选矛盾被拒绝(
    const 因果概率候选& 基础候选,
    const 任务执行冻结请求& 冻结请求,
    因果候选篡改种类 种类,
    std::uint64_t 冻结键) {
    auto 候选 = 基础候选;
    switch (种类) {
    case 因果候选篡改种类::单机会:
        候选.机会证据组.resize(1);
        候选.机会数 = 1;
        候选.正结果数 = 1;
        候选.负结果数 = 0;
        候选.Q10000 = 10'000;
        break;
    case 因果候选篡改种类::反转机会顺序:
        if (候选.机会证据组.size() < 2) return false;
        std::swap(候选.机会证据组[0], 候选.机会证据组[1]);
        break;
    case 因果候选篡改种类::重复后结果实例:
        if (候选.机会证据组.empty()
            || 候选.机会证据组.front().原因后结果组.empty()) return false;
        候选.机会证据组.front().原因后结果组.push_back(
            候选.机会证据组.front().原因后结果组.front());
        break;
    case 因果候选篡改种类::候选规则版本:
        ++候选.规则版本;
        break;
    }
    if (!候选.完整()) return false;
    const auto 结果 = 用途事件业务服务::冻结用途来源({
        候选, 冻结请求, 冻结键, 用途事件规则版本,
        冻结请求.调度请求.任务序号,
        冻结请求.调度请求.执行时间戳});
    return 结果.状态 == 用途事件处理状态::入口拒绝
        && 结果.拒绝原因 == 用途事件拒绝原因::因果候选不完整
        && !结果.材料.has_value();
}

bool 不同回合被拒绝(
    const 用途来源冻结材料& 冻结来源,
    const 规范化任务结果来源& 结果来源) {
    auto 不同回合冻结 = 冻结来源;
    if (!不同回合冻结.任务执行请求.任务材料.当前选择.has_value()) return false;
    ++不同回合冻结.任务执行请求.任务材料.当前选择->排序规则版本;
    const auto 结果 = 用途事件业务服务::形成结构化结果效用({
        不同回合冻结, 结果来源, 用途事件规则版本});
    return 结果.状态 == 用途事件处理状态::入口拒绝
        && 结果.拒绝原因 == 用途事件拒绝原因::来源冻结回合不一致
        && !结果.事件.has_value();
}

bool 非正式结果被拒绝(
    const 用途来源冻结材料& 冻结来源,
    const 任务结果治理请求& 请求,
    const 任务结果治理结果& 基础结果) {
    auto 非正式结果 = 基础结果;
    非正式结果.状态 = 任务结果治理状态::入口拒绝;
    const auto 结果 = 用途事件组合器::形成用途事件候选(
        冻结来源, 请求, 非正式结果);
    return 结果.状态 == 用途事件处理状态::入口拒绝
        && 结果.拒绝原因 == 用途事件拒绝原因::结果尚未正式收口
        && !结果.事件.has_value();
}

bool 冻结入口负例通过(
    const 因果概率候选& 因果候选,
    const 任务执行冻结请求& 冻结请求) {
    const auto 请求版本不支持 = 用途事件业务服务::冻结用途来源({
        因果候选, 冻结请求, 850'006, 用途事件规则版本 + 1,
        冻结请求.调度请求.任务序号, 冻结请求.调度请求.执行时间戳});
    const auto 晚于执行冻结 = 用途事件业务服务::冻结用途来源({
        因果候选, 冻结请求, 850'007, 用途事件规则版本,
        冻结请求.调度请求.任务序号,
        冻结请求.调度请求.执行时间戳 + 1});
    auto 生命周期漂移请求 = 冻结请求;
    生命周期漂移请求.任务材料.当前生命周期.发生时间戳
        = 冻结请求.调度请求.执行时间戳 + 1;
    const auto 生命周期晚于冻结 = 用途事件业务服务::冻结用途来源({
        因果候选, 生命周期漂移请求, 850'008, 用途事件规则版本,
        生命周期漂移请求.调度请求.任务序号,
        生命周期漂移请求.调度请求.执行时间戳});
    return 请求版本不支持.状态 == 用途事件处理状态::不支持
        && 请求版本不支持.拒绝原因 == 用途事件拒绝原因::规则版本不支持
        && !请求版本不支持.材料.has_value()
        && 晚于执行冻结.状态 == 用途事件处理状态::入口拒绝
        && 晚于执行冻结.拒绝原因 == 用途事件拒绝原因::来源冻结不完整
        && !晚于执行冻结.材料.has_value()
        && 生命周期晚于冻结.状态 == 用途事件处理状态::入口拒绝
        && 生命周期晚于冻结.拒绝原因 == 用途事件拒绝原因::来源冻结不完整
        && !生命周期晚于冻结.材料.has_value();
}

bool 连续纯值输出相同(
    const 用途来源冻结材料& 冻结来源,
    const 任务结果治理请求& 请求,
    const 任务结果治理结果& 结果,
    const 用途事件材料& 基线,
    std::size_t 轮数) {
    for (std::size_t 轮次 = 0; 轮次 < 轮数; ++轮次) {
        const auto 当前 = 用途事件组合器::形成用途事件候选(
            冻结来源, 请求, 结果);
        if (!当前.成功() || !当前.事件.has_value()
            || 当前.事件->需求 != 基线.需求 || 当前.事件->任务 != 基线.任务
            || 当前.事件->实际状态 != 基线.实际状态
            || 当前.事件->动态证据 != 基线.动态证据
            || 当前.事件->效用.历史概率.Q10000
                != 基线.效用.历史概率.Q10000
            || !因果候选相同(
                当前.事件->冻结来源.因果候选,
                基线.冻结来源.因果候选)) {
            return false;
        }
    }
    return true;
}

}

}

export namespace 海中鱼巣 {

自检单元结果 运行用途事件自检() {
    using namespace 用途事件自检内部;

    static_assert(std::is_same_v<
        decltype(用途事件业务服务::冻结用途来源(用途来源冻结请求{})),
        用途来源冻结结果>);
    static_assert(std::is_same_v<
        decltype(用途事件组合器::形成用途事件候选(
            用途来源冻结材料{}, 任务结果治理请求{}, 任务结果治理结果{})),
        用途事件结果>);
    static_assert(std::is_copy_constructible_v<用途来源冻结材料>);
    static_assert(std::is_copy_constructible_v<用途事件材料>);

    std::array<bool, 16> 验收{};
    try {
        const auto 冻结请求 = 形成冻结请求(200'000);
        const auto 因果候选 = 形成因果候选(冻结请求);
        const auto 冻结结果 = 用途事件业务服务::冻结用途来源({
            因果候选, 冻结请求, 850'001, 用途事件规则版本,
            冻结请求.调度请求.任务序号, 冻结请求.调度请求.执行时间戳});
        验收[0] = 冻结任务执行请求完整(冻结请求)
            && 因果候选.完整() && 冻结结果.成功();
        验收[1] = 用途事件规则版本 == 1
            && std::is_copy_constructible_v<规范化任务结果来源>
            && std::is_copy_constructible_v<结构化结果效用>
            && std::is_copy_constructible_v<用途事件材料>;
        if (!冻结结果.材料.has_value()
            || !冻结请求.任务材料.当前选择.has_value()) throw 0;
        const auto& 冻结来源 = *冻结结果.材料;

        const auto 未达成夹具 = 形成任务结果夹具(
            冻结请求, 任务结果治理状态::未达成已转待重筹办, 110'000);
        const auto 待结算夹具 = 形成任务结果夹具(
            冻结请求, 任务结果治理状态::任务已完成待需求结算, 120'000);
        const auto 已结算夹具 = 形成任务结果夹具(
            冻结请求, 任务结果治理状态::已完成并结算, 130'000);
        const auto 未达成 = 用途事件组合器::形成用途事件候选(
            冻结来源, 未达成夹具.请求, 未达成夹具.结果);
        const auto 待结算 = 用途事件组合器::形成用途事件候选(
            冻结来源, 待结算夹具.请求, 待结算夹具.结果);
        const auto 已结算 = 用途事件组合器::形成用途事件候选(
            冻结来源, 已结算夹具.请求, 已结算夹具.结果);

        验收[2] = 未达成.成功() && 待结算.成功() && 已结算.成功()
            && 未达成夹具.结果.协议结果.状态 == 任务结果回执准入状态::可准入
            && 待结算夹具.结果.协议结果.状态 == 任务结果回执准入状态::可准入
            && 已结算夹具.结果.协议结果.状态 == 任务结果回执准入状态::可准入;
        if (!验收[2] || !未达成.事件.has_value()
            || !待结算.事件.has_value() || !已结算.事件.has_value()
            || !已结算夹具.结果.任务提交.材料.当前选择.has_value()
            || !已结算夹具.结果.任务提交.材料.实际结果关系.has_value()) throw 0;

        const auto& 未达成事件 = *未达成.事件;
        const auto& 待结算事件 = *待结算.事件;
        const auto& 已结算事件 = *已结算.事件;

        用途来源冻结材料 缺冻结来源;
        缺冻结来源.规则版本 = 用途事件规则版本;
        const auto 缺冻结 = 用途事件组合器::形成用途事件候选(
            缺冻结来源, 未达成夹具.请求, 未达成夹具.结果);
        const 动态模式回合身份 当前结果回合{已结算夹具.请求.回执};
        const bool 历史机会独立于当前回合 = std::none_of(
            因果候选.机会证据组.begin(), 因果候选.机会证据组.end(),
            [&](const auto& 证据) {
                return 动态模式回合身份相同(证据.回合, 当前结果回合);
            });
        验收[3] = 冻结来源.冻结键与观察主键 == 850'001
            && 不同回合被拒绝(冻结来源, 未达成事件.结果来源)
            && 缺冻结.状态 == 用途事件处理状态::入口拒绝
            && 缺冻结.拒绝原因 == 用途事件拒绝原因::来源冻结不完整
            && !缺冻结.事件.has_value()
            && 历史机会独立于当前回合;

        验收[4] = 已结算事件.需求 == 冻结请求.任务材料.来源需求
            && 已结算事件.任务 == 冻结请求.任务材料.身份.节点
            && 已结算事件.选择记录
                == 冻结请求.任务材料.当前选择->记录身份.节点
            && 已结算事件.方法 == 冻结请求.方法材料.身份.节点
            && 已结算事件.动作 == 冻结请求.动作材料.身份.节点
            && 已结算事件.场景 == 冻结请求.任务材料.场景
            && 已结算事件.主体 == 冻结请求.任务材料.虚拟存在
            && 已结算事件.目标状态 == 冻结请求.任务材料.目标状态
            && 已结算事件.实际状态
                == 已结算夹具.请求.回执.句柄组.实际结果状态
            && 已结算事件.动态证据
                == 已结算夹具.请求.回执.句柄组.动态证据
            && 已结算事件.实际状态值 == 冻结请求.调度请求.实际状态值
            && 已结算事件.结果来源.目标裁决.实际状态材料.幂等主键
                == 冻结请求.调度请求.实际状态幂等主键
            && 正式结果矛盾被拒绝(
                冻结来源, 已结算夹具.请求, 已结算夹具.结果,
                正式结果篡改种类::实际状态幂等主键)
            && 正式结果矛盾被拒绝(
                冻结来源, 已结算夹具.请求, 已结算夹具.结果,
                正式结果篡改种类::任务场景关系句柄)
            && 正式结果矛盾被拒绝(
                冻结来源, 已结算夹具.请求, 已结算夹具.结果,
                正式结果篡改种类::选择排序规则版本)
            && 正式结果矛盾被拒绝(
                冻结来源, 已结算夹具.请求, 已结算夹具.结果,
                正式结果篡改种类::选择发布关系目标)
            && 正式结果矛盾被拒绝(
                冻结来源, 已结算夹具.请求, 已结算夹具.结果,
                正式结果篡改种类::实际结果关系顺序)
            && 正式结果矛盾被拒绝(
                冻结来源, 已结算夹具.请求, 已结算夹具.结果,
                正式结果篡改种类::需求主体关系顺序);
        验收[5] = 未达成事件.效用.任务达成 == 任务达成分量::未达成
            && 未达成事件.效用.需求结算 == 需求结算分量::未形成
            && 未达成事件.效用.观察阶段 == 用途观察阶段::尝试未达成
            && 未达成事件.结果来源.需求结算.状态
                == 需求任务方法业务状态::入口拒绝
            && !未达成事件.结果来源.待结算提示.has_value();
        const bool 待结算提示完整 = 待结算事件.结果来源.待结算提示.has_value()
            && 待结算夹具.结果.待结算提示.has_value()
            && 待结算提示相同(
                *待结算事件.结果来源.待结算提示,
                *待结算夹具.结果.待结算提示);
        验收[6] = 待结算事件.效用.任务达成 == 任务达成分量::已达成
            && 待结算事件.效用.需求结算 == 需求结算分量::待结算
            && 待结算事件.效用.观察阶段 == 用途观察阶段::待结算
            && 待结算提示完整;
        验收[7] = 已结算事件.效用.任务达成 == 任务达成分量::已达成
            && 已结算事件.效用.需求结算 == 需求结算分量::已满足
            && 已结算事件.效用.观察阶段 == 用途观察阶段::最终已结算
            && 已结算事件.结果来源.需求结算.成功()
            && 已结算事件.结果来源.需求结算.材料.最近结算状态.has_value()
            && 句柄有效(*已结算事件.结果来源.需求结算.材料.最近结算状态);
        验收[8] = 因果候选相同(已结算事件.冻结来源.因果候选, 因果候选)
            && 已结算事件.冻结来源.因果候选.机会证据组.size() == 2
            && 已结算事件.效用.历史概率.机会数 == 2
            && 已结算事件.效用.历史概率.正结果数 == 1
            && 已结算事件.效用.历史概率.负结果数 == 1
            && 已结算事件.效用.历史概率.Q10000 == 5'000
            && 历史机会独立于当前回合
            && 因果历史早于冻结(因果候选, 冻结来源.冻结时间戳);

        验收[9] = 正式结果矛盾被拒绝(
                冻结来源, 待结算夹具.请求, 待结算夹具.结果,
                正式结果篡改种类::删除待结算提示)
            && 正式结果矛盾被拒绝(
                冻结来源, 已结算夹具.请求, 已结算夹具.结果,
                正式结果篡改种类::已结算结论)
            && 正式结果矛盾被拒绝(
                冻结来源, 已结算夹具.请求, 已结算夹具.结果,
                正式结果篡改种类::已达成状态值)
            && 正式结果矛盾被拒绝(
                冻结来源, 未达成夹具.请求, 未达成夹具.结果,
                正式结果篡改种类::未达成状态值)
            && 正式结果矛盾被拒绝(
                冻结来源, 待结算夹具.请求, 待结算夹具.结果,
                正式结果篡改种类::失败状态夹带已满足材料,
                &已结算夹具.结果.需求结算)
            && 正式结果矛盾被拒绝(
                冻结来源, 未达成夹具.请求, 未达成夹具.结果,
                正式结果篡改种类::未达成需求提交状态)
            && 正式结果矛盾被拒绝(
                冻结来源, 已结算夹具.请求, 已结算夹具.结果,
                正式结果篡改种类::无效最近结算句柄);

        验收[10] = 连续纯值输出相同(
            冻结来源, 已结算夹具.请求, 已结算夹具.结果, 已结算事件, 1);

        验收[11] = 非正式结果被拒绝(
                冻结来源, 未达成夹具.请求, 未达成夹具.结果)
            && 因果候选矛盾被拒绝(
                因果候选, 冻结请求, 因果候选篡改种类::单机会, 850'002)
            && 因果候选矛盾被拒绝(
                因果候选, 冻结请求,
                因果候选篡改种类::反转机会顺序, 850'003)
            && 因果候选矛盾被拒绝(
                因果候选, 冻结请求,
                因果候选篡改种类::重复后结果实例, 850'004)
            && 因果候选矛盾被拒绝(
                因果候选, 冻结请求,
                因果候选篡改种类::候选规则版本, 850'005)
            && 冻结入口负例通过(因果候选, 冻结请求);

        验收[12] = 任务结果回执材料相同(
                已结算事件.结果来源.完整回执, 已结算夹具.请求.回执)
            && 冻结任务执行请求相同(
                已结算事件.冻结来源.任务执行请求, 冻结请求)
            && 因果候选相同(已结算事件.冻结来源.因果候选, 因果候选)
            && 已结算事件.结果来源.正式结果 == 用途正式结果分类::已完成并结算
            && 已结算事件.结果来源.收口原因 == 用途结果收口原因::无
            && 已结算事件.结果来源.协议结果.状态
                == 已结算夹具.结果.协议结果.状态
            && 已结算事件.结果来源.协议结果.拒绝原因
                == 已结算夹具.结果.协议结果.拒绝原因
            && 已结算事件.结果来源.目标裁决.裁决
                == 已结算夹具.结果.目标裁决.裁决
            && 已结算事件.结果来源.目标裁决.需求
                == 已结算夹具.结果.目标裁决.需求
            && 已结算事件.结果来源.目标裁决.目标状态材料.状态值
                == 已结算夹具.结果.目标裁决.目标状态材料.状态值
            && 已结算事件.结果来源.目标裁决.实际状态材料.幂等主键
                == 已结算夹具.结果.目标裁决.实际状态材料.幂等主键
            && 已结算事件.结果来源.目标裁决.实际状态材料.状态值
                == 已结算夹具.结果.目标裁决.实际状态材料.状态值
            && 已结算事件.结果来源.任务提交.状态
                == 已结算夹具.结果.任务提交.状态
            && 任务材料相同(
                已结算事件.结果来源.任务提交.材料,
                已结算夹具.结果.任务提交.材料)
            && 已结算事件.结果来源.需求结算.状态
                == 已结算夹具.结果.需求结算.状态
            && 需求材料相同(
                已结算事件.结果来源.需求结算.材料,
                已结算夹具.结果.需求结算.材料)
            && 任务结果参数相同(
                已结算事件.结果来源.参数, 已结算夹具.请求.参数)
            && 待结算提示完整;

        验收[13] = 连续纯值输出相同(
            冻结来源, 已结算夹具.请求, 已结算夹具.结果, 已结算事件, 20);
        验收[14] = 冻结结果.材料.has_value()
            && 未达成.事件.has_value() && 待结算.事件.has_value()
            && 已结算.事件.has_value() && 验收[3] && 验收[11];
        验收[15] = std::all_of(
            验收.begin(), 验收.begin() + 15, [](bool 通过) { return 通过; });
    } catch (...) {
    }

    static constexpr std::array<const char*, 16> 名称{
        "A01 正式接口纯值准入前置",
        "A02 DTO值类型前置；所有权与五模块由外部扫描验证",
        "A03 执行前冻结和新版正式结果准入",
        "A04 完整回合同一与唯一观察主键",
        "A05 身份状态动态逐项一致",
        "A06 未达成不伪造需求负效用",
        "A07 待结算保留完整材料",
        "A08 已完成并结算三分量映射",
        "A09 Q10000与历史机会独立保留",
        "A10 正式结果矛盾内部收口",
        "A11 确定性纯值前置；零写入由外部静态扫描验证",
        "A12 拒绝语义前置；禁止词与能力由外部扫描验证",
        "A13 完整来源无损适配与比较",
        "A14 模块内连续20次；DebugRelease门禁由外部验证",
        "A15 运行期前置；阶段与禁止范围由外部扫描验证",
        "A16 运行期前置；归档提交推送由治理收口验证"};
    std::size_t 失败数量 = 0;
    for (std::size_t 索引 = 0; 索引 < 验收.size(); ++索引) {
        if (!验收[索引]) ++失败数量;
        std::cout << "CAUSAL-USE-S1-" << 名称[索引] << ": "
            << (验收[索引] ? "通过" : "失败") << '\n';
    }
    return {"CAUSAL-USE-S1", "用途事件与结构化结果效用裁决",
        失败数量 == 0, 验收.size(), 失败数量};
}

}
#endif
