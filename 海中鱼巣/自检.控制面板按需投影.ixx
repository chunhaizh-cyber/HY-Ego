// 文件规则：本模块只验证控制面板按需只读投影；不得写业务事实、修改生产结构或承载窗口状态。
module;

#include "核心/主信息仓库.h"
#include "核心/关系仓库.h"
#include "核心/索引仓库.h"
#include "领域/控制面板服务.h"
#include "界面/控制面板窗口.h"

#include <algorithm>
#include <array>
#include <cstddef>
#include <cstdint>
#include <iomanip>
#include <iostream>
#include <optional>
#include <type_traits>
#include <utility>
#include <vector>

export module 海中鱼巣.自检.控制面板按需投影;

#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
import 海中鱼巣.自检.运行器;

export namespace 海中鱼巣 {

struct 控制面板按需投影自检上下文 {
    const 控制面板服务& 控制面板;
    const 显示服务& 显示;
    const 主信息仓库& 主信息;
    const 节点仓库& 节点;
    const 关系仓库& 关系;
    const 索引仓库& 索引;
    const 概念图服务& 概念图;
    const 语素服务& 语素;
    const 需求服务& 需求;
    const 任务服务& 任务;
    const 方法服务& 方法;
    const 状态服务& 状态;
    控制面板树结构材料 世界树结构材料;
    控制面板树结构材料 语素树结构材料;
    std::array<节点句柄, 2> 根需求组;
};

namespace 控制面板按需投影自检内部 {

控制面板按需树请求 形成请求(
    控制面板树分类 分类,
    std::optional<节点句柄> 概念根 = std::nullopt,
    std::size_t 节点预算 = 4096,
    std::size_t 深度预算 = 128,
    std::size_t 根页大小 = 256,
    std::optional<控制面板根页游标> 游标 = std::nullopt) {
    return {
        {true, false, false, false, false, false},
        分类,
        概念根,
        节点预算,
        深度预算,
        根页大小,
        std::move(游标)};
}

bool 节点材料等价(const 控制面板树节点材料& 左, const 控制面板树节点材料& 右) {
    if (左.节点 != 右.节点
        || 左.类型 != 右.类型
        || 左.关系角色 != 右.关系角色
        || 左.名称基础信息 != 右.名称基础信息
        || 左.类型基础信息 != 右.类型基础信息
        || 左.名称语素入口 != 右.名称语素入口
        || 左.类型语素入口 != 右.类型语素入口
        || 左.名称语素入口组 != 右.名称语素入口组
        || 左.显示名称 != 右.显示名称
        || 左.重复投影 != 右.重复投影
        || 左.子节点组.size() != 右.子节点组.size()) {
        return false;
    }
    for (std::size_t 索引 = 0; 索引 < 左.子节点组.size(); ++索引) {
        if (!节点材料等价(左.子节点组[索引], 右.子节点组[索引])) {
            return false;
        }
    }
    return true;
}

bool 树材料等价(const 控制面板树结构材料& 左, const 控制面板树结构材料& 右) {
    if (左.状态 != 右.状态
        || 左.分类 != 右.分类
        || 左.可展示 != 右.可展示
        || 左.只读快照 != 右.只读快照
        || 左.来源版本 != 右.来源版本
        || 左.真实节点投影数量 != 右.真实节点投影数量
        || 左.根节点组.size() != 右.根节点组.size()) {
        return false;
    }
    for (std::size_t 索引 = 0; 索引 < 左.根节点组.size(); ++索引) {
        if (!节点材料等价(左.根节点组[索引], 右.根节点组[索引])) {
            return false;
        }
    }
    return true;
}

const 控制面板树节点材料* 查找根(
    const 控制面板树结构材料& 树,
    节点句柄 根节点) {
    const auto 位置 = std::find_if(
        树.根节点组.begin(), 树.根节点组.end(), [&根节点](const auto& 根) {
            return 根.节点 == 根节点;
        });
    return 位置 == 树.根节点组.end() ? nullptr : &(*位置);
}

std::size_t 计算节点数量(const 控制面板树节点材料& 节点) {
    std::size_t 数量 = 1;
    for (const auto& 子节点 : 节点.子节点组) {
        数量 += 计算节点数量(子节点);
    }
    return 数量;
}

bool 存在重复投影(const 控制面板树节点材料& 节点) {
    if (节点.重复投影) {
        return true;
    }
    return std::any_of(节点.子节点组.begin(), 节点.子节点组.end(), [](const auto& 子节点) {
        return 存在重复投影(子节点);
    });
}

bool 复核节点和主信息(
    const 控制面板树节点材料& 节点材料,
    const 节点仓库& 节点,
    const 主信息仓库& 主信息) {
    const auto 节点记录 = 节点.读取节点(节点材料.节点);
    if (!节点记录.has_value()
        || 节点记录->类型 != 节点材料.类型
        || !主信息.读取主信息(节点记录->主信息).has_value()) {
        return false;
    }
    return std::all_of(
        节点材料.子节点组.begin(), 节点材料.子节点组.end(),
        [&节点, &主信息](const auto& 子节点) {
            return 复核节点和主信息(子节点, 节点, 主信息);
        });
}

bool 复核结果节点和主信息(
    const 控制面板按需树候选材料& 结果,
    const 节点仓库& 节点,
    const 主信息仓库& 主信息) {
    return 结果.完整
        && std::all_of(
            结果.当前页树结构材料.根节点组.begin(),
            结果.当前页树结构材料.根节点组.end(),
            [&节点, &主信息](const auto& 根) {
                return 复核节点和主信息(根, 节点, 主信息);
            });
}

bool 逻辑拒绝且无部分页(const 控制面板按需树候选材料& 结果) {
    return !结果.完整
        && !结果.追根因错误
        && 结果.候选序号 == 0
        && 结果.当前页树结构材料.根节点组.empty();
}

}

自检单元结果 运行控制面板按需投影自检(
    const 控制面板按需投影自检上下文& 上下文) {
    using namespace 控制面板按需投影自检内部;

    std::array<bool, 16> 验收{};
    try {
        const auto 初始节点数 = 上下文.节点.有效节点数量();
        const auto 初始关系数 = 上下文.关系.有效关系数量();
        const auto 初始索引数 = 上下文.索引.有效主键数量();
        const auto 初始六类入口调用次数 = 上下文.控制面板.读取六类入口调用次数用于自检();

        auto 非树请求 = 形成请求(控制面板树分类::状态详情);
        auto 零节点请求 = 形成请求(控制面板树分类::世界树);
        零节点请求.节点预算 = 0;
        auto 零深度请求 = 形成请求(控制面板树分类::世界树);
        零深度请求.深度预算 = 0;
        auto 零页请求 = 形成请求(控制面板树分类::需求树);
        零页请求.根页大小 = 0;
        auto 过大页请求 = 形成请求(控制面板树分类::需求树);
        过大页请求.根页大小 = 257;
        const std::array<控制面板按需树候选材料, 5> 基础拒绝组{
            上下文.控制面板.生成当前分类真实树只读材料(非树请求),
            上下文.控制面板.生成当前分类真实树只读材料(零节点请求),
            上下文.控制面板.生成当前分类真实树只读材料(零深度请求),
            上下文.控制面板.生成当前分类真实树只读材料(零页请求),
            上下文.控制面板.生成当前分类真实树只读材料(过大页请求)};
        验收[0] = std::all_of(基础拒绝组.begin(), 基础拒绝组.end(), 逻辑拒绝且无部分页);

        std::array<控制面板按需树候选材料, 6> 六类按需结果;
        bool 单分类计数隔离 = true;
        for (std::size_t 分类索引 = 0; 分类索引 < 六类按需结果.size(); ++分类索引) {
            const auto 调用前 = 上下文.控制面板.读取分类构造调用次数用于自检();
            六类按需结果[分类索引] = 上下文.控制面板.生成当前分类真实树只读材料(
                形成请求(static_cast<控制面板树分类>(分类索引)));
            const auto 调用后 = 上下文.控制面板.读取分类构造调用次数用于自检();
            for (std::size_t 复核索引 = 0; 复核索引 < 调用前.size(); ++复核索引) {
                const auto 预期增量 = 复核索引 == 分类索引 ? 1ULL : 0ULL;
                单分类计数隔离 = 单分类计数隔离
                    && 调用后[复核索引] == 调用前[复核索引] + 预期增量;
            }
        }
        验收[1] = 单分类计数隔离
            && std::all_of(六类按需结果.begin(), 六类按需结果.end(), [](const auto& 结果) {
                return 结果.完整
                    && 结果.状态 == 控制面板请求状态::可展示
                    && 结果.当前页树结构材料.分类 == 结果.当前分类;
            });

        const auto& 默认概念结果 = 六类按需结果[1];
        验收[2] = 默认概念结果.概念根选项组.size() == 4
            && 默认概念结果.当前概念根.has_value()
            && 默认概念结果.当前概念根 == std::optional<节点句柄>{
                默认概念结果.概念根选项组.front().根节点}
            && 默认概念结果.当前页树结构材料.根节点组.size() == 1
            && 默认概念结果.当前页树结构材料.根节点组.front().节点
                == 默认概念结果.当前概念根.value();

        const 节点句柄 非活动概念根{999999, 999999, 1};
        const auto 非活动概念结果 = 上下文.控制面板.生成当前分类真实树只读材料(
            形成请求(控制面板树分类::概念树, 非活动概念根));
        验收[3] = 逻辑拒绝且无部分页(非活动概念结果)
            && 非活动概念结果.状态 == 控制面板请求状态::拒绝概念根非活动;

        const auto& 任务结果 = 六类按需结果[4];
        const auto& 方法结果 = 六类按需结果[5];
        验收[4] = 任务结果.完整
            && 方法结果.完整
            && 任务结果.当前分类 == 控制面板树分类::任务树
            && 方法结果.当前分类 == 控制面板树分类::方法树
            && 任务结果.当前页树结构材料.分类 == 控制面板树分类::任务树
            && 方法结果.当前页树结构材料.分类 == 控制面板树分类::方法树;

        const auto 需求首页 = 上下文.控制面板.生成当前分类真实树只读材料(
            形成请求(控制面板树分类::需求树, std::nullopt, 4096, 128, 1));
        const auto 需求次页 = 需求首页.下一页游标.has_value()
            ? 上下文.控制面板.生成当前分类真实树只读材料(
                形成请求(
                    控制面板树分类::需求树,
                    std::nullopt,
                    4096,
                    128,
                    1,
                    需求首页.下一页游标))
            : 控制面板按需树候选材料{};
        auto 错误游标 = 需求首页.下一页游标;
        if (错误游标.has_value()) {
            ++错误游标->根集签名;
        }
        const auto 错误游标结果 = 上下文.控制面板.生成当前分类真实树只读材料(
            形成请求(
                控制面板树分类::需求树,
                std::nullopt,
                4096,
                128,
                1,
                错误游标));
        验收[5] = 需求首页.完整
            && 需求首页.当前页树结构材料.根节点组.size() == 1
            && 需求首页.下一页游标.has_value()
            && 需求次页.完整
            && 需求次页.当前页树结构材料.根节点组.size() == 1
            && !需求次页.下一页游标.has_value()
            && 需求首页.当前页树结构材料.根节点组.front().节点
                != 需求次页.当前页树结构材料.根节点组.front().节点
            && 逻辑拒绝且无部分页(错误游标结果)
            && 错误游标结果.状态 == 控制面板请求状态::拒绝游标失效;

        const auto 预算拒绝结果 = 上下文.控制面板.生成当前分类真实树只读材料(
            形成请求(控制面板树分类::需求树, std::nullopt, 1, 128, 1));
        验收[6] = 逻辑拒绝且无部分页(预算拒绝结果)
            && 预算拒绝结果.状态 == 控制面板请求状态::拒绝预算耗尽;

        bool 概念重复投影存在 = false;
        bool 概念单根有限 = true;
        std::vector<控制面板按需树候选材料> 概念单根结果组;
        for (const auto& 选项 : 默认概念结果.概念根选项组) {
            auto 结果 = 上下文.控制面板.生成当前分类真实树只读材料(
                形成请求(控制面板树分类::概念树, 选项.根节点));
            概念单根有限 = 概念单根有限
                && 结果.完整
                && 结果.当前页树结构材料.根节点组.size() == 1
                && 计算节点数量(结果.当前页树结构材料.根节点组.front()) <= 4096;
            if (结果.完整) {
                概念重复投影存在 = 概念重复投影存在
                    || 存在重复投影(结果.当前页树结构材料.根节点组.front());
            }
            概念单根结果组.push_back(std::move(结果));
        }
        验收[7] = 概念单根有限 && 概念重复投影存在;

        const auto 新入口后的六类调用次数 = 上下文.控制面板.读取六类入口调用次数用于自检();
        const auto 旧六类结果 = 上下文.控制面板.生成六类真实树只读材料(
            {true, false, false, false, false, false});
        bool 逐类一致 = 旧六类结果.完整;
        for (std::size_t 索引 = 0; 索引 < 六类按需结果.size(); ++索引) {
            if (索引 == static_cast<std::size_t>(控制面板树分类::概念树)) {
                for (const auto& 单根结果 : 概念单根结果组) {
                    const auto* 旧根 = 单根结果.当前概念根.has_value()
                        ? 查找根(旧六类结果.树结构材料组[索引], 单根结果.当前概念根.value())
                        : nullptr;
                    逐类一致 = 逐类一致
                        && 旧根 != nullptr
                        && 单根结果.当前页树结构材料.根节点组.size() == 1
                        && 节点材料等价(
                            单根结果.当前页树结构材料.根节点组.front(), *旧根);
                }
            } else {
                逐类一致 = 逐类一致
                    && 树材料等价(
                        六类按需结果[索引].当前页树结构材料,
                        旧六类结果.树结构材料组[索引]);
            }
        }
        验收[8] = 逐类一致;
        验收[9] = 新入口后的六类调用次数 == 初始六类入口调用次数
            && 上下文.控制面板.读取六类入口调用次数用于自检()
                == 初始六类入口调用次数 + 1;

        控制面板窗口快照 快照;
        快照.当前树候选 = 默认概念结果;
        快照.当前分类 = 默认概念结果.当前分类;
        快照.当前概念根 = 默认概念结果.当前概念根;
        快照.概念根选项组 = 默认概念结果.概念根选项组;
        验收[10] = 快照.当前分类 == 控制面板树分类::概念树
            && 快照.当前树候选.当前页树结构材料.根节点组.size() == 1
            && 快照.概念根选项组.size() == 4;

        auto 异常世界树 = 上下文.世界树结构材料;
        if (!异常世界树.根节点组.empty()) {
            if (!异常世界树.根节点组.front().子节点组.empty()) {
                异常世界树.根节点组.front().子节点组.front().节点 = {};
            } else {
                异常世界树.根节点组.front().节点 = {};
            }
        }
        控制面板服务 异常控制面板(
            上下文.显示,
            上下文.节点,
            上下文.概念图,
            上下文.语素,
            上下文.需求,
            上下文.任务,
            上下文.方法,
            上下文.状态,
            std::move(异常世界树),
            上下文.语素树结构材料,
            上下文.根需求组);
        const auto 内部不一致结果 = 异常控制面板.生成当前分类真实树只读材料(
            形成请求(控制面板树分类::世界树));
        验收[11] = 内部不一致结果.追根因错误
            && 内部不一致结果.状态 == 控制面板请求状态::追根因结构不一致
            && !内部不一致结果.完整
            && 内部不一致结果.当前页树结构材料.根节点组.empty();

        bool 完整句柄仍可读 = true;
        for (const auto& 结果 : 六类按需结果) {
            完整句柄仍可读 = 完整句柄仍可读
                && 复核结果节点和主信息(结果, 上下文.节点, 上下文.主信息);
        }
        验收[12] = 上下文.节点.有效节点数量() == 初始节点数
            && 上下文.关系.有效关系数量() == 初始关系数
            && 上下文.索引.有效主键数量() == 初始索引数
            && 完整句柄仍可读;

        验收[13] = std::is_standard_layout_v<控制面板根页游标>
            && std::is_copy_constructible_v<控制面板按需树请求>
            && std::is_copy_constructible_v<控制面板按需树候选材料>;
        验收[14] = 旧六类结果.完整
            && 旧六类结果.树结构材料组.size() == 6
            && 默认概念结果.下一页游标 == std::nullopt;
        验收[15] = std::all_of(验收.begin(), 验收.begin() + 15, [](bool 通过) {
            return 通过;
        });
    }
    catch (...) {
        验收.fill(false);
    }

    std::size_t 失败数量 = 0;
    for (std::size_t 索引 = 0; 索引 < 验收.size(); ++索引) {
        if (!验收[索引]) {
            ++失败数量;
        }
        std::cout << "PANEL-PROJECTION-S2-A"
                  << std::setw(2) << std::setfill('0') << (索引 + 1)
                  << '=' << (验收[索引] ? "通过" : "失败") << '\n';
    }
    std::cout << std::setfill(' ');
    return {
        "PANEL-PROJECTION-S2",
        "显示分类与当前概念根按需只读投影",
        失败数量 == 0,
        验收.size(),
        失败数量};
}

}
#endif
