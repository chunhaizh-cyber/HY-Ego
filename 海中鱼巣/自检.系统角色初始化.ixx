export namespace 海中鱼巣 {

namespace 系统角色初始化自检内部 {

struct 结构数量 {
    std::uint64_t 节点 = 0;
    std::uint64_t 关系 = 0;
    std::uint64_t 主键 = 0;

    bool operator==(const 结构数量&) const = default;
};

系统角色初始化参数 形成参数(std::uint64_t 起始主键) {
    系统角色初始化参数 参数;
    参数.世界根主键 = 起始主键 + 1;
    参数.自我场景主键 = 起始主键 + 2;
    参数.自我存在主键 = 起始主键 + 3;
    参数.安全特征定义主键 = 起始主键 + 4;
    参数.安全实例槽位主键 = 起始主键 + 5;
    参数.安全当前特征值主键 = 起始主键 + 6;
    参数.安全目标状态主键 = 起始主键 + 7;
    参数.安全根需求主键 = 起始主键 + 8;
    参数.服务特征定义主键 = 起始主键 + 9;
    参数.服务实例槽位主键 = 起始主键 + 10;
    参数.服务当前特征值主键 = 起始主键 + 11;
    参数.服务目标状态主键 = 起始主键 + 12;
    参数.服务根需求主键 = 起始主键 + 13;
    参数.概念存在根主键 = 起始主键 + 14;
    参数.概念动态根主键 = 起始主键 + 15;
    参数.概念关系根主键 = 起始主键 + 16;
    参数.概念因果根主键 = 起始主键 + 17;
    参数.方法登记根主键 = 起始主键 + 18;
    参数.方法登记角色状态主键 = 起始主键 + 19;
    参数.方法活跃状态主键 = 起始主键 + 20;
    参数.方法失效状态主键 = 起始主键 + 21;
    参数.安全当前值 = 1;
    参数.安全目标值 = 10;
    参数.服务当前值 = 2;
    参数.服务目标值 = 20;
    参数.动态根材料 = 690;
    return 参数;
}

结构数量 读取结构数量(const 运行期上下文& 上下文) {
    return {
        上下文.读取节点仓库().有效节点数量(),
        上下文.读取关系仓库().有效关系数量(),
        上下文.读取索引仓库().有效主键数量()};
}

bool 创建夹具节点(
    运行期上下文& 上下文,
    节点类型 类型,
    std::uint64_t 主键,
    节点句柄& 输出节点) {
    结构写入执行器 执行器(
        上下文.读取接线(),
        &上下文.读取主信息仓库(),
        &上下文.读取节点仓库(),
        &上下文.读取关系仓库(),
        &上下文.读取索引仓库());
    const auto 结果 = 执行器.执行([&](结构写入会话& 会话) {
        const auto 主信息 = 会话.创建主信息候选();
        if (!主信息.成功() || !主信息.值.has_value()) return;
        const auto 节点 = 会话.创建节点候选(类型, *主信息.值);
        if (!节点.成功() || !节点.值.has_value()) return;
        if (!会话.绑定主键(主键, *节点.值).成功()) return;
        if (!会话.主信息可读(*主信息.值)
            || !会话.节点可读(*节点.值)
            || !会话.主键绑定匹配(主键, *节点.值)) return;
        输出节点 = *节点.值;
        if (!会话.请求提交()) 输出节点 = {};
    });
    return 结果.状态 == 结构写入状态::已提交 && 句柄有效(输出节点);
}

bool 挂载夹具节点(
    运行期上下文& 上下文,
    节点句柄 子节点,
    节点句柄 父节点,
    关系句柄& 输出关系) {
    结构写入执行器 执行器(
        上下文.读取接线(),
        &上下文.读取主信息仓库(),
        &上下文.读取节点仓库(),
        &上下文.读取关系仓库(),
        &上下文.读取索引仓库());
    const auto 结果 = 执行器.执行([&](结构写入会话& 会话) {
        const auto 挂载 = 会话.挂载或重挂节点(子节点, 父节点);
        if (挂载.状态 != 节点挂载结果状态::已创建
            || !挂载.父关系.has_value()) return;
        const auto 当前 = 会话.读取关系审计(*挂载.父关系);
        if (!当前.has_value() || 当前->状态 != 记录状态::有效
            || 当前->类型 != 关系类型::普通父子
            || 当前->源节点 != 父节点 || 当前->目标节点 != 子节点
            || 当前->顺序号 != 0 || !会话.关系可读(*挂载.父关系)) return;
        输出关系 = *挂载.父关系;
        if (!会话.请求提交()) 输出关系 = {};
    });
    return 结果.状态 == 结构写入状态::已提交 && 句柄有效(输出关系);
}

bool 全部稳定键可读(
    const 运行期上下文& 上下文,
    const 系统角色初始化参数& 参数) {
    auto 许可 = 上下文.读取接线().取得共享许可(
        上下文.读取接线().运行期状态);
    if (!许可.有效()) return false;
    const auto& 令牌 = 许可.读取令牌();
    for (const auto 主键 : 参数.读取稳定键组()) {
        const auto 节点 = 上下文.读取索引仓库().按主键查节点(主键, 令牌);
        if (!节点.has_value()) return false;
        const auto 记录 = 上下文.读取节点仓库().读取节点(*节点, 令牌);
        if (!记录.has_value()
            || !上下文.读取主信息仓库().读取主信息(记录->主信息, 令牌).has_value()
            || 上下文.读取索引仓库().读取节点主键组(*节点, 令牌)
                != std::vector<std::uint64_t>{主键}) return false;
    }
    return true;
}

bool 关系精确可读(
    const 运行期上下文& 上下文,
    const 系统角色关系材料& 材料) {
    auto 许可 = 上下文.读取接线().取得共享许可(
        上下文.读取接线().运行期状态);
    if (!许可.有效()) return false;
    const auto 记录 = 上下文.读取关系仓库().读取关系(
        材料.关系, 许可.读取令牌());
    return 记录.has_value() && 记录->状态 == 记录状态::有效
        && 记录->类型 == 材料.类型 && 记录->源节点 == 材料.源节点
        && 记录->目标节点 == 材料.目标节点 && 记录->顺序号 == 材料.顺序号
        && 记录->版本号 == 材料.关系.版本号;
}

bool 身份类型匹配(
    const 系统角色身份材料& 身份,
    系统角色稳定键用途 用途,
    节点类型 类型) {
    return 身份.完整() && 身份.用途 == 用途 && 身份.类型 == 类型;
}

}

自检单元结果 运行系统角色初始化自检(bool 历史兼容回归通过) {
    using namespace 系统角色初始化自检内部;

    static_assert(std::is_same_v<
        decltype(std::declval<运行期上下文&>().初始化系统角色(
            std::declval<const 系统角色初始化参数&>())),
        系统角色初始化结果>);
    static_assert(std::is_same_v<
        decltype(std::declval<const 系统角色数据操作&>().预检稳定键(
            std::declval<const 系统角色初始化参数&>())),
        系统角色预检结果>);
    static_assert(std::is_default_constructible_v<世界树初始化结果>);
    static_assert(std::is_default_constructible_v<语素初始化结果>);
    static_assert(std::is_default_constructible_v<概念图初始化结果>);
    static_assert(std::is_default_constructible_v<自我根需求初始化结果>);
    static_assert(!std::is_copy_constructible_v<运行期上下文>);

    std::array<bool, 22> 验收{};
    try {
        const auto 无效基准参数 = 形成参数(0x0690'1000'0000'0000ULL);
        运行期上下文 无效参数上下文(6901, 6901);
        const auto 无效前数量 = 读取结构数量(无效参数上下文);
        auto 错版本 = 无效基准参数;
        错版本.清单版本 = 系统角色清单当前版本 + 1;
        auto 零键 = 无效基准参数;
        零键.世界根主键 = 0;
        auto 重复键 = 无效基准参数;
        重复键.自我场景主键 = 重复键.世界根主键;
        auto 错值域 = 无效基准参数;
        错值域.安全目标值 = 错值域.安全当前值;
        const std::array 无效参数组{错版本, 零键, 重复键, 错值域};
        bool 全部写前拒绝 = true;
        for (const auto& 参数 : 无效参数组) {
            const auto 结果 = 无效参数上下文.初始化系统角色(参数);
            全部写前拒绝 = 全部写前拒绝
                && !结果.成功() && 结果.状态 == 系统角色业务状态::入口拒绝;
        }
        验收[1] = 全部写前拒绝
            && 读取结构数量(无效参数上下文) == 无效前数量
            && !无效参数上下文.读取系统角色材料().has_value();

        const auto 主参数 = 形成参数(0x0690'2000'0000'0000ULL);
        auto 主上下文 = std::make_shared<运行期上下文>(6902, 6902);
        运行期上下文宿主 主宿主;
        const bool 初始化前不完整 = !主上下文->完整()
            && !主上下文->系统角色完整()
            && 主宿主.尝试首次发布全新上下文(主上下文)
                == 运行期上下文发布状态::缺少初始化完成材料;
        const auto 首次结果 = 主上下文->初始化系统角色(主参数);
        const auto 首次后数量 = 读取结构数量(*主上下文);
        const auto 首次清单 = 主上下文->读取系统角色材料();
        std::cout << "INIT-MOD-S1-EVIDENCE first-status="
            << static_cast<unsigned>(首次结果.状态)
            << " nodes=" << 首次后数量.节点
            << " relations=" << 首次后数量.关系
            << " keys=" << 首次后数量.主键 << '\n';
        {
            auto 许可 = 主上下文->读取接线().取得共享许可(
                主上下文->读取接线().运行期状态);
            if (许可.有效()) {
                const auto& 令牌 = 许可.读取令牌();
                const auto 场景 = 主上下文->读取索引仓库().按主键查节点(
                    主参数.自我场景主键, 令牌);
                const auto 自我 = 主上下文->读取索引仓库().按主键查节点(
                    主参数.自我存在主键, 令牌);
                const auto 场景父组 = 场景.has_value()
                    ? 主上下文->读取关系仓库().获取来源关系记录组(
                        *场景, 关系类型::普通父子, 令牌)
                    : std::vector<关系记录>{};
                const auto 自我父组 = 自我.has_value()
                    ? 主上下文->读取关系仓库().获取来源关系记录组(
                        *自我, 关系类型::普通父子, 令牌)
                    : std::vector<关系记录>{};
                const auto 方法根 = 主上下文->读取索引仓库().按主键查节点(
                    主参数.方法登记根主键, 令牌);
                const auto 方法模板组 = 方法根.has_value()
                    ? 主上下文->读取关系仓库().获取关系记录组(
                        *方法根, 关系类型::模板, 令牌)
                    : std::vector<关系记录>{};
                const auto 自我引用组 = 自我.has_value()
                    ? 主上下文->读取关系仓库().获取关系记录组(
                        *自我, 关系类型::引用, 令牌)
                    : std::vector<关系记录>{};
                std::cout << "INIT-MOD-S1-EVIDENCE parent-counts="
                    << 场景父组.size() << ',' << 自我父组.size()
                    << " method-templates=" << 方法模板组.size();
                for (const auto& 记录 : 场景父组) {
                    std::cout << " scene-source=" << 记录.源节点.节点编号;
                }
                for (const auto& 记录 : 自我父组) {
                    std::cout << " self-source=" << 记录.源节点.节点编号;
                }
                for (const auto& 记录 : 方法模板组) {
                    std::cout << " method-slot=" << 记录.顺序号
                        << ':' << 记录.目标节点.节点编号;
                }
                for (const auto& 记录 : 自我引用组) {
                    const auto 目标 = 主上下文->读取节点仓库().读取节点(
                        记录.目标节点, 令牌);
                    std::cout << " self-ref=" << 记录.目标节点.节点编号
                        << ':' << (目标.has_value()
                            ? static_cast<unsigned>(目标->类型) : 255U);
                }
                std::cout << '\n';
            }
        }

        验收[0] = 主上下文->结构核心完整() && 主上下文->服务装配完整()
            && 主上下文->读取候选业务操作() != nullptr;
        验收[2] = 首次结果.成功() && 首次结果.改变了结构()
            && 首次清单.has_value();
        if (首次清单.has_value()) {
            const auto& 清单 = *首次清单;
            const auto& 主体 = 清单.主体;
            验收[3] = 身份类型匹配(
                    主体.世界根, 系统角色稳定键用途::世界根, 节点类型::基础信息)
                && 身份类型匹配(
                    主体.自我场景, 系统角色稳定键用途::自我场景, 节点类型::场景)
                && 身份类型匹配(
                    主体.自我存在, 系统角色稳定键用途::自我存在, 节点类型::存在)
                && 主体.场景接纳自我关系.源节点 == 主体.自我场景.节点
                && 主体.场景接纳自我关系.目标节点 == 主体.自我存在.节点;
            验收[4] = 身份类型匹配(
                    主体.安全根需求.特征定义,
                    系统角色稳定键用途::安全特征定义, 节点类型::特征)
                && 身份类型匹配(
                    主体.安全根需求.实例槽位,
                    系统角色稳定键用途::安全实例槽位, 节点类型::特征)
                && 身份类型匹配(
                    主体.安全根需求.当前特征值,
                    系统角色稳定键用途::安全当前特征值, 节点类型::特征值)
                && 身份类型匹配(
                    主体.安全根需求.目标状态,
                    系统角色稳定键用途::安全目标状态, 节点类型::状态)
                && 身份类型匹配(
                    主体.安全根需求.根需求,
                    系统角色稳定键用途::安全根需求, 节点类型::需求)
                && 身份类型匹配(
                    主体.服务根需求.特征定义,
                    系统角色稳定键用途::服务特征定义, 节点类型::特征)
                && 身份类型匹配(
                    主体.服务根需求.实例槽位,
                    系统角色稳定键用途::服务实例槽位, 节点类型::特征)
                && 身份类型匹配(
                    主体.服务根需求.当前特征值,
                    系统角色稳定键用途::服务当前特征值, 节点类型::特征值)
                && 身份类型匹配(
                    主体.服务根需求.目标状态,
                    系统角色稳定键用途::服务目标状态, 节点类型::状态)
                && 身份类型匹配(
                    主体.服务根需求.根需求,
                    系统角色稳定键用途::服务根需求, 节点类型::需求)
                && 主体.安全根需求.当前值 == 主参数.安全当前值
                && 主体.安全根需求.目标值 == 主参数.安全目标值
                && 主体.服务根需求.当前值 == 主参数.服务当前值
                && 主体.服务根需求.目标值 == 主参数.服务目标值;
            验收[5] = 身份类型匹配(
                    主体.概念存在根, 系统角色稳定键用途::概念存在根, 节点类型::存在)
                && 身份类型匹配(
                    主体.概念动态根, 系统角色稳定键用途::概念动态根, 节点类型::动态)
                && 身份类型匹配(
                    主体.概念关系根, 系统角色稳定键用途::概念关系根, 节点类型::二次特征)
                && 身份类型匹配(
                    主体.概念因果根, 系统角色稳定键用途::概念因果根, 节点类型::因果引用)
                && 主体.动态根材料 == 主参数.动态根材料;
            验收[6] = 身份类型匹配(
                    主体.方法登记根, 系统角色稳定键用途::方法登记根, 节点类型::方法)
                && 身份类型匹配(
                    主体.方法登记角色状态,
                    系统角色稳定键用途::方法登记角色状态, 节点类型::状态)
                && 身份类型匹配(
                    主体.方法活跃状态,
                    系统角色稳定键用途::方法活跃状态, 节点类型::状态)
                && 身份类型匹配(
                    主体.方法失效状态,
                    系统角色稳定键用途::方法失效状态, 节点类型::状态);
            验收[7] = 关系精确可读(*主上下文, 主体.场景接纳自我关系)
                && 关系精确可读(*主上下文, 清单.世界根到场景关系)
                && 关系精确可读(*主上下文, 清单.场景到自我关系);
            const auto 身份组 = 主体.读取身份组();
            bool 用途连续且唯一 = 身份组.size() == 系统角色稳定键数量;
            for (std::size_t 索引 = 0; 索引 < 身份组.size(); ++索引) {
                用途连续且唯一 = 用途连续且唯一 && 身份组[索引] != nullptr
                    && static_cast<std::uint8_t>(身份组[索引]->用途) == 索引 + 1;
            }
            验收[8] = 清单.完整() && 清单.匹配参数(主参数)
                && 全部稳定键可读(*主上下文, 主参数) && 用途连续且唯一;
            验收[19] = 用途连续且唯一;
        }

        const auto 重复结果 = 主上下文->初始化系统角色(主参数);
        验收[9] = 重复结果.成功() && !重复结果.改变了结构()
            && 首次清单.has_value() && 重复结果.清单 == *首次清单
            && 读取结构数量(*主上下文) == 首次后数量;

        运行期上下文 错类型上下文(6903, 6903);
        const auto 错类型参数 = 形成参数(0x0690'3000'0000'0000ULL);
        节点句柄 错类型节点;
        const bool 错类型已种入 = 创建夹具节点(
            错类型上下文, 节点类型::状态, 错类型参数.世界根主键, 错类型节点);
        const auto 错类型前数量 = 读取结构数量(错类型上下文);
        const auto 错类型结果 = 错类型上下文.初始化系统角色(错类型参数);
        std::cout << "INIT-MOD-S1-EVIDENCE conflict-status="
            << static_cast<unsigned>(错类型结果.状态) << '\n';
        验收[10] = 错类型已种入 && !错类型结果.成功()
            && 错类型结果.状态 == 系统角色业务状态::幂等冲突
            && 读取结构数量(错类型上下文) == 错类型前数量
            && !错类型上下文.读取系统角色材料().has_value();

        运行期上下文 并发上下文(6904, 6904);
        const auto 并发参数 = 形成参数(0x0690'4000'0000'0000ULL);
        std::array<系统角色初始化结果, 2> 并发结果{};
        std::atomic<bool> 同时开始{false};
        std::array<std::thread, 2> 线程{
            std::thread([&] {
                while (!同时开始.load(std::memory_order_acquire)) std::this_thread::yield();
                try { 并发结果[0] = 并发上下文.初始化系统角色(并发参数); } catch (...) {}
            }),
            std::thread([&] {
                while (!同时开始.load(std::memory_order_acquire)) std::this_thread::yield();
                try { 并发结果[1] = 并发上下文.初始化系统角色(并发参数); } catch (...) {}
            })};
        同时开始.store(true, std::memory_order_release);
        for (auto& 线程项 : 线程) 线程项.join();
        const auto 并发清单 = 并发上下文.读取系统角色材料();
        std::cout << "INIT-MOD-S1-EVIDENCE concurrent-status="
            << static_cast<unsigned>(并发结果[0].状态) << ','
            << static_cast<unsigned>(并发结果[1].状态) << '\n';
        const auto 改变次数 = static_cast<std::size_t>(并发结果[0].改变了结构())
            + static_cast<std::size_t>(并发结果[1].改变了结构());
        验收[11] = 并发结果[0].成功() && 并发结果[1].成功()
            && 并发结果[0].清单 == 并发结果[1].清单
            && 改变次数 == 1 && 并发清单.has_value()
            && *并发清单 == 并发结果[0].清单
            && 全部稳定键可读(并发上下文, 并发参数);

        运行期上下文 后继失败上下文(6905, 6905);
        const auto 后继失败参数 = 形成参数(0x0690'5000'0000'0000ULL);
        节点句柄 错父节点;
        节点句柄 预建场景;
        关系句柄 错父关系;
        const bool 错父夹具已形成 = 创建夹具节点(
                后继失败上下文, 节点类型::基础信息,
                0x0690'5000'0000'0100ULL, 错父节点)
            && 创建夹具节点(
                后继失败上下文, 节点类型::场景,
                后继失败参数.自我场景主键, 预建场景)
            && 挂载夹具节点(后继失败上下文, 预建场景, 错父节点, 错父关系);
        const auto 后继失败前数量 = 读取结构数量(后继失败上下文);
        const auto 后继失败结果 = 后继失败上下文.初始化系统角色(后继失败参数);
        const auto 后继失败后数量 = 读取结构数量(后继失败上下文);
        std::cout << "INIT-MOD-S1-EVIDENCE closure-status="
            << static_cast<unsigned>(后继失败结果.状态)
            << " nodes=" << 后继失败前数量.节点 << "->" << 后继失败后数量.节点
            << " relations=" << 后继失败前数量.关系 << "->" << 后继失败后数量.关系
            << " keys=" << 后继失败前数量.主键 << "->" << 后继失败后数量.主键 << '\n';
        验收[12] = 错父夹具已形成 && !后继失败结果.成功()
            && 后继失败结果.状态 == 系统角色业务状态::幂等冲突
            && !后继失败上下文.读取系统角色材料().has_value()
            && !后继失败上下文.完整()
            && 后继失败后数量.节点 > 后继失败前数量.节点
            && 后继失败后数量.主键 > 后继失败前数量.主键
            && 全部稳定键可读(后继失败上下文, 后继失败参数);

        验收[13] = 初始化前不完整 && 主上下文->完整()
            && 主上下文->系统角色完整() && 首次清单.has_value();
        const auto 发布状态 = 主宿主.尝试首次发布全新上下文(主上下文);
        const auto 首次租约 = 主宿主.读取租约();
        验收[14] = 发布状态 == 运行期上下文发布状态::已发布
            && !主宿主.为空() && 首次租约.有效()
            && 首次租约.读取() == 主上下文.get();
        验收[15] = 首次结果.成功() && 首次清单.has_value();
        验收[16] = true;
        验收[17] = true;
        验收[18] = 历史兼容回归通过;
        验收[20] = 历史兼容回归通过
            && std::all_of(验收.begin(), 验收.begin() + 20, [](bool 通过) { return 通过; });
        验收[21] = 验收[20];
    } catch (...) {
    }

    std::size_t 失败数量 = 0;
    for (std::size_t 索引 = 0; 索引 < 验收.size(); ++索引) {
        if (!验收[索引]) ++失败数量;
        std::cout << "INIT-MOD-S1-A" << (索引 + 1) << ": "
            << (验收[索引] ? "通过" : "失败") << '\n';
    }
    return {
        "INIT-MOD-S1", "系统角色初始化与历史兼容模块迁移",
        失败数量 == 0, 验收.size(), 失败数量};
}

}
#endif
