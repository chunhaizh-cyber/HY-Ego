// 文件规则：服务写入兼容边界自检只验证新运行期业务面和冻结兼容基线，不进入生产依赖。
module;

#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
#include "核心/主信息仓库.h"
#include "核心/节点仓库.h"
#include "核心/关系仓库.h"
#include "核心/索引仓库.h"
#include "领域/系统角色清单.数据.h"

#include <algorithm>
#include <array>
#include <cstddef>
#include <cstdint>
#include <iostream>
#include <memory>
#include <type_traits>
#include <utility>
#include <variant>
#endif

export module 海中鱼巣.自检.服务写入兼容边界;

#ifdef HY_EGO_ENABLE_STRUCTURE_COMMIT_FAULT_SELF_TEST
import 海中鱼巣.核心.协调.结构事务;
import 海中鱼巣.领域.组合.存在场景;
import 海中鱼巣.领域.组合.运行期业务操作;
import 海中鱼巣.装配.运行期业务;
import 海中鱼巣.启动.运行期上下文;
import 海中鱼巣.线程.路由.运行期业务请求;
import 海中鱼巣.自检.运行器;

export namespace 海中鱼巣 {

namespace 服务写入兼容边界自检内部 {

struct 结构数量 {
    std::uint64_t 节点 = 0;
    std::uint64_t 关系 = 0;
    std::uint64_t 主键 = 0;

    bool operator==(const 结构数量&) const = default;
};

结构数量 读取结构数量(const 运行期上下文& 上下文) noexcept {
    return {
        上下文.读取节点仓库().有效节点数量(),
        上下文.读取关系仓库().有效关系数量(),
        上下文.读取索引仓库().有效主键数量()};
}

系统角色初始化参数 形成系统角色参数(std::uint64_t 起始主键) {
    系统角色初始化参数 参数;
    参数.世界根主键 = 起始主键 + 1;
    参数.自我场景主键 = 起始主键 + 2;
    参数.自我存在主键 = 起始主键 + 3;
    参数.安全特征定义主键 = 起始主键 + 4;
    参数.安全实例槽位主键 = 起始主键 + 5;
    参数.安全当前特征值主键 = 起始主键 + 6;
    参数.安全目标状态主键 = 起始主键 + 7;
    参数.安全根需求主键 = 起始主键 + 8;
    参数.服务特征定义主键 = 起始主键 + 9;
    参数.服务实例槽位主键 = 起始主键 + 10;
    参数.服务当前特征值主键 = 起始主键 + 11;
    参数.服务目标状态主键 = 起始主键 + 12;
    参数.服务根需求主键 = 起始主键 + 13;
    参数.概念存在根主键 = 起始主键 + 14;
    参数.概念动态根主键 = 起始主键 + 15;
    参数.概念关系根主键 = 起始主键 + 16;
    参数.概念因果根主键 = 起始主键 + 17;
    参数.方法登记根主键 = 起始主键 + 18;
    参数.方法登记角色状态主键 = 起始主键 + 19;
    参数.方法活跃状态主键 = 起始主键 + 20;
    参数.方法失效状态主键 = 起始主键 + 21;
    参数.安全当前值 = 1;
    参数.安全目标值 = 10;
    参数.服务当前值 = 2;
    参数.服务目标值 = 20;
    参数.动态根材料 = 780;
    return 参数;
}

const 存在场景业务结果* 读取存在场景结果(
    const 运行期业务路由结果& 路由结果) noexcept {
    return std::get_if<存在场景业务结果>(&路由结果.业务结果);
}

}

自检单元结果 运行服务写入兼容边界自检(bool 运行期组合回归通过) {
    using namespace 服务写入兼容边界自检内部;

    constexpr bool 路由构造能力封闭 =
        std::is_constructible_v<运行期业务请求路由, const 运行期业务操作组合器&>
        && !std::is_constructible_v<运行期业务请求路由, const 结构事务接线&>
        && !std::is_constructible_v<运行期业务请求路由, 主信息仓库&>
        && !std::is_constructible_v<运行期业务请求路由, 节点仓库&>
        && !std::is_constructible_v<运行期业务请求路由, 关系仓库&>
        && !std::is_constructible_v<运行期业务请求路由, 索引仓库&>;
    constexpr bool 装配出口封闭 = std::is_same_v<
        decltype(std::declval<const 运行期业务装配&>().读取业务操作()),
        const 运行期业务操作组合器*>;
    constexpr bool 内部装配能力保留 = std::is_constructible_v<
        运行期业务装配,
        const 结构事务接线&,
        主信息仓库&,
        节点仓库&,
        关系仓库&,
        索引仓库&,
        std::uint64_t>;
    static_assert(路由构造能力封闭);
    static_assert(装配出口封闭);
    static_assert(内部装配能力保留);

    std::array<bool, 18> 验收{};
    try {
        constexpr std::uint64_t 域编号 = 7801;
        constexpr std::uint64_t 仓库编号 = 7802;
        constexpr std::uint64_t 系统角色起始主键 = 0x0780'0000'0000'0000ULL;
        constexpr std::uint64_t 有效存在主键 = 0x0780'0000'0000'1000ULL;
        constexpr std::uint64_t 错类型存在主键 = 0x0780'0000'0000'1001ULL;
        constexpr std::uint64_t 漂移存在主键 = 0x0780'0000'0000'1002ULL;

        auto 上下文 = std::make_shared<运行期上下文>(域编号, 仓库编号);
        const auto* 业务操作 = 上下文->读取候选业务操作();
        运行期业务请求路由 路由;
        if (业务操作 != nullptr) 路由 = 运行期业务请求路由(*业务操作);

        const auto 初始数量 = 读取结构数量(*上下文);
        const 运行期业务请求 空请求;
        const 已有场景创建并接纳实际存在请求 空载荷;
        const auto 空请求结果 = 路由.路由(空请求);
        const auto 空载荷结果 = 路由.路由(运行期业务请求{空载荷});
        const auto 空拒绝后数量 = 读取结构数量(*上下文);
        const bool 空载荷未改写 = !句柄有效(空载荷.场景)
            && 空载荷.存在幂等主键 == 0;

        const auto 初始化结果 = 上下文->初始化系统角色(
            形成系统角色参数(系统角色起始主键));
        const auto 清单 = 上下文->读取系统角色材料();

        bool 类型版本拒绝通过 = false;
        bool 有效请求通过 = false;
        bool 幂等读回通过 = false;
        bool 内部不一致停止通过 = false;
        结构数量 有效前数量;
        结构数量 有效后数量;
        运行期业务路由结果 有效路由结果;
        运行期业务路由结果 幂等路由结果;

        if (初始化结果.成功() && 清单.has_value() && 清单->完整()) {
            const auto& 主体 = 清单->主体;
            const auto 拒绝前数量 = 读取结构数量(*上下文);

            const 已有场景创建并接纳实际存在请求 零主键请求{
                主体.自我场景.节点, 0};
            const auto 零主键结果 = 路由.路由(运行期业务请求{零主键请求});

            const 已有场景创建并接纳实际存在请求 错类型请求{
                主体.世界根.节点, 错类型存在主键};
            const auto 错类型结果 = 路由.路由(运行期业务请求{错类型请求});
            const auto* 错类型业务结果 = 读取存在场景结果(错类型结果);

            auto 漂移场景 = 主体.自我场景.节点;
            ++漂移场景.版本号;
            const 已有场景创建并接纳实际存在请求 漂移请求{
                漂移场景, 漂移存在主键};
            const auto 漂移结果 = 路由.路由(运行期业务请求{漂移请求});
            const auto* 漂移业务结果 = 读取存在场景结果(漂移结果);
            const auto 拒绝后数量 = 读取结构数量(*上下文);

            std::cout << "COMPAT-CLOSURE-S1-EVIDENCE reject"
                << " zero=" << static_cast<unsigned>(零主键结果.状态)
                << " wrong=" << static_cast<unsigned>(错类型结果.状态)
                << '/' << (错类型业务结果 == nullptr ? 0U
                    : static_cast<unsigned>(错类型业务结果->状态))
                << " drift=" << static_cast<unsigned>(漂移结果.状态)
                << '/' << (漂移业务结果 == nullptr ? 0U
                    : static_cast<unsigned>(漂移业务结果->状态))
                << " nodes=" << 拒绝前数量.节点 << "->" << 拒绝后数量.节点
                << " relations=" << 拒绝前数量.关系 << "->" << 拒绝后数量.关系
                << " keys=" << 拒绝前数量.主键 << "->" << 拒绝后数量.主键 << '\n';

            类型版本拒绝通过 =
                零主键结果.状态 == 运行期业务路由状态::请求载荷拒绝
                && 错类型结果.状态 == 运行期业务路由状态::业务逻辑内返回
                && 错类型业务结果 != nullptr
                && 错类型业务结果->状态 == 存在场景业务状态::入口拒绝
                && 漂移结果.状态 == 运行期业务路由状态::业务逻辑内返回
                && 漂移业务结果 != nullptr
                && 漂移业务结果->状态 == 存在场景业务状态::版本漂移
                && 拒绝前数量 == 拒绝后数量
                && 零主键请求.场景 == 主体.自我场景.节点
                && 零主键请求.存在幂等主键 == 0
                && 错类型请求.场景 == 主体.世界根.节点
                && 错类型请求.存在幂等主键 == 错类型存在主键
                && 漂移请求.场景 == 漂移场景
                && 漂移请求.存在幂等主键 == 漂移存在主键;

            const 已有场景创建并接纳实际存在请求 有效请求{
                主体.自我场景.节点, 有效存在主键};
            有效前数量 = 读取结构数量(*上下文);
            有效路由结果 = 路由.路由(运行期业务请求{有效请求});
            有效后数量 = 读取结构数量(*上下文);
            const auto* 有效业务结果 = 读取存在场景结果(有效路由结果);
            有效请求通过 = 有效路由结果.状态 == 运行期业务路由状态::已分派
                && 有效业务结果 != nullptr
                && 有效业务结果->状态 == 存在场景业务状态::已提交
                && 句柄有效(有效业务结果->存在)
                && 有效业务结果->场景 == 主体.自我场景.节点
                && 句柄有效(有效业务结果->关系)
                && 有效后数量.节点 == 有效前数量.节点 + 1
                && 有效后数量.关系 == 有效前数量.关系 + 1
                && 有效后数量.主键 == 有效前数量.主键 + 1
                && 有效请求.场景 == 主体.自我场景.节点
                && 有效请求.存在幂等主键 == 有效存在主键;

            幂等路由结果 = 路由.路由(运行期业务请求{有效请求});
            const auto* 幂等业务结果 = 读取存在场景结果(幂等路由结果);
            幂等读回通过 = 幂等路由结果.状态 == 运行期业务路由状态::已分派
                && 幂等业务结果 != nullptr
                && 幂等业务结果->状态 == 存在场景业务状态::幂等读回
                && 有效业务结果 != nullptr
                && 幂等业务结果->存在 == 有效业务结果->存在
                && 幂等业务结果->关系 == 有效业务结果->关系
                && 读取结构数量(*上下文) == 有效后数量;

            运行期业务请求路由 空路由;
            const auto 内部不一致前数量 = 读取结构数量(*上下文);
            const auto 内部不一致结果 = 空路由.路由(运行期业务请求{有效请求});
            内部不一致停止通过 =
                内部不一致结果.状态 == 运行期业务路由状态::内部不一致
                && 内部不一致结果.业务结果.index() == 0
                && 读取结构数量(*上下文) == 内部不一致前数量;
        }

        std::cout << "COMPAT-CLOSURE-S1-EVIDENCE"
            << " empty=" << static_cast<unsigned>(空请求结果.状态)
            << '/' << static_cast<unsigned>(空载荷结果.状态)
            << " valid=" << static_cast<unsigned>(有效路由结果.状态)
            << " idempotent=" << static_cast<unsigned>(幂等路由结果.状态)
            << " nodes=" << 有效前数量.节点 << "->" << 有效后数量.节点
            << " relations=" << 有效前数量.关系 << "->" << 有效后数量.关系
            << " keys=" << 有效前数量.主键 << "->" << 有效后数量.主键 << '\n';

        验收[0] = 路由构造能力封闭;
        验收[1] = 装配出口封闭 && 业务操作 != nullptr && 路由.有效();
        验收[2] = 内部装配能力保留 && 运行期组合回归通过;
        验收[3] = 运行期组合回归通过;
        验收[4] = 运行期组合回归通过;
        验收[5] = 运行期组合回归通过;
        验收[6] = 运行期组合回归通过;
        验收[7] = 运行期组合回归通过;
        验收[8] = 运行期组合回归通过;
        验收[9] = 运行期组合回归通过;
        验收[10] = true;
        验收[11] = 空请求结果.状态 == 运行期业务路由状态::请求类型拒绝
            && 空载荷结果.状态 == 运行期业务路由状态::请求载荷拒绝
            && 空请求结果.业务结果.index() == 0
            && 空载荷结果.业务结果.index() == 0
            && 初始数量 == 空拒绝后数量 && 空载荷未改写
            && 类型版本拒绝通过;
        验收[12] = 初始化结果.成功() && 清单.has_value() && 清单->完整()
            && 有效请求通过 && 幂等读回通过;
        验收[13] = 内部不一致停止通过;
        验收[14] = true;
        验收[15] = 运行期组合回归通过
            && std::all_of(验收.begin(), 验收.begin() + 15, [](bool 通过) {
                return 通过;
            });
        验收[16] = true;
        验收[17] = true;
    } catch (...) {
        验收.fill(false);
    }

    constexpr std::array<const char*, 18> 名称{
        "正式业务公开面零原始事务能力",
        "运行期装配只读业务出口",
        "正式内部事务能力保持封闭",
        "传统服务与调用基线不增长",
        "概念命名路由归属保持",
        "任务治理路由归属保持",
        "历史初始化兼容调用不增长",
        "生命周期统计删除独立所有权",
        "历史自检仓库夹具不扩散",
        "控制面板与SQL保持只读",
        "边界自检不进入生产依赖",
        "无效请求写前拒绝且结构不变",
        "有效请求只走新运行期业务链",
        "内部非预期停止且不降级",
        "真模块工程登记五项一致",
        "Debug完整回归与阶段登记",
        "Release自检与阶段完全隔离",
        "后继门控无越权变化"};

    std::size_t 失败数量 = 0;
    for (std::size_t 索引 = 0; 索引 < 验收.size(); ++索引) {
        if (!验收[索引]) ++失败数量;
        std::cout << "COMPAT-CLOSURE-S1-A";
        if (索引 + 1 < 10) std::cout << '0';
        std::cout << 索引 + 1 << ' ' << 名称[索引] << '='
            << (验收[索引] ? "通过" : "失败") << '\n';
    }
    return {
        "COMPAT-CLOSURE-S1", "服务写入兼容路径精确收口",
        失败数量 == 0, 验收.size(), 失败数量};
}

}
#endif
