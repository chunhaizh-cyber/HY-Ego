module;
#include <algorithm>
#include <cstdint>
#include <limits>
#include <string>
#include <vector>

export module 自我本能方法_学习兜底模块;


import 基础数据类型模块;
import 主信息定义模块;
import 本能动作管理模块;
import 方法环境模块;
import 任务模块;
import 状态模块;
import 动态模块;
import 因果信息模块;
import 世界树环境模块;
import 语素环境模块;
import 日志模块;
import 原生学习兜底函数定义模块_v0;

export class 自我本能方法类_学习兜底模块 {
private:
    static inline 时间戳 当前_微秒() noexcept { return 结构体_时间戳::当前_微秒(); }

    struct 结构_学习词性缓存
    {
        const 词性节点类* 学习局部结果有效 = nullptr;
        const 词性节点类* 学习动作ID = nullptr;
        const 词性节点类* 学习回滚标记 = nullptr;
        const 词性节点类* 学习预算细分 = nullptr;
        const 词性节点类* 学习预算路径 = nullptr;
        const 词性节点类* 学习预算回退 = nullptr;
        const 词性节点类* 学习预算检查 = nullptr;
    };

    static inline 结构_学习词性缓存 g_学习词性{};

    static void 私有_初始化学习词性()
    {
        if (g_学习词性.学习局部结果有效) return;
        g_学习词性.学习局部结果有效 = 语素集.添加词性词("学习兜底_局部结果有效", "名词");
        g_学习词性.学习动作ID = 语素集.添加词性词("学习兜底_动作ID", "名词");
        g_学习词性.学习回滚标记 = 语素集.添加词性词("学习兜底_已回滚", "名词");
        g_学习词性.学习预算细分 = 语素集.添加词性词("学习兜底_预算_细分", "名词");
        g_学习词性.学习预算路径 = 语素集.添加词性词("学习兜底_预算_路径", "名词");
        g_学习词性.学习预算回退 = 语素集.添加词性词("学习兜底_预算_回退", "名词");
        g_学习词性.学习预算检查 = 语素集.添加词性词("学习兜底_预算_检查", "名词");
    }

    static std::string 私有_拼调用点(
        const 结构_兜底学习上下文& 上下文,
        std::string_view 后缀)
    {
        if (上下文.调用点.empty()) {
            return std::string("自我本能方法类_学习兜底模块::") + std::string(后缀);
        }
        return 上下文.调用点 + "/" + std::string(后缀);
    }

    static 任务头结点信息* 私有_取任务头信息(const 结构_兜底学习上下文& 上下文) noexcept
    {
        return (上下文.当前任务头结点 && 上下文.当前任务头结点->主信息)
            ? dynamic_cast<任务头结点信息*>(上下文.当前任务头结点->主信息)
            : nullptr;
    }

    static 任务步骤节点信息* 私有_取步骤信息(const 结构_兜底学习上下文& 上下文) noexcept
    {
        return (上下文.当前步骤节点 && 上下文.当前步骤节点->主信息)
            ? dynamic_cast<任务步骤节点信息*>(上下文.当前步骤节点->主信息)
            : nullptr;
    }

    static 任务结果节点信息* 私有_取结果信息(const 结构_兜底学习上下文& 上下文) noexcept
    {
        return (上下文.当前结果节点 && 上下文.当前结果节点->主信息)
            ? dynamic_cast<任务结果节点信息*>(上下文.当前结果节点->主信息)
            : nullptr;
    }

    static 任务信息基类* 私有_取任务主信息(任务节点类* 节点) noexcept
    {
        return (节点 && 节点->主信息)
            ? dynamic_cast<任务信息基类*>(节点->主信息)
            : nullptr;
    }

    static 存在节点类* 私有_取任务虚拟存在(const 结构_兜底学习上下文& 上下文) noexcept
    {
        if (上下文.任务虚拟存在) {
            return 上下文.任务虚拟存在;
        }
        if (auto* 任务主信息 = 私有_取任务主信息(上下文.当前步骤节点)) {
            if (任务主信息->任务虚拟存在) return 任务主信息->任务虚拟存在;
        }
        if (auto* 任务主信息 = 私有_取任务主信息(上下文.当前任务头结点)) {
            return 任务主信息->任务虚拟存在;
        }
        return nullptr;
    }

    static 方法首节点主信息类* 私有_取方法头信息(方法节点类* 方法首节点) noexcept
    {
        return (方法首节点 && 方法首节点->主信息)
            ? dynamic_cast<方法首节点主信息类*>(方法首节点->主信息)
            : nullptr;
    }

    static bool 私有_动作句柄可试探(const 结构体_动作句柄& 动作句柄) noexcept
    {
        if (动作句柄.类型 != 枚举_动作句柄类型::本能函数ID) return false;
    if (动作句柄.本能ID == 0) return false;
    return 本能集.有(static_cast<枚举_本能动作ID>(动作句柄.本能ID));
    }

    static 结构体_动作句柄 私有_提取动作句柄(方法节点类* 方法首节点)
    {
        auto* hmi = (方法首节点 && 方法首节点->主信息)
            ? dynamic_cast<方法首节点主信息类*>(方法首节点->主信息)
            : nullptr;
        return hmi ? hmi->动作句柄 : 结构体_动作句柄{};
    }

    static bool 私有_方法可试探(方法节点类* 方法首节点)
    {
        return 私有_动作句柄可试探(私有_提取动作句柄(方法首节点));
    }

    static void 私有_追加方法首节点(
        std::vector<方法节点类*>& 输出,
        方法节点类* 方法首节点,
        时间戳 now,
        const std::string& 调用点)
    {
        if (!方法首节点 || !私有_方法可试探(方法首节点)) return;
        if (std::find(输出.begin(), 输出.end(), 方法首节点) != 输出.end()) return;
        方法集.初始化方法虚拟存在信息(方法首节点, now, 调用点);
        输出.push_back(方法首节点);
    }

    static void 私有_追加任务节点(
        std::vector<任务节点类*>& 输出,
        任务节点类* 任务节点)
    {
        if (!任务节点) return;
        if (std::find(输出.begin(), 输出.end(), 任务节点) == 输出.end()) {
            输出.push_back(任务节点);
        }
    }

    static 任务节点类* 私有_查找首个步骤节点(任务节点类* 任务头结点) noexcept
    {
        if (!任务头结点 || !任务头结点->子) return nullptr;
        auto* 起点 = static_cast<任务节点类*>(任务头结点->子);
        auto* 当前 = 起点;
        do {
            if (当前 && 当前->主信息 && dynamic_cast<任务步骤节点信息*>(当前->主信息)) {
                return 当前;
            }
            当前 = 当前 ? static_cast<任务节点类*>(当前->下) : nullptr;
        } while (当前 && 当前 != 起点);
        return nullptr;
    }

    static 任务节点类* 私有_确保最小步骤节点(
        const 结构_兜底学习上下文& 上下文,
        const std::string& 调用点)
    {
        if (上下文.当前步骤节点 && 私有_取步骤信息(上下文)) {
            return 上下文.当前步骤节点;
        }

        auto* 步骤节点 = 私有_查找首个步骤节点(上下文.当前任务头结点);
        if (步骤节点) {
            return 步骤节点;
        }
        if (!上下文.当前任务头结点) {
            return nullptr;
        }

        任务类::结构_创建步骤参数 参数{};
        参数.所属任务头结点 = 上下文.当前任务头结点;
        参数.步骤场景 = 上下文.当前场景;
        参数.初始状态 = 枚举_任务状态::就绪;
        参数.允许重试次数 = static_cast<std::int32_t>(std::clamp<I64>(上下文.当前回退预算, 0, 3));
        参数.允许切换方法 = true;
        return 任务类::创建步骤节点(
            上下文.当前任务头结点,
            参数,
            调用点 + "/创建最小步骤");
    }

    static 任务节点类* 私有_确保结果节点(
        const 结构_兜底学习上下文& 上下文,
        任务节点类* 步骤节点,
        方法节点类* 来源方法首节点,
        const std::string& 调用点)
    {
        if (上下文.当前结果节点 && 私有_取结果信息(上下文)) {
            return 上下文.当前结果节点;
        }
        if (!步骤节点) return nullptr;

        任务类::结构_创建结果参数 参数{};
        参数.所属任务头结点 = 上下文.当前任务头结点;
        参数.结果角色 = 枚举_任务结果角色::实际结果;
        参数.结果场景 = 上下文.当前场景;
        参数.来源方法首节点 = 来源方法首节点;
        参数.初始状态 = 枚举_任务状态::就绪;
        return 任务类::创建结果节点(
            步骤节点,
            参数,
            调用点 + "/创建结果节点");
    }

    static 存在节点类* 私有_归一动作主体(const 结构_兜底学习上下文& 上下文) noexcept
    {
        if (上下文.方法虚拟存在根) return 上下文.方法虚拟存在根;
        if (auto* 方法头信息 = 私有_取方法头信息(上下文.当前方法首节点)) {
            if (方法头信息->方法虚拟存在根) {
                return 方法头信息->方法虚拟存在根;
            }
        }
        if (auto* 任务存在 = 私有_取任务虚拟存在(上下文)) {
            return 任务存在;
        }
        return 世界树.自我指针;
    }

    static 场景节点类* 私有_归一结果场景(
        const 结构_兜底学习上下文& 上下文,
        时间戳 now,
        const std::string& 调用点)
    {
        if (auto* 结果信息 = 私有_取结果信息(上下文)) {
            if (结果信息->场景) return 结果信息->场景;
        }
        if (上下文.当前场景) return 上下文.当前场景;
        return 私有_准备输出场景(上下文, now, 调用点);
    }

    static I64 私有_动作评分(
        const 结构_兜底学习上下文& 上下文,
        const 结构体_动作句柄& 动作句柄) noexcept
    {
        if (!私有_动作句柄可试探(动作句柄)) {
            return (std::numeric_limits<I64>::min)();
        }

        const auto 当前动作句柄 = 私有_提取动作句柄(上下文.当前方法首节点);
        I64 得分 = 0;
        if (当前动作句柄.类型 == 动作句柄.类型
        && 当前动作句柄.本能ID == 动作句柄.本能ID) {
            得分 += 300;
        }

    const auto 本能ID = static_cast<枚举_本能动作ID>(动作句柄.本能ID);
        const bool 风险高 = 上下文.安全值_Q10000 > 0 && 上下文.安全值_Q10000 < 2500;
        const bool 需求紧迫 = 上下文.需求值_Q10000 >= 7000 || 上下文.服务值_Q10000 >= 7000;
        const bool 检查优先 = 上下文.当前检查预算 >= 上下文.当前路径预算;

        switch (本能ID) {
        case 枚举_本能动作ID::自我_停止当前试探并进入保守态:
            得分 += 风险高 ? 500 : 20;
            break;
        case 枚举_本能动作ID::自我_读取核心状态:
            得分 += 风险高 ? 260 : 180;
            break;
        case 枚举_本能动作ID::自我_观察场景:
            得分 += 检查优先 ? 220 : 140;
            break;
        case 枚举_本能动作ID::自我_读取最新人类输入:
            得分 += 需求紧迫 ? 260 : 120;
            break;
        case 枚举_本能动作ID::自我_确认收到:
            得分 += 需求紧迫 ? 240 : 100;
            break;
        case 枚举_本能动作ID::自我_请求补充信息:
            得分 += (需求紧迫 && 上下文.当前路径预算 > 0) ? 280 : 90;
            break;
        case 枚举_本能动作ID::学习_尝试学习:
            得分 += 160;
            break;
        default:
            得分 += 80;
            break;
        }

        得分 += std::clamp<I64>(上下文.当前检查预算, 0, 3) * 10;
        得分 += std::clamp<I64>(上下文.当前路径预算, 0, 3) * 8;
        return 得分;
    }

    static void 私有_追加动作句柄(
        std::vector<结构体_动作句柄>& 输出,
        const 结构体_动作句柄& 动作句柄)
    {
        if (!私有_动作句柄可试探(动作句柄)) return;
        const auto 已存在 = std::find_if(
            输出.begin(),
            输出.end(),
            [&](const 结构体_动作句柄& 已有) {
                return 已有.类型 == 动作句柄.类型
        && 已有.本能ID == 动作句柄.本能ID;
            });
        if (已存在 == 输出.end()) {
            输出.push_back(动作句柄);
        }
    }

    static void 私有_追加本能动作(
        std::vector<结构体_动作句柄>& 输出,
        枚举_本能动作ID 本能动作)
    {
        if (!本能集.有(本能动作)) return;
        私有_追加动作句柄(输出, 构造学习域动作句柄_v0(本能动作));
    }

    static 场景节点类* 私有_准备输出场景(
        const 结构_兜底学习上下文& 上下文,
        时间戳 now,
        const std::string& 调用点)
    {
        if (auto* 结果信息 = 私有_取结果信息(上下文)) {
            if (结果信息->场景) {
                return 结果信息->场景;
            }
        }

        auto* 父场景 = 上下文.当前场景;
        if (!父场景) {
            if (auto* 步骤信息 = 私有_取步骤信息(上下文)) {
                父场景 = 步骤信息->场景;
            }
        }

        auto* 父节点 = 父场景
            ? static_cast<基础信息节点类*>(父场景)
            : static_cast<基础信息节点类*>(世界树.取内部世界() ? 世界树.取内部世界() : 世界树.虚拟世界);
        if (!父节点) return nullptr;

        auto* 场景信息 = new 场景节点主信息类();
        场景信息->名称 = 语素集.添加词性词(std::string("学习兜底输出_") + std::to_string(now), "名词");
        场景信息->类型 = 语素集.添加词性词("学习兜底执行场景", "名词");
        场景信息->最后观测时间 = now;
        auto* 输出场景 = 世界树.创建场景(父节点, 场景信息, 调用点 + "/创建输出场景");
        if (!输出场景) {
            delete 场景信息;
            return nullptr;
        }

        if (auto* 结果信息 = 私有_取结果信息(上下文)) {
            if (!结果信息->场景) {
                结果信息->场景 = 输出场景;
            }
        }
        return 输出场景;
    }

public:
    static bool 判断任务是否缺方法(const 结构_兜底学习上下文& 上下文)
    {
        auto* 步骤信息 = 私有_取步骤信息(上下文);
        if (!步骤信息) return true;

        if (私有_方法可试探(步骤信息->当前选中方法首节点)) {
            return false;
        }

        for (auto* 方法首节点 : 步骤信息->可用方法首节点列表) {
            if (私有_方法可试探(方法首节点)) {
                return false;
            }
        }
        return true;
    }

    static bool 判断是否允许进入兜底学习(const 结构_兜底学习上下文& 上下文)
    {
        auto* 头信息 = 私有_取任务头信息(上下文);
        if (!头信息) return false;
        if (头信息->等待学习唤醒) return false;

        const auto 任务状态 = 头信息->状态;
        if (任务状态 == 枚举_任务状态::完成
            || 任务状态 == 枚举_任务状态::取消
            || 任务状态 == 枚举_任务状态::挂起) {
            return false;
        }

        auto* 步骤信息 = 私有_取步骤信息(上下文);
        if (步骤信息) {
            const bool 重试已耗尽 =
                步骤信息->允许重试次数 > 0
                && 步骤信息->已重试次数 >= 步骤信息->允许重试次数;
            if (重试已耗尽 && !步骤信息->允许切换方法 && 上下文.当前回退预算 <= 0) {
                return false;
            }
        }

        const bool 有预算 =
            上下文.当前细分预算 > 0
            || 上下文.当前路径预算 > 0
            || 上下文.当前回退预算 > 0
            || 上下文.当前检查预算 > 0;
        if (!有预算) return false;

        if (上下文.安全值_Q10000 < 0) return false;
        if (上下文.安全值_Q10000 < 1000 && 上下文.服务值_Q10000 <= 0) return false;

        return true;
    }

    static void 计算本轮学习预算(结构_兜底学习上下文& 上下文)
    {
        私有_初始化学习词性();

        const I64 安全值 = std::clamp<I64>(上下文.安全值_Q10000, 0, 10000);
        const I64 服务值 = std::clamp<I64>(上下文.服务值_Q10000, 0, 10000);
        const I64 需求值 = std::clamp<I64>(上下文.需求值_Q10000, 0, 10000);

        const bool 高风险 = 安全值 < 2500;
        const bool 中风险 = !高风险 && 安全值 < 5000;
        const bool 高需求 = std::max(服务值, 需求值) >= 7000;
        const bool 允许细分 = !高风险 && 需求值 >= 5000;

        上下文.当前检查预算 = std::clamp<I64>(
            std::max<I64>(上下文.当前检查预算, 1 + (高风险 ? 2 : (中风险 ? 1 : 0))),
            0,
            4);
        上下文.当前回退预算 = std::clamp<I64>(
            std::max<I64>(上下文.当前回退预算, 高风险 ? 2 : 1),
            0,
            3);
        上下文.当前路径预算 = std::clamp<I64>(
            std::max<I64>(上下文.当前路径预算, 高需求 ? 2 : 1),
            0,
            高风险 ? 1 : 4);
        上下文.当前细分预算 = std::clamp<I64>(
            std::max<I64>(上下文.当前细分预算, 允许细分 ? 1 : 0),
            0,
            高风险 ? 0 : 3);

        auto* 预算主体 = 私有_取任务虚拟存在(上下文);
        if (预算主体) {
            const auto 调用点 = 私有_拼调用点(上下文, "计算本轮学习预算");
            (void)世界树.写入特征_I64(预算主体, g_学习词性.学习预算细分, 上下文.当前细分预算, {}, 调用点 + "/细分");
            (void)世界树.写入特征_I64(预算主体, g_学习词性.学习预算路径, 上下文.当前路径预算, {}, 调用点 + "/路径");
            (void)世界树.写入特征_I64(预算主体, g_学习词性.学习预算回退, 上下文.当前回退预算, {}, 调用点 + "/回退");
            (void)世界树.写入特征_I64(预算主体, g_学习词性.学习预算检查, 上下文.当前检查预算, {}, 调用点 + "/检查");
        }
    }

    static std::vector<方法节点类*> 检索相似方法(const 结构_兜底学习上下文& 上下文)
    {
        const auto 调用点 = 私有_拼调用点(上下文, "检索相似方法");
        const 时间戳 now = 当前_微秒();
        std::vector<方法节点类*> 输出{};

        私有_追加方法首节点(输出, 上下文.当前方法首节点, now, 调用点 + "/当前方法");
        if (auto* 步骤信息 = 私有_取步骤信息(上下文)) {
            私有_追加方法首节点(输出, 步骤信息->当前选中方法首节点, now, 调用点 + "/当前选中");
            for (auto* 方法首节点 : 步骤信息->可用方法首节点列表) {
                私有_追加方法首节点(输出, 方法首节点, now, 调用点 + "/步骤候选");
            }
        }
        if (auto* 结果信息 = 私有_取结果信息(上下文)) {
            私有_追加方法首节点(输出, 结果信息->来源方法首节点, now, 调用点 + "/结果来源");
        }

        for (const auto& 动作句柄 : 生成单步候选动作集(上下文)) {
    if (动作句柄.类型 != 枚举_动作句柄类型::本能函数ID || 动作句柄.本能ID == 0) {
                continue;
            }
            auto* 方法首节点 = 方法集.查找或创建_本能方法首节点(
        static_cast<枚举_本能动作ID>(动作句柄.本能ID),
                now,
                调用点 + "/候选动作转方法");
            私有_追加方法首节点(输出, 方法首节点, now, 调用点 + "/候选动作方法");
        }

        std::stable_sort(
            输出.begin(),
            输出.end(),
            [&](方法节点类* 左, 方法节点类* 右) {
                if (左 == 上下文.当前方法首节点) return true;
                if (右 == 上下文.当前方法首节点) return false;
                return 私有_动作评分(上下文, 私有_提取动作句柄(左))
                    > 私有_动作评分(上下文, 私有_提取动作句柄(右));
            });
        return 输出;
    }

    static std::vector<任务节点类*> 降解任务为最小可试探步骤(const 结构_兜底学习上下文& 上下文)
    {
        std::vector<任务节点类*> 输出{};
        const auto 调用点 = 私有_拼调用点(上下文, "降解任务为最小可试探步骤");

        auto* 步骤节点 = 私有_确保最小步骤节点(上下文, 调用点);
        私有_追加任务节点(输出, 步骤节点);
        if (输出.empty()) {
            私有_追加任务节点(输出, 上下文.当前任务头结点);
        }
        return 输出;
    }

    static std::vector<结构体_动作句柄> 生成单步候选动作集(const 结构_兜底学习上下文& 上下文)
    {
        std::vector<结构体_动作句柄> 输出{};
        auto* 步骤信息 = 私有_取步骤信息(上下文);

        if (步骤信息) {
            私有_追加动作句柄(输出, 私有_提取动作句柄(步骤信息->当前选中方法首节点));
            for (auto* 方法首节点 : 步骤信息->可用方法首节点列表) {
                私有_追加动作句柄(输出, 私有_提取动作句柄(方法首节点));
            }
        }

        const bool 安全优先 = 上下文.安全值_Q10000 > 0 && 上下文.安全值_Q10000 <= 3000;
        const bool 服务优先 = 上下文.需求值_Q10000 >= 6000 || 上下文.服务值_Q10000 >= 上下文.安全值_Q10000;

        if (安全优先) {
            私有_追加本能动作(输出, 枚举_本能动作ID::自我_读取核心状态);
            私有_追加本能动作(输出, 枚举_本能动作ID::自我_停止当前试探并进入保守态);
            私有_追加本能动作(输出, 枚举_本能动作ID::自我_观察场景);
        }

        if (服务优先) {
            私有_追加本能动作(输出, 枚举_本能动作ID::自我_读取最新人类输入);
            私有_追加本能动作(输出, 枚举_本能动作ID::自我_确认收到);
            私有_追加本能动作(输出, 枚举_本能动作ID::自我_请求补充信息);
        }

        私有_追加本能动作(输出, 枚举_本能动作ID::自我_读取核心状态);
        私有_追加本能动作(输出, 枚举_本能动作ID::自我_观察场景);

        if (输出.empty()) {
            私有_追加本能动作(输出, 枚举_本能动作ID::自我_停止当前试探并进入保守态);
        }

        return 输出;
    }

    static 结构体_动作句柄 选择下一试探动作(
        const 结构_兜底学习上下文& 上下文,
        const std::vector<结构体_动作句柄>& 候选动作集)
    {
        结构体_动作句柄 最优{};
        I64 最优得分 = (std::numeric_limits<I64>::min)();

        for (const auto& 动作句柄 : 候选动作集) {
            const I64 当前得分 = 私有_动作评分(上下文, 动作句柄);
            if (!最优.有效() || 当前得分 > 最优得分) {
                最优 = 动作句柄;
                最优得分 = 当前得分;
            }
        }

        if (!最优.有效() && 本能集.有(枚举_本能动作ID::自我_停止当前试探并进入保守态)) {
            return 构造学习域动作句柄_v0(枚举_本能动作ID::自我_停止当前试探并进入保守态);
        }
        return 最优;
    }

    static 结构_任务返回消息 执行单步试探动作(
        const 结构_兜底学习上下文& 上下文,
        const 结构体_动作句柄& 动作句柄)
    {
        结构_任务返回消息 返回{};
        返回.来源任务 = 上下文.当前任务头结点;
        返回.来源步骤 = 上下文.当前步骤节点;
        返回.对应需求 = 上下文.来源需求;

        if (!私有_动作句柄可试探(动作句柄)) {
            返回.类型 = 枚举_任务返回消息类型::步骤无法执行;
            返回.摘要 = "试探动作句柄无效或未注册";
            返回.需要重筹办 = true;
            return 返回;
        }

    const auto 本能动作 = static_cast<枚举_本能动作ID>(动作句柄.本能ID);
        const 时间戳 now = 当前_微秒();
        const std::string 调用点 = 上下文.调用点.empty()
            ? "自我本能方法类_学习兜底模块::执行单步试探动作"
            : 上下文.调用点 + "/执行单步试探动作";

        auto* 方法首节点 = 方法集.查找或创建_本能方法首节点(本能动作, now, 调用点);
        if (方法首节点) {
            方法集.初始化方法虚拟存在信息(方法首节点, now, 调用点);
        }

        if (auto* 步骤信息 = 私有_取步骤信息(上下文)) {
            if (方法首节点) {
                步骤信息->当前选中方法首节点 = 方法首节点;
            }
        }
        if (auto* 结果信息 = 私有_取结果信息(上下文)) {
            if (方法首节点) {
                结果信息->来源方法首节点 = 方法首节点;
            }
        }

        auto* 输入场景 = 上下文.当前场景;
        if (!输入场景) {
            if (auto* 步骤信息 = 私有_取步骤信息(上下文)) {
                输入场景 = 步骤信息->场景;
            }
        }
        if (!输入场景) {
            输入场景 = 世界树.取内部世界() ? 世界树.取内部世界() : 世界树.虚拟世界;
        }

        auto* 输出场景 = 私有_准备输出场景(上下文, now, 调用点);
        if (!输入场景 || !输出场景) {
            返回.类型 = 枚举_任务返回消息类型::步骤无法执行;
            返回.摘要 = "缺少试探动作输入或输出场景";
            返回.需要重筹办 = true;
            return 返回;
        }

        const bool 成功 = 本能集.调用(本能动作, 输入场景, 输出场景);
        返回.类型 = 成功 ? 枚举_任务返回消息类型::步骤完成 : 枚举_任务返回消息类型::步骤失败;
        返回.摘要 = 本能集.查询函数名称(本能动作);
        if (返回.摘要.empty()) {
    返回.摘要 = std::string("本能_") + std::to_string(动作句柄.本能ID);
        }
        返回.需要重筹办 = !成功;

        if (!成功) {
            if (auto* 步骤信息 = 私有_取步骤信息(上下文)) {
                if (步骤信息->已重试次数 < (std::numeric_limits<std::int32_t>::max)()) {
                    ++步骤信息->已重试次数;
                }
            }
        }

        日志::运行f(
            "[学习兜底] 执行单步试探动作: 任务={}, 步骤={}, 本能ID={}, 成功={}, 摘要={}",
            (void*)上下文.当前任务头结点,
            (void*)上下文.当前步骤节点,
        static_cast<unsigned long long>(动作句柄.本能ID),
            成功 ? 1 : 0,
            返回.摘要);
        return 返回;
    }

    static bool 验证局部结果(
        const 结构_兜底学习上下文& 上下文,
        const 结构_任务返回消息& 返回消息)
    {
        if (返回消息.需求已满足) {
            return true;
        }
        if (返回消息.类型 == 枚举_任务返回消息类型::步骤完成 && !返回消息.需要重筹办) {
            return true;
        }

        auto* 结果信息 = 私有_取结果信息(上下文);
        if (结果信息 && !结果信息->是否预测外结果 && 结果信息->错误码 == 0) {
            return true;
        }
        return false;
    }

    static bool 回滚最近一步(const 结构_兜底学习上下文& 上下文)
    {
        私有_初始化学习词性();

        bool 已回滚 = false;
        const auto 调用点 = 私有_拼调用点(上下文, "回滚最近一步");

        if (auto* 步骤信息 = 私有_取步骤信息(上下文)) {
            if (步骤信息->当前选中方法首节点 != 上下文.当前方法首节点) {
                步骤信息->当前选中方法首节点 = 上下文.当前方法首节点;
                已回滚 = true;
            }
            if (步骤信息->已重试次数 > 0) {
                --步骤信息->已重试次数;
                已回滚 = true;
            }
        }

        if (auto* 结果信息 = 私有_取结果信息(上下文)) {
            if (结果信息->来源方法首节点 != 上下文.当前方法首节点) {
                结果信息->来源方法首节点 = 上下文.当前方法首节点;
                已回滚 = true;
            }
            if (结果信息->错误码 != 0) {
                结果信息->错误码 = 0;
                已回滚 = true;
            }
            if (结果信息->命中后动作 != 枚举_分支选择动作::未定义) {
                结果信息->命中后动作 = 枚举_分支选择动作::未定义;
                已回滚 = true;
            }
        }

        if (auto* 头信息 = 私有_取任务头信息(上下文)) {
            if (头信息->等待学习唤醒) {
                头信息->等待学习唤醒 = false;
                已回滚 = true;
            }
            if (头信息->等待学习方法首节点 && 头信息->等待学习方法首节点 != 上下文.当前方法首节点) {
                头信息->等待学习方法首节点 = 上下文.当前方法首节点;
                已回滚 = true;
            }
        }

        if (已回滚) {
            if (上下文.当前步骤节点) {
                任务类::设置任务状态(
                    上下文.当前步骤节点,
                    枚举_任务状态::就绪,
                    调用点 + "/步骤恢复就绪");
            }
            if (上下文.当前任务头结点) {
                任务类::设置任务状态(
                    上下文.当前任务头结点,
                    枚举_任务状态::就绪,
                    调用点 + "/任务恢复就绪");
            }
            if (auto* 任务存在 = 私有_取任务虚拟存在(上下文)) {
                (void)世界树.写入特征_I64(任务存在, g_学习词性.学习回滚标记, 1, {}, 调用点 + "/回滚标记");
            }
        }
        return 已回滚;
    }

    static 因果节点类* 登记控制因果(
        const 结构_兜底学习上下文& 上下文,
        const 结构_任务返回消息& 返回消息)
    {
        私有_初始化学习词性();

        const 时间戳 now = 当前_微秒();
        const auto 调用点 = 私有_拼调用点(上下文, "登记控制因果");
        auto* 动作主体 = 私有_归一动作主体(上下文);
        auto* 结果场景 = 私有_归一结果场景(上下文, now, 调用点 + "/结果场景");
        if (!动作主体 || !结果场景) {
            return nullptr;
        }

        auto* 局部结果特征 = 世界树.确保特征(
            动作主体,
            g_学习词性.学习局部结果有效,
            g_学习词性.学习局部结果有效,
            调用点 + "/确保结果特征");
        auto* 动作特征 = 世界树.确保特征(
            动作主体,
            g_学习词性.学习动作ID,
            g_学习词性.学习动作ID,
            调用点 + "/确保动作特征");
        if (!局部结果特征 || !动作特征) {
            return nullptr;
        }

        const I64 局部结果值 = 验证局部结果(上下文, 返回消息) ? 1 : 0;
        const auto 当前动作句柄 = 私有_提取动作句柄(上下文.当前方法首节点);

        auto* 条件状态 = 状态集.创建内部状态(
            结果场景,
            动作主体,
            动作特征,
        特征快照值{ 当前动作句柄.本能ID },
            枚举_存在状态事件::创建,
            false,
            now,
            {},
            调用点 + "/条件状态");
        auto* 结果状态 = 状态集.创建内部状态(
            结果场景,
            动作主体,
            局部结果特征,
            特征快照值{ 局部结果值 },
            枚举_存在状态事件::变化,
            true,
            now + 1,
            {},
            调用点 + "/结果状态");
        if (!条件状态 || !结果状态) {
            return nullptr;
        }

        auto* 过程动态 = 动态集.创建叶子动态(
            结果场景,
            条件状态,
            结果状态,
            now + 1);
        if (!过程动态) {
            return nullptr;
        }

        return static_cast<因果节点类*>(
            因果集.创建或累计因果信息(
                { 条件状态 },
                动作主体,
                { 过程动态 },
                { 结果状态 },
                nullptr,
                nullptr,
                now + 1,
                调用点));
    }

    static 方法节点类* 从成功片段提炼临时方法(const 结构_兜底学习上下文& 上下文)
    {
        const 时间戳 now = 当前_微秒();
        const auto 调用点 = 私有_拼调用点(上下文, "从成功片段提炼临时方法");

        auto* 目标方法首节点 = 上下文.当前方法首节点;
        if (!目标方法首节点) {
            if (auto* 结果信息 = 私有_取结果信息(上下文)) {
                目标方法首节点 = 结果信息->来源方法首节点;
            }
        }
        if (!目标方法首节点) {
            const auto 候选动作集 = 生成单步候选动作集(上下文);
            const auto 选择动作 = 选择下一试探动作(上下文, 候选动作集);
    if (选择动作.类型 == 枚举_动作句柄类型::本能函数ID && 选择动作.本能ID != 0) {
                目标方法首节点 = 方法集.查找或创建_本能方法首节点(
            static_cast<枚举_本能动作ID>(选择动作.本能ID),
                    now,
                    调用点 + "/由动作提炼方法");
            }
        }
        if (!目标方法首节点) {
            return nullptr;
        }

        方法集.初始化方法虚拟存在信息(目标方法首节点, now, 调用点);
        auto* 当前场景 = 上下文.当前场景;
        if (!当前场景) {
            if (auto* 步骤信息 = 私有_取步骤信息(上下文)) {
                当前场景 = 步骤信息->场景;
            }
        }
        if (当前场景) {
            方法集.同步场景特征到方法虚拟存在(
                目标方法首节点,
                当前场景,
                now,
                调用点 + "/同步当前场景");
        }

        auto* 条件节点 = 当前场景
            ? 方法集.取或创建_条件节点_按场景(
                目标方法首节点,
                当前场景,
                now,
                64,
                {},
                调用点 + "/条件节点")
            : 方法集.取或创建_条件节点_按签名(
                目标方法首节点,
                0,
                now,
                64,
                调用点 + "/默认条件节点");
        if (!条件节点) {
            return nullptr;
        }

        auto* 结果场景 = 私有_归一结果场景(上下文, now, 调用点 + "/结果场景");
        auto* 结果节点 = 方法集.取或创建_结果节点_按签名(
            条件节点,
            0,
            结果场景,
            now,
            64,
            调用点 + "/结果节点");
        if (!结果节点) {
            return nullptr;
        }

        if (auto* 步骤节点 = 私有_确保最小步骤节点(上下文, 调用点)) {
            if (auto* 步骤信息 = (步骤节点 && 步骤节点->主信息)
                ? dynamic_cast<任务步骤节点信息*>(步骤节点->主信息)
                : nullptr) {
                if (std::find(
                    步骤信息->可用方法首节点列表.begin(),
                    步骤信息->可用方法首节点列表.end(),
                    目标方法首节点) == 步骤信息->可用方法首节点列表.end()) {
                    步骤信息->可用方法首节点列表.push_back(目标方法首节点);
                }
                if (!步骤信息->当前选中方法首节点) {
                    步骤信息->当前选中方法首节点 = 目标方法首节点;
                }
            }

            if (auto* 结果节点任务 = 私有_确保结果节点(上下文, 步骤节点, 目标方法首节点, 调用点)) {
                if (auto* 结果信息 = (结果节点任务 && 结果节点任务->主信息)
                    ? dynamic_cast<任务结果节点信息*>(结果节点任务->主信息)
                    : nullptr) {
                    结果信息->来源方法首节点 = 目标方法首节点;
                    结果信息->对应方法结果节点 = 结果节点;
                }
            }
        }

        return 目标方法首节点;
    }

    static void 填充已实现接口(结构_原生学习兜底最小闭环接口_v0& 接口)
    {
        接口.判断任务是否缺方法 = &判断任务是否缺方法;
        接口.判断是否允许进入兜底学习 = &判断是否允许进入兜底学习;
        接口.计算本轮学习预算 = &计算本轮学习预算;
        接口.检索相似方法 = &检索相似方法;
        接口.降解任务为最小可试探步骤 = &降解任务为最小可试探步骤;
        接口.生成单步候选动作集 = &生成单步候选动作集;
        接口.选择下一试探动作 = &选择下一试探动作;
        接口.执行单步试探动作 = &执行单步试探动作;
        接口.验证局部结果 = &验证局部结果;
        接口.回滚最近一步 = &回滚最近一步;
        接口.登记控制因果 = &登记控制因果;
        接口.从成功片段提炼临时方法 = &从成功片段提炼临时方法;
    }

    static 结构_原生学习兜底最小闭环接口_v0 创建当前已实现接口()
    {
        结构_原生学习兜底最小闭环接口_v0 接口{};
        填充已实现接口(接口);
        return 接口;
    }
};
