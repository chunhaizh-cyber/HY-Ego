module;

#include <optional>
#include <string>
#include <string_view>
#include <utility>
#include <vector>

export module 任务失败恢复模块_v0;

import 元层核心模块;
import 主信息定义模块;
import 任务模块;
import 任务管理模块_v0;
import 方法管理模块_v0;
import 学习写回模块_v0;

export struct 结构_失败链候选方法_v0
{
    结构_元实体 方法实体{};
    方法节点类* 方法首节点 = nullptr;
};

export struct 结构_失败链参数_v0
{
    需求节点类* 需求 = nullptr;
    结构_元实体 任务实体{};
    std::vector<std::string> 任务标签{};
    std::vector<结构_失败链候选方法_v0> 候选方法{};
    任务类::结构_创建任务头参数 任务参数{};
    任务类::结构_创建步骤参数 步骤参数{};
    任务类::结构_创建结果参数 失败反馈参数{};
    任务类::结构_创建结果参数 成功反馈参数{};
    元字段表 失败学习反馈{};
    元字段表 成功学习反馈{};
    任务节点类* 父任务头结点 = nullptr;
    std::string 调用点 = "任务失败恢复器_v0::执行失败链";
};

export struct 结构_失败链结果_v0
{
    bool 成功 = false;
    std::string 错误摘要;
    std::string 元任务标识;
    std::string 首选方法标识;
    std::string 替代方法标识;
    std::string 失败反馈标识;
    std::string 恢复反馈标识;
    std::string 失败适配关系标识;
    std::string 恢复适配关系标识;
    double 首选方法评分 = 0.0;
    double 替代方法评分 = 0.0;
    int 分解深度上限 = 1;
    bool 允许探索新子任务 = false;
    int 执行范围收缩级别 = 0;
    int 备用方法数量 = 1;
    int 自检强度 = 0;
    任务节点类* 任务头结点 = nullptr;
    任务节点类* 步骤节点 = nullptr;
    任务节点类* 失败结果节点 = nullptr;
    任务节点类* 恢复结果节点 = nullptr;
    方法节点类* 首选方法首节点 = nullptr;
    方法节点类* 替代方法首节点 = nullptr;
};

export class 任务失败恢复器_v0
{
public:
    explicit 任务失败恢复器_v0(元层接口& 元层);

    结构_失败链结果_v0 执行失败链(const 结构_失败链参数_v0& 参数);

private:
    元层接口& 元层_;
};

namespace 任务失败恢复模块_v0_内部 {
inline std::string 取字段_(const 元字段表& 字段, std::string_view 键)
{
    if (const auto it = 字段.find(std::string(键)); it != 字段.end()) {
        return it->second;
    }
    return {};
}

inline double 取数字字段_(const 元字段表& 字段, std::string_view 键, double 默认值 = 0.0)
{
    const auto 值 = 取字段_(字段, 键);
    if (值.empty()) return 默认值;
    try {
        return std::stod(值);
    }
    catch (...) {
        return 默认值;
    }
}

inline 结构_元实体 准备任务实体_(
    结构_元实体 任务实体,
    const std::vector<std::string>& 任务标签)
{
    if (任务实体.标识.empty()) {
        任务实体.标识 = 生成元层标识("task");
    }
    任务实体.类型 = 枚举_元实体类型::任务;
    if (任务实体.状态 == 枚举_元对象状态::新建) {
        任务实体.状态 = 枚举_元对象状态::待执行;
    }
    for (const auto& 标签 : 任务标签) {
        if (!标签.empty()) {
            任务实体.标签.insert(标签);
        }
    }
    if (!任务标签.empty() && !任务实体.内容.contains("任务标签")) {
        std::string 串;
        for (std::size_t i = 0; i < 任务标签.size(); ++i) {
            if (i > 0) 串 += ",";
            串 += 任务标签[i];
        }
        任务实体.内容["任务标签"] = std::move(串);
    }
    return 任务实体;
}

inline std::vector<结构_失败链候选方法_v0> 准备候选方法_(
    std::vector<结构_失败链候选方法_v0> 候选方法)
{
    for (auto& 候选 : 候选方法) {
        if (候选.方法实体.标识.empty()) {
            候选.方法实体.标识 = 生成元层标识("method");
        }
        候选.方法实体.类型 = 枚举_元实体类型::方法;
        if (候选.方法实体.状态 == 枚举_元对象状态::新建) {
            候选.方法实体.状态 = 枚举_元对象状态::待处理;
        }
    }
    return 候选方法;
}

inline 方法节点类* 查找方法节点_(
    const std::vector<结构_失败链候选方法_v0>& 候选方法,
    const std::string& 方法标识)
{
    for (const auto& 候选 : 候选方法) {
        if (候选.方法实体.标识 == 方法标识) {
            return 候选.方法首节点;
        }
    }
    return nullptr;
}

inline 元字段表 构造默认失败学习反馈_(
    const std::string& 元任务标识,
    const std::string& 方法标识)
{
    return {
        {"任务标识", 元任务标识},
        {"方法标识", 方法标识},
        {"是否成功", "0"},
        {"反馈摘要", "方法执行失败，触发替换恢复"},
        {"风险成本修正", "1"},
        {"服务收益修正", "0"}
    };
}

inline 元字段表 构造默认成功学习反馈_(
    const std::string& 元任务标识,
    const std::string& 方法标识)
{
    return {
        {"任务标识", 元任务标识},
        {"方法标识", 方法标识},
        {"是否成功", "1"},
        {"反馈摘要", "方法替换后恢复成功"},
        {"风险成本修正", "0"},
        {"服务收益修正", "1"}
    };
}
}

inline 任务失败恢复器_v0::任务失败恢复器_v0(元层接口& 元层)
    : 元层_(元层)
{
}

inline 结构_失败链结果_v0 任务失败恢复器_v0::执行失败链(const 结构_失败链参数_v0& 参数)
{
    结构_失败链结果_v0 结果{};
    if (!参数.需求 || 参数.候选方法.size() < 2) {
        结果.错误摘要 = "需求为空或候选方法不足";
        return 结果;
    }

    auto 任务实体 = 任务失败恢复模块_v0_内部::准备任务实体_(参数.任务实体, 参数.任务标签);
    auto 候选方法 = 任务失败恢复模块_v0_内部::准备候选方法_(参数.候选方法);

    if (!元层_.写实体(任务实体)) {
        结果.错误摘要 = "写入元任务实体失败";
        return 结果;
    }

    方法管理模块_v0 方法管理(元层_);
    for (const auto& 候选 : 候选方法) {
        if (!候选.方法首节点) {
            结果.错误摘要 = "存在未绑定真实方法节点的候选方法";
            return 结果;
        }
        if (!方法管理.注册方法(候选.方法实体)) {
            结果.错误摘要 = "注册候选方法失败";
            return 结果;
        }
    }

    任务管理器_v0 任务管理;
    auto 创建结果 = 任务管理.确保需求任务头(参数.需求, 参数.任务参数, 参数.父任务头结点, 参数.调用点 + "/创建任务");
    if (!创建结果.成功 || !创建结果.任务头结点) {
        结果.错误摘要 = 创建结果.错误摘要.empty() ? "创建任务失败" : 创建结果.错误摘要;
        return 结果;
    }

    const auto 分解调制 = 任务管理.计算任务分解调制(任务实体, 参数.步骤参数, 参数.调用点 + "/分解调制");
    if (!分解调制.成功) {
        结果.错误摘要 = 分解调制.错误摘要.empty() ? "计算任务分解调制失败" : 分解调制.错误摘要;
        return 结果;
    }
    任务实体.内容["当前安全值"] = std::to_string(分解调制.当前安全值);
    任务实体.内容["当前服务值"] = std::to_string(分解调制.当前服务值);
    任务实体.内容["安全下限"] = std::to_string(分解调制.安全下限);
    任务实体.内容["当前风险权重"] = std::to_string(分解调制.风险权重);
    任务实体.内容["分解深度上限"] = std::to_string(分解调制.分解深度上限);
    任务实体.内容["允许探索新子任务"] = 分解调制.允许探索新子任务 ? "1" : "0";
    任务实体.内容["执行范围收缩级别"] = std::to_string(分解调制.执行范围收缩级别);
    任务实体.内容["备用方法数量"] = std::to_string(分解调制.备用方法数量);
    任务实体.内容["自检强度"] = std::to_string(分解调制.自检强度);
    (void)元层_.写实体(任务实体);

    auto 分解结果 = 任务管理.分解任务(创建结果.任务头结点, 分解调制.调制后步骤参数, 参数.调用点 + "/分解任务");
    if (!分解结果.成功 || !分解结果.步骤节点) {
        结果.错误摘要 = 分解结果.错误摘要.empty() ? "分解任务失败" : 分解结果.错误摘要;
        return 结果;
    }

    auto 首选方法实体 = 方法管理.为任务选择最佳方法(任务实体.标识, 参数.任务标签);
    if (!首选方法实体.has_value()) {
        结果.错误摘要 = "未找到首选方法";
        return 结果;
    }
    auto* 首选方法首节点 = 任务失败恢复模块_v0_内部::查找方法节点_(候选方法, 首选方法实体->标识);
    if (!首选方法首节点) {
        结果.错误摘要 = "首选方法缺少真实方法节点映射";
        return 结果;
    }

    if (!方法管理.绑定方法到任务(任务实体.标识, 首选方法实体->标识, 参数.调用点 + "/绑定方法A")) {
        结果.错误摘要 = "绑定首选元方法失败";
        return 结果;
    }
    if (!任务管理.绑定方法(分解结果.步骤节点, 首选方法首节点, true, 参数.调用点 + "/绑定真实方法A")) {
        结果.错误摘要 = "绑定首选真实方法失败";
        return 结果;
    }
    if (!任务管理.开始任务(创建结果.任务头结点, 参数.调用点 + "/开始任务A")) {
        结果.错误摘要 = "启动首选方法失败";
        return 结果;
    }

    auto 失败任务结果 = 任务管理.失败任务(创建结果.任务头结点, 参数.调用点 + "/方法A失败");
    if (!失败任务结果.成功) {
        结果.错误摘要 = 失败任务结果.错误摘要.empty() ? "写入失败状态失败" : 失败任务结果.错误摘要;
        return 结果;
    }

    auto 失败反馈参数 = 参数.失败反馈参数;
    if (!失败反馈参数.所属任务头结点) {
        失败反馈参数.所属任务头结点 = 创建结果.任务头结点;
    }
    if (!失败反馈参数.来源方法首节点) {
        失败反馈参数.来源方法首节点 = 首选方法首节点;
    }
    if (失败反馈参数.结果角色 == 枚举_任务结果角色::未定义) {
        失败反馈参数.结果角色 = 枚举_任务结果角色::实际结果;
    }
    if (失败反馈参数.初始状态 == 枚举_任务状态::未定义 || 失败反馈参数.初始状态 == 枚举_任务状态::就绪) {
        失败反馈参数.初始状态 = 枚举_任务状态::失败;
    }
    auto 失败反馈结果 = 任务管理.写入反馈(创建结果.任务头结点, 失败反馈参数, 参数.调用点 + "/失败反馈");
    if (!失败反馈结果.成功) {
        结果.错误摘要 = 失败反馈结果.错误摘要.empty() ? "写入失败反馈失败" : 失败反馈结果.错误摘要;
        return 结果;
    }

    学习写回模块_v0 学习写回(元层_);
    auto 失败学习反馈 = 参数.失败学习反馈.empty()
        ? 任务失败恢复模块_v0_内部::构造默认失败学习反馈_(任务实体.标识, 首选方法实体->标识)
        : 参数.失败学习反馈;
    const auto 失败学习结果 = 学习写回.写入反馈并学习写回(
        任务实体.标识,
        首选方法实体->标识,
        false,
        std::move(失败学习反馈),
        参数.调用点 + "/失败学习");
    if (!失败学习结果.成功) {
        结果.错误摘要 = 失败学习结果.错误摘要.empty() ? "失败学习写回失败" : 失败学习结果.错误摘要;
        return 结果;
    }

    if (分解调制.备用方法数量 <= 0) {
        结果.错误摘要 = "当前安全/服务约束未允许备用方法";
        return 结果;
    }

    auto 替代方法实体 = 方法管理.为任务选择候补方法(任务实体.标识, 参数.任务标签, 首选方法实体->标识);
    if (!替代方法实体.has_value()) {
        结果.错误摘要 = "未找到替代方法";
        return 结果;
    }
    auto* 替代方法首节点 = 任务失败恢复模块_v0_内部::查找方法节点_(候选方法, 替代方法实体->标识);
    if (!替代方法首节点) {
        结果.错误摘要 = "替代方法缺少真实方法节点映射";
        return 结果;
    }

    if (!方法管理.替换任务方法(任务实体.标识, 首选方法实体->标识, 替代方法实体->标识, 参数.调用点 + "/替换方法")) {
        结果.错误摘要 = "替换元方法失败";
        return 结果;
    }
    if (!任务管理.绑定方法(分解结果.步骤节点, 替代方法首节点, true, 参数.调用点 + "/绑定真实方法B")) {
        结果.错误摘要 = "绑定替代真实方法失败";
        return 结果;
    }
    if (!任务管理.开始任务(创建结果.任务头结点, 参数.调用点 + "/开始任务B")) {
        结果.错误摘要 = "重启替代方法失败";
        return 结果;
    }

    auto 完成结果 = 任务管理.完成任务(创建结果.任务头结点, 参数.调用点 + "/完成任务B");
    if (!完成结果.成功) {
        结果.错误摘要 = 完成结果.错误摘要.empty() ? "替代方法完成任务失败" : 完成结果.错误摘要;
        return 结果;
    }

    auto 成功反馈参数 = 参数.成功反馈参数;
    if (!成功反馈参数.所属任务头结点) {
        成功反馈参数.所属任务头结点 = 创建结果.任务头结点;
    }
    if (!成功反馈参数.来源方法首节点) {
        成功反馈参数.来源方法首节点 = 替代方法首节点;
    }
    if (成功反馈参数.结果角色 == 枚举_任务结果角色::未定义) {
        成功反馈参数.结果角色 = 枚举_任务结果角色::实际结果;
    }
    if (成功反馈参数.初始状态 == 枚举_任务状态::未定义 || 成功反馈参数.初始状态 == 枚举_任务状态::就绪) {
        成功反馈参数.初始状态 = 枚举_任务状态::完成;
    }
    auto 恢复反馈结果 = 任务管理.写入反馈(创建结果.任务头结点, 成功反馈参数, 参数.调用点 + "/成功反馈");
    if (!恢复反馈结果.成功) {
        结果.错误摘要 = 恢复反馈结果.错误摘要.empty() ? "写入恢复反馈失败" : 恢复反馈结果.错误摘要;
        return 结果;
    }

    auto 成功学习反馈 = 参数.成功学习反馈.empty()
        ? 任务失败恢复模块_v0_内部::构造默认成功学习反馈_(任务实体.标识, 替代方法实体->标识)
        : 参数.成功学习反馈;
    const auto 恢复学习结果 = 学习写回.写入反馈并学习写回(
        任务实体.标识,
        替代方法实体->标识,
        true,
        std::move(成功学习反馈),
        参数.调用点 + "/恢复学习");
    if (!恢复学习结果.成功) {
        结果.错误摘要 = 恢复学习结果.错误摘要.empty() ? "恢复学习写回失败" : 恢复学习结果.错误摘要;
        return 结果;
    }

    结果.成功 = true;
    结果.元任务标识 = 任务实体.标识;
    结果.首选方法标识 = 首选方法实体->标识;
    结果.替代方法标识 = 替代方法实体->标识;
    结果.失败反馈标识 = 失败学习结果.反馈标识;
    结果.恢复反馈标识 = 恢复学习结果.反馈标识;
    结果.失败适配关系标识 = 失败学习结果.适配关系标识;
    结果.恢复适配关系标识 = 恢复学习结果.适配关系标识;
    结果.首选方法评分 = 任务失败恢复模块_v0_内部::取数字字段_(首选方法实体->内容, "当前候选评分", 0.0);
    结果.替代方法评分 = 任务失败恢复模块_v0_内部::取数字字段_(替代方法实体->内容, "当前候选评分", 0.0);
    结果.分解深度上限 = 分解调制.分解深度上限;
    结果.允许探索新子任务 = 分解调制.允许探索新子任务;
    结果.执行范围收缩级别 = 分解调制.执行范围收缩级别;
    结果.备用方法数量 = 分解调制.备用方法数量;
    结果.自检强度 = 分解调制.自检强度;
    结果.任务头结点 = 创建结果.任务头结点;
    结果.步骤节点 = 分解结果.步骤节点;
    结果.失败结果节点 = 失败反馈结果.结果节点;
    结果.恢复结果节点 = 恢复反馈结果.结果节点;
    结果.首选方法首节点 = 首选方法首节点;
    结果.替代方法首节点 = 替代方法首节点;
    return 结果;
}
