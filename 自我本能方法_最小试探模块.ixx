    static bool 本能_自我_服务归零待机保护(场景节点类* 输入场景, 场景节点类* 输出场景)
    {
        私有_初始化词性();
        const 时间戳 now = 当前_微秒();
        auto* 方法首节点 = 私有_取或创建_方法首节点_并回填(
            枚举_本能动作ID::自我_服务归零待机保护,
            "本能_自我_服务归零待机保护",
            now);
        私有_确保方法形参(方法首节点, {});
        结构体_方法调用守卫 守卫(方法首节点, 输入场景, 输出场景, now, "本能_自我_服务归零待机保护");

        if (!输出场景) {
            守卫.设置结果(false, -10);
            return false;
        }

        auto* 自我 = 自我类::当前活动自我();
        if (!自我) {
            私有_写回执(输出场景, false, -11, now, "本能_自我_服务归零待机保护");
            守卫.设置结果(false, -11);
            return false;
        }

        const I64 维护前安全值 = 自我->获取安全值();
        const I64 维护前服务值 = 自我->获取服务值();
        const bool 规则已生效 = 自我->应用服务归零待机保护(
            now,
            "本能_自我_服务归零待机保护");

        私有_写维护输出摘要(
            输出场景,
            维护前安全值,
            维护前服务值,
            自我->获取安全值(),
            自我->获取服务值(),
            规则已生效,
            自我->是否待机状态(),
            "本能_自我_服务归零待机保护");

        私有_写回执(输出场景, true, 0, now, "本能_自我_服务归零待机保护");
        守卫.设置结果(true, 0);
        return true;
    }

    void 注册默认本能动作_自我最小试探()
    {
        私有_初始化词性();
        const 时间戳 now = 当前_微秒();

        auto reg = [&](枚举_本能动作ID id, 本能函数 fn, const char* name, std::initializer_list<const 词性节点类*> 需要类型) {
            auto* head = 方法集.注册本能函数(
                id,
                std::move(fn),
                name ? std::string(name) : std::string(),
                now,
                "注册默认本能动作_自我最小试探");

            私有_确保方法形参(head, 需要类型);
        };

        reg(枚举_本能动作ID::自我_读取核心状态, 本能_自我_读取核心状态, "本能_自我_读取核心状态", {});
        reg(枚举_本能动作ID::自我_读取最新人类输入, 本能_自我_读取最新人类输入, "本能_自我_读取最新人类输入", {});
        reg(枚举_本能动作ID::自我_确认收到, 本能_自我_确认收到, "本能_自我_确认收到", {});
        reg(枚举_本能动作ID::自我_请求补充信息, 本能_自我_请求补充信息, "本能_自我_请求补充信息", {});
        reg(枚举_本能动作ID::自我_停止当前试探并进入保守态, 本能_自我_停止当前试探并进入保守态, "本能_自我_停止当前试探并进入保守态", {});
        reg(枚举_本能动作ID::自我_服务归零待机保护, 本能_自我_服务归零待机保护, "本能_自我_服务归零待机保护", {});
    }
};

