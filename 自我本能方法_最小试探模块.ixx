        if (!输出场景) {
            守卫.设置结果(false, -10);
            return false;
        }

        I64 风险级别 = 1;
        I64 停止原因码 = 0;
        (void)私有_读I64_按类型(输入场景, g_t.风险级别, 风险级别);
        (void)私有_读I64_按类型(输入场景, g_t.试探停止原因码, 停止原因码);

