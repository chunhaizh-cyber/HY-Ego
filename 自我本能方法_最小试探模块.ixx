            (void)世界树.写入特征_I64(世界树.自我指针, g_t.试探停止原因码, 停止原因码, {}, "本能_自我_停止当前试探并进入保守态/自我写停止原因码");
            (void)世界树.写入特征_I64(世界树.自我指针, g_t.风险级别, 风险级别, {}, "本能_自我_停止当前试探并进入保守态/自我写风险级别");
        }

