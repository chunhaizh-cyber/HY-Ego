        const 结构_任务控制判定输入& 输入) const override
    {
        return 计算任务控制功能域判定结果_v0(输入).功能域;
    }
};

export class 缺方法分流器_v0
{
public:
    explicit 缺方法分流器_v0(const 结构_任务控制判定输入& 控制输入)
        : 控制输入_(&控制输入)
    {
    }

    枚举_方法查询结果 查询当前任务可用方法(
        任务节点类* 当前任务头结点,
        任务节点类* 当前步骤结点,
        方法节点类*& 输出方法首节点) const
    {
        using namespace 任务控制总控模块_v0_内部;

        输出方法首节点 = nullptr;
        auto* 任务头 = 归一到任务头_(当前任务头结点);
        auto* 步骤结点 = 当前步骤结点 ? 当前步骤结点 : 取当前或首个步骤_(任务头);
        auto* 步骤信息 = 取步骤信息_(步骤结点);
        if (!步骤信息) {
            return 枚举_方法查询结果::未找到可尝试方法;
        }

        输出方法首节点 = 选择首选方法_(步骤信息);
        if (!输出方法首节点) {
            return 枚举_方法查询结果::未找到可尝试方法;
        }

        (void)任务管理器_v0{}.绑定方法(
            步骤结点,
            输出方法首节点,
            true,
            "缺方法分流器_v0::查询当前任务可用方法/绑定当前方法");
        return 枚举_方法查询结果::找到可尝试方法;
    }

    枚举_学习进入判定结果 判定是否允许进入等待学习(
        任务节点类* 当前任务头结点) const
    {
        using namespace 任务控制总控模块_v0_内部;

        auto* 输入 = 控制输入_;
        auto* 任务头结点 = 归一到任务头_(当前任务头结点);
        auto* 头信息 = 取头信息_(任务头结点);
        if (!输入 || !头信息) {
            return 枚举_学习进入判定结果::不允许进入等待学习;
        }

        if (是否终结状态_(头信息->状态)) {
            return 枚举_学习进入判定结果::不允许进入等待学习;
        }
        if (输入->安全要求必须停止 || 输入->已确定无法继续) {
            return 枚举_学习进入判定结果::不允许进入等待学习;
        }
        if (输入->服务收益不足以继续 || 输入->已满足完成判据) {
            return 枚举_学习进入判定结果::不允许进入等待学习;
        }
        const bool 安全过低 =
            输入->安全值_Q10000 < 0
            || (输入->安全值_Q10000 < 1000
                && 输入->服务值_Q10000 <= 0
                && 输入->需求值_Q10000 <= 0);
        if (安全过低) {
            return 枚举_学习进入判定结果::不允许进入等待学习;
        }
        if (输入->当前预算_Q10000 < 0) {
            return 枚举_学习进入判定结果::不允许进入等待学习;
        }

        return 枚举_学习进入判定结果::允许进入等待学习;
    }

    bool 进入等待学习状态(
        任务节点类* 当前任务头结点,
        任务节点类* 当前步骤结点,
        方法节点类* 等待学习方法首节点) const
    {
        using namespace 任务控制总控模块_v0_内部;

        auto* 任务头结点 = 归一到任务头_(当前任务头结点);
        auto* 头信息 = 取头信息_(任务头结点);
        if (!任务头结点 || !头信息) {
            return false;
        }
        结构_任务动作事件守卫 动作守卫(
            任务头结点->主信息,
            动作_进入等待学习状态_(),
            头信息->场景,
            头信息->场景,
            结构体_时间戳::当前_微秒(),
            "缺方法分流器_v0::进入等待学习状态/动作动态");

        auto* 步骤结点 = 当前步骤结点 ? 当前步骤结点 : 取当前或首个步骤_(任务头结点);
        if (!等待学习方法首节点) {
            const 时间戳 now = 结构体_时间戳::当前_微秒();
            等待学习方法首节点 = 方法集.查找或创建_本能方法首节点(
                枚举_本能动作ID::学习_尝试学习,
                now,
                "缺方法分流器_v0::进入等待学习状态/确保学习入口");
            if (!等待学习方法首节点) {
                动作守卫.设置结果(false, 1);
                return false;
            }
            方法集.初始化方法虚拟存在信息(
                等待学习方法首节点,
                now,
                "缺方法分流器_v0::进入等待学习状态/初始化学习入口");
        }

        头信息->等待学习唤醒 = true;
        头信息->等待学习方法首节点 = 等待学习方法首节点;

        if (步骤结点) {
            任务类::设置任务状态(
                步骤结点,
                枚举_任务状态::待重筹办,
                "缺方法分流器_v0::进入等待学习状态/步骤待重筹办");
        }
        任务类::设置任务状态(
            任务头结点,
            枚举_任务状态::待重筹办,
            "缺方法分流器_v0::进入等待学习状态/任务待重筹办");
        return true;
    }

    bool 标记筹办失败(
        任务节点类* 当前任务头结点,
        const std::string& 原因说明) const
    {
        using namespace 任务控制总控模块_v0_内部;

        (void)原因说明;
        auto* 任务头结点 = 归一到任务头_(当前任务头结点);
        if (!任务头结点) {
            return false;
        }
        auto* 头信息 = 取头信息_(任务头结点);
        结构_任务动作事件守卫 动作守卫(
            任务头结点->主信息,
            动作_标记筹办失败_(),
            头信息 ? 头信息->场景 : nullptr,
            头信息 ? 头信息->场景 : nullptr,
            结构体_时间戳::当前_微秒(),
            "缺方法分流器_v0::标记筹办失败/动作动态");

        if (auto* 步骤结点 = 取当前或首个步骤_(任务头结点)) {
            任务类::设置任务状态(
                步骤结点,
                枚举_任务状态::无法执行,
                "缺方法分流器_v0::标记筹办失败/步骤无法执行");
        }
        任务类::设置任务状态(
            任务头结点,
            枚举_任务状态::无法执行,
            "缺方法分流器_v0::标记筹办失败/任务无法执行");
        return true;
    }

    结构_缺方法分流返回 执行缺方法分流(
        任务节点类* 当前任务头结点,
        任务节点类* 当前步骤结点) const
    {
        结构_缺方法分流返回 返回{};

        方法节点类* 当前方法首节点 = nullptr;
        const auto 查询结果 = 查询当前任务可用方法(
            当前任务头结点,
            当前步骤结点,
            当前方法首节点);
        if (查询结果 == 枚举_方法查询结果::找到可尝试方法) {
            返回.结果 = 枚举_缺方法分流结果::已绑定方法可执行;
            返回.当前方法首节点 = 当前方法首节点;
            返回.原因说明 = "已找到可尝试方法";
            return 返回;
        }

        const auto 学习判定 = 判定是否允许进入等待学习(当前任务头结点);
        if (学习判定 == 枚举_学习进入判定结果::允许进入等待学习) {
            if (进入等待学习状态(当前任务头结点, 当前步骤结点, nullptr)) {
                using namespace 任务控制总控模块_v0_内部;
                if (auto* 头信息 = 取头信息_(归一到任务头_(当前任务头结点))) {
                    返回.当前方法首节点 = 头信息->等待学习方法首节点;
                }
                返回.结果 = 枚举_缺方法分流结果::已进入等待学习;
                返回.原因说明 = "未找到方法，已进入等待学习";
                return 返回;
            }
        }

        (void)标记筹办失败(当前任务头结点, "未找到可尝试方法，且不允许进入等待学习");
        返回.结果 = 枚举_缺方法分流结果::无法继续已失败;
        返回.原因说明 = "未找到可尝试方法，且不允许进入等待学习";
        return 返回;
    }

    结构_缺方法分流返回 执行分流(任务节点类* 当前任务) const
    {
        using namespace 任务控制总控模块_v0_内部;
        auto* 任务头结点 = 归一到任务头_(当前任务);
        return 执行缺方法分流(任务头结点, 取当前或首个步骤_(任务头结点));
    }

private:
    const 结构_任务控制判定输入* 控制输入_ = nullptr;
};

export class 筹办任务执行器_v0 : public 筹办任务执行接口_v0
{
public:
    explicit 筹办任务执行器_v0(缺方法分流器_v0& 缺方法分流器)
        : 缺方法分流器引用_(缺方法分流器)
    {
    }

    结构_筹办返回 执行筹办(
        const 结构_任务控制判定输入& 输入,
        方法节点类* 当前域方法树根 = nullptr) const override
    {
        using namespace 任务控制总控模块_v0_内部;

        结构_筹办返回 返回{};

        auto* 当前任务头结点 = 确保任务头结点存在(输入, 返回);
        if (!当前任务头结点) {
            返回.结果 = 枚举_筹办结果::筹办失败;
            if (返回.原因说明.empty()) {
                返回.原因说明 = "当前任务头结点为空";
            }
            return 返回;
        }
        返回.当前任务头结点 = 当前任务头结点;
        auto* 任务头信息 = 取头信息_(当前任务头结点);
        结构_任务动作事件守卫 动作守卫(
            当前任务头结点->主信息,
            动作_执行筹办_(),
            任务头信息 ? 任务头信息->场景 : nullptr,
            任务头信息 ? 任务头信息->场景 : nullptr,
            结构体_时间戳::当前_微秒(),
            "筹办任务执行器_v0::执行筹办/动作动态");

        auto* 当前步骤结点 = 确保初始步骤结点存在(当前任务头结点, 返回);
        auto* 当前结果结点 = 确保初始结果结点存在(当前任务头结点, 当前步骤结点, 返回);
        返回.当前步骤结点 = 当前步骤结点;
        返回.当前结果结点 = 当前结果结点;

        if (!当前步骤结点 || !当前结果结点) {
            动作守卫.设置结果(false, 1);
            返回.结果 = 枚举_筹办结果::筹办失败;
            返回.原因说明 = "任务骨架不完整";
            return 返回;
        }

        if (当前域方法树根) {
            结构_四域方法树条件签名输入_v0 条件输入{};
            条件输入.域标签 = 功能域标签_(枚举_任务控制功能域::筹办);
            条件输入.任务虚拟存在 = 取任务虚拟存在_(当前任务头结点);
            条件输入.安全值_Q10000 = 输入.安全值_Q10000;
            条件输入.服务值_Q10000 = 输入.服务值_Q10000;
            条件输入.需求值_Q10000 = 输入.需求值_Q10000;
            条件输入.当前预算_Q10000 = 输入.当前预算_Q10000;
            条件输入.最近结果稳定 = 输入.最近结果稳定;
            条件输入.最近执行失败 = 输入.最近执行失败;
            条件输入.风险变坏 = 输入.风险变坏;
            条件输入.检查点通过 = 输入.检查点通过;
            条件输入.依赖缺失 = 输入.依赖缺失;
            条件输入.需要新子任务或新步骤 = 输入.需要新子任务或新步骤;
            条件输入.关键方法不再可用 = 输入.关键方法不再可用;
            条件输入.已满足完成判据 = 输入.已满足完成判据;

            结构_四域方法树匹配请求_v0 匹配请求{};
            匹配请求.域方法树根 = 当前域方法树根;
            匹配请求.条件主键 = 四域方法树匹配器_v0::生成条件主键(条件输入);
            const auto 匹配结果 = 四域方法树匹配器_v0{}.匹配(匹配请求);
            if (匹配结果.找到 && 匹配结果.建议执行首节点) {
                任务管理器_v0{}.绑定方法(
                    当前步骤结点,
                    匹配结果.建议执行首节点,
                    true,
                    "筹办任务执行器_v0::执行筹办/命中域树绑定方法");
                返回.当前域建议方法首节点 = 匹配结果.建议执行首节点;
                返回.当前选中方法首节点 = 匹配结果.建议执行首节点;
                返回.结果 = 枚举_筹办结果::已可执行;
                返回.原因说明 = 匹配结果.原因说明;

                任务类::设置任务状态(
                    当前步骤结点,
                    枚举_任务状态::就绪,
                    "筹办任务执行器_v0::执行筹办/步骤就绪");
                任务类::设置任务状态(
                    当前任务头结点,
                    枚举_任务状态::就绪,
                    "筹办任务执行器_v0::执行筹办/任务就绪");
                return 返回;
            }
        }

        auto* 当前选中方法首节点 = 尝试绑定方法(当前步骤结点);
        if (当前选中方法首节点) {
            返回.当前选中方法首节点 = 当前选中方法首节点;
            返回.结果 = 枚举_筹办结果::已可执行;
            返回.原因说明 = "已找到并绑定可尝试方法";

            任务类::设置任务状态(
                当前步骤结点,
                枚举_任务状态::就绪,
                "筹办任务执行器_v0::执行筹办/步骤就绪");
            任务类::设置任务状态(
                当前任务头结点,
                枚举_任务状态::就绪,
                "筹办任务执行器_v0::执行筹办/任务就绪");
            return 返回;
        }

        const auto 分流返回 = 缺方法分流器引用_.执行缺方法分流(
            当前任务头结点,
            当前步骤结点);
        auto* 分流方法首节点 = 分流返回.当前方法首节点;
        if (分流返回.结果 == 枚举_缺方法分流结果::已进入等待学习) {
            返回.当前选中方法首节点 = 分流返回.当前方法首节点;
            返回.是否进入等待学习 = true;
            返回.结果 = 枚举_筹办结果::已等待学习;
            返回.原因说明 = 分流返回.原因说明;
            return 返回;
        }
        if (分流返回.结果 != 枚举_缺方法分流结果::已绑定方法可执行 || !分流方法首节点) {
            动作守卫.设置结果(false, 2);
            返回.结果 = 枚举_筹办结果::筹办失败;
            返回.原因说明 = 分流返回.原因说明.empty()
                ? "当前无可尝试方法，且未能进入等待学习"
                : 分流返回.原因说明;
            return 返回;
        }

        返回.当前选中方法首节点 = 分流方法首节点;
        返回.结果 = 枚举_筹办结果::已可执行;
        返回.原因说明 = 分流返回.原因说明.empty()
            ? "已找到并绑定可尝试方法"
            : 分流返回.原因说明;

        if (当前步骤结点) {
            任务类::设置任务状态(
                当前步骤结点,
                枚举_任务状态::就绪,
                "筹办任务执行器_v0::执行筹办/步骤就绪");
        }
        任务类::设置任务状态(
            当前任务头结点,
            枚举_任务状态::就绪,
            "筹办任务执行器_v0::执行筹办/任务就绪");
        return 返回;
    }

private:
    任务节点类* 确保任务头结点存在(
        const 结构_任务控制判定输入& 输入,
        结构_筹办返回& 返回) const
    {
        using namespace 任务控制总控模块_v0_内部;

        任务管理器_v0 任务管理;
        auto* 当前任务头结点 = 归一到任务头_(输入.当前任务);
        if (!当前任务头结点) {
            if (!输入.来源需求) {
                返回.原因说明 = "缺少来源需求，无法创建根任务";
                return nullptr;
            }

            任务类::结构_创建任务头参数 任务头参数{};
            任务头参数.初始场景 = 输入.当前场景;
            任务头参数.自动进入筹办阶段 = true;
            auto 结果 = 任务管理.确保需求任务头(
                输入.来源需求,
                任务头参数,
                nullptr,
                "筹办任务执行器_v0::确保任务骨架存在/确保需求任务头");
            if (!结果.成功 || !结果.任务头结点) {
                返回.原因说明 = 结果.错误摘要.empty()
                    ? "确保需求任务头失败"
                    : 结果.错误摘要;
                return nullptr;
            }
            当前任务头结点 = 结果.任务头结点;
        }
        else {
            (void)任务类::进入筹办阶段(
                当前任务头结点,
                输入.当前场景,
                "筹办任务执行器_v0::确保任务头结点存在/进入筹办");
        }

        返回.当前任务头结点 = 当前任务头结点;
        return 当前任务头结点;
    }

    任务节点类* 确保初始步骤结点存在(
        任务节点类* 当前任务头结点,
        结构_筹办返回& 返回) const
    {
        using namespace 任务控制总控模块_v0_内部;

        if (!当前任务头结点) return nullptr;
        auto* 当前步骤结点 = 取当前或首个步骤_(当前任务头结点);
        if (!当前步骤结点) {
            任务管理器_v0 任务管理;
            任务类::结构_创建步骤参数 步骤参数{};
            步骤参数.所属任务头结点 = 当前任务头结点;
            步骤参数.初始状态 = 枚举_任务状态::就绪;
            auto 分解结果 = 任务管理.分解任务(
                当前任务头结点,
                步骤参数,
                "筹办任务执行器_v0::确保任务骨架存在/创建初始步骤");
            if (!分解结果.成功 || !分解结果.步骤节点) {
                返回.原因说明 = 分解结果.错误摘要.empty()
                    ? "创建初始步骤失败"
                    : 分解结果.错误摘要;
                return nullptr;
            }
            当前步骤结点 = 分解结果.步骤节点;
        }

        返回.当前步骤结点 = 当前步骤结点;
        return 当前步骤结点;
    }

    任务节点类* 确保初始结果结点存在(
        任务节点类* 当前任务头结点,
        任务节点类* 当前步骤结点,
        结构_筹办返回& 返回) const
    {
        using namespace 任务控制总控模块_v0_内部;

        (void)当前任务头结点;
        if (!当前步骤结点) return nullptr;

        auto* 当前结果结点 = 取首个结果_(当前步骤结点);
        if (!当前结果结点) {
            任务类::结构_创建结果参数 结果参数{};
            结果参数.所属任务头结点 = 当前任务头结点;
            结果参数.结果角色 = 枚举_任务结果角色::实际结果;
            当前结果结点 = 任务类::创建结果节点(
                当前步骤结点,
                结果参数,
                "筹办任务执行器_v0::确保任务骨架存在/创建初始结果");
            if (!当前结果结点) {
                返回.原因说明 = "创建初始结果失败";
                return nullptr;
            }
        }

        返回.当前结果结点 = 当前结果结点;
        return 当前结果结点;
    }

    方法节点类* 尝试绑定方法(任务节点类* 当前步骤结点) const
    {
        using namespace 任务控制总控模块_v0_内部;

        if (!当前步骤结点) return nullptr;
        auto* 步骤信息 = 取步骤信息_(当前步骤结点);
        if (!步骤信息) return nullptr;

        auto* 方法首节点 = 选择首选方法_(步骤信息);
        if (方法首节点) {
            任务管理器_v0{}.绑定方法(
                当前步骤结点,
                方法首节点,
                true,
                "筹办任务执行器_v0::尝试绑定方法/绑定当前方法");
        }
        return 方法首节点;
    }

private:
    缺方法分流器_v0& 缺方法分流器引用_;
};

export class 方法执行适配器_v0
{
public:
    结构_任务返回消息 执行一步(
        任务节点类* 当前步骤结点,
        方法节点类* 当前方法首节点) const
    {
        using namespace 任务控制总控模块_v0_内部;

        结构_任务返回消息 返回{};

        auto* 当前任务头结点 = 归一到任务头_(当前步骤结点);
        auto* 步骤结点 = 取步骤信息_(当前步骤结点)
            ? 当前步骤结点
            : 取当前或首个步骤_(当前任务头结点);
        auto* 头信息 = 取头信息_(当前任务头结点);
        auto* 步骤信息 = 取步骤信息_(步骤结点);

        返回.来源任务 = 当前任务头结点;
        返回.来源步骤 = 步骤结点;
        返回.对应需求 = 头信息 ? 头信息->需求 : nullptr;

        if (!当前任务头结点 || !步骤结点 || !头信息 || !步骤信息) {
            返回.类型 = 枚举_任务返回消息类型::步骤无法执行;
            返回.摘要 = "维护执行缺少任务骨架";
            return 返回;
        }

        if (当前方法首节点) {
            步骤信息->当前选中方法首节点 = 当前方法首节点;
        }
        if (!步骤信息->当前选中方法首节点 && !步骤信息->可用方法首节点列表.empty()) {
            步骤信息->当前选中方法首节点 = 选择首选方法_(步骤信息);
        }
        if (!方法可由执行适配器直接执行_(步骤信息->当前选中方法首节点)) {
            if (auto* 可执行方法首节点 = 选择首选可直接执行方法_(步骤信息)) {
                步骤信息->当前选中方法首节点 = 可执行方法首节点;
            }
        }

        auto* 方法首节点 = 步骤信息->当前选中方法首节点;
        auto* 方法头信息 = 取方法头信息_(方法首节点);
        if (!方法头信息) {
            返回.类型 = 枚举_任务返回消息类型::步骤无法执行;
            返回.摘要 = "当前步骤缺少可执行方法";
            返回.需要重筹办 = true;
            return 返回;
        }
        if (方法头信息->动作句柄.类型 != 枚举_动作句柄类型::本能函数ID
        || 方法头信息->动作句柄.本能ID == 0
        || !本能集.有(static_cast<枚举_本能动作ID>(方法头信息->动作句柄.本能ID))) {
            返回.类型 = 枚举_任务返回消息类型::步骤无法执行;
            返回.摘要 = "当前方法不可执行";
            返回.需要重筹办 = true;
            return 返回;
        }

        const 时间戳 now = 结构体_时间戳::当前_微秒();
        (void)任务类::设置任务当前步骤(
            当前任务头结点->主信息,
            步骤结点,
            now,
            "方法执行适配器_v0::执行一步/设置当前步骤");

        任务执行器 执行器{};
        执行器.设置叶子执行回调(
            [当前任务头结点, 步骤结点](任务节点类* 回调步骤结点) {
                return 执行当前本能方法_(
                    当前任务头结点,
                    回调步骤结点 ? 回调步骤结点 : 步骤结点,
                    nullptr);
            });

        const bool 推进成功 = 执行器.推进一步(当前任务头结点, &返回);
        if (!推进成功 && 返回.类型 == 枚举_任务返回消息类型::未定义) {
            返回.类型 = 枚举_任务返回消息类型::步骤无法执行;
            返回.摘要 = "维护执行推进失败";
        }
        if (!返回.来源任务) {
            返回.来源任务 = 当前任务头结点;
        }
        if (!返回.来源步骤) {
            返回.来源步骤 = 步骤结点;
        }
        if (!返回.对应需求) {
            返回.对应需求 = 头信息->需求;
        }
        return 返回;
    }
};

export class 维护任务执行器_v0 : public 维护任务执行接口_v0
{
public:
    explicit 维护任务执行器_v0(方法执行适配器_v0& 方法执行适配器)
        : 方法执行适配器引用_(方法执行适配器)
    {
    }

    结构_维护返回 执行维护(
        任务节点类* 当前任务头结点,
        任务节点类* 当前步骤结点,
        任务节点类* 当前结果结点,
        方法节点类* 当前方法首节点,
        方法节点类* 当前域方法树根 = nullptr) const override
    {
        using namespace 任务控制总控模块_v0_内部;
        (void)当前域方法树根;

        结构_维护返回 返回{};

        auto* 任务头结点 = 归一到任务头_(当前任务头结点 ? 当前任务头结点 : 当前步骤结点);
        auto* 头信息 = 取头信息_(任务头结点);
        auto* 步骤结点 = 取步骤信息_(当前步骤结点)
            ? 当前步骤结点
            : 取当前或首个步骤_(任务头结点);
        auto* 步骤信息 = 取步骤信息_(步骤结点);

        返回.当前任务头结点 = 任务头结点;
        返回.当前步骤结点 = 步骤结点;
        返回.当前结果结点 = 当前结果结点;
        返回.当前方法首节点 = 当前方法首节点;

        if (!任务头结点 || !头信息 || !步骤结点 || !步骤信息) {
            返回.结果 = 枚举_维护结果::维护失败;
            返回.原因说明 = "当前任务骨架损坏";
            return 返回;
        }
        if (是否终结状态_(头信息->状态)) {
            返回.结果 = 枚举_维护结果::转入收束;
            返回.原因说明 = "当前任务已处于终结态";
            返回.已命中完成判据 = (头信息->状态 == 枚举_任务状态::完成);
            return 返回;
        }

        const bool 步骤原本缺当前方法 = !步骤信息->当前选中方法首节点;
        if (当前方法首节点) {
            if (步骤原本缺当前方法 && 步骤结点) {
                if (任务管理器_v0{}.绑定方法(
                    步骤结点,
                    当前方法首节点,
                    true,
                    "维护任务执行器_v0::执行维护/接管域树建议方法")) {
                    返回.当前域建议方法首节点 = 当前方法首节点;
                }
            }
            else {
                步骤信息->当前选中方法首节点 = 当前方法首节点;
            }
        }
        if (!步骤信息->当前选中方法首节点 && !步骤信息->可用方法首节点列表.empty()) {
            步骤信息->当前选中方法首节点 = 选择首选方法_(步骤信息);
        }
        if (!方法可由执行适配器直接执行_(步骤信息->当前选中方法首节点)) {
            if (auto* 可执行方法首节点 = 选择首选可直接执行方法_(步骤信息)) {
                if (可执行方法首节点 != 步骤信息->当前选中方法首节点 && 步骤结点) {
                    (void)任务管理器_v0{}.绑定方法(
                        步骤结点,
                        可执行方法首节点,
                        true,
                        "维护任务执行器_v0::执行维护/切换到可执行方法");
                }
                else {
                    步骤信息->当前选中方法首节点 = 可执行方法首节点;
                }
            }
        }
        返回.当前方法首节点 = 步骤信息->当前选中方法首节点;
        if (!返回.当前方法首节点) {
            返回.结果 = 枚举_维护结果::回到筹办;
            返回.原因说明 = "当前步骤缺少可执行方法";
            return 返回;
        }

        const auto 反馈 = 方法执行适配器引用_.执行一步(步骤结点, 返回.当前方法首节点);
        返回.最近反馈 = 反馈;
        返回.当前结果结点 = 头信息->最近实际结果节点
            ? 头信息->最近实际结果节点
            : 当前结果结点;
        返回.本次结果稳定出现 = 判断结果是否稳定出现(任务头结点, 反馈);
        返回.已命中完成判据 = 判断是否命中完成判据(任务头结点, 反馈);
        (void)更新方法可靠度(返回.当前方法首节点, 返回.本次结果稳定出现);

        if (反馈.需要重筹办) {
            返回.结果 = 枚举_维护结果::回到筹办;
            返回.原因说明 = 反馈.摘要.empty()
                ? "当前步骤需要重筹办"
                : 反馈.摘要;
            return 返回;
        }
        if (返回.已命中完成判据) {
            返回.结果 = 枚举_维护结果::转入收束;
            返回.原因说明 = 反馈.摘要.empty()
                ? "已命中完成判据"
                : 反馈.摘要;
            return 返回;
        }
        if (反馈.类型 == 枚举_任务返回消息类型::步骤完成 && 返回.本次结果稳定出现) {
            返回.结果 = 枚举_维护结果::继续维护;
            返回.原因说明 = 反馈.摘要.empty()
                ? "步骤执行成功，可继续维护"
                : 反馈.摘要;
            return 返回;
        }
        if (反馈.类型 == 枚举_任务返回消息类型::步骤失败
            || 反馈.类型 == 枚举_任务返回消息类型::步骤无法执行
            || !返回.本次结果稳定出现) {
            返回.结果 = 枚举_维护结果::转入纠偏;
            返回.原因说明 = 反馈.摘要.empty()
                ? "方法执行失败或结果不稳定"
                : 反馈.摘要;
            return 返回;
        }

        返回.结果 = 枚举_维护结果::维护失败;
        返回.原因说明 = 反馈.摘要.empty()
            ? "维护结果未定义"
            : 反馈.摘要;
        return 返回;
    }

private:
    bool 判断结果是否稳定出现(
        任务节点类* 当前任务头结点,
        const 结构_任务返回消息& 返回消息) const
    {
        using namespace 任务控制总控模块_v0_内部;

        if (返回消息.类型 != 枚举_任务返回消息类型::步骤完成) {
            return false;
        }

        auto* 头信息 = 取头信息_(当前任务头结点);
        auto* 结果信息 = 取结果信息_(头信息 ? 头信息->最近实际结果节点 : nullptr);
        if (!结果信息) {
            return !返回消息.需要重筹办;
        }
        if (结果信息->是否预测外结果) {
            return false;
        }
        if (结果信息->错误码 != 0) {
            return false;
        }
        return true;
    }

    bool 判断是否命中完成判据(
        任务节点类* 当前任务头结点,
        const 结构_任务返回消息& 返回消息) const
    {
        using namespace 任务控制总控模块_v0_内部;

        if (返回消息.需求已满足) {
            return true;
        }
        auto* 头信息 = 取头信息_(当前任务头结点);
        return 头信息 && 头信息->状态 == 枚举_任务状态::完成;
    }

    bool 更新方法可靠度(
        方法节点类* 当前方法首节点,
        bool 结果稳定出现) const
    {
        return 任务控制总控模块_v0_内部::更新方法可靠度统计_(
            当前方法首节点,
            结果稳定出现,
            结构体_时间戳::当前_微秒());
    }

private:
    方法执行适配器_v0& 方法执行适配器引用_;
};

export class 纠偏任务执行器_v0 : public 纠偏任务执行接口_v0
{
public:
    结构_纠偏返回 执行纠偏(
        任务节点类* 当前任务头结点,
        任务节点类* 当前步骤结点,
        任务节点类* 当前结果结点,
        方法节点类* 当前方法首节点,
        const 结构_任务返回消息& 最近反馈,
        方法节点类* 当前域方法树根 = nullptr,
        const 结构_任务控制判定输入* 控制输入 = nullptr) const override
    {
        using namespace 任务控制总控模块_v0_内部;

        结构_纠偏返回 返回{};
        auto* 任务头结点 = 归一到任务头_(当前任务头结点 ? 当前任务头结点 : 当前步骤结点);
        auto* 头信息 = 取头信息_(任务头结点);
        auto* 步骤结点 = 取步骤信息_(当前步骤结点)
            ? 当前步骤结点
            : 取当前或首个步骤_(任务头结点);
        auto* 步骤信息 = 取步骤信息_(步骤结点);

        返回.当前任务头结点 = 任务头结点;
        返回.当前步骤结点 = 步骤结点;
        返回.当前结果结点 = 当前结果结点;
        返回.当前方法首节点 = 当前方法首节点;

        if (!任务头结点 || !头信息 || !步骤结点 || !步骤信息) {
            日志::运行_错误("[纠偏任务执行器_v0] 当前任务骨架损坏，无法纠偏");
            返回.结果 = 枚举_纠偏结果::纠偏失败;
            返回.原因说明 = "当前任务骨架损坏";
            return 返回;
        }

        日志::运行f(
            "[纠偏任务执行器_v0] 开始纠偏: 任务={}, 步骤={}, 方法={}, 反馈类型={}",
            (void*)任务头结点,
            (void*)步骤结点,
            (void*)(当前方法首节点 ? 当前方法首节点 : 步骤信息->当前选中方法首节点),
            static_cast<int>(最近反馈.类型));

        if (!是否需要纠偏(最近反馈, 控制输入)) {
            日志::运行("[纠偏任务执行器_v0] 当前无需纠偏，直接恢复维护");
            返回.结果 = 枚举_纠偏结果::已恢复维护;
            返回.原因说明 = "当前无需纠偏";
            返回.当前方法首节点 = 步骤信息->当前选中方法首节点;
            return 返回;
        }

        if (是否应直接转入收束(任务头结点, 步骤结点, 最近反馈, 控制输入)) {
            日志::运行_警告("[纠偏任务执行器_v0] 当前不适合继续纠偏，转入收束");
            返回.结果 = 枚举_纠偏结果::转入收束;
            返回.原因说明 = "安全或服务条件不支持继续纠偏";
            返回.当前方法首节点 = 步骤信息->当前选中方法首节点;
            return 返回;
        }

        auto* 当前已选方法 = 步骤信息->当前选中方法首节点;
        auto* 域树纠偏建议方法 = 当前方法首节点;
        if ((!域树纠偏建议方法 || 域树纠偏建议方法 == 当前已选方法)
            && 当前域方法树根) {
            域树纠偏建议方法 = 解析域方法树建议方法首节点_(当前域方法树根);
        }
        if (域树纠偏建议方法
            && 域树纠偏建议方法 != 当前已选方法
            && 方法可由执行适配器直接执行_(域树纠偏建议方法)) {
            返回.当前域建议方法首节点 = 域树纠偏建议方法;
            if (尝试采用域树纠偏方法(任务头结点, 步骤结点, 域树纠偏建议方法)) {
                日志::运行f(
                    "[纠偏任务执行器_v0] 已采用域树纠偏方法，恢复维护: 任务={}, 步骤={}, 新方法={}",
                    (void*)任务头结点,
                    (void*)步骤结点,
                    (void*)域树纠偏建议方法);
                返回.结果 = 枚举_纠偏结果::已恢复维护;
                返回.原因说明 = "已采用纠偏域方法树建议方法";
                返回.当前方法首节点 = 域树纠偏建议方法;
                返回.是否已替换方法 = true;
                return 返回;
            }
        }

        auto* 替代方法 = 尝试查找替代方法(
            步骤结点,
            当前方法首节点 ? 当前方法首节点 : 步骤信息->当前选中方法首节点);
        if (替代方法 && 尝试替换方法(步骤结点, 替代方法)) {
            日志::运行f(
                "[纠偏任务执行器_v0] 已替换方法，恢复维护: 任务={}, 步骤={}, 新方法={}",
                (void*)任务头结点,
                (void*)步骤结点,
                (void*)替代方法);
            返回.结果 = 枚举_纠偏结果::已恢复维护;
            返回.原因说明 = "已替换为替代方法";
            返回.当前方法首节点 = 替代方法;
            返回.是否已替换方法 = true;
            return 返回;
        }

        if (尝试局部回退(任务头结点, 步骤结点)) {
            日志::运行f(
                "[纠偏任务执行器_v0] 已执行局部回退，返回筹办: 任务={}, 步骤={}",
                (void*)任务头结点,
                (void*)步骤结点);
            返回.结果 = 枚举_纠偏结果::回到筹办;
            返回.原因说明 = "无替代方法，已回退到待重筹办";
            返回.当前方法首节点 = nullptr;
            返回.是否已执行回退 = true;
            return 返回;
        }

        if (是否应直接转入收束(任务头结点, 步骤结点, 最近反馈, 控制输入)) {
            日志::运行_警告("[纠偏任务执行器_v0] 替换与回退都不可行，转入收束");
            返回.结果 = 枚举_纠偏结果::转入收束;
            返回.原因说明 = "无替代方法且回退不再值得继续";
            返回.当前方法首节点 = 步骤信息->当前选中方法首节点;
            return 返回;
        }

        日志::运行_错误("[纠偏任务执行器_v0] 无法替换方法，也无法完成回退");
        返回.结果 = 枚举_纠偏结果::纠偏失败;
        返回.原因说明 = "无法替换方法，也无法执行局部回退";
        返回.当前方法首节点 = 步骤信息->当前选中方法首节点;
        return 返回;
    }

private:
    bool 是否需要纠偏(
        const 结构_任务返回消息& 最近反馈,
        const 结构_任务控制判定输入* 控制输入) const
    {
        if (最近反馈.类型 == 枚举_任务返回消息类型::步骤失败
            || 最近反馈.类型 == 枚举_任务返回消息类型::步骤无法执行
            || 最近反馈.需要重筹办) {
            return true;
        }
        if (!控制输入) {
            return false;
        }
        return 控制输入->最近执行失败
            || !控制输入->最近结果稳定
            || !控制输入->检查点通过
            || 控制输入->风险变坏
            || 控制输入->关键方法不再可用;
    }

    方法节点类* 尝试查找替代方法(
        任务节点类* 当前步骤结点,
        方法节点类* 当前方法首节点) const
    {
        using namespace 任务控制总控模块_v0_内部;

        auto* 步骤信息 = 取步骤信息_(当前步骤结点);
        if (auto* 可执行替代 = 选择替代可直接执行方法_(步骤信息, 当前方法首节点)) {
            return 可执行替代;
        }
        return 选择替代方法_(步骤信息, 当前方法首节点);
    }

    bool 尝试替换方法(
        任务节点类* 当前步骤结点,
        方法节点类* 新方法首节点) const
    {
        using namespace 任务控制总控模块_v0_内部;

        auto* 步骤信息 = 取步骤信息_(当前步骤结点);
        auto* 任务头结点 = 归一到任务头_(当前步骤结点);
        if (!步骤信息 || !任务头结点 || !新方法首节点 || !步骤信息->允许切换方法) {
            return false;
        }
        auto* 头信息 = 取头信息_(任务头结点);
        结构_任务动作事件守卫 动作守卫(
            任务头结点->主信息,
            动作_尝试替换方法_(),
            头信息 ? 头信息->场景 : nullptr,
            头信息 ? 头信息->场景 : nullptr,
            结构体_时间戳::当前_微秒(),
            "纠偏任务执行器_v0::尝试替换方法/动作动态");

        const bool 绑定成功 = 任务管理器_v0{}.绑定方法(
            当前步骤结点,
            新方法首节点,
            true,
            "纠偏任务执行器_v0::尝试替换方法/绑定替代方法");
        if (!绑定成功) {
            动作守卫.设置结果(false, 1);
            return false;
        }

        任务类::设置任务状态(
            当前步骤结点,
            枚举_任务状态::就绪,
            "纠偏任务执行器_v0::尝试替换方法/步骤恢复就绪");
        任务类::设置任务状态(
            任务头结点,
            枚举_任务状态::就绪,
            "纠偏任务执行器_v0::尝试替换方法/任务恢复就绪");
        return true;
    }

    bool 尝试采用域树纠偏方法(
        任务节点类* 当前任务头结点,
        任务节点类* 当前步骤结点,
        方法节点类* 域树建议方法首节点) const
    {
        using namespace 任务控制总控模块_v0_内部;

        auto* 步骤信息 = 取步骤信息_(当前步骤结点);
        if (!步骤信息 || !当前任务头结点 || !域树建议方法首节点) {
            return false;
        }
        auto* 头信息 = 取头信息_(当前任务头结点);
        结构_任务动作事件守卫 动作守卫(
            当前任务头结点->主信息,
            动作_采用域树纠偏方法_(),
            头信息 ? 头信息->场景 : nullptr,
            头信息 ? 头信息->场景 : nullptr,
            结构体_时间戳::当前_微秒(),
            "纠偏任务执行器_v0::尝试采用域树纠偏方法/动作动态");

        auto* 当前已选方法 = 步骤信息->当前选中方法首节点;
        if (!当前已选方法) {
            if (!任务管理器_v0{}.绑定方法(
                当前步骤结点,
                域树建议方法首节点,
                true,
                "纠偏任务执行器_v0::尝试采用域树纠偏方法/绑定建议方法")) {
                动作守卫.设置结果(false, 1);
                return false;
            }
            任务类::设置任务状态(
                当前步骤结点,
                枚举_任务状态::就绪,
                "纠偏任务执行器_v0::尝试采用域树纠偏方法/步骤恢复就绪");
            任务类::设置任务状态(
                当前任务头结点,
                枚举_任务状态::就绪,
                "纠偏任务执行器_v0::尝试采用域树纠偏方法/任务恢复就绪");
            return true;
        }

        if (当前已选方法 == 域树建议方法首节点) {
            动作守卫.设置结果(false, 2);
            return false;
        }

        const bool ok = 尝试替换方法(当前步骤结点, 域树建议方法首节点);
        if (!ok) 动作守卫.设置结果(false, 3);
        return ok;
    }

    bool 尝试局部回退(
        任务节点类* 当前任务头结点,
        任务节点类* 当前步骤结点) const
    {
        using namespace 任务控制总控模块_v0_内部;

        auto* 步骤信息 = 取步骤信息_(当前步骤结点);
        auto* 头信息 = 取头信息_(当前任务头结点);
        if (!步骤信息 || !头信息) {
            return false;
        }
        结构_任务动作事件守卫 动作守卫(
            当前任务头结点->主信息,
            动作_尝试局部回退_(),
            头信息->场景,
            头信息->场景,
            结构体_时间戳::当前_微秒(),
            "纠偏任务执行器_v0::尝试局部回退/动作动态");

        const std::int32_t 回退上限 = 步骤信息->允许重试次数 > 0
            ? 步骤信息->允许重试次数
            : 1;
        if (步骤信息->已重试次数 >= 回退上限) {
            动作守卫.设置结果(false, 1);
            return false;
        }

        ++步骤信息->已重试次数;
        步骤信息->当前选中方法首节点 = nullptr;
        头信息->当前步骤节点 = 当前步骤结点;

        任务类::设置任务状态(
            当前步骤结点,
            枚举_任务状态::待重筹办,
            "纠偏任务执行器_v0::尝试局部回退/步骤待重筹办");
        任务类::设置任务状态(
            当前任务头结点,
            枚举_任务状态::待重筹办,
            "纠偏任务执行器_v0::尝试局部回退/任务待重筹办");
        return true;
    }

    bool 是否应直接转入收束(
        任务节点类* 当前任务头结点,
        任务节点类* 当前步骤结点,
        const 结构_任务返回消息& 最近反馈,
        const 结构_任务控制判定输入* 控制输入) const
    {
        using namespace 任务控制总控模块_v0_内部;

        if (最近反馈.需求已满足) {
            return true;
        }
        if (控制输入) {
            if (控制输入->安全要求必须停止
                || 控制输入->服务收益不足以继续
                || 控制输入->已确定无法继续) {
                return true;
            }
        }

        auto* 头信息 = 取头信息_(当前任务头结点);
        auto* 步骤信息 = 取步骤信息_(当前步骤结点);
        if (!头信息 || !步骤信息) {
            return true;
        }
        if (是否终结状态_(头信息->状态)) {
            return true;
        }

        const auto 回退上限 = 步骤信息->允许重试次数 > 0
            ? 步骤信息->允许重试次数
            : 1;
        const bool 已无替代方法 = 尝试查找替代方法(
            当前步骤结点,
            步骤信息->当前选中方法首节点) == nullptr;
        const bool 回退预算耗尽 = 步骤信息->已重试次数 >= 回退上限;
        return 已无替代方法 && 回退预算耗尽;
    }
};

export class 收束任务执行器_v0 : public 收束任务执行接口_v0
{
public:
    结构_收束返回 执行收束(
        任务节点类* 当前任务头结点,
        任务节点类* 当前步骤结点,
        任务节点类* 当前结果结点,
        方法节点类* 当前方法首节点,
        const 结构_任务返回消息& 最近反馈,
        方法节点类* 当前域方法树根 = nullptr,
        const 结构_任务控制判定输入* 控制输入 = nullptr) const override
    {
        using namespace 任务控制总控模块_v0_内部;

        结构_收束返回 返回{};
        auto* 任务头结点 = 归一到任务头_(当前任务头结点 ? 当前任务头结点 : 当前步骤结点);
        auto* 头信息 = 取头信息_(任务头结点);
        auto* 步骤结点 = 取步骤信息_(当前步骤结点)
            ? 当前步骤结点
            : 取当前或首个步骤_(任务头结点);
        auto* 步骤信息 = 取步骤信息_(步骤结点);
        auto* 结果结点 = 取结果信息_(当前结果结点)
            ? 当前结果结点
            : (头信息 ? 头信息->最近实际结果节点 : nullptr);

        返回.当前任务头结点 = 任务头结点;
        返回.当前步骤结点 = 步骤结点;
        返回.当前结果结点 = 结果结点;
        返回.当前方法首节点 = 步骤信息 && 步骤信息->当前选中方法首节点
            ? 步骤信息->当前选中方法首节点
            : 当前方法首节点;

        if (!任务头结点 || !头信息 || !步骤结点 || !步骤信息) {
            日志::运行_错误("[收束任务执行器_v0] 当前任务骨架损坏，无法收束");
            返回.结果 = 枚举_收束结果::收束失败;
            返回.原因说明 = "进入收束时关键结点为空";
            return 返回;
        }

        auto* 当前已选方法 = 步骤信息->当前选中方法首节点;
        auto* 域树收束建议方法 = 当前方法首节点;
        if ((!域树收束建议方法
            || 域树收束建议方法 == 当前已选方法
            || !方法可由执行适配器直接执行_(域树收束建议方法))
            && 当前域方法树根) {
            域树收束建议方法 = 解析域方法树建议方法首节点_(当前域方法树根);
        }
        if (域树收束建议方法 && 方法可由执行适配器直接执行_(域树收束建议方法)) {
            const bool 当前已选方法可直接执行 = 方法可由执行适配器直接执行_(当前已选方法);
            if (当前已选方法 == 域树收束建议方法) {
                返回.当前域建议方法首节点 = 域树收束建议方法;
                返回.当前方法首节点 = 域树收束建议方法;
            }
            else if ((!当前已选方法 || !当前已选方法可直接执行)
                && 尝试采用域树收束方法(步骤结点, 域树收束建议方法)) {
                日志::运行f(
                    "[收束任务执行器_v0] 已采用域树收束方法: 任务={}, 步骤={}, 新方法={}",
                    (void*)任务头结点,
                    (void*)步骤结点,
                    (void*)域树收束建议方法);
                返回.当前域建议方法首节点 = 域树收束建议方法;
                返回.当前方法首节点 = 域树收束建议方法;
            }
        }

        const bool 进入时已终结 = 是否终结状态_(头信息->状态);
        返回.结果 = 判定最终收束结果(任务头结点, 最近反馈, 控制输入);
        if (返回.结果 == 枚举_收束结果::收束失败) {
            日志::运行_错误("[收束任务执行器_v0] 无法判定最终收束结果");
            返回.原因说明 = "最终状态未定义";
            return 返回;
        }

        日志::运行f(
            "[收束任务执行器_v0] 开始收束: 任务={}, 步骤={}, 方法={}, 收束结果={}",
            (void*)任务头结点,
            (void*)步骤结点,
            (void*)返回.当前方法首节点,
            static_cast<int>(返回.结果));

        if (!应用最终任务状态(任务头结点, 步骤结点, 返回.结果)) {
            日志::运行_错误("[收束任务执行器_v0] 应用最终任务状态失败");
            返回.结果 = 枚举_收束结果::收束失败;
            返回.原因说明 = "应用最终任务状态失败";
            return 返回;
        }

        返回.是否已写反馈 = 写最终反馈(
            任务头结点,
            返回.当前方法首节点,
            最近反馈,
            返回.结果);
        if (!返回.是否已写反馈) {
            日志::运行_错误("[收束任务执行器_v0] 写最终反馈失败");
            返回.结果 = 枚举_收束结果::收束失败;
            返回.原因说明 = "写最终反馈失败";
            return 返回;
        }

        auto* 最新头信息 = 取头信息_(任务头结点);
        返回.当前结果结点 = 最新头信息 && 最新头信息->最近实际结果节点
            ? 最新头信息->最近实际结果节点
            : 返回.当前结果结点;

        if (!进入时已终结) {
            返回.是否已更新可靠度 = 更新方法可靠度(
                返回.当前方法首节点,
                最近反馈,
                返回.结果);
        }

        if (!清理临时状态(任务头结点, 步骤结点, 返回.当前结果结点)) {
            日志::运行_警告("[收束任务执行器_v0] 清理临时状态未完全成功");
        }

        返回.是否已归档 = 归档任务结果(任务头结点, 返回.当前结果结点);
        if (!返回.是否已归档) {
            日志::运行_错误("[收束任务执行器_v0] 归档任务结果失败");
            返回.结果 = 枚举_收束结果::收束失败;
            返回.原因说明 = "归档任务结果失败";
            return 返回;
        }

        switch (返回.结果) {
        case 枚举_收束结果::已完成收束:
            返回.原因说明 = "任务已完成并完成收束";
            break;
        case 枚举_收束结果::已失败收束:
            返回.原因说明 = "任务已失败并完成收束";
            break;
        case 枚举_收束结果::已取消收束:
            返回.原因说明 = "任务已取消并完成收束";
            break;
        default:
            返回.原因说明 = "收束结果未定义";
            break;
        }

        日志::运行f(
            "[收束任务执行器_v0] 收束完成: 任务={}, 收束结果={}, 已归档={}",
            (void*)任务头结点,
            static_cast<int>(返回.结果),
            返回.是否已归档);
        return 返回;
    }

private:
    bool 尝试采用域树收束方法(
        任务节点类* 当前步骤结点,
        方法节点类* 域树建议方法首节点) const
    {
        using namespace 任务控制总控模块_v0_内部;

        auto* 步骤信息 = 取步骤信息_(当前步骤结点);
        if (!步骤信息 || !当前步骤结点 || !域树建议方法首节点) {
            return false;
        }
        if (步骤信息->当前选中方法首节点 == 域树建议方法首节点) {
            return true;
        }
        if (步骤信息->当前选中方法首节点 && !步骤信息->允许切换方法) {
            return false;
        }

        return 任务管理器_v0{}.绑定方法(
            当前步骤结点,
            域树建议方法首节点,
            true,
            "收束任务执行器_v0::尝试采用域树收束方法/绑定建议方法");
    }

    枚举_收束结果 判定最终收束结果(
        任务节点类* 当前任务头结点,
        const 结构_任务返回消息& 最近反馈,
        const 结构_任务控制判定输入* 控制输入) const
    {
        using namespace 任务控制总控模块_v0_内部;

        auto* 头信息 = 取头信息_(当前任务头结点);
        if (!头信息) {
            return 枚举_收束结果::收束失败;
        }

        if (最近反馈.需求已满足
            || 头信息->状态 == 枚举_任务状态::完成
            || (控制输入 && 控制输入->已满足完成判据)) {
            return 枚举_收束结果::已完成收束;
        }

        if (头信息->状态 == 枚举_任务状态::取消
            || 头信息->状态 == 枚举_任务状态::挂起
            || (控制输入 && 控制输入->服务收益不足以继续)) {
            return 枚举_收束结果::已取消收束;
        }

        if (头信息->状态 == 枚举_任务状态::失败
            || 头信息->状态 == 枚举_任务状态::无法执行
            || 头信息->状态 == 枚举_任务状态::超时
            || 最近反馈.类型 == 枚举_任务返回消息类型::步骤失败
            || 最近反馈.类型 == 枚举_任务返回消息类型::步骤无法执行
            || (控制输入 && (控制输入->已确定无法继续 || 控制输入->安全要求必须停止))) {
            return 枚举_收束结果::已失败收束;
        }

        return 枚举_收束结果::收束失败;
    }

    bool 应用最终任务状态(
        任务节点类* 当前任务头结点,
        任务节点类* 当前步骤结点,
        枚举_收束结果 收束结果) const
    {
        using namespace 任务控制总控模块_v0_内部;

        if (!当前任务头结点) {
            return false;
        }
        auto* 头信息 = 取头信息_(当前任务头结点);
        结构_任务动作事件守卫 动作守卫(
            当前任务头结点->主信息,
            动作_应用最终任务状态_(),
            头信息 ? 头信息->场景 : nullptr,
            头信息 ? 头信息->场景 : nullptr,
            结构体_时间戳::当前_微秒(),
            "收束任务执行器_v0::应用最终任务状态/动作动态");

        任务管理器_v0 任务管理;
        switch (收束结果) {
        case 枚举_收束结果::已完成收束: {
            const auto 结果 = 任务管理.完成任务(
                当前任务头结点,
                "收束任务执行器_v0::应用最终任务状态/完成");
            if (结果.成功) {
                return true;
            }
            if (当前步骤结点) {
                任务类::设置任务状态(
                    当前步骤结点,
                    枚举_任务状态::完成,
                    "收束任务执行器_v0::应用最终任务状态/步骤完成");
            }
            任务类::设置任务状态(
                当前任务头结点,
                枚举_任务状态::完成,
                "收束任务执行器_v0::应用最终任务状态/任务完成");
            return true;
        }
        case 枚举_收束结果::已失败收束: {
            const auto 结果 = 任务管理.失败任务(
                当前任务头结点,
                "收束任务执行器_v0::应用最终任务状态/失败");
            if (结果.成功) {
                return true;
            }
            if (当前步骤结点) {
                任务类::设置任务状态(
                    当前步骤结点,
                    枚举_任务状态::失败,
                    "收束任务执行器_v0::应用最终任务状态/步骤失败");
            }
            任务类::设置任务状态(
                当前任务头结点,
                枚举_任务状态::失败,
                "收束任务执行器_v0::应用最终任务状态/任务失败");
            return true;
        }
        case 枚举_收束结果::已取消收束:
            if (当前步骤结点) {
                任务类::设置任务状态(
                    当前步骤结点,
                    枚举_任务状态::取消,
                    "收束任务执行器_v0::应用最终任务状态/步骤取消");
            }
            任务类::逻辑取消任务(
                当前任务头结点,
                "收束任务执行器_v0::应用最终任务状态/任务取消");
            return true;
        default:
            动作守卫.设置结果(false, 1);
            return false;
        }
    }

    bool 写最终反馈(
        任务节点类* 当前任务头结点,
        方法节点类* 当前方法首节点,
        const 结构_任务返回消息& 最近反馈,
        枚举_收束结果 收束结果) const
    {
        if (!当前任务头结点) {
            return false;
        }

        任务类::结构_创建结果参数 结果参数{};
        结果参数.所属任务头结点 = 当前任务头结点;
        结果参数.来源方法首节点 = 当前方法首节点;
        结果参数.结果角色 = 枚举_任务结果角色::实际结果;

        switch (收束结果) {
        case 枚举_收束结果::已完成收束:
            结果参数.初始状态 = 枚举_任务状态::完成;
            结果参数.错误码 = 0;
            break;
        case 枚举_收束结果::已失败收束:
            结果参数.初始状态 = 枚举_任务状态::失败;
            结果参数.错误码 =
                最近反馈.类型 == 枚举_任务返回消息类型::未定义
                ? static_cast<std::int64_t>(1)
                : static_cast<std::int64_t>(最近反馈.类型);
            break;
        case 枚举_收束结果::已取消收束:
            结果参数.初始状态 = 枚举_任务状态::取消;
            结果参数.错误码 = 0;
            break;
        default:
            return false;
        }

        auto 反馈结果 = 任务管理器_v0{}.写入反馈(
            当前任务头结点,
            结果参数,
            "收束任务执行器_v0::写最终反馈");
        return 反馈结果.成功 && 反馈结果.结果节点 != nullptr;
    }

    bool 更新方法可靠度(
        方法节点类* 当前方法首节点,
        const 结构_任务返回消息& 最近反馈,
        枚举_收束结果 收束结果) const
    {
        if (!当前方法首节点) {
            return false;
        }

        auto 可靠度反馈 = 最近反馈;
        if (可靠度反馈.类型 == 枚举_任务返回消息类型::未定义) {
            可靠度反馈.类型 = 收束结果 == 枚举_收束结果::已完成收束
                ? 枚举_任务返回消息类型::步骤完成
                : 枚举_任务返回消息类型::步骤失败;
            可靠度反馈.需求已满足 = (收束结果 == 枚举_收束结果::已完成收束);
            可靠度反馈.需要重筹办 = false;
        }

        const bool 结果稳定出现 =
            收束结果 == 枚举_收束结果::已完成收束
            && 可靠度反馈.类型 == 枚举_任务返回消息类型::步骤完成
            && !可靠度反馈.需要重筹办;

        return 任务控制总控模块_v0_内部::更新方法可靠度统计_(
            当前方法首节点,
            结果稳定出现,
            结构体_时间戳::当前_微秒());
    }

    bool 清理临时状态(
        任务节点类* 当前任务头结点,
        任务节点类* 当前步骤结点,
        任务节点类* 当前结果结点) const
    {
        using namespace 任务控制总控模块_v0_内部;

        auto* 头信息 = 取头信息_(当前任务头结点);
        if (!头信息) {
            return false;
        }

        const 时间戳 now = 结构体_时间戳::当前_微秒();
        头信息->等待学习唤醒 = false;
        头信息->等待学习方法首节点 = nullptr;
        (void)任务类::设置任务当前步骤(
            头信息,
            nullptr,
            now,
            "收束任务执行器_v0::清理临时状态/清理当前步骤");
        (void)任务类::设置任务当前子任务(
            头信息,
            nullptr,
            now,
            "收束任务执行器_v0::清理临时状态/清理当前子任务");
        (void)任务类::设置任务当前分支动作(
            头信息,
            枚举_分支选择动作::未定义,
            now,
            "收束任务执行器_v0::清理临时状态/清理当前分支动作");

        if (当前步骤结点) {
            (void)任务类::设置任务当前子任务(
                当前步骤结点->主信息,
                nullptr,
                now,
                "收束任务执行器_v0::清理临时状态/步骤清理当前子任务");
            if (auto* 步骤信息 = 取步骤信息_(当前步骤结点)) {
                步骤信息->当前子任务头结点 = nullptr;
            }
        }
        if (当前结果结点) {
            (void)当前结果结点;
        }
        return true;
    }

    bool 归档任务结果(
        任务节点类* 当前任务头结点,
        任务节点类* 当前结果结点) const
    {
        using namespace 任务控制总控模块_v0_内部;

        auto* 头信息 = 取头信息_(当前任务头结点);
        if (!头信息) {
            return false;
        }

        auto* 最终结果结点 = 当前结果结点
            ? 当前结果结点
            : 头信息->最近实际结果节点;
        if (!最终结果结点) {
            return false;
        }

        (void)任务类::设置任务最近结果节点(
            头信息,
            最终结果结点,
            结构体_时间戳::当前_微秒(),
            "收束任务执行器_v0::归档任务结果/设置最近结果");
        return true;
    }
};

export class 任务控制总控模块_v0
{
public:
    任务控制总控模块_v0() = default;

    任务控制总控模块_v0(
        功能域判定接口_v0& 功能域判定器,
        筹办任务执行接口_v0& 筹办执行器)
        : 功能域判定器引用_(&功能域判定器),
        筹办执行器引用_(&筹办执行器)
    {
    }

    任务控制总控模块_v0(
        功能域判定接口_v0& 功能域判定器,
        筹办任务执行接口_v0& 筹办执行器,
        维护任务执行接口_v0& 维护执行器)
        : 功能域判定器引用_(&功能域判定器),
        筹办执行器引用_(&筹办执行器),
        维护执行器引用_(&维护执行器)
    {
    }

    任务控制总控模块_v0(
        功能域判定接口_v0& 功能域判定器,
        筹办任务执行接口_v0& 筹办执行器,
        维护任务执行接口_v0& 维护执行器,
        纠偏任务执行接口_v0& 纠偏执行器)
        : 功能域判定器引用_(&功能域判定器),
        筹办执行器引用_(&筹办执行器),
        维护执行器引用_(&维护执行器),
        纠偏执行器引用_(&纠偏执行器)
    {
    }

    任务控制总控模块_v0(
        功能域判定接口_v0& 功能域判定器,
        筹办任务执行接口_v0& 筹办执行器,
        维护任务执行接口_v0& 维护执行器,
        纠偏任务执行接口_v0& 纠偏执行器,
        收束任务执行接口_v0& 收束执行器)
        : 功能域判定器引用_(&功能域判定器),
        筹办执行器引用_(&筹办执行器),
        维护执行器引用_(&维护执行器),
        纠偏执行器引用_(&纠偏执行器),
        收束执行器引用_(&收束执行器)
    {
    }

    结构_任务控制判定结果 判定当前功能域(
        const 结构_任务控制判定输入& 输入) const
    {
        if (功能域判定器引用_) {
            结构_任务控制判定结果 结果{};
            结果.功能域 = 功能域判定器引用_->判定(输入);
            return 结果;
        }
        return 计算任务控制功能域判定结果_v0(输入);
    }

    bool 确保四域方法树已注册() const
    {
        return 四域方法树注册器_.注册全部四域方法树();
    }

    方法节点类* 获取功能域方法树根(枚举_任务控制功能域 功能域) const
    {
        (void)确保四域方法树已注册();
        switch (功能域) {
        case 枚举_任务控制功能域::筹办:
            return 四域方法树注册器_.获取筹办方法树根();
        case 枚举_任务控制功能域::维护:
            return 四域方法树注册器_.获取维护方法树根();
        case 枚举_任务控制功能域::纠偏:
            return 四域方法树注册器_.获取纠偏方法树根();
        case 枚举_任务控制功能域::收束:
            return 四域方法树注册器_.获取收束方法树根();
        default:
            return nullptr;
        }
    }

    void 同步当前域方法树根(结构_总控返回& 返回值) const
    {
        返回值.当前域方法树根 = 获取功能域方法树根(返回值.当前功能域);
    }

    void 同步下一域方法树根(结构_总控返回& 返回值) const
    {
        返回值.下一域方法树根 = 获取功能域方法树根(返回值.下一功能域);
    }

    void 设置下一功能域(结构_总控返回& 返回值, 枚举_任务控制功能域 下一功能域) const
    {
        返回值.下一功能域 = 下一功能域;
        同步下一域方法树根(返回值);
    }

    std::string 构造域条件主键(
        枚举_任务控制功能域 功能域,
        const 结构_任务控制判定输入& 输入,
        任务节点类* 当前任务头结点,
        方法节点类* 当前方法首节点) const
    {
        using namespace 任务控制总控模块_v0_内部;

        结构_四域方法树条件签名输入_v0 条件输入{};
        条件输入.域标签 = 功能域标签_(功能域);
        条件输入.任务虚拟存在 = 取任务虚拟存在_(当前任务头结点);
        条件输入.当前方法首节点 = 当前方法首节点;
        条件输入.安全值_Q10000 = 输入.安全值_Q10000;
        条件输入.服务值_Q10000 = 输入.服务值_Q10000;
        条件输入.需求值_Q10000 = 输入.需求值_Q10000;
        条件输入.当前预算_Q10000 = 输入.当前预算_Q10000;
        条件输入.最近结果稳定 = 输入.最近结果稳定;
        条件输入.最近执行失败 = 输入.最近执行失败;
        条件输入.风险变坏 = 输入.风险变坏;
        条件输入.检查点通过 = 输入.检查点通过;
        条件输入.依赖缺失 = 输入.依赖缺失;
        条件输入.需要新子任务或新步骤 = 输入.需要新子任务或新步骤;
        条件输入.关键方法不再可用 = 输入.关键方法不再可用;
        条件输入.已满足完成判据 = 输入.已满足完成判据;
        return 四域方法树匹配器_v0::生成条件主键(条件输入);
    }

    void 记录方法树稳定复现(
        方法节点类* 方法首节点,
        bool 结果稳定出现,
        const std::string& 调用点) const
    {
        if (!方法首节点) {
            return;
        }

        const auto now = 结构体_时间戳::当前_微秒();
        (void)四域方法树生长判定器_.记录运行结果(
            方法首节点,
            结果稳定出现,
            now,
            调用点 + "/记录运行结果");
        const auto 判定结果 = 四域方法树生长判定器_.判定(方法首节点);
        (void)四域方法树生长判定器_.应用升级(
            方法首节点,
            判定结果,
            调用点 + "/应用升级");
    }

    方法节点类* 写回成功路径并尝试升级(
        枚举_任务控制功能域 功能域,
        方法节点类* 当前域方法树根,
        方法节点类* 父结果节点,
        const std::string& 条件主键,
        方法节点类* 已成功方法首节点,
        bool 结果稳定出现,
        枚举_方法沉淀来源 来源,
        const std::string& 调用点) const
    {
        using namespace 任务控制总控模块_v0_内部;

        if (!当前域方法树根 || !已成功方法首节点 || 条件主键.empty()) {
            return nullptr;
        }

        std::string 动作名{};
        结构体_动作句柄 动作句柄{};
        if (!提取动作信息_(已成功方法首节点, 动作名, 动作句柄)) {
            return nullptr;
        }

        结构_四域方法树写回请求_v0 写回请求{};
        写回请求.域方法树根 = 当前域方法树根;
        写回请求.父结果节点 = 父结果节点;
        写回请求.条件主键 = 条件主键;
        写回请求.动作名 = 动作名.empty()
            ? std::string("四域自动生长/") + 功能域标签_(功能域)
            : 动作名;
        写回请求.动作句柄 = 动作句柄;
        写回请求.来源 = 来源;

        const auto 写回结果 = 四域方法树写回器_.按成功路径写回(写回请求);
        if (!写回结果.成功 || !写回结果.写回首节点) {
            return nullptr;
        }

        记录方法树稳定复现(
            写回结果.写回首节点,
            结果稳定出现,
            调用点 + "/记录稳定复现");
        return 写回结果.写回首节点;
    }

    结构_总控返回 处理任务入口(const 结构_任务控制判定输入& 输入) const
    {
        结构_总控返回 返回值{};

        功能域判定器_v0 默认功能域判定器{};
        缺方法分流器_v0 默认缺方法分流器{ 输入 };
        筹办任务执行器_v0 默认筹办执行器{ 默认缺方法分流器 };
        方法执行适配器_v0 默认方法执行适配器{};
        维护任务执行器_v0 默认维护执行器{ 默认方法执行适配器 };
        纠偏任务执行器_v0 默认纠偏执行器{};
        收束任务执行器_v0 默认收束执行器{};

        auto& 功能域判定器 =
            功能域判定器引用_ ? *功能域判定器引用_ : 默认功能域判定器;
        auto& 筹办执行器 =
            筹办执行器引用_ ? *筹办执行器引用_ : 默认筹办执行器;
        auto& 维护执行器 =
            维护执行器引用_ ? *维护执行器引用_ : 默认维护执行器;
        auto& 纠偏执行器 =
            纠偏执行器引用_ ? *纠偏执行器引用_ : 默认纠偏执行器;
        auto& 收束执行器 =
            收束执行器引用_ ? *收束执行器引用_ : 默认收束执行器;

        返回值.当前功能域 = 功能域判定器.判定(输入);
        同步当前域方法树根(返回值);
        返回值.当前域建议方法首节点 = nullptr;

        if (返回值.当前功能域 == 枚举_任务控制功能域::筹办) {
            const auto 筹办返回 = 筹办执行器.执行筹办(输入, 返回值.当前域方法树根);
            if (筹办返回.当前域建议方法首节点) {
                返回值.当前域建议方法首节点 = 筹办返回.当前域建议方法首节点;
            }
            返回值.当前任务头结点 = 筹办返回.当前任务头结点;
            返回值.当前步骤结点 = 筹办返回.当前步骤结点;
            返回值.当前结果结点 = 筹办返回.当前结果结点;
            返回值.当前方法首节点 = 筹办返回.当前选中方法首节点;
            返回值.原因说明 = 筹办返回.原因说明;
            if (筹办返回.结果 == 枚举_筹办结果::已可执行
                && 返回值.当前方法首节点) {
                const auto 条件主键 = 构造域条件主键(
                    枚举_任务控制功能域::筹办,
                    输入,
                    返回值.当前任务头结点,
                    返回值.当前方法首节点);
                if (返回值.当前域建议方法首节点) {
                    记录方法树稳定复现(
                        返回值.当前域建议方法首节点,
                        true,
                        "任务控制总控模块_v0::处理任务入口/筹办/稳定复现");
                }
                else if (auto* 写回首节点 = 写回成功路径并尝试升级(
                    枚举_任务控制功能域::筹办,
                    返回值.当前域方法树根,
                    nullptr,
                    条件主键,
                    返回值.当前方法首节点,
                    true,
                    枚举_方法沉淀来源::运行期临时,
                    "任务控制总控模块_v0::处理任务入口/筹办/写回")) {
                    返回值.当前域建议方法首节点 = 写回首节点;
                }
            }

            switch (筹办返回.结果) {
            case 枚举_筹办结果::已可执行:
                返回值.结果 = 枚举_总控结果::已可执行;
                设置下一功能域(返回值, 枚举_任务控制功能域::维护);
                return 返回值;
            case 枚举_筹办结果::已等待学习:
                返回值.结果 = 枚举_总控结果::已等待学习;
                设置下一功能域(返回值, 枚举_任务控制功能域::筹办);
                return 返回值;
            case 枚举_筹办结果::筹办失败:
                返回值.结果 = 枚举_总控结果::需进入收束;
                设置下一功能域(返回值, 枚举_任务控制功能域::收束);
                return 返回值;
            default:
                返回值.结果 = 枚举_总控结果::控制失败;
                返回值.原因说明 = "筹办返回结果未定义";
                同步下一域方法树根(返回值);
                return 返回值;
            }
        }
        else if (返回值.当前功能域 == 枚举_任务控制功能域::维护) {
            using namespace 任务控制总控模块_v0_内部;

            auto* 当前任务头结点 = 归一到任务头_(输入.当前任务);
            auto* 当前步骤结点 = 取当前或首个步骤_(当前任务头结点);
            auto* 当前结果结点 = 当前任务头结点 && 取头信息_(当前任务头结点)
                ? 取头信息_(当前任务头结点)->最近实际结果节点
                : nullptr;
            auto* 当前方法首节点 = 当前步骤结点 && 取步骤信息_(当前步骤结点)
                ? 取步骤信息_(当前步骤结点)->当前选中方法首节点
                : nullptr;
            const auto 当前条件主键 = 构造域条件主键(
                枚举_任务控制功能域::维护,
                输入,
                当前任务头结点,
                当前方法首节点);
            结构_四域方法树匹配请求_v0 维护匹配请求{};
            维护匹配请求.域方法树根 = 返回值.当前域方法树根;
            维护匹配请求.条件主键 = 当前条件主键;
            const auto 维护树匹配结果 = 四域方法树匹配器_v0{}.匹配(维护匹配请求);
            if (维护树匹配结果.找到 && 维护树匹配结果.建议执行首节点) {
                返回值.当前域建议方法首节点 = 维护树匹配结果.建议执行首节点;
                if (当前步骤结点
                    && (!当前方法首节点 || !方法可由执行适配器直接执行_(当前方法首节点))
                    && 方法可由执行适配器直接执行_(维护树匹配结果.建议执行首节点)) {
                    (void)任务管理器_v0{}.绑定方法(
                        当前步骤结点,
                        维护树匹配结果.建议执行首节点,
                        true,
                        "任务控制总控模块_v0::处理任务入口/维护/绑定域树方法");
                    当前方法首节点 = 维护树匹配结果.建议执行首节点;
                }
                else if (!当前方法首节点) {
                    当前方法首节点 = 维护树匹配结果.建议执行首节点;
                }
            }

            const auto 维护返回 = 维护执行器.执行维护(
                当前任务头结点,
                当前步骤结点,
                当前结果结点,
                当前方法首节点,
                返回值.当前域方法树根);
            if (维护返回.当前域建议方法首节点) {
                返回值.当前域建议方法首节点 = 维护返回.当前域建议方法首节点;
            }
            返回值.当前任务头结点 = 维护返回.当前任务头结点;
            返回值.当前步骤结点 = 维护返回.当前步骤结点;
            返回值.当前结果结点 = 维护返回.当前结果结点;
            返回值.当前方法首节点 = 维护返回.当前方法首节点;
            返回值.原因说明 = 维护返回.原因说明;
            if (维护返回.结果 != 枚举_维护结果::维护失败 && 返回值.当前方法首节点) {
                if (返回值.当前域建议方法首节点) {
                    记录方法树稳定复现(
                        返回值.当前域建议方法首节点,
                        维护返回.本次结果稳定出现,
                        "任务控制总控模块_v0::处理任务入口/维护/稳定复现");
                }
                else if (auto* 写回首节点 = 写回成功路径并尝试升级(
                    枚举_任务控制功能域::维护,
                    返回值.当前域方法树根,
                    维护树匹配结果.父结果节点,
                    当前条件主键,
                    返回值.当前方法首节点,
                    维护返回.本次结果稳定出现,
                    枚举_方法沉淀来源::运行期临时,
                    "任务控制总控模块_v0::处理任务入口/维护/写回")) {
                    返回值.当前域建议方法首节点 = 写回首节点;
                }
            }

            switch (维护返回.结果) {
            case 枚举_维护结果::继续维护:
                返回值.结果 = 枚举_总控结果::已可执行;
                设置下一功能域(返回值, 枚举_任务控制功能域::维护);
                return 返回值;
            case 枚举_维护结果::转入纠偏:
                返回值.结果 = 枚举_总控结果::需进入纠偏;
                设置下一功能域(返回值, 枚举_任务控制功能域::纠偏);
                return 返回值;
            case 枚举_维护结果::转入收束:
                返回值.结果 = 枚举_总控结果::需进入收束;
                设置下一功能域(返回值, 枚举_任务控制功能域::收束);
                return 返回值;
            case 枚举_维护结果::回到筹办:
                返回值.结果 = 枚举_总控结果::需回到筹办;
                设置下一功能域(返回值, 枚举_任务控制功能域::筹办);
                return 返回值;
            default:
                返回值.结果 = 枚举_总控结果::控制失败;
                返回值.原因说明 = 维护返回.原因说明.empty()
                    ? "维护返回结果未定义"
                    : 维护返回.原因说明;
                同步下一域方法树根(返回值);
                return 返回值;
            }
        }
        else if (返回值.当前功能域 == 枚举_任务控制功能域::纠偏) {
            using namespace 任务控制总控模块_v0_内部;

            auto* 当前任务头结点 = 归一到任务头_(输入.当前任务);
            auto* 当前步骤结点 = 取当前或首个步骤_(当前任务头结点);
            auto* 当前结果结点 = 当前任务头结点 && 取头信息_(当前任务头结点)
                ? 取头信息_(当前任务头结点)->最近实际结果节点
                : nullptr;
            auto* 当前方法首节点 = 当前步骤结点 && 取步骤信息_(当前步骤结点)
                ? 取步骤信息_(当前步骤结点)->当前选中方法首节点
                : nullptr;
            const auto 最近反馈 = 构造最近反馈_自输入_(输入);
            const auto 当前条件主键 = 构造域条件主键(
                枚举_任务控制功能域::纠偏,
                输入,
                当前任务头结点,
                当前方法首节点);
            结构_四域方法树匹配请求_v0 纠偏匹配请求{};
            纠偏匹配请求.域方法树根 = 返回值.当前域方法树根;
            纠偏匹配请求.条件主键 = 当前条件主键;
            const auto 纠偏树匹配结果 = 四域方法树匹配器_v0{}.匹配(纠偏匹配请求);
            if (纠偏树匹配结果.找到 && 纠偏树匹配结果.建议执行首节点) {
                返回值.当前域建议方法首节点 = 纠偏树匹配结果.建议执行首节点;
                if (!当前方法首节点
                    || !方法可由执行适配器直接执行_(当前方法首节点)) {
                    当前方法首节点 = 纠偏树匹配结果.建议执行首节点;
                }
            }

            const auto 纠偏返回 = 纠偏执行器.执行纠偏(
                当前任务头结点,
                当前步骤结点,
                当前结果结点,
                当前方法首节点,
                最近反馈,
                返回值.当前域方法树根,
                &输入);
            if (纠偏返回.当前域建议方法首节点) {
                返回值.当前域建议方法首节点 = 纠偏返回.当前域建议方法首节点;
            }
            返回值.当前任务头结点 = 纠偏返回.当前任务头结点;
            返回值.当前步骤结点 = 纠偏返回.当前步骤结点;
            返回值.当前结果结点 = 纠偏返回.当前结果结点;
            返回值.当前方法首节点 = 纠偏返回.当前方法首节点;
            返回值.原因说明 = 纠偏返回.原因说明;
            if (纠偏返回.结果 != 枚举_纠偏结果::纠偏失败 && 返回值.当前方法首节点) {
                if (返回值.当前域建议方法首节点) {
                    记录方法树稳定复现(
                        返回值.当前域建议方法首节点,
                        true,
                        "任务控制总控模块_v0::处理任务入口/纠偏/稳定复现");
                }
                else if (auto* 写回首节点 = 写回成功路径并尝试升级(
                    枚举_任务控制功能域::纠偏,
                    返回值.当前域方法树根,
                    纠偏树匹配结果.父结果节点,
                    当前条件主键,
                    返回值.当前方法首节点,
                    true,
                    枚举_方法沉淀来源::运行期临时,
                    "任务控制总控模块_v0::处理任务入口/纠偏/写回")) {
                    返回值.当前域建议方法首节点 = 写回首节点;
                }
            }

            switch (纠偏返回.结果) {
            case 枚举_纠偏结果::已恢复维护:
                返回值.结果 = 枚举_总控结果::已可执行;
                设置下一功能域(返回值, 枚举_任务控制功能域::维护);
                return 返回值;
            case 枚举_纠偏结果::回到筹办:
                返回值.结果 = 枚举_总控结果::需回到筹办;
                设置下一功能域(返回值, 枚举_任务控制功能域::筹办);
                return 返回值;
            case 枚举_纠偏结果::转入收束:
                返回值.结果 = 枚举_总控结果::需进入收束;
                设置下一功能域(返回值, 枚举_任务控制功能域::收束);
                return 返回值;
            default:
                返回值.结果 = 枚举_总控结果::控制失败;
                返回值.原因说明 = 纠偏返回.原因说明.empty()
                    ? "纠偏返回结果未定义"
                    : 纠偏返回.原因说明;
                同步下一域方法树根(返回值);
                return 返回值;
            }
        }
        else if (返回值.当前功能域 == 枚举_任务控制功能域::收束) {
            using namespace 任务控制总控模块_v0_内部;

            auto* 当前任务头结点 = 归一到任务头_(输入.当前任务);
            auto* 当前步骤结点 = 取当前或首个步骤_(当前任务头结点);
            auto* 当前结果结点 = 当前任务头结点 && 取头信息_(当前任务头结点)
                ? 取头信息_(当前任务头结点)->最近实际结果节点
                : nullptr;
            auto* 当前方法首节点 = 当前步骤结点 && 取步骤信息_(当前步骤结点)
                ? 取步骤信息_(当前步骤结点)->当前选中方法首节点
                : nullptr;
            const auto 最近反馈 = 构造最近反馈_自输入_(输入);
            const auto 当前条件主键 = 构造域条件主键(
                枚举_任务控制功能域::收束,
                输入,
                当前任务头结点,
                当前方法首节点);
            结构_四域方法树匹配请求_v0 收束匹配请求{};
            收束匹配请求.域方法树根 = 返回值.当前域方法树根;
            收束匹配请求.条件主键 = 当前条件主键;
            const auto 收束树匹配结果 = 四域方法树匹配器_v0{}.匹配(收束匹配请求);
            if (收束树匹配结果.找到 && 收束树匹配结果.建议执行首节点) {
                if (!当前方法首节点
                    || !方法可由执行适配器直接执行_(当前方法首节点)) {
                    当前方法首节点 = 收束树匹配结果.建议执行首节点;
                }
            }

            const auto 收束返回 = 收束执行器.执行收束(
                当前任务头结点,
                当前步骤结点,
                当前结果结点,
                当前方法首节点,
                最近反馈,
                返回值.当前域方法树根,
                &输入);
            返回值.当前域建议方法首节点 = 收束返回.当前域建议方法首节点;
            返回值.当前任务头结点 = 收束返回.当前任务头结点;
            返回值.当前步骤结点 = 收束返回.当前步骤结点;
            返回值.当前结果结点 = 收束返回.当前结果结点;
            返回值.当前方法首节点 = 收束返回.当前方法首节点;
            返回值.原因说明 = 收束返回.原因说明;
            设置下一功能域(返回值, 枚举_任务控制功能域::未定义);
            if (收束返回.结果 != 枚举_收束结果::收束失败 && 返回值.当前方法首节点) {
                if (返回值.当前域建议方法首节点) {
                    记录方法树稳定复现(
                        返回值.当前域建议方法首节点,
                        true,
                        "任务控制总控模块_v0::处理任务入口/收束/稳定复现");
                }
                else if (auto* 写回首节点 = 写回成功路径并尝试升级(
                    枚举_任务控制功能域::收束,
                    返回值.当前域方法树根,
                    收束树匹配结果.父结果节点,
                    当前条件主键,
                    返回值.当前方法首节点,
                    true,
                    枚举_方法沉淀来源::运行期临时,
                    "任务控制总控模块_v0::处理任务入口/收束/写回")) {
                    返回值.当前域建议方法首节点 = 写回首节点;
                }
            }

            switch (收束返回.结果) {
            case 枚举_收束结果::已完成收束:
                返回值.结果 = 枚举_总控结果::已完成收束;
                return 返回值;
            case 枚举_收束结果::已失败收束:
                返回值.结果 = 枚举_总控结果::已失败收束;
                return 返回值;
            case 枚举_收束结果::已取消收束:
                返回值.结果 = 枚举_总控结果::已取消收束;
                return 返回值;
            default:
                返回值.结果 = 枚举_总控结果::控制失败;
                返回值.原因说明 = 收束返回.原因说明.empty()
                    ? "收束返回结果未定义"
                    : 收束返回.原因说明;
                同步下一域方法树根(返回值);
                return 返回值;
            }
        }

        返回值.结果 = 枚举_总控结果::控制失败;
        返回值.原因说明 = "当前版本未命中有效功能域入口";
        同步下一域方法树根(返回值);
        return 返回值;
    }

    bool 执行筹办任务(const 结构_任务控制判定输入& 输入) const
    {
        const auto 返回 = 处理任务入口(输入);
        return 返回.结果 == 枚举_总控结果::已可执行
            || 返回.结果 == 枚举_总控结果::已等待学习;
    }

    bool 执行维护任务(const 结构_任务控制判定输入& 输入) const
    {
        const auto 返回 = 处理任务入口(输入);
        return 返回.结果 == 枚举_总控结果::已可执行
            || 返回.结果 == 枚举_总控结果::需进入纠偏
            || 返回.结果 == 枚举_总控结果::需进入收束
            || 返回.结果 == 枚举_总控结果::需回到筹办;
    }

    bool 执行纠偏任务(const 结构_任务控制判定输入& 输入) const
    {
        const auto 返回 = 处理任务入口(输入);
        return 返回.结果 == 枚举_总控结果::已可执行
            || 返回.结果 == 枚举_总控结果::需回到筹办
            || 返回.结果 == 枚举_总控结果::需进入收束;
    }

    bool 执行收束任务(const 结构_任务控制判定输入& 输入) const
    {
        const auto 返回 = 处理任务入口(输入);
        return 返回.结果 == 枚举_总控结果::已完成收束
            || 返回.结果 == 枚举_总控结果::已失败收束
            || 返回.结果 == 枚举_总控结果::已取消收束;
    }

private:
    功能域判定接口_v0* 功能域判定器引用_ = nullptr;
    筹办任务执行接口_v0* 筹办执行器引用_ = nullptr;
    维护任务执行接口_v0* 维护执行器引用_ = nullptr;
    纠偏任务执行接口_v0* 纠偏执行器引用_ = nullptr;
    收束任务执行接口_v0* 收束执行器引用_ = nullptr;
    mutable 方法类 四域方法树方法集_{}; 
    mutable 四域方法树注册器_v0 四域方法树注册器_{ 四域方法树方法集_ };
    mutable 四域方法树写回器_v0 四域方法树写回器_{ 四域方法树方法集_ };
    mutable 四域方法树生长判定器_v0 四域方法树生长判定器_{};
};

export struct 结构_总控回归轨迹项_v0
{
    std::int32_t 轮次 = 0;
    枚举_任务控制功能域 当前功能域 = 枚举_任务控制功能域::未定义;
    枚举_任务控制功能域 下一功能域 = 枚举_任务控制功能域::未定义;
    枚举_总控结果 结果 = 枚举_总控结果::未定义;
    std::string 原因说明{};
};

export struct 结构_总控回归结果_v0
{
    bool 成功 = false;
    bool 已经过筹办 = false;
    bool 已经过维护 = false;
    bool 已经过纠偏 = false;
    bool 已经过收束 = false;
    bool 已到达终态 = false;
    std::string 错误摘要{};
    std::vector<结构_总控回归轨迹项_v0> 轨迹{};
};

export struct 结构_方法树自动生长回归结果_v0
{
    bool 成功 = false;
    bool 已完成写回 = false;
    bool 已命中写回枝条 = false;
    bool 已验证三次前不升级 = false;
    bool 已升格候选枝 = false;
    bool 已升格正式组合枝 = false;
    枚举_方法沉淀来源 最终来源 = 枚举_方法沉淀来源::未定义;
    std::string 错误摘要{};
};

export class 任务控制总控回归测试_v0
{
public:
    static 结构_总控回归结果_v0 测试_筹办维护纠偏收束全链()
    {
        struct 假筹办执行器 final : public 筹办任务执行接口_v0
        {
            结构_筹办返回 执行筹办(
                const 结构_任务控制判定输入&,
                方法节点类* 当前域方法树根) const override
            {
                结构_筹办返回 返回{};
                返回.当前域建议方法首节点 = 当前域方法树根;
                返回.结果 = 枚举_筹办结果::已可执行;
                返回.原因说明 = "回归测试/筹办成功";
                return 返回;
            }
        };

        struct 假维护执行器 final : public 维护任务执行接口_v0
        {
            结构_维护返回 执行维护(
                任务节点类*,
                任务节点类*,
                任务节点类*,
                方法节点类*,
                方法节点类* 当前域方法树根) const override
            {
                结构_维护返回 返回{};
                返回.当前域建议方法首节点 = 当前域方法树根;
                返回.结果 = 枚举_维护结果::转入纠偏;
                返回.原因说明 = "回归测试/维护转纠偏";
                return 返回;
            }
        };

        struct 假纠偏执行器 final : public 纠偏任务执行接口_v0
        {
            结构_纠偏返回 执行纠偏(
                任务节点类*,
                任务节点类*,
                任务节点类*,
                方法节点类*,
                const 结构_任务返回消息&,
                方法节点类* 当前域方法树根,
                const 结构_任务控制判定输入*) const override
            {
                结构_纠偏返回 返回{};
                返回.当前域建议方法首节点 = 当前域方法树根;
                返回.结果 = 枚举_纠偏结果::转入收束;
                返回.原因说明 = "回归测试/纠偏转收束";
                return 返回;
            }
        };

        struct 假收束执行器 final : public 收束任务执行接口_v0
        {
            结构_收束返回 执行收束(
                任务节点类*,
                任务节点类*,
                任务节点类*,
                方法节点类*,
                const 结构_任务返回消息&,
                方法节点类* 当前域方法树根,
                const 结构_任务控制判定输入*) const override
            {
                结构_收束返回 返回{};
                返回.当前域建议方法首节点 = 当前域方法树根;
                返回.结果 = 枚举_收束结果::已完成收束;
                返回.原因说明 = "回归测试/收束完成";
                返回.是否已写反馈 = true;
                返回.是否已归档 = true;
                return 返回;
            }
        };

        结构_总控回归结果_v0 测试结果{};
        功能域判定器_v0 判定器{};
        假筹办执行器 筹办执行器{};
        假维护执行器 维护执行器{};
        假纠偏执行器 纠偏执行器{};
        假收束执行器 收束执行器{};
        任务控制总控模块_v0 总控{
            判定器,
            筹办执行器,
            维护执行器,
            纠偏执行器,
            收束执行器
        };

        auto 记录 = [&](std::int32_t 轮次, const 结构_总控返回& 返回) {
            测试结果.轨迹.push_back({
                轮次,
                返回.当前功能域,
                返回.下一功能域,
                返回.结果,
                返回.原因说明
                });
            测试结果.已经过筹办 = 测试结果.已经过筹办 || 返回.当前功能域 == 枚举_任务控制功能域::筹办;
            测试结果.已经过维护 = 测试结果.已经过维护 || 返回.当前功能域 == 枚举_任务控制功能域::维护;
            测试结果.已经过纠偏 = 测试结果.已经过纠偏 || 返回.当前功能域 == 枚举_任务控制功能域::纠偏;
            测试结果.已经过收束 = 测试结果.已经过收束 || 返回.当前功能域 == 枚举_任务控制功能域::收束;
        };

        结构_任务控制判定输入 输入1{};
        输入1.任务链已成形 = false;
        const auto 返回1 = 总控.处理任务入口(输入1);
        记录(1, 返回1);
        if (返回1.当前功能域 != 枚举_任务控制功能域::筹办
            || 返回1.当前域方法树根 == nullptr
            || 返回1.当前域建议方法首节点 == nullptr
            || 返回1.下一域方法树根 == nullptr
            || 返回1.结果 != 枚举_总控结果::已可执行
            || 返回1.下一功能域 != 枚举_任务控制功能域::维护) {
            测试结果.错误摘要 = "回归测试第1步失败：筹办未正确映射到维护";
            return 测试结果;
        }

        结构_任务控制判定输入 输入2{};
        输入2.任务链已成形 = true;
        输入2.已有可尝试方法 = true;
        输入2.当前任务状态 = 枚举_任务状态::运行中;
        输入2.最近结果稳定 = true;
        输入2.检查点通过 = true;
        const auto 返回2 = 总控.处理任务入口(输入2);
        记录(2, 返回2);
        if (返回2.当前功能域 != 枚举_任务控制功能域::维护
            || 返回2.当前域方法树根 == nullptr
            || 返回2.当前域建议方法首节点 == nullptr
            || 返回2.下一域方法树根 == nullptr
            || 返回2.结果 != 枚举_总控结果::需进入纠偏
            || 返回2.下一功能域 != 枚举_任务控制功能域::纠偏) {
            测试结果.错误摘要 = "回归测试第2步失败：维护未正确映射到纠偏";
            return 测试结果;
        }

        结构_任务控制判定输入 输入3 = 输入2;
        输入3.最近执行失败 = true;
        const auto 返回3 = 总控.处理任务入口(输入3);
        记录(3, 返回3);
        if (返回3.当前功能域 != 枚举_任务控制功能域::纠偏
            || 返回3.当前域方法树根 == nullptr
            || 返回3.当前域建议方法首节点 == nullptr
            || 返回3.下一域方法树根 == nullptr
            || 返回3.结果 != 枚举_总控结果::需进入收束
            || 返回3.下一功能域 != 枚举_任务控制功能域::收束) {
            测试结果.错误摘要 = "回归测试第3步失败：纠偏未正确映射到收束";
            return 测试结果;
        }

        结构_任务控制判定输入 输入4 = 输入2;
        输入4.已满足完成判据 = true;
        const auto 返回4 = 总控.处理任务入口(输入4);
        记录(4, 返回4);
        if (返回4.当前功能域 != 枚举_任务控制功能域::收束
            || 返回4.当前域方法树根 == nullptr
            || 返回4.当前域建议方法首节点 == nullptr
            || 返回4.下一域方法树根 != nullptr
            || 返回4.结果 != 枚举_总控结果::已完成收束
            || 返回4.下一功能域 != 枚举_任务控制功能域::未定义) {
            测试结果.错误摘要 = "回归测试第4步失败：收束未正确落到终态";
            return 测试结果;
        }

        测试结果.已到达终态 = true;
        测试结果.成功 =
            测试结果.已经过筹办
            && 测试结果.已经过维护
            && 测试结果.已经过纠偏
            && 测试结果.已经过收束
            && 测试结果.已到达终态;
        if (!测试结果.成功 && 测试结果.错误摘要.empty()) {
            测试结果.错误摘要 = "四域全流程轨迹不完整";
        }
        return 测试结果;
    }

    static 结构_方法树自动生长回归结果_v0 测试_方法树自动生长升级链()
    {
        结构_方法树自动生长回归结果_v0 测试结果{};

        方法类 方法集{};
        四域方法树注册器_v0 注册器{ 方法集 };
        四域方法树写回器_v0 写回器{ 方法集 };
        四域方法树生长判定器_v0 生长判定器{};
        四域方法树匹配器_v0 匹配器{};

        auto* 维护域根 = 注册器.获取维护方法树根();
        if (!维护域根) {
            测试结果.错误摘要 = "回归测试失败：无法获取维护域方法树根";
            return 测试结果;
        }

        结构_四域方法树条件签名输入_v0 条件输入{};
        条件输入.域标签 = "维护";
        条件输入.安全值_Q10000 = 6000;
        条件输入.服务值_Q10000 = 7000;
        条件输入.需求值_Q10000 = 6500;
        条件输入.当前预算_Q10000 = 5000;
        条件输入.最近结果稳定 = true;
        条件输入.检查点通过 = true;
        const auto 条件主键 = 四域方法树匹配器_v0::生成条件主键(条件输入);

        结构_四域方法树匹配请求_v0 初始匹配请求{};
        初始匹配请求.域方法树根 = 维护域根;
        初始匹配请求.条件主键 = 条件主键;
        const auto 初始匹配结果 = 匹配器.匹配(初始匹配请求);
        if (!初始匹配结果.需转本域兜底 || !初始匹配结果.父结果节点) {
            测试结果.错误摘要 = "回归测试失败：初始状态未落到本域兜底挂载点";
            return 测试结果;
        }

        结构_四域方法树写回请求_v0 写回请求{};
        写回请求.域方法树根 = 维护域根;
        写回请求.父结果节点 = 初始匹配结果.父结果节点;
        写回请求.条件主键 = 条件主键;
        写回请求.动作名 = "回归_维护_稳定推进";
        写回请求.动作句柄.类型 = 枚举_动作句柄类型::动作序列主键;
        写回请求.动作句柄.动作序列主键 = "四域方法树/维护/回归稳定推进";
        写回请求.来源 = 枚举_方法沉淀来源::运行期临时;
        const auto 写回结果 = 写回器.按成功路径写回(写回请求);
        if (!写回结果.成功 || !写回结果.写回首节点) {
            测试结果.错误摘要 = "回归测试失败：未能把兜底成功路径写回临时枝";
            return 测试结果;
        }
        测试结果.已完成写回 = true;

        auto* 首信息 = 写回结果.写回首节点 && 写回结果.写回首节点->主信息
            ? dynamic_cast<方法首节点主信息类*>(写回结果.写回首节点->主信息)
            : nullptr;
        if (!首信息 || 首信息->来源 != 枚举_方法沉淀来源::运行期临时) {
            测试结果.错误摘要 = "回归测试失败：新枝初始来源不是运行期临时";
            return 测试结果;
        }

        const auto 写回后匹配结果 = 匹配器.匹配(初始匹配请求);
        if (!写回后匹配结果.找到
            || 写回后匹配结果.建议执行首节点 != 写回结果.写回首节点) {
            测试结果.错误摘要 = "回归测试失败：写回后的新枝未被同条件再次命中";
            return 测试结果;
        }
        测试结果.已命中写回枝条 = true;

        for (std::int32_t i = 0; i < 2; ++i) {
            (void)生长判定器.记录运行结果(
                写回结果.写回首节点,
                true,
                结构体_时间戳::当前_微秒(),
                "任务控制总控回归测试_v0::测试_方法树自动生长升级链/前两次稳定复现");
            const auto 判定结果 = 生长判定器.判定(写回结果.写回首节点);
            (void)生长判定器.应用升级(
                写回结果.写回首节点,
                判定结果,
                "任务控制总控回归测试_v0::测试_方法树自动生长升级链/前两次应用升级");
        }

        if (首信息->来源 != 枚举_方法沉淀来源::运行期临时) {
            测试结果.错误摘要 = "回归测试失败：稳定复现未达3次前提前升级";
            return 测试结果;
        }
        测试结果.已验证三次前不升级 = true;

        (void)生长判定器.记录运行结果(
            写回结果.写回首节点,
            true,
            结构体_时间戳::当前_微秒(),
            "任务控制总控回归测试_v0::测试_方法树自动生长升级链/第三次稳定复现");
        const auto 三次判定结果 = 生长判定器.判定(写回结果.写回首节点);
        (void)生长判定器.应用升级(
            写回结果.写回首节点,
            三次判定结果,
            "任务控制总控回归测试_v0::测试_方法树自动生长升级链/第三次应用升级");
        if (首信息->来源 != 枚举_方法沉淀来源::反推) {
            测试结果.错误摘要 = "回归测试失败：稳定复现达到3次后未升格为候选枝";
            return 测试结果;
        }
        测试结果.已升格候选枝 = true;

        for (std::int32_t i = 0; i < 2; ++i) {
            (void)生长判定器.记录运行结果(
                写回结果.写回首节点,
                true,
                结构体_时间戳::当前_微秒(),
                "任务控制总控回归测试_v0::测试_方法树自动生长升级链/第四五次稳定复现");
            const auto 判定结果 = 生长判定器.判定(写回结果.写回首节点);
            (void)生长判定器.应用升级(
                写回结果.写回首节点,
                判定结果,
                "任务控制总控回归测试_v0::测试_方法树自动生长升级链/第四五次应用升级");
        }

        if (首信息->来源 != 枚举_方法沉淀来源::组合) {
            测试结果.错误摘要 = "回归测试失败：稳定复现达到5次后未升格为正式组合枝";
            return 测试结果;
        }

        测试结果.已升格正式组合枝 = true;
        测试结果.最终来源 = 首信息->来源;
        测试结果.成功 =
            测试结果.已完成写回
            && 测试结果.已命中写回枝条
            && 测试结果.已验证三次前不升级
            && 测试结果.已升格候选枝
            && 测试结果.已升格正式组合枝;
        if (!测试结果.成功 && 测试结果.错误摘要.empty()) {
            测试结果.错误摘要 = "方法树自动生长升级链回归未完成";
        }
        return 测试结果;
    }
};
