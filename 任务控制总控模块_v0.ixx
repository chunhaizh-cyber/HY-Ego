struct 结构_任务动作事件守卫 {
    任务信息基类* 主信息 = nullptr;
    const 词性节点类* 动作词 = nullptr;
    场景节点类* 输入场景 = nullptr;
    场景节点类* 输出场景 = nullptr;
    时间戳 开始时间 = 0;
    std::string 调用点{};
    bool 成功 = true;
    std::int64_t 错误码 = 0;

    结构_任务动作事件守卫(
        任务信息基类* mi,
        const 词性节点类* 动作,
        场景节点类* 输入,
        场景节点类* 输出,
        时间戳 now,
        std::string cp)
        : 主信息(mi)
        , 动作词(动作)
        , 输入场景(输入)
        , 输出场景(输出)
        , 开始时间(now ? now : 结构体_时间戳::当前_微秒())
        , 调用点(std::move(cp))
    {
        if (!主信息 || !动作词) return;
        (void)任务类::记录任务动作动态(
            主信息,
            动作词,
            输入场景,
            输出场景,
            true,
            0,
            开始时间,
            开始时间,
            枚举_动作事件相位::开始运行,
            调用点 + "/开始");
    }

    void 设置结果(bool ok, std::int64_t err = 0) noexcept {
        成功 = ok;
        错误码 = err;
    }

    ~结构_任务动作事件守卫() {
        if (!主信息 || !动作词) return;
        const 时间戳 结束时间 = 结构体_时间戳::当前_微秒();
        (void)任务类::记录任务动作动态(
            主信息,
            动作词,
            输入场景,
            输出场景,
            成功,
            错误码,
            结束时间,
            结束时间,
            成功 ? 枚举_动作事件相位::完成 : 枚举_动作事件相位::失败,
            调用点 + "/结束");
    }
};

inline 枚举_任务状态 取当前任务状态_(
    任务节点类* 当前任务,
    枚举_任务状态 显式状态) noexcept
{
    if (显式状态 != 枚举_任务状态::未定义) {
        return 显式状态;
    }
    if (auto* 主信息 = 任务类::取任务主信息指针_不加锁(当前任务)) {
        return 主信息->状态;
    }
    return 枚举_任务状态::未定义;
}

inline bool 是否终结状态_(枚举_任务状态 状态) noexcept
{
    return 状态 == 枚举_任务状态::完成
        || 状态 == 枚举_任务状态::失败
        || 状态 == 枚举_任务状态::取消
        || 状态 == 枚举_任务状态::超时
        || 状态 == 枚举_任务状态::无法执行;
}

inline bool 是否筹办态_(枚举_任务状态 状态) noexcept
{
    return 状态 == 枚举_任务状态::未定义
        || 状态 == 枚举_任务状态::未启动
        || 状态 == 枚举_任务状态::筹办中
        || 状态 == 枚举_任务状态::待重筹办;
}

