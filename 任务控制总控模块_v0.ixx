export enum class 枚举_任务控制功能域 : std::int64_t
{
    未定义 = 0,
    筹办 = 1,
    维护 = 2,
    纠偏 = 3,
    收束 = 4
};

export enum class 枚举_治理阶段 : std::int64_t
{
    筹办 = 0,
    维护 = 1,
    纠偏 = 2,
    收束 = 3
};

export struct 结构_控制快照
{
    I64 安全值_Q10000 = 0;
    I64 服务值_Q10000 = 0;
    I64 需求值_Q10000 = 0;
};

export struct 结构_治理上下文
{
    基础信息节点类* 被控任务 = nullptr;
    基础信息节点类* 当前需求 = nullptr;

    bool 根任务已建立 = false;
    bool 存在纠偏请求 = false;
    bool 满足收束条件 = false;
    bool 当前步骤完成 = false;
    bool 当前步骤失败 = false;

    结构_控制快照 当前控制快照{};
};

export struct 结构_治理切换结果
{
    枚举_治理阶段 阶段 = 枚举_治理阶段::筹办;
    std::string 原因说明{};
};

export inline 枚举_治理阶段 计算当前治理阶段(
    const 结构_治理上下文& 上下文) noexcept
{
    if (!上下文.根任务已建立) {
        return 枚举_治理阶段::筹办;
    }
    if (上下文.满足收束条件) {
        return 枚举_治理阶段::收束;
    }
    if (上下文.存在纠偏请求 || 上下文.当前步骤失败) {
        return 枚举_治理阶段::纠偏;
    }
    return 枚举_治理阶段::维护;
}

export inline 结构_治理切换结果 计算当前治理阶段_带原因(
    const 结构_治理上下文& 上下文)
{
    结构_治理切换结果 结果{};
    结果.阶段 = 计算当前治理阶段(上下文);
    switch (结果.阶段) {
    case 枚举_治理阶段::筹办:
        结果.原因说明 = "根任务未建立，进入筹办阶段";
        break;
    case 枚举_治理阶段::收束:
        结果.原因说明 = "满足收束条件，进入收束阶段";
        break;
    case 枚举_治理阶段::纠偏:
        结果.原因说明 = "存在纠偏请求或当前步骤失败，进入纠偏阶段";
        break;
    case 枚举_治理阶段::维护:
        结果.原因说明 = "主链可继续推进，进入维护阶段";
        break;
    default:
        结果.原因说明 = "治理阶段未定义";
        break;
    }
    return 结果;
}

export constexpr 枚举_任务控制功能域 转为任务控制功能域_v0(
    枚举_治理阶段 阶段) noexcept
{
    switch (阶段) {
    case 枚举_治理阶段::筹办:
        return 枚举_任务控制功能域::筹办;
    case 枚举_治理阶段::维护:
        return 枚举_任务控制功能域::维护;
    case 枚举_治理阶段::纠偏:
        return 枚举_任务控制功能域::纠偏;
    case 枚举_治理阶段::收束:
        return 枚举_任务控制功能域::收束;
    default:
        return 枚举_任务控制功能域::未定义;
    }
}

export struct 结构_任务控制四域职责项_v0
{
    枚举_任务控制功能域 功能域 = 枚举_任务控制功能域::未定义;
    std::string 目标{};
    std::vector<std::string> 触发条件{};
    std::vector<std::string> 允许动作{};
    std::vector<std::string> 禁止动作{};
    std::vector<std::string> 退出条件{};
};

export inline 结构_任务控制四域职责项_v0 查询任务控制四域职责_v0(
    枚举_任务控制功能域 功能域)
{
    switch (功能域) {
    case 枚举_任务控制功能域::筹办:
        return {
            功能域,
            "把任务立起来，搭成可执行结构",
            {"新需求进入", "现有任务尚未成形", "当前任务缺方法", "当前任务需要细分或补前置条件"},
            {"创建任务", "细分任务", "铺设步骤", "绑定方法", "插入检查任务", "初始化预算"},
            {"直接归档", "无因回退", "无预算的路径扩张"},
            {"已形成可执行任务链", "已绑定至少一个可尝试方法", "必要检查点已插入"}
        };
    case 枚举_任务控制功能域::维护:
        return {
            功能域,
            "让任务保持可执行、可跟踪、可稳定推进",
            {"任务已进入执行期", "当前链路仍有效", "方法可继续使用", "无明显偏差但需持续保活"},
            {"刷新状态", "维护依赖", "局部检查", "更新优先级", "小范围补丁式修正"},
            {"大规模重建任务树", "无证据的回退", "无必要的多分支扩张"},
            {"出现明显偏差，转纠偏", "已满足结束条件，转收束", "任务失去可执行性，回筹办"}
        };
    case 枚举_任务控制功能域::纠偏:
        return {
            功能域,
            "把跑偏的任务拉回可控轨道",
            {"方法失败", "结果不稳定", "风险上升", "目标偏离", "检查点未通过"},
            {"替换方法", "回退", "收缩", "插恢复任务", "补条件任务", "局部重筹办"},
            {"无限制重试", "越过安全硬边界", "直接把失败伪装成完成"},
            {"已恢复到可执行状态，转维护", "需要重新搭建，转筹办", "已不值得继续，转收束"}
        };
    case 枚举_任务控制功能域::收束:
        return {
            功能域,
            "把任务关干净，留下结果和经验",
            {"已完成目标", "已达到可接受结果", "已确定无法继续", "已决定终止"},
            {"判定完成/失败/取消", "清理临时节点", "关闭无效分支", "写入反馈", "学习写回", "归档结果"},
            {"再次无因扩张", "在收束阶段偷偷重启主流程", "跳过反馈和因果登记"},
            {"最终状态已确定", "反馈已写入", "必要经验已沉淀", "临时资源已释放"}
        };
    default:
        return {};
    }
}

