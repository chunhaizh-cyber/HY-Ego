namespace 任务控制总控模块_v0_内部 {

inline 任务头结点信息* 取头信息_(任务节点类* 节点) noexcept
{
    return (节点 && 节点->主信息)
        ? dynamic_cast<任务头结点信息*>(节点->主信息)
        : nullptr;
}

inline 任务步骤节点信息* 取步骤信息_(任务节点类* 节点) noexcept
{
    return (节点 && 节点->主信息)
        ? dynamic_cast<任务步骤节点信息*>(节点->主信息)
        : nullptr;
}

inline 任务结果节点信息* 取结果信息_(任务节点类* 节点) noexcept
{
    return (节点 && 节点->主信息)
        ? dynamic_cast<任务结果节点信息*>(节点->主信息)
        : nullptr;
}

inline 方法首节点主信息类* 取方法头信息_(方法节点类* 节点) noexcept
{
    return (节点 && 节点->主信息)
        ? dynamic_cast<方法首节点主信息类*>(节点->主信息)
        : nullptr;
}

inline 存在节点类* 取任务虚拟存在_(任务节点类* 任务头结点) noexcept
{
    auto* 头信息 = 取头信息_(任务头结点);
    return 头信息 ? 头信息->任务虚拟存在 : nullptr;
}

inline const char* 功能域标签_(枚举_任务控制功能域 功能域) noexcept
{
    switch (功能域) {
    case 枚举_任务控制功能域::筹办:
        return "筹办";
    case 枚举_任务控制功能域::维护:
        return "维护";
    case 枚举_任务控制功能域::纠偏:
        return "纠偏";
    case 枚举_任务控制功能域::收束:
        return "收束";
    default:
        return "未定义";
    }
}

inline bool 提取动作信息_(
    方法节点类* 方法首节点,
    std::string& 动作名,
    结构体_动作句柄& 动作句柄) noexcept
{
    auto* 方法头信息 = 取方法头信息_(方法首节点);
    if (!方法头信息 || !方法头信息->动作句柄.有效()) {
        return false;
    }

    动作句柄 = 方法头信息->动作句柄;
    动作名 = 方法头信息->动作名
        ? 方法头信息->动作名->获取主键()
        : std::string{};
    if (动作名.empty()) {
        switch (动作句柄.类型) {
        case 枚举_动作句柄类型::本能函数ID:
        动作名 = std::string("本能_") + std::to_string(动作句柄.本能ID);
            break;
        case 枚举_动作句柄类型::动作序列主键:
            动作名 = 动作句柄.动作序列主键;
            break;
        case 枚举_动作句柄类型::外部实现主键:
            动作名 = 动作句柄.外部实现主键;
            break;
        default:
            break;
        }
    }
    return !动作名.empty();
}

inline 方法条件节点主信息类* 取方法条件信息_(方法节点类* 节点) noexcept
{
    return (节点 && 节点->主信息)
        ? dynamic_cast<方法条件节点主信息类*>(节点->主信息)
        : nullptr;
}

inline 方法结果节点主信息类* 取方法结果信息_(方法节点类* 节点) noexcept
{
    return (节点 && 节点->主信息)
        ? dynamic_cast<方法结果节点主信息类*>(节点->主信息)
        : nullptr;
}

template<class 谓词>
inline 方法节点类* 查找首个方法子节点_(方法节点类* 父节点, 谓词&& 匹配) noexcept
{
    auto* first = static_cast<方法节点类*>(父节点 ? 父节点->子 : nullptr);
    if (!first) return nullptr;

    auto* cur = first;
    do {
        if (匹配(cur)) return cur;
        cur = static_cast<方法节点类*>(cur->下);
    } while (cur && cur != first);
    return nullptr;
}

struct 结构_域方法树首段命中_v0
{
    方法节点类* 域根首节点 = nullptr;
    方法节点类* 命中条件节点 = nullptr;
    方法节点类* 命中结果节点 = nullptr;
    方法节点类* 建议下一首节点 = nullptr;
};

inline 结构_域方法树首段命中_v0 解析域方法树首段_(方法节点类* 当前域方法树根) noexcept
{
    结构_域方法树首段命中_v0 返回{};
    返回.域根首节点 = 取方法头信息_(当前域方法树根) ? 当前域方法树根 : nullptr;
    if (!返回.域根首节点) {
        return 返回;
    }

    返回.命中条件节点 = 查找首个方法子节点_(
        返回.域根首节点,
        [](方法节点类* 节点) { return 取方法条件信息_(节点) != nullptr; });
    auto* 结果父节点 = 返回.命中条件节点 ? 返回.命中条件节点 : 返回.域根首节点;
    返回.命中结果节点 = 查找首个方法子节点_(
        结果父节点,
        [](方法节点类* 节点) { return 取方法结果信息_(节点) != nullptr; });
    auto* 下一首父节点 = 返回.命中结果节点 ? 返回.命中结果节点 : 结果父节点;
    返回.建议下一首节点 = 查找首个方法子节点_(
        下一首父节点,
        [](方法节点类* 节点) { return 取方法头信息_(节点) != nullptr; });
    return 返回;
}

inline 方法节点类* 解析域方法树建议方法首节点_(方法节点类* 当前域方法树根) noexcept
{
    auto 命中 = 解析域方法树首段_(当前域方法树根);
    return 命中.建议下一首节点;
}

inline 任务节点类* 归一到任务头_(任务节点类* 节点) noexcept
{
    if (!节点) return nullptr;
    if (取头信息_(节点)) return 节点;
    if (auto* 步骤信息 = 取步骤信息_(节点)) return 步骤信息->所属任务头结点;
    if (auto* 结果信息 = 取结果信息_(节点)) return 结果信息->所属任务头结点;
    return nullptr;
}

inline 任务节点类* 取当前或首个步骤_(任务节点类* 任务头结点) noexcept
{
    auto* 头信息 = 取头信息_(任务头结点);
    if (!头信息) return nullptr;
    if (头信息->当前步骤节点 && 取步骤信息_(头信息->当前步骤节点)) {
        return 头信息->当前步骤节点;
    }

    auto* first = static_cast<任务节点类*>(任务头结点 ? 任务头结点->子 : nullptr);
    if (!first) return nullptr;

    auto* cur = first;
    do {
        if (取步骤信息_(cur)) return cur;
        cur = static_cast<任务节点类*>(cur->下);
    } while (cur && cur != first);
    return nullptr;
}

inline 任务节点类* 取首个结果_(任务节点类* 步骤节点) noexcept
{
    auto* first = static_cast<任务节点类*>(步骤节点 ? 步骤节点->子 : nullptr);
    if (!first) return nullptr;

    auto* cur = first;
    do {
        if (取结果信息_(cur)) return cur;
        cur = static_cast<任务节点类*>(cur->下);
    } while (cur && cur != first);
    return nullptr;
}

inline bool 方法存在即可候选_(方法节点类* 方法首节点) noexcept
{
    return 取方法头信息_(方法首节点) != nullptr;
}

inline bool 方法可由执行适配器直接执行_(方法节点类* 方法首节点) noexcept
{
    auto* 方法头信息 = 取方法头信息_(方法首节点);
    if (!方法头信息) return false;
    if (方法头信息->动作句柄.类型 != 枚举_动作句柄类型::本能函数ID) {
        return false;
    }
    if (方法头信息->动作句柄.本能ID == 0) {
        return false;
    }
    return 本能集.有(static_cast<枚举_本能动作ID>(方法头信息->动作句柄.本能ID));
}

inline I64 计算方法可靠度_Q10000_(方法节点类* 方法首节点) noexcept
{
    auto* 方法信息 = (方法首节点 && 方法首节点->主信息)
        ? dynamic_cast<方法信息基类*>(方法首节点->主信息)
        : nullptr;
    if (!方法信息) return 0;

    const auto& 评估 = 方法信息->评估原始量;
    const I64 尝试次数 = (std::max)(
        评估.节点_运行次数,
        评估.节点_成功次数 + 评估.节点_失败次数);
    if (尝试次数 <= 0) return 0;

    const I64 可靠度 = (评估.节点_成功次数 * 10000) / 尝试次数;
    return (std::clamp)(可靠度, static_cast<I64>(0), static_cast<I64>(10000));
}

inline 方法节点类* 选择首选方法_(任务步骤节点信息* 步骤信息) noexcept
{
    if (!步骤信息) return nullptr;

    方法节点类* 最优方法 = nullptr;
    I64 最优得分 = -1;

    auto 尝试更新 = [&](方法节点类* 方法首节点, bool 当前已选) {
        if (!方法存在即可候选_(方法首节点)) return;
        I64 得分 = 计算方法可靠度_Q10000_(方法首节点);
        if (当前已选) 得分 += 100;
        if (!最优方法 || 得分 > 最优得分) {
            最优方法 = 方法首节点;
            最优得分 = 得分;
        }
    };

    尝试更新(步骤信息->当前选中方法首节点, true);
    for (auto* 方法首节点 : 步骤信息->可用方法首节点列表) {
        尝试更新(方法首节点, false);
    }
    return 最优方法;
}

inline 方法节点类* 选择首选可直接执行方法_(任务步骤节点信息* 步骤信息) noexcept
{
    if (!步骤信息) return nullptr;

    方法节点类* 最优方法 = nullptr;
    I64 最优得分 = -1;

    auto 尝试更新 = [&](方法节点类* 方法首节点, bool 当前已选) {
        if (!方法可由执行适配器直接执行_(方法首节点)) return;
        I64 得分 = 计算方法可靠度_Q10000_(方法首节点);
        if (当前已选) 得分 += 100;
        if (!最优方法 || 得分 > 最优得分) {
            最优方法 = 方法首节点;
            最优得分 = 得分;
        }
    };

    尝试更新(步骤信息->当前选中方法首节点, true);
    for (auto* 方法首节点 : 步骤信息->可用方法首节点列表) {
        尝试更新(方法首节点, false);
    }
    return 最优方法;
}

inline 方法节点类* 选择替代方法_(
    任务步骤节点信息* 步骤信息,
    方法节点类* 当前方法首节点) noexcept
{
    if (!步骤信息 || !步骤信息->允许切换方法) {
        return nullptr;
    }

    方法节点类* 最优替代 = nullptr;
    I64 最优得分 = -1;
    for (auto* 方法首节点 : 步骤信息->可用方法首节点列表) {
        if (!方法存在即可候选_(方法首节点)) continue;
        if (方法首节点 == 当前方法首节点) continue;
        const I64 得分 = 计算方法可靠度_Q10000_(方法首节点);
        if (!最优替代 || 得分 > 最优得分) {
            最优替代 = 方法首节点;
            最优得分 = 得分;
        }
    }
    return 最优替代;
}

inline 方法节点类* 选择替代可直接执行方法_(
    任务步骤节点信息* 步骤信息,
    方法节点类* 当前方法首节点) noexcept
{
    if (!步骤信息 || !步骤信息->允许切换方法) {
        return nullptr;
    }

    方法节点类* 最优替代 = nullptr;
    I64 最优得分 = -1;
    for (auto* 方法首节点 : 步骤信息->可用方法首节点列表) {
        if (!方法可由执行适配器直接执行_(方法首节点)) continue;
        if (方法首节点 == 当前方法首节点) continue;
        const I64 得分 = 计算方法可靠度_Q10000_(方法首节点);
        if (!最优替代 || 得分 > 最优得分) {
            最优替代 = 方法首节点;
            最优得分 = 得分;
        }
    }
    return 最优替代;
}

inline 结构_兜底学习上下文 构造兜底学习上下文_(
    const 结构_任务控制判定输入& 输入,
    任务节点类* 当前任务头结点,
    任务节点类* 当前步骤结点,
    任务节点类* 当前结果结点,
    const std::string& 调用点)
{
    结构_兜底学习上下文 上下文{};
    上下文.来源需求 = 输入.来源需求;
    上下文.当前任务头结点 = 当前任务头结点;
    上下文.当前步骤节点 = 当前步骤结点;
    上下文.当前结果节点 = 当前结果结点;

    auto* 头信息 = 取头信息_(当前任务头结点);
    auto* 步骤信息 = 取步骤信息_(当前步骤结点);
    auto* 结果信息 = 取结果信息_(当前结果结点);
    上下文.当前场景 = 输入.当前场景
        ? 输入.当前场景
        : (步骤信息 && 步骤信息->场景
            ? 步骤信息->场景
            : (结果信息 && 结果信息->场景
                ? 结果信息->场景
                : (头信息 ? 头信息->场景 : nullptr)));
    上下文.任务虚拟存在 = 头信息 ? 头信息->任务虚拟存在 : nullptr;
    上下文.当前方法首节点 = 步骤信息 ? 步骤信息->当前选中方法首节点 : nullptr;
    上下文.方法虚拟存在根 = (上下文.当前方法首节点 && 上下文.当前方法首节点->主信息)
        ? dynamic_cast<方法信息基类*>(上下文.当前方法首节点->主信息)->方法虚拟存在根
        : nullptr;

    上下文.安全值_Q10000 = 输入.安全值_Q10000;
    上下文.服务值_Q10000 = 输入.服务值_Q10000;
    上下文.需求值_Q10000 = 输入.需求值_Q10000;

    const bool 有筹办预算 =
        输入.当前预算_Q10000 > 0
        || 输入.需求值_Q10000 > 0
        || 输入.服务值_Q10000 > 0;
    上下文.当前细分预算 = (输入.需要新子任务或新步骤 || 输入.依赖缺失 || !输入.已有可尝试方法) && 有筹办预算 ? 1 : 0;
    上下文.当前路径预算 = 有筹办预算 ? 1 : 0;
    上下文.当前回退预算 = 有筹办预算 ? 1 : 0;
    上下文.当前检查预算 = 有筹办预算 ? 1 : 0;
    上下文.调用点 = 调用点;
    return 上下文;
}

inline bool 是否需要插检查任务_(
    const 结构_任务控制判定输入& 输入,
    方法节点类* 当前方法首节点) noexcept
{
    if (输入.当前预算_Q10000 < 0) return false;

    const I64 方法可靠度 = 计算方法可靠度_Q10000_(当前方法首节点);
    if (方法可靠度 > 0 && 方法可靠度 < 7000) return true;
    if (方法可靠度 == 0 && 当前方法首节点 != nullptr) return true;
    if (输入.需求值_Q10000 >= 8000) return true;
    if (输入.安全值_Q10000 > 0 && 输入.安全值_Q10000 <= 4000) return true;
    return false;
}

inline 场景节点类* 准备维护输出场景_(
    任务节点类* 当前任务头结点,
    任务节点类* 当前步骤结点,
    任务节点类* 当前结果结点,
    时间戳 now,
    const std::string& 调用点)
{
    if (auto* 结果信息 = 取结果信息_(当前结果结点)) {
        if (结果信息->场景) {
            return 结果信息->场景;
        }
    }

    auto* 步骤信息 = 取步骤信息_(当前步骤结点);
    auto* 头信息 = 取头信息_(当前任务头结点);
    auto* 父场景 = 步骤信息 && 步骤信息->场景
        ? 步骤信息->场景
        : (头信息 ? 头信息->场景 : nullptr);
    auto* 父节点 = 父场景
        ? static_cast<基础信息节点类*>(父场景)
        : static_cast<基础信息节点类*>(世界树.取内部世界() ? 世界树.取内部世界() : 世界树.虚拟世界);
    if (!父节点) {
        return nullptr;
    }

    auto* 场景信息 = new 场景节点主信息类();
    场景信息->名称 = 语素集.添加词性词(std::string("维护执行输出_") + std::to_string(now), "名词");
    场景信息->类型 = 语素集.添加词性词("维护任务执行场景", "名词");
    场景信息->最后观测时间 = now;
    auto* 输出场景 = 世界树.创建场景(父节点, 场景信息, 调用点 + "/创建输出场景");
    if (!输出场景) {
        delete 场景信息;
        return nullptr;
    }
    return 输出场景;
}

inline 任务执行器::结构_叶子执行结果 执行当前本能方法_(
    任务节点类* 当前任务头结点,
    任务节点类* 当前步骤结点,
    任务节点类* 当前结果结点)
{
    任务执行器::结构_叶子执行结果 返回{};

    auto* 步骤信息 = 取步骤信息_(当前步骤结点);
    auto* 头信息 = 取头信息_(当前任务头结点);
    if (!步骤信息 || !头信息) {
        返回.摘要 = "维护执行缺少任务骨架";
        返回.失败类型 = 枚举_任务失败类型::无叶子执行回调;
        返回.建议动作 = 枚举_任务反馈动作::挂起等待;
        return 返回;
    }

    auto* 方法首节点 = 步骤信息->当前选中方法首节点;
    auto* 方法头信息 = 取方法头信息_(方法首节点);
    if (!方法头信息
        || 方法头信息->动作句柄.类型 != 枚举_动作句柄类型::本能函数ID
        || 方法头信息->动作句柄.本能ID == 0) {
        返回.摘要 = "当前仅支持本能方法执行";
        返回.失败类型 = 枚举_任务失败类型::无叶子执行回调;
        返回.建议动作 = 枚举_任务反馈动作::挂起等待;
        return 返回;
    }

    const auto 本能ID = static_cast<枚举_本能动作ID>(方法头信息->动作句柄.本能ID);
    if (!本能集.有(本能ID)) {
        返回.摘要 = "当前本能方法未注册";
        返回.失败类型 = 枚举_任务失败类型::无叶子执行回调;
        返回.建议动作 = 枚举_任务反馈动作::挂起等待;
        return 返回;
    }

    auto* 输入场景 = 步骤信息->场景
        ? 步骤信息->场景
        : (头信息->场景 ? 头信息->场景 : (世界树.取内部世界() ? 世界树.取内部世界() : 世界树.虚拟世界));
    const 时间戳 now = 结构体_时间戳::当前_微秒();
    auto* 输出场景 = 准备维护输出场景_(
        当前任务头结点,
        当前步骤结点,
        当前结果结点,
        now,
        "任务控制总控模块_v0::方法执行适配器_v0");
    if (!输入场景 || !输出场景) {
        返回.摘要 = "缺少维护执行输入或输出场景";
        返回.失败类型 = 枚举_任务失败类型::无叶子执行回调;
        返回.建议动作 = 枚举_任务反馈动作::挂起等待;
        return 返回;
    }

    const auto 调用结果 = 方法集.调用本能函数(本能ID, 输入场景, 输出场景, 方法首节点);
    const bool 成功 = 调用结果.成功;
    返回.成功 = 成功;
    返回.结果场景 = 输出场景;
    返回.摘要 = 本能集.查询函数名称(本能ID);
    if (返回.摘要.empty()) {
    返回.摘要 = std::string("本能_") + std::to_string(方法头信息->动作句柄.本能ID);
    }
    返回.建议动作 = 成功
        ? 枚举_任务反馈动作::继续下一步
        : 枚举_任务反馈动作::挂起等待;
    if (!成功) {
        返回.失败类型 = 枚举_任务失败类型::无叶子执行回调;
    }
    return 返回;
}

inline bool 更新方法可靠度统计_(
    方法节点类* 当前方法首节点,
    bool 结果稳定出现,
    时间戳 now) noexcept
{
    auto* 方法信息 = (当前方法首节点 && 当前方法首节点->主信息)
        ? dynamic_cast<方法信息基类*>(当前方法首节点->主信息)
        : nullptr;
    if (!方法信息) {
        return false;
    }

    auto& 评估 = 方法信息->评估原始量;
    ++评估.节点_运行次数;
    ++评估.节点_样本数;
    评估.节点_最后运行时间_微秒 = static_cast<I64>(now);
    if (结果稳定出现) {
        ++评估.节点_成功次数;
        ++评估.节点_连续成功次数;
        评估.节点_连续失败次数 = 0;
    评估.节点_最后成功时间_微秒 = static_cast<I64>(now);
    }
    else {
        ++评估.节点_失败次数;
        ++评估.节点_连续失败次数;
        评估.节点_连续成功次数 = 0;
    评估.节点_最后失败时间_微秒 = static_cast<I64>(now);
    }
    return true;
}

inline 结构_任务返回消息 构造最近反馈_自输入_(
    const 结构_任务控制判定输入& 输入) noexcept
{
    if (输入.最近反馈) {
        return *输入.最近反馈;
    }

    结构_任务返回消息 返回{};
    返回.来源任务 = 输入.当前任务;
    返回.对应需求 = 输入.来源需求;
    返回.需求已满足 = 输入.已满足完成判据;
    返回.需要重筹办 = 输入.需要新子任务或新步骤 || 输入.依赖缺失;

    if (输入.最近执行失败 || 输入.关键方法不再可用) {
        返回.类型 = 枚举_任务返回消息类型::步骤失败;
        返回.摘要 = 输入.关键方法不再可用
            ? "关键方法不再可用"
            : "最近执行失败";
        return 返回;
    }
    if (!输入.最近结果稳定 || !输入.检查点通过 || 输入.风险变坏) {
        返回.类型 = 枚举_任务返回消息类型::步骤失败;
        返回.摘要 = !输入.检查点通过
            ? "检查点未通过"
            : (!输入.最近结果稳定 ? "结果不稳定" : "风险已恶化");
        return 返回;
    }
    if (输入.已满足完成判据) {
        返回.类型 = 枚举_任务返回消息类型::步骤完成;
        返回.摘要 = "已命中完成判据";
        return 返回;
    }

    返回.类型 = 枚举_任务返回消息类型::未定义;
    返回.摘要 = "缺少最近反馈";
    return 返回;
}

} // namespace 任务控制总控模块_v0_内部

export inline 结构_任务控制判定结果 计算任务控制功能域判定结果_v0(
    const 结构_任务控制判定输入& 输入)
{
    using namespace 任务控制总控模块_v0_内部;

    const auto 当前状态 = 取当前任务状态_(输入.当前任务, 输入.当前任务状态);

    auto 构造结果 = [](枚举_任务控制功能域 功能域, const std::string& 原因) {
        结构_任务控制判定结果 结果{};
        结果.功能域 = 功能域;
        结果.原因说明 = 原因;
        switch (功能域) {
        case 枚举_任务控制功能域::筹办:
            结果.允许细分 = true;
            结果.允许延长 = true;
            break;
        case 枚举_任务控制功能域::维护:
            结果.允许维护 = true;
            break;
        case 枚举_任务控制功能域::纠偏:
            结果.允许替换方法 = true;
            结果.允许回退 = true;
            break;
        case 枚举_任务控制功能域::收束:
            结果.允许收束 = true;
            break;
        default:
            break;
        }
        return 结果;
    };

    if (输入.已满足完成判据) {
        return 构造结果(枚举_任务控制功能域::收束, "已满足完成判据，转入收束");
    }
    if (输入.已确定无法继续) {
        return 构造结果(枚举_任务控制功能域::收束, "已确定无法继续，转入收束");
    }
    if (输入.服务收益不足以继续) {
        return 构造结果(枚举_任务控制功能域::收束, "服务收益不足以继续，转入收束");
    }
    if (输入.安全要求必须停止) {
        return 构造结果(枚举_任务控制功能域::收束, "安全要求必须停止，转入收束");
    }
    if (是否终结状态_(当前状态)) {
        return 构造结果(枚举_任务控制功能域::收束, "任务已处于终结态，转入收束");
    }

    if (输入.最近执行失败) {
        return 构造结果(枚举_任务控制功能域::纠偏, "最近执行失败，转入纠偏");
    }
    if (!输入.最近结果稳定 && 输入.任务链已成形) {
        return 构造结果(枚举_任务控制功能域::纠偏, "最近结果不稳定，转入纠偏");
    }
    if (输入.风险变坏) {
        return 构造结果(枚举_任务控制功能域::纠偏, "风险变坏，转入纠偏");
    }
    if (!输入.检查点通过 && 输入.任务链已成形) {
        return 构造结果(枚举_任务控制功能域::纠偏, "检查点未通过，转入纠偏");
    }
    if (输入.关键方法不再可用) {
        return 构造结果(枚举_任务控制功能域::纠偏, "关键方法不再可用，转入纠偏");
    }

    if (!输入.任务链已成形) {
        return 构造结果(枚举_任务控制功能域::筹办, "任务链尚未成形，转入筹办");
    }
    if (!输入.已有可尝试方法) {
        return 构造结果(枚举_任务控制功能域::筹办, "当前无可尝试方法，转入筹办");
    }
    if (输入.依赖缺失) {
        return 构造结果(枚举_任务控制功能域::筹办, "依赖缺失，转入筹办");
    }
    if (输入.需要新子任务或新步骤) {
        return 构造结果(枚举_任务控制功能域::筹办, "需要新子任务或新步骤，转入筹办");
    }
    if (是否筹办态_(当前状态)) {
        return 构造结果(枚举_任务控制功能域::筹办, "当前任务处于筹办相关状态，转入筹办");
    }

    return 构造结果(枚举_任务控制功能域::维护, "任务链已成形且无明显偏差，转入维护");
}

