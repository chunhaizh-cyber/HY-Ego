
export module 相机外设基类模块;

import 外设模块;
import 基础数据类型模块;

// ============================================================================
// 相机外设基类模块
// 目的：
//  - 将“相机外设壳”抽成独立模块，避免 D455 外设反向依赖 虚拟相机外设。
//  - 任何“能产出 结构体_原始场景帧 的外设”都可以继承此基类。
// ============================================================================

export class 相机外设基类 : public 外设运行基类<结构体_原始场景帧> {
public:
    virtual ~相机外设基类() = default;
};
