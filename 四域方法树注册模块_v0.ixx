module;

#include <string>
#include <string_view>
#include <utility>

export module 四域方法树注册模块_v0;

import 主信息定义模块;
import 数据仓库模块;
import 方法模块;
import 本能动作管理模块;
import 语素环境模块;

namespace 四域方法树注册模块_v0_内部 {

using namespace 数据仓库模块;

inline const 词性节点类* 动作词_(std::string_view 名称)
{
    return 语素集.添加词性词(std::string(名称), "动词");
}

inline 结构体_动作句柄 本能句柄_(枚举_本能动作ID 本能ID)
{
    结构体_动作句柄 h{};
    h.类型 = 枚举_动作句柄类型::本能函数ID;
    h.本能ID = static_cast<I64>(本能ID);
    return h;
}

inline 结构体_动作句柄 组合句柄_(std::string 主键)
{
    结构体_动作句柄 h{};
    h.类型 = 枚举_动作句柄类型::动作序列主键;
    h.动作序列主键 = std::move(主键);
    return h;
}

inline bool 动作句柄相同_(const 结构体_动作句柄& 左, const 结构体_动作句柄& 右)
{
    if (左.类型 != 右.类型) return false;
    switch (左.类型) {
    case 枚举_动作句柄类型::本能函数ID:
        return 左.本能ID == 右.本能ID;
    case 枚举_动作句柄类型::外部实现主键:
        return 左.外部实现主键 == 右.外部实现主键;
    case 枚举_动作句柄类型::动作序列主键:
        return 左.动作序列主键 == 右.动作序列主键;
    default:
        return false;
    }
}

inline 方法首节点主信息类* 取首信息_(方法节点类* 节点)
{
    return 节点 ? dynamic_cast<方法首节点主信息类*>(节点->主信息) : nullptr;
}

inline 方法条件节点主信息类* 取条件信息_(方法节点类* 节点)
{
    return 节点 ? dynamic_cast<方法条件节点主信息类*>(节点->主信息) : nullptr;
}

inline 方法结果节点主信息类* 取结果信息_(方法节点类* 节点)
{
    return 节点 ? dynamic_cast<方法结果节点主信息类*>(节点->主信息) : nullptr;
}

template<class 谓词>
inline 方法节点类* 查找首个子节点_(方法节点类* 父节点, 谓词&& 匹配)
{
    if (!父节点 || !父节点->子) return nullptr;

    auto* 起点 = static_cast<方法节点类*>(父节点->子);
    auto* 当前 = 起点;
    do {
        if (匹配(当前)) return 当前;
        当前 = static_cast<方法节点类*>(当前->下);
    } while (当前 && 当前 != 起点);
    return nullptr;
}

inline 方法节点类* 取或创建结果节点_(
    方法类& 方法集,
    方法节点类* 父节点,
    const std::string& 调用点)
{
    if (!父节点) return nullptr;

    if (auto* 已有 = 查找首个子节点_(父节点, [](方法节点类* 节点) {
        return 取结果信息_(节点) != nullptr;
        })) {
        return 已有;
    }

    return 方法集.创建结果节点(父节点, nullptr, false, 调用点);
}

inline 方法节点类* 创建子首节点_(
    方法类& 方法集,
    方法节点类* 父节点,
    std::string_view 动作名,
    const 结构体_动作句柄& 动作句柄,
    枚举_方法沉淀来源 来源 = 枚举_方法沉淀来源::组合,
    const std::string& 调用点 = "四域方法树注册模块_v0_内部::创建子首节点_")
{
    if (!父节点) return nullptr;

    {
        锁调度器守卫 锁({
            锁请求::写(方法链.链表锁, 枚举_锁域::方法链, "方法链", 调用点)
            });

        if (auto* 已有 = 查找首个子节点_(父节点, [&](方法节点类* 节点) {
            auto* hmi = 取首信息_(节点);
            return hmi && 动作句柄相同_(hmi->动作句柄, 动作句柄);
            })) {
            return 已有;
        }

        // 结果节点后挂下一首，当前没有公开包装接口，这里直接复用现有方法链节点体系建最小骨架。
        auto* mi = new 方法首节点主信息类(动作词_(动作名), 动作句柄);
        mi->来源 = 来源;
        auto* 节点 = static_cast<方法节点类*>(方法链.添加子节点_已加锁(
            父节点,
            static_cast<方法信息基类*>(mi)));
        if (节点) {
            方法集.初始化方法虚拟存在信息(节点, 0, 调用点 + "/初始化方法虚拟存在");
        }
        return 节点;
    }
}

struct 结构_域树注册配置 {
    std::string 根动作名;
    枚举_本能动作ID 根本能ID = 枚举_本能动作ID::未定义;
    std::string 条件模板主键;
    std::string 下一首动作名;
    std::string 下一首动作序列主键;
};

inline 方法节点类* 注册域方法树根_(
    方法类& 方法集,
    const 结构_域树注册配置& 配置,
    const std::string& 调用点)
{
    auto* 根节点 = 方法集.注册方法首节点(
        动作词_(配置.根动作名),
        本能句柄_(配置.根本能ID),
        枚举_方法沉淀来源::组合,
        {},
        调用点 + "/注册根首节点");
    if (!根节点) return nullptr;

    方法集.初始化方法虚拟存在信息(根节点, 0, 调用点 + "/根节点初始化");
    if (auto* 根信息 = 取首信息_(根节点)) {
        根信息->来源 = 枚举_方法沉淀来源::组合;
    }

    auto* 条件节点 = 方法集.创建条件节点(
        根节点,
        {},
        配置.条件模板主键,
        0,
        0,
        调用点 + "/创建默认条件");
    if (!条件节点 || !取条件信息_(条件节点)) return 根节点;

    auto* 结果节点 = 取或创建结果节点_(
        方法集,
        条件节点,
        调用点 + "/创建默认结果");
    if (!结果节点 || !取结果信息_(结果节点)) return 根节点;

    (void)创建子首节点_(
        方法集,
        结果节点,
        配置.下一首动作名,
        组合句柄_(配置.下一首动作序列主键),
        枚举_方法沉淀来源::组合,
        调用点 + "/创建下一首");
    return 根节点;
}

} // namespace 四域方法树注册模块_v0_内部

export class 四域方法树注册器_v0
{
public:
    explicit 四域方法树注册器_v0(方法类& 方法集引用)
        : 方法集(方法集引用)
    {
    }

    方法节点类* 获取筹办方法树根()
    {
        if (!筹办方法树根) {
            筹办方法树根 = 注册筹办方法树根();
        }
        return 筹办方法树根;
    }

    方法节点类* 获取维护方法树根()
    {
        if (!维护方法树根) {
            维护方法树根 = 注册维护方法树根();
        }
        return 维护方法树根;
    }

    方法节点类* 获取纠偏方法树根()
    {
        if (!纠偏方法树根) {
            纠偏方法树根 = 注册纠偏方法树根();
        }
        return 纠偏方法树根;
    }

    方法节点类* 获取收束方法树根()
    {
        if (!收束方法树根) {
            收束方法树根 = 注册收束方法树根();
        }
        return 收束方法树根;
    }

    bool 注册全部四域方法树()
    {
        return 获取筹办方法树根()
            && 获取维护方法树根()
            && 获取纠偏方法树根()
            && 获取收束方法树根();
    }

private:
    方法节点类* 注册筹办方法树根()
    {
        using namespace 四域方法树注册模块_v0_内部;
        const 结构_域树注册配置 配置{
            .根动作名 = "四域_筹办_入口",
            .根本能ID = 枚举_本能动作ID::管理_筹办器,
            .条件模板主键 = "四域方法树/筹办/默认条件",
            .下一首动作名 = "四域_筹办_默认续接",
            .下一首动作序列主键 = "四域方法树/筹办/默认续接"
        };
        return 注册域方法树根_(方法集, 配置, "四域方法树注册器_v0::注册筹办方法树根");
    }

    方法节点类* 注册维护方法树根()
    {
        using namespace 四域方法树注册模块_v0_内部;
        const 结构_域树注册配置 配置{
            .根动作名 = "四域_维护_入口",
            .根本能ID = 枚举_本能动作ID::管理_门控器,
            .条件模板主键 = "四域方法树/维护/默认条件",
            .下一首动作名 = "四域_维护_默认续接",
            .下一首动作序列主键 = "四域方法树/维护/默认续接"
        };
        return 注册域方法树根_(方法集, 配置, "四域方法树注册器_v0::注册维护方法树根");
    }

    方法节点类* 注册纠偏方法树根()
    {
        using namespace 四域方法树注册模块_v0_内部;
        const 结构_域树注册配置 配置{
            .根动作名 = "四域_纠偏_入口",
            .根本能ID = 枚举_本能动作ID::管理_失败策略器,
            .条件模板主键 = "四域方法树/纠偏/默认条件",
            .下一首动作名 = "四域_纠偏_默认续接",
            .下一首动作序列主键 = "四域方法树/纠偏/默认续接"
        };
        return 注册域方法树根_(方法集, 配置, "四域方法树注册器_v0::注册纠偏方法树根");
    }

    方法节点类* 注册收束方法树根()
    {
        using namespace 四域方法树注册模块_v0_内部;
        const 结构_域树注册配置 配置{
            .根动作名 = "四域_收束_入口",
            .根本能ID = 枚举_本能动作ID::管理_复盘器,
            .条件模板主键 = "四域方法树/收束/默认条件",
            .下一首动作名 = "四域_收束_默认续接",
            .下一首动作序列主键 = "四域方法树/收束/默认续接"
        };
        return 注册域方法树根_(方法集, 配置, "四域方法树注册器_v0::注册收束方法树根");
    }

private:
    方法类& 方法集;
    方法节点类* 筹办方法树根 = nullptr;
    方法节点类* 维护方法树根 = nullptr;
    方法节点类* 纠偏方法树根 = nullptr;
    方法节点类* 收束方法树根 = nullptr;
};
