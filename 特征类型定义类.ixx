    static inline const 词性节点类* 类型_方法_幂等性 = nullptr;                // I64 0/1
    static inline const 词性节点类* 类型_方法_确定性_Q10000 = nullptr;         // I64 0~10000
    static inline const 词性节点类* 类型_方法_风险分_Q10000 = nullptr;         // I64 0~10000
    static inline const 词性节点类* 类型_方法_安全阻断次数 = nullptr;          // I64
    static inline const 词性节点类* 类型_方法_外部调用次数累计 = nullptr;      // I64

    // ---- 方法首节点（Entry） ----
    static inline const 词性节点类* 类型_首节点_触发求值次数 = nullptr;        // I64
    static inline const 词性节点类* 类型_首节点_触发通过次数 = nullptr;        // I64
    static inline const 词性节点类* 类型_首节点_触发拒绝次数 = nullptr;        // I64
    static inline const 词性节点类* 类型_首节点_触发通过率_Q10000 = nullptr;   // I64 0~10000

    static inline const 词性节点类* 类型_首节点_输入绑定失败次数 = nullptr;    // I64
    static inline const 词性节点类* 类型_首节点_平均触发判定耗时_ms_EMA = nullptr; // I64
    static inline const 词性节点类* 类型_首节点_最近触发时间_UTCms = nullptr;  // I64

    static inline const 词性节点类* 类型_首节点_输入缺失率_Q10000 = nullptr;   // I64 0~10000
    static inline const 词性节点类* 类型_首节点_上下文漂移_Q10000 = nullptr;   // I64 0~10000

    // ---- 条件（Condition） ----
    static inline const 词性节点类* 类型_条件_求值次数 = nullptr;              // I64
    static inline const 词性节点类* 类型_条件_true次数 = nullptr;             // I64
    static inline const 词性节点类* 类型_条件_false次数 = nullptr;            // I64
    static inline const 词性节点类* 类型_条件_true率_Q10000 = nullptr;         // I64 0~10000

