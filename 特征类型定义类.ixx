    static inline const 词性节点类* 类型_任务_优先级 = nullptr;                // I64
    static inline const 词性节点类* 类型_任务_截止时间_UTCms = nullptr;        // I64
    static inline const 词性节点类* 类型_任务_进度_Q10000 = nullptr;           // I64 0~10000
    static inline const 词性节点类* 类型_任务_依赖未满足数 = nullptr;          // I64

    static inline const 词性节点类* 类型_任务_允许重试次数 = nullptr;          // I64
    static inline const 词性节点类* 类型_任务_已重试次数 = nullptr;            // I64
    static inline const 词性节点类* 类型_任务_最近调度时间_UTCms = nullptr;    // I64
    static inline const 词性节点类* 类型_任务_调度次数 = nullptr;              // I64

    static inline const 词性节点类* 类型_任务_预估成本 = nullptr;              // I64
    static inline const 词性节点类* 类型_任务_实际成本累计 = nullptr;          // I64
    static inline const 词性节点类* 类型_任务_预估收益_Q10000 = nullptr;       // I64 0~10000
    static inline const 词性节点类* 类型_任务_实际收益_Q10000 = nullptr;       // I64 0~10000
    static inline const 词性节点类* 类型_任务_风险预算_Q10000 = nullptr;       // I64 0~10000
    static inline const 词性节点类* 类型_任务_阻断次数 = nullptr;              // I64

    // ---- 方法（Method） ----
    static inline const 词性节点类* 类型_方法_被考虑次数 = nullptr;            // I64
    static inline const 词性节点类* 类型_方法_被选中次数 = nullptr;            // I64
    static inline const 词性节点类* 类型_方法_被排除次数 = nullptr;            // I64
