        if (!类型_结果_平均风险_Q10000_EMA)   类型_结果_平均风险_Q10000_EMA = 语素集.添加词性词("结果_平均风险_Q10000_EMA", "名词");
        if (!类型_结果_回滚次数)              类型_结果_回滚次数 = 语素集.添加词性词("结果_回滚次数", "名词");

        // -------------------- 常用名称/类型 --------------------
        if (!名_自我)         名_自我 = 语素集.添加词性词("自我", "专有名词");
        if (!型_自我)         型_自我 = 语素集.添加词性词("自我类型", "名词");

        if (!名_摄像机)       名_摄像机 = 语素集.添加词性词("摄像机", "专有名词");
        if (!型_外设摄像机)   型_外设摄像机 = 语素集.添加词性词("外设", "名词");

        if (!名_自我内部世界) 名_自我内部世界 = 语素集.添加词性词("自我内部世界", "专有名词");

        // 输入观测包
        if (!类型_时间戳_us) 类型_时间戳_us = 语素集.添加词性词("特征_时间戳_us", "名词");
        if (!类型_深度帧句柄) 类型_深度帧句柄 = 语素集.添加词性词("特征_深度帧句柄", "名词");
        if (!类型_相机内参) 类型_相机内参 = 语素集.添加词性词("特征_相机内参", "名词");
        if (!类型_深度尺度) 类型_深度尺度 = 语素集.添加词性词("特征_深度尺度_scale", "名词");

        // 输出候选
        if (!类型_候选_相对位置) 类型_候选_相对位置 = 语素集.添加词性词("特征_候选存在_相对位置", "名词");
        if (!类型_候选_尺寸) 类型_候选_尺寸 = 语素集.添加词性词("特征_候选存在_尺寸", "名词");
        if (!类型_候选_签名) 类型_候选_签名 = 语素集.添加词性词("特征_候选存在_签名", "名词");
        if (!类型_候选_置信) 类型_候选_置信 = 语素集.添加词性词("特征_候选存在_置信_Q10000", "名词");

        // 场景名
        if (!名称_场景_存在集) 名称_场景_存在集 = 语素集.添加词性词("场景_存在集", "名词");
        if (!名称_场景_存在候选) 名称_场景_存在候选 = 语素集.添加词性词("场景_存在候选", "名词");
    }

    // 供外部调用：确保语素集初始化后再初始化本模块。
    static inline void 初始化特征类型定义模块_依赖语素() {
        std::call_once(g_once, 初始化_实现);
    }

    static inline void 注册默认特征策略(特征比较策略表& 表) {
        初始化特征类型定义模块_依赖语素();

     

        // 轮廓：默认0.8允许 h=80bit -> K=5*h=400
        表.注册(类型_轮廓编码, { 枚举_特征值类型::VecIU64, 枚举_比较模式::海明距离, 6, 1, 0, 400 });

        // 轮廓记忆：与轮廓编码同策略（海明距离）
        表.注册(类型_轮廓编码_记忆, { 枚举_特征值类型::VecIU64, 枚举_比较模式::海明距离, 6, 1, 0, 400 });
        表.注册(类型_轮廓编码_记忆_并集, { 枚举_特征值类型::VecIU64, 枚举_比较模式::海明距离, 6, 1, 0, 450 });
     
        // 体素：默认0.8允许 h=120bit -> K=600
        表.注册(类型_三维模型_体素立方体, { 枚举_特征值类型::VecIU64, 枚举_比较模式::海明距离, 6, 1, 0, 600 });
      
    }
};



