    static inline const 词性节点类* 类型_自我_尝试学习状态 = nullptr; // I64

    // ---- 摄像机：运行态（示例，供自我内部世界子存在使用）----
    static inline const 词性节点类* 类型_相机_连接状态 = nullptr;    // I64
