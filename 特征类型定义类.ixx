    static inline const 词性节点类* 类型_节点_最近修改时间_UTCms = nullptr;   // I64
    static inline const 词性节点类* 类型_节点_启用 = nullptr;                 // I64 0/1
    static inline const 词性节点类* 类型_节点_冻结截止时间_UTCms = nullptr;   // I64
