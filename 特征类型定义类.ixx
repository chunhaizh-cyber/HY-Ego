    static inline const 词性节点类* 类型_节点_最近失败时间_UTCms = nullptr;   // I64

    // ---- 节点通用：成本/性能 ----
    static inline const 词性节点类* 类型_节点_最近耗时_ms = nullptr;           // I64
    static inline const 词性节点类* 类型_节点_平均耗时_ms_EMA = nullptr;       // I64
    static inline const 词性节点类* 类型_节点_平均成本_EMA = nullptr;          // I64

    // ---- 节点通用：质量/路由 ----
    static inline const 词性节点类* 类型_节点_质量分_Q10000 = nullptr;         // I64 0~10000
    static inline const 词性节点类* 类型_节点_置信度_Q10000 = nullptr;         // I64 0~10000
    static inline const 词性节点类* 类型_节点_信任度_Q10000 = nullptr;         // I64 0~10000
