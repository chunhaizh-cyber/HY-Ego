module;
#include <mutex>

export module 特征类型定义模块;


import 特征比较策略模块;
import 主信息定义模块;
import 语素环境模块;

export class 特征类型定义类 {
public:
    // ==================== 外设底座特征（必须注册） ====================
    // 这些类型是“基础中的基础”，用于索引/匹配/稳态维护。
    // 其它更抽象的名词特征类型不需要在这里注册。

    // 位置（mm）
    static inline const 词性节点类* 类型_绝对位置 = nullptr; // VecI64 [x,y,z]
    static inline const 词性节点类* 类型_相对位置 = nullptr; // VecI64 [x,y,z]
    static inline const 词性节点类* 类型_主方向 = nullptr;

    // 尺寸（mm）
    static inline const 词性节点类* 类型_尺寸 = nullptr;     // VecI64 [w,h,d]

    // 2D 轮廓编码（blocks，VecIU64）；写入时会在特征值类内部一次性生成金字塔并分层索引。
    static inline const 词性节点类* 类型_轮廓编码 = nullptr; // VecIU64 (2D blocks)

    // 2D 轮廓记忆（多帧累积的“记忆版”轮廓编码）
    static inline const 词性节点类* 类型_轮廓编码_记忆 = nullptr;      // VecIU64（稳态）
    static inline const 词性节点类* 类型_轮廓编码_记忆_并集 = nullptr; // VecIU64（并集）
    static inline const 词性节点类* 类型_轮廓记忆元信息 = nullptr;     // VecI64 [N]

    // 3D 体素立方体（blocks，VecIU64）；同上，写入时一次性生成金字塔并分层索引。
    static inline const 词性节点类* 类型_三维模型_体素立方体 = nullptr; // VecIU64 (3D blocks)
    static inline const 词性节点类* 类型_三维模型颜色 = nullptr;

    static inline const 词性节点类* 类型_部件键 = nullptr;

    // ==================== 自我/外设运行态特征（不强制注册策略） ====================
    // 说明：
    // - 这些特征主要用于“状态维护/调度/日志”，通常不参与空间匹配，因此默认不在策略表里注册。
    // - 若未来要把它们纳入“相似度匹配/稳态维护”，再在 注册默认特征策略() 里补策略即可。

    // ---- 自我：安全/服务值（0 ~ int64max）----
    static inline const 词性节点类* 类型_自我_安全值 = nullptr;   // I64
    static inline const 词性节点类* 类型_自我_服务值 = nullptr;   // I64
    static inline const 词性节点类* 类型_自我_物理安全 = nullptr; // I64
    static inline const 词性节点类* 类型_自我_风险安全 = nullptr; // I64

    // ---- 自我：情绪（内部态）----
    static inline const 词性节点类* 类型_自我_情绪ID = nullptr;     // I64 (枚举/编号)
    static inline const 词性节点类* 类型_自我_情绪强度 = nullptr;   // I64 (0~1000)

    // ---- 自我：情绪（外显态）----
    static inline const 词性节点类* 类型_自我_外显情绪ID = nullptr;   // I64
