    static inline const 词性节点类* 类型_条件_最近求值时间_UTCms = nullptr;    // I64

    static inline const 词性节点类* 类型_条件_阈值_Q10000 = nullptr;           // I64 0~10000
    static inline const 词性节点类* 类型_条件_阈值调整次数 = nullptr;          // I64
    static inline const 词性节点类* 类型_条件_灰区次数 = nullptr;              // I64

    static inline const 词性节点类* 类型_条件_FP次数 = nullptr;                // I64
    static inline const 词性节点类* 类型_条件_FN次数 = nullptr;                // I64

    // ---- 结果（Result） ----
    static inline const 词性节点类* 类型_结果_产出次数 = nullptr;              // I64
    static inline const 词性节点类* 类型_结果_被采纳次数 = nullptr;            // I64
    static inline const 词性节点类* 类型_结果_被拒绝次数 = nullptr;            // I64
    static inline const 词性节点类* 类型_结果_采纳率_Q10000 = nullptr;         // I64 0~10000

    static inline const 词性节点类* 类型_结果_平均生成耗时_ms_EMA = nullptr;   // I64
    static inline const 词性节点类* 类型_结果_最近产出时间_UTCms = nullptr;    // I64

    static inline const 词性节点类* 类型_结果_验证通过次数 = nullptr;          // I64
    static inline const 词性节点类* 类型_结果_验证失败次数 = nullptr;          // I64
    static inline const 词性节点类* 类型_结果_验证通过率_Q10000 = nullptr;     // I64 0~10000

    static inline const 词性节点类* 类型_结果_平均收益_Q10000_EMA = nullptr;   // I64 0~10000
    static inline const 词性节点类* 类型_结果_平均风险_Q10000_EMA = nullptr;   // I64 0~10000
    static inline const 词性节点类* 类型_结果_回滚次数 = nullptr;              // I64

    // ==================== 常用“名称/类型”词性（非特征类型，但在工程里经常复用） ====================
        // 用途：
        // - 避免业务模块到处调用 语素集.添加词性词() 造成“词性指针散落 + 初始化顺序风险”
    static inline const 词性节点类* 名_自我 = nullptr;
    static inline const 词性节点类* 型_自我 = nullptr;

    static inline const 词性节点类* 名_摄像机 = nullptr;
    static inline const 词性节点类* 型_外设摄像机 = nullptr;

    static inline const 词性节点类* 名_自我内部世界 = nullptr;

    // ============ 观测包必需特征类型 ============
     static inline const 词性节点类* 类型_时间戳_us = nullptr;
     static inline const 词性节点类* 类型_深度帧句柄 = nullptr;
     static inline const 词性节点类* 类型_相机内参 = nullptr;
     static inline const 词性节点类* 类型_深度尺度 = nullptr;

    // ============ 输出：存在候选的特征类型（挂在“候选子场景”上） ============
     static inline const 词性节点类* 类型_候选_相对位置 = nullptr; // VecI64{ x,y,z } mm
     static inline const 词性节点类* 类型_候选_尺寸 = nullptr; // VecI64{ dx,dy,dz } mm
     static inline const 词性节点类* 类型_候选_签名 = nullptr; // VecIU64
     static inline const 词性节点类* 类型_候选_置信 = nullptr; // I64(Q10000)

    // 场景命名（词性节点）
      static inline const 词性节点类* 名称_场景_存在集 = nullptr;
      static inline const 词性节点类* 名称_场景_存在候选 = nullptr;


    // ==================== 初始化（在语素集初始化之后调用） ====================
    // 本模块只声明“词性指针”，不在静态初始化阶段触发 语素集.添加词性词()，
    // 以避免“特征类型定义模块先于语素集初始化”导致的初始化顺序问题。

    static inline std::once_flag g_once;
    static inline void 初始化_实现()
    {
        // -------------------- 外设底座特征 --------------------
        if (!类型_绝对位置) 类型_绝对位置 = 语素集.添加词性词("绝对位置", "名词");
        if (!类型_相对位置) 类型_相对位置 = 语素集.添加词性词("相对位置", "名词");
        if (!类型_尺寸)     类型_尺寸 = 语素集.添加词性词("尺寸", "名词");
        if (!类型_轮廓编码) 类型_轮廓编码 = 语素集.添加词性词("轮廓编码", "名词");
        if (!类型_三维模型_体素立方体) 类型_三维模型_体素立方体 = 语素集.添加词性词("三维模型_体素立方体", "名词");
        if (!类型_三维模型颜色)       类型_三维模型颜色 = 语素集.添加词性词("三维模型颜色", "名词");
        if (!类型_主方向)             类型_主方向 = 语素集.添加词性词("主方向", "名词");
        if (!类型_部件键)             类型_部件键 = 语素集.添加词性词("部件键", "名词");

        if (!类型_轮廓编码_记忆)      类型_轮廓编码_记忆 = 语素集.添加词性词("轮廓编码_记忆", "名词");
        if (!类型_轮廓编码_记忆_并集) 类型_轮廓编码_记忆_并集 = 语素集.添加词性词("轮廓编码_记忆_并集", "名词");
        if (!类型_轮廓记忆元信息)     类型_轮廓记忆元信息 = 语素集.添加词性词("轮廓记忆元信息", "名词");

        // -------------------- 自我 --------------------
        if (!类型_自我_安全值)       类型_自我_安全值 = 语素集.添加词性词("安全值", "名词");
        if (!类型_自我_服务值)       类型_自我_服务值 = 语素集.添加词性词("服务值", "名词");
        if (!类型_自我_物理安全)     类型_自我_物理安全 = 语素集.添加词性词("物理安全", "名词");
        if (!类型_自我_风险安全)     类型_自我_风险安全 = 语素集.添加词性词("风险安全", "名词");
        if (!类型_自我_情绪ID)       类型_自我_情绪ID = 语素集.添加词性词("情绪ID", "名词");
