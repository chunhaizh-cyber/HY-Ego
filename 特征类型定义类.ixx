    static inline const 词性节点类* 类型_评估_比较正确率_Q10000 = nullptr;   // I64 0~10000
    static inline const 词性节点类* 类型_评估_否定正确率_Q10000 = nullptr;   // I64 0~10000
    static inline const 词性节点类* 类型_评估_程度正确率_Q10000 = nullptr;   // I64 0~10000



    // ==================== 任务/方法/节点统计特征（用于调度/诊断，不参与默认空间匹配） ====================
    // 说明：
    // - 这些特征用于 任务/方法/条件/结果 等节点的运行态统计
