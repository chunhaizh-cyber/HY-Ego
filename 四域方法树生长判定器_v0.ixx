module;

#include <cstdint>
#include <string>

export module 四域方法树生长判定器_v0;

import 基础数据类型模块;
import 主信息定义模块;

namespace 四域方法树生长判定器_v0_内部 {

inline 方法信息基类* 取方法信息_(方法节点类* 方法首节点) noexcept
{
    return 方法首节点 && 方法首节点->主信息
        ? dynamic_cast<方法信息基类*>(方法首节点->主信息)
        : nullptr;
}

inline 方法首节点主信息类* 取首信息_(方法节点类* 方法首节点) noexcept
{
    return 方法首节点 && 方法首节点->主信息
        ? dynamic_cast<方法首节点主信息类*>(方法首节点->主信息)
        : nullptr;
}

inline int 来源等级_(枚举_方法沉淀来源 来源) noexcept
{
    switch (来源) {
    case 枚举_方法沉淀来源::运行期临时:
        return 1;
    case 枚举_方法沉淀来源::本能:
        return 2;
    case 枚举_方法沉淀来源::反推:
        return 3;
    case 枚举_方法沉淀来源::组合:
        return 4;
    case 枚举_方法沉淀来源::外部导入:
        return 5;
    default:
        return 0;
    }
}

} // namespace 四域方法树生长判定器_v0_内部

export struct 结构_四域方法树生长判定结果_v0
{
    bool 达到候选枝阈值 = false;
    bool 达到正式组合枝阈值 = false;
    枚举_方法沉淀来源 建议来源 = 枚举_方法沉淀来源::未定义;
    std::string 原因说明{};
};

export class 四域方法树生长判定器_v0
{
public:
    static constexpr std::int32_t 候选枝稳定阈值 = 3;
    static constexpr std::int32_t 正式组合枝稳定阈值 = 5;

    bool 记录运行结果(
        方法节点类* 方法首节点,
        bool 结果稳定出现,
        时间戳 now = 0,
        const std::string& 调用点 = "四域方法树生长判定器_v0::记录运行结果") const
    {
        (void)调用点;

        auto* 方法信息 = 四域方法树生长判定器_v0_内部::取方法信息_(方法首节点);
        if (!方法信息) {
            return false;
        }

        if (now <= 0) {
            now = 结构体_时间戳::当前_微秒();
        }

        auto& 评估 = 方法信息->评估原始量;
        ++评估.节点_运行次数;
        ++评估.节点_样本数;
    评估.节点_最后运行时间_微秒 = static_cast<I64>(now);
        if (结果稳定出现) {
            ++评估.节点_成功次数;
            ++评估.节点_连续成功次数;
            评估.节点_连续失败次数 = 0;
    评估.节点_最后成功时间_微秒 = static_cast<I64>(now);
        }
        else {
            ++评估.节点_失败次数;
            ++评估.节点_连续失败次数;
            评估.节点_连续成功次数 = 0;
    评估.节点_最后失败时间_微秒 = static_cast<I64>(now);
        }
        return true;
    }

    结构_四域方法树生长判定结果_v0 判定(方法节点类* 方法首节点) const
    {
        auto* 方法信息 = 四域方法树生长判定器_v0_内部::取方法信息_(方法首节点);
        if (!方法信息) {
            return {};
        }

        const auto& 评估 = 方法信息->评估原始量;
        结构_四域方法树生长判定结果_v0 返回{};

        if (评估.节点_成功次数 >= 正式组合枝稳定阈值
            && 评估.节点_连续失败次数 == 0
            && 评估.节点_成功次数 >= 评估.节点_失败次数) {
            返回.达到候选枝阈值 = true;
            返回.达到正式组合枝阈值 = true;
            返回.建议来源 = 枚举_方法沉淀来源::组合;
            返回.原因说明 = "已达到正式组合枝稳定阈值";
            return 返回;
        }

        if (评估.节点_成功次数 >= 候选枝稳定阈值
            && 评估.节点_成功次数 >= 评估.节点_失败次数) {
            返回.达到候选枝阈值 = true;
            返回.建议来源 = 枚举_方法沉淀来源::反推;
            返回.原因说明 = "已达到候选枝稳定阈值";
            return 返回;
        }

        返回.原因说明 = "稳定复现次数不足，保留原来源";
        return 返回;
    }

    bool 应用升级(
        方法节点类* 方法首节点,
        const 结构_四域方法树生长判定结果_v0& 判定结果,
        const std::string& 调用点 = "四域方法树生长判定器_v0::应用升级") const
    {
        (void)调用点;

        auto* 首信息 = 四域方法树生长判定器_v0_内部::取首信息_(方法首节点);
        if (!首信息 || 判定结果.建议来源 == 枚举_方法沉淀来源::未定义) {
            return false;
        }

        if (四域方法树生长判定器_v0_内部::来源等级_(判定结果.建议来源)
            <= 四域方法树生长判定器_v0_内部::来源等级_(首信息->来源)) {
            return false;
        }

        首信息->来源 = 判定结果.建议来源;
        return true;
    }
};
